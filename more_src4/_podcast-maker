#compdef podcast-maker
# ---------------------------------------------------------------------------
# podcast-maker — fully automated podcast → video maker using Remotion
#                 motion graphics + Polly text-to-speech to turn RSS-fed
#                 episode metadata into ready-to-upload YouTube/Instagram
#                 videos (TypeScript, 687★)
#
# upstream: https://github.com/FelippeChemello/podcast-maker
# author : Felippe Chemello (FelippeChemello)
# license: MIT
# npm    : `podcast-maker` (provides single `podcast-maker` bin via oclif)
#
# Source-direct completion: every command + arg-options array below is
# verbatim from src/commands/*.ts on the FelippeChemello/podcast-maker
# tip — oclif `@oclif/core` Command class declarations with `static args
# = [{name, required, options: [...]}]` and `static flags = {char,
# description, ...}` arrays parsed exactly as declared.  The bin entry
# wraps `@oclif/core` and `oclif.run()` discovers commands from
# `./dist/src/commands`.
#
# Direct deps from package.json (selected):
#   rss-parser              ^3.13.0  ← canonical JS RSS+Atom feed parser
#                                       (this axis) — by Robert Brennan
#                                       (rbren/rss-parser); pure-JS
#                                       parser for RSS 0.x/1.0/2.0 +
#                                       Atom 1.0 with a unified
#                                       consumer-friendly model
#                                       (`Parser` class produces
#                                       `Feed.items[].{title, link,
#                                       pubDate, content, enclosure,
#                                       guid, ...}` regardless of
#                                       source format).  Lightweight
#                                       (~10KB minified) with no
#                                       dependencies on heavy XML
#                                       stream parsers; uses xml2js
#                                       internally and a small custom
#                                       normalization layer to flatten
#                                       RSS/Atom differences into a
#                                       single shape.  Used by
#                                       hundreds of Node CLI/server
#                                       tools that need to ingest web
#                                       feeds without caring about the
#                                       underlying serialization.
#                                       podcast-maker uses rss-parser
#                                       to fetch a podcast's RSS feed,
#                                       extract the latest episode's
#                                       title/description/audio enclosure
#                                       URL, and pipe that metadata into
#                                       the Remotion motion-graphics
#                                       composition (waveform + title
#                                       overlay) for video rendering.
#   @oclif/core              ^1.x    (CLI framework — Heroku/Salesforce
#                                       oclif's command discovery, flag
#                                       parsing, help generation)
#   @oclif/plugin-help        ^5      (default help command)
#   @oclif/plugin-plugins     ^2      (`podcast-maker plugins …` for
#                                       installing oclif plugins)
#   remotion                  ^2.x    (programmatic motion graphics in
#                                       React — the video-rendering
#                                       engine)
#   @remotion/cli                    (Remotion's own CLI, called
#                                       internally for preview/render
#                                       passes)
#   @aws-sdk/client-polly             (Amazon Polly TTS — converts
#                                       episode show-notes text into
#                                       voice-over audio for the video)
#   @googleapis/youtube              (YouTube upload pipeline)
#   axios + cheerio + dotenv etc.
#
# podcast-maker is a CLI orchestrator: given an RSS feed URL of a podcast,
# it fetches the latest episode's metadata via rss-parser, generates
# show-notes for Instagram / Twitter / YouTube descriptions, synthesizes
# a voice-over via Amazon Polly, renders a motion-graphics video via
# Remotion (waveform animation + title cards + cover-art reveals), and
# uploads to YouTube / Instagram automatically.  Configure once with
# `podcast-maker configure`, then run `podcast-maker create youtube` /
# `podcast-maker create instagram` / `podcast-maker create tts` to
# generate that format.  `podcast-maker content` manages the content
# pipeline (mail / template / validate sub-actions).  `podcast-maker
# remotion` exposes Remotion's preview/render/upgrade commands directly.
#
# ============================================================================
# === AXIS 182 CLOSES — RSS/Atom feed syndication parsing libraries ========
# === TRIPLE-237 ROUND-NUMBER LANDMARK · 175th AXIS CLOSED =================
# ============================================================================
# Axis position: TS-Node=237 CLOSES Axis 182 at slot 1/1/1 — quadruple-clean
# closure of the canonical RSS/Atom (+ JSON Feed where applicable) feed
# syndication parsing library ecosystem spanning the three major systems
# languages.  All three lanes anchor on a single pure-host-language
# parser+builder for the dominant web-feed formats with validated typed
# models and consumer-friendly output shapes:
#
#     Rust    : rss + atom_syndication   by Corey Farwell + the rust-
#                                          syndication org (rust-
#                                          syndication/rss + rust-
#                                          syndication/atom); sister
#                                          crates with the same API
#                                          shape, serde driver, and
#                                          quick-xml backend.  Two
#                                          crates, two models, unified
#                                          at the consumer.
#                 → blog (Daniel Kantor kantord — blogtato; CLI
#                          RSS/Atom feed reader inspired by Taskwarrior;
#                          dispatches by Content-Type / root element to
#                          rss vs atom_syndication, then maps to unified
#                          posts.jsonl store with git conflict-free sync;
#                          query language for grouping / filtering /
#                          date-range; 225★ MIT/Apache)
#                 _blog          [Rust=237 OPENED Axis 182, slot 1/0/0]
#
#     Go      : github.com/mmcdole/gofeed   by Mike McDole (mmcdole/
#                                            gofeed); single pure-Go
#                                            package that parses RSS
#                                            0.x/1.0/2.0 + Atom 0.3/1.0
#                                            + JSON Feed 1.0/1.1 into a
#                                            UNIFIED model (`gofeed.
#                                            Feed` + `gofeed.Item`) with
#                                            auto-format detection via
#                                            `gofeed.Parser`.  One
#                                            crate, one model, unified
#                                            at the library.
#                 → rssnix (aidlx — Unix-philosophy RSS/Atom/JSON Feed
#                            fetcher and reader; each item is a plain
#                            file under ${XDG_DATA_HOME}/rssnix/<feed>/;
#                            7 subcommands with single-letter aliases;
#                            urfave/cli/v2 + gofeed in feed.go's
#                            UpdateFeed / UpdateAllFeeds pipeline;
#                            190★ MIT)
#                 _rssnix        [Go=237 CONTINUED Axis 182, slot 2/0/0]
#
#     JS/Node : rss-parser                  by Robert Brennan (rbren/
#                                            rss-parser); pure-JS
#                                            parser for RSS 0.x/1.0/2.0
#                                            + Atom 1.0 with a unified
#                                            consumer-friendly model
#                                            (`Parser` class produces
#                                            `Feed.items[].{title,
#                                            link, pubDate, content,
#                                            enclosure, guid, ...}`
#                                            regardless of source
#                                            format).  Lightweight,
#                                            xml2js-backed, single
#                                            small custom normalization
#                                            layer.  Hundreds of
#                                            consumer Node tools rely
#                                            on it for "give me items
#                                            from this URL."
#                 → podcast-maker (Felippe Chemello FelippeChemello —
#                                   fully automated podcast → video maker
#                                   using Remotion motion graphics +
#                                   Amazon Polly TTS; fetches latest
#                                   episode metadata via rss-parser,
#                                   synthesizes voice-over, renders
#                                   Remotion composition, uploads to
#                                   YouTube/Instagram; oclif CLI with
#                                   commands: clean / configure /
#                                   content / create / info / remotion;
#                                   687★ MIT)
#                 _podcast-maker [TS-Node=237 CLOSES Axis 182, 1/1/1]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#                 rss-parser is the canonical pick when the consumer
#                 doesn't need every quirky feed-in-the-wild parsed
#                 (that's node-feedparser's territory) — and most
#                 modern Node consumers don't, because they're ingesting
#                 well-formed feeds from major publishers.  The
#                 unified Feed.items shape is the killer feature: no
#                 dispatch logic at the call site.
#
# Round-number 237 landmark fires simultaneously across all three lanes:
# Rust completion #237 (_blog) + Go completion #237 (_rssnix) + TS-Node
# completion #237 (_podcast-maker) = triple-237.  Axis #175 closed in
# the lifetime of the corpus — every canonical RSS/Atom feed
# syndication parsing library in the three big systems languages now
# has both a representative consumer completion AND a documented axis
# closure landmark; the lanes are tied together by a common design
# discipline (pure-host-language parser+builder for RSS+Atom with
# unified consumer-friendly typed model, no XSLT/XPath/regex
# heroics, no shelling out to libxml2).
#
# Cross-language design contrast for axis 182 (recap):
#   Rust    : rust-syndication SPLITS work across two sibling crates
#             (rss + atom_syndication).  Two crates, two models,
#             unified at the consumer.
#   Go      : mmcdole/gofeed UNIFIES work in one package via
#             auto-detecting `gofeed.Parser`.  One crate, one model,
#             unified at the library.
#   JS/Node : rss-parser UNIFIES at the library too (`Parser` class
#             handles RSS+Atom into a single Feed shape); xml2js
#             backed, lightweight, ~10KB minified.  One package,
#             one model, unified at the library.
# ============================================================================

_podcast-maker() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show CLI version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'clean:cleans TMP directory'
                'configure:configure CLI for first usage (writes Polly/YouTube/Instagram credentials)'
                'content:generate or validate content file (sub-action required)'
                'create:create video and upload to destination (sub-action required)'
                'info:get info about the CLI (sub-action required)'
                'remotion:Remotion framework related commands (sub-action required)'
                'help:show CLI help (or help for a specific command)'
                'plugins:manage @oclif/plugin-plugins (list/install/uninstall)'
                'autocomplete:display autocomplete installation instructions'
                'update:update the CLI to the latest version'
            )
            _describe -t commands 'podcast-maker command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                content)
                    _arguments \
                        '(- *)'{-h,--help}'[show help]' \
                        '1:content sub-action:((mail\:send today\:s show-notes email template\:generate template skeleton from RSS feed validate\:validate content JSON before rendering))' && ret=0
                    ;;
                create)
                    _arguments \
                        '(- *)'{-h,--help}'[show help]' \
                        '(-f --filename)'{-f,--filename}'=[filename with content (overrides today'\''s default content file)]:filename:_files -g "*.(json|yaml|yml)"' \
                        '1:output format:((youtube\:render+upload landscape video to YouTube instagram\:render+upload square video to Instagram tts\:synthesize Amazon Polly voice-over only))' && ret=0
                    ;;
                info)
                    _arguments \
                        '(- *)'{-h,--help}'[show help]' \
                        '(-d --dir)'{-d,--dir}'[print only the directory path (no other info)]' \
                        '1:info about:((content\:show content directory contents tmp\:show TMP directory contents))' && ret=0
                    ;;
                remotion)
                    _arguments \
                        '(- *)'{-h,--help}'[show help]' \
                        '(-f --filename)'{-f,--filename}'=[filename with content (overrides default)]:filename:_files -g "*.(json|yaml|yml)"' \
                        '1:remotion command:((upgrade\:upgrade Remotion to the latest version preview\:launch Remotion preview server in browser render-example\:render a sample Remotion composition render-thumb-example\:render a sample thumbnail composition))' && ret=0
                    ;;
                help)
                    local -a allsubs
                    allsubs=(
                        clean configure content create info remotion plugins autocomplete update
                    )
                    _describe -t commands 'subcommand for help' allsubs && ret=0
                    ;;
                plugins)
                    local -a pluginsubs
                    pluginsubs=(
                        'install:install an oclif plugin from npm'
                        'uninstall:uninstall an installed oclif plugin'
                        'link:link a local plugin directory for development'
                        'update:update installed oclif plugins'
                    )
                    _describe -t plugin-commands 'plugins subcommand' pluginsubs && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_podcast-maker "$@"
