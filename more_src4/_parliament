# Zsh completion for parliament - AWS IAM linting

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--version[show version]' \
  '--aws-managed-policies=[AWS managed policies directory]:dir:_directories' \
  '--auth-details-file=[file from aws iam get-account-authorization-details]:file:_files' \
  '--string=[IAM policy as a string]:policy string:' \
  '--file=[IAM policy file]:file:_files' \
  '--files=[IAM policy file pattern]:pattern:' \
  '--directory=[directory of IAM policy files]:directory:_directories' \
  '--include_policy_extension=[Python file extending policy class]:file:_files' \
  '--exclude_pattern=[regex to exclude file names]:pattern:' \
  '--minimal[only show findings, no other info]' \
  '--json[output in JSON format]' \
  '--minimum_severity=[minimum severity to report]:severity:(MUTE INFO LOW MEDIUM HIGH CRITICAL)' \
  '--private_auditors=[directory of private auditors]:directory:_directories' \
  '--config=[config file]:config:_files -g "*.{yml,yaml,json}"' \
  '--include-community-auditors[include community auditors]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  && ret=0

return ret
