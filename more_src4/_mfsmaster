#compdef mfsmaster
# Documentation: https://manpages.debian.org/bookworm/moosefs-master/mfsmaster.8.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mfsmaster: MooseFS master server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-v[print version and exit]' \
  '(- *)-h[print usage and exit]' \
  '-c[alternative config file]:file:_files -g "*.cfg"' \
  '-u[log undefined config values]' \
  '-f[foreground, do not daemonize]' \
  '-t[lockfile timeout (seconds)]:seconds:' \
  '-i[ignore some metadata structure errors]' \
  '-a[restore metadata from change logs]' \
  '-e[start without metadata (pro version)]' \
  '-x[verbose output]' \
  '*:action:(start stop restart reload test restore kill)' && ret=0
return ret
