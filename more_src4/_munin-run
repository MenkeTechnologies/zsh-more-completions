#compdef munin-run
# Documentation: https://manpages.debian.org/trixie/munin-node/munin-run.1p.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# munin-run: run a Munin node plugin (debug helper)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--config=[Munin node config file]:file:_files' \
  '--servicedir=[plugin directory]:dir:_files -/' \
  '--sconfdir=[plugin config directory]:dir:_files -/' \
  '--sconffile=[plugin config file]:file:_files' \
  '--paranoia[only run root-owned plugins with safe perms]' \
  '--ignore-systemd-properties[ignore systemd-supplied props]' \
  '--debug[print debug messages]' \
  '--pidebug[plugin debug (sets MUNIN_DEBUG=1)]' \
  '*:plugin name:_files' && ret=0
return ret
