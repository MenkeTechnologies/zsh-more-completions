#compdef pnmnoraw
# Documentation: man pnmnoraw (Netpbm, replaced by pamtopnm -plain)
# Source: legacy alias — convert PNM to plain (ASCII) PNM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
