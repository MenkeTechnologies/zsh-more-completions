#compdef ocp-indent
# Documentation: https://github.com/OCamlPro/ocp-indent/blob/master/src/ocp-indent/indentArgs.ml
# Reference accessed: 2026-05-19
# Verified: upstream Cmdliner option definitions in indentArgs.ml.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help=-[show help]::format:(auto pager groff plain)' \
  '(- *)--version[show version]' \
  '(-c --config)'{-c+,--config=}'[configuration parameters]:config:' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(-i --inplace)'{-i,--inplace}'[re-indent files in-place]' \
  '--indent-empty[indent empty lines]' \
  '(-l --lines)'{-l+,--lines=}'[only indent specified line range]:range:' \
  '--numeric[output numeric indentation values]' \
  '(-o --output)'{-o+,--output=}'[output to file]:output file:_files' \
  '--print-config[print current parameters and exit]' \
  '*--syntax=[syntax extension to use]:syntax:' \
  '*--load-pkgs=[load plugins]:pkg:' \
  '*--load-mods=[load plugins]:mod:' \
  '*:file:_files' && ret=0

return ret
