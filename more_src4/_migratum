#
#  Clingon distinctive features:
#    - INSPIRED BY clap (Rust) and cobra (Go) ‚Äî modern subcommand-first
#      design with typed options, env-var fallbacks, structured
#      commands
#    - `clingon:make-command :name "X" :description "..." :options
#      (list ...) :sub-commands (list ...) :handler #'fn :pre-hook
#      #'fn :authors '(...) :license "..." :version "..."` ‚Äî KEYWORD-
#      ARG COMMAND CONSTRUCTOR
#    - NESTED SUBCOMMANDS via `:sub-commands (list ...)` ‚Äî RECURSIVE
#      structure of commands containing commands
#    - `clingon:make-option :TYPE :short-name #\c :long-name "name"
#      :description "..." :initial-value V :env-vars '("VAR")
#      :key :KEYWORD` ‚Äî KEYWORD-ARG OPTION CONSTRUCTOR
#    - RICH TYPE SYSTEM: `:string`, `:integer`, `:flag` (boolean),
#      `:enum` (with `:items '(("name" . :value))`), `:list/string`,
#      `:list/integer`, `:filepath`, `:list/filepath`, `:choice`,
#      `:counter` (incrementable count flag like `-vvv`), `:switch`,
#      `:option`, `:boolean/true`, `:boolean/false`
#    - ENV-VAR FALLBACKS via `:env-vars '("VAR1" "VAR2")` ‚Äî checked in
#      order, first non-empty value used as fallback when CLI flag
#      not provided
#    - OPTION CATEGORIES via `:category "..."` ‚Äî groups options in
#      `--help` output (e.g. "DBI driver options" vs "RDBMS-PGSQL
#      driver options")
#    - SHORT NAMES via Common Lisp CHARACTER LITERAL `#\h` (CL char
#      syntax ‚Äî distinguishes from other Common Lisp libs that use
#      strings)
#    - LONG NAMES via plain string `"long-name"` (no leading dashes
#      in spec ‚Äî Clingon adds `--` at parse time)
#    - KEY via Common Lisp KEYWORD `:key :keyword-name` ‚Äî looked up
#      later via `clingon:getopt cmd :keyword-name`
#    - HANDLER via `:handler #'function-reference` ‚Äî Common Lisp
#      function-quote for handler callback
#    - PRE-HOOK via `:pre-hook #'function-reference` ‚Äî runs before
#      handler
#    - POST-HOOK via `:post-hook #'function-reference` ‚Äî runs after
#      handler
#    - `clingon:run command argv` ‚Äî entry point; runs full pipeline
#      (parse ‚Üí pre-hook ‚Üí handler ‚Üí post-hook)
#    - `clingon:getopt cmd :key` ‚Äî fetch parsed option value by key
#    - `clingon:command-arguments cmd` ‚Äî remaining positional args
#    - `clingon:print-usage-and-exit cmd t` ‚Äî for top-level handler
#      when no subcommand specified
#    - AUTO-GENERATED `--help`/`-h` per command
#    - AUTO-GENERATED `--version` for top-level command
#    - AUTO-GENERATED Zsh/Bash/Fish completion scripts via Clingon's
#      `zsh-completions` command pattern (see `cl-migratum`'s own
#      `zsh-completions` subcommand which generates the completion
#      from the command spec itself)
#  Distinct from R285 Common Lisp cl-cli (older imperative style),
#  R286 Common Lisp unix-opts (POSIX getopt-style with `define-opts`
#  macro), R351 Common Lisp sjl/adopt (REVERSED imperative model
#  with `make-option`/`make-context`), R275 Rust clap-derive (Rust
#  struct + macros ‚Äî INSPIRATION but different language), R357 Go
#  mitchellh/cli (Go Cmd interface), R334 Go alecthomas/kong (Go
#  struct tags), R343 commander.js (JS fluent builder).  Clingon's
#  approach: COBRA/CLAP-INSPIRED design with `clingon:make-command`
#  + `clingon:make-option` KEYWORD-ARG CONSTRUCTORS + RICH TYPE
#  SYSTEM (:string/:integer/:flag/:enum/:list-X/:filepath/etc.) +
#  ENV-VAR FALLBACKS via `:env-vars` + OPTION CATEGORIES via
#  `:category` + KEY-BASED LOOKUP via `clingon:getopt cmd :keyword`
#  + RECURSIVE NESTED SUBCOMMANDS + PRE-HOOK/POST-HOOK callbacks +
#  AUTO-GENERATED --help/--version/COMPLETION ‚Äî corpus's **first
#  documented clap-inspired-with-keyword-arg-constructors Common
#  Lisp CLI library**.  Brings cross-language CLI library taxonomy
#  variant count to 119; Common Lisp ecosystem now has 4 documented
#  CLI libraries ‚Äî joining Crystal (4) at the fourth-most-documented
#  tier behind Rust/Go (9) and Python (6).
#
#  Surface (verbatim from `src/cli/main.lisp` + per-subcommand
#  `src/cli/{migrate,pending,applied,create,status,reset,revert,
#  print-doc,zsh-completions}.lisp` files):
#
#  Global options:
#    -l, --log-level LEVEL          Log level: off | info | debug
#                                   (default: info; env MIGRATUM_LOG_LEVEL)
#    -d, --driver DRIVER            Migration driver: dbi | rdbms-pgsql
#                                   (env MIGRATUM_DRIVER)
#    -p, --provider PROVIDER        Migration resource provider:
#                                   local-path (env MIGRATUM_PROVIDER)
#
#  Provider options (local-path provider):
#    --resources PATH               Migration resources path
#                                   (multi-value list/filepath;
#                                   env MIGRATUM_LP_RESOURCES)
#
#  DBI driver options:
#    --dbi-db-kind KIND             DB kind: sqlite3 | postgres | mysql
#                                   (env MIGRATUM_DBI_DB_KIND)
#    --dbi-db-host HOST             DB host (default localhost;
#                                   env MIGRATUM_DBI_DB_HOST)
#    --dbi-db-name NAME             DB name (env MIGRATUM_DBI_DB_NAME)
#    --dbi-db-user USER             DB user (env MIGRATUM_DBI_USER)
#    --dbi-db-pass PASS             DB password
#                                   (env MIGRATUM_DBI_DB_PASSWORD)
#    --dbi-db-port PORT             DB port (env MIGRATUM_DBI_DB_PORT)
#
#  RDBMS-PGSQL driver options:
#    --rdbms-pgsql-db-host HOST     PG host (env PGHOST; default localhost)
#    --rdbms-pgsql-db-name NAME     PG database name (env PGDATABASE)
#    --rdbms-pgsql-db-user USER     PG user (env PGUSER)
#    --rdbms-pgsql-db-pass PASS     PG password (env PGPASSWORD)
#    --rdbms-pgsql-db-port PORT     PG port (env PGPORT)
#
#  Subcommands:
#    applied                        Show applied migrations
#    create                         Create a new migration
#    migrate                        Apply pending migrations
#    pending                        Show pending migrations
#    print-doc                      Print documentation for migrations
#    reset                          Reset all migrations (revert all)
#    revert                         Revert the latest migration
#    status                         Show current migration status
#    zsh-completions                Generate Zsh completion script
#                                   (auto-generated from command spec!)
#
#  Auto-generated by Clingon:
#    --help, -h                     Show help (per command)
#    --version                      Show migratum version
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also Clingon-based):
#    - ocicl (ocicl/ocicl 296 stars ‚Äî uses Clingon in templates for
#      scaffolding, but ocicl's own main CLI uses hand-rolled
#      parse-args; FUTURE candidate if ocicl migrates to Clingon
#      internally)
#    - screenshotbot-oss (300 stars ‚Äî uses Clingon for cluster
#      leadership subcommands; large project, FUTURE candidate)
#    - shop3 (shop-planner/shop3 165 stars ‚Äî HTN planner, narrow AI
#      planning use case; FUTURE academic-targeted round)
#    - rlgl-server / red-light-green-light (Anthony Green 49 stars ‚Äî
#      smaller community)
#    - icl (Anthony Green's icl 176 stars ‚Äî interactive Common Lisp
#      REPL, niche)
#    - lisp-chat / lunanode-cli / portofino-cli-lisp / cl-qob /
#      kiln / hack-cl (all CLEAR but smaller user bases)
# ============================================================================

_migratum() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '(-l --log-level)'{-l,--log-level}'=[log level]:level:(off info debug)' \
    '(-d --driver)'{-d,--driver}'=[migration driver]:driver:(dbi rdbms-pgsql)' \
    '(-p --provider)'{-p,--provider}'=[migration resource provider]:provider:(local-path)' \
    '*--resources=[migration resources path]:path:_files' \
    '--dbi-db-kind=[DBI database kind]:kind:(sqlite3 postgres mysql)' \
    '--dbi-db-host=[DBI database host]:host:_hosts' \
    '--dbi-db-name=[DBI database name]:name' \
    '--dbi-db-user=[DBI database user]:user:_users' \
    '--dbi-db-pass=[DBI database password]:password' \
    '--dbi-db-port=[DBI database port]:port' \
    '--rdbms-pgsql-db-host=[PostgreSQL host]:host:_hosts' \
    '--rdbms-pgsql-db-name=[PostgreSQL database name]:name' \
    '--rdbms-pgsql-db-user=[PostgreSQL user]:user:_users' \
    '--rdbms-pgsql-db-pass=[PostgreSQL password]:password' \
    '--rdbms-pgsql-db-port=[PostgreSQL port]:port' \
    '(-h --help)'{-h,--help}'[show help]' \
    '--version[show version]' \
    '1: :->cmd' \
    '*:: :->subargs'

  case $state in
    cmd)
      local -a verbs=(
        'applied:show applied migrations'
        'create:create a new migration'
        'migrate:apply pending migrations'
        'pending:show pending migrations'
        'print-doc:print documentation for migrations'
        'reset:reset all migrations (revert all)'
        'revert:revert the latest migration'
        'status:show current migration status'
        'zsh-completions:generate Zsh completion script'
      )
      _describe -t commands 'migratum subcommand' verbs
      ;;
    subargs)
      case $line[1] in
        create)
          _arguments \
            '(-d --description)'{-d,--description}'=[migration description]:description' \
            '(-h --help)'{-h,--help}'[show help]'
          ;;
        *)
          _arguments '(-h --help)'{-h,--help}'[show help]'
          ;;
      esac
      ;;
  esac
}

_migratum "$@"
