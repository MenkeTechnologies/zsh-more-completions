#compdef neosync
# Documentation: https://docs.neosync.dev/cli/introduction
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_neosync_commands() {
  local -a commands=(
    'accounts:manage accounts'
    'connections:manage connections'
    'jobs:manage jobs'
    'login:authenticate with Neosync'
    'logout:log out of Neosync'
    'sync:synchronize data'
    'version:print version'
    'whoami:display current user info'
  )
  _describe -t commands 'neosync command' commands
}

_arguments -s -S \
  '--api-key=[API key]:key' \
  '--config=[config file]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:_neosync_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      sync)
        _arguments -s -S \
          '--api-key=[Neosync API key]:key' \
          '--config=[yaml config file]:file:_files' \
          '--connection-id=[source connection ID]:id' \
          '--job-id=[Neosync job ID]:id' \
          '--job-run-id=[Neosync job run ID]:id' \
          '--output=[output type]:type:(auto plain tty)' \
          '--debug[set log level to debug]' \
          '--destination-connection-url=[destination connection URL]:url' \
          '--destination-driver=[destination driver]:driver:(postgres mysql)' \
          '--truncate-before-insert[truncate table before insert]' \
          '--truncate-cascade[cascade truncation (postgres)]' \
          '--init-schema[create table schema and constraints]' \
          '--on-conflict-do-nothing[skip conflicting rows]' \
          '--destination-idle-duration=[max idle conn time]:duration' \
          '--destination-idle-limit=[max idle connections]:n' \
          '--destination-open-duration=[max open conn time]:duration' \
          '--destination-open-limit=[max open connections]:n' \
          '--destination-max-in-flight=[max batched rows]:n' \
          '--destination-batch-count=[batch size]:n' \
          '--destination-batch-period=[batch interval]:duration' \
          '--aws-access-key-id=[AWS access key]:key' \
          '--aws-secret-access-key=[AWS secret]:secret' \
          '--aws-session-token=[AWS session token]:token' \
          '--aws-role-arn=[AWS role ARN]:arn' \
          '--aws-role-external-id=[AWS role external ID]:id' \
          '--aws-profile=[AWS profile]:profile' \
          '--aws-endpoint=[AWS endpoint URL]:url' \
          '--aws-region=[AWS region]:region' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac
return ret
