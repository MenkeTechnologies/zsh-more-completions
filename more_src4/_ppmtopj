#compdef ppmtopj
# Documentation: man ppmtopj (Netpbm)
# Source: convert a PPM image to HP PaintJet printer commands.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-gamma+[gamma correction]:val:' \
    '-xpos+[x-axis offset]:val:' \
    '-ypos+[y-axis offset]:val:' \
    '-back+[background brightness]:back:(dark lite)' \
    '-rle[run-length-encode output]' \
    '-center[centre image on page]' \
    '-render+[dither rendering method]:method:(none snap bw dither diffuse monodither monodiffuse clusterdither monoclusterdither)' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
