#compdef mangohud-cli
# _mangohud-cli — flightlessmango MangoHud Vulkan/OpenGL overlay for monitoring FPS/temperature CLI alias (flightlessmango team, C++); custom argparse
# upstream: https://github.com/flightlessmango/MangoHud

_mangohud-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--dlsym[force dlsym hook]' \
        '-d[force dlsym hook]' \
        '--config-file=+[config file]:file:_files -g "MangoHud.conf"' \
        '-c+[config file]:file:_files -g "MangoHud.conf"' \
        '--no-display[no display]' \
        '--read-cfg=+[cfg name]:str:' \
        '--preset=+[preset name]:str:' \
        '--upload-log[upload log]' \
        '--upload-log-async[upload log async]' \
        '--toggle-hud[toggle hud]' \
        '--toggle-fps-limit[toggle fps limit]' \
        '--toggle-logging[toggle logging]' \
        '--reload-cfg[reload config]' \
        '--unset-vulkan-icd[unset vulkan icd]' \
        '--graphs=+[graphs csv]:str:' \
        '--fps-limit=+[fps]:n:' \
        '--vsync=+[mode]:m:(0 1 2 3)' \
        '--gl-vsync=+[mode]:n:' \
        '--log-duration=+[seconds]:n:' \
        '--log-interval=+[ms]:n:' \
        '--autostart-log=+[seconds]:n:' \
        '--output-folder=+[dir]:dir:_files -/' \
        '--position=+[position]:p:(top-left top-right middle-left middle-right bottom-left bottom-right top-center bottom-center)' \
        '--font-size=+[size]:n:' \
        '--font-size-text=+[size]:n:' \
        '--text-color=+[hex]:str:' \
        '--gpu-color=+[hex]:str:' \
        '--cpu-color=+[hex]:str:' \
        '--vram-color=+[hex]:str:' \
        '--ram-color=+[hex]:str:' \
        '--io-color=+[hex]:str:' \
        '--engine-color=+[hex]:str:' \
        '--background-color=+[hex]:str:' \
        '--frametime-color=+[hex]:str:' \
        '--background-alpha=+[0.0-1.0]:str:' \
        '--alpha=+[0.0-1.0]:str:' \
        '--blacklist=+[apps csv]:str:' \
        '--no-secrets[no secrets]' \
        '--no-display-toggle[no display toggle]' \
        '*:program args:_files'
}

_mangohud-cli "$@"
