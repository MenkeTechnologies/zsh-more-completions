#compdef pvfs2-ls
# Documentation: https://www.mankier.com/1/pvfs2-ls
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pvfs2-ls: list PVFS2 directory
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-a --all)'{-a,--all}'[do not hide entries starting with .]' \
  '(-A --almost-all)'{-A,--almost-all}'[do not list . and ..]' \
  '(-d --directory)'{-d,--directory}'[list directory entries, not contents]' \
  '-l[long listing]' \
  '-g[long listing, omit owner]' \
  '-o[long listing, omit group]' \
  '(-n --numeric-uid-gid)'{-n,--numeric-uid-gid}'[numeric uid/gid]' \
  '(-G --no-group)'{-G,--no-group}'[do not display group info]' \
  '(-h --human-readable)'{-h,--human-readable}'[human readable sizes]' \
  '(-i --inode)'{-i,--inode}'[print inode number]' \
  '--help[show help]' \
  '--version[show version]' \
  '*:path:_files' && ret=0
return ret
