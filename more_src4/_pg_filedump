#compdef pg_filedump
# Documentation: https://github.com/df7cb/pg_filedump
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-a[show absolute addresses]' \
  '-b[binary block images in range]' \
  '-d[formatted block content dump only]' \
  '-D+[decode tuples using type list]:types:' \
  '-f[formatted dump with interpretation]' \
  '-i[interpreted item details]' \
  '-k[verify block checksums]' \
  '-o[exclude old values from output]' \
  '-R+[display specific block range]:start[-end]:' \
  '-s+[segment size]:size:' \
  '-n+[segment number]:number:' \
  '-S+[force block size]:bytes:' \
  '-t[dump TOAST files]' \
  '-v[verbose TOAST relation info]' \
  '-x[force index item formatting]' \
  '-y[force heap item formatting]' \
  '-c[interpret as control file]' \
  '-m[interpret as pg_filenode.map]' \
  '*:file:_files' && ret=0

return ret
