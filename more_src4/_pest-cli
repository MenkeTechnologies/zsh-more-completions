#compdef pest-cli
# _pest-cli — Nuno Maduro Pest PHP testing framework CLI alias (pestphp team, PHP); built on phpunit
# upstream: https://github.com/pestphp/pest

_pest-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--init[initialize pest]' \
        '--migrate[migrate from phpunit]' \
        '--no-color[no color]' \
        '--colors=+[colors]:c:(auto never always)' \
        '--bail[bail on first failure]' \
        '--parallel[parallel mode]' \
        '--processes=+[number of processes]:n:' \
        '--profile[profile slowest tests]' \
        '--coverage[show coverage]' \
        '--coverage-clover=+[file]:file:_files' \
        '--coverage-cobertura=+[file]:file:_files' \
        '--coverage-html=+[dir]:dir:_files -/' \
        '--coverage-text=+[file]:file:_files' \
        '--coverage-xml=+[dir]:dir:_files -/' \
        '--min=+[min coverage pct]:n:' \
        '--type-coverage[type coverage]' \
        '--mutate[mutation testing]' \
        '--mutate-class=+[class]:str:' \
        '--mutate-everything[mutate everything]' \
        '--watch[watch mode]' \
        '--watch-paths=+[paths]:str:' \
        '--filter=+[filter pattern]:str:' \
        '--testdox[testdox output]' \
        '--retry[retry failed]' \
        '--ci[CI mode]' \
        '--dirty[only dirty files]' \
        '--todos[list todos]' \
        '--snapshot[snapshot mode]' \
        '--update-snapshots[update snapshots]' \
        '-u[update snapshots]' \
        '--group=+[group]:str:' \
        '--exclude-group=+[group]:str:' \
        '--filter-method=+[method]:str:' \
        '--testsuite=+[suite]:str:' \
        '--configuration=+[config file]:file:_files -g "*.xml"' \
        '-c+[config file]:file:_files -g "*.xml"' \
        '--bootstrap=+[bootstrap]:file:_files' \
        '--stop-on-failure[stop on failure]' \
        '--stop-on-error[stop on error]' \
        '--stop-on-warning[stop on warning]' \
        '--stop-on-risky[stop on risky]' \
        '--stop-on-skipped[stop on skipped]' \
        '--stop-on-incomplete[stop on incomplete]' \
        '--stop-on-defect[stop on defect]' \
        '--debug[debug]' \
        '--printer=+[printer class]:str:' \
        '--no-output[no output]' \
        '--memory-limit=+[limit]:str:' \
        '--compact[compact output]' \
        '*:test file:_files'
}

_pest-cli "$@"
