#compdef pambrighten ppmbrighten
# Documentation: man pambrighten (Netpbm)
# Source: adjust saturation and value (HSV brightness) of a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-saturation=[saturation percent (+/-NN)]:percent:' \
    '-value=[value percent (+/-NN)]:percent:' \
    '-normalize[normalize first (ppmbrighten compat)]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:netpbm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
