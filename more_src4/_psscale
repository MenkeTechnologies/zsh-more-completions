#compdef psscale
# Documentation: https://docs.generic-mapping-tools.org/latest/colorbar.html
# Source: GenericMappingTools/gmt classic-mode psscale — plot a colour scale (color bar) for a CPT.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-B+[annotation/tick/grid interval]:basemap:_default' \
    '-C+[CPT to display]:cpt:_files -g "*.cpt(-.)"' \
    '-D+[position + dimensions of scale bar]:opts:_default' \
    '-F+[rectangular border styling]:opts:_default' \
    '-G+[truncate CPT to z-range]:opts:_default' \
    '-I+[illumination intensity]:opts:_default' \
    '-J+[projection]:proj:_default' \
    '-L+[equal-sized color rectangles]:opts:_default' \
    '-M[monochrome (YIQ transform)]' \
    '-N+[color encoding (rect vs image)]:opts:_default' \
    '-Q[logarithmic (base-10 annotations)]' \
    '-R+[region west/east/south/north]:region:_default' \
    '-S+[appearance when -B absent]:opts:_default' \
    '-W+[scale all CPT z-values by factor]:factor:_default' \
    '-X+[X offset of plot origin]:offset:_default' \
    '-Y+[Y offset of plot origin]:offset:_default' \
    '-Z+[custom bar widths per CPT entry]:file:_files' \
    '-K[multi-page: more pages follow]' \
    '-O[multi-page: this is overlay]' \
    '-P[portrait orientation]' \
    '*-V[verbose (stackable)]' \
    && ret=0

return ret
