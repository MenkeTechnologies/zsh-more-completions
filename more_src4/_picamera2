#compdef picamera2
# _picamera2 — Raspberry Pi Foundation picamera2 Python library CLI for the modern libcamera-based replacement of picamera supporting Bayer raw still capture video record live preview encoders metadata tuning AF (raspberrypi team, Python); argparse
# upstream: https://github.com/raspberrypi/picamera2

_picamera2() {
    local -a sub=(
        'capture:capture a still image'
        'record:record video'
        'preview:show live preview'
        'list-cameras:list cameras'
        'list-controls:list controls'
        'list-modes:list sensor modes'
        'metadata:print metadata'
        'tuning:print tuning'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--camera-num=+[index]:n:' \
        '-c+[index]:n:' \
        '--tuning-file=+[file]:file:_files -g "*.json"' \
        '--config-file=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'picamera2 subcommand' sub ;;
        args)
            case $words[1] in
                capture) _arguments \
                    '--width=+[N]:n:' \
                    '--height=+[N]:n:' \
                    '--format=+[f]:f:(jpg png bmp dng rgb yuv420 raw)' \
                    '--quality=+[N]:n:' \
                    '--exposure=+[us]:n:' \
                    '--gain=+[F]:f:' \
                    '--awb=+[mode]:m:(auto incandescent tungsten fluorescent indoor daylight cloudy)' \
                    '--metering=+[mode]:m:(centre spot matrix)' \
                    '--ev=+[F]:f:' \
                    '--saturation=+[F]:f:' \
                    '--sharpness=+[F]:f:' \
                    '--contrast=+[F]:f:' \
                    '--brightness=+[F]:f:' \
                    '--rotation=+[deg]:n:(0 90 180 270)' \
                    '--hflip[horizontal flip]' \
                    '--vflip[vertical flip]' \
                    '-o+[output file]:file:_files' ;;
                record) _arguments \
                    '--width=+[N]:n:' \
                    '--height=+[N]:n:' \
                    '--framerate=+[F]:f:' \
                    '--bitrate=+[bps]:n:' \
                    '--duration=+[s]:f:' \
                    '--codec=+[c]:c:(h264 mjpeg)' \
                    '-o+[output file]:file:_files' ;;
                list-controls|list-modes|metadata|tuning) _arguments \
                    '--camera-num=+[index]:n:' ;;
            esac
            ;;
    esac
}

_picamera2 "$@"
