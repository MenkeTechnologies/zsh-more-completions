#compdef opendkim-testmsg
# Documentation: https://manpages.debian.org/bookworm/opendkim-tools/opendkim-testmsg.8.en.html
# Reference accessed: 2026-05-20
# Verified: opendkim-testmsg(8) - single-letter options only.
# Removed: fabricated --help/--version/--debug long forms and bogus
# -D/--domain flag (real flag is -d). Added: -C, -K, -t per manpage.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-C[terminate generated signature header with CRLF instead of LF]' \
  '-d+[signing domain]:domain:' \
  '-K[keep temporary files generated during canonicalization]' \
  '-k+[private key file]:file:_files' \
  '-s+[selector to include in signature]:selector:' \
  '-t+[temp files directory (default /tmp)]:dir:_files -/' \
  '*:file:_files' && ret=0

return ret
