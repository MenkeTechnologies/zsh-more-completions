#compdef ppmtoxpm
# Documentation: man ppmtoxpm (Netpbm)
# Source: convert a PPM image to X Pixmap (XPM3) format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-name=[XPM symbol name]:xpmname:' \
    '-hexonly[use hex color codes only]' \
    '-rgb=[rgb.txt-style color name file]:file:_files' \
    '-alphamask=[alpha-mask PGM file]:file:_files -g "*.(pgm|pnm|pam)"' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
