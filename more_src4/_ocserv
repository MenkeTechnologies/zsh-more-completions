#compdef ocserv
# Documentation: https://ocserv.gitlab.io/www/manual.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-f --foreground)'{-f,--foreground}'[no fork]' \
  '(-d --debug)'{-d+,--debug=}'[debug level 0-9999]:n:' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
  '(-t --test-config)'{-t,--test-config}'[test config and exit]' \
  '(-p --pid-file)'{-p+,--pid-file=}'[PID file]:file:_files' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]'
