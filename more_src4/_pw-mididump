#compdef pw-mididump
# Documentation: https://docs.pipewire.org/page_man_pw-mididump_1.html
# Source: PipeWire — human-readable MIDI event dumper.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-r --remote)'{-r+,--remote=}'[remote instance name]:name:' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '*:MIDI file (optional):_files' \
    && ret=0

return ret
