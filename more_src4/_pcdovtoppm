#compdef pcdovtoppm
# Documentation: man pcdovtoppm (Netpbm)
# Source: render a Kodak PhotoCD overview file as a contact-sheet PPM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-maxwidth+[output image max width]:width:' \
    '-size+[thumbnail size]:size:' \
    '-across+[thumbnails per row]:across:' \
    '-colors+[color count]:colors:' \
    '-font+[BDF font]:font:_files' \
    '(-black -white)-black[black background]' \
    '(-black -white)-white[white background]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pcd overview file:_files' \
    && ret=0

return ret
