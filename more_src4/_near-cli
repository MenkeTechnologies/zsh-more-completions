#compdef near-cli
# Documentation: https://github.com/near/near-cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# near-cli (JS, archived 2024-10-04) - flat command structure. The README
# recommends migrating to near-cli-rs (`_near`).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'login:store a full access key locally using NEAR Wallet'
  'create-account:create a new account'
  'delete-account:delete an account'
  'state:show account details'
  'send-near:send NEAR tokens'
  'add-credentials:store credentials for an account'
  'add-key:add an access key to an account'
  'delete-key:delete an access key from an account'
  'generate-key:generate a key pair'
  'list-keys:list access keys for an account'
  'call:schedule a function call'
  'view:view a contract function'
  'deploy:deploy a smart contract'
  'storage:view account storage details'
  'tx-status:lookup transaction status by hash'
  'repl:launch a REPL session connected to NEAR'
  'validators:view current validators'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '--networkId=[NEAR network]:network:(mainnet testnet betanet localnet)' \
  '--nodeUrl=[NEAR node URL]:url' \
  '--walletUrl=[NEAR wallet URL]:url' \
  '--helperUrl=[NEAR contract helper URL]:url' \
  '--keyPath=[path to access key file]:file:_files' \
  '--accountId=[account ID]:account' \
  '--useLedgerKey[sign with hardware wallet]' \
  '--seedPhrase=[seed phrase]:phrase' \
  '--seedPath=[HD path]:path' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'near-cli command' commands && ret=0
    ;;
esac

return ret
