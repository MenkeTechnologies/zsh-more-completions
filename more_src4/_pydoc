#compdef pydoc pydoc3
# Documentation: https://docs.python.org/3/library/pydoc.html
# Source: CPython Lib/pydoc.py — text/HTML docs server for Python modules.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-w -k -p -n -b)-w[write HTML documentation to a file in cwd]:module or path:' \
    '(-w -k -p -n -b)-k[search synopsis lines of all modules for keyword]:keyword:' \
    '(-w -k -p)-p[start HTTP docs server on specified port]:port:' \
    '(-w -k -p)-n[server hostname (default localhost)]:host:' \
    '(-w -k -p)-b[start server and open browser to module index]' \
    '*:module/path/identifier:' \
    && ret=0

return ret
