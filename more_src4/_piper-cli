#compdef piper-cli
# _piper-cli — libratbag Piper gaming mouse configurator CLI alias (libratbag team, Python); argparse
# upstream: https://github.com/libratbag/piper

_piper-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--list-devices[list devices]' \
        '--device=+[device path]:file:_files -g "/dev/hidraw* /sys/class/hidraw/*"' \
        '*:arg:'
}

_piper-cli "$@"
