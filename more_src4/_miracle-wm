#compdef miracle-wm
# _miracle-wm — Matthew Kosarek miracle-wm tiling Wayland compositor built on Mir (canonical team, C++); custom argparse
# upstream: https://github.com/mattkae/miracle-wm

_miracle-wm() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml"' \
        '-c+[config file]:file:_files -g "*.yaml *.yml"' \
        '--add-wayland-extensions=+[extensions]:str:' \
        '--add-wayland-extension=+[extension]:str:' \
        '--display-config=+[mode]:m:(clone sidebyside single)' \
        '--display-layout=+[file]:file:_files' \
        '--enable-x11[enable x11 support]' \
        '--no-enable-x11[disable x11 support]' \
        '--idle-timeout=+[seconds]:n:' \
        '--idle-timeout-when-locked=+[seconds]:n:' \
        '--cursor-theme=+[theme]:str:' \
        '--cursor-size=+[size]:n:' \
        '--font=+[font name]:str:' \
        '--keymap=+[xkb layout]:str:' \
        '--no-keymap[no keymap]' \
        '--socket=+[mir socket]:str:' \
        '--bypass[enable bypass]' \
        '--debug[debug mode]' \
        '--gamma[gamma correction]' \
        '--platform-input-lib=+[lib]:str:' \
        '--platform-graphics-lib=+[lib]:str:'
}

_miracle-wm "$@"
