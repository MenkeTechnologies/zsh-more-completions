#compdef mythffmpeg
# Documentation: https://ffmpeg.org/ffmpeg.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# mythffmpeg is the MythTV-bundled ffmpeg binary; it inherits the full
# ffmpeg(1) flag set, so the canonical ffmpeg docs are authoritative.

# mythffmpeg: MythTV-bundled ffmpeg (use ffmpeg flag set)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-?[show help]' \
  '--help[show help]' \
  '-version[show version]' \
  '-i+[input file]:file:_files' \
  '-y[overwrite output without asking]' \
  '-n[do not overwrite output]' \
  '-f+[force format]:format:' \
  '-c:v+[video codec]:codec:' \
  '-c:a+[audio codec]:codec:' \
  '-vcodec+[video codec]:codec:' \
  '-acodec+[audio codec]:codec:' \
  '-vn[disable video]' \
  '-an[disable audio]' \
  '-sn[disable subtitles]' \
  '-dn[disable data]' \
  '-b:v+[video bitrate]:bitrate:' \
  '-b:a+[audio bitrate]:bitrate:' \
  '-vf+[video filtergraph]:filter:' \
  '-af+[audio filtergraph]:filter:' \
  '-filter_complex+[complex filtergraph]:filter:' \
  '-map+[map stream]:stream:' \
  '-ss+[seek to position]:time:' \
  '-to+[stop at position]:time:' \
  '-t+[duration]:time:' \
  '-r+[frame rate]:fps:' \
  '-s+[frame size WxH]:size:' \
  '-aspect+[aspect ratio]:ratio:' \
  '-pix_fmt+[pixel format]:format:' \
  '-loglevel+[log level]:level:(quiet panic fatal error warning info verbose debug trace)' \
  '-v+[log level alias]:level:' \
  '-report[generate report]' \
  '-hide_banner[hide banner]' \
  '-stats[print stats]' \
  '-progress+[progress info to URL]:url:' \
  '-threads+[thread count]:n:' \
  '-codecs[list codecs]' \
  '-formats[list formats]' \
  '-filters[list filters]' \
  '-pix_fmts[list pixel formats]' \
  '-protocols[list protocols]' \
  '-encoders[list encoders]' \
  '-decoders[list decoders]' \
  '*:output file:_files' && ret=0
return ret
