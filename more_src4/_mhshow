#compdef mhshow
# Documentation: man mhshow(1)
# Source: nmh uip/mhshow.c (master) — display MIME messages (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-check -nocheck)-check[check MIME structure]' \
    '(-check -nocheck)-nocheck[no check]' \
    '(-verbose -noverbose)-verbose[verbose]' \
    '(-verbose -noverbose)-noverbose[no verbose]' \
    '(-concat -noconcat)-concat[concatenate parts]' \
    '(-concat -noconcat)-noconcat[no concat]' \
    '(-textonly -notextonly)-textonly[only show text parts]' \
    '(-textonly -notextonly)-notextonly[show all parts]' \
    '(-inlineonly -noinlineonly)-inlineonly[only inline-disposition parts]' \
    '(-inlineonly -noinlineonly)-noinlineonly[all parts]' \
    '-file+[message file]:file:_files' \
    '-form+[format file]:file:_files' \
    '-markform+[mark format file]:file:_files' \
    '*-part+[show part number]:N:_default' \
    '*-type+[content type filter]:type:_default' \
    '-rcache+[read cache policy]:policy:(public private never ask)' \
    '-wcache+[write cache policy]:policy:(public private never ask)' \
    '-version[show version]' \
    '-help[show help]' \
    '-moreproc+[pager program]:cmd:_command_names -e' \
    '-nomoreproc[no pager]' \
    '-length+[output length]:N:_default' \
    '1::+folder:_default' \
    '*::msgs:_default' \
    && ret=0

return ret
