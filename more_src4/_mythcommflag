#compdef mythcommflag
# Documentation: https://github.com/MythTV/mythtv/blob/master/mythtv/programs/mythcommflag/mythcommflag_commandlineparser.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mythcommflag: MythTV commercial flagging tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help,--usage}'[show help]' \
  '(- *)--version[show version]' \
  '(-j --jobid)'{-j,--jobid=}'[job ID]:id:' \
  '--chanid=[channel ID]:id:' \
  '--starttime=[start time]:time:' \
  '(-f --file)'{-f,--file=}'[file to flag]:file:_files' \
  '--video=[video gallery file]:file:_files' \
  '--gencutlist[copy commercial skip list to cutlist]' \
  '--clearcutlist[clear cutlist]' \
  '--clearskiplist[clear skip list]' \
  '--getcutlist[display current cutlist]' \
  '--getskiplist[display current skip list]' \
  '--setcutlist=[set cutlist #-#[,#-#]...]:list:' \
  '--rebuild[rebuild seektable instead of flagging]' \
  '--method=[commercial detection method]:method:' \
  '--outputmethod=[output method]:method:' \
  '--queue[queue job in JobQueue]' \
  '--noprogress[do not show progress]' \
  '--force[force flag]' \
  '--outputfile=[output file]:file:_files' \
  '--skipdb[external third-party use - skip DB writes]' \
  '--dontwritetodb[external third-party use - do not write to DB]' \
  '--onlydumpdb[only dump DB contents]' \
  '--dry-run[dry run]' \
  '(-v --verbose)'{-v,--verbose=}'[log filtering]:level:' \
  '--logpath=[log to file]:dir:_files -/' \
  '(-q --quiet)'{-q,--quiet}'[reduce logging]' \
  '--loglevel=[logging level]:level:(emerg alert crit err warning notice info debug trace)' \
  '--syslog=[syslog facility]:facility:' && ret=0
return ret
