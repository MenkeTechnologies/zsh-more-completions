# Reference accessed: 2026-05-31 via gh api.
#
# CLI surface (decoded from short_option +
# long_option + option_defaults + usage block):
#   -h / --help            show help
#   -v / --version         show version
#   -l / --local           use local documentation (implied by -i)
#   -n / --no-cache        load remote docs without caching
#   -b / --backup          use backup (mercury-in.space) URL
#   -i [INDEX]             load doc INDEX:
#                          lib / ref / user / prolog / faq
#   -g / --grep            search for substrings instead of tokens
#   -c / --comment         search for comment substrings
#   -t DECLARATION         restrict search to:
#                          type / pred / func / mode / inst / typeclass
#                          (maybe_string default — optional)
#       --list-modules     list standard library modules
#       --refresh-cache    download all stdlib library files if old
#
# Positional: <module> [<token>]
#
# mmc-doc is a Mercury documentation lookup tool —
# pulls up Mercury stdlib documentation by module
# name, searches stdlib modules for predicate/
# function declarations.  Authored by jrfondren (6
# GH stars).  Sister tools: mmc (Mercury compiler;
# in corpus as `_mmc`), the Mercury compiler
# itself which uses an internal getopt_io-based
# CLI for its hundreds of compiler flags.
#
# Critical extraction note: mmc-doc uses **Mercury
# stdlib `getopt_io` module** at mmcdoc.m:7 —
# corpus's **first documented Mercury CLI library**.
# Mercury's stdlib `getopt_io` is the IO-AWARE
# variant of `getopt` — handles option parsing
# with explicit I/O state threading.  Implementation
# at `library/getopt_io.m` in the Mercury source
# tree.  Distinct from R297 SWI-Prolog `optparse`
# (term-based specs, no IO threading), R270
# Haskell `optparse-applicative` (applicative-
# functor), R313 Idris 2 `System.GetOpts` (Haskell-
# port, list-of-MkOpt).  Mercury's approach uses
# Prolog-style FACT-PATTERNS for the option spec
# but adds STRONG STATIC TYPES and DETERMINISM
# annotations (`is semidet`/`is multi`).  Extends
# cross-language CLI taxonomy to FIFTY-THREE
# library variants: Rust (6), Go (4), Python (3),
# Crystal 1 OptionParser (R269), Haskell (R270),
# OCaml (R271), C (R272), Java (R276),
# Kotlin (R277), Scala (R278), Dart (R279),
# Ruby (R280), Perl (R281), PHP (R282),
# Swift (R283), F# (R284), Lua (R285), C# (R286),
# Nim 1 parseopt (R287), Zig (R288), D (R289),
# Racket (R290), Common Lisp 1 (R291),
# Erlang (R292), Tcl (R293), Pharo Smalltalk (R294),
# Common Lisp 2 clingon (R295), Julia (R296),
# SWI-Prolog optparse (R297), Pony stdlib cli (R298),
# Crystal 2 Admiral (R299), V stdlib `flag` (R300),
# Nim 2 cligen (R301), Clojure babashka.cli (R302),
# Gleam Glint (R303), Ada GNAT.Command_Line (R304),
# C++ CLI11 (R305), Elixir Optimus (R306), Vala
# GLib.OptionContext (R307), Hare stdlib getopt
# (R308), Standard ML stdlib GetOpt (R309),
# Fortran M_CLI2 (R310), Guile (ice-9 getopt-long)
# (R311), Free Pascal TCustomApplication (R312),
# Idris 2 System.GetOpts (R313), **Mercury stdlib
# getopt_io** (R314 — NEW).  **MAJOR PATTERN
# MILESTONE**: 53 cross-language CLI library
# variants documented.  Mercury joins the taxonomy
# as the SECOND logic-language CLI library after
# R297 SWI-Prolog optparse — corpus now documents
# CLI libraries in BOTH MAJOR LOGIC-PROGRAMMING
# DIALECTS.
#
# Critical extraction note: mmc-doc uses **Mercury
# Prolog-fact-as-option-spec CLI pattern** at
# mmcdoc.m:25-43 — `short_option('h', help).` and
# `long_option("help", help).` are Prolog-style
# FACTS pattern-matching the input char/string
# and binding the corresponding option ADT
# constructor.  Mercury's strong typing (`:- pred
# short_option(char::in, option::out) is semidet`)
# makes these facts TYPED — the compiler enforces
# char→option mapping.  Distinct from R297 SWI-
# Prolog `optparse` (term-based OptSpec list), R313
# Idris 2 `MkOpt ['h'] ["help"] ...` (positional
# constructor args), R270 Haskell `Option ['h']
# ["help"] ...` (ADT constructor).  Mercury's
# approach is UNIQUE: the option spec IS the
# PROLOG-FACT-DATABASE, queried by the parser.
# Corpus's **first documented Prolog-fact-as-
# option-spec CLI pattern**.
#
# Critical extraction note: mmc-doc uses **Mercury
# `option_data` typed-union default-value spec**
# at mmcdoc.m:45-56 — `option_defaults(help,
# bool(no)).` and `option_defaults(restrict,
# maybe_string(no)).` use the `option_data` TAGGED-
# UNION type with variants:
#   `bool(yes|no)`           ← boolean default
#   `int(N)`                 ← integer default
#   `string("...")`          ← string default
#   `maybe_string(yes("...") | no)` ← optional string
#   `accumulating([...])`    ← list-append default
# Distinct from R313 Idris 2 `NoArg ctor /
# ReqArg ctor "<plc>"` (constructor variant), R311
# Guile `(value #t/#f/optional)` (boolean-or-
# symbol), R309 SML `NoArg/ReqArg/OptArg`
# constructor variants (with thunks/constructors).
# Mercury's approach: TYPED-DEFAULT-AS-DISCRIMINATED-
# UNION — corpus's **first documented typed-union-
# default-value CLI pattern**.
#
# Critical extraction note: mmc-doc uses **Mercury
# `option_ops_multi(short_option, long_option,
# option_defaults)` predicates-as-first-class
# values** at mmcdoc.m:92 — Mercury constructs a
# CONFIG STRUCT carrying THREE PREDICATES as
# values.  `option_ops_multi/3` is the getopt_io
# constructor.  The predicates are passed BY NAME,
# not by inlining their data.  Distinct from R272
# C POSIX getopt (option-string), R305 C++ CLI11
# (struct + reference binding), R313 Idris 2
# `descs : List $ OptDescr Option` (data list with
# all info inline).  Mercury's approach: PREDICATES-
# AS-FIRST-CLASS-VALUES — the option spec is
# DEFERRED to runtime predicate queries.  Corpus's
# **first documented predicates-as-data CLI
# pattern**.
#
# Critical extraction note: mmc-doc uses **Mercury
# `!IO` destructive-update state-threading** at
# mmcdoc.m:93+ — `getopt_io.process_options_io(
# Config, RawArgs, Args, ResOpts, !IO)` uses
# Mercury's `!IO` SYNTACTIC SUGAR for I/O state
# threading.  `!IO` desugars to TWO arguments
# `IO0, IO` (input and output state) — Mercury
# enforces SINGLE-THREADED I/O at the type level
# via the `io::di` (destructive input) and
# `io::uo` (unique output) modes.  Distinct from
# R270 Haskell `IO` monad (also linear I/O), R311
# Guile (no I/O typing — side effects implicit),
# R272 C POSIX getopt (no I/O abstraction), R313
# Idris 2 `HasIO io => io ...` (effect-aware but
# similar to Haskell).  Mercury's approach:
# `!Var` STATE-PASS-THROUGH SUGAR — corpus's
# **first documented destructive-state-threading
# CLI parse pattern**.
#
# Critical extraction note: mmc-doc uses **Mercury
# `:- mode option_defaults(out, out) is multi`
# multi-mode declaration** at mmcdoc.m:46 — the
# `option_defaults` predicate is declared MULTI-
# MODE: `(out, out) is multi` says when both args
# are output, the predicate has MULTIPLE
# SOLUTIONS (Mercury's term for "many answers via
# backtracking").  The getopt_io library calls
# this in `(out, out)` mode to enumerate ALL
# option-default pairs.  Distinct from `is det`
# (deterministic — exactly one answer), `is
# semidet` (zero or one answer), `is nondet`
# (any number of answers).  Sister to R297 SWI-
# Prolog (no mode declarations — Prolog is
# implicitly multi-mode).  Mercury's mode system
# is what distinguishes it from Prolog: STATIC
# TYPING + MODE ANNOTATIONS + DETERMINISM
# CATEGORIES.  Corpus's **first documented
# multi-mode-determinism-annotation CLI pattern**.
#
# Hunt-skip notes: skipped `_mmc` (Mercury
# compiler, already in corpus + blacklisted —
# uses getopt_io too but ~1000+ flags surface),
# `_unison` (DUP with stock zsh).  Probed
# `testock/mercury-template` (0 stars, niche
# scaffolding tool with very small CLI), `Mercury-
# Language/mercury hlds_out_module.m`
# (compiler-internal, no standalone binary).
# Chose mmc-doc: 6 GH stars (small but real
# user-facing utility), 12 FLAGS in a single
# 250-line mmcdoc.m, exercises EVERY MAJOR
# Mercury getopt_io PATTERN (PROLOG-fact-style
# short_option/long_option/option_defaults
# predicates, ADT for parsed options, `option_data`
# typed-union default values, `option_ops_multi`
# config with predicates as first-class values,
# `process_options_io` parse with `!IO` state
# threading, `lookup_bool_option`/`lookup_maybe_
# string_option` type-specific accessors), real
# Mercury binary distributed via the project's
# Makefile (`BIN=mmc-doc`).

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# Mercury doc-index values from index/2 facts at
# mmcdoc.m:85-89
local -a mmcdoc_indexes=(
  'lib:Standard library reference'
  'ref:Mercury language reference'
  'user:User guide'
  'prolog:Trans-from-Prolog guide'
  'faq:Frequently asked questions'
)
# Mercury declaration kinds for -t (from common
# Mercury terms: type, pred, func, mode, inst,
# typeclass)
local -a mmcdoc_decls=(
  'type:type declaration'
  'pred:predicate declaration'
  'func:function declaration'
  'mode:mode declaration'
  'inst:inst declaration'
  'typeclass:typeclass declaration'
)

# 11 flags decoded source-direct from short_option +
# long_option + usage at mmcdoc.m:25-43,57-77.
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-l --local)'{-l,--local}'[use local documentation (implied by -i)]' \
  '(-n --no-cache)'{-n,--no-cache}'[load remote docs without caching]' \
  '(-b --backup)'{-b,--backup}'[use backup (mercury-in.space) URL for remote docs]' \
  '-i+[load doc INDEX]:index:->indexes' \
  '(-g --grep)'{-g,--grep}'[search for substrings instead of tokens]' \
  '(-c --comment)'{-c,--comment}'[search for comment substrings]' \
  '-t+[restrict search to a declaration kind]:declaration:->decls' \
  '--list-modules[list standard library modules]' \
  '--refresh-cache[download all stdlib library files if old]' \
  '1:Mercury stdlib module:' \
  '2:token (or substring with -g/-c):' && ret=0

case $state in
  indexes)
    _describe -t doc_indexes 'doc index' mmcdoc_indexes && ret=0
    ;;
  decls)
    _describe -t mercury_decls 'Mercury declaration kind' mmcdoc_decls && ret=0
    ;;
esac

return ret
