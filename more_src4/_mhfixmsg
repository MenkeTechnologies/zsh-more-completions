#compdef mhfixmsg
# Documentation: man mhfixmsg(1)
# Source: nmh uip/mhfixmsg.c (master) — repair MIME messages (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-decodetext -nodecodetext)-decodetext+[decode CTE in text parts]:cte:(8bit 7bit)' \
    '(-decodetext -nodecodetext)-nodecodetext[no CTE decoding]' \
    '(-textcharset -notextcharset)-textcharset[try alternate charsets]' \
    '(-textcharset -notextcharset)-notextcharset[no charset retry]' \
    '(-reformat -noreformat)-reformat[reformat message]' \
    '(-reformat -noreformat)-noreformat[no reformat]' \
    '(-replacetextplain -noreplacetextplain)-replacetextplain[replace text/plain part]' \
    '(-replacetextplain -noreplacetextplain)-noreplacetextplain[do not replace]' \
    '(-fixboundary -nofixboundary)-fixboundary[fix MIME boundaries]' \
    '(-fixboundary -nofixboundary)-nofixboundary[no boundary fix]' \
    '(-fixcte -nofixcte)-fixcte[fix Content-Transfer-Encoding]' \
    '(-fixcte -nofixcte)-nofixcte[no CTE fix]' \
    '-fixtype+[fix Content-Type to mimetype]:mimetype:_default' \
    '-file+[message file]:file:_files' \
    '-outfile+[output file]:file:_files' \
    '-rmmproc+[external remove program]:cmd:_command_names -e' \
    '-normmproc[no external remove program]' \
    '(-changecur -nochangecur)-changecur[change current message]' \
    '(-changecur -nochangecur)-nochangecur[do not change current]' \
    '(-verbose -noverbose)-verbose[verbose]' \
    '(-verbose -noverbose)-noverbose[no verbose]' \
    '-version[show version]' \
    '-help[show help]' \
    '1::+folder:_default' \
    '*::msgs:_default' \
    && ret=0

return ret
