#compdef pd-gui
# Documentation: https://github.com/pure-data/pure-data/blob/master/tcl/pd-gui.tcl
# Reference accessed: 2026-05-20
# Verified: upstream Pure Data Tcl/Tk GUI helper.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-stderr[redirect output to stderr]' \
  '*-open+[open Pd patch on startup]:file:_files -g "*.pd"' \
  '*-pdarg+[pass argument to the Pd core process]:arg:' \
  '*: :_files -g "*.pd"' && ret=0

return ret
