#compdef opm
# Documentation: https://github.com/operator-framework/operator-registry
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above
# (cmd/opm/root/cmd.go AddCommand registration).

# opm: Operator Lifecycle Manager registry tool
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'alpha:alpha subcommands'
  'completion:emit shell completion'
  'generate:generate registry data'
  'index:operator-registry index commands'
  'init:init a registry catalog'
  'migrate:migrate registry data'
  'registry:registry server commands'
  'render:render registry objects to a declarative config catalog'
  'serve:serve a registry catalog'
  'validate:validate a declarative config catalog'
  'version:show version'
  'help:show help for a command'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--skip-tls[deprecated\: use --use-http and --skip-tls-verify]' \
  '--skip-tls-verify[skip TLS certificate verification when pulling bundles]' \
  '--use-http[use plain HTTP for container image registries]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'opm command' commands && ret=0 ;;
esac
return ret
