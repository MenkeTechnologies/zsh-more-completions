#compdef munin-asyncd
# Documentation: https://manpages.debian.org/experimental/munin-async/munin-asyncd.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian experimental munin-asyncd(1) manpage.

# munin-asyncd: Munin async daemon (spool builder)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-s --spool)'{-s,--spool=}'[spool directory]:dir:_files -/' \
  '--host=[node hostname:port (default localhost:4949)]:host\:port:' \
  '--interval=[poll interval seconds (default 86400)]:seconds:' \
  '--retain=[interval files to retain (default 7)]:n:' \
  '--nocleanup[disable automated spool cleanup]' \
  '--fork[fork one thread per plugin]' && ret=0
return ret
