#compdef mri_info
# mri_info — print information about MRI volume files (FreeSurfer)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--voxel[print voxel sizes]' \
  '--dim[print dimensions]' \
  '--res[print voxel resolution]' \
  '--orient[print orientation string]' \
  '--tr[print repetition time (TR)]' \
  '--te[print echo time (TE)]' \
  '--ti[print inversion time (TI)]' \
  '--type[print data type]' \
  '--ras_good[print RAS good flag]' \
  '--cras[print center RAS coordinates]' \
  '--format[print file format]' \
  '1:input volume:_files -g "*.{nii,nii.gz,mgz,mgh,mnc,img,hdr}"'
