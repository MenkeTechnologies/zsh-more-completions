#compdef proxytrack
# Documentation: https://manpages.debian.org/bookworm/httrack/proxytrack.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--convert[convert mode]' \
  '*--list+[file list]:list file:_files' \
  '*:archive (zip/ndx/arc) or proxy address:_files -g "*.(zip|ndx|arc)"' && ret=0

return ret
