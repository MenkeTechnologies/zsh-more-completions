#compdef nfct
# Documentation: man nfct(8)
# Source: netfilter conntrack-tools nfct.8 — manage Netfilter conntrack subsystems (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a subs=(
    'timeout:fine-grain timeout policies'
    'helper:user-space conntrack helpers'
    'version:show version information'
    'help:show help'
)

local -a tmout_cmds=(
    'list:list existing timeout policies'
    'add:add a new timeout policy'
    'delete:delete a timeout policy'
    'get:get details of a timeout policy'
    'flush:flush all timeout policies'
)

_arguments -s -C \
    '1:subsystem:->subsys' \
    '2:command:->subcmd' \
    '*::params:_default' \
    && ret=0

case $state in
    subsys) _describe -t subs 'nfct subsystem' subs && ret=0 ;;
    subcmd)
        case $line[1] in
            timeout|helper) _describe -t cmds 'nfct command' tmout_cmds && ret=0 ;;
        esac
        ;;
esac

return ret
