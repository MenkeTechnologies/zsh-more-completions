#compdef megahit
# megahit — ultra-fast metagenomic assembler

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-1,--read1}'=[forward paired-end reads]:FASTQ file:_files' \
  {-2,--read2}'=[reverse paired-end reads]:FASTQ file:_files' \
  {-r,--read}'=[single-end reads]:FASTQ file:_files' \
  '--12=[interleaved paired-end reads]:FASTQ file:_files' \
  {-o,--out-dir}'=[output directory]:output dir:_directories' \
  '--min-contig-len=[minimum contig length]:length:' \
  '--k-min=[minimum kmer size]:kmer size:' \
  '--k-max=[maximum kmer size]:kmer size:' \
  '--k-step=[kmer size step]:step:' \
  '--k-list=[comma-separated kmer sizes]:kmer list:' \
  {-t,--num-cpu-threads}'=[number of threads]:threads:' \
  {-m,--memory}'=[max memory in byte (or fraction of total)]:memory:' \
  '--min-count=[minimum multiplicity for filtering]:count:' \
  '--no-mercy[do not add mercy kmers]' \
  '--bubble-level=[bubble merging level 0-2]:level:(0 1 2)' \
  '--merge-level=[merge complex bubbles of length <= l*kmer_size and target similarity >= s]:l\,s:' \
  '--prune-level=[prune complex 0-3]:level:(0 1 2 3)' \
  '--prune-depth=[remove unitigs below depth]:depth:' \
  '--disconnect-ratio=[disconnect ratio]:ratio:' \
  '--low-local-ratio=[local low depth ratio]:ratio:' \
  '--max-tip-len=[maximum tip length]:length:' \
  '--cleaning-rounds=[number of cleaning rounds]:rounds:' \
  '--no-local[disable local assembly]' \
  '--kmin-1pass[use 1-pass mode for minimum kmer]' \
  '--presets=[apply preset parameters]:preset:(meta-sensitive meta-large)' \
  '--continue[continue a previous run]' \
  '--restart[restart a previous run]' \
  '--tmp-dir=[temp directory]:temp dir:_directories' \
  '--keep-tmp-files[keep temp files]' && ret=0

return ret
