#compdef mongodb-kubernetes
# _mongodb-kubernetes — MongoDB Enterprise Kubernetes operator (reconciles MongoDB, MongoDBCommunity, MongoDBUser, MongoDBOpsManager + Atlas CRs)
# upstream: https://github.com/mongodb/mongodb-kubernetes
# Flags from main.go on tip; OTEL_* env vars carry tracing context and OM_OPERATOR_* / WATCH_NAMESPACE / mongodbXXX_image env vars supply runtime config.

_mongodb-kubernetes() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '*--watch-resource=[Kubernetes resource the operator should watch (repeatable)]:resource:' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_mongodb-kubernetes "$@"
