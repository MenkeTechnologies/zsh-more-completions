#compdef pkgutil
# Documentation: https://www.unix.com/man-page/osx/1/pkgutil/
# Source: Apple macOS — receipt-database + flat-package CLI (pkgs installed by installer(8)).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[brief summary of commands]' \
    '(-f --force)'{-f,--force}'[do not ask for confirmation on destructive ops]' \
    '(-v --verbose)'{-v,--verbose}'[human-readable output]' \
    '--volume=[operate on specified volume / home directory]:path:_directories' \
    '--edit-pkg=[receipt to modify in-place (with --learn)]:pkg-id:' \
    '(--only-files --only-dirs)--only-files[list files only in --files]' \
    '(--only-files --only-dirs)--only-dirs[list directories only in --files]' \
    '--regexp[interpret package-id as regex if no exact match]' \
    '(--packages --pkgs)--packages[list all installed package IDs]' \
    '(--packages --pkgs)--pkgs[list all installed package IDs (alias)]' \
    '--pkgs-plist[list installed package IDs as plist]' \
    '--files=[list files installed under package-id]:pkg-id:' \
    '--export-plist=[print receipt info as plist]:pkg-id:' \
    '--verify=[verify the package via repair_packages(8)]:pkg-id:' \
    '--repair=[repair the package via repair_packages(8)]:pkg-id:' \
    '--pkg-info=[extended info about package-id]:pkg-id:' \
    '--pkg-info-plist=[extended info as plist]:pkg-id:' \
    '--forget=[discard receipt data (do not touch files)]:pkg-id:' \
    '--learn=[update ACLs of path in receipt (with --edit-pkg)]:path:_files' \
    '--pkg-groups=[list package groups containing package-id]:pkg-id:' \
    '--groups[list all package groups on --volume]' \
    '--groups-plist[list all package groups as plist]' \
    '--group-pkgs=[list packages in the given group-id]:group-id:' \
    '--file-info=[show metadata about path]:path:_files' \
    '--file-info-plist=[show metadata about path as plist]:path:_files' \
    '--expand=[expand flat pkg into directory (pkg-path dir-path)]:pkg-path:_files' \
    '--flatten=[flatten dir into new flat pkg (dir-path pkg-path)]:dir-path:_directories' \
    '--bom=[extract BOMs from flat pkg into /tmp]:pkg-path:_files' \
    '--payload-files=[list files in flat-pkg payload]:pkg-path:_files' \
    '--check-signature=[check validity + trust of pkg signature]:pkg-path:_files' \
    '*:package-id or path:' \
    && ret=0

return ret
