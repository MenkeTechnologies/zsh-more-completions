#compdef netcat-openbsd
# Documentation: https://manpages.debian.org/unstable/netcat-openbsd/nc.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# nc.openbsd: OpenBSD-style netcat
local curcontext="$curcontext" ret=1
_arguments -C \
  '-4[use IPv4]' \
  '-6[use IPv6]' \
  '-b[allow broadcast]' \
  '-C[send CRLF as line endings]' \
  '-D[debug socket]' \
  '-d[no read from stdin]' \
  '-F[pass socket fd]' \
  '-h[show help]' \
  '-I[recv socket buf size]:bytes:' \
  '-i[interval between connects]:seconds:' \
  '-k[keep listening for more connections]' \
  '-l[listen mode]' \
  '-M[set TTL]:ttl:' \
  '-m[minimum TTL]:ttl:' \
  '-N[shutdown socket after EOF]' \
  '-n[no DNS]' \
  '-O[send buffer size]:bytes:' \
  '-o[output binary file]:file:_files' \
  '-P[ssl handshake using proxy auth]:user:_users' \
  '-p[source port]:port:' \
  '-q[quit after N seconds at EOF]:seconds:' \
  '-r[random source port]' \
  '-S[enable TCP MD5 signature]' \
  '-s[source address]:address:' \
  '-T[set IP ToS]:tos:' \
  '-t[answer TELNET negotiation]' \
  '-U[use UNIX domain socket]' \
  '-u[UDP mode]' \
  '-V[set routing table]:rtable:' \
  '-v[verbose]' \
  '-W[recv only N pkts]:n:' \
  '-w[timeout]:seconds:' \
  '-X[proxy protocol]:protocol:(4 5 connect)' \
  '-x[proxy address[:port]]:addr:' \
  '-Z[DCCP mode]' \
  '-z[scan mode (no data sent)]' \
  '*::host port:_hosts' && ret=0
return ret
