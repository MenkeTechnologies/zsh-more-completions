#compdef pbmtopk
# Documentation: man pbmtopk (Netpbm)
# Source: convert a sequence of PBM images into a TeX PK font.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-s+[design size]:designsize:' \
    '*-p+[param NUM VALUE]:param:' \
    '-C+[coding scheme]:scheme:' \
    '-F+[font family]:family:' \
    '-f+[option file]:file:_files' \
    '-c+[character code]:num:' \
    '-W+[character width]:width:' \
    '-H+[character height]:height:' \
    '-D+[character depth]:depth:' \
    '-I+[italic correction]:ital:' \
    '-h+[horizontal escapement]:horiz:' \
    '-v+[vertical escapement]:vert:' \
    '-x+[x offset]:xoff:' \
    '-y+[y offset]:yoff:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pk output:_files -g "*.pk"' \
    '2:tfm output:_files -g "*.tfm"' \
    '3:resolution dpi:' \
    '*:pbm character files:_files -g "*.(pbm|pnm|pam)"' \
    && ret=0

return ret
