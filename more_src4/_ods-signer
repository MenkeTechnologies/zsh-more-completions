#compdef ods-signer ods-signerd
# Documentation: https://github.com/opendnssec/opendnssec
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'help:show help'
  'zones:list zones'
  'sign:sign a zone'
  'sign-all:sign all zones'
  'clear:clear zone state'
  'queue:show task queue'
  'flush:flush all tasks'
  'update:update zone'
  'start:start signer'
  'stop:stop signer'
  'reload:reload signer'
  'running:show running tasks'
  'verbosity:set log verbosity'
)

_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'ods-signer command' commands && ret=0 ;;
esac

return ret
