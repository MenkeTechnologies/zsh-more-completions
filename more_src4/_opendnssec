#compdef ods-control ods-enforcer ods-enforcerd ods-signer ods-signerd ods-ksmutil ods-hsmutil
# _opendnssec — NLnet OpenDNSSEC suite for automated DNSSEC zone signing and key management (NLnetLabs team, C); custom argparse
# upstream: https://github.com/opendnssec/opendnssec

_opendnssec() {
    local -a sub=(
        'start:start all daemons'
        'stop:stop all daemons'
        'enforcer:enforcer subcommands'
        'signer:signer subcommands'
        'ksmutil:key signing management utility'
        'hsmutil:HSM management utility'
        'status:show all daemons status'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[config file]:file:_files -g "conf.xml *.xml"' \
        '--config=+[config file]:file:_files -g "conf.xml *.xml"' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'opendnssec subcommand' sub ;;
        args)
            case $words[1] in
                enforcer) _arguments '1:enforcer cmd:(start stop reload notify update zone-add zone-del zone-list key-list key-export key-import key-purge key-rollover policy-list policy-import policy-export policy-purge backup setup queue running flush)' ;;
                signer) _arguments '1:signer cmd:(zones sign clear queue flush update running verbosity)' ;;
                ksmutil) _arguments '1:ksmutil cmd:(setup update zone delete export import list key control policy purge rollover backup)' ;;
                hsmutil) _arguments '1:hsmutil cmd:(login logout list test purge generate remove dnskey)' ;;
            esac
            ;;
    esac
}

_opendnssec "$@"
