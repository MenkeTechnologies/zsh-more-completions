#compdef modiinfo
# Documentation: https://github.com/libyal/libmodi
# Source: libyal/libmodi manuals/modiinfo.1 — display info about an Apple Mac OS Disk Image (sparseimage / sparsebundle / UDIF DMG).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[show help]' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '*:Mac OS disk image:_files' \
    && ret=0

return ret
