#compdef ppmrough
# Documentation: man ppmrough (Netpbm)
# Source: generate a PPM image of a rough-edged colored frame.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-left+[left margin in pixels]:n:' \
    '-right+[right margin in pixels]:n:' \
    '-top+[top margin in pixels]:n:' \
    '-bottom+[bottom margin in pixels]:n:' \
    '-width+[image width]:n:' \
    '-height+[image height]:n:' \
    '-bg+[background color]:color:' \
    '-fg+[foreground color]:color:' \
    '-var+[edge variation in pixels]:n:' \
    '-randomseed+[random seed]:seed:' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    && ret=0

return ret
