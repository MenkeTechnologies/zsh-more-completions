#compdef okta-aws-cli
# Documentation: https://github.com/okta/okta-aws-cli
# Reference accessed: 2026-05-19
# Verified: upstream README at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'web:combined human and device authorization'
  'm2m:headless authorization'
  'direct:direct authorization with OOB MFA'
  'list-profiles:list profile names in ~/.okta/okta.yaml'
  'debug:debug okta.yaml config file and exit'
)

local -a global_flags=(
  '--aws-region=[AWS region]:region'
  '--org-domain=[Okta org domain]:domain'
  '--oidc-client-id=[OIDC client ID]:client-id'
  '--aws-iam-role=[AWS IAM role ARN]:arn'
  '--aws-session-duration=[session duration seconds]:n'
  '--format=[output format]:format:(env-var aws-credentials process-credentials noop)'
  '--profile=[AWS profile]:profile'
  '--cache-access-token[cache the access token]'
  '--aws-credentials=[AWS credentials file path]:file:_files'
  '--write-aws-credentials[overwrite profile in credentials file]'
  '--legacy-aws-variables[include deprecated aws_security_token]'
  '--expiry-aws-variables[emit x_security_token_expires timestamp]'
  '--debug[print operational information]'
  '--debug-api-calls[verbose API call logging]'
  '--exec=[execute a process with credentials]:command'
  '--short-user-agent[use simplified user agent]'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  $global_flags \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'okta-aws-cli command' commands && ret=0
    ;;
  args)
    case $line[1] in
      web)
        _arguments \
          $global_flags \
          '--aws-acct-fed-app-id=[AWS Federation app ID]:id' \
          '--aws-iam-idp=[AWS IAM IdP ARN]:arn' \
          '--qr-code[display QR code]' \
          '--open-browser[auto-open browser]' \
          '--open-browser-command=[custom browser command]:command' \
          '--all-profiles[gather all profiles for all IdPs/Roles]' && ret=0
        ;;
      m2m)
        _arguments \
          $global_flags \
          '--key-id=[Key ID from service app]:kid' \
          '--private-key=[PEM private key]:key' \
          '--private-key-file=[PEM private key file]:file:_files' \
          '--authz-id=[authorization server ID]:id' \
          '--custom-scope=[custom scope]:scope' \
          '--aws-sts-role-session-name=[STS role session name]:name' && ret=0
        ;;
      direct)
        _arguments \
          $global_flags \
          '--username=[operator username]:user' \
          '--password=[operator password]:pass' \
          '--authz-id=[authorization server ID]:id' \
          '--aws-sts-role-session-name=[STS role session name]:name' && ret=0
        ;;
    esac
    ;;
esac

return ret
