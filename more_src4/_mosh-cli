#compdef mosh-cli
# _mosh-cli — MIT Mosh mobile shell over UDP CLI alias (Keith Winstein / MIT, C++); custom argparse
# upstream: https://github.com/mobile-shell/mosh

_mosh-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--client=+[mosh-client path]:file:_files' \
        '--server=+[mosh-server command]:str:' \
        '--ssh=+[ssh command]:str:' \
        '--predict=+[predict mode]:p:(adaptive always never experimental)' \
        '-a[predict always]' \
        '-n[no predict]' \
        '--port=+[server-side UDP port]:port:' \
        '-p+[server-side UDP port]:port:' \
        '--bind-server=+[bind addr]:str:' \
        '--no-init[no init mosh-server]' \
        '--family=+[network family]:f:(inet inet6 prefer-inet prefer-inet6)' \
        '-4[force IPv4]' \
        '-6[force IPv6]' \
        '--predict-overwrite[predict overwrite]' \
        '--experimental-remote-ip=+[experimental remote IP]:str:' \
        '--local[run local copy of mosh-server]' \
        '*:user-host-and-cmd:'
}

_mosh-cli "$@"
