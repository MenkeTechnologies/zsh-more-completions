#compdef ovf2ovp
# Documentation: ovf2ovp --help (TeX Live 2026 Omega)
# Source: translate Omega Virtual Font + OFM back to a human-readable Virtual Property List.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[display help]' \
    '(- *)-version[output version information]' \
    '-verbose[display progress reports]' \
    '-char-format=[character-code output type]:type:(num ascii)' \
    '-num-format=[number output radix]:type:(hex octal)' \
    '-text-format=[coding-scheme and family case]:type:(mixed upper)' \
    '-charcode-format=[character-code output (compat)]:type:(hex octal ascii)' \
    '1:ovf input:_files -g "*.ovf"' \
    '2:ofm input:_files -g "*.ofm"' \
    '3:ovp output:_files -g "*.ovp"' \
    && ret=0

return ret
