_monero-blockchain-mark-spent-outputs() {
  _arguments \
    '(- *)--help[Produce help message]' \
    '--check-subsets[Check ring subsets (very expensive)]' \
    '--db-sync-mode=[Sync option, format safe|fast|fastest:nrecords_per_sync]:mode' \
    '--export=[Filename to export the spent-outputs list to]:file:_files' \
    '--extra-spent-list=[Optional list of known spent outputs]:file:_files' \
    '--force-chain-reaction-pass[Run the chain reaction pass even if no new blockchain data was processed]' \
    '--historical-stat[Report historical stat of spent outputs for every 10000 blocks window]' \
    '--log-level=[0-4 or categories]:log level' \
    '--rct-only[Only work on ringCT outputs]' \
    '--spent-output-db-dir=[Specify spent output database directory]:database directory:_directories' \
    '--verbose[Verbose output]' \
    '*:Monero database directory:_directories'
}

_monero-blockchain-mark-spent-outputs "$@"
