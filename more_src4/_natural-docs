#compdef natural-docs naturaldocs naturaldocs.exe
# _natural-docs — Greg Valure Natural Docs language-agnostic source-code documentation generator CLI producing HTML XML docs from inline comments with topic-keyword linking for over 20 languages (greg-valure team, C#); System.CommandLine
# upstream: https://github.com/NaturalDocs/NaturalDocs

_natural-docs() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-?[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-i+[input source dir]:dir:_files -/' \
        '--input=+[input source dir]:dir:_files -/' \
        '--source=+[input source dir]:dir:_files -/' \
        '-r+[input image dir]:dir:_files -/' \
        '--images=+[input image dir]:dir:_files -/' \
        '-o+[format directory]:str:' \
        '--output=+[format directory]:str:' \
        '-p+[project config dir]:dir:_files -/' \
        '--project-config=+[project config dir]:dir:_files -/' \
        '-w+[working data dir]:dir:_files -/' \
        '--working-data=+[working data dir]:dir:_files -/' \
        '-t+[tab length]:n:' \
        '--tab-length=+[tab length]:n:' \
        '-do+[documented only]' \
        '--documented-only[documented only]' \
        '-nag[no auto-group]' \
        '--no-auto-group[no auto-group]' \
        '-rs[rebuild source]' \
        '--rebuild[rebuild]' \
        '--rebuild-output[rebuild output]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-bo+[benchmark output]:str:' \
        '--benchmark-output=+[benchmark output]:str:' \
        '-p+[pause-on-error]' \
        '--pause-on-error[pause on error]' \
        '--pause-before-exit[pause before exit]' \
        '*:project file:_files'
}

_natural-docs "$@"
