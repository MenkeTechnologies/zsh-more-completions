#compdef pcp-dmcache
# _pcp-dmcache — PCP-based device-mapper cache statistics (performancecopilot/pcp)
# upstream: https://github.com/performancecopilot/pcp
# Flags from src/pcp/dmcache/pcp-dmcache.1 SYNOPSIS.

_pcp-dmcache() {
    _arguments \
        '(- *)-?[show help]' \
        '(- *)-V[show version]' \
        '-i[show per-device IOPS]' \
        '-R[show real-time (live) values]' \
        '*:dmcache device:'
}

_pcp-dmcache "$@"
