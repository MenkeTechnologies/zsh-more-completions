#compdef mmafm
# Documentation: mmafm --help (lcdf-typetools)
# Source: create an AFM metric file for a multiple-master font by interpolating at a design point.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[print help]' \
    '(- *)'{-v,--version}'[print version]' \
    '(-o --output)'{-o+,--output=}'[write output to FILE]:file:_files -g "*.afm"' \
    '(-w --weight)'{-w+,--weight=}'[set weight axis]:n:' \
    '(-W --width)'{-W+,--width=}'[set width axis]:n:' \
    '(-O --optical-size)'{-O+,--optical-size=}'[set optical-size axis]:n:' \
    '--style=[set style axis]:n:' \
    '--1=[set first design axis]:n:' \
    '--2=[set second design axis]:n:' \
    '--3=[set third design axis]:n:' \
    '--4=[set fourth design axis]:n:' \
    '(-p --precision)'{-p+,--precision=}'[digits of fraction (default 3)]:n:' \
    '(-k --min-kern)'{-k+,--min-kern=}'[remove kerns smaller than N (default 2)]:n:' \
    '*:afm or amfm file:_files -g "*.(afm|amfm)"' \
    && ret=0

return ret
