#compdef mdadm-cli
# _mdadm-cli — Linux md software RAID CLI alias (Neil Brown / Jes Sorensen, C); custom argparse
# upstream: https://git.kernel.org/pub/scm/utils/mdadm/mdadm.git

_mdadm-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--help-options[show options help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--manage[manage mode]' \
        '--misc[misc mode]' \
        '-A[assemble]' \
        '--assemble[assemble]' \
        '-B[build]' \
        '--build[build]' \
        '-C[create]' \
        '--create[create]' \
        '-F[follow/monitor]' \
        '--follow[follow/monitor]' \
        '--monitor[follow/monitor]' \
        '-G[grow]' \
        '--grow[grow]' \
        '-I[incremental assembly]' \
        '--incremental[incremental assembly]' \
        '--examine[examine devices]' \
        '-E[examine devices]' \
        '--examine-bitmap[examine bitmap]' \
        '-X[examine bitmap]' \
        '--detail[detail array]' \
        '-D[detail array]' \
        '--detail-platform[detail platform]' \
        '--query[query device]' \
        '-Q[query device]' \
        '--config=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--scan[scan]' \
        '-s[scan]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--force[force]' \
        '-f[force]' \
        '--level=+[raid level]:l:(0 1 4 5 6 10 linear raid0 raid1 raid4 raid5 raid6 raid10 multipath faulty container)' \
        '-l+[raid level]:l:(0 1 4 5 6 10 linear raid0 raid1 raid4 raid5 raid6 raid10 multipath faulty container)' \
        '--raid-devices=+[raid devices]:n:' \
        '-n+[raid devices]:n:' \
        '--spare-devices=+[spare devices]:n:' \
        '-x+[spare devices]:n:' \
        '--metadata=+[metadata version]:m:(0 0.90 1 1.0 1.1 1.2 default ddf imsm)' \
        '-e+[metadata version]:m:(0 0.90 1 1.0 1.1 1.2 default ddf imsm)' \
        '--bitmap=+[bitmap file]:file:_files' \
        '-b+[bitmap file]:file:_files' \
        '--bitmap-chunk=+[bitmap chunk]:n:' \
        '--chunk=+[chunk size]:n:' \
        '-c+[chunk size]:n:' \
        '--size=+[size]:str:' \
        '-z+[size]:str:' \
        '--assume-clean[assume clean]' \
        '--update=+[update super block]:u:(name uuid homehost summaries resync byteorder no-bitmap bbl no-bbl revert-reshape force-no-bbl)' \
        '-U+[update super block]:u:(name uuid homehost summaries resync byteorder no-bitmap bbl no-bbl revert-reshape force-no-bbl)' \
        '--name=+[name]:str:' \
        '-N+[name]:str:' \
        '--homehost=+[homehost]:str:' \
        '--uuid=+[uuid]:str:' \
        '-u+[uuid]:str:' \
        '--add[add device]' \
        '-a[add device]' \
        '--remove[remove device]' \
        '-r[remove device]' \
        '--fail[fail device]' \
        '--replace[replace device]' \
        '--with=+[with device]:file:_files' \
        '--re-add[re-add device]' \
        '--zero-superblock[zero super block]' \
        '--write-mostly[write mostly]' \
        '-W[write mostly]' \
        '--write-behind=+[write behind]:n:' \
        '-Y+[write behind]:n:' \
        '--stop[stop array]' \
        '-S[stop array]' \
        '--readonly[set readonly]' \
        '-o[set readonly]' \
        '--readwrite[set readwrite]' \
        '-w[set readwrite]' \
        '--zero[zero blocks]' \
        '*:device:_files'
}

_mdadm-cli "$@"
