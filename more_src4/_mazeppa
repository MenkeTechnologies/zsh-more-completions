#compdef mazeppa
# ============================================================================
#  _mazeppa — A modern supercompiler for call-by-value functional languages
#
#  Source-direct extraction from
#    https://github.com/hirrolot/mazeppa/blob/master/bin/main.ml
#    https://github.com/rbardou/clap (the Clap library itself)
#
#  Authored by Hirrolot.  478 GH stars.  Mazeppa is a positive supercompiler
#  that performs program specialisation on a small functional language
#  (terms over symbols + integer/string/tuple literals) and emits residual
#  programs.  Sister tools: PE (partial evaluators) like Sloth, mwhile.
#
#  CLI library taxonomy update: 4th OCaml CLI library — rbardou/clap (NOT
#  to be confused with Rust's `clap`).  `Clap` is an IMPERATIVE
#  CONSUMPTION-MECHANISM CLI parser for OCaml — calls to `Clap.flag`,
#  `Clap.mandatory_string`, `Clap.optional_string`, `Clap.default_string`
#  IMPLICITLY CONSUME from a global parser state initialised by `Clap.parse`.
#  `Clap.case "verb" ~description @@ fun () -> handler` builds a subcommand
#  case; `Clap.subcommand [cases...]` assembles them into a dispatch table
#  with help-derived-from-descriptions.  Distinct from R271 OCaml Cmdliner
#  (term-applicative-combinator), R325 OCaml stdlib Arg (handler-callback),
#  R331 OCaml Jane Street Core.Command (`let%map_open.Command` PPX).
#  Brings cross-language CLI library taxonomy variant count to 78 and
#  OCaml documented CLI libraries to 4 (tied with Rust as most-documented).
#
#  Surface (verbatim from bin/main.ml `get_command`):
#    Subcommands:
#      run         Run the supercompiler
#      translate   Translate a program to some target language
#      check       Check a program for errors
#      eval        Evaluate a program and print the result
#
#    `run` flags:
#      --target-dir DIR    Target directory (default: "target")
#      --inspect           Inspect supercompiler work
#
#    `translate` flags:
#      --language LANG     Target language (mandatory; only `C` supported)
#      --entry NAME        `extern` main function name (mandatory)
#      --dump-header-to D  Directory to dump mazeppa.h (optional)
#
#    `check` / `eval` flags: none (always reads `main.mz`)
# ============================================================================

_mazeppa() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '1: :->subcommand' \
    '*:: :->cmd_args'

  case $state in
    subcommand)
      local -a verbs
      verbs=(
        'run:run the supercompiler'
        'translate:translate a program to a target language'
        'check:check main.mz for errors'
        'eval:evaluate main.mz and print the result'
      )
      _describe -t commands 'mazeppa subcommand' verbs
      ;;
    cmd_args)
      case $line[1] in
        run)
          _arguments -s -S \
            '--target-dir=[target directory (default target)]:dir:_directories' \
            '--inspect[inspect the work of the supercompiler]'
          ;;
        translate)
          _arguments -s -S \
            '--language=[target language (case-insensitive; only C supported)]:language:(C c)' \
            '--entry=[name of extern main function]:entry name' \
            '--dump-header-to=[directory to dump mazeppa.h]:dir:_directories'
          ;;
        check|eval)
          ;;
      esac
      ;;
  esac
}

_mazeppa "$@"
