#compdef mysqlmanager
# Documentation: MySQL Instance Manager
# Source: MySQL server-tools/instance-manager/options.cc (5.1 era) — MySQL Instance Manager daemon (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-? --help)'{-\\?,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '--add-user[add a user to password file]' \
    '--drop-user[drop a user from password file]' \
    '--edit-user[edit existing user in password file]' \
    '--list-users[list users in password file]' \
    '--check-password-file[check password file for consistency]' \
    '--clean-password-file[clean password file]' \
    '--print-password-line[print encrypted password line]' \
    '--password=[password]:password:_default' \
    '--password-file=[password file]:file:_files' \
    '--username=[username]:user:_default' \
    '--bind-address=[bind address]:address:_default' \
    '--port=[port number]:port:_default' \
    '--socket=[Unix socket file]:file:_files' \
    '--pid-file=[pid file]:file:_files' \
    '--angel-pid-file=[angel pid file]:file:_files' \
    '--default-mysqld-path=[mysqld binary path]:path:_files' \
    '--monitoring-interval=[monitoring interval seconds]:seconds:_default' \
    '--mysqld-safe-compatible[mysqld_safe compatibility mode]' \
    '--log=[log file]:file:_files' \
    '--standalone[run standalone (no fork)]' \
    '--run-as-service[run as system service]' \
    '--install[install as system service]' \
    '--remove[remove system service]' \
    '--user=[username to run as]:user:_users' \
    '--wait-timeout=[seconds IM waits for instance]:seconds:_default' \
    '--print-defaults[print argument list and exit]' \
    '--defaults-file=[read config from file]:file:_files' \
    '--debug=[debug log spec]::spec:_default' \
    && ret=0

return ret
