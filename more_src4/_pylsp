#compdef pylsp
# Documentation: https://github.com/python-lsp/python-lsp-server
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '--tcp[use TCP server instead of stdio]' \
  '--ws[use WebSocket server instead of stdio]' \
  '--host=[bind to this address]:host:' \
  '--port=[bind to this port]:port:' \
  '--check-parent-process[shut down when parent process is not alive]' \
  '--log-config=[path to JSON logging config]:file:_files' \
  '--log-file=[redirect logs to the given file]:file:_files' \
  '*'{-v,--verbose}'[increase log verbosity (repeatable)]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]'
