#compdef papi_avail papi_clockres papi_command_line papi_component_avail papi_cost papi_decode papi_error_codes papi_event_chooser papi_mem_info papi_multiplex_cost papi_native_avail papi_version papi_xml_event_info papi
# _papi — UTK ICL PAPI Performance Application Programming Interface utilities for performance counter event introspection (icl team, C); getopt
# upstream: https://github.com/icl-utk-edu/papi

_papi() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-d[detailed]' \
        '--detail[detailed]' \
        '-a[available]' \
        '--avail[available]' \
        '-c+[component]:str:' \
        '--component=+[component]:str:' \
        '-e+[event]:str:' \
        '--event=+[event]:str:' \
        '-l+[event level]:n:' \
        '-x[XML output]' \
        '--xml[XML output]' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-i+[iterations]:n:' \
        '--iters=+[iterations]:n:' \
        '-r+[trial repeats]:n:' \
        '-s+[sample size]:n:' \
        '-m[multiplex]' \
        '--multiplex[multiplex]' \
        '-t[threading]' \
        '--thread[threading]' \
        '-n+[N events]:n:' \
        '-T[thread mode]' \
        '--threaded[thread mode]' \
        '-D+[domain]:d:(PAPI_DOM_USER PAPI_DOM_KERNEL PAPI_DOM_OTHER PAPI_DOM_SUPERVISOR PAPI_DOM_ALL)' \
        '--domain=+[domain]:d:(PAPI_DOM_USER PAPI_DOM_KERNEL PAPI_DOM_OTHER PAPI_DOM_SUPERVISOR PAPI_DOM_ALL)' \
        '*:event:'
}

_papi "$@"
