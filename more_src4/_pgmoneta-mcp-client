#compdef pgmoneta-mcp-client
# _pgmoneta-mcp-client — interactive MCP client for pgmoneta (pgmoneta/pgmoneta_mcp)
# upstream: https://github.com/pgmoneta/pgmoneta_mcp
# Flags from src/bin/client/client.rs (clap derive).

_pgmoneta-mcp-client() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-c --conf)'{-c+,--conf=}'[client configuration file]:file:_files -g "*.conf"' \
        '(-u --users)'{-u+,--users=}'[users configuration file]:file:_files -g "*.conf"'
}

_pgmoneta-mcp-client "$@"
