#compdef pamthreshold
# Documentation: man pamthreshold (Netpbm)
# Source: Netpbm pamthreshold — threshold grayscale image to black and white.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-simple -local -dual)-simple[global thresholding (default behavior)]' \
    '(-simple -local -dual)-local=[local thresholding window WxH]:WxH:' \
    '(-simple -local -dual)-dual=[dual thresholding window WxH]:WxH:' \
    '-threshold=[explicit threshold (0..1)]:threshold:' \
    '-contrast=[contrast threshold for -dual]:threshold:' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:input PAM/PGM file:_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    && ret=0

return ret
