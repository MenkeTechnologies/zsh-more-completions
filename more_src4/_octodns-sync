#compdef octodns-sync
# Documentation: https://github.com/octodns/octodns

_arguments -s -S \
  '(- *)--help[show help]' \
  '--config-file=[path to configuration file]:config:_files -g "*.y(a|)ml"' \
  '--doit[actually execute the sync (default is dry-run/plan)]' \
  '--force[force changes even when safety checks would prevent them]' \
  '--plan-output-fh=[file to write plan output]:file:_files' \
  '*:zone or source:' \
  && return 0
