#compdef pg_format
# Documentation: https://github.com/darold/pgFormatter
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-a --anonymize)'{-a,--anonymize}'[obscure literals in queries]' \
  '(-b --comma-start)'{-b,--comma-start}'[start parameters list with comma]' \
  '(-B --comma-break)'{-B,--comma-break}'[add newline after each comma in INSERT]' \
  '(-c --config)'{-c+,--config=}'[configuration file]:file:_files' \
  '(-C --wrap-comment)'{-C,--wrap-comment}'[reformat comments]' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '(-e --comma-end)'{-e,--comma-end}'[end parameters list with comma]' \
  '(-f --function-case)'{-f+,--function-case=}'[function name case]:level:(0 1 2 3)' \
  '(-F --format)'{-F+,--format=}'[output format]:format:(text html)' \
  '(-g --nogrouping)'{-g,--nogrouping}'[add newlines between statements]' \
  '(-i --inplace)'{-i,--inplace}'[override input files]' \
  '(-k --keep-newline)'{-k,--keep-newline}'[preserve empty lines in plpgsql]' \
  '(-L --no-extra-line)'{-L,--no-extra-line}'[remove extra empty line at end]' \
  '(-m --maxlength)'{-m+,--maxlength=}'[maximum query length]:length:' \
  '(-M --multiline)'{-M,--multiline}'[multi-line search for placeholders]' \
  '(-n --nocomment)'{-n,--nocomment}'[remove comments from SQL]' \
  '(-N --numbering)'{-N,--numbering}'[add statement numbering]' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '(-p --placeholder)'{-p+,--placeholder=}'[regex for unchanged code]:pattern:' \
  '(-s --spaces)'{-s+,--spaces=}'[indentation size]:spaces:' \
  '(-S --separator)'{-S+,--separator=}'[dynamic code separator]:sep:' \
  '(-t --format-type)'{-t,--format-type}'[alternative formatting]' \
  '(-T --tabs)'{-T,--tabs}'[use tabs instead of spaces]' \
  '(-u --keyword-case)'{-u+,--keyword-case=}'[keyword case]:level:(0 1 2 3)' \
  '(-U --type-case)'{-U+,--type-case=}'[data type name case]:level:(0 1 2 3)' \
  '(-w --wrap-limit)'{-w+,--wrap-limit=}'[wrap queries at length]:width:' \
  '(-W --wrap-after)'{-W+,--wrap-after=}'[wrap lists after N columns]:columns:' \
  '(-X --no-rcfile)'{-X,--no-rcfile}'[skip reading rc files]' \
  '*:file:_files -g "*.sql"' && ret=0

return ret
