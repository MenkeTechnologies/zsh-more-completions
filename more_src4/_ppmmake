#compdef ppmmake
# Documentation: man ppmmake (Netpbm)
# Source: produce a solid-color PPM image of given dimensions.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-maxval=[max sample value]:maxval:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:color:' \
    '2:width:' \
    '3:height:' \
    && ret=0

return ret
