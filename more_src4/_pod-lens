#compdef pod-lens
# Documentation: https://github.com/sunny0826/kubectl-pod-lens
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above (cmd/plugin/cli/root.go).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--kubeconfig=[path to kubeconfig file]:file:_files' \
  '--context=[kubeconfig context]:context' \
  {-n+,--namespace=}'[namespace scope]:namespace' \
  {-A,--all-namespaces}'[query all namespaces]' \
  {-l+,--selector=}'[label selector to filter on]:selector' \
  '-v+[verbosity level]:level' \
  '*:args:_default'
