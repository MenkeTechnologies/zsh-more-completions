#compdef mpd-mpris
# Documentation: https://github.com/natsukagami/mpd-mpris/blob/master/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mpd-mpris: MPRIS2 D-Bus bridge for MPD
local curcontext="$curcontext" ret=1
_arguments -C \
  '-host=[MPD host]:host:_hosts' \
  '-port=[MPD port]:port:' \
  '-pwd=[MPD password]:password:' \
  '-pwd-file=[file containing MPD password]:file:_files' \
  '-network=[network used to dial MPD]:net:(tcp unix)' \
  '-no-instance[use bare org.mpris.MediaPlayer2.mpd interface]' \
  '-instance-name=[suffix for the MPRIS bus name]:name:' && ret=0
return ret
