#compdef pbmtog3
# Documentation: man pbmtog3 (Netpbm)
# Source: convert a PBM image to G3 fax format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-reversebits[reverse bit order in output bytes]' \
    '-nofixedwidth[do not pad to fixed fax width]' \
    '(-align8 -align16)-align8[byte-align EOL]' \
    '(-align8 -align16)-align16[16-bit align EOL]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pbm file:_files -g "*.(pbm|pnm|pam)"' \
    && ret=0

return ret
