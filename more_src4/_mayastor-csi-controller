#compdef mayastor-csi-controller
# _mayastor-csi-controller — Mayastor CSI controller plugin (REST→io-engine bridge; one Deployment per cluster)
# upstream: https://github.com/openebs/mayastor-control-plane
# Flags from control-plane/csi-driver/src/bin/controller/{main,config}.rs on tip (clap).

_mayastor-csi-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '--rest-endpoint=[Mayastor REST API endpoint]:url:_urls' \
        '--csi-socket=[UNIX socket the CSI plugin listens on]:socket:_files' \
        '--timeout=[REST I/O timeout (humantime, e.g. 30s)]:duration:' \
        '*--node-selector=[key=value label that selects node plugins]:kv:' \
        '--create-volume-limit=[max outstanding CreateVolume requests]:n:' \
        '--force-unstage-volume=[force-unstage volumes on NodeUnstageVolume]:bool:(true false)' \
        '--ca-certificate-path=[CA certificate file]:file:_files' \
        '--rest-username=[REST basic-auth username]:user:' \
        '--rest-password=[REST basic-auth password]:password:' \
        '--tracing-tags=[csv key=value tags for tracing]:csv:' \
        '--jaeger=[Jaeger collector endpoint]:url:_urls' \
        '--fmt-style=[log format style]:style:(default compact pretty json)' \
        '--fmt-layer=[log layer]:layer:(stdout stderr console)' \
        '*--io-engine-pool=[I/O engine pool selector]:sel:'
}

_mayastor-csi-controller "$@"
