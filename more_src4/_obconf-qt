#compdef obconf-qt
# Documentation: https://github.com/lxqt/obconf-qt
# Reference accessed: 2026-05-19
# Verified: upstream src/obconf-qt.cpp parse_args. Real options:
# --help, --version, --install ARCHIVE.obt, --archive THEME,
# --config-file FILE. No short forms. Trailing positional is an
# .obt archive to install. Removed: fabricated -h/-v/--theme=.

# obconf-qt: Qt configuration tool for the Openbox window manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[display help and exit]' \
  '(- *)--version[display version and exit]' \
  '--install[install given theme archive and select it]:archive:_files -g "*.obt"' \
  '--archive[create theme archive from theme directory]:theme directory:_files -/' \
  '--config-file[path to config file]:file:_files' \
  '*:archive:_files -g "*.obt"' && ret=0
return ret
