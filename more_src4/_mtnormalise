#compdef mtnormalise
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/mtnormalise.html
# Source: MRtrix3/mrtrix3 cmd/mtnormalise.cpp — multi-tissue log-domain bias-field/intensity normalisation (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-mask+[mask defining data used for normalisation]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-order+[polynomial basis max order]:number:(0 1 2 3)' \
    '-niter+[iteration counts (comma-separated)]:n:_default' \
    '-reference+[reference value for summed compartments]:value:_default' \
    '-balanced[apply per-tissue balancing factors to output]' \
    '-check_norm+[output estimated spatially varying intensity]:image:_files' \
    '-check_mask+[output final normalisation mask]:image:_files' \
    '-check_factors+[output tissue balance factors]:file:_files' \
    '*:input output tissue files (paired):_files -g "*.{nii,nii.gz,mif}"' \
    && ret=0

return ret
