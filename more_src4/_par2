#compdef par2 par2create par2verify par2repair
# Documentation: https://man.archlinux.org/man/extra/par2cmdline/par2.1.en
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for par2 - PAR 2.0 parity file tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'create:create recovery files (c)'
  'verify:verify files using recovery data (v)'
  'repair:repair files using recovery data (r)'
)

if [[ "$service" = "par2" ]]; then
  _arguments -s -S \
    '1:command:->command' \
    '*::args:->args' && ret=0
else
  state=args
fi

case "$state" in
  command)
    _describe -t commands 'par2 command' commands && ret=0
    ;;
  args)
    _arguments -s -S \
      '-h[show help]' \
      '-V[show version]' \
      '-a-[set main PAR2 archive name]:file:_files' \
      '-b-[set block count]:block count:' \
      '-s-[set block size]:block size:' \
      '-r-[set redundancy level (percent)]:percent:' \
      '-c-[set recovery block count]:count:' \
      '-f-[set first recovery block number]:number:' \
      '-u[uniform recovery file sizes]' \
      '-l[limit size of recovery files]' \
      '-n-[set number of recovery files (max 31)]:count:' \
      '-m-[set memory limit (MB)]:megabytes:' \
      '-t-[set number of threads]:threads:' \
      '-T-[set number of files hashed in parallel]:files:' \
      '*-v[verbose output (repeatable)]' \
      '*-q[quiet mode (repeatable)]' \
      '-p[purge backup files after successful repair]' \
      '-R[recurse into subdirectories]' \
      '-N-[data skipping mode]:n:' \
      '-O[rename-only mode]' \
      '-S-[skip leeway distance]:n:' \
      '-B-[set base path]:path:_files -/' \
      '*:files:_files' && ret=0
    ;;
esac

return ret
