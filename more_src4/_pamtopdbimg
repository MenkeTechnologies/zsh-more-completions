#compdef pamtopdbimg
# Documentation: man pamtopdbimg (Netpbm)
# Source: Netpbm pamtopdbimg — convert a Netpbm image to a Palm Pilot Image Viewer PDB image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-notefile=[attach note from this file]:file:_files' \
    '-title=[image title text]:text:' \
    '(-compressed -uncompressed -maybecompressed)-compressed[compressed format]' \
    '(-compressed -uncompressed -maybecompressed)-uncompressed[uncompressed format]' \
    '(-compressed -uncompressed -maybecompressed)-maybecompressed[smaller of compressed or uncompressed]' \
    '-4depth[16-level (4 bits) grayscale, not default 4-level]' \
    '-fixedtime[fake mtime/ctime for deterministic output]' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:Netpbm file:_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    && ret=0

return ret
