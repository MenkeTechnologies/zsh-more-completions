#compdef models
# Documentation: https://github.com/arimxyer/models
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for arimxyer/models - TUI/CLI for browsing AI models

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'list:list AI models'
  'show:show detailed model information'
  'search:cross-provider model search'
  'providers:list available providers'
  'benchmarks:browse benchmark entries'
  'agents:browse coding agents'
  'status:provider status info'
  'link:create configurable command alias'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--no-color[disable color]' \
  '1:command:->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd) _describe -t commands 'models command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (benchmarks|status)
        _arguments \
          '1:subcommand:(list show)' \
          '*:: :_files' && ret=0
        ;;
      (agents)
        _arguments \
          '1:subcommand:(status latest list-sources)' \
          '*:: :_files' && ret=0
        ;;
      (*) _files && ret=0 ;;
    esac
    ;;
esac

return ret
