#compdef panoglview
# Documentation: https://panoglview.sourceforge.net/
# Reference accessed: 2026-05-20
# Verified: upstream project page at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-f[fullscreen mode]' \
  '*:image:_files' && ret=0

return ret
