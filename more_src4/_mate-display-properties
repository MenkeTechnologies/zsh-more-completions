#compdef mate-display-properties
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/mate-display-properties.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mate-display-properties: per the man page, this program accepts the standard MATE and GTK options;
# no application-specific flags are documented.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options including GTK]' \
  '(- *)--help-gtk[show GTK options]' \
  '(- *)--version[show version]' \
  '--display=[X display]:display:' \
  '*::args:_files' && ret=0
return ret
