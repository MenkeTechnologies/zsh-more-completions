#compdef mktexlsr texhash
# Documentation: mktexlsr --help (TeX Live kpathsea)
# Source: TeX mktexlsr / texhash — rebuild ls-R filename databases.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--dry-run[do not actually update]' \
    '(- *)--help[show help]' \
    '(--quiet --silent --verbose)--quiet[cancel --verbose]' \
    '(--quiet --silent --verbose)--silent[same as --quiet]' \
    '(--quiet --silent --verbose)--verbose[explain what is being done]' \
    '(- *)--version[show version]' \
    '*:directory:_files -/' \
    && ret=0

return ret
