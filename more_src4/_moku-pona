#compdef moku-pona
# _moku-pona — moku-pona small-internet feed reader (Perl); polls gemini/gopher capsules from a sources list and renders newest changes
# upstream: https://alexschroeder.ch/cgit/moku-pona/about/

_moku-pona() {
    local -a sub=(
        'add:add URL to list'
        'remove:remove URL from list'
        'update:fetch all URLs and write changes'
        'list:print list of URLs'
        'feed:render last updates as Gemtext feed'
        'page:render last updates as a page'
        'help:show help'
    )
    _arguments -C \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'moku-pona subcommand' sub ;;
        args)
            case $words[1] in
                add|remove) _arguments '*:URL:_urls' ;;
            esac
            ;;
    esac
}

_moku-pona "$@"
