#compdef prance
# Documentation: https://github.com/jfinkhaeuser/prance
# Reference accessed: 2026-05-23
# Verified: prance --help (prance PyPI).

# Zsh completion for prance - OpenAPI spec compile and validate CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'prance command' \
      'compile[compile spec resolving references]' \
      'convert[convert spec to OpenAPI 3.x]' \
      'validate[validate OpenAPI specs]' && ret=0
    ;;
  args)
    case $line[1] in
      compile)
        _arguments \
          '--resolve[resolve external references]' \
          '--no-resolve[do not resolve references]' \
          '--backend[validation backend]:(flex swagger-spec-validator openapi-spec-validator)' \
          '--strict[strict validation]' \
          '--no-strict[lenient validation]' \
          '--encoding[file encoding override]:encoding:' \
          ':url or path:_files' \
          ':output file:_files' && ret=0
        ;;
      convert)
        _arguments ':url or path:_files' && ret=0
        ;;
      validate)
        _arguments \
          '--output-file[write validated specs to file]:file:_files' \
          '--resolve[resolve references before validation]' \
          '--no-resolve[do not resolve references]' \
          '--backend[validation backend]:(flex swagger-spec-validator openapi-spec-validator)' \
          '--strict[strict validation]' \
          '--no-strict[lenient validation]' \
          '*:url or path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
