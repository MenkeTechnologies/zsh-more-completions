#compdef mrthreshold
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/mrthreshold.html
# Source: MRtrix3/mrtrix3 cmd/mrthreshold.cpp — produce binary mask from image via threshold (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(-percentile -top -bottom)-abs+[absolute intensity threshold]:value:_default' \
    '(-abs -top -bottom)-percentile+[threshold at percentile of intensity (0-100)]:value:_default' \
    '(-abs -percentile -bottom)-top+[select N top-valued voxels]:count:_default' \
    '(-abs -percentile -top)-bottom+[select N bottom-valued voxels]:count:_default' \
    '-allvolumes[single threshold across all volumes]' \
    '-ignorezero[ignore zero values during threshold determination]' \
    '-mask+[compute threshold within mask only]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-comparison+[comparison operator]:op:(lt le ge gt)' \
    '-invert[invert output binary mask]' \
    '-out_masked[mask output by input mask]' \
    '-nan[failed voxels become NaN instead of zero]' \
    '1:input image:_files -g "*.{nii,nii.gz,mif}"' \
    '2::output mask:_files' \
    && ret=0

return ret
