#compdef node2nix

# Zsh completion for node2nix - generate Nix expressions from npm package.json

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-i --input)'{-i,--input}'[input package.json]:file:_files' \
  '(-o --output)'{-o,--output}'[output node-packages.nix]:file:_files' \
  '(-c --composition)'{-c,--composition}'[output default.nix]:file:_files' \
  '(-e --node-env)'{-e,--node-env}'[output node-env.nix]:file:_files' \
  '(-l --lock)'{-l,--lock}'[input package-lock.json]:file:_files' \
  '(-s --supplement-input)'{-s,--supplement-input}'[supplemental input]:file:_files' \
  '--supplement-output[supplemental output]:file:_files' \
  '(-d --development)'{-d,--development}'[include devDependencies]' \
  '--include-peer-dependencies[include peerDependencies]' \
  '--flatten[flatten dependency graph]' \
  '--nodejs-18[use Node.js 18]' \
  '--nodejs-20[use Node.js 20]' \
  '--strip-optional-dependencies[strip optional dependencies]' \
  '--no-bypass-cache[do not bypass Nix cache]' \
  '--no-copy-node-env[do not copy node env]'
