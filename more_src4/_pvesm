#compdef pvesm
# _pvesm — Proxmox Server Solutions pvesm Proxmox VE storage manager CLI (proxmox team, Perl); custom argparse
# upstream: https://git.proxmox.com/?p=pve-manager.git

_pvesm() {
    local -a sub=(
        'add:add a storage'
        'remove:remove a storage'
        'set:update storage configuration'
        'status:show storage status'
        'list:list volumes'
        'free:free a volume'
        'alloc:allocate a volume'
        'path:show volume path'
        'extract-config:extract VM config from backup'
        'export:export a volume'
        'import:import a volume'
        'apiinfo:show api info'
        'cifsscan:scan CIFS shares'
        'glusterfsscan:scan GlusterFS volumes'
        'iscsiscan:scan iSCSI targets'
        'lvmscan:scan LVM volume groups'
        'lvmthinscan:scan LVM thin pools'
        'nfsscan:scan NFS exports'
        'pbsscan:scan Proxmox Backup datastores'
        'zfsscan:scan ZFS pools'
        'scan:scan subcommands'
        'prunebackups:prune backups'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '--output-format=+[format]:f:(text json json-pretty)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pvesm subcommand' sub ;;
        args)
            case $words[1] in
                add) _arguments \
                    '--type=+[type]:t:(dir nfs cifs glusterfs lvm lvmthin iscsi iscsidirect rbd cephfs zfs zfspool pbs btrfs)' \
                    '--path=+[path]:dir:_files -/' \
                    '--export=+[NFS export]:str:' \
                    '--server=+[server host]:host:_hosts' \
                    '--username=+[user]:user:_users' \
                    '--password=+[password]:str:' \
                    '--share=+[smb share]:str:' \
                    '--content=+[content types csv]:str:' \
                    '--nodes=+[node csv]:str:' \
                    '--maxfiles=+[N]:n:' \
                    '--shared=+[bool]:b:(0 1)' \
                    '--disable[create disabled]' \
                    '*:storage id:' ;;
                list) _arguments \
                    '--storage=+[storage id]:str:' \
                    '--vmid=+[VM id]:n:' \
                    '--content=+[content types csv]:str:' ;;
                status) _arguments \
                    '--enabled[only enabled]' \
                    '--storage=+[storage id]:str:' \
                    '--content=+[content type]:c:(images rootdir vztmpl iso backup snippets)' \
                    '--target=+[target node]:str:' ;;
                free|path|extract-config|export|import) _arguments '*:volume id:' ;;
                scan) _arguments '1:scan cmd:(cifs glusterfs iscsi lvm lvmthin nfs pbs zfs)' ;;
                prunebackups) _arguments \
                    '--storage=+[storage id]:str:' \
                    '--type=+[type]:t:(qemu lxc)' \
                    '--vmid=+[VM id]:n:' \
                    '--keep-last=+[N]:n:' \
                    '--keep-hourly=+[N]:n:' \
                    '--keep-daily=+[N]:n:' \
                    '--keep-weekly=+[N]:n:' \
                    '--keep-monthly=+[N]:n:' \
                    '--keep-yearly=+[N]:n:' \
                    '--dry-run[dry run]' ;;
            esac
            ;;
    esac
}

_pvesm "$@"
