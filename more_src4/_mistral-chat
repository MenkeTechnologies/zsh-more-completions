#compdef mistral-chat mistral-demo
# Documentation: upstream README at github.com/mistralai/mistral-inference
# Reference accessed: 2026-05-30
# Mistral inference R56 — local inference for Mistral/Mixtral/Codestral/
# Mathstral/Codestral-Mamba/Mistral-Nemo/Mistral-Small-3.1 models.
# Sister-binary pair. NOTE: upstream archived 2026-05-18; coverage is
# for historical models still in use.

local curcontext="$curcontext" state line ret=1

case $service in

  mistral-chat)
    # mistralai/mistral-inference mistral-chat — interactive chat client
    # for Mistral models. Multi-GPU via `torchrun --nproc-per-node N
    # --no-python mistral-chat $MODEL_DIR [FLAGS]`.
    _arguments -s -S \
      '--instruct[enable instruction-following mode]' \
      '--max_tokens=[maximum tokens to generate]:N:' \
      '--temperature=[response randomness (e.g. 0.35)]:value:' \
      '1:model directory:_directories' \
      && ret=0
    ;;

  mistral-demo)
    # mistralai/mistral-inference mistral-demo — demo script.
    # Surface is minimal upstream; mainly the model-directory positional.
    _arguments -s -S \
      '1:model directory:_directories' \
      && ret=0
    ;;

esac

return ret
