#compdef moloch moloch-capture moloch-viewer
# _moloch — AOL moloch Arkime legacy moloch-capture and moloch-viewer CLIs for large-scale full-packet capture indexing on Elasticsearch with HTTP DNS TLS SMTP SMB protocol decoding (aol team, C); getopt
# upstream: https://github.com/arkime/arkime

_moloch() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[config file]:file:_files -g "*.ini config.ini moloch.ini"' \
        '--config=+[config file]:file:_files -g "*.ini config.ini moloch.ini"' \
        '-n+[node name]:str:' \
        '--node=+[node name]:str:' \
        '-r+[pcap file]:file:_files -g "*.pcap *.cap *.pcapng"' \
        '--read=+[pcap file]:file:_files -g "*.pcap *.cap *.pcapng"' \
        '-R+[pcap directory]:dir:_files -/' \
        '--recursive[recursive]' \
        '--copy[copy pcap]' \
        '--monitor[monitor dir]' \
        '--insecure[insecure]' \
        '--tests[run unit tests]' \
        '--debug[debug]' \
        '-o+[opt=value]:str:' \
        '--option=+[opt=value]:str:' \
        '--port=+[port]:n:' \
        '--host=+[host]:str:' \
        '--dontSaveSPIView[do not save SPIView]' \
        '--flush[flush after each pcap]' \
        '--skipUpgrade[skip upgrade]' \
        '--regressionTests[regression tests]' \
        '--prefix=+[prefix]:str:' \
        '--update[update]' \
        '*:command:'
}

_moloch "$@"
