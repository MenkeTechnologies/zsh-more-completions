#compdef pup
# Documentation: https://github.com/ericchiang/pup
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Zsh completion for pup
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  {-f,--file}'[file to read]:file:_files' \
  '--charset[character set of the input]:charset:' \
  {-c,--color}'[colorize output]' \
  {-p,--plain}'[do not colorize output]' \
  '--pre[preserve preformatted text]' \
  {-n,--number}'[number the results]' \
  {-l,--limit}'[limit number of results]:number:' \
  {-i,--indent}'[number of spaces for indentation]:spaces:' \
  '--version[display version]' \
  {-h,--help}'[display help]' \
  '*:CSS selector:' && ret=0
return ret
