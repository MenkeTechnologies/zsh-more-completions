#compdef mistralrs mistralrs-server mistralrs-bench
# Documentation: https://github.com/EricLBuehler/mistral.rs
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:load a model and open an interactive chat'
  'serve:load a model and expose an OpenAI-compatible HTTP server'
  'bench:benchmark model performance'
  'tune:recommend quantization and device-mapping configurations'
  'quantize:generate UQFF files from models'
  'from-config:load and run from TOML configuration'
  'login:save Hugging Face authentication tokens'
  'doctor:report system and hardware information'
  'cache:manage cached model entries'
  'completions:generate shell completions'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--verbose[verbose output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'mistralrs command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (serve)
        _arguments \
          '(-p --port)'{-p+,--port=}'[server port]:port:' \
          '--serve-ip=[bind address]:host:_hosts' \
          '(-s --seed)'{-s+,--seed=}'[random seed]:n:' \
          '(-l --log)'{-l+,--log=}'[log file]:file:_files' \
          '(-c --chat-template)'{-c+,--chat-template=}'[JINJA chat template file]:file:_files' \
          '(-j --jinja-explicit)'{-j+,--jinja-explicit=}'[explicit JINJA template file]:file:_files -g "*.jinja"' \
          '--token-source=[HF token source]:src:' \
          '(-i --interactive-mode)'{-i,--interactive-mode}'[enter interactive mode]' \
          '--prefix-cache-n=[prefix caches on device]:n:' \
          '(-n --num-device-layers)'{-n+,--num-device-layers=}'[device layers]:layers:' \
          '--isq=[in-situ quantization]:level:' \
          '--pa-gpu-mem=[KV cache GPU memory MBs]:n:' \
          '--pa-gpu-mem-usage=[GPU memory utilization fraction]:n:' \
          '--pa-ctxt-len=[total context length for KV cache]:n:' \
          '--pa-cache-type=[paged cache type]:type:' \
          '--pa-blk-size=[PagedAttention block size]:n:' \
          '--no-paged-attn[disable PagedAttention on CUDA]' \
          '--paged-attn[enable PagedAttention on Metal]' \
          '--cpu[CPU only]' \
          '--enable-search[enable OpenAI-compatible web search]' \
          '--search-embedding-model=[search embedding model]:model:' \
          '--thinking[control thinking mode]' \
          '--mcp-port=[MCP server port]:port:' \
          '--mcp-config=[MCP client config file]:file:_files' && ret=0 ;;
      (run)
        _arguments \
          '--image=[image input file]:file:_files' \
          '--video=[video input file]:file:_files' \
          '--audio=[audio input file]:file:_files' \
          '--input=[one-shot prompt input]:prompt:' \
          '--thinking[control thinking mode]' && ret=0 ;;
      (bench)
        _arguments \
          '--prompt-len=[prompt token length]:n:' \
          '--gen-len=[tokens to generate]:n:' \
          '--iterations=[bench iterations]:n:' \
          '--warmup=[warmup iterations]:n:' && ret=0 ;;
      (tune)
        _arguments \
          '--profile=[hardware profile]:profile:' \
          '--json[output JSON]' \
          '--emit-config=[output config file]:file:_files -g "*.toml"' && ret=0 ;;
      (from-config)
        _arguments \
          '(-f --file)'{-f+,--file=}'[config file]:file:_files -g "*.toml"' && ret=0 ;;
      (completions)
        _arguments '1:shell:(bash zsh fish powershell elvish)' && ret=0 ;;
      (cache)
        _arguments \
          '1:subcommand:(list delete)' \
          '*: :' && ret=0 ;;
      (login)
        _arguments \
          '--token=[HF token]:token:' && ret=0 ;;
      (doctor)
        _arguments \
          '--json[output JSON]' && ret=0 ;;
      (quantize)
        _arguments \
          '*: :' && ret=0 ;;
    esac ;;
esac

return ret
