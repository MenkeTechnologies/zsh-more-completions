#compdef mysql.server
# Documentation: https://dev.mysql.com/doc/refman/8.4/en/mysql-server.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:command:(start stop restart reload force-reload status)' \
  '*:option:' && ret=0

return ret
