#compdef pki-healthcheck
# Documentation: https://github.com/dogtagpki/pki/blob/master/docs/manuals/man8/pki-healthcheck.8.md
# Reference accessed: 2026-05-16
# Verified: upstream docs/manuals/man8/pki-healthcheck.8.md.

# pki-healthcheck: Dogtag PKI health-check framework
local curcontext="$curcontext" ret=1
_arguments -C \
  '--list-sources[list available sources and checks]' \
  '--source=[execute checks within source]:source:' \
  '--check=[execute particular check (requires --source)]:check:' \
  '--output-type=[output format]:type:(json human)' \
  '--failures-only[exclude successful results from output]' \
  '*--severity=[filter by severity]:severity:(SUCCESS WARNING ERROR CRITICAL)' \
  '--debug[generate additional debugging output]' \
  '--output-file=[write output to file]:file:_files' \
  '--indent=[JSON pretty-print indent level]:n:' \
  '--input-file=[convert JSON results to human-readable]:file:_files' && ret=0
return ret
