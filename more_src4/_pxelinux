#compdef pxelinux
# Documentation: https://wiki.syslinux.org/wiki/index.php?title=PXELINUX
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# STUB: pxelinux is a PXE network bootloader (Syslinux project); not a shell CLI.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*::pxelinux args:_files' && ret=0
return ret
