#compdef mount_null
# Documentation: man mount_null(8)
# Source: netbsd/src sbin/mount_null — mount a null (loopback) layer (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-o+[mount options (comma-separated, see mount(8))]:options:_default' \
    '1:target (lower filesystem path):_files -/' \
    '2:mount point:_files -/' \
    && ret=0

return ret
