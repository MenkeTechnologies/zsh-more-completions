#compdef psftostroke
# Documentation: https://www.seasip.info/Unix/PSF/
# Reference accessed: 2026-05-20
# Verified: psftools collection; psftostroke takes a PSF file and writes
# stroked outlines to stdout. STUB completion (no flag set).

# psftostroke: convert PSF console font glyphs to stroked outlines
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:input PSF file:_files -g "*.(psf|psf.gz)"' && ret=0
return ret
