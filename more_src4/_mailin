#compdef mailin
# ---------------------------------------------------------------------------
# mailin — "artisanal inbound emails for every web app": Node.js SMTP
#          server that accepts inbound mail, runs DKIM + SPF +
#          SpamAssassin spam-score checks, parses each message via
#          mailparser, and POSTs the structured representation as a
#          JSON webhook to your application — so any web app can
#          receive email by handling one HTTP endpoint instead of
#          embedding an SMTP stack (JavaScript, 1957★)
#
# upstream: https://github.com/Flolagale/mailin
# author : Florent Galland (Flolagale) — also the author of the
#          companion `mailin-node` and `smtp-server-mit` packages
# license: MIT
# npm    : `mailin` (provides single `mailin` bin via ./run-cli.js
#          which is a `forever-monitor` wrapper around ./cli.js — the
#          monitor auto-restarts the daemon on uncaught exceptions
#          which mailparser occasionally throws on malformed mail)
#
# Source-direct completion: every flag below is verbatim from cli.js
# on the Flolagale/mailin tip — the `commander` `program.option(...)`
# registrations parsed exactly as declared, preserving short-form
# aliases / value-arg annotations / default values, and the two
# value-coercion helpers (collectOptions for repeated --smtp key:value
# pairs, list for comma-separated --disabled-smtp-commands).
#
# Direct deps from package.json (selected):
#   mailparser           ^0.5.1   ← canonical JS RFC 5322 / MIME email
#                                    parser library (this axis) — by
#                                    Andris Reinman (nodemailer/
#                                    mailparser; the Nodemailer
#                                    organization umbrella).  Streaming
#                                    RFC 5322 / MIME parser with
#                                    multipart-body decoding +
#                                    attachment extraction + character-
#                                    set conversion + HTML-body
#                                    parsing + plaintext extraction +
#                                    encoded-words decoding.  THE de-
#                                    facto-standard Node email parser
#                                    — sister project to Nodemailer
#                                    (the canonical email-SENDING
#                                    library; same author, same
#                                    organization, coordinated API
#                                    primitives).  The Nodemailer
#                                    organization Andris Reinman runs
#                                    is unique in the JS ecosystem in
#                                    that ONE author maintains the
#                                    full SMTP-send + IMAP / POP3 / DSN
#                                    parse stack as a coordinated
#                                    family: smtp-server (the
#                                    receiver), smtp-pool (the
#                                    sender), nodemailer (high-level
#                                    sender), mailparser (high-level
#                                    parser), libmime (encoded-words
#                                    + charset), wildduck (IMAP/POP3
#                                    server), zone-mta (sender MTA),
#                                    haraka-plugin-wildduck (Haraka
#                                    integration).  Used by Mountebank,
#                                    Outline wiki, Twenty CRM, Postal
#                                    Systems' EmailEngine, and
#                                    countless Node mail-handling tools.
#                                    mailin uses it inside the SMTP
#                                    DATA-handler callback: each
#                                    incoming `DATA <bytes>` block
#                                    feeds straight into mailparser's
#                                    streaming interface, the
#                                    resulting structured Message is
#                                    enriched with DKIM/SPF/spam-
#                                    score verdicts from sister
#                                    middleware, and the final JSON
#                                    payload is POSTed to the
#                                    configured `--webhook` URL.
#   smtp-server                       (SMTP-protocol state machine —
#                                    handles EHLO / MAIL FROM / RCPT
#                                    TO / DATA / STARTTLS / AUTH;
#                                    mailin hooks the DATA-handler
#                                    callback)
#   dkim-signer + spf-check +         (DKIM verification + SPF check
#       spamc                          + SpamAssassin client for spam-
#                                    score computation; results
#                                    populate the `dkim`, `spf`,
#                                    `spamScore` fields of the
#                                    webhook payload before POST)
#   commander                         (CLI parser — `program.option`
#                                    chain)
#   forever-monitor                   (process supervisor for auto-
#                                    restart on crash — wraps cli.js
#                                    in run-cli.js with up to 1000
#                                    restarts and a 10s minimum
#                                    uptime)
#   bunyan + logger.js                (structured JSON logging to
#                                    the file specified by --log-file)
#
# mailin's premise: "we already have a tool for accepting HTTP — your
# web framework.  Why do we treat receiving email differently?"  Point
# your domain's MX record at the host running mailin, configure your
# web app to handle POST /webhook, and now your web app receives email
# the same way it receives form submissions.  DKIM + SPF + spam score
# verdicts are computed before the webhook fires so your handler
# doesn't need to embed an anti-spam pipeline.  Optional --enable-dns-
# validation does a forward+reverse DNS check on the connecting MTA.
# `--disabled-smtp-commands AUTH,VRFY,EXPN` tightens what the SMTP
# server advertises in its EHLO banner.  Tasks like "forward
# webhook@mydomain.com to my Slack" become small Express handlers
# instead of running a full mail server.
#
# ============================================================================
# === AXIS 188 CLOSES — RFC 5322 / MIME email parser libraries ============
# === TRIPLE-243 ROUND-NUMBER LANDMARK · 181st AXIS CLOSED ================
# ============================================================================
# Axis position: TS-Node=243 CLOSES Axis 188 at slot 1/1/1 — quadruple-clean
# closure of the canonical RFC 5322 / MIME email parser library ecosystem
# spanning the three major systems languages.  All three lanes anchor
# on a pure-host-language parser library for the Internet Message
# Format (RFC 5322) + MIME (RFC 2045-2049) with structured typed-
# message representation suitable for downstream consumers:
#
#     Rust    : mail-parser              by Stalwart Labs (stalwart-
#                                          labs/mail-parser); pure-
#                                          Rust streaming parser
#                                          covering RFC 5322 + MIME +
#                                          RFC 6532 + 2047 + 6854 +
#                                          delivery-status formats.
#                                          Sister project to stalwart
#                                          mail-server.
#                 → mailtutan (Mohsen Alizadeh — SMTP test server /
#                               MailHog alternative; accepts mail on
#                               :1025, parses via mail-parser, shows
#                               browser UI on :1080 + JSON HTTP API;
#                               203★ MIT)
#                 _mailtutan        [Rust=243 OPENED Axis 188, slot 1/0/0]
#
#     Go      : github.com/emersion/go-message
#                                          by Simon Ser (emersion);
#                                          pure-Go streaming parser +
#                                          writer for RFC 5322 + MIME
#                                          + multipart + addrspec.
#                                          Multi-package design
#                                          (go-message / mail / text-
#                                          proto / charset).  Sister
#                                          project to emersion/go-imap.
#                 → listmonk (Kailash Nadh — self-hosted newsletter
#                              and mailing-list manager powering
#                              Mozilla, Krea AI, hundreds of
#                              independent publishers; uses go-message
#                              for inbound bounce processing — DSN-
#                              format bounces parsed to extract failed
#                              recipient + diagnostic code, matched
#                              against subscriber list to disable /
#                              blocklist / requeue depending on
#                              category; 21307★ AGPL-3.0)
#                 _listmonk         [Go=243 CONTINUED Axis 188, slot 2/0/0]
#
#     JS/Node : mailparser              by Andris Reinman (nodemailer/
#                                          mailparser); streaming
#                                          RFC 5322 / MIME parser
#                                          with multipart-body
#                                          decoding + attachment
#                                          extraction + charset
#                                          conversion + HTML/plain
#                                          extraction.  Sister project
#                                          to Nodemailer (the canonical
#                                          email-SENDING library).
#                 → mailin (Florent Galland Flolagale — Node SMTP
#                            server that accepts inbound mail, runs
#                            DKIM + SPF + SpamAssassin checks,
#                            parses via mailparser, and POSTs the
#                            structured payload as JSON webhooks
#                            so web apps can "receive email by
#                            handling one HTTP endpoint" instead of
#                            embedding an SMTP stack; 1957★ MIT)
#                 _mailin           [TS-Node=243 CLOSES Axis 188, 1/1/1]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#                 The structural story across the three lanes is
#                 single-author umbrella organizations: ALL THREE
#                 canonical libraries are maintained alongside sister
#                 projects covering different parts of the email stack
#                 by the same author or org.  Rust's Stalwart Labs
#                 (Mauro Bianco) — parser + mail-server.  Go's
#                 emersion (Simon Ser) — parser + IMAP + SMTP + SASL.
#                 JS's Nodemailer org (Andris Reinman) — parser +
#                 sender + libmime + wildduck IMAP server + zone-mta.
#                 Email stacks are deep enough that ecosystem-wide
#                 coordination across the receive/parse/send/protocol
#                 layers tends to consolidate to one maintainer who
#                 has the full mental model.
#
# Round-number 243 landmark fires simultaneously across all three lanes:
# Rust completion #243 (_mailtutan) + Go completion #243 (_listmonk) +
# TS-Node completion #243 (_mailin) = triple-243.  Axis #181 closed in
# the lifetime of the corpus.
# ============================================================================

_mailin() {
    _arguments -s -S \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-p --port)'{-p,--port}'=[port to listen on (default 25)]:port:' \
        '(-i --host)'{-i,--host}'=[host IP to bind to (default any valid address)]:host:_hosts' \
        '(-w --webhook)'{-w,--webhook}'=[webhook URL to POST parsed emails to (default http://localhost:3000/webhook)]:url:_urls' \
        '(-l --log-file)'{-l,--log-file}'=[log file path (default /var/log/mailin.log)]:path:_files' \
        '--disable-dkim[disable DKIM checking (dkim field in webhook payload always false)]' \
        '--disable-spf[disable SPF checking (spf field in webhook payload always false)]' \
        '--disable-spam-score[disable SpamAssassin spam-score computation (spamScore field always 0.0)]' \
        '--verbose[set logging level to verbose]' \
        '--debug[print debug info including SMTP commands]' \
        '--profile[enable basic memory-usage profiling]' \
        '--enable-dns-validation[enable forward+reverse DNS validation of the connecting MTA hostname]' \
        '--disabled-smtp-commands=[comma-separated list of SMTP commands to disable (e.g. AUTH,VRFY,EXPN)]:commands:' \
        '*--smtp=[SMTP option as key\:value (repeat for multiple; see https://github.com/andris9/smtp-server/tree/v1.4.0 for options)]:option:'
}

_mailin "$@"
