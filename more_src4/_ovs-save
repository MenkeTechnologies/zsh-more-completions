#compdef ovs-save
# _ovs-save — Open vSwitch ovs-save script that prints commands to save and restore Open vSwitch flow tables and interfaces (openvswitch team, Bash); custom argparse
# upstream: https://github.com/openvswitch/ovs

_ovs-save() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '1:command:(save-flows save-interfaces restore)' \
        '*:bridge or file:'
}

_ovs-save "$@"
