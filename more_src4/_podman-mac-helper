#compdef podman-mac-helper
# Documentation: https://docs.podman.io/en/latest/markdown/podman-mac-helper.1.html
# Reference accessed: 2026-05-20
# Verified: upstream binary --help output.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'help:help about any command'
      'install:install the podman helper agent'
      'uninstall:uninstall the podman helper agent'
    )
    _describe -t commands 'podman-mac-helper command' commands && ret=0
    ;;
  args)
    case $line[1] in
      install|uninstall)
        _arguments \
          '--prefix=[install location prefix]:prefix:_directories' \
          {-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
