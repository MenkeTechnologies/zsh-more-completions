#compdef panel-cli
# _panel-cli — HoloViz Panel data app server CLI (HoloViz, Python); argparse
# upstream: https://github.com/holoviz/panel

_panel-cli() {
    local -a sub=(
        'serve:serve panel apps'
        'convert:convert to pyodide/pyscript'
        'oauth-secret:generate oauth secret'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'panel subcommand' sub ;;
        args)
            case $words[1] in
                serve) _arguments \
                    '--port=+[port]:port:' \
                    '--address=+[address]:host:_hosts' \
                    '--unix-socket=+[unix socket path]:file:_files' \
                    '--allow-websocket-origin=+[allowed websocket origin]:host:_hosts' \
                    '--prefix=+[prefix]:str:' \
                    '--keep-alive=+[keep alive ms]:n:' \
                    '--check-unused-sessions=+[check unused sessions ms]:n:' \
                    '--unused-session-lifetime=+[unused session lifetime ms]:n:' \
                    '--stats-log-frequency=+[stats log frequency ms]:n:' \
                    '--mem-log-frequency=+[mem log frequency ms]:n:' \
                    '--use-xheaders[use xheaders]' \
                    '--ssl-certfile=+[ssl cert]:file:_files' \
                    '--ssl-keyfile=+[ssl key]:file:_files' \
                    '--session-ids=+[session ids]:list:' \
                    '--index=+[index]:file:_files' \
                    '--disable-index[disable index]' \
                    '--disable-index-redirect[disable index redirect]' \
                    '--num-procs=+[num procs]:n:' \
                    '--websocket-max-message-size=+[ws max msg size]:n:' \
                    '--websocket-compression-level=+[ws compression level]:n:' \
                    '--websocket-ping-interval=+[ws ping interval ms]:n:' \
                    '--websocket-ping-timeout=+[ws ping timeout ms]:n:' \
                    '--glob[glob expand args]' \
                    '--static-dirs=+[static dirs json]:str:' \
                    '--basic-auth=+[basic auth user:pwd]:str:' \
                    '--cookie-secret=+[cookie secret]:str:' \
                    '--cookie-path=+[cookie path]:str:' \
                    '--oauth-provider=+[oauth provider]:p:(github google azure auth0 generic okta gitlab bitbucket)' \
                    '--oauth-key=+[oauth key]:str:' \
                    '--oauth-secret=+[oauth secret]:str:' \
                    '--oauth-extra-params=+[oauth extra params json]:str:' \
                    '--oauth-redirect-uri=+[oauth redirect uri]:url:_urls' \
                    '--oauth-jwt-user=+[oauth jwt user]:str:' \
                    '--oauth-encryption-key=+[oauth encryption key]:str:' \
                    '--auth-template=+[auth template]:file:_files' \
                    '--basic-login-template=+[basic login template]:file:_files' \
                    '--logout-template=+[logout template]:file:_files' \
                    '--rest-provider=+[rest provider]:p:(param tranquilizer)' \
                    '--rest-endpoint=+[rest endpoint]:str:' \
                    '--rest-session-info=+[rest session info]:b:(true false)' \
                    '--admin[enable admin page]' \
                    '--admin-endpoint=+[admin endpoint]:str:' \
                    '--admin-log-level=+[admin log level]:level:(debug info warn error critical)' \
                    '--profiler=+[profiler]:p:(pyinstrument snakeviz memray)' \
                    '--autoreload[autoreload]' \
                    '--num-threads=+[num threads]:n:' \
                    '--setup=+[setup script]:file:_files' \
                    '--warm[warm sessions]' \
                    '*:script:_files -g "*.py *.ipynb"' ;;
                convert) _arguments \
                    '--to=+[target]:t:(pyodide pyscript pyodide-worker pyscript-worker)' \
                    '--out=+[output dir]:dir:_files -/' \
                    '--title=+[title]:str:' \
                    '--prerender[prerender]' \
                    '--watch[watch]' \
                    '--build-pwa[build PWA]' \
                    '--pwa-config=+[pwa config json]:str:' \
                    '--http-patch=+[http patch]:str:' \
                    '--runtime=+[runtime version]:str:' \
                    '--requirements=+[requirements list]:str:' \
                    '*:script:_files -g "*.py *.ipynb"' ;;
            esac
            ;;
    esac
}

_panel-cli "$@"
