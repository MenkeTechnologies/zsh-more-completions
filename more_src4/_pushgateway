#compdef pushgateway
# Documentation: https://github.com/prometheus/pushgateway
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--web.listen-address=[address to listen on]:address:' \
  '--web.telemetry-path=[path for metrics]:path:' \
  '--web.config.file=[TLS/auth config file]:file:_files' \
  '--web.external-url=[external URL for the pushgateway]:url:' \
  '--web.route-prefix=[prefix for web routes]:prefix:' \
  '--web.enable-admin-api[enable admin API endpoints]' \
  '--web.enable-lifecycle[enable lifecycle API endpoints]' \
  '--log.level=[log level]:level:(debug info warn error)' \
  '--log.format=[log format]:format:(logfmt json)' \
  '--persistence.file=[file to persist metrics]:file:_files' \
  '--persistence.interval=[minimum interval between persistence writes]:duration:' \
  '--push.disable-consistency-check[disable label consistency check on push]' && ret=0

return ret
