#compdef pactl
# Documentation: https://manpages.debian.org/pactl.1
# Source: PulseAudio (and PipeWire-Pulse) control CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '(-s --server)'{-s+,--server=}'[server to connect to]:server:' \
    '(-f --format)'{-f+,--format=}'[output format]:fmt:(text json)' \
    '(-n --client-name)'{-n+,--client-name=}'[client name passed to the server]:name:' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'stat:dump memory-usage statistics of the daemon'
            'info:dump daemon info'
            'list:list loaded modules / sinks / sources / streams / etc'
            'exit:ask the server to terminate'
            'upload-sample:upload a sound file into the sample cache'
            'play-sample:play a sample from the sample cache'
            'remove-sample:remove a sample from the sample cache'
            'load-module:load a module with arguments'
            'unload-module:unload module by id or name'
            'move-sink-input:move playback stream to a different sink'
            'move-source-output:move recording stream to a different source'
            'suspend-sink:suspend or resume a sink (true/false)'
            'suspend-source:suspend or resume a source (true/false)'
            'set-card-profile:set card profile'
            'get-default-sink:return the default sink symbolic name'
            'set-default-sink:set the default sink'
            'set-sink-port:set the active port of a sink'
            'get-default-source:return the default source symbolic name'
            'set-default-source:set the default source'
            'set-source-port:set the active port of a source'
            'set-port-latency-offset:set per-port latency offset (card port offset)'
            'get-sink-volume:get sink volume'
            'set-sink-volume:set sink volume'
            'get-source-volume:get source volume'
            'set-source-volume:set source volume'
            'set-sink-input-volume:set a playback-stream volume'
            'set-source-output-volume:set a recording-stream volume'
            'get-sink-mute:get sink mute state'
            'set-sink-mute:set sink mute state (1/0/toggle)'
            'get-source-mute:get source mute state'
            'set-source-mute:set source mute state (1/0/toggle)'
            'set-sink-input-mute:set playback-stream mute state'
            'set-source-output-mute:set recording-stream mute state'
            'set-sink-formats:set supported sink formats'
            'send-message:send a message to an object'
            'subscribe:subscribe to events and keep running'
        )
        _describe -t subcmds 'pactl command' subcmds && ret=0
        ;;
    args)
        case $words[1] in
            list)
                local -a list_types=(short modules sinks sources sink-inputs source-outputs clients samples cards)
                _describe -t types 'list type' list_types && ret=0
                ;;
            upload-sample|play-sample|remove-sample|load-module)
                _files && ret=0
                ;;
            *)
                _default && ret=0
                ;;
        esac
        ;;
esac

return ret
