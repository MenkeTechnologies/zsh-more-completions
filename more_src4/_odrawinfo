#compdef odrawinfo
# Documentation: https://github.com/libyal/libodraw
# Source: libyal/libodraw manuals/odrawinfo.1 — display info about an Optical Disc Raw image (CUE/TOC + .bin/.img tracks).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[show help]' \
    '-i[ignore data file(s)]' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '*:CUE/TOC file:_files' \
    && ret=0

return ret
