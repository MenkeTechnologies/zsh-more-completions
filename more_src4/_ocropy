#compdef ocropy ocropus
# Documentation: https://github.com/ocropus/ocropy
# Reference accessed: 2026-05-16
# Verified: upstream ocropus/ocropy GitHub repository archived 2026-04-27;
# project unmaintained. There is no single `ocropy` binary - the toolkit
# ships ocropus-nlbin (binarization), ocropus-gpageseg (layout),
# ocropus-rpred (recognition), ocropus-hocr (hOCR output) and
# ocropus-linegen (line generation). Each has its own argparse help.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# ocropy: archived Python OCR toolkit (use ocropus-* binaries)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:image:_files' && ret=0
return ret
