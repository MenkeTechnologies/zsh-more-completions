#compdef ossutil ossutil64 ossutilmac64
# _ossutil — Alibaba Cloud Object Storage Service CLI (aliyun/ossutil)
# upstream: https://github.com/aliyun/ossutil
# Subcommand names harvested from each lib/*.go file (Command.name field).

_ossutil() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '(-e --endpoint)'{-e+,--endpoint=}'[OSS endpoint]:endpoint:' \
        '(-i --access-key-id)'{-i+,--access-key-id=}'[access key ID]:id:' \
        '(-k --access-key-secret)'{-k+,--access-key-secret=}'[access key secret]:key:' \
        '(-t --sts-token)'{-t+,--sts-token=}'[STS token]:token:' \
        '(-c --config-file)'{-c+,--config-file=}'[config file path]:file:_files' \
        '(-L --language)'{-L+,--language=}'[output language]:lang:(CH EN)' \
        '--loglevel=[log verbosity]:level:(info debug)' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'help:print command help'
                'config:configure credentials and endpoint'
                'mb:make bucket'
                'ls:list buckets/objects'
                'rm:remove buckets/objects'
                'stat:show bucket/object metadata'
                'cp:copy local↔OSS↔OSS files'
                'sync:synchronize directory and bucket'
                'cat:print object contents'
                'du:bucket/object size summary'
                'mkdir:create a directory in a bucket'
                'restore:restore archived objects'
                'sign:generate a presigned URL'
                'listpart:list multipart uploads/parts'
                'probe:diagnostic probes'
                'update:self-update ossutil'
                'hash:compute object hash'
                'appendfromfile:append file contents to an object'
                'set-acl:set ACL on bucket or object'
                'set-meta:set object metadata'
                'cors:bucket CORS rules'
                'cors-options:CORS preflight options'
                'lifecycle:bucket lifecycle rules'
                'logging:bucket access logging'
                'website:bucket static website hosting'
                'worm:bucket WORM policy'
                'inventory:bucket inventory'
                'referer:bucket referer policy'
                'replication:bucket replication'
                'resource-group:bucket resource group'
                'style:bucket image style rules'
                'access-monitor:bucket access monitoring'
                'bucket-cname:bucket custom domain'
                'bucket-encryption:bucket default encryption'
                'bucket-policy:bucket policy'
                'bucket-qos:bucket QoS'
                'bucket-tagging:bucket tags'
                'bucket-versioning:bucket versioning'
                'object-tagging:object tags'
                'create-symlink:create symlink object'
                'read-symlink:read symlink object target'
                'request-payment:bucket requester-pays setting'
                'revert-versioning:revert versioning state'
                'user-qos:user-level QoS'
                'getallpartsize:list all multipart upload sizes'
                'lcb:list cross-region buckets'
                'lrb:list region buckets'
            )
            _describe -t commands command cmds
            ;;
        args)
            _arguments \
                '(-f --force)'{-f,--force}'[force operation, no prompt]' \
                '(-r --recursive)'{-r,--recursive}'[recurse into directories/prefixes]' \
                '--parallel=[concurrency]:n:' \
                '--part-size=[multipart part size (bytes)]:bytes:' \
                '--retry-times=[retry attempts on failure]:n:' \
                '*:source/destination:_files'
            ;;
    esac
}

_ossutil "$@"
