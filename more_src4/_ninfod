#compdef ninfod
# Documentation: man ninfod(8)
# Source: dgibson/iputils ninfod/ninfod.c (master) — Node Information Daemon for IPv6 (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d[debug mode]' \
    '-v[verbose]' \
    '-p+[PID file]:file:_files' \
    '-u+[user to drop privileges to]:user:_users' \
    '-h[show help]' \
    && ret=0

return ret
