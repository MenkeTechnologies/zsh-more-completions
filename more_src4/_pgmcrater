#compdef pgmcrater
# Documentation: man pgmcrater (Netpbm)
# Source: synthesise a cratered landscape PGM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-number=[number of craters]:n:' \
    '(-height -ysize)-height=[output height]:s:' \
    '(-height -ysize)-ysize=[output height]:s:' \
    '(-width -xsize)-width=[output width]:s:' \
    '(-width -xsize)-xsize=[output width]:s:' \
    '-gamma=[output gamma]:g:' \
    '-randomseed=[random seed]:integer:' \
    '-quiet[suppress libnetpbm chatter]' \
    && ret=0

return ret
