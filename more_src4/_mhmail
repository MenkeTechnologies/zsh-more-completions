#compdef mhmail
# Documentation: man mhmail(1)
# Source: nmh mhmail (man) — send mail (Berkeley mail replacement) (sh).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-to+[recipient addresses]:addrs:_default' \
    '*-attach+[attach file]:file:_files' \
    '-body+[message body]:text:_default' \
    '*-cc+[cc addresses]:addrs:_default' \
    '-from+[sender address]:from:_default' \
    '*-headerfield+[extra header (name\:value)]:header:_default' \
    '-subject+[subject]:subject:_default' \
    '-resent[mark message as resent]' \
    '(-send -nosend)-send[send the message]' \
    '(-send -nosend)-nosend[do not send]' \
    '-profile+[profile switches for send]:switches:_default' \
    '-version[show version]' \
    '-help[show help]' \
    '*::address:_email_addresses' \
    && ret=0

return ret
