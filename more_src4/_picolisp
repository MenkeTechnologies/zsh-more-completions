#compdef picolisp pil
# Documentation: https://software-lab.de/doc/ref.html
# Reference accessed: 2026-05-20
# Verified: upstream PicoLisp reference. The executable explicitly
# does NOT accept traditional command-line flags. Arguments are
# either file paths (.l) to execute, "-FUNCTION" calls, "+" to enable
# debug mode, or "-" to halt argument processing. STUB completing
# file arguments only.

local curcontext="$curcontext" ret=1

_arguments -C \
  '*:file or -expression:_files -g "*.l"' && ret=0

return ret
