#compdef midicat
# _midicat — sndio MIDI manipulation tool (OpenBSD)
# upstream: https://man.openbsd.org/midicat.1
# Flags from midicat(1) man page.

_midicat() {
    _arguments \
        '-d[dump transferred data as hex on stderr]' \
        '-i+[read MIDI data from file (- for stdin)]:file:_files' \
        '-o+[write MIDI data to file (- for stdout)]:file:_files' \
        '*-q+[sndio MIDI port (input then output)]:port:'
}

_midicat "$@"
