#compdef ovito
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/ovito.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# OVITO: scientific visualisation/analysis for atomistic data
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--nogui[run without GUI]' \
  '--script[execute Python script]:file:_files -g "*.py"' \
  '--scriptarg[pass arg to script]:arg:' \
  '--exec[execute Python statement]:stmt:' \
  '--data-load[load data file at startup]:file:_files' \
  '--render-output[render to image/movie file]:file:_files' \
  '--render-frame[frame number to render]:n:' \
  '--render-resolution[render resolution WxH]:res:' \
  '--render-color-depth[render colour depth]:depth:' \
  '--anim[render animation range]:start-end:' \
  '--keep-tmpdir[do not delete temp files]' \
  '--debug[enable debug output]' \
  '--log-output[redirect log to file]:file:_files' \
  '*:data file:_files -g "*.(dump|xyz|cfg|car|imd|lammpsdump|gsd|pdb|cif|vasp|POSCAR|FHI)"' && ret=0
return ret
