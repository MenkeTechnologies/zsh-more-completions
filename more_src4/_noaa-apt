#compdef noaa-apt
# ---------------------------------------------------------------------------
# noaa-apt — NOAA APT weather satellite image decoder (Rust, 655★)
#
# upstream: https://github.com/martinber/noaa-apt
# author : Martín Bernardi (martinber, martinber.710@gmail.com)
# license: GPL-3.0
#
# Source-direct completion: every flag below is verbatim from src/config.rs
# on the martinber/noaa-apt v1.4.1 tip — `argparse` (Rust) `parser.refer(...)
# .add_option(...)` registrations parsed exactly as declared.
#
# Direct deps from Cargo.toml (selected):
#   image            0.24.7   ← canonical Rust pure-Rust image processing
#                              library (this axis) — by the image-rs
#                              collective (Andrew Hickman + Piston devs
#                              + Niklas Korz + many contributors at
#                              github.com/image-rs); pure-Rust readers
#                              and writers for PNG, JPEG, GIF, WebP,
#                              TIFF, BMP, ICO, plus core RGB/RGBA buffer
#                              types + pixel-iterator combinators.
#                              noaa-apt uses image::ImageBuffer to compose
#                              the decoded APT scan into a PNG.
#   rustfft          6.1.0    (FFT for demodulation/resampling)
#   hound            3.5.1    (WAV reader/writer — APT signals arrive as
#                              recorded WAV files from SDR receivers)
#   chrono           0.4.31   (date/time for orbit calculations)
#   shapefile        0.4.0    (ESRI shapefile reader for country/state/
#                              lake overlays)
#   satellite        (richinfante/satellite-rs — TLE-based satellite
#                    orbit prediction)
#   gtk + gdk + gdk-pixbuf + gio + glib (GTK GUI when `--features gui`
#                                        is enabled; default-on)
#   argparse         0.2.2    (Tailhook's argparse — Python-argparse-
#                              inspired Rust CLI parser, predates clap's
#                              dominance)
#   reqwest          0.11.22  (HTTP for fetching weather.txt TLE from
#                              celestrak.com when cache is stale)
#   lab              0.11.0   (CIELAB color space for false-color rendering)
#   line_drawing     1.0.0    (Bresenham/Wu line raster for map overlays)
#   simple_logger    4.3.0
#
# noaa-apt decodes APT (Automatic Picture Transmission) weather satellite
# imagery from NOAA-15/18/19 — the legacy 4 kHz AM-modulated 2400 Hz
# subcarrier signal that anyone with a $25 RTL-SDR dongle can receive.
# Workflow: SDR captures a pass to WAV, noaa-apt demodulates +
# synchronizes + decodes to a 2080×N PNG with both visible and IR
# channels side-by-side.  Optional false-color synthesis using a PNG
# palette + map overlay via TLE-based orbit calculations + scene rotation
# for South-to-North passes.  Without arguments launches the GTK GUI;
# pass any positional or `--resample` to run CLI mode.
#
# === AXIS 175 OPENER — pure-language image processing libraries ==========
# Axis position: Rust=230 OPENS Axis 175 at slot 1/0/0.  Canonical Rust
# pure-language image processing library is `image` from the image-rs
# collective (github.com/image-rs/image) — pure-Rust readers and writers
# for PNG (via Andrew Hickman's png crate), JPEG (via the jpeg-decoder/
# jpeg-encoder crates), GIF (via Niklas Korz's gif crate), WebP, TIFF,
# BMP, ICO, plus core RGB/RGBA buffer types and pixel-iterator
# combinators for transforms (resize, crop, rotate, filter).  No
# libpng/libjpeg/giflib system dependencies.  Used by oculante, photon,
# imager, menyoki, kornia-rs, noaa-apt, paper-age (via printpdf's
# embedded_images feature), and most modern Rust CLIs that touch raster
# images.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=230     ← THIS FILE              (axis 175 OPENS, slot 1/0/0)
#   Go=230       ← next round              (axis 175 continues, slot 2/0/0)
#   TS-Node=230  ← round after             (axis 175 CLOSES at triple-230, slot 1/1/1)
# ---------------------------------------------------------------------------

_noaa-apt() {
    _arguments -s \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version and quit]' \
        '(-d --debug)'{-d,--debug}'[print debugging messages]' \
        '(-q --quiet)'{-q,--quiet}'[don'\''t print info messages]' \
        '(-o --output)'{-o,--output=}'[output path (default ./output.png for decode, ./output.wav for resample)]:FILENAME:_files' \
        '(-r --resample)'{-r,--resample=}'[resample WAV to a given sample rate (no APT decode)]:SAMPLE_RATE (Hz):' \
        '--no-sync[disable syncing — useful when sync frames are noisy enough that syncing does more harm than good]' \
        '(-c --contrast)'{-c,--contrast=}'[contrast adjustment method for decode (default 98_percent)]:method:(98_percent telemetry histogram disable)' \
        '(-s --sat)'{-s,--sat=}'[indicate satellite name (default: guess from filename, else noaa_19)]:satellite:(noaa_15 noaa_18 noaa_19)' \
        '(-m --map)'{-m,--map=}'[enable map overlay using TLE orbit calculations]:MAP_MODE:(yes no)' \
        '--map-yaw=[yaw correction for map overlay in degrees (default 0)]:YAW degrees:' \
        '--map-hscale=[horizontal map scale correction (default 1)]:HSCALE:' \
        '--map-vscale=[vertical map scale correction (default 1)]:VSCALE:' \
        '(-R --rotate)'{-R,--rotate=}'[rotate image (useful for South-to-North passes; auto uses orbit + reception time to decide)]:rotation:(auto yes no)' \
        '(-F --false-color)'{-F,--false-color}'[attempt to produce a colored image (pair with --contrast 98_percent or telemetry; see --palette)]' \
        '(-P --palette)'{-P,--palette=}'[palette PNG for false color (256×256, X=channel A brightness, Y=channel B; built-ins in res/palettes/)]:palette PNG:_files -g "*.(png|PNG)"' \
        '(-t --start-time)'{-t,--start-time=}'[recording start time in RFC 3339 (e.g. 1996-12-19T16:39:57-08:00); inferred from filename or mtime otherwise]:RFC3339 datetime:' \
        '(-T --tle)'{-T,--tle=}'[load TLE from path; downloads cached weather.txt from celestrak.com if cache >1 week old]:TLE file:_files' \
        '(-p --profile)'{-p,--profile=}'[profile from settings file]:profile:(standard fast slow)' \
        '--wav-steps[export a WAV for every step of decoding for debugging (cwd, named {number}_{description}.wav)]' \
        '--export-resample-filtered[export expanded+filtered signal on resampling step — VERY expensive (GiB of RAM+disk); requires --wav-steps]' \
        '--rotate-image[DEPRECATED: use --rotate instead]' \
        '*:input WAV file (omit to launch GTK GUI):_files -g "*.(wav|WAV)"'
}

_noaa-apt "$@"
