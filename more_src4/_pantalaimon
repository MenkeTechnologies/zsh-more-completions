#compdef pantalaimon
# _pantalaimon — E2E-aware Matrix daemon (matrix-org/pantalaimon)
# upstream: https://github.com/matrix-org/pantalaimon
# Flags from pantalaimon/main.py (click).

_pantalaimon() {
    _arguments \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '--log-level=[log level]:level:(error warning info debug)' \
        '--debug-encryption[enable encryption debug logging]' \
        '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.conf"' \
        '--data-path=[data directory]:dir:_files -/'
}

_pantalaimon "$@"
