#compdef mcp-remote
# Documentation: https://github.com/geelen/mcp-remote
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '*--header=[add custom HTTP header (Name: value, repeatable)]:header' \
  '--resource=[isolate OAuth sessions for multiple server instances]:resource' \
  '--static-oauth-client-metadata=[OAuth metadata JSON or @filepath]:metadata' \
  '--static-oauth-client-info=[pre-registered OAuth client credentials]:info' \
  '--transport=[transport strategy]:transport:(http-first sse-first http-only sse-only)' \
  '--host=[OAuth callback hostname (default localhost)]:host' \
  '--allow-http[enable HTTP connections (trusted networks only)]' \
  '--enable-proxy[use environment proxy settings]' \
  '*--ignore-tool=[filter tools matching pattern (supports * wildcard)]:pattern' \
  '--debug[enable detailed debugging logs]' \
  '--silent[suppress default logs]' \
  '--auth-timeout=[OAuth callback timeout in seconds]:seconds' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::server URL or args:_default'
