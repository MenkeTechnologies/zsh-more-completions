#compdef npfctl
# Documentation: man npfctl(8)
# Source: netbsd/src usr.sbin/npf/npfctl — NPF packet filter control (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:command:(start stop reload flush show validate rule table save load stats debug list)' \
    '*::argument:_files' \
    && ret=0

return ret
