#compdef mtr-packet
# Documentation: https://manpages.ubuntu.com/manpages/focal/en/man8/mtr-packet.8.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mtr-packet: send and receive network probes (helper for mtr, driven over
# stdin/stdout). Per the manpage there are no command-line options beyond
# the standard help/version flags; commands are read from stdin.

local -a arguments

arguments=(
    '(- *)--help[show help]'
    '(- *)-h[show help]'
    '(- *)--version[show version]'
    '(- *)-v[show version]'
)

_arguments -s -S $arguments
