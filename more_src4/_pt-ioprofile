#compdef pt-ioprofile
# Documentation: https://docs.percona.com/percona-toolkit/pt-ioprofile.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--aggregate=[aggregation function]:fn:(sum avg)' \
  '--cell=[cell content]:cell:(count sizes times)' \
  '--group-by=[group by]:by:(all filename pid)' \
  '--profile-pid=[profile this PID (overrides --profile-process)]:pid:' \
  '--profile-process=[profile this process name]:name:' \
  '--run-time=[profiling duration seconds]:sec:' \
  '--save-samples=[save samples file]:file:_files' \
  '*:trace_file:_files' && ret=0

return ret
