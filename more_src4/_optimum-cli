#compdef optimum-cli
# Documentation: https://github.com/huggingface/optimum
# Reference accessed: 2026-05-23
# Verified: optimum-cli --help (Hugging Face Optimum CLI).

# Zsh completion for optimum-cli - Hugging Face Optimum model export utilities

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'optimum-cli command' \
      'export[export PyTorch models to other formats]' \
      'env[show environment information]' && ret=0
    ;;
  args)
    case $line[1] in
      export|env)
        _arguments '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
