#compdef parlay
# Documentation: https://github.com/snyk/parlay/blob/main/README.md
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'deps:commands for using parlay with deps.dev'
  'ecosystems:commands for using parlay with ecosyste.ms'
  'scorecard:commands for using parlay with OpenSSF Scorecard'
  'snyk:commands for using parlay with Snyk'
  'help:help about any command'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--debug[enable debug logging]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'parlay command' commands && ret=0 ;;
  args)
    case ${line[1]} in
      (ecosystems|scorecard|snyk|deps)
        _values 'subcommand' enrich package repo && ret=0
        ;;
      (*) _default && ret=0 ;;
    esac
    ;;
esac

return ret
