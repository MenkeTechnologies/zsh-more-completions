#compdef pw-cli
# Documentation: https://docs.pipewire.org/page_man_pw-cli_1.html
# Source: PipeWire CLI for introspecting and manipulating the local/remote PipeWire instance.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'help:show quick help on commands available'
            'h:show quick help on commands available'
            'quit:exit the application'
            'q:exit the application'
            'list-vars:list all currently known variables and their type'
            'load-module:load a module in the local instance'
            'unload-module:unload a module by its variable'
            'list-objects:list the objects of the current instance'
            'info:get information about a specific object or all objects'
            'connect:connect to a remote instance'
            'disconnect:disconnect from a remote instance'
            'list-remotes:list all remote instances'
            'switch-remote:make a specified remote the current instance'
            'create-node:create a node from a factory'
            'export-node:export a node to another instance'
            'create-device:create a device from a factory'
            'create-link:create a link between nodes and ports'
            'destroy:destroy a global object'
            'enum-params:enumerate object parameters'
            'set-param:set object parameters'
            'permissions:set client permissions'
            'get-permissions:retrieve client permissions'
            'send-command:send a command to an object'
        )
        _describe -t subcmds 'pw-cli command' subcmds && ret=0
        ;;
    args)
        _files
        ;;
esac

return ret
