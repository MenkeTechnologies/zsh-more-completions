#compdef prestop-checker
# _prestop-checker — TiDB Operator pre-stop drain checker (TiKV/TiCDC)
# upstream: https://github.com/pingcap/tidb-operator
# Flags from cmd/prestop-checker/main.go on tip.

_prestop-checker() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--mode=[component mode]:mode:(tikv ticdc)' \
        '--pd=[PD URL]:url:_urls' \
        '--tikv-status-addr=[TiKV status address]:url:_urls' \
        '--ticdc-status-addr=[TiCDC status address]:url:_urls' \
        '--tls=[enable TLS]:bool:(true false)' \
        '--ca=[CA cert file path]:file:_files' \
        '--cert=[client cert file path]:file:_files' \
        '--key=[client key file path]:file:_files'
}

_prestop-checker "$@"
