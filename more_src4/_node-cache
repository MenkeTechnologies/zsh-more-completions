#compdef node-cache
# _node-cache — NodeLocal DNSCache daemon (runs CoreDNS as a node-local cache for kube-dns/CoreDNS upstream)
# upstream: https://github.com/kubernetes-sigs/node-local-dns
# Flags from cmd/node-cache/main.go on tip; deeper config via Corefile.

_node-cache() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--localip=[csv of IPs to bind dnscache to]:csv:' \
        '--setupinterface=[setup the network interface]:bool:(true false)' \
        '--interfacename=[name of the interface to create]:name:' \
        '--syncinterval=[interval to check iptables rules (seconds)]:s:' \
        '--metrics-listen-address=[address to serve metrics on]:addr:' \
        '--setupiptables=[setup iptables rules]:bool:(true false)' \
        '--basecorefile=[path to the template Corefile]:file:_files' \
        '--corefile=[path to the Corefile]:file:_files' \
        '--kubednscm=[path where the kube-dns ConfigMap is mounted]:dir:_files -/' \
        '--upstreamsvc=[Service name whose ClusterIP is upstream]:svc:' \
        '--health-port=[port used by the health plugin]:port:' \
        '--skipteardown[skip iptables-rule teardown on exit]' \
        '--reloadwithsignal[send SIGUSR1 to self to reload CoreDNS]'
}

_node-cache "$@"
