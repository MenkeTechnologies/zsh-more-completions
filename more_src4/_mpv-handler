#compdef mpv-handler
# _mpv-handler — URL handler that dispatches mpv:// URLs to mpv + yt-dlp (akiirui/mpv-handler)
# upstream: https://github.com/akiirui/mpv-handler
# Flags from src/main.rs (takes a single URL argument; no flags).

_mpv-handler() {
    _arguments \
        '1:mpv:// URL:'
}

_mpv-handler "$@"
