#compdef poop
# Documentation: https://github.com/andrewrk/poop
# Reference accessed: 2026-05-27
# Verified: upstream src/main.zig usage_text and argument parser (andrewrk/poop)

# Zsh completion for poop (Performance Of Our Programs benchmark)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show usage information]' \
  '(-d --duration)'{-d+,--duration=}'[how long to repeatedly sample each command, ms (default 5000)]:ms:' \
  '--color=[color output mode]:when:(auto never ansi)' \
  '(-f --allow-failures)'{-f,--allow-failures}'[compare performance even when commands exit non-zero]' \
  '*:command:_command_names -e' && ret=0

return ret
