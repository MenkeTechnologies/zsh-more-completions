#compdef ntp-keygen
# _ntp-keygen — ntp-project ntp-keygen (Autokey + symmetric key generator for ntpd; generates RSA/DSA/MD5/IFF/GQ/MV cryptographic keys + X.509 certificates)
# upstream: https://github.com/ntp-project/ntp
# Flags from util/ntp-keygen-opts.def on tip (AutoOpts).

_ntp-keygen() {
    _arguments \
        '(- *)'{-?,--help}'[show help]' \
        '(- *)--version[show version and exit]' \
        '(-b --imbits)'{-b+,--imbits=}'[identity modulus bits]:n:' \
        '(-c --certificate)'{-c+,--certificate=}'[certificate scheme]:scheme:(RSA-MD2 RSA-MD5 RSA-MDC2 RSA-SHA RSA-SHA1 RSA-RIPEMD160 DSA-SHA DSA-SHA1)' \
        '(-C --cipher)'{-C+,--cipher=}'[private-key cipher]:cipher:' \
        '(-e --id)'{-e,--id}'[write IFF/GQ identity keys]' \
        '(-G --gq)'{-G,--gq}'[generate GQ parameters and keys]' \
        '(-H --host)'{-H,--host}'[generate RSA host key]' \
        '(-I --iffkey)'{-I,--iffkey}'[generate IFF parameters]' \
        '(-i --ident)'{-i+,--ident=}'[set Autokey group name]:name:' \
        '(-l --lifetime)'{-l+,--lifetime=}'[certificate lifetime (days)]:days:' \
        '(-m --modulus)'{-m+,--modulus=}'[prime modulus bits]:n:' \
        '(-M --md5key)'{-M,--md5key}'[generate symmetric (MD5) keys]' \
        '(-P --pvt)'{-P,--pvt}'[generate PC private certificate]' \
        '(-p --password)'{-p+,--password=}'[local private password]:pwd:' \
        '(-q --export)'{-q+,--export=}'[export IFF/GQ group keys with this password]:pwd:' \
        '(-s --subject)'{-s+,--subject=}'[host[/group] name for the certificate subject]:subject:' \
        '(-S --sign)'{-S+,--sign=}'[generate sign key (RSA or DSA)]:alg:(RSA DSA)' \
        '(-T --trusted)'{-T,--trusted}'[mark as trusted certificate (TC scheme)]' \
        '(-V --mv)'{-V+,--mv=}'[generate N MV parameters]:n:' \
        '(-v --mv)'{-v+,--mv=}'[update N MV keys]:n:'
}

_ntp-keygen "$@"
