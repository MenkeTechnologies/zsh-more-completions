#compdef mdbook-termlink
# _mdbook-termlink — glossary term auto-linker for mdbook (rubentalstra/mdbook-termlink)
# upstream: https://github.com/rubentalstra/mdbook-termlink
# Subcommands from src/main.rs.

_mdbook-termlink() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'supports:check whether a renderer is supported'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                supports) _arguments '1:renderer:(html)' ;;
            esac
            ;;
    esac
}

_mdbook-termlink "$@"
