#compdef protoc-gen-go-grpc
# Documentation: https://github.com/grpc/grpc-go
# Reference accessed: 2026-05-29

_arguments -s \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--require_unimplemented_servers[require unimplemented service server implementations (default true)]:bool:(true false)' \
  '--module[module path for generated code]:module path: ' \
  '--paths[output path mode]:mode:(source_relative import)'
