#compdef ppmtoterm
# Documentation: man ppmtoterm (Netpbm)
# Source: convert a PPM image to ANSI 256-color terminal text.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
