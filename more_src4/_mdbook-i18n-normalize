#compdef mdbook-i18n-normalize
# _mdbook-i18n-normalize — normalize Markdown inside PO/POT files (google/mdbook-i18n-helpers)
# upstream: https://github.com/google/mdbook-i18n-helpers
# Usage from i18n-helpers/src/bin/mdbook-i18n-normalize.rs.

_mdbook-i18n-normalize() {
    _arguments \
        '1:input PO file:_files -g "*.(po|pot)"' \
        '2:output PO file:_files -g "*.(po|pot)"'
}

_mdbook-i18n-normalize "$@"
