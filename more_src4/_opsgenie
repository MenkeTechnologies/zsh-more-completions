#compdef lamp
# _opsgenie — OpsGenie alert CLI (opsgenie/opsgenie-lamp)
# upstream: https://github.com/opsgenie/opsgenie-lamp

_opsgenie() {
    local curcontext="$curcontext" state line ret=1

    local -a commands=(
        'createAlert:create a new alert'
        'getAlert:get alert details'
        'closeAlert:close an alert'
        'deleteAlert:delete an alert'
        'acknowledgeAlert:acknowledge an alert'
        'heartbeat:send a heartbeat'
        'enable:enable an integration'
        'disable:disable an integration'
    )

    _arguments -C \
        '--apiKey=[OpsGenie API key]:key:' \
        '--user=[user for alert actions]:user:' \
        '--help[show help]' \
        '1: :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        cmd)
            _describe -t commands 'lamp command' commands && ret=0 ;;
        args)
            case $line[1] in
                createAlert)
                    _arguments \
                        '--message=[alert message]:message:' \
                        '--teams=[team names]:teams:' \
                        '--alias=[alert alias]:alias:' \
                        '--description=[alert description]:desc:' \
                        '--source=[alert source]:source:' \
                        '--entity=[alert entity]:entity:' \
                        '--tags=[comma-separated tags]:tags:' \
                        '--priority=[alert priority]:priority:(P1 P2 P3 P4 P5)' \
                        '--apiKey=[OpsGenie API key]:key:' && ret=0 ;;
                getAlert|closeAlert|deleteAlert|acknowledgeAlert)
                    _arguments \
                        '--alertId=[alert ID]:id:' \
                        '--alias=[alert alias]:alias:' \
                        '--apiKey=[OpsGenie API key]:key:' && ret=0 ;;
                heartbeat)
                    _arguments \
                        '--name=[heartbeat name]:name:' \
                        '--apiKey=[OpsGenie API key]:key:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

_opsgenie "$@"
