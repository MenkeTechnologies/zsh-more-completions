#compdef pnmhistmap
# Documentation: man pnmhistmap (Netpbm)
# Source: produce a PGM histogram graph from a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-red[show only red channel]' \
    '-green[show only green channel]' \
    '-blue[show only blue channel]' \
    '(-black -white)-black[black background]' \
    '(-black -white)-white[white background]' \
    '-max+[max histogram count]:n:' \
    '-lval+[left-edge value cutoff]:n:' \
    '-rval+[right-edge value cutoff]:n:' \
    '-height+[graph height]:n:' \
    '-width+[graph width]:n:' \
    '-dots[draw dots instead of lines]' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
