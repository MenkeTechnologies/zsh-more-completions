                'debug-five-whys:5-whys debug'
                'oracle:oracle test'
                'perfection-score:perfection score'
                'spec:specification ops'
                'comply:compliance ops'
                'kaizen:Kaizen continuous improvement'
                'project-diag:project diagnose'
                'test-discovery:test discovery'
                'localize:code localization'
                'extract:code extraction'
                'split:code split'
                'cuda-tdg:CUDA TDG'
                'sql:SQL ops'
                'help:show help for command'
            )
            _describe -t commands 'pmat command' _pm_cmds && ret=0
            ;;
        args)
            case $words[1] in
                serve|server|api)
                    _arguments \
                        '--transport=[server transport]:transport:(stdio http https tcp)' \
                        '--bind=[bind address]:addr:' \
                        '--port=[bind port]:port:' \
                        '--mcp[MCP protocol mode]' \
                        '--cors[enable CORS]' \
                        '*: :_files' && ret=0
                    ;;
                analyze|a|an)
                    _arguments \
                        '1:analysis type:(complexity churn duplicates defects dead-code coverage tdg deep-context security)' \
                        '*: :_files' && ret=0
                    ;;
                context|ctx|ast)
                    _arguments \
                        '--format=[output format]:format:(markdown json text)' \
                        '--toolchain=[language toolchain]:toolchain:(rust python typescript javascript go java cpp)' \
                        '*: :_files' && ret=0
                    ;;
                query|q|search-code)
                    _arguments \
                        '--mode=[search mode]:mode:(semantic lexical hybrid)' \
                        '--format=[output format]:format:(text json markdown)' \
                        '--max-results=[max results]:n:' \
                        '--max-chars=[max chars per result]:n:' \
                        '(-A --after-context)'{-A,--after-context}'=[lines after context]:n:' \
                        '(-B --before-context)'{-B,--before-context}'=[lines before context]:n:' \
                        '(-C --context)'{-C,--context}'=[context lines]:n:' \
                        '--min-level=[min level (e.g. L3)]:level:' \
                        '--max-level=[max level (e.g. L1)]:level:' \
                        '--coverage-file=[coverage file path]:file:_files' \
                        '*: :_files' && ret=0
                    ;;
                list|ls|search|find|s|validate|generate|gen|g|scaffold|sc|demo|d|show|report|r|score|tdg|grade|debt-grade)
                    _arguments \
                        '*: :_files' && ret=0
                    ;;
                help)
                    _arguments \
                        '1:command:(generate scaffold list search validate context query analyze qdd demo serve diagnose enforce refactor roadmap test config)' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_pmat "$@"
