#compdef maestro-cli
# _maestro-cli — mobile.dev Maestro mobile UI automation CLI alias (mobile.dev, Kotlin); picocli
# upstream: https://github.com/mobile-dev-inc/maestro

_maestro-cli() {
    local -a sub=(
        'test:run flow'
        'studio:run interactive studio'
        'record:record flow video'
        'cloud:run on Maestro Cloud'
        'login:authenticate to maestro cloud'
        'logout:logout from maestro cloud'
        'start-device:start a virtual device'
        'hierarchy:show ui hierarchy'
        'query:query for elements'
        'mock-server:run mock server'
        'download-samples:download sample flows'
        'bugreport:generate bug report'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--device=+[device id]:str:' \
        '-d+[device id]:str:' \
        '--host=+[host]:host:_hosts' \
        '--port=+[port]:port:' \
        '--platform=+[platform]:p:(android ios web)' \
        '--api-key=+[maestro cloud api key]:str:' \
        '--proxy-host=+[proxy host]:host:_hosts' \
        '--proxy-port=+[proxy port]:port:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'maestro subcommand' sub ;;
        args)
            case $words[1] in
                test) _arguments \
                    '--continuous[continuous]' \
                    '-c[continuous]' \
                    '--config=+[config file]:file:_files -g "*.(yaml|yml)"' \
                    '-e+[env var key=value]:str:' \
                    '--env-file=+[env file]:file:_files' \
                    '--format=+[report format]:fmt:(noop junit html)' \
                    '-f+[report format]:fmt:(noop junit html)' \
                    '--output=+[report output]:file:_files' \
                    '-o+[report output]:file:_files' \
                    '--include-tags=+[include tags]:list:' \
                    '--exclude-tags=+[exclude tags]:list:' \
                    '--debug-output=+[debug output dir]:dir:_files -/' \
                    '--flatten-debug-output[flatten debug output]' \
                    '--no-ansi[no ansi]' \
                    '*:flow:_files -g "*.(yaml|yml)"' ;;
                cloud) _arguments \
                    '--api-key=+[api key]:str:' \
                    '--app-file=+[app file]:file:_files -g "*.(ipa|apk|app|zip)"' \
                    '--upload-name=+[upload name]:str:' \
                    '--name=+[upload name]:str:' \
                    '--mapping-file=+[android mapping file]:file:_files -g "*.txt"' \
                    '--device-locale=+[device locale]:str:' \
                    '--device-model=+[device model]:str:' \
                    '--device-os=+[device OS]:str:' \
                    '--branch=+[branch]:str:' \
                    '--commit-sha=+[commit sha]:sha:' \
                    '--repo-name=+[repo name]:str:' \
                    '--repo-owner=+[repo owner]:str:' \
                    '--pull-request-id=+[pull request id]:n:' \
                    '--async[async]' \
                    '--include-tags=+[include tags]:list:' \
                    '--exclude-tags=+[exclude tags]:list:' \
                    '--timeout=+[timeout minutes]:n:' \
                    '*:flow:_files -g "*.(yaml|yml)"' ;;
                start-device) _arguments \
                    '--platform=+[platform]:p:(android ios web)' \
                    '--device-locale=+[locale]:str:' \
                    '--os-version=+[OS version]:str:' \
                    '--force-create[force create]' ;;
                record) _arguments \
                    '--local[record local]' \
                    '--api-key=+[api key]:str:' \
                    '*:flow:_files -g "*.(yaml|yml)"' ;;
                hierarchy) _arguments \
                    '--debug[debug]' ;;
                query) _arguments \
                    '--debug[debug]' \
                    '*:query:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_maestro-cli "$@"
