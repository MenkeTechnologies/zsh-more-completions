#compdef ppmquant
# Documentation: man ppmquant (Netpbm)
# Source: quantise a PPM image to a given number of colors or to a colormap.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-floyd -fs -nofloyd -nofs)'{-floyd,-fs}'[Floyd-Steinberg dithering]' \
    '(-floyd -fs -nofloyd -nofs)'{-nofloyd,-nofs}'[disable Floyd-Steinberg]' \
    '-mapfile=[colormap file]:file:_files -g "*.(ppm|pnm|pam)"' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:ncolors and/or ppm:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
