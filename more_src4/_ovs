#compdef ovs
# _ovs — Open vSwitch project ovs CLI top-level dispatcher for the Open vSwitch multilayer software switch with VXLAN GRE Geneve STT NSH IPSEC tunneling NetFlow IPFIX sFlow flow accounting OpenFlow control bridge port interface mirror QoS LACP STP RSTP MTU VLAN VRRP-state management (OVS team, C); getopt
# upstream: https://www.openvswitch.org/

_ovs() {
    local -a sub=(
        'vsctl:bridge configuration'
        'ofctl:OpenFlow operations'
        'dpctl:datapath operations'
        'appctl:application control'
        'pki:PKI management'
        'tcpdump:tcpdump on bridge'
        'fields:list ofctl fields'
        'docker:legacy docker plugin'
        'check-controller:check controller'
        'check-cluster:check cluster state'
        'kmod:kernel module operations'
        'install:installation helper'
        'uninstall:uninstall helper'
        'show:show running state'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--db=+[unix:/sock]:str:' \
        '--private-key=+[file]:file:_files' \
        '--certificate=+[file]:file:_files' \
        '--ca-cert=+[file]:file:_files' \
        '--bootstrap-ca-cert=+[file]:file:_files' \
        '--ssl-protocols=+[list]:str:' \
        '--no-syslog[no syslog]' \
        '--log-file=+[file]:file:_files' \
        '-o+[output]:f:(table list csv json yaml)' \
        '--format=+[format]:f:(table list csv json yaml)' \
        '--pretty[pretty json]' \
        '--no-headings[no headings]' \
        '--timeout=+[sec]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ovs subcommand' sub ;;
    esac
}

_ovs "$@"
