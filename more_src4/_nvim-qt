#compdef nvim-qt
# Documentation: https://github.com/equalsraf/neovim-qt/blob/master/src/gui/app.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--nvim=[nvim executable path]:nvim path:_files' \
  '--timeout=[error if nvim does not respond within count ms]:milliseconds:' \
  '--geometry=[set initial window geometry]:WxH:' \
  '--qwindowgeometry=[set initial window geometry]:WxH:' \
  '--stylesheet=[apply qss stylesheet from file]:stylesheet file:_files' \
  '--maximized[maximize the window on startup]' \
  '--fullscreen[open the window in fullscreen on startup]' \
  '--embed[communicate with nvim over stdin/stdout]' \
  '--server=[connect to existing nvim instance]:address:' \
  '--spawn[treat positional arguments as the nvim argv]' \
  '--nofork[run in foreground (Unix only)]' \
  '*:file:_files' && ret=0

return ret
