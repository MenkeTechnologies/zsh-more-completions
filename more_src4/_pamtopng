#compdef pamtopng
# Documentation: man pamtopng (Netpbm)
# Source: convert a Netpbm PAM/PNM to PNG.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-verbose[verbose output]' \
    '-transparent=[transparent color]:color:' \
    '-background=[background color]:color:' \
    '-gamma=[output gamma]:value:' \
    '-chroma=[primary chromaticities (wx wy rx ry gx gy bx by)]:chroma:' \
    '-srgbintent=[sRGB rendering intent]:intent:(perceptual relative-colorimetric saturation absolute-colorimetric)' \
    '-time=[timestamp yy-mm-dd hh\:mm\:ss]:time:' \
    '-text=[file with tEXt chunks]:file:_files' \
    '-ztxt=[file with zTXt (compressed) chunks]:file:_files' \
    '-itxt=[file with iTXt (international) chunks]:file:_files' \
    '-interlace[write interlaced PNG]' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:pnm/pam file:_files -g "*.(pnm|pam|pbm|pgm|ppm)"' \
    && ret=0

return ret
