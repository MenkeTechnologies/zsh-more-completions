#compdef posh
# Documentation: https://manpages.debian.org/testing/posh/posh.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# posh = Policy-compliant Ordinary SHell (Debian POSIX shell)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c+[execute command string]:command:' \
  '-i[interactive mode]' \
  '-l[login shell]' \
  '-s[read commands from stdin]' \
  '-o+[set shell option]:option:(allexport errexit ignoreeof monitor noclobber noexec noglob nolog notify nounset verbose xtrace)' \
  '+o+[unset shell option]:option:' \
  '-a[export all variables]' \
  '-C[noclobber, prevent file overwriting]' \
  '-e[exit on error]' \
  '-f[disable filename expansion]' \
  '-n[read commands without executing]' \
  '-u[error on unset variables]' \
  '-v[verbose, print input lines as read]' \
  '-x[xtrace, print commands before execution]' \
  '*:script:_files' && ret=0

return ret
