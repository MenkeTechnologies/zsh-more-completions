#compdef openfang
# Documentation: https://github.com/RightNow-AI/openfang
# Reference accessed: 2026-05-22
# Verified: crates/openfang-cli/src/main.rs clap command definitions.

# Zsh completion for openfang - open-source Agent Operating System CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--config[path to config file]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'openfang command' \
      'init[initialize OpenFang workspace and configuration]' \
      'start[start kernel daemon]' \
      'stop[stop running daemon]' \
      'status[show kernel status]' \
      'doctor[run diagnostic health checks]' \
      'dashboard[open web dashboard]' \
      'chat[quick chat with default or named agent]' \
      'tui[launch interactive terminal dashboard]' \
      'message[send one-shot message to an agent]' \
      'agent[manage agents]' \
      'workflow[manage workflows]' \
      'trigger[manage event triggers]' \
      'skill[manage skills]' \
      'channel[manage channel integrations]' \
      'hand[manage hands]' \
      'config[show or edit configuration]' \
      'models[browse models and providers]' \
      'cron[manage scheduled jobs]' \
      'sessions[list conversation sessions]' \
      'logs[tail OpenFang log file]' \
      'health[quick daemon health check]' \
      'vault[manage credential vault]' \
      'security[security tools and audit trail]' \
      'memory[search and manage agent memory KV store]' \
      'devices[device pairing and tokens]' \
      'webhooks[webhook helpers]' \
      'gateway[daemon control]' \
      'approvals[manage execution approvals]' \
      'auth[dashboard authentication]' \
      'add[install integration MCP server]' \
      'remove[remove installed integration]' \
      'integrations[list or search integrations]' \
      'migrate[migrate from another agent framework]' \
      'new[scaffold skill or integration template]' \
      'onboard[interactive onboarding wizard]' \
      'setup[quick non-interactive initialization]' \
      'configure[interactive setup wizard for credentials]' \
      'completion[generate shell completion scripts]' \
      'mcp[start MCP server over stdio]' \
      'qr[generate device pairing QR code]' \
      'system[system info and version]' \
      'reset[reset local config and state]' \
      'uninstall[completely remove OpenFang]' && ret=0
    ;;
  args)
    case $line[1] in
      init|setup|onboard)
        _arguments '--quick[non-interactive quick mode]' && ret=0
        ;;
      start)
        _arguments '--yolo[auto-approve all tool calls]' && ret=0
        ;;
      status|health|sessions)
        _arguments '--json[JSON output]' && ret=0
        ;;
      doctor)
        _arguments '--json[JSON output]' '--repair[auto-fix issues]' && ret=0
        ;;
      chat)
        _arguments '1:agent name:' && ret=0
        ;;
      message)
        _arguments '--json[JSON output]' '1:agent:' '2:message text:' && ret=0
        ;;
      migrate)
        _arguments \
          '--from[source framework]:framework:(openclaw langchain autogpt)' \
          '--source-dir[source workspace path]:directory:_directories' \
          '--dry-run[preview migration without changes]' && ret=0
        ;;
      add)
        _arguments '--key[API key or token]:key:' '1:integration name:' && ret=0
        ;;
      remove|integrations)
        _arguments '1:integration name:' && ret=0
        ;;
      new)
        _arguments '2:kind:(skill integration)' && ret=0
        ;;
      completion)
        _arguments '2:shell:(bash zsh fish powershell elvish)' && ret=0
        ;;
      reset|uninstall)
        _arguments '--confirm[skip confirmation prompt]' '--keep-config[keep config files on uninstall]' && ret=0
        ;;
      logs)
        _arguments '--lines[number of lines to show]:count:' '--follow[follow log output]' && ret=0
        ;;
      agent|workflow|trigger|skill|channel|hand|config|models|cron|vault|security|memory|devices|webhooks|gateway|approvals|auth|system)
        _arguments '--json[JSON output]' && ret=0
        ;;
    esac
    ;;
esac

return ret
