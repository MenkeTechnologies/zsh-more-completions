#compdef mov-cli
# _mov-cli — terminal streaming and downloading via plugins (mov-cli/mov-cli)
# upstream: https://github.com/mov-cli/mov-cli
# Flags from mov_cli/cli/__main__.py (typer).

_mov-cli() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '--debug[enable extra logging]' \
        '(-p --player)'{-p+,--player=}'[player binary (mpv, vlc, ...)]:player:(mpv vlc iina syncplay)' \
        '(-s --scraper)'{-s+,--scraper=}'[scraper to use]:scraper:' \
        '(--fzf --no-fzf)--fzf[force fzf for user selection]' \
        '(--fzf --no-fzf)--no-fzf[disable fzf for user selection]' \
        '(--preview --no-preview)--preview[enable fzf preview]' \
        '(--preview --no-preview)--no-preview[disable fzf preview]' \
        '(-ep --episode)'{-ep+,--episode=}'[episode:season (e.g. 26\:3)]:spec:' \
        '(-c --choice)'{-c+,--choice=}'[auto-select Nth search result]:n:' \
        '(-l --limit)'{-l+,--limit=}'[max results]:n:' \
        '(-e --edit)'{-e,--edit}'[open config in editor]' \
        '(-d --download)'{-d,--download}'[download instead of play]' \
        '(-co --continue)'{-co,--continue}'[continue where you left off]' \
        '(-lp --list-plugins)'{-lp,--list-plugins}'[list configured plugins / scrapers]' \
        '(--no-cache --clear-cache)--no-cache[clear all cache]' \
        '(--no-cache --clear-cache)--clear-cache[clear all cache]' \
        '(--auto-try-next-scraper --atns)--auto-try-next-scraper[auto-try next scraper on failure]' \
        '(--auto-try-next-scraper --atns)--atns[auto-try next scraper on failure]' \
        '*:query:'
}

_mov-cli "$@"
