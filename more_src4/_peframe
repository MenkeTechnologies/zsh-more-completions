  '(-v --version)'{-v,--version}'[show version and exit]' \
  '(-i --interactive)'{-i,--interactive}'[enter interactive analysis mode]' \
  '(-x --xorsearch)'{-x+,--xorsearch=}'[search for XOR-encoded strings]:pattern:' \
  '(-j --json)'{-j,--json}'[export short report as JSON to stdout]' \
  '(-s --strings)'{-s,--strings}'[export all extracted strings]' \
  '1:sample file to analyze:_files'
