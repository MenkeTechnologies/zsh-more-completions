#compdef otbcli_ColorMapping
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_ColorMapping.html
# Source: orfeotoolbox/OTB ColorMapping — apply custom/continuous/optimal/image-based color LUT.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-in+[input image]:image:_files' \
    '-out+[output image]:image:_files' \
    '-op+[conversion direction]:dir:(labeltocolor colortolabel)' \
    '-method+[color mapping method]:method:(custom continuous optimal image)' \
    '-method.custom.lut+[ASCII LUT file]:file:_files' \
    '-method.continuous.lut+[predefined palette]:palette:(red green blue grey hot cool spring summer autumn winter copper jet hsv overunder relief)' \
    '-method.continuous.min+[min value (default 0)]:value:_default' \
    '-method.continuous.max+[max value (default 255)]:value:_default' \
    '-method.optimal.background+[background label (default 0)]:n:_default' \
    '-method.image.in+[reference image]:image:_files' \
    '-method.image.nodatavalue+[NoData value (default 0)]:value:_default' \
    '-method.image.low+[low quantile (default 2)]:value:_default' \
    '-method.image.up+[upper quantile (default 2)]:value:_default' \
    '-op.colortolabel.notfound+[label for unknown colors (default 404)]:n:_default' \
    '-ram+[available RAM (MB, default 256)]:mb:_default' \
    '-progress[show progress]' \
    '(- *)-help[show help]' \
    && ret=0

return ret
