#compdef metar_ls
# Documentation: https://confluence.ecmwf.int/display/ECC/metar_ls
# Source: ecmwf/eccodes tools/metar_ls.cc — list keys from METAR messages (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f[force, do not fail on error]' \
    '-p+[keys to print]:keys:_default' \
    '-F+[C-style float format (default %g)]:format:_default' \
    '-P+[append keys to default list]:keys:_default' \
    '-w+[where clause filter]:filter:_default' \
    '-s+[key=value pairs to set]:kvs:_default' \
    '-n+[namespace (default ls)]:namespace:_default' \
    '-m[print MARS keys]' \
    '(- *)-V[show version]' \
    '-W+[minimum column width (default 10)]:n:_default' \
    '-g[copy GTS header]' \
    '-T+[message type]:type:(T B M A)' \
    '-7[do not fail on wrong message length]' \
    '*:metar file:_files' \
    && ret=0

return ret
