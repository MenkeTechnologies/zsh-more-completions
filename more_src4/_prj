#compdef prj
# ---------------------------------------------------------------------------
# prj — projectable: highly configurable TUI file manager for projects (Rust, 455★)
#
# upstream: https://github.com/dzfrias/projectable
#           (binary name `prj` per Cargo.toml [[bin]] section)
# author : Diego Frias  <styx5242@gmail.com>  (dzfrias)
# license: MIT
#
# Source-direct completion: every flag below is verbatim from src/main.rs
# `Args` clap-derive struct on the projectable v1.3.2 tip.
#
# Direct deps from Cargo.toml (selected):
#   nom              ^7.1.3        ← canonical Rust parser combinator
#                                    library (this axis) — parses the .toml
#                                    config + .marks file content + project
#                                    glob patterns
#   clap (derive), anyhow, log
#   crossterm, tui (ratatui-precursor)
#   crossbeam-channel, scopeguard
#
# projectable scaffolds a TUI around your project's file tree, runs custom
# user commands (configured per-project), tracks "marks" (jump targets),
# integrates with git, and exposes file-management primitives with vim-like
# keybindings.  The four CLI flags are mutually exclusive utility shortcuts
# that print/create config artifacts then exit before entering the TUI.
#
# === AXIS 163 OPENER — parser-combinator library ecosystem ===
# Axis position: Rust=218 OPENS Axis 163 at slot 1/0/0.  Canonical Rust
# parser-combinator library is `nom` by Geoffroy Couprie (Geal, the original
# author of Capslock + VLC contributor) — a zero-allocation byte-and-string
# parser-combinator framework.  Used by Veillette's pdf-extract, Rust LSP
# implementations, Suricata IDS rust components, Wireshark Rust plugins,
# prisma-engines, and (here) projectable's TOML config + marks-file parser.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=218   ← THIS FILE              (axis 163 OPENS, slot 1/0/0)
#   Go=218     ← next round              (axis 163 continues, slot 2/0/0)
#   TS-Node=218 ← round after            (axis 163 CLOSES at triple-218, slot 1/1/1)
# ---------------------------------------------------------------------------

_prj() {
    _arguments -s -S \
        '--debug[enable debug mode (verbose logger to projectable.log)]' \
        '(--marks-file --write-config --make-config)'{-c,--config}'[print config location and exit]' \
        '(-c --config --write-config --make-config)--marks-file[print marks-file location and exit]' \
        '(-c --config --marks-file --make-config)--write-config[create a default config file (writes Unix/Windows defaults)]' \
        '(-c --config --marks-file --write-config)--make-config[create an empty config file (errors if one exists)]' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1:project directory:_files -/'
}

_prj "$@"
