#compdef pa11y
# Documentation: https://github.com/pa11y/pa11y
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for pa11y - automated accessibility testing

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-n --environment)'{-n,--environment}'[output details about the environment]' \
  '(-s --standard)'{-s,--standard}'[accessibility standard to use]:standard:(WCAG2A WCAG2AA WCAG2AAA)' \
  '(-r --reporter)'{-r,--reporter}'[reporter to use]:reporter:(cli csv html json tsv)' \
  '(-e --runner)'{-e,--runner}'[test runner(s) to use]:runner:(axe htmlcs)' \
  '(-l --level)'{-l,--level}'[level of issues to fail on]:level:(error warning notice)' \
  '(-T --threshold)'{-T,--threshold}'[number of errors to permit before failing]:count' \
  '(-i --ignore)'{-i,--ignore}'[types or codes to ignore]:rule' \
  '--include-notices[include notices in the report]' \
  '--include-warnings[include warnings in the report]' \
  '--level-cap-when-needs-review=[cap severity of axe needs-review issues]:level:(error warning notice)' \
  '(-R --root-element)'{-R,--root-element}'[CSS selector for root element]:selector' \
  '(-E --hide-elements)'{-E,--hide-elements}'[CSS selector for elements to hide]:selector' \
  '(-c --config)'{-c,--config}'[JSON or JavaScript configuration file]:file:_files' \
  '(-t --timeout)'{-t,--timeout}'[timeout in milliseconds]:milliseconds' \
  '(-w --wait)'{-w,--wait}'[time to wait before running tests]:milliseconds' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '(-S --screen-capture)'{-S,--screen-capture}'[save a screenshot]:file:_files' \
  '(-A --add-rule)'{-A,--add-rule}'[WCAG rule to add]:rule' \
  '1:URL or file:_urls'
