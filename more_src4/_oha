#compdef oha
# Documentation: https://github.com/hatoo/oha/blob/master/src/lib.rs
# Reference accessed: 2026-05-19
# Verified: upstream clap derive in src/lib.rs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-n+[number of requests]:n:' \
  '-c+[concurrent connections]:n:' \
  '-p+[parallel HTTP/2 requests per connection]:n:' \
  '-z+[duration of application to send requests]:duration:' \
  '(-w --wait-ongoing-requests-after-deadline)'{-w,--wait-ongoing-requests-after-deadline}'[wait for ongoing requests after deadline]' \
  '-q+[rate limit (QPS)]:rate:' \
  '--burst-delay=[delay between request batches]:duration:' \
  '--burst-rate=[requests per burst]:n:' \
  '--rand-regex-url[generate URLs from regex]' \
  '--urls-from-file[read URLs from a file]' \
  '--max-repeat=[max regex repeat count]:n:' \
  '--dump-urls=[dump generated URLs N times]:n:' \
  '--latency-correction[correct latency to avoid coordinated omission]' \
  '--no-tui[disable realtime TUI]' \
  '--fps=[frames per second for TUI]:n:' \
  '(-m --method)'{-m+,--method=}'[HTTP method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
  '*-H+[custom HTTP header]:header:' \
  '*--proxy-header=[custom proxy HTTP header]:header:' \
  '-t+[request timeout]:timeout:' \
  '--connect-timeout=[connection timeout]:duration:' \
  '-A+[Accept header]:accept:' \
  '-d+[HTTP request body]:body:' \
  '-D+[HTTP request body from file]:file:_files' \
  '-Z+[HTTP request body from file line-by-line]:file:_files' \
  '(-F --form)'{-F+,--form=}'[multipart form data]:form:' \
  '-T+[Content-Type]:content-type:' \
  '-a+[basic auth user:password or AWS access:secret]:auth:' \
  '--aws-session=[AWS session token]:token:' \
  '--aws-sigv4=[AWS SigV4 signing params]:params:' \
  '-x+[HTTP proxy]:url:' \
  '--proxy-http-version=[proxy HTTP version]:v:(0.9 1.0 1.1 2)' \
  '--proxy-http2[use HTTP/2 to proxy]' \
  '--http-version=[HTTP version]:version:(0.9 1.0 1.1 2 3)' \
  '--http2[use HTTP/2]' \
  '--host=[HTTP Host header]:host:_hosts' \
  '--disable-compression[disable compression]' \
  '(-r --redirect)'{-r+,--redirect=}'[max redirects]:n:' \
  '--disable-keepalive[disable keep-alive]' \
  '--no-pre-lookup[do not perform DNS lookup at start]' \
  '--ipv6[lookup only IPv6]' \
  '--ipv4[lookup only IPv4]' \
  '--cacert=[TLS CA cert file]:file:_files' \
  '--cert=[TLS client cert file]:file:_files' \
  '--key=[TLS client key file]:file:_files' \
  '--insecure[accept invalid certs]' \
  '*--connect-to=[override DNS resolution and ports]:spec:' \
  '--no-color[disable color scheme]' \
  '--disable-color[disable color scheme]' \
  '--unix-socket=[connect to Unix socket]:path:_files' \
  '--vsock-addr=[connect to VSOCK cid:port]:addr:' \
  '--stats-success-breakdown[include success/failure breakdown]' \
  '--db-url=[SQLite DB url to write succeeded requests]:url:' \
  '--debug[perform a single request and dump it]' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '--output-format=[output format]:format:(text json csv quiet)' \
  '(-u --time-unit)'{-u+,--time-unit=}'[time unit]:unit:(ns us ms s m h)' \
  '*:url:_urls' \
  && return 0
