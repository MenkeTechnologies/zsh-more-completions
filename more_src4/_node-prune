#
# WHAT IS go-humanize AND WHY IS IT THE 63RD GO CLI LIBRARY?
#
# go-humanize (https://github.com/dustin/go-humanize, 5,000+ stars,
# ~700M go.sum downloads cumulative) is **Dustin Sallings's
# canonical Go library for human-friendly number/byte/time/ordinal
# formatting** — released 2014, the LONGEST-RUNNING and
# MOST-WIDELY-USED humanization library in the Go ecosystem.
# Where humantime (R621) is narrowly focused on durations + RFC 3339,
# go-humanize is multi-domain: covering bytes, numbers, ordinals,
# time differences, SI prefixes, and pluralization in a unified
# package.
#
# go-humanize's distinguishing characteristics:
#
#   1. Bytes / IBytes WITH SI vs IEC SPLIT — go-humanize correctly
#      distinguishes SI (1000-base) from IEC (1024-base) byte units:
#
#          import "github.com/dustin/go-humanize"
#
#          // SI (decimal, used by disk manufacturers, networking):
#          humanize.Bytes(1024)       // "1.0 kB"  (SI 1000-base)
#          humanize.Bytes(1_000_000)  // "1.0 MB"
#          humanize.Bytes(1_500_000_000)  // "1.5 GB"
#
#          // IEC (binary, used by OS memory, RAM specs):
#          humanize.IBytes(1024)      // "1.0 KiB" (IEC 1024-base)
#          humanize.IBytes(1_048_576) // "1.0 MiB"
#          humanize.IBytes(1_073_741_824)  // "1.0 GiB"
#
#          // Reverse parsing:
#          humanize.ParseBytes("1.5 GB")   // → uint64 bytes
#          humanize.ParseBytes("256 KiB")  // → uint64 bytes
#
#      Compare:
#         * stdlib fmt: no byte humanization
#         * humantime (R621, Rust): no byte humanization
#         * Rust humansize: similar SI/IEC split (Rust equivalent)
#         * Node pretty-bytes: SI by default, no IEC option in
#                                older versions
#         * Python humanize: naturalsize() with binary= toggle
#         * go-humanize: BOTH SI + IEC AS SEPARATE FUNCTIONS,
#                         not a parameter
#      FIRST documented Axis 11 library with SI vs IEC byte units
#      as SEPARATE TOP-LEVEL FUNCTIONS (rather than parameter
#      toggle).
#
#   2. Comma + Commaf FOR THOUSANDS SEPARATORS — go-humanize
#      formats large numbers with English thousands separators:
#
#          humanize.Comma(1234567)        // "1,234,567"
#          humanize.Comma(-1234567)       // "-1,234,567"
#          humanize.Commaf(1234567.89)    // "1,234,567.89"
#          humanize.Commaf(-1234567.89)   // "-1,234,567.89"
#          humanize.BigComma(big.NewInt(123456789))  // big.Int support
#
#      Used in node-prune's output to format "files total" + "files
#      removed" counts.  Compare:
#         * stdlib fmt: %d / %f have no thousands separators
#         * humantime (R621, Rust): no number formatting
#         * Rust thousands: separate crate for this
#         * Node Intl.NumberFormat: locale-aware (broader)
#         * Python humanize: intcomma()
#         * go-humanize: Comma + Commaf + BigComma — separate
#                         APIs for int/float/big.Int
#      FIRST documented Axis 11 library with separate int/float/
#      big.Int variants of thousands-separator formatting.
#
#   3. Time + RelTime FOR RELATIVE TIME DIFFERENCES — go-humanize
#      computes "N units ago" / "in N units" strings:
#
#          import "time"
#          import "github.com/dustin/go-humanize"
#
#          t := time.Now().Add(-72 * time.Hour)
#          humanize.Time(t)  // "3 days ago"
#
#          future := time.Now().Add(2 * time.Hour)
#          humanize.Time(future)  // "2 hours from now"
#
#          // Custom prefix/suffix:
#          humanize.RelTime(a, b, "before", "after")
#          // → "5 hours before" or "3 days after"
#
#      Compare:
#         * stdlib time.Since: returns Duration, not human string
#         * humantime (R621, Rust): no relative-time string
#         * Rust chrono-humanize: similar feature in different
#                                   crate
#         * Node humanize-duration: similar
#         * Python humanize: naturaltime()
#         * go-humanize: Time + RelTime + custom prefix/suffix
#      FIRST documented Go Axis 11 library with relative-time
#      string generation built-in.
#
#   4. Ordinal + Plural FOR ENGLISH MORPHOLOGY — go-humanize
#      handles English-specific morphology:
#
#          humanize.Ordinal(1)    // "1st"
#          humanize.Ordinal(2)    // "2nd"
#          humanize.Ordinal(3)    // "3rd"
#          humanize.Ordinal(11)   // "11th"  (correctly handles teens)
#          humanize.Ordinal(22)   // "22nd"
#          humanize.Ordinal(103)  // "103rd"
#
#          humanize.Plural(0, "file", "files")  // "files"
#          humanize.Plural(1, "file", "files")  // "file"
#          humanize.Plural(2, "file", "files")  // "files"
#
#      Compare:
#         * stdlib: no morphology functions
#         * humantime (R621, Rust): no morphology
#         * Rust: various separate ordinal/plural crates
#         * Node pluralize: similar feature
#         * Python humanize: similar ordinal()
#         * go-humanize: Ordinal + Plural built-in
#      FIRST documented Go Axis 11 library with English-
#      morphology helpers (ordinals + plurals).
#
#   5. DUSTIN SALLINGS / COUCHBASE / 11-YEAR PROVENANCE — go-
#      humanize is by Dustin Sallings (dustin on GitHub), Couchbase
#      engineer + prolific Go open-source contributor.  Released
#      2014, continuously maintained for 11+ years.  Downstream
#      users:
#         * helm (Kubernetes package manager)
#         * k9s (Kubernetes TUI)
#         * kubectl (originally; later moved to per-feature
#                     formatting)
#         * docker (originally; partial)
#         * filecoin-project/venus (Filecoin Go, 2k stars)
#         * andreimarcu/linx-server (file sharing, 1.6k stars)
#         * tj/node-prune (THIS — 4.4k stars)
#         * keybase/client (Keybase)
#         * Netflix/p2plab (Netflix P2P lab)
#         * sahib/brig (IPFS file sync)
#         * Sioro-Neoku/go-peerflix (BitTorrent streamer)
#         * cortesi/devd (devd web server)
#         * jondot/goweight (Go binary analyzer)
#         * 2000+ Go CLIs
#      FIRST documented Go Axis 11 library with this specific
#      Dustin-Sallings + 11-year-sustained-development provenance.
#
# go-humanize's relationship to humantime (R621) and other Axis 11
# libraries:
#
#   * Unlike humantime (R621, Rust) — humantime is narrowly-focused
#                                       on durations + RFC 3339;
#                                       go-humanize is multi-domain
#                                       across bytes/numbers/time/
#                                       ordinals/floats/morphology
#   * Closest cross-language analogs:
#         * Rust humansize — byte-only humanization
#         * Rust bytesize — byte-only humanization
#         * Rust chrono-humanize — relative-time only
#         * Rust thousands — number-comma only
#         * Node humanize-duration — duration only
#         * Node pretty-bytes — byte-only humanization
#         * Node vercel/ms — duration only (parse + format)
#         * Node humanize-string — string-only humanization
#         * Python humanize (Jason Moiron) — DIRECT ANALOG;
#                                              multi-domain
#         * Java humanize-jvm — direct analog
#     go-humanize is the FIRST documented Go Axis 11 library
#     providing MULTI-DOMAIN humanization (bytes / numbers / time /
#     ordinals / floats / pluralization) in a single package.
#
# -----------------------------------------------------------------------------
#
# THE node-prune CLI — stdlib flag + go-humanize + apex/log
#
# node-prune's CLI is in main.go.  Uses Go's stdlib `flag` package
# with custom arrayFlags type for repeatable flags:
#
#     type arrayFlags []string
#     func (i *arrayFlags) String() string { return strings.Join(*i, ", ") }
#     func (i *arrayFlags) Set(value string) error {
#         *i = append(*i, value)
#         return nil
#     }
#
#     var exclusionGlobs arrayFlags
#     var inclusionGlobs arrayFlags
#
#     func main() {
#         debug := flag.Bool("verbose", false, "Verbose log output.")
#         flag.Var(&exclusionGlobs, "exclude", "Glob of files that should not be pruned. Can be specified multiple times.")
#         flag.Var(&inclusionGlobs, "include", "Globs of files that should always be pruned in addition to the defaults. Can be specified multiple times.")
#         flag.Parse()
#         dir := flag.Arg(0)
#         // ... prune ...
#         output("files total", humanize.Comma(stats.FilesTotal))
#         output("files removed", humanize.Comma(stats.FilesRemoved))
#         output("size removed", humanize.Bytes(uint64(stats.SizeRemoved)))
#         output("duration", time.Since(start).Round(time.Millisecond).String())
#     }
#
# Flags:
#   --verbose                       Verbose log output
#   --exclude GLOB (repeatable)     Globs of files NOT to prune
#   --include GLOB (repeatable)     Additional globs to prune
#   [directory]                     Positional path to node_modules
#                                    (defaults to ./node_modules)
#
# go-humanize is used in the final stats output to format file
# counts (Comma) + bytes (Bytes).  apex/log is the headline logger.
#
# Five-axis distinctness from humantime (R621) and other Axis 11
# libraries:
#
#   1. MULTI-DOMAIN HUMANIZATION — bytes, numbers, time, ordinals,
#      floats, pluralization in ONE package (humantime is narrow).
#
#   2. SI vs IEC BYTE-UNIT SPLIT — Bytes() vs IBytes() as separate
#      top-level functions.
#
#   3. COMMA/COMMAF FOR THOUSANDS SEPARATORS — separate int/float/
#      big.Int variants.
#
#   4. TIME + RELTIME FOR RELATIVE-TIME STRINGS — "3 days ago" /
#      "in 2 hours" built-in.
#
#   5. DUSTIN-SALLINGS / COUCHBASE / 11-YEAR PROVENANCE.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/tj/node-prune/blob/master/main.go
# stdlib flag.Bool + flag.Var definitions.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '--verbose[verbose log output]' \
    '*--exclude=[glob of files NOT to prune (repeatable)]:glob:_default' \
    '*--include=[additional globs to always prune (repeatable)]:glob:_default' \
    '(- *)'{-h,--help}'[show help]' \
    '1:node_modules directory:_directories' \
    && ret=0

return ret
