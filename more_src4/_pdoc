#compdef pdoc
# Documentation: https://github.com/mitmproxy/pdoc/blob/main/pdoc/__main__.py
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-o --output-directory)'{-o,--output-directory}'[output directory]:directory:_files -/' \
  '(-d --docformat)'{-d,--docformat}'[docstring format]:format:(markdown google numpy restructuredtext)' \
  '--include-undocumented[show undocumented members]' \
  '--no-include-undocumented[hide undocumented members]' \
  '*'{-e,--edit-url}'[module=URL mapping for Edit button]:mapping:' \
  '--favicon[custom favicon URL]:url:' \
  '--footer-text[footer text]:text:' \
  '--logo[logo image URL]:url:' \
  '--logo-link[link target for logo]:url:' \
  '--math[enable math rendering]' \
  '--no-math[disable math rendering]' \
  '--mermaid[enable Mermaid diagrams]' \
  '--no-mermaid[disable Mermaid diagrams]' \
  '--search[enable search]' \
  '--no-search[disable search]' \
  '--show-source[show View Source buttons]' \
  '--no-show-source[hide View Source buttons]' \
  '(-t --template-directory)'{-t,--template-directory}'[Jinja2 template directory]:directory:_files -/' \
  '(-h --host)'{-h,--host}'[HTTP host]:host:' \
  '(-p --port)'{-p,--port}'[HTTP port]:port:' \
  '(-n --no-browser)'{-n,--no-browser}'[do not open browser]' \
  '--help[show help]' \
  '--version[show version]' \
  '*:module:'
