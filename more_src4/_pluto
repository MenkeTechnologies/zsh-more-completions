#compdef pluto
# Documentation: https://github.com/FairwindsOps/pluto
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above (cmd/root.go).

local curcontext="$curcontext" state line ret=1

local -a persistent_opts=(
  '--ignore-deprecations[do not exit 2 if deprecated apiVersions are found]'
  '--ignore-removals[do not exit 3 if removed apiVersions are found]'
  '--ignore-unavailable-replacements[do not exit 4 if no replacement is available]'
  '(-r --only-show-removed)'{-r,--only-show-removed}'[only show apiVersions removed in target version]'
  '(-H --no-headers)'{-H,--no-headers}'[do not print headers]'
  '(-f --additional-versions)'{-f+,--additional-versions=}'[additional deprecated versions file]:file:_files'
  '(-t --target-versions)'{-t+,--target-versions=}'[map of target versions]:versions:'
  '(-o --output)'{-o+,--output=}'[output format]:format:(normal wide custom json yaml markdown csv)'
  '--columns=[list of columns to print]:columns:'
  '--components=[list of components to check]:components:'
)

_arguments -s -S -C \
  $persistent_opts \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'detect:check a single file or stdin for deprecated apiVersions'
      'detect-files:detect deprecated APIs in files'
      'detect-helm:detect deprecated APIs in Helm releases'
      'detect-api-resources:detect deprecated APIs in cluster resources'
      'detect-all-in-cluster:detect all deprecated APIs in cluster'
      'list-versions:list supported API versions'
      'version:show version'
      'help:show help'
    )
    _describe -t commands 'pluto command' commands && ret=0
    ;;
  args)
    case $words[1] in
      (detect-files)
        _arguments -s -S \
          $persistent_opts \
          '(-d --directory)'{-d+,--directory=}'[directory to scan]:dir:_directories' \
          '*:file:_files' && ret=0
        ;;
      (detect-helm|detect-api-resources|detect-all-in-cluster)
        _arguments -s -S \
          $persistent_opts \
          '--kubeconfig=[path to kubeconfig]:file:_files' \
          '(-n --namespace)'{-n+,--namespace=}'[only detect in namespace]:namespace:' \
          '--kube-context=[kube context to use]:context:' && ret=0
        ;;
      (detect)
        _arguments -s -S \
          $persistent_opts \
          '*:file:_files' && ret=0
        ;;
      (*)
        _arguments -s -S $persistent_opts '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
