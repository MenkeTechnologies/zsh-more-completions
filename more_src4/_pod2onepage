#compdef pod2onepage pod2onepage-j pod2onepage-js pod2onepage-m
# Documentation: https://github.com/Raku/doc/blob/main/util/pod2onepage
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above (pod2onepage is a Raku/Perl 6 tool).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  {-v,--verbose}'[verbose output]' \
  '--source-path=[path to POD source files]:path:_files -/' \
  '--exclude=[exclude pattern]:pattern' \
  '--no-cache[disable cache]' \
  '--html[output HTML]' \
  '--title=[document title]:title' \
  '--threads=[number of threads]:n' \
  '--anchored[generate anchors]' \
  '--precomp-path=[precompilation cache path]:path:_files -/' \
  '*:POD source file:_files -g "*.(pod|pm|pm6|rakumod|raku|pl)"' && ret=0

return ret
