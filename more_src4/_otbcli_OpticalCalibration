#compdef otbcli_OpticalCalibration
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_OpticalCalibration.html
# Source: orfeotoolbox/OTB OpticalCalibration — TOA/TOC reflectance calibration with 6S atmospheric correction.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-in+[input image]:image:_files' \
    '-out+[output calibrated image]:image:_files' \
    '-level+[calibration level]:level:(toa toatoim toc)' \
    '-milli+[(true/false) use milli-reflectance]:bool:(true false)' \
    '-clamp+[(true/false) clamp reflectivity to 0..1]:bool:(true false)' \
    '-acqui.minute+[acquisition minute (0-59)]:n:_default' \
    '-acqui.hour+[acquisition hour (0-23)]:n:_default' \
    '-acqui.day+[acquisition day (1-31)]:n:_default' \
    '-acqui.month+[acquisition month (1-12)]:n:_default' \
    '-acqui.year+[acquisition year]:n:_default' \
    '-acqui.fluxnormcoeff+[flux normalization coeff]:value:_default' \
    '-acqui.solardistance+[solar distance (AU)]:value:_default' \
    '-acqui.gainbias+[gain/bias file]:file:_files' \
    '-acqui.solarilluminations+[solar illuminations file]:file:_files' \
    '-acqui.sun.elev+[sun elevation (deg, default 90)]:deg:_default' \
    '-acqui.sun.azim+[sun azimuth (deg, default 0)]:deg:_default' \
    '-acqui.view.elev+[view elevation (deg, default 90)]:deg:_default' \
    '-acqui.view.azim+[view azimuth (deg, default 0)]:deg:_default' \
    '-atmo.aerosol+[aerosol model]:model:(noaersol continental maritime urban desertic)' \
    '-atmo.oz+[ozone (cm-atm)]:value:_default' \
    '-atmo.wa+[water vapour (g/cm²)]:value:_default' \
    '-atmo.pressure+[atmospheric pressure (hPa)]:value:_default' \
    '-atmo.opt+[aerosol optical thickness]:value:_default' \
    '-atmo.aeronet+[Aeronet file]:file:_files' \
    '-atmo.rsr+[relative spectral response]:file:_files' \
    '-atmo.radius+[adjacency window radius (default 2)]:n:_default' \
    '-atmo.pixsize+[pixel size km (default 1)]:km:_default' \
    '-ram+[available RAM (MB, default 256)]:mb:_default' \
    '-progress[show progress]' \
    '(- *)-help[show help]' \
    && ret=0

return ret
