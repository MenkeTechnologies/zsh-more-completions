#compdef pivx pivx-qt
# _pivx — PIVX Project pivx-qt GUI desktop client CLI for the privacy-focused Bitcoin fork running the network wallet zPIV minting master-node staking budget governance with optional Qt arguments for testnet regtest reset wallet rescan reindex (PIVX-Project team, C++/Qt); custom argparse
# upstream: https://github.com/PIVX-Project/PIVX

_pivx() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-?[show help]' \
        '-conf=+[file]:file:_files -g "*.conf pivx.conf"' \
        '-datadir=+[dir]:dir:_files -/' \
        '-printtoconsole[print to console]' \
        '-debug=+[category]:c:(net mempool http bench zmq walletdb rpc estimatefee addrman selectcoins reindex cmpctblock rand prune libevent coindb leveldb staking masternode budget all)' \
        '-testnet[use testnet]' \
        '-regtest[use regtest]' \
        '-rest[enable REST]' \
        '-rpcuser=+[user]:str:' \
        '-rpcpassword=+[password]:str:' \
        '-rpcport=+[port]:n:' \
        '-rpcbind=+[addr]:str:' \
        '-rpcallowip=+[cidr]:str:' \
        '-listen[enable inbound]' \
        '-port=+[port]:n:' \
        '-bind=+[host]:str:' \
        '-externalip=+[ip]:str:' \
        '-onion=+[host:port]:str:' \
        '-proxy=+[host:port]:str:' \
        '-maxconnections=+[N]:n:' \
        '-paytxfee=+[PIV/kB]:f:' \
        '-reindex[reindex]' \
        '-rescan[rescan]' \
        '-wallet=+[file]:file:_files' \
        '-staking=+[b]:b:(0 1)' \
        '-masternode=+[b]:b:(0 1)' \
        '-masternodeprivkey=+[key]:str:' \
        '-masternodeaddr=+[host:port]:str:' \
        '-enablezeromint=+[b]:b:(0 1)' \
        '-zeromintpercentage=+[N]:n:' \
        '-enablezpiv=+[b]:b:(0 1)' \
        '-mintpiv[mint PIV]' \
        '-budgetvotemode=+[m]:m:(no auto suggest)' \
        '-min[start minimized]' \
        '-resetguisettings[reset GUI settings]' \
        '-splash[show splash]' \
        '-style=+[Qt style]:s:(fusion windows windowsvista gtk2 macintosh)'
}

_pivx "$@"
