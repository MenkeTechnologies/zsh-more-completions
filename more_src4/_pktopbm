#compdef pktopbm
# Documentation: man pktopbm (Netpbm)
# Source: convert a TeX PK font's characters into a sequence of PBM bitmaps.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-x+[character bitmap width]:width:' \
    '-y+[character bitmap height]:height:' \
    '*-c+[character code to extract]:num:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pk font:_files -g "*.pk"' \
    '*:pbm output files:_files -g "*.pbm"' \
    && ret=0

return ret
