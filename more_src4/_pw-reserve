#compdef pw-reserve
# Documentation: https://docs.pipewire.org/page_man_pw-reserve_1.html
# Source: PipeWire — D-Bus org.freedesktop.ReserveDevice1 device-reservation client.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-r --release)'{-r,--release}'[ask current holder to release; try to reserve after]' \
    '(-n --name)'{-n+,--name=}'[device name to reserve]:name:' \
    '(-a --appname)'{-a+,--appname=}'[application name used while reserving]:app:' \
    '(-p --priority)'{-p+,--priority=}'[reservation priority]:prio:' \
    '(-m --monitor)'{-m,--monitor}'[monitor reservations instead of reserving]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    && ret=0

return ret
