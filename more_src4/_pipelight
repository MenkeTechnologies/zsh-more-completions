#compdef pipelight
# Documentation: https://pipelight.dev/guide/cli.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# STUB: two unrelated tools share the name (Rust pipeline runner at
# pipelight.dev; Wine NPAPI wrapper from joejb/pipelight). Provide a
# minimal stub that defers to subcommand completion.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '*::arguments:_default'
