#compdef pigs
# _pigs — joan2937 pigpio pigs CLI for sending commands to the pigpio daemon pigpiod accessing Raspberry Pi GPIO PWM I2C SPI servo bit-bang serial-bridge timing register-access notifications (joan2937 team, C); getopt
# upstream: https://github.com/joan2937/pigpio

_pigs() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-x[interpret data as hex]' \
        '-a[run as ASCII]' \
        '-n+[host]:h:_hosts' \
        '--host=+[host]:h:_hosts' \
        '-p+[port]:n:' \
        '--port=+[port]:n:' \
        '-l[list connections]' \
        '*:command:(modes modeg pud read write pwm prs prg pfs gpw gpr p1 p2 p2g servo serv1 prrg t cf1 cf2 hi nb nc nl no rg sl shells slr slro slrc tag tc tick wave waps wac wcr wcsf wcwf wapn wags wvaag wvbsy wvchain wvclr wvcre wvcap wvdel wvtat wvgo wvgor wvbsy wvhlt i2co i2cc i2crd i2crw i2crk i2crb i2cwd i2crrb i2cwb i2cwk i2cwrb spio spic spir spiw bsc fr fw fc fo fl fwf wvas wvbsy wvhlt eb gdc gpw gpr gtb tag tick test bsc_xfer)'
}

_pigs "$@"
