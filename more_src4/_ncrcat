#compdef ncrcat ncecat
# Documentation: https://nco.sourceforge.net/nco.html#ncrcat
# Source: nco/nco src/nco/ncrcat.c — netCDF record concatenator (ncecat shares source for ensembles).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-3[netCDF3 CLASSIC (32-bit offset) output]' \
    '-4[netCDF4 (HDF5) output]' \
    '-5[netCDF3 64-bit data (CDF5) output]' \
    '-6[netCDF3 64-bit offset output]' \
    '-7[netCDF4 CLASSIC output]' \
    '-A[append to existing output file]' \
    '-C[exclude coordinates and CF-associated variables]' \
    '-c[extract coordinates and CF-associated variables]' \
    '-D+[debug level]:lvl:_default' \
    '*-d+[dimension hyperslab dim,[min],[max],[stride]]:dim_spec:_default' \
    '-F[Fortran (1-based) indexing]' \
    '-G+[group path editing path]:gpe_dsc:_default' \
    '*-g+[groups to process]:grp:_default' \
    '-H[do not create input_file_list attribute]' \
    '-h[do not append to history attribute]' \
    '-L+[deflation level (0-9) for netCDF4]:lvl:_default' \
    '-l+[local storage path for remote files]:path:_directories' \
    '-n+[NINTAP-style file list abbreviation]:loop:_default' \
    '-O[overwrite existing output file]' \
    '-p+[path prefix for input filenames]:path:_directories' \
    '-R[retain remotely-retrieved files after use]' \
    '-r[print version info]' \
    '-t+[OpenMP thread number]:threads:_default' \
    '*-v+[variables to process (regex)]:var:_default' \
    '-X+[auxiliary coordinate bounding box]:box:_default' \
    '-x[exclude variables specified with -v]' \
    '--rec_apn[append records (do not concatenate)]' \
    '--bfr=[I/O buffer size]:bytes:_default' \
    '--hdr_pad=[header padding]:bytes:_default' \
    '--gaa=[global attribute append]:spec:_default' \
    '--gad=[global attribute delete]:names:_default' \
    '*:netcdf file:_files -g "*.(nc|nc4|cdf|hdf|h5)(-.)"' \
    && ret=0

return ret
