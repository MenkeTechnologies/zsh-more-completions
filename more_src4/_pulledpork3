#compdef pulledpork3
# Documentation: https://github.com/shirkdog/pulledpork3
# Reference accessed: 2026-05-20
# Verified: upstream README. Python 3 rewrite; smaller flag set than original.

# pulledpork3: Snort/Suricata rule updater (Python 3 rewrite)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-V[show version]' \
  '(-c --config)'{-c+,--config=}'[configuration file]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-vv --debug)'{-vv,--debug}'[debug output]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-i --ignore-warn)'{-i,--ignore-warn}'[override exit-on-warning]' \
  '(-k --keep-temp-dir)'{-k,--keep-temp-dir}'[preserve temp directory]' && ret=0
return ret
