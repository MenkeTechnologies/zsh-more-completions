#compdef nwg-look
# Documentation: https://github.com/nwg-piotr/nwg-look
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for nwg-look - GTK settings editor for Wayland

_arguments \
  '-a[apply stored gsetting and quit]' \
  '-d[turn on debug messages]' \
  '-r[restore default values and quit]' \
  '-v[display version information]' \
  '-x[export config files and quit]'
