#compdef payload_dumper
# Documentation: https://github.com/vm03/payload_dumper
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# payload_dumper: extract Android OTA payload.bin (vm03/payload_dumper)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--out=[output directory]:dir:_files -/' \
  '--diff[incremental OTA diff mode]' \
  '--old=[directory containing old partition images for diff mode]:dir:_files -/' \
  '--images=[comma-separated list of partitions to extract]:list:' \
  '*:payload.bin file:_files -g "payload.bin"' && ret=0
return ret
