#compdef phono3py
# phono3py — phonon-phonon interaction and lattice thermal conductivity

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-d[create displacements]' \
  '-f[forces from first-principles calculations]:force files:_files' \
  '--fc2[read second-order force constants]:file:_files' \
  '--fc3[read third-order force constants]:file:_files' \
  '--dim[supercell dimension for fc3]:dimensions:' \
  '--dim-fc2[supercell dimension for fc2]:dimensions:' \
  '--pa[primitive axis]:axes:' \
  '--mesh[sampling mesh]:mesh:' \
  '--br[calculate lattice thermal conductivity (RTA)]' \
  '--lbte[calculate with full LBTE solution]' \
  '--isotope[include isotope scattering]' \
  '--boundary-mfp[boundary mean free path]:mfp:' \
  '--tmin[minimum temperature]:temperature:' \
  '--tmax[maximum temperature]:temperature:' \
  '--tstep[temperature step]:step:' \
  '--ts[temperature list]:temperatures:' \
  '--sigma[smearing width]:sigma:' \
  '--nac[non-analytical term correction]' \
  '--born[Born effective charges file]:file:_files' \
  '-c[crystal structure file]:file:_files' \
  '--tolerance[symmetry tolerance]:tolerance:' \
  '-v[verbose output]' \
  '-q[quiet mode]' \
  '*:configuration file:_files -g "*.conf"'
