#compdef meek meek-client meek-server
# _meek — Tor Project meek pluggable transport CLI for the domain-fronting censorship circumvention proxy client and server tunneling Tor traffic through CDN HTTPS endpoints (torproject team, Go); flag
# upstream: https://gitlab.torproject.org/tpo/anti-censorship/pluggable-transports/meek

_meek() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-url=+[front URL]:str:' \
        '--url=+[front URL]:str:' \
        '-front=+[front host]:str:' \
        '--front=+[front host]:str:' \
        '-ua=+[user agent]:str:' \
        '--ua=+[user agent]:str:' \
        '-cert=+[file]:file:_files -g "*.pem *.crt"' \
        '--cert=+[file]:file:_files -g "*.pem *.crt"' \
        '-disable-tls[disable TLS]' \
        '--disable-tls[disable TLS]' \
        '-log=+[file]:file:_files' \
        '--log=+[file]:file:_files' \
        '-utls=+[fingerprint]:f:(HelloChrome HelloFirefox HelloIOS HelloRandomized HelloChrome_Auto)' \
        '--utls=+[fingerprint]:f:(HelloChrome HelloFirefox HelloIOS HelloRandomized HelloChrome_Auto)' \
        '-helper=+[helper addr]:str:' \
        '--helper=+[helper addr]:str:' \
        '-proxy=+[proxy URL]:str:' \
        '--proxy=+[proxy URL]:str:' \
        '-port=+[port]:n:' \
        '-listenAddr=+[addr]:str:' \
        '-acmeEmail=+[email]:str:' \
        '-acmeHostnames=+[csv]:str:'
}

_meek "$@"
