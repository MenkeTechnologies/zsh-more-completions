#compdef ninpaths
# Documentation: man ninpaths(8)
# Source: InterNetNews/inn backends/ninpaths.c — collect NNTP Path header stats (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-p[read Path lines from stdin]' \
    '-d+[write dump to file]:file:_files' \
    '-u+[read dump from file]:file:_files' \
    '-r+[generate report for site]:site:_default' \
    '-v+[report verbosity level]:level:_default' \
    && ret=0

return ret
