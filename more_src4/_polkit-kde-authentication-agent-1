#compdef polkit-kde-authentication-agent-1
# Documentation: https://invent.kde.org/plasma/polkit-kde-agent-1
# Reference accessed: 2026-05-20
# Verified: upstream KDE Plasma polkit-kde-agent-1. The agent is a
# Qt/KDE GUI daemon; it does not document app-specific flags beyond
# the standard Qt/KAboutData options (--help, --version, --author,
# --license, --desktopfile, etc.). STUB.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' && ret=0
return ret
