#compdef mdbook-svgbob2
# _mdbook-svgbob2 — second-generation svgbob preprocessor for mdbook (matthiasbeyer/mdbook-svgbob2)
# upstream: https://github.com/matthiasbeyer/mdbook-svgbob2
# Subcommands from src/main.rs (clap).

_mdbook-svgbob2() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'supports:check whether a renderer is supported'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                supports) _arguments '1:renderer:(html epub markdown)' ;;
            esac
            ;;
    esac
}

_mdbook-svgbob2 "$@"
