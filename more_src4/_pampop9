#compdef pampop9
# Documentation: man pampop9 (Netpbm)
# Source: create an Andy Warhol-style tiled grid from a single image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:input pnm:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    '2:xtiles:' \
    '3:ytiles:' \
    '4:xdelta:' \
    '5:ydelta:' \
    && ret=0

return ret
