#compdef mrfilter
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/mrfilter.html
# Source: MRtrix3/mrtrix3 cmd/mrfilter.cpp — apply image filters (fft/gradient/median/smooth/normalise/zclean) (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-axes+[axes along which to apply transform (FFT)]:list:_default' \
    '-inverse[apply inverse FFT]' \
    '-magnitude[output FFT magnitude]' \
    '-centre_zero[zero-frequency at image centre]' \
    '-stdev+[smoothing stdev per axis (mm)]:list:_default' \
    '-fwhm+[smoothing FWHM per axis (mm)]:list:_default' \
    '-extent+[median filter extent per axis]:list:_default' \
    '-maskin+[input mask for normalise/zclean]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-maskout+[output mask filename for zclean]:image:_files' \
    '-strides+[output data strides]:strides:_default' \
    '-datatype+[output datatype]:dtype:(float16 cfloat16 float32 cfloat32 float64 cfloat64 int8 uint8 int16 uint16 int32 uint32 int64 uint64 bit)' \
    '1:input image:_files -g "*.{nii,nii.gz,mif}"' \
    '2:filter:(fft gradient median smooth normalise zclean)' \
    '3:output image:_files' \
    && ret=0

return ret
