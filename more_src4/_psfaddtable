#compdef psfaddtable psfstriptable psfgettable
# _psfaddtable — Linux kbd psfaddtable / psfstriptable / psfgettable (manage Unicode font-position tables in PSF (.psf/.psfu) console fonts; add merges sfm table into font, strip removes it, get extracts it)
# upstream: https://github.com/legionus/kbd
# Argument shape from kbd src/psfxtable.c on tip.

_psfaddtable() {
    _arguments \
        '1:font file:_files -g "*.psf*"' \
        '2:table file:_files' \
        '3:output font:_files -g "*.psf*"'
}

_psfaddtable "$@"
