#compdef pamsistoaglyph
# Documentation: man pamsistoaglyph (Netpbm)
# Source: convert a SIS (single-image-stereogram) PAM into a red/cyan anaglyph.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--invert[invert eye assignment]' \
    '--sep=[stereo separation pixels]:number:' \
    '--minsep=[minimum separation pixels]:number:' \
    '--gray=[gray balance]:number:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:sis pam file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
