#compdef marqo
# Documentation: https://github.com/marqo-ai/marqo
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. STUB: Marqo ships as a Python
# library plus a Docker-deployed service; there is no first-party `marqo`
# shell binary documented upstream, so this stub only handles -h/--version
# and falls through to file completion.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*::passthrough:_command_names' && ret=0

return ret
