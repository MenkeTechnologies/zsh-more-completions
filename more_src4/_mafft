#compdef mafft
# Documentation: https://mafft.cbrc.jp/alignment/software/manual/manual.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# MAFFT: multiple sequence alignment with iterative refinement
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--auto[choose strategy automatically based on size]' \
  '--6merpair[approximate pairwise distance from 6-mers (default)]' \
  '--globalpair[Needleman-Wunsch all-vs-all then progressive]' \
  '--localpair[Smith-Waterman all-vs-all then progressive]' \
  '--genafpair[generalized affine local alignment]' \
  '--fastapair[fast pairwise via FASTA]' \
  '--weighti[weighting factor for the consistency term]:val' \
  '--retree[number of guide-tree rebuilds]:n' \
  '--maxiterate[number of iterative refinements]:n' \
  '--fft[use FFT approximation in group alignment]' \
  '--nofft[do not use FFT approximation]' \
  '--noscore[do not check alignment score in iterative refinement]' \
  '--memsave[save memory]' \
  '--parttree[use a fast tree-building method]' \
  '--dpparttree[partree variant using DP]' \
  '--fastaparttree[partree variant using FASTA]' \
  '--partsize[number of partitions]:n' \
  '--groupsize[max group size]:n' \
  '--ep[offset for gap-extension penalty]:val' \
  '--op[gap-opening penalty]:val' \
  '--lop[gap-opening at lobe penalty]:val' \
  '--lep[gap-extension at lobe penalty]:val' \
  '--lexp[lobe extension exponent]:val' \
  '--LOP[long-gap opening penalty]:val' \
  '--LEXP[long-gap extension exponent]:val' \
  '--bl[BLOSUM matrix variant]:n:(30 45 62 80)' \
  '--jtt[JTT matrix variant for proteins]:val' \
  '--tm[transmembrane variant]:val' \
  '--aamatrix[custom amino-acid matrix]:file:_files' \
  '--fmodel[FASTA-style scoring]' \
  '--nuc[force nucleic acid]' \
  '--amino[force protein]' \
  '--seed[seed alignment]:file:_files' \
  '--thread[CPU threads (-1 = auto)]:n' \
  '--threadtb[threads for progressive alignment]:n' \
  '--threadit[threads for iterative refinement]:n' \
  '--clustalout[ClustalW output]' \
  '--phylipout[PHYLIP interleaved output]' \
  '--namelength[sequence name length in phylipout]:n' \
  '--inputorder[output in input order]' \
  '--reorder[output reordered by tree]' \
  '--treeout[write guide tree]' \
  '--quiet[no progress messages]' \
  '*:FASTA input file:_files -g "*.(fa|fasta|fna)"' && ret=0
return ret
