#compdef ogrmerge ogrmerge.py
# Documentation: https://gdal.org/programs/ogrmerge.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--help-general[show generic GDAL options]' \
  '-o+[output dataset name]:file:_files' \
  '-f+[output format]:format:' \
  '-single[merge into a single layer]' \
  '-nln+[output layer name template]:name:' \
  '-field_strategy+[field strategy]:strategy:(FirstLayer Union Intersection)' \
  '-src_geom_type+[source geometry type filter]:type:(GEOMETRY POINT LINESTRING POLYGON MULTIPOINT MULTILINESTRING MULTIPOLYGON GEOMETRYCOLLECTION)' \
  '-src_layer_field_name+[field tracking source layer]:name:' \
  '-src_layer_field_content+[source tracking field template]:template:' \
  '*-dsco+[dataset creation option]:NAME=VALUE:' \
  '*-lco+[layer creation option]:NAME=VALUE:' \
  '-update[update existing dataset]' \
  '-overwrite_ds[overwrite existing dataset]' \
  '-overwrite_layer[overwrite existing layer]' \
  '-append[append to existing layer]' \
  '-progress[display progress]' \
  '-skipfailures[skip failures]' \
  '-a_srs+[assign SRS]:srs:' \
  '-s_srs+[source SRS]:srs:' \
  '-t_srs+[target SRS]:srs:' \
  '*:input vector file:_files' && ret=0

return ret
