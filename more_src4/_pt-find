#compdef pt-find
# Documentation: https://docs.percona.com/percona-toolkit/pt-find.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--ask-pass[prompt for password]' \
  '(--buffer-stdout --no-buffer-stdout)'{--buffer-stdout,--no-buffer-stdout}'[enable/disable STDOUT buffering]' \
  '--case-insensitive[make regex searches case-insensitive]' \
  '--charset=[default character set]:charset:' \
  '--config=[comma-separated config files]:files:_files' \
  '--database=[connect to this database]:db:' \
  '--day-start[measure times from beginning of today]' \
  '--defaults-file=[MySQL defaults file]:file:_files' \
  '--host=[MySQL host]:host:_hosts' \
  '--mysql_ssl=[create SSL MySQL connection]:n:' \
  '--or[combine tests with OR instead of AND]' \
  '--password=[MySQL password]:pw:' \
  '--pid=[PID file]:file:_files' \
  '--port=[MySQL port]:port:' \
  '(--quote --no-quote)'{--quote,--no-quote}'[quote MySQL identifiers with backticks]' \
  '--set-vars=[set MySQL variables]:vars:' \
  '--socket=[MySQL socket]:file:_files' \
  '--user=[MySQL user]:user:' \
  '(--version-check --no-version-check)'{--version-check,--no-version-check}'[check for latest versions]' \
  '--autoinc=[match table next AUTO_INCREMENT value]:val:' \
  '--avgrowlen=[average row length in bytes]:size:' \
  '--checksum=[table checksum value]:val:' \
  '--cmin=[table created n minutes ago]:n:' \
  '--ctime=[table created n days ago]:n:' \
  '--collation=[table collation pattern]:pat:' \
  '--column-name=[column name matches pattern]:pat:' \
  '--column-type=[column type]:type:' \
  '--comment=[table comment matches pattern]:pat:' \
  '--connection-id=[table name contains nonexistent connection ID]:val:' \
  '--createopts=[table create option matches pattern]:pat:' \
  '--datafree=[free space in bytes]:size:' \
  '--datasize=[data uses n bytes]:size:' \
  '--dblike=[database name matches LIKE pattern]:pat:' \
  '--dbregex=[database name matches regex]:re:' \
  '--empty[table has no rows]' \
  '--engine=[storage engine matches pattern]:engine:' \
  '--function=[function definition matches pattern]:pat:' \
  '--indexsize=[indexes use n bytes]:size:' \
  '--kmin=[table checked n minutes ago]:n:' \
  '--ktime=[table checked n days ago]:n:' \
  '--mmin=[last modified n minutes ago]:n:' \
  '--mtime=[last modified n days ago]:n:' \
  '--procedure=[procedure definition matches pattern]:pat:' \
  '--rowformat=[row format matches pattern]:pat:' \
  '--rows=[table has n rows]:n:' \
  '--server-id=[ensure tables match server ID in name]:id:' \
  '--tablesize=[total table size in bytes]:size:' \
  '--tbllike=[table name matches LIKE pattern]:pat:' \
  '--tblregex=[table name matches regex]:re:' \
  '--tblversion=[table version number]:n:' \
  '--trigger=[trigger action matches pattern]:pat:' \
  '--trigger-table=[trigger defined on table matching pattern]:pat:' \
  '--view=[CREATE VIEW matches pattern]:pat:' \
  '--exec=[execute SQL with each found item]:sql:' \
  '--exec-dsn=[DSN for executing SQL]:dsn:' \
  '--exec-plus=[execute SQL with all items at once]:sql:' \
  '--print[print database and table name (default)]' \
  '--printf=[print formatted output]:fmt:' \
  '*:DSN:' && ret=0

return ret
