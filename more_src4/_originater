#compdef originater
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/spotter/originater.html
# Source: GenericMappingTools/gmt supplements/spotter — associate seamounts with nearest hotspot origin.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-E+[rotation (file / plate IDs / lon/lat/angle)]:opts:_default' \
    '-F+[hotspot locations file]:file:_files' \
    '-D+[flowline sampling interval (km, default 5)]:km:_default' \
    '-L+[closest-approach output for nearest hotspot]:format:_default' \
    '-N+[extend oldest stage to max age]:age:_default' \
    '-Q+[constant radius+age (when input lacks)]:opts:_default' \
    '-S+[number of closest hotspots to report (default 1)]:n:_default' \
    '-T[truncate ages over upper limit]' \
    '*-V[verbose (stackable)]' \
    '-W+[max distance to hotspot]:distance:_default' \
    '-Z[output hotspot IDs (not names)]' \
    '-bi+[binary input format]:format:_default' \
    '-di+[input nodata → NaN]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-q+[row selection]:opts:_default' \
    '-s+[NaN-record handling]:opts:_default' \
    '-:[swap first two columns]' \
    '*:input seamount table:_files' \
    && ret=0

return ret
