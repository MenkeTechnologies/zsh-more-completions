#compdef pgcli
# _pgcli — dbcli pgcli (Postgres REPL with autocompletion, syntax highlighting, multi-line editing — alternative to psql)
# upstream: https://github.com/dbcli/pgcli
# Flags from pgcli/main.py @click decorators on tip; respects PGHOST/PGPORT/PGUSER/PGDATABASE/PGAPPNAME/PGROWLIMIT/PGCLIRC env vars.

_pgcli() {
    _arguments \
        '(- *)--help[show help]' \
        '(- *)'{-v,--version}'[show version and exit]' \
        '(-h --host)'{-h+,--host=}'[postgres host (env PGHOST)]:host:_hosts' \
        '(-p --port)'{-p+,--port=}'[postgres port (env PGPORT)]:port:' \
        '(-U --username -u --user)'{-U+,--username=,-u+,--user=}'[username (env PGUSER)]:user:' \
        '(-W --password)'{-W,--password}'[force password prompt]' \
        '(-w --no-password)'{-w,--no-password}'[never prompt for password]' \
        '--single-connection[do not use a separate connection for completions]' \
        '(-d --dbname)'{-d+,--dbname=}'[database name (env PGDATABASE)]:dbname:' \
        '--pgclirc=[pgclirc file location (env PGCLIRC)]:file:_files' \
        '(-D --dsn)'{-D+,--dsn=}'[DSN alias from pgclirc [alias_dsn] section (env DSN)]:alias:' \
        '--list-dsn[list configured DSN aliases and exit]' \
        '--row-limit=[row threshold before prompt (0=off, env PGROWLIMIT)]:n:' \
        '--application-name=[application_name for the connection (env PGAPPNAME)]:name:' \
        '--less-chatty[skip intro/goodbye banners]' \
        '--prompt=[prompt format (default: \u@\h:\d>)]:fmt:' \
        '--prompt-dsn=[prompt format for DSN-alias connections]:fmt:' \
        '(-l --list)'{-l,--list}'[list databases and exit]' \
        '--ping[check DB connectivity and exit]' \
        '--auto-vertical-output[switch to vertical output when wider than terminal]' \
        '--warn=[warn before running destructive queries]:level:(none all moderate)' \
        '--ssh-tunnel=[open SSH tunnel and connect through it]:hostport:' \
        '--log-file=[mirror queries+output to this file]:file:_files' \
        '--init-command=[SQL statement to run after connecting]:sql:' \
        '1:dbname:' \
        '2:username:'
}

_pgcli "$@"
