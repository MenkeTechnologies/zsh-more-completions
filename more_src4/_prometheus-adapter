#compdef prometheus-adapter
# _prometheus-adapter — Kubernetes custom/external metrics adapter for Prometheus
# upstream: https://github.com/kubernetes-sigs/prometheus-adapter
# Flags from cmd/adapter/adapter.go cmd.Flags() on tip.

_prometheus-adapter() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--prometheus-url=[Prometheus base URL]:url:_urls' \
        '--prometheus-auth-incluster=[use in-cluster auth to Prometheus]:bool:(true false)' \
        '--prometheus-auth-config=[kubeconfig-style auth config file]:file:_files' \
        '--prometheus-ca-file=[CA cert file for Prometheus TLS]:file:_files' \
        '--prometheus-client-tls-cert-file=[client TLS cert file]:file:_files' \
        '--prometheus-client-tls-key-file=[client TLS key file]:file:_files' \
        '--prometheus-token-file=[bearer token file for Prometheus]:file:_files' \
        '*--prometheus-header=[extra HTTP request header (Key=Value)]:header:' \
        '--prometheus-verb=[HTTP verb for Prometheus queries]:verb:(GET POST)' \
        '--config=[adapter configuration YAML]:file:_files -g "*.(yaml|yml)"' \
        '--metrics-relist-interval=[interval to relist available metrics]:dur:' \
        '--metrics-max-age=[max age accepted for a metric sample]:dur:' \
        '--disable-http2=[disable HTTP/2 for serving]:bool:(true false)' \
        '--secure-port=[secure-serving bind port]:port:' \
        '--cert-dir=[secure-serving cert directory]:dir:_files -/' \
        '--tls-cert-file=[TLS cert file]:file:_files' \
        '--tls-private-key-file=[TLS private key file]:file:_files' \
        '--authentication-kubeconfig=[delegated authn kubeconfig]:file:_files' \
        '--authorization-kubeconfig=[delegated authz kubeconfig]:file:_files' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_prometheus-adapter "$@"
