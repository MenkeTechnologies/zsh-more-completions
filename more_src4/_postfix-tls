#compdef postfix-tls
# Documentation: https://manpages.debian.org/postfix-tls
# Source: Postfix postfix-tls(1) — Postfix TLS management subcommands (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    '1:subcommand:(enable-client enable-server new-server-key new-server-cert deploy-server-cert output-server-csr output-server-tlsa)' \
    '*::subcommand args:->cmdargs' \
    && ret=0

case $state in
    cmdargs)
        case $line[1] in
            enable-client)
                _arguments '-r+[randsource]:source:_default' ;;
            enable-server|new-server-key|new-server-cert)
                _arguments \
                    '-r+[randsource]:source:_default' \
                    '-a+[key algorithm]:algorithm:(rsa ecdsa)' \
                    '-b+[bits or EC curve name]:bits:(2048 3072 4096 secp256r1 secp384r1 secp521r1)' \
                    '*:hostname:_hosts' \
                    ;;
            deploy-server-cert)
                _arguments '1:cert file:_files' '2:key file:_files' ;;
            output-server-csr)
                _arguments '-k+[key file]:file:_files' '*:hostname:_hosts' ;;
            output-server-tlsa)
                _arguments '-h+[hostname]:host:_hosts' '*:key file:_files' ;;
        esac
        ;;
esac

return ret
