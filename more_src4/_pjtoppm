#compdef pjtoppm
# Documentation: man pjtoppm (Netpbm)
# Source: convert an HP PaintJet printer-command stream to PPM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:paintjet file:_files' \
    && ret=0

return ret
