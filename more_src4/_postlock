#compdef postlock
# _postlock — Postfix mailbox lock helper (acquires an exclusive lock on a mailbox file using the local-delivery-agent lock style, then execs a command while holding it)
# upstream: https://github.com/vdukhovni/postfix
# Flags from postfix/man/man1/postlock.1 on tip.

_postlock() {
    _arguments \
        '-c+[config directory]:dir:_files -/' \
        '-l+[override mailbox_delivery_lock style]:style:(fcntl flock dotlock)' \
        '*-v[verbose logging (repeat for more)]' \
        '1:mailbox file:_files' \
        '*::command:_command_names -e'
}

_postlock "$@"
