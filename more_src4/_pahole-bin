#compdef pahole
# _pahole-bin — pahole DWARF struct layout pretty-printer (Arnaldo Carvalho de Melo); print structs with hole/cache-line analysis
# upstream: https://github.com/acmel/dwarves

_pahole-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-a --anon_include)'{-a,--anon_include}'[show anonymous]' \
        '(-A --nested_anon_include)'{-A,--nested_anon_include}'[show nested anon]' \
        '(-b --bit_holes)'{-b,--bit_holes}'+[minimal bit holes]:n:' \
        '(-B --btf_base)'{-B,--btf_base}'+[BTF base]:file:_files' \
        '(-c --cacheline_size)'{-c,--cacheline_size}'+[cacheline bytes]:n:' \
        '(-C --class_name)'{-C,--class_name}'+[print class]:class:' \
        '(-d --recursive)'{-d,--recursive}'[recursive]' \
        '(-D --decl_exclude)'{-D,--decl_exclude}'+[exclude decl]:str:' \
        '(-E --expand_types)'{-E,--expand_types}'[expand]' \
        '(-f --find_pointers_to)'{-f,--find_pointers_to}'+[class]:class:' \
        '(-F --format_path)'{-F,--format_path}'+[format]:fmt:' \
        '(-H --holes)'{-H,--holes}'+[min holes]:n:' \
        '(-i --contains)'{-i,--contains}'+[contains type]:type:' \
        '(-I --show_decl_info)'{-I,--show_decl_info}'[show decl info]' \
        '(-j --jobs)'{-j,--jobs}'+[parallel jobs]:n:' \
        '(-J --btf_encode)'{-J,--btf_encode}'[encode BTF]' \
        '(-l --show_first_biggest_size_base_type_member)'{-l,--show_first_biggest_size_base_type_member}'[order rule]' \
        '(-m --nr_methods)'{-m,--nr_methods}'+[methods threshold]:n:' \
        '(-M --show_only_data_members)'{-M,--show_only_data_members}'[only data members]' \
        '(-n --nr_members)'{-n,--nr_members}'+[member threshold]:n:' \
        '(-N --class_name_len)'{-N,--class_name_len}'[show class name len]' \
        '(-O --no_ordinary_enums)'{-O,--no_ordinary_enums}'[no ordinary enums]' \
        '(-p --expand_pointers)'{-p,--expand_pointers}'[expand pointer types]' \
        '(-P --packable)'{-P,--packable}'[packable structs]' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '(-r --reorganize)'{-r,--reorganize}'[reorg fields]' \
        '(-R --rel_offset)'{-R,--rel_offset}'[show rel offset]' \
        '(-s --sizes)'{-s,--sizes}'[show sizes]' \
        '(-S --suppress_aligned_attribute)'{-S,--suppress_aligned_attribute}'[suppress aligned attr]' \
        '(-t --separator)'{-t,--separator}'+[separator]:c:' \
        '(-T --total_struct_stats)'{-T,--total_struct_stats}'[stats]' \
        '(-u --defined_in)'{-u,--defined_in}'[file printed]' \
        '(-x --exclude)'{-x,--exclude}'+[exclude prefix]:prefix:' \
        '(-X --cu_exclude)'{-X,--cu_exclude}'+[cu exclude]:str:' \
        '(-y --prefix_filter)'{-y,--prefix_filter}'+[prefix filter]:prefix:' \
        '(-z --hex_fixed_arrays)'{-z,--hex_fixed_arrays}'[hex arrays]' \
        '--structs[only structs]' \
        '--unions[only unions]' \
        '--enums[only enums]' \
        '--typedefs[only typedefs]' \
        '*:file:_files'
}

_pahole-bin "$@"
