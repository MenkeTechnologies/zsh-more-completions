#compdef npins
# Documentation: https://github.com/andir/npins
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# npins: Nix dependency pinning, inspired by niv.
local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '(-d --directory)'{-d+,--directory=}'[set sources.json location]:folder:_files -/' \
  '--lock-file=[activate lockfile mode]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[enable debug message output]' \
  '(- 1 *)'{-h,--help}'[show help]' \
  '(- 1 *)'{-V,--version}'[show version]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'init:initialize the npins directory'
      'add:add a new pin entry'
      'show:list the current pin entries'
      'update:update all or the given pins to the latest version'
      'verify:verify pin hashes in dry-run mode'
      'upgrade:upgrade sources.json and default.nix to the latest format version'
      'remove:remove one pin entry'
      'import-niv:import entries from niv'
      'import-flake:import entries from flake.lock'
      'freeze:prevent pins from updating'
      'unfreeze:allow frozen pins to update normally'
      'get-path:evaluate and fetch store paths for pins'
      'fetch:download pinned sources into the store'
      'help:show help for subcommands'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
