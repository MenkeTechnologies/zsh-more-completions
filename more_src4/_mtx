#compdef mtx
# Documentation: man mtx(1)
# Source: mtx (SourceForge) — control SCSI media changer devices (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a cmds=(
    'version:show mtx version'
    'inquiry:report changer product info'
    'noattach:use regular changer API (not _ATTACHED)'
    'inventory:make robot re-scan all slots'
    'status:report drives and slot contents'
    'load:load media from slot to drive'
    'unload:unload drive media back to slot'
    'transfer:transfer media between slots'
    'exchange:swap media between two slots'
    'first:load first slot media to drive'
    'last:load last slot media to drive'
    'next:load next slot media to drive'
    'eject:eject media currently in drive'
    'eepos:control import/export tray (prefix)'
    'invert:flip media before insertion (prefix)'
    'nobarcode:disable barcode reading'
)

_arguments -s -C \
    '-f+[SCSI generic device]:device:_files -g "/dev/sg* /dev/pass* /dev/rdsk/*"' \
    '--version[show version]' \
    'nobarcode[ignore barcodes]' \
    'invert[flip media before insertion]' \
    'noattach[use regular media changer API]' \
    '*::command:->cmd' \
    && ret=0

case $state in
    cmd) _describe -t commands 'mtx command' cmds && ret=0 ;;
esac

return ret
