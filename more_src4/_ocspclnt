#compdef ocspclnt
# Documentation: man ocspclnt(1)
# Source: nss-dev/nss cmd/ocspclnt/ocspclnt.c (master) — NSS OCSP test client (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-p -P -r -R -S -V)-p[pretty-print binary request from stdin]' \
    '(-p -P -r -R -S -V)-P[pretty-print binary response from stdin]' \
    '(-p -P -r -R -S -V)-r+[create request for cert nickname]:nickname:_default' \
    '(-p -P -r -R -S -V)-R+[get response for cert nickname]:nickname:_default' \
    '(-p -P -r -R -S -V)-S+[get status for cert nickname]:nickname:_default' \
    '(-p -P -r -R -S -V)-V+[fully verify cert nickname]:nickname:_default' \
    '-a[decode input cert from PEM (default DER)]' \
    '-L[use OCSP responder URL from cert (AIA)]' \
    '-d+[NSS database directory]:dir:_files -/' \
    '-l+[OCSP responder URL]:url:_default' \
    '-t+[trusted responder cert nickname]:nickname:_default' \
    '-s+[signer nickname]:nickname:_default' \
    '-u+[cert usage]:usage:(SSLClient SSLServer SSLServerWithStepUp SSLCA EmailSigner EmailRecipient ObjectSigner UserCertImport VerifyCA ProtectedObjectSigner StatusResponder AnyCA)' \
    '-w+[verify time]:time:_default' \
    '-H[show long help]' \
    && ret=0

return ret
