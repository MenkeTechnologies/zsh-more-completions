#compdef metrics-server
# _metrics-server — Kubernetes Metrics Server (sigs.k8s.io/metrics-server)
# upstream: https://github.com/kubernetes-sigs/metrics-server
# Flags from cmd/metrics-server/app/options/options.go + kubelet_client.go on tip.

_metrics-server() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metric-resolution=[resolution at which to retain metrics (>=10s)]:dur:' \
        '--version[show version]' \
        '--kubeconfig=[kubeconfig path]:file:_files' \
        '--kubelet-insecure-tls[do not verify Kubelet serving certificates]' \
        '--kubelet-use-node-status-port[use the port in node status]' \
        '--kubelet-port=[Kubelet port]:port:' \
        '--kubelet-preferred-address-types=[priority of node address types]:csv:(Hostname InternalDNS InternalIP ExternalDNS ExternalIP)' \
        '--kubelet-certificate-authority=[CA file for Kubelet serving certs]:file:_files' \
        '--kubelet-client-key=[TLS client key file]:file:_files' \
        '--kubelet-client-certificate=[TLS client cert file]:file:_files' \
        '--kubelet-request-timeout=[per-Kubelet request timeout]:dur:' \
        {-l,--node-selector=}'[node label selector]:selector:' \
        '--deprecated-kubelet-completely-insecure[DEPRECATED: disable Kubelet TLS+auth entirely]' \
        '--secure-port=[secure-serving bind port]:port:' \
        '--bind-address=[secure-serving bind address]:host:' \
        '--cert-dir=[secure-serving cert directory]:dir:_files -/' \
        '--tls-cert-file=[TLS cert file]:file:_files' \
        '--tls-private-key-file=[TLS private key file]:file:_files' \
        '--authentication-kubeconfig=[delegated authn kubeconfig]:file:_files' \
        '--authorization-kubeconfig=[delegated authz kubeconfig]:file:_files' \
        '--logging-format=[log format]:fmt:(text json)' \
        '-v[klog verbosity level]:n:'
}

_metrics-server "$@"
