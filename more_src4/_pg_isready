#compdef pg_isready
# Documentation: pg_isready --help (PostgreSQL)
# Source: check connection status of a PostgreSQL server.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-?,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    {-d+,--dbname=}'[database name or connection string]:db:' \
    {-q,--quiet}'[run quietly]' \
    {-h+,--host=}'[server host/socket]:host:_hosts' \
    {-p+,--port=}'[server port]:port:_ports' \
    {-t+,--timeout=}'[seconds to wait (0=disable)]:seconds:' \
    {-U+,--username=}'[user name]:user:_users' \
    && ret=0

return ret
