#compdef moptrace
# Documentation: man moptrace(1)
# Source: netbsd/src usr.sbin/mopd/moptrace — trace MOP Ethernet traffic (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[monitor all Ethernet interfaces]' \
    '-d[debug mode, output to stderr]' \
    '(-4)-3[ignore MOP V3 messages (Ethernet II)]' \
    '(-3)-4[ignore MOP V4 messages (Ethernet 802.3)]' \
    '1::interface:_net_interfaces' \
    && ret=0

return ret
