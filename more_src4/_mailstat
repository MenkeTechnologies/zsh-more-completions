#compdef mailstat
# _mailstat — procmail's mailstat (parse a procmail $LOGFILE and print a per-folder mail-arrival summary; truncates the log unless -k is used)
# upstream: https://github.com/BuGlessRB/procmail
# Flags from man/mailstat.man on tip.

_mailstat() {
    _arguments \
        '-k[keep logfile intact (do not truncate)]' \
        '-l[long display format]' \
        '-m[merge errors into one line]' \
        '-o[use the old logfile]' \
        '-t[terse display format]' \
        '-s[silent if no mail]' \
        '1:logfile:_files'
}

_mailstat "$@"
