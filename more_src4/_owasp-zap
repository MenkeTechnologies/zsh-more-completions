#compdef owasp-zap zap zap.sh
# Documentation: https://www.zaproxy.org/docs/desktop/cmdline/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# OWASP ZAP: web app proxy/scanner (Java). Single-dash long options.
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-h[show help]' \
  '-version[show version]' \
  '-cmd[command-line mode (no GUI)]' \
  '-daemon[run as daemon (headless)]' \
  '-host[host to bind]:host:_hosts' \
  '-port[port to listen]:port:' \
  '-config[set config key=value]:kv:' \
  '-configfile[config properties file]:file:_files' \
  '-dir[home directory]:dir:_files -/' \
  '-session[open existing session]:file:_files' \
  '-newsession[create new session]:file:_files' \
  '-installdir[ZAP install directory]:dir:_files -/' \
  '-script[execute script]:file:_files' \
  '-quickurl[quick attack URL]:url:' \
  '-quickout[quick scan output file]:file:_files' \
  '-quickprogress[print quick scan progress]' \
  '-silent[prevent unsolicited requests]' \
  '-nostdout[disable stdout logging]' \
  '-loglevel[log level]:level:(OFF FATAL ERROR WARN INFO DEBUG TRACE ALL)' \
  '-addoninstall[install marketplace add-on]:id:' \
  '-addoninstallall[install all available add-ons]' \
  '-addonuninstall[remove add-on]:id:' \
  '-addonupdate[update changed add-ons]' \
  '-addonlist[list installed add-ons]' \
  '-suppinfo[output diagnostic details]' \
  '-sbomzip[generate SBOMs archive]:file:_files' \
  '-lowmem[prioritize database over memory]' \
  '-experimentaldb[use experimental database code]' \
  '*::owasp-zap args:_files' && ret=0
return ret
