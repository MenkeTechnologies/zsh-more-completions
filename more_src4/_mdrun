#compdef mdrun mdrun_mpi mdrun_d mdrun_mpi_d
# _mdrun — GROMACS team mdrun MD integrator energy minimizer mostly via gmx mdrun also as standalone legacy binary (gromacs team, C/C++); custom argparse
# upstream: https://gitlab.com/gromacs/gromacs

_mdrun() {
    _arguments \
        '-h[show help]' \
        '-version[show version]' \
        '-s+[tpr file]:file:_files -g "*.tpr"' \
        '-o+[trr file]:file:_files -g "*.trr"' \
        '-x+[xtc file]:file:_files -g "*.xtc *.tng"' \
        '-cpi+[checkpoint in]:file:_files -g "*.cpt"' \
        '-cpo+[checkpoint out]:file:_files -g "*.cpt"' \
        '-c+[gro file]:file:_files -g "*.gro *.pdb"' \
        '-e+[energy file]:file:_files -g "*.edr"' \
        '-g+[log file]:file:_files -g "*.log"' \
        '-dhdl+[free energy dhdl file]:file:_files -g "*.xvg"' \
        '-field+[external field file]:file:_files -g "*.xvg"' \
        '-tpi+[TPI energy file]:file:_files' \
        '-tpid+[TPI distribution file]:file:_files' \
        '-ei+[ensemble file]:file:_files' \
        '-eo+[ensemble out]:file:_files' \
        '-px+[pull x file]:file:_files' \
        '-pf+[pull force file]:file:_files' \
        '-ro+[swap file]:file:_files' \
        '-ra+[swap file]:file:_files' \
        '-rs+[swap file]:file:_files' \
        '-rt+[swap file]:file:_files' \
        '-mtx+[matrix file]:file:_files' \
        '-multidir+[multidir]:dir:_files -/' \
        '-replex+[N]:n:' \
        '-nex+[N]:n:' \
        '-reseed+[seed]:n:' \
        '-deffnm+[default name]:str:' \
        '-noappend[no append]' \
        '-resethway[reset half way]' \
        '-resetstep+[N]:n:' \
        '-nsteps+[N]:n:' \
        '-maxh+[hours]:f:' \
        '-pforce+[F]:f:' \
        '-stepout+[N]:n:' \
        '-nb+[nb mode]:m:(auto cpu gpu cpu_gpu)' \
        '-pme+[pme mode]:m:(auto cpu gpu)' \
        '-bonded+[bonded mode]:m:(auto cpu gpu)' \
        '-update+[update mode]:m:(auto cpu gpu)' \
        '-tunepme[tune PME]' \
        '-notunepme[no tune PME]' \
        '-rerun+[trajectory file]:file:_files -g "*.trr *.xtc *.tng"' \
        '-nt+[N total threads]:n:' \
        '-ntomp+[N OpenMP threads]:n:' \
        '-ntmpi+[N MPI threads]:n:' \
        '-ntomp_pme+[N PME OpenMP threads]:n:' \
        '-pin+[pin mode]:m:(auto on off)' \
        '-pinstride+[N]:n:' \
        '-pinoffset+[N]:n:' \
        '-gpu_id+[GPUs csv]:str:' \
        '-gputasks+[gpu tasks]:str:' \
        '-ddorder+[order]:m:(interleave pp_pme cartesian)' \
        '-ddorder=+[order]:m:(interleave pp_pme cartesian)' \
        '-npme+[N]:n:' \
        '-dd+[NXxNYxNZ]:str:' \
        '-rdd+[F]:f:' \
        '-rcon+[F]:f:' \
        '-dlb+[mode]:m:(auto yes no)' \
        '-dds+[F]:f:' \
        '-gcom+[N]:n:' \
        '-nb+[mode]:m:(auto cpu gpu cpu_gpu)'
}

_mdrun "$@"
