#compdef posthog-cli
# Documentation: https://github.com/PostHog/posthog
# Reference accessed: 2026-05-23
# Verified: @posthog/cli posthog-cli --help.

# Zsh completion for posthog-cli - PostHog CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--host[PostHog host]:url:' \
  '--no-fail[disable non-zero exit on errors]' \
  '--skip-ssl-verification[skip SSL verification]' \
  '--rate-limit[API requests per minute]:n:' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'posthog-cli command' \
      'login[authenticate and store API token]' \
      'exp[experimental commands]' \
      'sourcemap[upload bundled sourcemaps]' \
      'dsym[upload Apple dSYM debug symbols]' \
      'hermes[upload Hermes sourcemaps]' \
      'proguard[upload ProGuard mapping files]' \
      'symbol-sets[manage uploaded symbol sets]' && ret=0
    ;;
esac

return ret
