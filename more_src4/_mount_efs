#compdef mount_efs
# Documentation: man mount_efs(8)
# Source: netbsd/src sbin/mount_efs — mount an SGI EFS file system (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-o+[mount options (comma-separated, see mount(8))]:options:_default' \
    '1:special device:_files' \
    '2:mount point:_files -/' \
    && ret=0

return ret
