#compdef mongoimport
# Documentation: https://www.mongodb.com/docs/database-tools/mongoimport/
# Source: MongoDB Database Tools — import JSON / CSV / TSV into a collection.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(-v --verbose)*'{-v,--verbose}'[increase verbosity]' \
    '--quiet[quiet mode]' \
    '(- *)--version[show version]' \
    '--config=[YAML config file]:file:_files' \
    '--uri=[MongoDB connection URI]:uri:' \
    '(-h --host)'{-h+,--host=}'[hostname[:port]]:host:_hosts' \
    '--port=[TCP port]:port:' \
    '--ssl[enable TLS/SSL]' \
    '--sslCAFile=[CA cert chain (.pem)]:file:_files' \
    '--sslPEMKeyFile=[client cert+key (.pem)]:file:_files' \
    '--sslPEMKeyPassword=[cert-key password]:password:' \
    '--sslCRLFile=[CRL file]:file:_files' \
    '--sslAllowInvalidCertificates[bypass server cert validation]' \
    '--sslAllowInvalidHostnames[bypass hostname validation]' \
    '(-u --username)'{-u+,--username=}'[auth username]:user:_users' \
    '(-p --password)'{-p+,--password=}'[auth password]:password:' \
    '--awsSessionToken=[AWS session token]:token:' \
    '--authenticationDatabase=[auth database]:db:' \
    '--authenticationMechanism=[auth mechanism]:mech:(SCRAM-SHA-1 SCRAM-SHA-256 MONGODB-X509 MONGODB-AWS GSSAPI PLAIN)' \
    '--gssapiServiceName=[GSSAPI service name]:name:' \
    '--gssapiHostName=[GSSAPI host name]:host:_hosts' \
    '(-d --db)'{-d+,--db=}'[database name]:db:' \
    '(-c --collection)'{-c+,--collection=}'[collection to import into]:collection:' \
    '(-f --fields)'{-f+,--fields=}'[field names for CSV/TSV]:list:' \
    '--fieldFile=[file with field names]:file:_files' \
    '--ignoreBlanks[ignore empty fields in CSV/TSV]' \
    '--type=[input file type]:type:(json csv tsv)' \
    '--file=[input file path]:file:_files' \
    '--drop[drop collection before importing]' \
    '--headerline[first CSV/TSV line is field names]' \
    '--useArrayIndexFields[natural numbers in field names = array indexes]' \
    '--mode=[handling of existing docs]:mode:(insert upsert merge delete)' \
    '--upsertFields=[fields used as upsert query]:list:' \
    '--stopOnError[halt on first error]' \
    '--jsonArray[accept JSON array of documents]' \
    '--legacy[Extended JSON v1 format]' \
    '--maintainInsertionOrder[insert in source order]' \
    '--numInsertionWorkers=[parallel insertion workers]:n:' \
    '--writeConcern=[write-concern document]:doc:' \
    '--bypassDocumentValidation[skip document validation]' \
    '--columnsHaveTypes[field list specifies types]' \
    '--parseGrace=[type-coercion failure mode]:mode:(autoCast skipField skipRow stop)' \
    '*:input file:_files' \
    && ret=0

return ret
