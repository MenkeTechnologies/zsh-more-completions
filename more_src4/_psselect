#compdef psselect
# Documentation: psselect usage (psutils 1.23)
# Source: extract/reorder pages from a PostScript document.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-q[quiet operation]' \
    '-e[only even pages]' \
    '-o[only odd pages]' \
    '-r[reverse page order]' \
    '-p+[page range list]:pages:' \
    '1:input ps:_files -g "*.ps"' \
    '2:output ps:_files -g "*.ps"' \
    && ret=0

return ret
