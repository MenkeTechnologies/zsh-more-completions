#compdef pscontour
# Documentation: https://docs.generic-mapping-tools.org/latest/pscontour.html
# Source: GenericMappingTools/gmt src/pscontour.c — contour table data via Delaunay triangulation (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-J+[map projection]:projection:_default' \
    '-R+[region]:region:_default' \
    '-A+[annotated contour spec]:opts:_default' \
    '-B+[axes options]:opts:_default' \
    '-C+[contour interval / file]:contours:_default' \
    '-D+[contour-dump template]:template:_default' \
    '-E+[triangle index table]:file:_files' \
    '-I[colour triangles using CPT]' \
    '-K[allow more PS later]' \
    '-N[do not clip contours at border]' \
    '-O[append PostScript]' \
    '-P[portrait]' \
    '-Q+[skip short contours]:opts:_default' \
    '-S+[skip points outside region]:opts:(p t)' \
    '-U+[plot timestamp]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-X+[x shift]:shift:_default' \
    '-bi+[binary input format]:format:_default' \
    '-bo+[binary output format]:format:_default' \
    '-c+[subplot panel]:panel:_default' \
    '-d+[nodata↔NaN replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-l+[legend setting]:opts:_default' \
    '-p+[3D perspective]:view:_default' \
    '-qi+[record selection]:cols:_default' \
    '-s+[skip records with NaN]:cols:_default' \
    '-t+[transparency]:value:_default' \
    '*:input table:_files' \
    && ret=0

return ret
