#compdef markmap
# markmap - Visualize markdown as a mind map

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-o --output)'{-o+,--output=}'[output file path]:file:_files' \
  '--no-open[do not open output file in browser]' \
  '--no-toolbar[hide toolbar in output]' \
  '--no-network-assets[use inline assets instead of CDN]' \
  '--offline[shorthand for --no-network-assets]' \
  '-w[watch for file changes and auto-reload]' \
  '--watch[watch for file changes and auto-reload]' \
  '--enable-mathjax[enable MathJax support]' \
  '--enable-prism[enable PrismJS code highlighting]' \
  '--color-free-node=[colorize nodes by depth]:colors:' \
  '--duration=[animation duration in ms]:ms:' \
  '--max-width=[max width of each node]:width:' \
  '--zoom[enable zoom and pan]' \
  '--no-zoom[disable zoom and pan]' \
  '--pan[enable panning]' \
  '--no-pan[disable panning]' \
  '--fit[zoom to fit on initial load]' \
  '--no-fit[do not zoom to fit on initial load]' \
  '1:markdown file:_files -g "*.{md,markdown,mmd}"' && ret=0

return ret
