#compdef phalanx
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man6/phalanx.6.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-v[print version and exit]' \
  '-t+[transposition table size KB]:kb:' \
  '-f+[fixed search seconds]:sec:' \
  '-x+[toggle xboard mode]:state:(+ -)' \
  '-p+[toggle permanent brain]:state:(+ -)' \
  '-s+[toggle show thinking]:state:(+ -)' \
  '-c+[toggle CPU time display]:state:(+ -)' \
  '-o+[toggle polling input]:state:(+ -)' \
  '-b+[toggle opening book]:state:(+ -)' \
  '-r+[resign value in centipawns]:cp:' \
  '-e+[easy level 0-100]:lvl:' \
  '-l+[toggle learning]:state:(+ -)' \
  '-P+[primary book directory]:dir:_directories' \
  '-S+[secondary book directory]:dir:_directories' \
  '-L+[learning file directory]:dir:_directories' \
  '-g+[log file]:file:_files' && ret=0

return ret
