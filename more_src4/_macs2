#compdef macs2
# Documentation: https://github.com/macs3-project/MACS
# Reference accessed: 2026-05-27
# Verified: upstream macs3-project/MACS bin/macs2 (subparser registration) and per-subcommand argparse blocks.

# Zsh completion for MACS2 ChIP-seq peak caller.

local curcontext="$curcontext" state line ret=1

local -a _macs2_subcommands
_macs2_subcommands=(
  'callpeak:main MACS2 function: call peaks from alignment results'
  'bdgpeakcall:call peaks from bedGraph output'
  'bdgbroadcall:call broad peaks from bedGraph output'
  'bdgcmp:deduct noise by comparing two signal tracks in bedGraph'
  'bdgopt:operations on score column of a bedGraph file'
  'cmbreps:combine bedGraphs of scores from replicates'
  'bdgdiff:differential peak detection from paired bedGraph files'
  'filterdup:remove duplicate reads, save as BED/BEDPE'
  'predictd:predict d or fragment size from alignment results'
  'pileup:pileup aligned reads with a given extension size'
  'randsample:randomly sample number/percentage of total reads'
  'refinepeak:refine peak summits from raw read alignments'
)

_arguments -C \
  '--version[print version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'macs2 subcommand' _macs2_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      callpeak)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '*'{-t+,--treatment=}'[ChIP-seq treatment file]:file:_files' \
          '*'{-c+,--control=}'[control file]:file:_files' \
          '(-f --format)'{-f+,--format=}'[input format]:format:(AUTO BAM SAM BED ELAND ELANDMULTI ELANDEXPORT BOWTIE BAMPE BEDPE)' \
          '(-g --gsize)'{-g+,--gsize=}'[effective genome size]:size:(hs mm ce dm)' \
          '(-s --tsize)'{-s+,--tsize=}'[tag size]:int:' \
          '--keep-dup=[duplicate tag behavior]:value:(auto all 1)' \
          '--outdir=[output directory]:dir:_files -/' \
          '(-n --name)'{-n+,--name=}'[experiment name]:name:' \
          '(-B --bdg)'{-B,--bdg}'[save extended fragment pileup as bedGraph]' \
          '--verbose=[verbose level (0-3)]:int:' \
          '--trackline[include UCSC trackline]' \
          '--SPMR[signal per million reads in bedGraph]' \
          '--nomodel[bypass shifting model]' \
          '--shift=[arbitrary shift in bp]:int:' \
          '--extsize=[extension size in bp]:int:' \
          '--bw=[band width for model building]:int:' \
          '--d-min=[minimum fragment size]:int:' \
          '(-m --mfold)'{-m+,--mfold=}'[mfold range (lo hi)]:range:' \
          '--fix-bimodal[turn on auto-pair for non-bimodal data]' \
          '(-q --qvalue)'{-q+,--qvalue=}'[q-value cutoff]:float:' \
          '(-p --pvalue)'{-p+,--pvalue=}'[p-value cutoff]:float:' \
          '--scale-to=[scale direction]:dir:(large small)' \
          '--down-sample[down-sample to smaller set]' \
          '--seed=[random seed]:int:' \
          '--tempdir=[temp directory]:dir:_files -/' \
          '--nolambda[skip dynamic lambda]' \
          '--slocal=[small local region size]:int:' \
          '--llocal=[large local region size]:int:' \
          '--max-gap=[max gap between sites]:int:' \
          '--min-length=[min peak length]:int:' \
          '--broad[broad peak calling]' \
          '--broad-cutoff=[broad region cutoff]:float:' \
          '--cutoff-analysis[output cutoff analysis report]' \
          '--call-summits[call sub-peak summits]' \
          '--fe-cutoff=[fold-enrichment filter]:float:' \
          '--buffer-size=[buffer size]:int:' && ret=0
        ;;
      bdgpeakcall)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-i --ifile)'{-i+,--ifile=}'[input bedGraph file]:file:_files' \
          '(-c --cutoff)'{-c+,--cutoff=}'[score cutoff]:float:' \
          '(-l --min-length)'{-l+,--min-length=}'[min peak length]:int:' \
          '(-g --max-gap)'{-g+,--max-gap=}'[max gap]:int:' \
          '--no-trackline[suppress trackline]' \
          '--outdir=[output directory]:dir:_files -/' \
          '(-o --ofile)'{-o+,--ofile=}'[output file]:file:_files' && ret=0
        ;;
      bdgbroadcall)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-i --ifile)'{-i+,--ifile=}'[input bedGraph]:file:_files' \
          '(-c --cutoff-peak)'{-c+,--cutoff-peak=}'[peak cutoff]:float:' \
          '(-C --cutoff-link)'{-C+,--cutoff-link=}'[link cutoff]:float:' \
          '(-l --min-length)'{-l+,--min-length=}'[min length]:int:' \
          '(-g --lvl1-max-gap)'{-g+,--lvl1-max-gap=}'[level-1 max gap]:int:' \
          '(-G --lvl2-max-gap)'{-G+,--lvl2-max-gap=}'[level-2 max gap]:int:' \
          '--outdir=[output directory]:dir:_files -/' \
          '(-o --ofile)'{-o+,--ofile=}'[output file]:file:_files' && ret=0
        ;;
      bdgcmp)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-t --tfile)'{-t+,--tfile=}'[treatment bedGraph]:file:_files' \
          '(-c --cfile)'{-c+,--cfile=}'[control bedGraph]:file:_files' \
          '(-S --scaling-factor)'{-S+,--scaling-factor=}'[scaling factor]:float:' \
          '(-p --pseudocount)'{-p+,--pseudocount=}'[pseudocount]:float:' \
          '(-m --method)'{-m+,--method=}'[comparison method]:method:(ppois qpois subtract logFE FE logLR slogR max)' \
          '--outdir=[output directory]:dir:_files -/' \
          '(-o --ofile)'{-o+,--ofile=}'[output file(s)]:files:_files' && ret=0
        ;;
      bdgopt)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-i --ifile)'{-i+,--ifile=}'[input bedGraph]:file:_files' \
          '(-m --method)'{-m+,--method=}'[operation]:method:(multiply add p2q max min)' \
          '(-p --extra-param)'{-p+,--extra-param=}'[extra parameter]:value:' \
          '--outdir=[output directory]:dir:_files -/' \
          '(-o --ofile)'{-o+,--ofile=}'[output file]:file:_files' && ret=0
        ;;
      cmbreps)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '*'{-i+,--ifile=}'[input bedGraph files]:file:_files' \
          '(-m --method)'{-m+,--method=}'[combination method]:method:(fisher max mean)' \
          '--outdir=[output directory]:dir:_files -/' \
          '(-o --ofile)'{-o+,--ofile=}'[output file]:file:_files' && ret=0
        ;;
      bdgdiff)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--t1=[treatment 1 pileup]:file:_files' \
          '--c1=[control 1 pileup]:file:_files' \
          '--t2=[treatment 2 pileup]:file:_files' \
          '--c2=[control 2 pileup]:file:_files' \
          '(-C --cutoff)'{-C+,--cutoff=}'[log10 likelihood ratio cutoff]:float:' \
          '(-l --min-len)'{-l+,--min-len=}'[min region length]:int:' \
          '(-g --max-gap)'{-g+,--max-gap=}'[max gap]:int:' \
          '--d1=[depth of treatment 1]:int:' \
          '--d2=[depth of treatment 2]:int:' \
          '--outdir=[output directory]:dir:_files -/' \
          '--o-prefix=[output prefix]:prefix:' && ret=0
        ;;
      filterdup)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-t --ifile)'{-t+,--ifile=}'[input alignment]:file:_files' \
          '(-f --format)'{-f+,--format=}'[input format]:format:(AUTO BAM SAM BED BAMPE BEDPE)' \
          '(-g --gsize)'{-g+,--gsize=}'[genome size]:size:' \
          '(-s --tsize)'{-s+,--tsize=}'[tag size]:int:' \
          '(-p --pvalue)'{-p+,--pvalue=}'[p-value cutoff]:float:' \
          '--keep-dup=[duplicate behavior]:value:(auto all 1)' \
          '--outdir=[output directory]:dir:_files -/' \
          '(-o --ofile)'{-o+,--ofile=}'[output file]:file:_files' \
          '(-d --dry-run)'{-d,--dry-run}'[no output, only stats]' \
          '--buffer-size=[buffer size]:int:' \
          '--verbose=[verbose level]:int:' && ret=0
        ;;
      predictd)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-i --ifile)'{-i+,--ifile=}'[input file(s)]:file:_files' \
          '(-f --format)'{-f+,--format=}'[input format]:format:(AUTO BAM SAM BED BAMPE BEDPE)' \
          '(-g --gsize)'{-g+,--gsize=}'[genome size]:size:' \
          '(-s --tsize)'{-s+,--tsize=}'[tag size]:int:' \
          '--bw=[band width]:int:' \
          '--d-min=[min fragment size]:int:' \
          '(-m --mfold)'{-m+,--mfold=}'[mfold range]:range:' \
          '--outdir=[output directory]:dir:_files -/' \
          '--rfile=[output R script]:file:_files' \
          '--buffer-size=[buffer size]:int:' \
          '--verbose=[verbose level]:int:' && ret=0
        ;;
      pileup)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-i --ifile)'{-i+,--ifile=}'[input file]:file:_files' \
          '(-f --format)'{-f+,--format=}'[input format]:format:(AUTO BAM SAM BED BAMPE BEDPE)' \
          '(-B --both-direction)'{-B,--both-direction}'[pileup in both directions]' \
          '--extsize=[extension size]:int:' \
          '--buffer-size=[buffer size]:int:' \
          '--outdir=[output directory]:dir:_files -/' \
          '(-o --ofile)'{-o+,--ofile=}'[output file]:file:_files' \
          '--verbose=[verbose level]:int:' && ret=0
        ;;
      randsample)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-t --tfile)'{-t+,--tfile=}'[input alignment]:file:_files' \
          '(-p --percentage)'{-p+,--percentage=}'[sampling percent]:float:' \
          '(-n --number)'{-n+,--number=}'[sampling read count]:int:' \
          '--seed=[random seed]:int:' \
          '(-f --format)'{-f+,--format=}'[input format]:format:(AUTO BAM SAM BED BAMPE BEDPE)' \
          '(-s --tsize)'{-s+,--tsize=}'[tag size]:int:' \
          '--outdir=[output directory]:dir:_files -/' \
          '(-o --ofile)'{-o+,--ofile=}'[output file]:file:_files' \
          '--buffer-size=[buffer size]:int:' \
          '--verbose=[verbose level]:int:' && ret=0
        ;;
      refinepeak)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-b --bedfile)'{-b+,--bedfile=}'[peak BED file]:file:_files' \
          '(-i --ifile)'{-i+,--ifile=}'[raw read alignment]:file:_files' \
          '(-f --format)'{-f+,--format=}'[input format]:format:(AUTO BAM SAM BED)' \
          '(-c --cutoff)'{-c+,--cutoff=}'[cutoff]:float:' \
          '(-w --window-size)'{-w+,--window-size=}'[scan window size]:int:' \
          '--outdir=[output directory]:dir:_files -/' \
          '(-o --ofile)'{-o+,--ofile=}'[output file]:file:_files' \
          '--buffer-size=[buffer size]:int:' \
          '--verbose=[verbose level]:int:' && ret=0
        ;;
      *)
        _arguments '*:path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
