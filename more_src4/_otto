#compdef otto
# _otto — otto JavaScript interpreter in Go (Robert Krimen); ES5 interpreter for embedding in Go apps
# upstream: https://github.com/robertkrimen/otto

_otto() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '*:script:_files -g "*.js"'
}

_otto "$@"
