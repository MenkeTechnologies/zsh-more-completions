#compdef pyinfra
# Documentation: https://docs.pyinfra.com/
# Reference accessed: 2026-05-20
# Verified: pyinfra src/pyinfra_cli/cli.py (3.x branch).

# Zsh completion for pyinfra - infrastructure automation in Python

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '*-v[increase verbosity (-vv, -vvv for more)]' \
  '--support[show support information]' \
  '--dry[dry run; do not execute]' \
  '--debug[enable debug]' \
  '--debug-all[enable all debug outputs]' \
  '--debug-facts[print collected facts]' \
  '--debug-operations[print operations data]' \
  '--diff[show file diffs]' \
  '--json[emit machine-readable JSON]' \
  '--yes[apply changes non-interactively]' \
  '--serial[run operations serially]' \
  '--no-wait[do not wait between operations]' \
  '--parallel=[number of parallel operations]:n' \
  '--limit=[limit hosts by glob]:limit' \
  '--retry=[retry failed operations N times]:n' \
  '--retry-delay=[seconds between retries]:n' \
  '--fail-percent=[percent of hosts that can fail]:percent' \
  '--data=[extra data key=value]:data' \
  '--group-data=[extra group data path]:data' \
  '--config=[config file]:file:_files' \
  '--chdir=[change directory before running]:dir:_directories' \
  '--shell-executable=[shell to use]:shell' \
  '--sudo[execute with sudo]' \
  '--sudo-user=[sudo to user]:user:_users' \
  '--use-sudo-password[prompt for sudo password]' \
  '--use-sudo-login[use sudo login shell]' \
  '--same-sudo-password[reuse single sudo password]' \
  '--su-user=[su to user]:user:_users' \
  '--dzdo[execute with dzdo]' \
  '--dzdo-user=[dzdo to user]:user:_users' \
  '(--ssh-user --user)'{--ssh-user=,--user=}'[SSH user]:user:_users' \
  '(--ssh-port --port)'{--ssh-port=,--port=}'[SSH port]:port' \
  '(--ssh-key --key)'{--ssh-key=,--key=}'[SSH private key file]:file:_files' \
  '(--ssh-key-password --key-password)'{--ssh-key-password=,--key-password=}'[SSH key password]:password' \
  '(--ssh-password --password)'{--ssh-password=,--password=}'[SSH password]:password' \
  '--ssh-password-prompt[prompt for SSH password]' \
  '1:inventory:_files' \
  '2:operations or deploy file:_files' \
  '*::args:' && ret=0

return ret
