#compdef pnmalias
# Documentation: man pnmalias (Netpbm)
# Source: anti-alias a PNM image by smoothing pixels between background and foreground.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-bgcolor+[background color]:color:' \
    '-fgcolor+[foreground color]:color:' \
    '(-fonly)-bonly[smooth only background pixels]' \
    '(-bonly)-fonly[smooth only foreground pixels]' \
    '-balias[antialias background pixels]' \
    '-falias[antialias foreground pixels]' \
    '-weight+[smoothing weight]:w:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
