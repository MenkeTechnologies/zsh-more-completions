#compdef mdq
# Documentation: https://github.com/yshavit/mdq/blob/main/help.txt
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--link-pos=[link reference placement]:placement:(section doc)' \
  '--footnote-pos=[footnote reference placement]:placement:(section doc)' \
  '(-l --link-format)'{-l,--link-format}'=[link output style]:format:(keep inline never-inline)' \
  '--renumber-footnotes=[renumber numeric footnotes]:value:(true false)' \
  '(-o --output)'{-o,--output}'=[output format]:format:(markdown md json plain)' \
  '--wrap-width=[wrap text at width in markdown output]:width:' \
  '(-q --quiet)'{-q,--quiet}'[no stdout; exit status indicates matches]' \
  '--br[include breaks between elements]' \
  '--no-br[omit breaks between elements]' \
  '*:selector or markdown path:_files' && ret=0

return ret
