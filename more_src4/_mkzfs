#compdef mkzfs mkfs.zfs zfs-create
# _mkzfs — OpenZFS mkzfs CLI helper wrapping zpool-create and zfs-create for the OpenZFS file-system over one or more block devices supporting RAID-Z mirror striping pool properties dataset compression encryption (openzfs team, C); getopt
# upstream: https://github.com/openzfs/zfs

_mkzfs() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-q[quiet]' \
        '-f[force]' \
        '--force[force]' \
        '-n[dry run]' \
        '--dry-run[dry run]' \
        '-d[dont auto mount]' \
        '--no-mount[dont auto mount]' \
        '-o+[pool property]:str:' \
        '-O+[fs property]:str:' \
        '-m+[mountpoint]:dir:_files -/' \
        '--mountpoint=+[mountpoint]:dir:_files -/' \
        '-l+[layout]:l:(stripe mirror raidz raidz1 raidz2 raidz3 dRAID dRAID2 dRAID3)' \
        '--layout=+[layout]:l:(stripe mirror raidz raidz1 raidz2 raidz3 dRAID dRAID2 dRAID3)' \
        '-R+[root dir]:dir:_files -/' \
        '--altroot=+[root dir]:dir:_files -/' \
        '-r+[reservation]:str:' \
        '--reservation=+[size]:str:' \
        '-c+[compression]:c:(off on lzjb gzip gzip-1 gzip-2 gzip-3 gzip-4 gzip-5 gzip-6 gzip-7 gzip-8 gzip-9 zle lz4 zstd)' \
        '--compression=+[compression]:c:(off on lzjb gzip lz4 zstd zle)' \
        '-e[encryption]:e:(off aes-128-ccm aes-192-ccm aes-256-ccm aes-128-gcm aes-192-gcm aes-256-gcm)' \
        '--encryption=+[encryption]:e:(off aes-128-ccm aes-192-ccm aes-256-ccm aes-128-gcm aes-192-gcm aes-256-gcm)' \
        '-D+[dedup]:d:(on off)' \
        '--dedup=+[dedup]:d:(on off)' \
        '--ashift=+[bits]:n:(9 12 13)' \
        '*:pool name devices:_files'
}

_mkzfs "$@"
