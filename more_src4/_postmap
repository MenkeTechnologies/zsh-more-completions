#compdef postmap
# Documentation: https://www.postfix.org/postmap.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s \
  '-b[message body query mode with -q -]' \
  '-c[config directory]:dir:_files -/' \
  '-d[delete entry by key]:key:' \
  '-f[do not fold lookup key to lower case]' \
  '-h[message header query mode with -q -]' \
  '-i[incremental mode, do not truncate existing db]' \
  '-m[enable MIME parsing with -b and -h]' \
  '-N[include terminating null character]' \
  '-n[do not include terminating null character]' \
  '-o[do not release root privileges]' \
  '-p[do not inherit input file access permissions]' \
  '-q[query map for key]:key:' \
  '-r[update without complaining about existing entries]' \
  '-s[retrieve all elements and write key value pairs]' \
  '-u[disable UTF-8 support]' \
  '-U[force UTF-8 syntax checks with -b and -h]' \
  '-v[verbose logging]' \
  '-w[ignore attempts to update existing entries]' \
  '*:input:_files'
