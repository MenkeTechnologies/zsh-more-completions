#compdef mstregdump
# Documentation: https://www.mankier.com/1/mstregdump
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mstregdump: Mellanox mstdump utility, dumps device internal configuration data.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '-full[dump expanded address list (use with care)]' \
  '*:device:' && ret=0
return ret
