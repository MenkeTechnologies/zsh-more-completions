# Reference accessed: 2026-05-30 via gh api.
#
# matugen is the **Material You color palette generator**
# — generates Material Design 3 color schemes from images
# (wallpapers, screenshots) or explicit colors, then
# applies the palette to dotfiles via templating.  Used
# by ricers / dotfile customizers to maintain consistent
# color schemes across the entire desktop.  Pivots from
# database tooling (R261 replibyte) into the **theming/
# dotfile-management cluster**.  Sister to pywal / wpgtk
# / oomox (not in corpus; matugen is the most active
# modern alternative).
#
# Critical extraction note: matugen uses **`r#type`** at
# arguments.rs:23 — the Rust **raw identifier syntax**
# for using a reserved keyword as a field name.  `type`
# is a Rust keyword; `r#type` lets the field be named
# `type` while clap derive emits `--type` as the CLI
# flag (auto-derived from the field name by stripping
# `r#`).  Documents the **raw identifier (`r#X`) pattern**
# in clap derive — when the desired field/flag name is a
# Rust keyword.  Corpus's **first documented `r#X` raw
# identifier** in a clap derive struct.  Distinct from
# R253 fuelup's `Default_` trailing-underscore (which is
# for enum VARIANT names — the strip-trailing rule) and
# R253 fuelup's `#[clap(name = "self", subcommand)]`
# (which is for ENUM variant name override).  The `r#X`
# pattern is for FIELD names in structs.
#
# Critical extraction note: matugen uses
# **`allow_negative_numbers = true`** at arguments.rs:35
# + 118 + 126 on `--contrast` (f64), `--lightness-dark`
# (f64), `--lightness-light` (f64) — these flags accept
# negative numeric values (e.g. `--contrast=-0.5`).
# Without this attribute, clap interprets the leading
# `-` as a missing flag.  Distinct from R258 bevy's
# `allow_hyphen_values = true` (which allows ALL hyphen-
# prefixed values, useful for forwarding dash-prefixed
# args to downstream tools).  `allow_negative_numbers`
# is SPECIFICALLY for numeric flags — allows `-N.NN` to
# parse as a negative number but still rejects `--FOO`.
# Documents the **`allow_negative_numbers` vs
# `allow_hyphen_values` distinction** — corpus's first
# documented `allow_negative_numbers`.
#
# Critical extraction note: matugen uses **built-in
# `clap::builder::RangedI64ValueParser::<i64>::new()
# .range(0..4)`** at arguments.rs:134 on
# `--source-color-index` — clap's built-in range-
# checking ValueParser via the builder API.  Documents
# the **built-in RangedI64ValueParser pattern** — clap
# v4 ships range parsers for i8/i16/i32/i64/u8/u16/u32/
# u64 + f32/f64.  Distinct from R248 cairo-coverage's
# custom `parse_trace_file` validators (custom fn-based)
# and R252 saya's `validate_non_empty` (simple String).
# Corpus's first documented built-in RangedXxxValueParser.
# When the value is a number with a range, prefer the
# built-in parser over a custom fn.
#
# Critical extraction note: matugen uses **CLOSURE
# value_parser** at arguments.rs:143 on `--opacity`:
# `|s: &str| validate_float_range(s, 0.0..=1.0)` —
# clap accepts an inline closure as the value_parser
# (since the closure satisfies `Fn(&str) -> Result<T, E>`).
# Documents the **inline-closure value_parser pattern**
# — distinct from R248 cairo-coverage's separate fn,
# R252 saya's separate fn, R253 fuelup's separate fn.
# Corpus's **first documented inline-closure
# value_parser**.  Useful for one-off range checks
# where the validator doesn't need a name.
#
# Critical extraction note: matugen has a **3-deep
# subcommand tree via inline-struct + nested-subcommand
# variants**:
#   1. `matugen <Source>` — image/web-image/color/json
#   2. `matugen color <ColorFormat>` — hex/rgb/hsl
#   3. (no further nesting; each ColorFormat variant
#      takes a single `string: String` positional)
# The `Source::Color(ColorFormat)` variant wraps another
# Subcommand enum via the tuple-struct variant pattern.
# Combined with `#[clap(subcommand)]` on the wrapping
# enum, clap nests the parser.  Documents the **enum-
# wrapping-enum subcommand nesting** — for hierarchical
# subcommand trees.  Distinct from R254 subxt's 3-deep
# `Option<Subcommand>` progressive disclosure (which
# uses Option<> instead of tuple-wrap).
#
# Critical extraction note: matugen uses **inline-struct
# variants for ALL Source variants**: `Image { path:
# String }`, `WebImage { url: String }`, `Json { path:
# String }`.  Plus `ColorFormat` variants `Hex { string:
# String }`, `Rgb { string: String }`, `Hsl { string:
# String }`.  Documents extensive use of **inline-struct
# variant** pattern (R258 bevy was first to document for
# Completions { shell }).  matugen uses it 6+ times,
# making it a common pattern when each variant has only
# a single positional.  Eliminates the need for separate
# `ImageArgs` / `WebImageArgs` / etc. structs.
#
# Critical extraction note: matugen has **3 cfg-gated
# fields/variants**:
#   - arguments.rs:72-75 — `#[cfg(feature = "dump-json")]`
#     on `--json` field (field-level)
#   - arguments.rs:108-111 — `#[cfg(feature = "filter-
#     docs")]` on `--filter-docs-html` field (field-level)
#   - color/color.rs:53-54 — `#[cfg(feature = "web-image")]`
#     on `WebImage { url }` variant (variant-level)
# Documents the **mixed field+variant cfg-gating** within
# a single CLI — different features control different
# layers of the CLI surface.

local curcontext="$curcontext" state line ret=1

# 4 top-level subcommands (Source enum) decoded source-
# direct from src/color/color.rs lines 46-60.
local -a subcommands=(
  'image:image to use for generating a color scheme'
  'web-image:image to fetch from web (FEATURE-GATED: web-image)'
  'color:source color to use for generating a color scheme (sub: hex / rgb / hsl)'
  'json:json file to use and import for templates'
)

local -a color_subs=(
  'hex:hex color string (e.g. #ff0000)'
  'rgb:rgb color string (e.g. rgb(255,0,0))'
  'hsl:hsl color string (e.g. hsl(0,100%,50%))'
)

local -a scheme_types=(
  scheme-tonal-spot scheme-content scheme-expressive scheme-fidelity
  scheme-fruit-salad scheme-monochrome scheme-neutral scheme-rainbow
  scheme-vibrant
)

local -a modes=(dark light amoled)

local -a filter_types=(nearest triangle catmull-rom gaussian lanczos3)

local -a json_formats=(hex rgb rgba hsl hsla strip)

local -a selection_prefs=(
  darkness lightness saturation less-saturation value
  closest-to-fallback
)

local -a base16_backends=(
  base16 base24
)

# 27 global flags decoded source-direct from Cli at
# arguments.rs lines 7-145.
local -a global_flags=(
  '(-h --help)'{-h,--help}'[show help]'
  '(-V --version)'{-V,--version}'[show version]'
  '(-t --type)'{-t+,--type=}'[color scheme type (default: scheme-tonal-spot; r#type raw ident)]:type:($scheme_types)'
  '(-c --config)'{-c+,--config=}'[custom config file]:file:_files -g "*.toml"'
  '(-p --prefix)'{-p+,--prefix=}'[prefix to prepend to paths]:path:_files -/'
  '--contrast=[contrast (-1 to 1; allow_negative_numbers)]:n:'
  '(-v --verbose)'{-v,--verbose}'[verbose output]'
  '(-q --quiet)'{-q,--quiet}'[show no output]'
  '(-d --debug)'{-d,--debug}'[show debug output]'
  '--include-image-in-json[add image field into json output]'
  '(-m --mode)'{-m+,--mode=}'[color scheme mode (default: dark)]:mode:($modes)'
  '--dry-run[do not generate templates, reload apps, set wallpaper, or run any commands]'
  '--show-colors[show colors]'
  '(-j --json)'{-j+,--json=}'[dump json of colors (FEATURE-GATED: dump-json)]:format:($json_formats)'
  '*--import-json=[import a json file as render data (repeatable)]:file:_files -g "*.json"'
  '*--import-json-string=[import a json string as render data (repeatable)]:string:'
  '(-r --resize-filter)'{-r+,--resize-filter=}'[custom resize filter for source-color extraction]:filter:($filter_types)'
  '--continue-on-error[continue on error]'
  '--fallback-color=[fallback source_color when no good color found in image]:color:'
  '--prefer=[selection preference for color picking]:pref:($selection_prefs)'
  '--old-json-output[make json output like before version 4.0.0]'
  '(-b --base16-backend)'{-b+,--base16-backend=}'[backend for base16 color scheme generation]:backend:($base16_backends)'
  '--filter-docs-html[output filter documentation in HTML (FEATURE-GATED: filter-docs)]'
  '--lightness-dark=[dark-scheme lightness (-∞ to 1; allow_negative_numbers)]:n:'
  '--lightness-light=[light-scheme lightness (-1 to +∞; allow_negative_numbers)]:n:'
  '--source-color-index=[auto-pick source color by index (0-3; RangedI64ValueParser)]:index:(0 1 2 3)'
  '--show-source-colors[print possible source colors instead of setting a theme]'
  '--opacity=[opacity for all template colors (0.0 to 1.0; closure value_parser)]:opacity:'
)

_arguments -C \
  $global_flags \
  '1:subcommand:->subcmd' \
  '*::args:->args' && ret=0

case $state in
  subcmd)
    _describe -t subcommands 'matugen subcommand' subcommands && ret=0
    ;;
  args)
    case $words[1] in
      image)
        _arguments $global_flags '1:image file:_files -g "*.(png|jpg|jpeg|webp|jxl)"' && ret=0
        ;;
      web-image)
        _arguments $global_flags '1:image URL:' && ret=0
        ;;
      color)
        if (( CURRENT == 2 )); then
          _describe -t color-subs 'color format' color_subs && ret=0
        else
          # All ColorFormat variants take a single
          # `string: String` positional.
          _arguments $global_flags '1:color string:' && ret=0
        fi
        ;;
      json)
        _arguments $global_flags '1:json file:_files -g "*.json"' && ret=0
        ;;
    esac
    ;;
esac

return ret
