#compdef pamtopnm
# Documentation: man pamtopnm (Netpbm)
# Source: Netpbm pamtopnm — convert PAM image to PBM / PGM / PPM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-assume[ignore tuple-type sanity check]' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:PAM file:_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    && ret=0

return ret
