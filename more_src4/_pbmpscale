#compdef pbmpscale
# Documentation: man pbmpscale (Netpbm)
# Source: enlarge a PBM image using pixel-scale algorithm (anti-aliased growth).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:scale factor N:' \
    '2:pbm file:_files -g "*.(pbm|pnm|pam)"' \
    && ret=0

return ret
