#compdef plow
# Documentation: https://github.com/six-ddc/plow
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for plow - high-performance HTTP benchmarking tool
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-c --concurrency)'{-c,--concurrency=}'[number of concurrent connections]:number:' \
  '(-d --duration)'{-d,--duration=}'[duration of the test]:duration:' \
  '(-n --requests)'{-n,--requests=}'[total number of requests]:number:' \
  '(-i --interval)'{-i,--interval=}'[print snapshot every interval]:duration:' \
  '(-b --body)'{-b,--body=}'[request body (or @file)]:body:' \
  '(-T --content)'{-T,--content=}'[Content-Type header]:type:' \
  '*'{-H,--header=}'[custom HTTP header]:header:' \
  '(-m --method)'{-m,--method=}'[HTTP method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
  '--timeout=[timeout for each HTTP request]:duration:' \
  '--dial-timeout=[timeout for dialing address]:duration:' \
  '--host=[host header]:host:' \
  '--cert=[client TLS certificate file]:file:_files' \
  '--key=[client TLS private key file]:file:_files' \
  '(-k --insecure)'{-k,--insecure}'[skip TLS verification]' \
  '--rate=[requests per time unit]:rate:' \
  '--ramp-up=[concurrency increase per second]:seconds:' \
  '--unix-socket=[path to UNIX domain socket]:socket:_files' \
  '--socks5=[SOCKS5 proxy ip:port]:proxy:' \
  '--http-proxy=[HTTP proxy URL]:proxy:' \
  '--listen=[listen address for Web UI]:address:' \
  '--seconds[use seconds as time unit]' \
  '--summary[print summary only]' \
  '--json[output results as JSON]' \
  '--auto-open-browser[auto-open browser for charts]' \
  '--output-errors=[output errors to a file]:file:_files' \
  '(- *)--version[show version]' \
  '(- *)--help[show help information]' \
  '1:url:' && ret=0
return ret
