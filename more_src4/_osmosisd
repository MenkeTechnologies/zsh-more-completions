#compdef osmosisd
# _osmosisd — Osmosis Labs osmosisd Cosmos-SDK node daemon for Osmosis AMM DEX blockchain (osmosis-labs team, Go); cobra
# upstream: https://github.com/osmosis-labs/osmosis

_osmosisd() {
    local -a sub=(
        'start:start the node'
        'status:show node status'
        'init:initialize node config'
        'add-genesis-account:add genesis account'
        'gentx:create gentx'
        'collect-gentxs:collect gentxs'
        'validate-genesis:validate genesis'
        'tendermint:tendermint subcommands'
        'comet:comet subcommands'
        'export:export state to JSON'
        'tx:transaction subcommands'
        'query:query subcommands'
        'q:query alias'
        'keys:keys subcommands'
        'config:config subcommands'
        'snapshots:snapshot subcommands'
        'genesis:genesis subcommands'
        'rosetta:rosetta API'
        'in-place-testnet:create in-place testnet'
        'prune:prune state'
        'debug:debug subcommands'
        'rollback:rollback state'
        'version:show version'
        'completion:generate completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--chain-id=+[chain id]:str:' \
        '--home=+[node home]:dir:_files -/' \
        '--keyring-backend=+[backend]:b:(os file kwallet pass test memory)' \
        '--keyring-dir=+[keyring dir]:dir:_files -/' \
        '--log-level=+[level]:l:(trace debug info warn error fatal panic)' \
        '--log-format=+[format]:f:(plain json)' \
        '--log-no-color[no color logs]' \
        '--trace[trace stack]' \
        '--node=+[tendermint rpc]:url:_urls' \
        '--output=+[format]:f:(text json)' \
        '-o+[format]:f:(text json)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'osmosisd subcommand' sub ;;
        args)
            case $words[1] in
                tx) _arguments '1:tx module:(bank staking gamm lockup superfluid concentratedliquidity poolmanager incentives mint distribution gov ibc-transfer authz feegrant slashing crisis vesting)' ;;
                query|q) _arguments '1:query module:(bank staking gamm lockup superfluid concentratedliquidity poolmanager incentives mint distribution gov ibc params tendermint block tx auth slashing)' ;;
                keys) _arguments '1:keys cmd:(add delete export import list mnemonic parse rename show migrate)' ;;
                tendermint|comet) _arguments '1:cmt cmd:(reset-state show-node-id show-validator show-address version unsafe-reset-all)' ;;
                snapshots) _arguments '1:snap cmd:(list load restore export delete dump)' ;;
                genesis) _arguments '1:genesis cmd:(migrate validate collect-gentxs gentx add-genesis-account init)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_osmosisd "$@"
