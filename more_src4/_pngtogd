#compdef pngtogd
# Documentation: https://manpages.debian.org/testing/libgd-tools/pngtogd.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input PNG file:_files -g "*.png"' \
  '2:output GD file:_files -g "*.gd"' && ret=0

return ret
