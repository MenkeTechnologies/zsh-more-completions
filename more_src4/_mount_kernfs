#compdef mount_kernfs
# Documentation: man mount_kernfs(8)
# Source: netbsd/src sbin/mount_kernfs — mount the /kern kernel namespace (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-o+[mount options (comma-separated, see mount(8))]:options:_default' \
    '1:source (/kern):_files -/' \
    '2:mount point:_files -/' \
    && ret=0

return ret
