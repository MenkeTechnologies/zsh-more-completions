#compdef mega-cmd
# _mega-cmd — interactive MEGA cloud storage CLI (meganz/MEGAcmd)
# upstream: https://github.com/meganz/MEGAcmd
# Subcommands from src/megacmd.cpp.

_mega-cmd() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'attr:show file/folder attributes'
                'backup:configure / manage backups'
                'cancel:cancel transfers'
                'cd:change cloud directory'
                'clear:clear screen'
                'completion:print shell completion'
                'confirm:confirm a code'
                'confirmcancel:confirm account cancellation'
                'cp:copy a node'
                'debug:set debug log level'
                'deleteversions:delete file versions'
                'df:show disk usage'
                'du:show file/folder size'
                'errorcode:print info about MEGA error code'
                'exclude:manage sync exclusions'
                'exit:exit the shell'
                'export:export public links'
                'find:search the cloud tree'
                'ftp:start an FTP server for the cloud'
                'get:download files from MEGA'
                'graphics:enable / disable graphical thumbnails'
                'help:show help'
                'history:show command history'
                'https:enable / disable HTTPS for transfers'
                'import:import a public link to cloud'
                'invite:invite a contact'
                'ipc:manage incoming contact requests'
                'killsession:kill an active session'
                'lcd:change local working directory'
                'log:adjust log levels'
                'login:log in to MEGA'
                'logout:log out'
                'lpwd:print local working directory'
                'ls:list cloud directory contents'
                'masterkey:show master key'
                'mediainfo:show media file info'
                'mkdir:create cloud directory'
                'mount:show mounts (sync, backup, webdav, ftp)'
                'mv:move or rename a node'
                'passwd:change password'
                'permissions:show or set permissions'
                'preview:retrieve / set previews'
                'proxy:configure HTTP proxy'
                'put:upload files to MEGA'
                'pwd:print cloud working directory'
                'quit:quit the shell'
                'reload:reload the cloud tree'
                'rm:remove cloud nodes'
                'session:print current session ID'
                'share:manage outgoing folder shares'
                'showpcr:show incoming contact requests'
                'signup:create a new MEGA account'
                'speedlimit:set transfer speed limit'
                'sync:configure sync pairs'
                'sync-ignore:edit sync ignore filters'
                'sync-issues:show issues with active syncs'
                'thumbnail:retrieve / set thumbnails'
                'transfers:list / manage transfers'
                'unicode:toggle unicode output'
                'update:update MEGAcmd'
                'userattr:show user attributes'
                'users:show users known to the account'
                'version:show MEGAcmd version'
                'webdav:start a WebDAV server for the cloud'
                'whoami:show currently logged-in account'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_mega-cmd "$@"
