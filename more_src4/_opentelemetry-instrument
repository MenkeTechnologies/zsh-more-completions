#compdef opentelemetry-instrument
# Documentation: https://github.com/open-telemetry/opentelemetry-python
# Reference accessed: 2026-05-23
# Verified: opentelemetry-instrument --help (OpenTelemetry auto-instrumentation).

# Zsh completion for opentelemetry-instrument - wrap commands with OTel tracing

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--logs_exporter[logs exporter]:exporter:' \
  '--metrics_exporter[metrics exporter]:exporter:' \
  '--traces_exporter[traces exporter]:exporter:' \
  '--propagators[propagators]:propagators:' \
  '--context[context implementation]:context:' \
  '--id_generator[ID generator]:generator:' \
  '--meter_provider[meter provider]:provider:' \
  '--tracer_provider[tracer provider]:provider:' \
  '--configurator[configurator]:configurator:' \
  '--distro[distro]:distro:' \
  '--disabled_instrumentations[disabled instrumentations]:list:' \
  '*:command and args:' && ret=0

return ret
