#compdef pcxtoppm
# Documentation: man pcxtoppm (Netpbm)
# Source: convert a ZSoft PCX image to PPM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-stdpalette[use the standard 16-color palette]' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pcx file:_files -g "*.pcx"' \
    && ret=0

return ret
