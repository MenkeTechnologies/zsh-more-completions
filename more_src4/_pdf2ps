#compdef pdf2ps
# _pdf2ps — Ghostscript pdf2ps (PDF -> PostScript via the gs ps2write device; -dLanguageLevel selects PS level 1/2/3, -dCompatibilityLevel pdf level, -sPAPERSIZE sets paper)
# upstream: https://github.com/ArtifexSoftware/ghostpdl
# Forwarded gs flags from ghostpdl pdf2ps.in on tip.

_pdf2ps() {
    _arguments \
        '-dLanguageLevel=*[PostScript language level]:level:(1 1.5 2 3)' \
        '-dCompatibilityLevel=*[PDF level]:level:(1.3 1.4 1.5 1.6 1.7)' \
        '-sPAPERSIZE=*[paper size]:size:(a4 letter legal a3 a5 ledger)' \
        '-dNOPAUSE[non-interactive]' \
        '-dQUIET[quiet]' \
        '-dBATCH[batch (exit after)]' \
        '1:input pdf:_files -g "*.pdf"' \
        '2:output ps:_files -g "*.ps"'
}

_pdf2ps "$@"
