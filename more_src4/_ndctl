#compdef ndctl
# Documentation: man ndctl(1)
# Source: pmem/ndctl ndctl/ndctl.c (main) — NVDIMM management utility (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a cmds=(
    'version:show ndctl version'
    'create-nfit:create an NFIT-like file'
    'enable-namespace:enable a namespace'
    'disable-namespace:disable a namespace'
    'create-namespace:create a namespace'
    'destroy-namespace:destroy a namespace'
    'read-infoblock:read namespace info block'
    'write-infoblock:write namespace info block'
    'check-namespace:check a namespace'
    'clear-errors:clear poison list'
    'enable-region:enable a region'
    'disable-region:disable a region'
    'enable-dimm:enable a DIMM'
    'disable-dimm:disable a DIMM'
    'zero-labels:zero DIMM label area'
    'read-labels:read DIMM labels'
    'write-labels:write DIMM labels'
    'init-labels:initialize DIMM labels'
    'check-labels:check DIMM labels'
    'inject-error:inject media errors'
    'update-firmware:update DIMM firmware'
    'inject-smart:inject SMART data'
    'wait-scrub:wait for ARS scrub to complete'
    'activate-firmware:activate staged firmware'
    'start-scrub:start ARS scrub'
    'setup-passphrase:set DIMM security passphrase'
    'update-passphrase:update DIMM security passphrase'
    'remove-passphrase:remove DIMM security passphrase'
    'freeze-security:freeze DIMM security state'
    'sanitize-dimm:sanitize DIMM (overwrite/erase)'
    'load-keys:load passphrase keys'
    'wait-overwrite:wait for overwrite to complete'
    'list:list devices'
    'monitor:monitor SMART events'
    'help:show command help'
)

_arguments -s -C \
    '(-v --version)'{-v,--version}'[show version]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '1:command:->cmd' \
    '*::cmd args:_default' \
    && ret=0

case $state in
    cmd) _describe -t commands 'ndctl command' cmds && ret=0 ;;
esac

return ret
