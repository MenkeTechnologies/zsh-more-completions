#compdef piper-tts piper-tts-cli
# _piper-tts — rhasspy Piper fast offline neural TTS CLI alias (rhasspy / Mike Hansen, C++/Python); custom argparse
# upstream: https://github.com/rhasspy/piper

_piper-tts() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--model=+[model file]:file:_files -g "*.onnx"' \
        '-m+[model file]:file:_files -g "*.onnx"' \
        '--config=+[model config json]:file:_files -g "*.json"' \
        '-c+[model config json]:file:_files -g "*.json"' \
        '--output_file=+[output wav]:file:_files' \
        '-f+[output wav]:file:_files' \
        '--output_dir=+[output dir]:dir:_files -/' \
        '-d+[output dir]:dir:_files -/' \
        '--output_raw[output raw PCM to stdout]' \
        '--output-raw[output raw PCM to stdout]' \
        '-r[output raw PCM to stdout]' \
        '--speaker=+[speaker id]:n:' \
        '-s+[speaker id]:n:' \
        '--length_scale=+[length scale]:f:' \
        '--length-scale=+[length scale]:f:' \
        '-l+[length scale]:f:' \
        '--noise_scale=+[noise scale]:f:' \
        '--noise-scale=+[noise scale]:f:' \
        '-n+[noise scale]:f:' \
        '--noise_w=+[noise w]:f:' \
        '--noise-w=+[noise w]:f:' \
        '-w+[noise w]:f:' \
        '--sentence_silence=+[sentence silence sec]:f:' \
        '--silent_phonemes[silent phonemes]' \
        '--phoneme_silence=+[phoneme silence]:str:' \
        '--cuda[CUDA acceleration]' \
        '--update-voices[update voices]' \
        '--data-dir=+[data dir]:dir:_files -/' \
        '--download-dir=+[download dir]:dir:_files -/' \
        '--debug[debug]' \
        '*:text-or-file:_files'
}

_piper-tts "$@"
