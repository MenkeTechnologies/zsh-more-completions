#compdef mlxctl
# Documentation: man mlxctl(8)
# Source: netbsd/src usr.sbin/mlxctl — Mylex DAC960 management utility (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[apply action to all attached drives]' \
    '-f+[control device (default /dev/mlx0)]:device:_files' \
    '-v[increased verbosity]' \
    '1:command:(cstatus status rescan detach check rebuild config)' \
    '*::drive (ldN) or channel\:target:_default' \
    && ret=0

return ret
