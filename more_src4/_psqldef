#compdef psqldef
# Documentation: https://github.com/sqldef/sqldef
# Source: sqldef/sqldef cmd/psqldef/psqldef.go — declarative PostgreSQL schema migration tool.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-U --user)'{-U+,--user=}'[PostgreSQL user name]:user:_default' \
    '(-W --password)'{-W+,--password=}'[PostgreSQL user password (overridden by PGPASSWORD)]:password:_default' \
    '(-h --host)'{-h+,--host=}'[host or socket directory of the PostgreSQL server]:host:_hosts' \
    '(-p --port)'{-p+,--port=}'[port for the connection]:port:_default' \
    '--password-prompt[force password prompt]' \
    '(-f --file)*'{-f+,--file=}'[read desired SQL from a file instead of stdin]:file:_files -g "*.sql"' \
    '--dry-run[do not run DDLs, just show them]' \
    '--check[exit code 2 when DDL would be applied (CI gate for drift)]' \
    '--apply[apply DDLs to the database]' \
    '--export[dump the current schema to stdout]' \
    '--enable-drop[enable destructive changes such as DROP]' \
    '--skip-view[skip managing views and materialized views]' \
    '--skip-extension[skip managing extensions]' \
    '--skip-partition[skip managing partitioned tables]' \
    '--disable-ddl-transaction[execute DDL statements outside a transaction block]' \
    '--before-apply=[execute the given SQL before applying regular DDLs]:sql:_default' \
    '*--config=[YAML configuration file]:file:_files -g "*.(yml|yaml)"' \
    '*--config-inline=[YAML configuration as inline string]:yaml:_default' \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '1:dbname-or-sqlfile:_default' \
    && ret=0

return ret
