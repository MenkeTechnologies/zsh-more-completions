#compdef mrtrix_cleanup
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/mrtrix_cleanup.html
# Source: MRtrix3/mrtrix3 bin/mrtrix_cleanup — clean up residual MRtrix3 temp files (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(-failed)-test[list found items without deleting]' \
    '(-test)-failed+[write list of items script failed to delete]:file:_files' \
    '-nthreads+[number of threads]:n:_default' \
    '1:path (filesystem search root):_files -/' \
    && ret=0

return ret
