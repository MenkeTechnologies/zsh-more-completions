#compdef pmgcm pmg-cluster
# _pmg-cluster — Proxmox Server Solutions pmgcm Proxmox Mail Gateway cluster management CLI (proxmox team, Perl); custom argparse
# upstream: https://git.proxmox.com/?p=pmg-api.git

_pmg-cluster() {
    local -a sub=(
        'create:create a cluster'
        'join:join a cluster'
        'delete:delete a cluster node'
        'status:show cluster status'
        'sync:run sync from master'
        'promote:promote node to master'
        'list:list cluster nodes'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '--output-format=+[format]:f:(text json json-pretty)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pmgcm subcommand' sub ;;
        args)
            case $words[1] in
                join) _arguments \
                    '--master_ip=+[master ip]:host:_hosts' \
                    '--fingerprint=+[fingerprint]:str:' ;;
                delete|promote) _arguments '1:cid:' ;;
                sync) _arguments '--master_ip=+[master ip]:host:_hosts' ;;
                status) _arguments \
                    '--list_single_node[list single node]' \
                    '--verbose[verbose status]' ;;
            esac
            ;;
    esac
}

_pmg-cluster "$@"
