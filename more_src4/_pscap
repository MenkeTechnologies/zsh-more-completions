#compdef pscap
# Documentation: man pscap(8)
# Source: stevegrubb/libcap-ng utils/pscap.c (master) — show capabilities of running processes (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[show all processes (including those without caps)]' \
    '-p+[only show this PID]:pid:_pids' \
    '--tree[show in tree format]' \
    && ret=0

return ret
