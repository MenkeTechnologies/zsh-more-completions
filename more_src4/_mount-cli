#compdef mount-cli
# _mount-cli — util-linux mount filesystem mount CLI alias (util-linux team, C); custom argparse
# upstream: https://github.com/util-linux/util-linux

_mount-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[mount all]' \
        '--all[mount all]' \
        '-F[fork for each fs]' \
        '--fork[fork for each fs]' \
        '-f[fake mount]' \
        '--fake[fake mount]' \
        '-i[do not call helpers]' \
        '--internal-only[do not call helpers]' \
        '-l[show labels]' \
        '--show-labels[show labels]' \
        '-c[canonicalize paths]' \
        '--no-canonicalize[no canonicalize]' \
        '-n[do not update /etc/mtab]' \
        '--no-mtab[do not update /etc/mtab]' \
        '--options-mode=+[mode]:m:(ignore append prepend replace)' \
        '--options-source=+[src]:s:(fstab mtab disable)' \
        '--options-source-force[force options source]' \
        '-o+[options]:str:' \
        '--options=+[options]:str:' \
        '-O+[options match]:str:' \
        '--test-opts=+[options match]:str:' \
        '-r[read only]' \
        '--read-only[read only]' \
        '-w[read-write]' \
        '--rw[read-write]' \
        '-R[remount mount points recursively]' \
        '--rbind[recursive bind]' \
        '-B[bind mount]' \
        '--bind[bind mount]' \
        '-M[move mount]' \
        '--move[move mount]' \
        '--make-shared[make shared mount]' \
        '--make-slave[make slave mount]' \
        '--make-private[make private mount]' \
        '--make-unbindable[make unbindable mount]' \
        '--make-rshared[make recursively shared]' \
        '--make-rslave[make recursively slave]' \
        '--make-rprivate[make recursively private]' \
        '--make-runbindable[make recursively unbindable]' \
        '-N+[namespace]:n:' \
        '--namespace=+[namespace]:n:' \
        '-T+[fstab path]:file:_files' \
        '--fstab=+[fstab path]:file:_files' \
        '-t+[fstype]:str:' \
        '--types=+[fstype]:str:' \
        '--source=+[device]:_files' \
        '--target=+[mount point]:_files -/' \
        '--target-prefix=+[prefix]:str:' \
        '-U+[uuid]:str:' \
        '--uuid=+[uuid]:str:' \
        '-L+[label]:str:' \
        '--label=+[label]:str:' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '*:device or mountpoint:_files'
}

_mount-cli "$@"
