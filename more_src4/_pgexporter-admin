#compdef pgexporter-admin
# _pgexporter-admin — manage pgexporter admin/user files (pgexporter/pgexporter)
# upstream: https://github.com/pgexporter/pgexporter
# Flags from src/admin.c (getopt_long).

_pgexporter-admin() {
    _arguments \
        '(- *)'{-?,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-U --user)'{-U+,--user=}'[username]:user:' \
        '(-P --password)'{-P+,--password=}'[password]:pass:' \
        '(-f --file)'{-f+,--file=}'[admin/users file]:file:_files' \
        '(-g --generate)'{-g,--generate}'[generate password]' \
        '(-l --length)'{-l+,--length=}'[generated password length]:n:' \
        '(-F --format)'{-F+,--format=}'[file format]:fmt:(plaintext md5 scram-sha-256)' \
        '1:command:(master-key add-user remove-user update-user list-users)'
}

_pgexporter-admin "$@"
