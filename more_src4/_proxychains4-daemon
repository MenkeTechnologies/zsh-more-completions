#compdef proxychains4-daemon
# Documentation: https://github.com/rofl0r/proxychains-ng
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# proxychains4-daemon: remote DNS daemon for proxychains-ng

local -a arguments

arguments=(
    '-i[listen IP (default 127.0.0.1)]:ip:'
    '-p[listen port (default 1053)]:port:'
    '-r[remote subnet (default 224)]:subnet:'
)

_arguments -s -S $arguments
