_nsecbunkerd() {
    case "${service:-${words[1]}}" in
        nsecbunker-client)
            _arguments -C \
                '(- *)--help[show help]' \
                '--dont-publish[print signature only; do not publish to relays]' \
                '--debug[verbose debug output]' \
                '--relays=[comma-separated extra relays]:relays:' \
                '--pk=[override persisted local private key]:key:' \
                '1: :_nsecbunker_client_commands' \
                '2::remote bunker npub or nip05 (user@domain):' \
                '3::sign: event JSON or kind:1 content / create_account: nip05[,domain[,email]]:' \
                '*: :' && return 0
            ;;
        nsecbunkerd|*)
            _arguments -C \
                '(- *)--help[show help]' \
                '(- *)--version[show version]' \
                '(-c --config)'{-c,--config}'=[path to config file (default config/nsecbunker.json)]:config:_files -g "*.json"' \
                '1: :_nsecbunkerd_commands' \
                '*::arg:->args' && return 0

            case $state in
                args)
                    case $words[1] in
                        setup)
                            _arguments \
                                '(-c --config)'{-c,--config}'=[path to config file]:config:_files -g "*.json"' && return 0 ;;
                        start)
                            _arguments \
                                '(-v --verbose)'{-v,--verbose}'[run with verbose logging]' \
                                '*--key=[name of key to enable (repeatable)]:key-name:' \
                                '*'{-a,--admin}'=[admin npub (repeatable)]:npub:' \
                                '(-c --config)'{-c,--config}'=[path to config file]:config:_files -g "*.json"' && return 0 ;;
                        add)
                            _arguments \
                                '(-n --name)'{-n,--name}'=[name of the nsec (REQUIRED)]:nsec-name:' \
                                '(-c --config)'{-c,--config}'=[path to config file]:config:_files -g "*.json"' && return 0 ;;
                    esac
                    ;;
            esac
            ;;
    esac
}

(( $+functions[_nsecbunkerd_commands] )) ||
_nsecbunkerd_commands() {
    local -a commands
    commands=(
        'setup:setup nsecBunker (interactive wizard)'
        'start:start the nsecBunker daemon'
        'add:add an nsec to the bunker'
    )
    _describe -t commands 'nsecbunkerd command' commands
}

(( $+functions[_nsecbunker_client_commands] )) ||
_nsecbunker_client_commands() {
    local -a commands
    commands=(
        'ping:liveness check against the remote bunker'
        'sign:ask the bunker to sign an event or kind:1 note'
        'create_account:ask the bunker to create a new account (NIP-05)'
    )
    _describe -t commands 'nsecbunker-client command' commands
}

_nsecbunkerd "$@"
