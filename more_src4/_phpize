#compdef phpize
# _phpize — PHP phpize (prepare a PECL/external PHP extension's build environment: regenerates configure/Makefile.in from config.m4 by copying the active PHP installation's m4 macros into the extension dir)
# upstream: https://github.com/php/php-src (scripts/phpize.in)
# Flags from php-src scripts/phpize.in on tip.

_phpize() {
    _arguments \
        '--clean[remove generated build files]' \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]'
}

_phpize "$@"
