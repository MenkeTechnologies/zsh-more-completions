#compdef papyri papyri-cli
# _papyri — Matthias Bussonnier papyri Python scientific documentation CLI rendering numpydoc docstrings with cross-references type-hints code examples and intersphinx (jupyter team, Python); typer
# upstream: https://github.com/jupyter/papyri

_papyri() {
    local -a sub=(
        'ingest:ingest package into local DB'
        'render:render package to HTML'
        'gen:generate IR for package'
        'install:install rendered docs'
        'open:open rendered docs in browser'
        'relink:relink cross-references'
        'serve:serve documentation'
        'browse:browse docs'
        'bootstrap:bootstrap config'
        'build-parsed:build parsed cache'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--debug[debug]' \
        '--config=+[file]:file:_files -g "*.toml *.json"' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'papyri subcommand' sub ;;
        args)
            case $words[1] in
                gen|ingest) _arguments \
                    '--examples[examples]' \
                    '--no-examples[no examples]' \
                    '--no-narrative[no narrative]' \
                    '--check[check]' \
                    '--target=+[dir]:dir:_files -/' \
                    '*:package or config file:_files -g "*.toml *.py"' ;;
                render) _arguments \
                    '--output=+[dir]:dir:_files -/' \
                    '--theme=+[t]:t:(papyri dark light pydata-sphinx furo readthedocs scipy numpy)' \
                    '--gen-static-files[gen static files]' \
                    '*:package:' ;;
                serve) _arguments \
                    '--port=+[port]:n:' \
                    '--host=+[host]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_papyri "$@"
