#compdef ppmpat
# Documentation: man ppmpat (Netpbm)
# Source: generate a textile-like patterned PPM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-gingham2 -g2 -gingham3 -g3 -madras -tartan -poles -squig -camo -anticamo -argyle1 -argyle2)'{-gingham2,-g2}'[2-color gingham]' \
    '(-gingham2 -g2 -gingham3 -g3 -madras -tartan -poles -squig -camo -anticamo -argyle1 -argyle2)'{-gingham3,-g3}'[3-color gingham]' \
    '(-gingham2 -g2 -gingham3 -g3 -madras -tartan -poles -squig -camo -anticamo -argyle1 -argyle2)-madras[madras pattern]' \
    '(-gingham2 -g2 -gingham3 -g3 -madras -tartan -poles -squig -camo -anticamo -argyle1 -argyle2)-tartan[tartan pattern]' \
    '(-gingham2 -g2 -gingham3 -g3 -madras -tartan -poles -squig -camo -anticamo -argyle1 -argyle2)-poles[radial pole pattern]' \
    '(-gingham2 -g2 -gingham3 -g3 -madras -tartan -poles -squig -camo -anticamo -argyle1 -argyle2)-squig[squig pattern]' \
    '(-gingham2 -g2 -gingham3 -g3 -madras -tartan -poles -squig -camo -anticamo -argyle1 -argyle2)-camo[camo pattern]' \
    '(-gingham2 -g2 -gingham3 -g3 -madras -tartan -poles -squig -camo -anticamo -argyle1 -argyle2)-anticamo[anti-camo pattern]' \
    '(-gingham2 -g2 -gingham3 -g3 -madras -tartan -poles -squig -camo -anticamo -argyle1 -argyle2)-argyle1[argyle pattern variant 1]' \
    '(-gingham2 -g2 -gingham3 -g3 -madras -tartan -poles -squig -camo -anticamo -argyle1 -argyle2)-argyle2[argyle pattern variant 2]' \
    '-color+[colorlist for pattern]:colors:' \
    '-mesh[draw mesh overlay]' \
    '-randomseed+[random seed]:integer:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:width:' \
    '2:height:' \
    && ret=0

return ret
