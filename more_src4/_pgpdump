#compdef pgpdump
# _pgpdump — display PGP packet information (kazu-yamamoto/pgpdump)
# upstream: https://github.com/kazu-yamamoto/pgpdump

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-a[read ASCII armor input]' \
  '-d[debug mode]' \
  '-g[dump as GnuPG compatible output]' \
  '-i[dump as integers]' \
  '-l[dump literal packets]' \
  '-m[dump marker packets]' \
  '-p[dump public key packets]' \
  '-u[use UTC for timestamps]' \
  '*:file:_files'
