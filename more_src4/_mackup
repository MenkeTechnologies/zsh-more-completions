#compdef mackup
# Documentation: https://github.com/lra/mackup
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mackup - keep your application settings in sync

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-f --force)'{-f,--force}'[answer yes to every question]' \
  '--force-no[answer no to every question]' \
  '(-r --root)'{-r,--root}'[allow mackup to be run as superuser]' \
  '(-n --dry-run)'{-n,--dry-run}'[show steps without executing]' \
  '(-v --verbose)'{-v,--verbose}'[show additional details]' \
  '(-c --config-file)'{-c,--config-file=}'[specify custom config file path]:file:_files' \
  '1:command:->command' \
  '2:subcommand:->subcommand' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'list:display a list of all supported applications'
      'show:display the details for a supported application'
      'backup:copy local config files in the configured remote folder'
      'restore:copy config files from the configured remote folder locally'
      'link:move/link local config files (subcommands: install, uninstall)'
    )
    _describe -t commands 'mackup commands' commands && ret=0
    ;;
  subcommand)
    case "$line[1]" in
      link)
        local -a sub
        sub=(
          'install:move local config files to remote folder, then link'
          'uninstall:remove links and copy config files back locally'
        )
        _describe -t link-sub 'link subcommands' sub && ret=0
        ;;
    esac
    ;;
esac

return ret
