#compdef mlserver
# _mlserver — Seldon MLServer machine learning model serving
# upstream: https://github.com/SeldonIO/MLServer

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:Start the MLServer'
  'build:Build a Docker image for serving'
  'infer:Send an inference request'
  'help:Show help for a command'
)

_arguments -s -S -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'mlserver command' commands && ret=0
    ;;
  args)
    case $words[1] in
      start)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '1:settings-folder:_directories' && ret=0
        ;;
      build)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '--tag=[Docker image tag]:tag' \
          '--no-cache[build without Docker cache]' \
          '1:settings-folder:_directories' && ret=0
        ;;
      infer)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '--model-name=[model name]:name' \
          '--model-version=[model version]:version' \
          '--url=[MLServer URL]:url' \
          '--input-data-path=[path to input data JSON]:file:_files' \
          '--output-data-path=[path to save output]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
