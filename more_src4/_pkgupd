#compdef pkgupd
# _pkgupd — Rlxos pkgupd CLI command-line package manager for Rlxos GNU Linux source-recipes distribution providing install remove update upgrade search info trigger build deptest recipe-add-mirror sysroot reset-jails-images-system-roots-pkg-rollback for the rlx-pkg-recipe-source-build-Linux-Repositories-pkg-management (Rlxos team, C++); getopt
# upstream: https://rlxos.cloud/

_pkgupd() {
    local -a sub=(
        'install:install a package'
        'remove:remove a package'
        'update:update the cache'
        'upgrade:upgrade installed packages'
        'search:search for packages'
        'info:show package info'
        'list:list installed packages'
        'trigger:run install triggers'
        'depends:show dependencies'
        'build:build a recipe'
        'recipe:recipe operations'
        'mirror:mirror management'
        'sysroot:sysroot management'
        'rollback:rollback to previous root'
        'reset:reset system'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-y[assume yes]' \
        '-n[dry run]' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml *.ini"' \
        '--root=+[dir]:dir:_files -/' \
        '--cache=+[dir]:dir:_files -/' \
        '--repos=+[list]:str:' \
        '--mirror=+[url]:str:' \
        '--installer=+[type]:t:(deb rpm tar binary)' \
        '--force[force]' \
        '--no-triggers[no triggers]' \
        '--no-deps[no deps]' \
        '--with-deps[with deps]' \
        '--keep-cache[keep cache]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pkgupd subcommand' sub ;;
        args)
            _arguments '*:package:'
            ;;
    esac
}

_pkgupd "$@"
