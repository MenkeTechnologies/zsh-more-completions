#compdef pterm
# Documentation: https://github.com/openpmix/prrte/blob/master/src/tools/pterm/pterm.c
# Reference accessed: 2026-05-20
# Verified: upstream PRRTE pterm.c source (see schizo CLI options).

# pterm: terminate a running PRRTE DVM
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--personality=[set tool personality]:personality:' \
  '--system-server-first[contact system server first]' \
  '--system-server-only[only contact system server]' \
  '--wait-to-connect=[seconds to wait between connect retries]:seconds:' \
  '--num-connect-retries=[max connect retry attempts]:n:' \
  '--pid=[PRRTE server PID or file:<path>]:pid:' \
  '--dvm-uri=[DVM server URI]:uri:' \
  '*::pterm args:_files' && ret=0
return ret
