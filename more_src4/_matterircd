#compdef matterircd
# _matterircd — Mattermost/Slack/Discord IRC bridge daemon (42wim/matterircd)
# upstream: https://github.com/42wim/matterircd
# Flags from main.go (flag).

_matterircd() {
    _arguments \
        '(- *)-h[show help]' \
        '(- *)-version[show version]' \
        '-conf=[config file]:file:_files -g "*.toml"' \
        '-debug[enable debug logging]' \
        '-bind=[IRC bind addr (ip:port or unix socket)]:addr:' \
        '-tlsbind=[TLS IRC bind addr]:addr:' \
        '-tlsdir=[dir holding key.pem and cert.pem]:dir:_files -/'
}

_matterircd "$@"
