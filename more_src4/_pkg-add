#compdef pkg-add pkg_add
# _pkg-add — OpenBSD pkg_add install/upgrade package CLI alias (OpenBSD project, Perl); custom argparse
# upstream: https://github.com/openbsd/src/tree/master/usr.sbin/pkg_add

_pkg-add() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[install for all archs]' \
        '-A+[arch]:str:' \
        '-B+[chroot]:dir:_files -/' \
        '-c[clean cache]' \
        '-D+[debug option]:str:' \
        '-F+[force option]:list:(allversions checksum donttie repair scripts SIGNER updatedepends)' \
        '-i[interactive]' \
        '-I[no interaction]' \
        '-l+[load file]:file:_files' \
        '-L+[location]:dir:_files -/' \
        '-m[multi packages]' \
        '-n[dry run]' \
        '-O[no install]' \
        '-P+[path]:dir:_files -/' \
        '-Q+[query]:str:' \
        '-r[replace]' \
        '-s[show signatures]' \
        '-t[temp dir]' \
        '-u[update]' \
        '-U[force update]' \
        '-v[verbose]' \
        '-vv[more verbose]' \
        '-V[print version]' \
        '-z[interactive]' \
        '-Z[force interactive]' \
        '*:package:'
}

_pkg-add "$@"
