#compdef musixflx
# Documentation: musixflx (Musixflx-0.83.3.lua7) — second-pass MusiXTeX line-break processor.
# Source: Reads BASENAME.mx1 produced by the first etex pass, writes BASENAME.mx2.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:mx1 input basename:_files -g "*.mx1(:r)"' \
    && ret=0

return ret
