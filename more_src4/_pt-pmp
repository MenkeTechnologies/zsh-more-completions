#compdef pt-pmp
# Documentation: https://docs.percona.com/percona-toolkit/pt-pmp.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  {-b+,--binary=}'[binary to trace]:binary:' \
  {-d+,--dumper=}'[stack trace collection method]:dumper:(gdb eu-stack pt-eustack-resolver)' \
  {-s+,--interval=}'[seconds between iterations]:sec:' \
  {-i+,--iterations=}'[number of iterations]:n:' \
  {-l+,--lines=}'[strip backtrace to N lines]:n:' \
  {-p+,--pid=}'[PID to profile]:pid:' \
  '--readnever[pass --readnever to gdb for faster traces]' \
  {-k+,--save-samples=}'[save raw traces to file]:file:_files' \
  {-t+,--tids=}'[extract traces only for specified tids]:tids:' \
  '*:file:_files' && ret=0

return ret
