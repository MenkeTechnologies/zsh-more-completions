#compdef purs-tidy
# _purs-tidy — PureScript code formatter (natefaubion/purescript-tidy)
# upstream: https://github.com/natefaubion/purescript-tidy
# Subcommands from README usage examples.

_purs-tidy() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '1: :_purs-tidy_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                format)
                    _arguments \
                        '--config=[path to .tidyrc.json config file]:file:_files -g "*.json"' \
                        '*:PureScript file (or - for stdin):_files -g "*.purs"' && ret=0 ;;
                format-in-place)
                    _arguments \
                        '--config=[path to .tidyrc.json config file]:file:_files -g "*.json"' \
                        '*:PureScript files / globs:_files -g "*.purs"' && ret=0 ;;
                check)
                    _arguments \
                        '--config=[path to .tidyrc.json config file]:file:_files -g "*.json"' \
                        '*:PureScript files / globs:_files -g "*.purs"' && ret=0 ;;
                generate-operators)
                    _arguments \
                        '*:PureScript source file:_files -g "*.purs"' && ret=0 ;;
                generate-config)
                    _arguments \
                        '--arrow-first[align by arrow first]' \
                        '--arrow-last[align by arrow last]' \
                        '--unicode-always[always emit unicode operators]' \
                        '--unicode-never[never emit unicode operators]' \
                        '--unicode-source[match unicode operators from the source]' \
                        '--width=[max line width]:n:' \
                        '--indent=[indent width in spaces]:n:' \
                        '--operators=[path to a generated operators file]:file:_files' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_purs-tidy_commands] )) ||
_purs-tidy_commands() {
    local -a commands
    commands=(
        'format:format PureScript source (stdin or file argument) to stdout'
        'format-in-place:format PureScript files in place'
        'check:verify that the given files are formatted'
        'generate-operators:emit operator-precedence table for the given sources'
        'generate-config:emit a .tidyrc.json with the chosen options'
    )
    _describe -t commands 'purs-tidy command' commands
}

_purs-tidy "$@"
