#compdef postinstall
# Documentation: man postinstall(8)
# Source: netbsd/src usr.sbin/postinstall — check/fix installation after upgrade (sh).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a+[set MACHINE_ARCH (default host)]:arch:_default' \
    '-d+[target directory to check (default /)]:destdir:_files -/' \
    '-m+[set MACHINE (default host)]:machine:_default' \
    '-s+[source tree, set directory, or set file]:source:_files' \
    '-x+[X11 source directory]:xsrcdir:_files -/' \
    '(- *)-\?[display help]' \
    '1:operation:(check diff fix help list usage)' \
    '*::item:_default' \
    && ret=0

return ret
