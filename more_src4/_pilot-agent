#compdef pilot-agent
# Documentation: https://istio.io/latest/docs/reference/commands/pilot-agent/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pilot-agent: Istio sidecar entrypoint (manages envoy)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'proxy:run as sidecar proxy'
  'request:make a request to admin API'
  'completion:emit shell completion'
  'version:show version'
  'wait:wait for envoy to be ready'
  'istio-clean-iptables:clean iptables rules'
  'istio-iptables:set up iptables rules'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--domain=[DNS domain suffix]:domain:' \
  '--meshConfig=[meshconfig file]:file:_files' \
  '--proxyComponentLogLevel=[proxy component log level]:level:' \
  '--proxyLogLevel=[proxy log level]:level:' \
  '--statusPort=[status port]:port:' \
  '--adminPort=[admin port]:port:' \
  '--concurrency=[proxy worker threads]:n:' \
  '--templateFile=[envoy template file]:file:_files' \
  '--disable-installmanager[disable install manager]' \
  '--profiling[enable pprof]' \
  '--log_as_json[log as json]' \
  '--log_caller=[log caller scope]:scope:' \
  '--log_output_level=[log output level]:level:' \
  '--log_stacktrace_level=[log stacktrace level]:level:' \
  '--log_target=[log target]:target:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'pilot-agent command' commands && ret=0 ;;
esac
return ret
