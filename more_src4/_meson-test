#compdef meson-test
# _meson-test — Meson build system meson-test CLI alias (Meson team / Jussi Pakkanen, Python); argparse
# upstream: https://github.com/mesonbuild/meson

_meson-test() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--maxfail=+[max fail]:n:' \
        '--no-rebuild[no rebuild before tests]' \
        '--gdb[run tests under gdb]' \
        '--gdb-path=+[gdb path]:file:_files' \
        '--list[list tests]' \
        '--wrapper=+[wrapper]:str:' \
        '-C+[build dir]:dir:_files -/' \
        '--suite=+[suite]:list:' \
        '--no-suite=+[no suite]:list:' \
        '--no-stdsplit[no stdsplit]' \
        '--print-errorlogs[print error logs]' \
        '--benchmark[only benchmarks]' \
        '--logbase=+[log base name]:str:' \
        '--num-processes=+[num processes]:n:' \
        '-j+[num processes]:n:' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--repeat=+[repeat]:n:' \
        '-t+[multiplier for timeout]:f:' \
        '--timeout-multiplier=+[multiplier for timeout]:f:' \
        '--max-lines=+[max lines]:n:' \
        '--setup=+[test setup]:str:' \
        '--test-args=+[args for tests]:str:' \
        '--interactive[run interactive]' \
        '-i[run interactive]' \
        '*:test:'
}

_meson-test "$@"
