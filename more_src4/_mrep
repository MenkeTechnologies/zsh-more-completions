#compdef mrep
# Documentation: https://manpages.debian.org/testing/mblaze/mrep.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. mblaze mrep reply tool. Header
# flags (-to, -cc, -subject, -from, -bcc, -body) prefill draft headers and
# may be combined with `--` before the msg argument.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-noquote[do not quote the original message]' \
  '-send[send directly without editor]' \
  '-body[prepopulate draft body from file]:file:_files' \
  '-to[prefill To header]:address:' \
  '-cc[prefill Cc header]:address:' \
  '-bcc[prefill Bcc header]:address:' \
  '-from[prefill From header]:address:' \
  '-subject[prefill Subject header]:subject:' \
  '*:msg:' && ret=0

return ret
