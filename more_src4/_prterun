#compdef prterun
# Documentation: https://docs.prrte.org/en/latest/manpages/prterun.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above plus local `prterun --help` output.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-v,--verbose}'[verbose output]' \
  '-n+[number of processes]:n:' \
  '-N+[processes per node]:n:' \
  '-H+[host list]:hosts:_hosts' \
  '--hostfile=[host file]:file:_files' \
  '-c+[number of processes]:n:' \
  '-s+[scratch directory]:dir:_files -/' \
  '--wdir=[working directory]:dir:_files -/' \
  '--prefix=[PRRTE install prefix]:dir:_files -/' \
  '--no-app-prefix[disable application prefix lookup]' \
  '--noprefix[do not use prefix]' \
  '--no-ready-msg[suppress ready message]' \
  '--show-progress[show launch progress]' \
  '--get-stack-traces[show stack traces on failure]' \
  '--do-not-launch[parse but do not launch]' \
  '--stop-in-init[stop in init for debug]' \
  '--stop-in-app[stop in app for debug]' \
  '--stop-on-exec[stop on exec for debug]' \
  '--debug-daemons[debug PRTE daemons]' \
  '--hetero-nodes[cluster has heterogeneous nodes]' \
  '--set-sid[direct daemon to separate session]' \
  '--system-server[start as system server]' \
  '*::command:_normal' && ret=0

return ret
