#compdef packemon
# Documentation: https://packemon.dev/docs
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:compile packages for distribution'
  'build-workspace:build multiple packages in a workspace'
  'clean:remove build artifacts'
  'files:manage package files'
  'init:initialize a new packemon project'
  'pack:create distributable package archives (clean + build + validate)'
  'pack-workspace:pack multiple workspace packages'
  'scaffold:generate new TypeScript packages'
  'validate:verify package requirements and configuration'
  'watch:monitor files and rebuild automatically'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'packemon command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (build|pack)
        _arguments -s -S \
          '--addEngines[add engines block to package.json]' \
          '--addExports[populate exports field in package.json]' \
          '--addFiles[update files whitelist in package.json]' \
          '--concurrency=[parallel build limit]:n:' \
          '--declaration[generate TypeScript declarations]' \
          '--loadConfigs[load custom Babel and Rollup configs]' \
          '--skipPrivate[skip private packages]' \
          '--stamp[stamp release timestamp in package.json]' \
          '--timeout=[build timeout in milliseconds]:ms:' && ret=0
        ;;
      (validate)
        _arguments -s -S \
          '--deps[validate dependencies]' \
          '--engines[validate engine versions]' \
          '--entries[validate entry points]' \
          '--license[validate license info]' \
          '--links[validate URL fields]' \
          '--meta[validate metadata fields]' \
          '--people[validate author/contributors]' \
          '--repo[validate repository field]' \
          '--skipPrivate[skip private packages]' && ret=0
        ;;
    esac
    ;;
esac

return ret
