#compdef mcp-google-sheets
# Documentation: https://github.com/xing5/mcp-google-sheets
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Google Sheets MCP server

_arguments -s -S \
  '--include-tools=[comma-separated tool names to enable]:tools' \
  '--transport=[transport protocol]:transport:(stdio sse)' \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*::args:_default' && return 0
