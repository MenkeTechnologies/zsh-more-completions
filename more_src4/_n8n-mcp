#compdef n8n-mcp
# Documentation: https://github.com/czlonkowski/n8n-mcp
# Reference accessed: 2026-05-17
# Verified: czlonkowski/n8n-mcp. MCP server invoked via npx/Docker;
# behavior is configured via environment variables (MCP_MODE,
# MCP_AUTH_TOKEN, N8N_API_URL, N8N_API_KEY, LOG_LEVEL, PORT, HOST).
# Removed from prior file: bogus man.archlinux.org search URL.

# n8n-mcp: n8n Model Context Protocol server (env-driven)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' && ret=0
return ret
