#compdef oclock
# Documentation: man oclock (X.Org)
# Source: round-face X11 clock.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-fg+[foreground color]:color:' \
    '-bg+[background color]:color:' \
    '-jewel+[jewel color]:color:' \
    '-minute+[minute-hand color]:color:' \
    '-hour+[hour-hand color]:color:' \
    '-backing+[backing-store mode]:mode:(WhenMapped Always NotUseful)' \
    '-geometry+[window geometry]:geom:' \
    '-display+[X display]:display:' \
    '-bd+[border color]:color:' \
    '-bw+[border width]:n:' \
    '(-shape -noshape)-shape[use Shape extension for oval]' \
    '(-shape -noshape)-noshape[rectangular window]' \
    '-transparent[transparent background]' \
    && ret=0

return ret
