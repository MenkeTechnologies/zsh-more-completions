#compdef pop-cli pop
# Documentation: source-direct extraction from upstream
# r0gue-io/pop-cli crates/pop-cli/src/ (clap v4 derive):
#   main.rs lines 115-123 (Cli Parser struct: subcommand +
#     global `--json` flag)
#   commands/mod.rs lines 44-92 (Command Subcommand enum:
#     14 variants; 11 with single-letter aliases; up has
#     2-array aliases ["u", "deploy"]; 4 feature-gated by
#     `chain`/`contract`/either-of-them)
#   commands/mod.rs lines 95-115 (about_build() +
#     about_up() — runtime cfg-cascading about-text fns)
#   commands/hash.rs lines 27-77 (HashArgs + Command enum:
#     4 hash algorithms with per-algorithm bit-length
#     restrictions via `SupportedLengths::new([N,N,..])`
#     runtime ValueParser)
#   commands/completion.rs lines 22-37 (CompletionShell
#     ValueEnum mirroring clap_complete::Shell + 5 variants
#     with explicit value names)
#   commands/completion.rs lines 50-60 (CompletionArgs with
#     BOTH positional `shell` AND `--shell` flag with
#     `conflicts_with = "shell"` — 2 ways to specify same
#     thing)
#   commands/upgrade.rs lines 20-31 (UpgradeArgs:
#     `args_conflicts_with_subcommands = true` + --path/-p
#     + --version/-v)
# Reference accessed: 2026-05-30 via gh api.
#
# pop-cli (binary name `pop`) is the **r0gue Polkadot
# dapp/parachain/contract CLI** — all-in-one tool for
# Polkadot development: install toolchains, scaffold new
# projects, build/test/deploy/upgrade/verify parachains
# and ink! smart contracts, fork live chains for local
# testing, hash data with the chain's hash algorithms,
# convert between Polkadot/Ethereum address formats.
# Pivots from Fuel/Substrate (R254 subxt) into the
# **Polkadot application-layer CLI** — sister to subxt
# (codegen), polkadot (node), pop (already a different
# tool in corpus).
#
# Critical extraction note: pop-cli uses
# **`#[command(subcommand_required = true)]`** at
# commands/mod.rs:45 — forces a subcommand to be specified
# (no default behavior).  Documents the corpus's pattern
# already at R213/R214 in another production CLI.
#
# Critical extraction note: pop-cli uses **single-letter
# aliases on 11 of 14 subcommands** for muscle-memory
# shorthand:
#   install → `i`, new → `n`, build → `b`, call → `c`,
#   up → `u` (+ "deploy" alias), upgrade → `ug`, test → `t`,
#   hash → `h`, clean → `C` (capital), convert → `cv`,
#   verify → `v`, fork → `f`
# Documents **clap's `#[clap(alias = "X")]` and
# `#[clap(aliases = ["X", "Y"])]` at scale** — one CLI
# applying alias-shortcut convention systematically across
# subcommands.  Note: `--C` (capital) avoids collision with
# `-c` (call's alias).  Plus `up` uses ARRAY-form
# `#[clap(aliases = ["u", "deploy"])]` for 2 aliases.
# Extends the corpus's subcommand-alias documentation
# (R240+, R250 sozo's 2-depth aliases).  Most-aliases-
# per-CLI in the corpus so far.
#
# Critical extraction note: pop-cli's `Command` enum has
# **4 feature-gating variants combinatorially**: variants
# are present if `feature = "chain"` OR `feature = "contract"`
# (Install, New, Call, Up) — `#[cfg(any(feature = "chain",
# feature = "contract"))]`.  Bench/Fork require `chain`
# only.  Verify requires `contract` only.  Build/Upgrade/
# Test/Hash/Clean/Convert/Completion are unconditional.
# Documents the **multi-feature OR-gated variant pattern**
# — `#[cfg(any(feature = "A", feature = "B"))]` makes the
# variant present if EITHER feature is on (not requiring
# both).  Distinct from R250 sozo's single-feature
# `#[cfg(feature = "walnut")]` and R254 subxt's single-
# feature field gating.  Pop-cli has **4 different
# feature-set memberships** for its 14 variants — a
# production example of conditional CLI surface based
# on build features.
#
# Critical extraction note: pop-cli uses **runtime
# `about = about_build()` + `about = about_up()` fns**
# at commands/mod.rs:58 + 64 — each returns a different
# `&'static str` based on which features are enabled at
# compile time via cfg-cascading returns.  E.g.:
#   if (chain && contract) → "Build a parachain, chain
#     specification, smart contract or Rust package."
#   if (chain && !contract) → "Build a parachain, chain
#     specification or Rust package."
#   if (!chain && contract) → "Build a smart contract or
#     Rust package."
#   if (!chain && !contract) → "Build a Rust package."
# Documents the **cfg-cascading about-text fn pattern**
# — the help message dynamically reflects which features
# are enabled.  Plus the `about_build()` fn uses
# `#[cfg(all(...))]` for combinatorial cfg matching (not
# `#[cfg(any(...))]`).  Distinct from R249 cairo-profiler's
# runtime `version = generate_version()` (which computes
# version string) and R256 fuel-core-keygen's runtime
# `default_value = trait::FQN::method()` — pop-cli's
# `about = fn()` is for ABOUT TEXT specifically.
#
# Critical extraction note: pop-cli's `hash` sub-subcommand
# uses **`value_parser = SupportedLengths::new([N,N,..])`**
# at hash.rs:43-77 — a runtime-constructed ValueParser
# that restricts the bit-length arg to specific values per
# hash algorithm:
#   blake2  → 64 / 128 / 256 / 512
#   keccak  → 256 / 512
#   sha2    → 256
#   twox    → 64 / 128 / 256 (alias: xx; name renamed via
#            `#[clap(alias = "xx", name = "twox")]`)
# Documents the **per-variant value_parser restriction
# pattern** — different sibling subcommands accept
# different value sets for the same-named positional arg
# (`LENGTH`).  Bonus: TwoX uses BOTH `alias = "xx"` AND
# `name = "twox"` — the variant Rust name is `TwoX` but
# the CLI name is `twox` (since `name = "twox"` overrides
# the auto-rename).  Documents the **simultaneous name
# + alias override** pattern — rename the canonical CLI
# name AND add an alias.
#
# Critical extraction note: pop-cli's `completion`
# subcommand offers **2 mutually-exclusive ways to
# specify shell** at completion.rs:50-60:
#   positional: `pop completion zsh`
#   flag:       `pop completion --shell zsh`
# The flag form has `conflicts_with = "shell"` (the
# positional's clap-id).  Distinct from R251 torii's
# dotted-prefix flag namespacing.  Documents the
# **positional-or-flag dual-input pattern** — useful for
# scripts that prefer explicit `--flag value` form over
# positional args.  Most CLIs pick one; pop-cli supports
# both for ergonomic flexibility.

local curcontext="$curcontext" state line ret=1

# 14 top-level subcommands decoded source-direct from
# Command enum at commands/mod.rs lines 46-91.  Aliases
# shown in parens after the command name.
local -a subcommands=(
  'install:set up dev environment by installing required packages'
  'i:alias for `install`'
  'new:generate a new parachain, pallet, or smart contract'
  'n:alias for `new`'
  'bench:benchmark a pallet or parachain (FEATURE-GATED: chain)'
  'build:build a parachain, chain spec, smart contract or Rust package'
  'b:alias for `build`'
  'call:call a chain or smart contract'
  'c:alias for `call`'
  'up:deploy a chain (parachain), deploy a smart contract, or launch local network'
  'u:alias for `up`'
  'deploy:alias for `up`'
  'upgrade:upgrade the Polkadot SDK toolchain'
  'ug:alias for `upgrade`'
  'test:test a Rust project'
  't:alias for `test`'
  'hash:hash data using a supported algorithm (sub: blake2 / keccak / sha2 / twox)'
  'h:alias for `hash`'
  'clean:remove generated/cached artifacts'
  'C:alias for `clean` (capital to avoid collision with -c)'
  'convert:convert between formats (e.g. ETH ↔ Polkadot address)'
  'cv:alias for `convert`'
  'completion:generate shell completions'
  'verify:verify a smart contract binary (FEATURE-GATED: contract)'
  'v:alias for `verify`'
  'fork:fork a live chain and start a local RPC server (FEATURE-GATED: chain)'
  'f:alias for `fork`'
)

local -a hash_subs=(
  'blake2:BLAKE2b hash (lengths: 64 / 128 / 256 / 512)'
  'b2:alias for `blake2`'
  'keccak:Keccak hash (lengths: 256 / 512)'
  'kk:alias for `keccak`'
  'sha2:SHA-2 hash (length: 256 only)'
  's2:alias for `sha2`'
  'twox:xxHash non-cryptographic (lengths: 64 / 128 / 256)'
  'xx:alias for `twox`'
)

local -a completion_shells=(bash zsh fish powershell elvish)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--json[emit output as JSON envelope (for scripting / CI / MCP; global)]' \
  '1:subcommand:->subcmd' \
  '*::args:->args' && ret=0

case $state in
  subcmd)
    _describe -t subcommands 'pop-cli subcommand' subcommands && ret=0
    ;;
  args)
    case $words[1] in
      hash|h)
        if (( CURRENT == 2 )); then
          _describe -t hash-subs 'hash algorithm' hash_subs && ret=0
        else
          case $words[2] in
            blake2|b2)
              _arguments \
                '1:bit length:(64 128 256 512)' \
                '2:data (literal or file path):' \
                '(-c --concat)'{-c,--concat}'[append source data to the hash]' && ret=0
              ;;
            keccak|kk)
              _arguments \
                '1:bit length:(256 512)' \
                '2:data (literal or file path):' && ret=0
              ;;
            sha2|s2)
              _arguments \
                '1:bit length:(256)' \
                '2:data (literal or file path):' && ret=0
              ;;
            twox|xx)
              _arguments \
                '1:bit length:(64 128 256)' \
                '2:data (literal or file path):' \
                '(-c --concat)'{-c,--concat}'[append source data to the hash]' && ret=0
              ;;
          esac
        fi
        ;;
      completion)
        _arguments \
          '(-o --output)'{-o+,--output=}'[write completions to file instead of stdout]:file:_files' \
          '(--shell)1:shell:($completion_shells)' \
          '(1)--shell=[shell type (mutex with positional shell)]:shell:($completion_shells)' && ret=0
        ;;
      upgrade|ug)
        _arguments \
          '(-p --path)'{-p+,--path=}'[path to Cargo.toml (default: current directory)]:file:_files -g "Cargo.toml"' \
          '(-v --version)'{-v+,--version=}'[target Polkadot SDK version (prompts if omitted)]:version:' && ret=0
        ;;
      convert|cv)
        _arguments \
          '1:address (ETH 0x40-hex / SS58 / hex 0x64-hex public key):' && ret=0
        ;;
    esac
    ;;
esac

return ret
