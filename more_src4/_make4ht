#compdef make4ht
# Documentation: make4ht --help
# Source: TeX make4ht — build system for TeX4ht (LaTeX -> HTML/XML).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-a --loglevel)'{-a,--loglevel=}'[log level]:level:(debug info status warning error fatal)' \
    '(-b --backend)'{-b,--backend=}'[XML generation backend]:backend:(tex4ht lua4ht)' \
    '(-c --config)'{-c,--config=}'[custom config file]:config:_files' \
    '(-d --output-dir)'{-d,--output-dir=}'[output directory]:dir:_files -/' \
    '(-B --build-dir)'{-B,--build-dir=}'[build directory]:dir:_files -/' \
    '(-e --build-file)'{-e,--build-file=}'[custom build file]:file:_files' \
    '(-f --format)'{-f,--format=}'[output format]:format:(html5 xhtml ooffice odt epub docbook)' \
    '(- *)'{-h,--help}'[show help]' \
    '(-j --jobname)'{-j,--jobname=}'[job name]:name:' \
    '(-l --lua -x --xetex)'{-l,--lua}'[use lualatex]' \
    '(-m --mode)'{-m,--mode=}'[makefile mode switch]:mode:' \
    '(-n --no-tex4ht)'{-n,--no-tex4ht}'[disable DVI processing with tex4ht]' \
    '(-s --shell-escape)'{-s,--shell-escape}'[enable LaTeX shell-escape]' \
    '(-u --utf8)'{-u,--utf8}'[obsolete UTF-8 toggle]' \
    '(- *)'{-v,--version}'[show version]' \
    '(-l --lua -x --xetex)'{-x,--xetex}'[use xelatex]' \
    '1:LaTeX input file:_files -g "*.tex"' \
    '*::tex4ht / t4ht / latex op strings:' \
    && ret=0

return ret
