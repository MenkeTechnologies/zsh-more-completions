#compdef pod2usage
# Documentation: pod2usage --help
# Source: Perl POD pod2usage — generate usage messages from POD docs.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[show help]' \
    '(- *)-man[show this command manual page]' \
    '-exit=[exit status to return]:exitval:' \
    '-output=[output file (- / >&1 / >&2 special)]:file:_files' \
    '-verbose=[verbosity level]:level:(1 2 3)' \
    '-pathlist=[colon-separated dirs to search input in]:dirlist:' \
    '-formatter=[text formatter module]:module:(Pod::Text Pod::Text::Termcap Pod::Text::Color)' \
    '-utf8[generate UTF-8 output]' \
    '*:POD file:_files -g "*.{pod,pm,pl}"' \
    && ret=0

return ret
