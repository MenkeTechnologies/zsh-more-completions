#compdef perlbrew
# Documentation: https://perlbrew.pl/
# Source: gugod/App-perlbrew lib/App/perlbrew.pm — Perl version manager (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    {-h,--help}'[show help]' \
    '--quiet[suppress messages]' \
    '--verbose[verbose output]' \
    '--force[force action]' \
    '1:command:(alias available clean compgen display-bashrc display-cshrc display-pristine-manpath display-pristine-path display-system-perl-executable display-system-perl-shebang download env exec help info init install install-cpanm install-cpm install-patchperl install-multiple lib list list-modules make-shim mirror off self-install self-upgrade switch switch-off symlink-executables uninstall upgrade-perl use version)' \
    '*::command args:->cmdargs' \
    && ret=0

return ret
