#compdef pnmtojpeg ppmtojpeg
# Documentation: man pnmtojpeg (Netpbm)
# Source: convert a Netpbm image to JPEG (libjpeg-based).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-exif=[Exif data from filespec]:file:_files' \
    '-quality=[JPEG quality 0..100]:n:' \
    '(-grayscale -greyscale)-grayscale[force grayscale JPEG]' \
    '(-grayscale -greyscale)-greyscale[force grayscale JPEG]' \
    '-density=[JFIF density (NxN[dpi|dpcm])]:density:' \
    '(-optimize -optimise)-optimize[optimise Huffman tables]' \
    '(-optimize -optimise)-optimise[optimise Huffman tables]' \
    '-rgb[do not convert RGB to YCbCr]' \
    '-progressive[progressive JPEG]' \
    '-comment=[embed COM marker text]:text:' \
    '-dct=[DCT method]:method:(int fast float)' \
    '-arithmetic[arithmetic coding]' \
    '-restart=[restart interval]:n:' \
    '-smooth=[smoothing factor 0..100]:n:' \
    '-maxmemory=[max memory (bytes)]:n:' \
    '-verbose[verbose output]' \
    '-baseline[force baseline JPEG (8-bit)]' \
    '-qtables=[quantisation tables file]:file:_files' \
    '-qslots=[qtable selector list]:list:' \
    '-sample=[sampling factors (HxV[,...])]:list:' \
    '-scans=[scan-script file]:file:_files' \
    '-tracelevel=[libjpeg trace level]:n:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:netpbm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
