#compdef passwd-cli
# _passwd-cli — shadow passwd change user password CLI alias (shadow-maint team, C); custom argparse
# upstream: https://github.com/shadow-maint/shadow

_passwd-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-a[show password status for all users]' \
        '--all[show password status for all users]' \
        '-d[delete password]' \
        '--delete[delete password]' \
        '-e[expire password]' \
        '--expire[expire password]' \
        '-i+[inactive days after expiry]:n:' \
        '--inactive=+[inactive days after expiry]:n:' \
        '-k[keep tokens]' \
        '--keep-tokens[keep tokens]' \
        '-l[lock account]' \
        '--lock[lock account]' \
        '-n+[min days between password changes]:n:' \
        '--mindays=+[min days between password changes]:n:' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-r+[repository]:r:(files nis ldap)' \
        '--repository=+[repository]:r:(files nis ldap)' \
        '-R+[chroot]:dir:_files -/' \
        '--root=+[chroot]:dir:_files -/' \
        '-P+[prefix]:dir:_files -/' \
        '--prefix=+[prefix]:dir:_files -/' \
        '-S[show password status]' \
        '--status[show password status]' \
        '-s[change shell]' \
        '--stdin[read from stdin]' \
        '-u[unlock account]' \
        '--unlock[unlock account]' \
        '-w+[warn days before expiry]:n:' \
        '--warndays=+[warn days before expiry]:n:' \
        '-x+[max days password valid]:n:' \
        '--maxdays=+[max days password valid]:n:' \
        '*:user:_users'
}

_passwd-cli "$@"
