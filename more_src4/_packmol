#compdef packmol
# Documentation: https://m3g.github.io/packmol/userguide.shtml
# Source: m3g/packmol — pack molecules into boxes for molecular dynamics.
# Reference accessed: 2026-06-10
#
# Two invocation forms:
#   packmol < input.inp
#   packmol -i input.inp [-o output.pdb]

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-i+[input file]:file:_files -g "*.(inp|in)(-.)"' \
    '-o+[output file (overrides input file output)]:file:_files -g "*.(pdb|xyz|mol2|tinker)(-.)"' \
    && ret=0

return ret
