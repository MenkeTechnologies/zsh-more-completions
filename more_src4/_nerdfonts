#compdef font-patcher
# Documentation: https://raw.githubusercontent.com/ryanoasis/nerd-fonts/master/font-patcher
# Reference accessed: 2026-05-19
# Verified: argparse.add_argument definitions in upstream font-patcher.

# Zsh completion for the Nerd Fonts font-patcher Python script.

_arguments \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(- *)'{-v,--version}'[show version and exit]' \
  '(-c --complete)'{-c,--complete}'[add all available glyphs]' \
  '(-s --mono --use-single-width-glyphs)'{-s,--mono,--use-single-width-glyphs}'[create monospaced font]' \
  '--single-width-glyphs[generate single-width (Nerd Font Mono)]' \
  '--variable-width-glyphs[do not adjust advance width (Nerd Font Propo)]' \
  '(-l --adjust-line-height)'{-l,--adjust-line-height}'[adjust line height]' \
  '(-q --quiet)'{-q,--quiet}'[suppress verbose output]' \
  '--debug=[verbose debug level]:level:(0 1 2 3)' \
  '--fontawesome[add Font Awesome glyphs]' \
  '--fontawesomeext[add Font Awesome Extension glyphs]' \
  '--fontlogos[add Font Logos glyphs]' \
  '--octicons[add Octicons glyphs]' \
  '--codicons[add Codicons glyphs]' \
  '--powersymbols[add IEC Power Symbols]' \
  '--pomicons[add Pomicons glyphs]' \
  '--powerline[add Powerline glyphs]' \
  '--powerlineextra[add Powerline Extra glyphs]' \
  '(--material --mdi)'{--material,--mdi}'[add Material Design Icons]' \
  '--weather[add Weather Icons]' \
  '--braille=[add Braille glyphs]:style:(rectangle circle gapless)' \
  '--custom=[specify custom symbol font]:file:_files' \
  '--postprocess=[script for post processing]:file:_files' \
  '(--removeligs --removeligatures)'{--removeligs,--removeligatures}'[remove ligatures]' \
  '--configfile=[specify config file]:file:_files' \
  '(-ext --extension)'{-ext,--extension}'=[change output file extension]:extension' \
  '(-out --outputdir)'{-out,--outputdir}'=[specify output directory]:dir:_directories' \
  '--glyphdir=[specify glyph directory]:dir:_directories' \
  '--makegroups=[grouping of patched font names]:n:(-1 0 1 2 3 4 5 6)' \
  '--has-no-italic[font family lacks italic (uses Oblique)]' \
  '--progressbars[show progress bars]' \
  '--no-progressbars[disable progress bars]' \
  '--careful[do not overwrite existing glyphs]' \
  '--boxdrawing[force patching box drawing glyphs]' \
  '--cell=[adjust or query cell size]:spec' \
  '--metrics=[select vertical metrics source]:source' \
  '--name=[naming source]:source:(full postscript filename)' \
  '--xavgcharwidth=[adjust xAvgCharWidth]:value' \
  '--dry[do not patch or store font]' \
  '1:font file:_files -g "*.{ttf,otf,woff,woff2}"' \
  && return 0
