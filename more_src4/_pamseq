#compdef pamseq
# Documentation: man pamseq (Netpbm)
# Source: generate a PAM image containing all values for a given depth and maxval.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-tupletype=[output tuple type]:type:(BLACKANDWHITE GRAYSCALE GRAYSCALE_ALPHA RGB RGB_ALPHA CMYK)' \
    '-min=[per-channel min values (n,n,...)]:list:' \
    '-max=[per-channel max values (n,n,...)]:list:' \
    '-step=[per-channel step values (n,n,...)]:list:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:depth:' \
    '2:maxval:' \
    && ret=0

return ret
