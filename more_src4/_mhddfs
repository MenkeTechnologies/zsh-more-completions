#compdef mhddfs
# Documentation: https://manpages.debian.org/bookworm/mhddfs/mhddfs.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-o+[mount option]:opt:(allow_other allow_root nonempty mlimit\= logfile\= loglevel\= entry_timeout\= attr_timeout\= negative_timeout\= readonly direct_io)' \
  '-f[run in foreground]' \
  '-d[debug mode]' \
  '*:source_and_mountpoint:_directories' && ret=0

return ret
