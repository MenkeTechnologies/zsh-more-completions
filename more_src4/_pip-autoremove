#compdef pip-autoremove
# Documentation: https://github.com/invl/pip-autoremove
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message and exit]' \
  '(- *)--version[show program version and exit]' \
  '(-l --list)'{-l,--list}'[list unused dependencies without uninstalling]' \
  '(-L --leaves)'{-L,--leaves}'[list leaf packages not used by any other packages]' \
  '(-y --yes)'{-y,--yes}'[do not ask for confirmation of uninstall deletions]' \
  '*:package' && ret=0

return ret
