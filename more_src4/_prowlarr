#compdef Prowlarr prowlarr
# Documentation: https://github.com/Prowlarr/Prowlarr
# Reference accessed: 2026-05-27
# Verified: upstream src/NzbDrone.Common/EnvironmentInfo/StartupContext.cs and
# src/NzbDrone.Host/ApplicationModes.cs in Prowlarr/Prowlarr. StartupContext
# parses tokens of the form "/flag", "-flag", or "/key=value" (case-insensitive
# after trimming leading - or /). Recognised flags: ? data nobrowser i u
# terminateexisting restart registerurl nosingleinstancecheck exitimmediately.

local ret=1

_arguments -s \
  '-?[show help]' \
  '/?[show help]' \
  '-help[show help]' \
  '-data=[application data directory]:directory:_files -/' \
  '/data=[application data directory]:directory:_files -/' \
  '-nobrowser[do not launch the browser on startup]' \
  '/nobrowser[do not launch the browser on startup]' \
  '-i[install Windows service]' \
  '/i[install Windows service]' \
  '-u[uninstall Windows service]' \
  '/u[uninstall Windows service]' \
  '-terminateexisting[terminate any other running Prowlarr instance]' \
  '/terminateexisting[terminate any other running Prowlarr instance]' \
  '-restart[restart Prowlarr after exit]' \
  '/restart[restart Prowlarr after exit]' \
  '-registerurl[register URL reservation (Windows)]' \
  '/registerurl[register URL reservation (Windows)]' \
  '-nosingleinstancecheck[skip the single-instance lock check]' \
  '/nosingleinstancecheck[skip the single-instance lock check]' \
  '-exitimmediately[exit immediately after startup tasks]' \
  '/exitimmediately[exit immediately after startup tasks]' && ret=0

return ret
