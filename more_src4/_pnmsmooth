#compdef pnmsmooth
# Documentation: man pnmsmooth (Netpbm)
# Source: smooth (low-pass / box-filter) a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-width=[filter width in pixels]:cols:' \
    '-height=[filter height in pixels]:rows:' \
    '-size[print filter size and exit]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
