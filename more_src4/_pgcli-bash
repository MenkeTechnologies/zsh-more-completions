#compdef pgcli mssqlcli
# Documentation: https://github.com/dbcli/pgcli/blob/main/pgcli/main.py
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

case $service in
  (pgcli)
    _arguments -C \
      '--help[show help]' \
      '(-h --host)'{-h+,--host=}'[host address]:host:_hosts' \
      '(-p --port)'{-p+,--port=}'[port]:port:' \
      '(-U --username)'{-U+,--username=}'[username]:user:_users' \
      '(-u --user)'{-u+,--user=}'[username]:user:_users' \
      '(-W --password)'{-W,--password}'[force password prompt]' \
      '(-w --no-password)'{-w,--no-password}'[never prompt for password]' \
      '(-d --dbname)'{-d+,--dbname=}'[database name]:db:' \
      '--single-connection[do not use a separate connection for completions]' \
      '(-v --version)'{-v,--version}'[version]' \
      '(-D --dsn)'{-D+,--dsn=}'[DSN alias from pgclirc]:dsn:' \
      '--list-dsn[list DSN aliases]' \
      '--pgclirc=[location of pgclirc file]:file:_files' \
      '--row-limit=[row limit threshold]:n:' \
      '--application-name=[application name]:name:' \
      '--less-chatty[skip intro on startup and goodbye on exit]' \
      '--prompt=[prompt format]:s:' \
      '--prompt-dsn=[prompt format for DSN connections]:s:' \
      '(-l --list)'{-l,--list}'[list available databases and exit]' \
      '--ping[check database connectivity and exit]' \
      '--auto-vertical-output[switch to vertical output if too wide]' \
      '--warn=[warn before destructive query]:mode:(all moderate off)' \
      '--ssh-tunnel=[open SSH tunnel]:address:' \
      '--log-file=[log file]:file:_files' \
      '--init-command=[SQL statement after connecting]:sql:' \
      '*:database:' && ret=0 ;;
  (mssqlcli)
    _arguments -C \
      '--help[show help]' \
      '(-S --server)'{-S+,--server=}'[server]:host:_hosts' \
      '(-d --database)'{-d+,--database=}'[database]:db:' \
      '(-U --username)'{-U+,--username=}'[user]:user:_users' \
      '(-P --password)'{-P+,--password=}'[password]:pass:' \
      '(-E --integrated)'{-E,--integrated}'[integrated auth]' \
      '(-N --encrypt)'{-N,--encrypt}'[encrypt]' \
      '(-C --trust-server-certificate)'{-C,--trust-server-certificate}'[trust cert]' \
      '--row-limit=[row limit]:n:' \
      '--less-chatty[less chatty]' \
      '--prompt=[prompt format]:s:' \
      '--logfile=[log file]:file:_files' \
      '--mssqlclirc=[config]:file:_files' \
      '--auto-vertical-output[auto vertical]' \
      '*: :' && ret=0 ;;
esac

return ret
