#compdef olm-copy-content
# _olm-copy-content — OLM catalog content copier (initContainer that copies FBC + cache into an emptyDir)
# upstream: https://github.com/operator-framework/operator-lifecycle-manager
# Flags from cmd/copy-content/main.go on tip.

_olm-copy-content() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--catalog.from=[path to catalog contents to copy]:dir:_files -/' \
        '--catalog.to=[destination path for catalog contents]:dir:_files -/' \
        '--cache.from=[path to cache contents to copy (requires --cache.to)]:dir:_files -/' \
        '--cache.to=[destination path for cache contents (requires --cache.from)]:dir:_files -/'
}

_olm-copy-content "$@"
