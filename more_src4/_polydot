#compdef polydot
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/polydot.1e.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# EMBOSS polydot: draw a dot plot for multiple sequences against each other
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequences=[input sequence(s)]:sequence USA:_files' \
  '-wordsize=[word size for matches]:size:' \
  '-boxit[draw a box around the dot plot]' \
  '-dumpfeat[also dump features to a file]' \
  '-gap=[gap between dot plots in pixels]:n:' \
  '-graph=[graph output format]:format:(x11 png ps cps colourps eps gif pdf hp7470 hp7580 meta data)' \
  '-outfeat=[feature output file]:file:_files' \
  '*:sequence USA:_files' && ret=0
return ret
