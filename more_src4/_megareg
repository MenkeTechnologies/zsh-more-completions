#compdef megareg
# megareg — register a new MEGA account

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--scripted[use scripted mode for non-interactive registration]' \
  {-n,--name}'=[full name for the account]:name:' \
  {-e,--email}'=[email address for registration]:email:' \
  {-p,--password}'=[password for the account]:password:' \
  '--register[perform the registration step]' \
  '--verify=[verify account with link from confirmation email]:verification link:' \
  '--config=[load configuration from a file]:config file:_files' \
  '--ignore-config-file[do not load configuration file]' \
  '--debug=[enable debugging output]:debug flags:' \
  '(- *)--version[show version]' \
  '--reload[reload filesystem cache]' \
  '--no-ask-password[never ask interactively for a password]' \
  '--disable-previews[do not generate previews on upload]' && ret=0

return ret
