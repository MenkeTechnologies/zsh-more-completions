#compdef mount_sysvbfs
# Documentation: man mount_sysvbfs(8)
# Source: netbsd/src sbin/mount_sysvbfs — mount a System V Boot File System (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-o+[mount options (comma-separated, see mount(8))]:options:_default' \
    '1:special device:_files' \
    '2:mount point:_files -/' \
    && ret=0

return ret
