#compdef pmlogcheck
# _pmlogcheck — Performance Co-Pilot pmlogcheck (verify integrity of a PCP archive; -l detailed listing, -v verbose, -w warn-only mode, -i metric instance list, -n namespace file, -S start, -T finish, -z archive timezone; positional argument is the archive prefix or .index file)
# upstream: https://github.com/performancecopilot/pcp
# Flags from PCP src/pmlogcheck/pmlogcheck.c on tip.

_pmlogcheck() {
    _arguments \
        '-l[detailed listing]' \
        '-v[verbose]' \
        '-w[warn only]' \
        '-i+[instance list]:instances:' \
        '-n+[namespace]:file:_files' \
        '-S+[start time]:time:' \
        '-T+[finish time]:time:' \
        '-z[archive timezone]' \
        '-Z+[timezone]:tz:' \
        '1:archive:_files'
}

_pmlogcheck "$@"
