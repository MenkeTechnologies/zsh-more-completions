#compdef mockgen
# Documentation: https://github.com/uber-go/mock
# Reference accessed: 2026-05-19
# Verified: uber-go/mock README (active fork; golang/mock is archived).

# Zsh completion for mockgen - GoMock mock interface code generator

_arguments -s -S \
  '-source[source file to generate mocks from (source mode)]:source file:_files -g "*.go"' \
  '-destination[output file (defaults to stdout)]:output file:_files -g "*.go"' \
  '-package[package name for generated mocks]:package name:' \
  '-imports[explicit import mapping (deprecated)]:imports:' \
  '-aux_files[auxiliary Go source files]:files:_files -g "*.go"' \
  '-build_flags[additional flags for go build]:flags:' \
  '-mock_names[custom names for generated mocks]:name mapping:' \
  '-self_package[full package import path for generated code]:import path:' \
  '-copyright_file[file containing copyright header]:file:_files' \
  '-debug_parser[print debug info from parser]' \
  '-write_package_comment[write package documentation comment (default true)]' \
  '-write_generate_directive[write go:generate directive]' \
  '-write_source_comment[write source comment]' \
  '-typed[generate type-safe methods]' \
  '-exclude_interfaces[comma-separated interface names to exclude]:interfaces:' \
  '*:package or interface:_files -g "*.go"' && return 0
