#compdef polespotter
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/spotter/polespotter.html
# Source: GenericMappingTools/gmt supplements/spotter — recover rotation poles from fracture-zone + abyssal-hill lineaments.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[abyssal-hill lineament segments file]:file:_files' \
    '-F+[fracture-zone lineament segments file]:file:_files' \
    '-G+[output grid file]:file:_files' \
    '-D+[great-circle increment (km, default 5)]:km:_default' \
    '-E+[angular uncertainty (a/f sigma)]:opts:_default' \
    '-I+[grid spacing dx/dy]:spacing:_default' \
    '-N[normalize max grid value to 1]' \
    '-R+[region west/east/south/north]:region:_default' \
    '-Sl+[line mode: test trial pole plon/plat]:plonplat:_default' \
    '-Sp[pole mode: grid-search chi-square misfits]' \
    '-Ss[spot mode: great-circle intersections]' \
    '*-V[verbose (stackable)]' \
    '-bi+[binary input format]:format:_default' \
    '-di+[input nodata → NaN]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-o+[output column selection]:cols:_default' \
    '-r[pixel registration (default gridline)]' \
    '-:[swap first two columns]' \
    '*:input lineament file:_files' \
    && ret=0

return ret
