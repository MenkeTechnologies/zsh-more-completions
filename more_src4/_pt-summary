#compdef pt-summary
# Documentation: https://docs.percona.com/percona-toolkit/pt-summary.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--config=[config file]:config file:_files' \
  '--read-samples=[read saved samples]:directory:_directories' \
  '--save-samples=[save samples to directory]:directory:_directories' \
  '--sleep=[sleep time for sampling]:seconds:' \
  '(--summarize-mounts --no-summarize-mounts)'{--summarize-mounts,--no-summarize-mounts}'[report on mounted filesystems]' \
  '(--summarize-network --no-summarize-network)'{--summarize-network,--no-summarize-network}'[report on network controllers]' \
  '(--summarize-processes --no-summarize-processes)'{--summarize-processes,--no-summarize-processes}'[report on top processes and vmstat]' && ret=0

return ret
