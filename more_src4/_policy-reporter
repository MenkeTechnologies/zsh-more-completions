#compdef policy-reporter policyreporter
# _policy-reporter — emit Prometheus metrics and notifications from PolicyReports (kyverno/policy-reporter)
# upstream: https://github.com/kyverno/policy-reporter
# Flags from cmd/run.go and cmd/send.go (spf13/cobra).

_policy-reporter() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-k --kubeconfig)'{-k+,--kubeconfig=}'[path to kubeconfig]:file:_files' \
        '(-c --config)'{-c+,--config=}'[target configuration file]:file:_files -g "*.(yml|yaml)"' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'run:run watcher & HTTP metrics server'
                'send:send report summaries/violations to targets'
                'version:print version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                run)
                    _arguments \
                        '(-p --port)'{-p+,--port=}'[REST API port]:port:' \
                        '(-d --dbfile)'{-d+,--dbfile=}'[SQLite DB file path]:file:_files -g "*.db"' \
                        '(-m --metrics-enabled)'{-m,--metrics-enabled}'[enable metrics API]' \
                        '(-r --rest-enabled)'{-r,--rest-enabled}'[enable REST API]' \
                        '--profile[enable pprof profiling]' \
                        '--lease-name=[LeaseLock name]:name:' \
                        '--pod-name=[pod name for leader election]:name:' \
                        '(-t --template-dir)'{-t+,--template-dir=}'[template directory]:dir:_files -/' \
                        '--worker=[worker queue size]:n:' \
                        '--qps=[K8s RESTClient QPS]:qps:' \
                        '--burst=[K8s RESTClient burst]:n:'
                    ;;
                send)
                    _arguments \
                        '(-t --template-dir)'{-t+,--template-dir=}'[email report template directory]:dir:_files -/' \
                        '1:subcommand:(summary violations)'
                    ;;
            esac
            ;;
    esac
}

_policy-reporter "$@"
