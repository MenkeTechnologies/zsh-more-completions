#compdef pastel
# Documentation: https://github.com/sharkdp/pastel
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for pastel - command-line tool to generate, convert, and manipulate colors

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'color:Display information about the given color'
  'list:Show a list of available color names'
  'random:Generate a list of random colors'
  'distinct:Generate a set of visually distinct colors'
  'sort-by:Sort colors by the given property'
  'pick:Interactively pick a color from the screen'
  'format:Convert a color to the given format'
  'paint:Print colored text using ANSI escape sequences'
  'gradient:Generate an interpolating sequence of colors'
  'mix:Mix two colors in the given colorspace'
  'colorblind:Simulate a color under a colorblindness profile'
  'set:Set a color property to a specific value'
  'saturate:Increase color saturation by a specified amount'
  'desaturate:Decrease color saturation by a specified amount'
  'lighten:Lighten color by a specified amount'
  'darken:Darken color by a specified amount'
  'rotate:Rotate the hue channel by the specified angle'
  'complement:Get the complementary color (hue rotated by 180 degrees)'
  'gray:Create a gray tone from a given lightness'
  'to-gray:Completely desaturate a color preserving luminance'
  'textcolor:Get a readable text color for the given background'
  'colorcheck:Check if terminal supports 24-bit colors'
  'help:Print help'
)

_arguments -s -S \
  '(-m --color-mode)'{-m,--color-mode}'[terminal color mode]:mode:(24bit 8bit off auto)' \
  '(-f --force-color)'{-f,--force-color}'[alias for --mode=24bit]' \
  '--color-picker[external color picker tool]:tool:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      format)
        _arguments \
          ':format:(rgb rgb-float rgb-r rgb-g rgb-b hex hsl hsl-hue hsl-saturation hsl-lightness hsv hsv-hue hsv-saturation hsv-value lch lch-lightness lch-chroma lch-hue oklch oklch-lightness oklch-chroma oklch-hue lab lab-a lab-b oklab oklab-l oklab-a oklab-b luminance brightness ansi-8bit ansi-24bit ansi-8bit-value ansi-8bit-escapecode ansi-24bit-escapecode cmyk name)' \
          '*:color:' && ret=0
        ;;
      mix|gradient)
        _arguments \
          '(-s --colorspace)'{-s,--colorspace}'[colorspace for interpolation]:cs:(Lab LCh RGB HSL OkLab)' \
          '(-n --number)'{-n,--number}'[number of colors]:count:' \
          '(-f --fraction)'{-f,--fraction}'[mix fraction between 0.0 and 1.0]:fraction:' \
          '*:color:' && ret=0
        ;;
      sort-by|sort)
        _arguments \
          ':field:(brightness luminance hue chroma random)' \
          '(-r --reverse)'{-r,--reverse}'[reverse the sort order]' \
          '(-u --unique)'{-u,--unique}'[remove duplicate colors]' \
          '*:color:' && ret=0
        ;;
      saturate|desaturate|lighten|darken)
        _arguments \
          ':amount:' \
          '*:color:' && ret=0
        ;;
      rotate)
        _arguments \
          ':degrees:' \
          '*:color:' && ret=0
        ;;
      random)
        _arguments \
          '(-n --number)'{-n,--number}'[number of random colors]:count:' \
          '(-s --strategy)'{-s,--strategy}'[strategy for random colors]:strategy:(vivid rgb gray lch_hue)' \
          && ret=0
        ;;
      distinct)
        _arguments \
          ':count:' \
          '(-m --metric)'{-m,--metric}'[distance metric]:metric:(CIEDE2000 CIE76)' \
          '(-v --verbose)'{-v,--verbose}'[print simulation output to STDERR]' \
          '--print-minimal-distance[only show the optimized minimal distance]' \
          '*:color:' && ret=0
        ;;
      list)
        _arguments \
          '(-s --sort)'{-s,--sort}'[sort order]:key:(brightness luminance hue chroma random)' \
          && ret=0
        ;;
      paint)
        _arguments \
          '(-o --on)'{-o,--on}'[background color]:bg-color:' \
          '(-b --bold)'{-b,--bold}'[print the text in bold face]' \
          '(-i --italic)'{-i,--italic}'[print the text in italic font]' \
          '(-u --underline)'{-u,--underline}'[draw a line below the text]' \
          '(-n --no-newline)'{-n,--no-newline}'[do not print a trailing newline]' \
          ':color:' \
          '*:text:' && ret=0
        ;;
      colorblind)
        _arguments \
          ':type:(prot deuter trit)' \
          '*:color:' && ret=0
        ;;
      set)
        _arguments \
          ':property:(lightness hue chroma lab-a lab-b oklab-l oklab-a oklab-b red green blue hsl-hue hsl-saturation hsl-lightness alpha)' \
          ':value:' \
          '*:color:' && ret=0
        ;;
      pick)
        _arguments \
          ':count:' && ret=0
        ;;
      gray)
        _arguments \
          ':lightness:' && ret=0
        ;;
    esac
    ;;
esac

return ret
