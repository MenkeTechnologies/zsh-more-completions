#compdef postgres_exporter
# Documentation: https://github.com/prometheus-community/postgres_exporter
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--web.listen-address=[address to listen on]:address:' \
  '--web.telemetry-path=[path for metrics]:path:' \
  '--web.config.file=[TLS/auth config file]:file:_files' \
  '--log.level=[log level]:level:(debug info warn error)' \
  '--log.format=[log format]:format:(logfmt json)' \
  '--extend.query-path=[path to YAML file with custom queries]:file:_files' \
  '--disable-default-metrics[disable default metrics collection]' \
  '--disable-settings-metrics[disable pg_settings metrics collection]' \
  '--auto-discover-databases[discover databases on the server dynamically]' \
  '--include-databases=[databases to include when auto-discovering]:databases:' \
  '--exclude-databases=[databases to exclude when auto-discovering]:databases:' \
  '--constantLabels=[constant labels to apply to all metrics]:labels:' && ret=0

return ret
