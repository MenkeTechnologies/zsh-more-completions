#compdef ps2pdf ps2pdf12 ps2pdf13 ps2pdf14 ps2pdfwr ps2ps ps2ps2 ps2epsi ps2ascii
# Documentation: ps2pdfwr (Ghostscript)
# Source: Ghostscript-based PostScript/PDF/EPS conversion wrappers.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-d-[Ghostscript -d option]:option:' \
    '*-s-[Ghostscript -s option]:option:' \
    '*-c+[Ghostscript -c option]:postscript:' \
    '*-r+[resolution dpi]:dpi:' \
    '*-g+[geometry WIDTHxHEIGHT]:geometry:' \
    ':input:_files -g "*.(ps|eps|EPS|PS)"' \
    '::output:_files' \
    && ret=0

return ret
