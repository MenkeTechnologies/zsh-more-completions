#compdef mongoexport
# Documentation: https://www.mongodb.com/docs/database-tools/mongoexport/
# Source: MongoDB Database Tools — query + export to JSON / CSV.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(-v --verbose)*'{-v,--verbose}'[increase verbosity]' \
    '--quiet[quiet mode]' \
    '(- *)--version[show version]' \
    '--config=[YAML config file]:file:_files' \
    '--uri=[MongoDB connection URI]:uri:' \
    '(-h --host)'{-h+,--host=}'[hostname[:port]]:host:_hosts' \
    '--port=[TCP port]:port:' \
    '--ssl[enable TLS/SSL]' \
    '--sslCAFile=[CA cert chain (.pem)]:file:_files' \
    '--sslPEMKeyFile=[client cert+key (.pem)]:file:_files' \
    '--sslPEMKeyPassword=[cert-key password]:password:' \
    '--sslCRLFile=[CRL file]:file:_files' \
    '--sslAllowInvalidCertificates[bypass server cert validation]' \
    '--sslAllowInvalidHostnames[bypass hostname validation]' \
    '(-u --username)'{-u+,--username=}'[auth username]:user:_users' \
    '(-p --password)'{-p+,--password=}'[auth password]:password:' \
    '--awsSessionToken=[AWS session token]:token:' \
    '--authenticationDatabase=[auth database]:db:' \
    '--authenticationMechanism=[auth mechanism]:mech:(SCRAM-SHA-1 SCRAM-SHA-256 MONGODB-X509 MONGODB-AWS GSSAPI PLAIN)' \
    '--gssapiServiceName=[GSSAPI service name]:name:' \
    '--gssapiHostName=[GSSAPI host name]:host:_hosts' \
    '(-d --db)'{-d+,--db=}'[database name]:db:' \
    '(-c --collection)'{-c+,--collection=}'[collection name]:collection:' \
    '(-f --fields)'{-f+,--fields=}'[fields to include (comma-separated)]:list:' \
    '--fieldFile=[file containing field names]:file:_files' \
    '(-q --query)'{-q+,--query=}'[JSON query filter]:json:' \
    '--queryFile=[file containing query (extended JSON v2)]:file:_files' \
    '--type=[output type]:type:(json csv)' \
    '(-o --out)'{-o+,--out=}'[output file]:file:_files' \
    '--jsonFormat=[Extended JSON v2 mode]:mode:(canonical relaxed)' \
    '--jsonArray[wrap output in a JSON array]' \
    '--pretty[pretty-print JSON output]' \
    '--noHeaderLine[no header row (CSV only)]' \
    '--readPreference=[read preference]:pref:(primary primaryPreferred secondary secondaryPreferred nearest)' \
    '--skip=[skip N documents]:n:' \
    '--limit=[max documents to export]:n:' \
    '--sort=[ordering JSON document]:json:' \
    && ret=0

return ret
