#compdef oc-mirror
# Documentation: https://github.com/openshift/oc-mirror/blob/main/cmd/oc-mirror/main.go
# Reference accessed: 2026-05-19
# Verified: oc-mirror upstream main.go. Top-level routing flags
# --v1/--v2 (mutually exclusive), --cpu-prof, --mem-prof.
# Subcommands: version, describe (v1-only), init (v1-only),
# delete. v2 flags: -c/--config, --workspace, --from, --since,
# --image-timeout, --strict-archive, --rootless-storage-path,
# --secure-policy, --policy, --max-nested-paths.

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'version:show version'
  'describe:describe an archive (v1 only)'
  'init:initialize an imageset config (v1 only)'
  'delete:delete images from remote registry'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--v2)--v1[run legacy oc-mirror v1 binary]' \
  '(--v1)--v2[run oc-mirror v2 code path]' \
  '--cpu-prof[write cpu.prof in cwd]' \
  '--mem-prof[write mem.prof in cwd]' \
  '(-c --config)'{-c+,--config=}'[imageset configuration file]:file:_files' \
  '--workspace=[v2 workspace directory]:dir:_files -/' \
  '--from=[local storage directory (disk-to-mirror)]:dir:_files -/' \
  '--since=[mirror content since date (yyyy-MM-dd)]:date:' \
  '--image-timeout=[timeout for mirroring an image]:duration:' \
  '--strict-archive[strict archive size]' \
  '--rootless-storage-path=[override container storage path]:path:_files -/' \
  '--secure-policy[enable signature verification]' \
  '--policy=[trust policy file]:file:_files' \
  '--max-nested-paths=[limit nested paths]:n:' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'oc-mirror command' subcommands && ret=0 ;;
  args)
    case $line[1] in
      delete)
        _arguments \
          '--generate[generate delete yaml]' \
          '--delete-yaml-file=[delete yaml file]:file:_files' \
          '--delete-id=[delete id]:id:' \
          '--delete-signatures[delete container image signatures]' \
          '--delete-v1-images[delete v1-mirrored images during migration]' \
          '--force-cache-delete[force delete local cache]' && ret=0 ;;
    esac ;;
esac
return ret
