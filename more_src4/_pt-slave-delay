#compdef pt-slave-delay
# Documentation: https://docs.percona.com/percona-toolkit/pt-slave-delay.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--ask-pass[prompt for password]' \
  '(--buffer-stdout --no-buffer-stdout)'{--buffer-stdout,--no-buffer-stdout}'[enable/disable STDOUT buffering]' \
  '--charset=[default character set]:charset:' \
  '--config=[comma-separated config files]:files:_files' \
  '(--continue --no-continue)'{--continue,--no-continue}'[resume normal replication on exit]' \
  '--daemonize[fork to background]' \
  '--database=[default database]:db:' \
  '--defaults-file=[defaults file]:file:_files' \
  '--delay=[target lag behind master]:dur:' \
  '--host=[host]:host:_hosts' \
  '--interval=[check frequency]:dur:' \
  '--log=[log file when daemonized]:file:_files' \
  '--mysql_ssl=[create SSL connection]:n:' \
  '--password=[password]:pw:' \
  '--pid=[PID file]:file:_files' \
  '--port=[port]:port:' \
  '--quiet[suppress informational messages]' \
  '--run-time=[duration before exit]:dur:' \
  '--set-vars=[set MySQL variables]:list:' \
  '--socket=[socket]:file:_files' \
  '--use-master[get binlog positions from master]' \
  '--user=[user]:user:' \
  '(--version-check --no-version-check)'{--version-check,--no-version-check}'[check for latest versions]' \
  '*:slave_DSN:' && ret=0

return ret
