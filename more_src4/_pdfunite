#compdef pdfunite
# Documentation: https://manpages.debian.org/pdfunite.1
# Source: poppler-utils — concatenate multiple PDF files into a single PDF.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-v[print copyright + version]' \
    '(- *)-h[print usage]' \
    '*:input PDFs then output:_files -g "*.pdf"' \
    && ret=0

return ret
