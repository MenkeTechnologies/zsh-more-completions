#compdef newfs_lfs
# Documentation: man newfs_lfs(8)
# Source: netbsd/src sbin/newfs_lfs — construct a log-structured file system (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A[calculate segment size from bandwidth and access time]' \
    '-B+[logical segment size in bytes]:size:_default' \
    '-b+[block size in bytes]:block size:_default' \
    '-F[force LFS creation regardless of partition label]' \
    '-f+[fragment size in bytes]:fragment size:_default' \
    '-I+[interleave between segments]:interleave:_default' \
    '-i[set inode block size]' \
    '-L[create log-structured filesystem (default)]' \
    '-M+[segments reserved outside user data]:nsegs:_default' \
    '-m+[free space percentage reserved]:percent:_default' \
    '-N[simulate creation only]' \
    '-O+[first segment offset in sectors]:offset:_default' \
    '-R+[segments reserved for cleaner]:nsegs:_default' \
    '-r+[roll-forward identifier (v2)]:ident:_default' \
    '-s+[filesystem size in sectors]:size:_default' \
    '-v+[disk layout version (default 2)]:version:(1 2)' \
    '-w+[filesystem bit width]:bitwidth:(32 64)' \
    '1:special device:_files' \
    && ret=0

return ret
