#compdef policy-assistant
# _policy-assistant — sigs.k8s.io network-policy-api analyzer CLI
# upstream: https://github.com/kubernetes-sigs/network-policy-api
# Subcommands + flags from policy-assistant/pkg/cli/root.go + analyze.go on tip.

_policy-assistant() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'analyze:analyze policies in cluster or from files'
                'generate:generate test policies + probes'
                'probe:run a connectivity probe'
                'version:print version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                analyze)
                    _arguments \
                        '--use-example-policies=[read example policies]:bool:(true false)' \
                        '(-A --all-namespaces)'{-A,--all-namespaces}'[read from all namespaces]' \
                        '*'{-n,--namespace=}'[namespace(s) to read from]:ns:' \
                        '--policy-path=[file or directory of policies]:path:_files' \
                        '--context=[kubeconfig context]:context:' \
                        '--simplify-policies=[reduce policies to simpler form]:bool:(true false)' \
                        '*--mode=[csv of analysis modes]:csv:(explain query probe)' \
                        '--target-pod-path=[target pod JSON file]:file:_files' \
                        '--traffic-path=[traffic JSON file]:file:_files' \
                        '--probe-path=[synthetic probe model file]:file:_files' \
                        '--kube-client-timeout=[kube client timeout]:dur:' \
                        '--src-workload=[source workload (ns/type/name)]:spec:' \
                        '--dst-workload=[destination workload (ns/type/name)]:spec:' \
                        '--port=[port to test]:port:' \
                        '--protocol=[protocol to test]:protocol:(TCP UDP SCTP)' \
                        '--kubeconfig=[kubeconfig file]:file:_files'
                    ;;
            esac
            ;;
    esac
}

_policy-assistant "$@"
