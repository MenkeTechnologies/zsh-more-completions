#compdef pt
# Documentation: https://github.com/monochromegane/the_platinum_searcher
# Reference accessed: 2026-05-20
# Verified: upstream option.go at
# https://raw.githubusercontent.com/monochromegane/the_platinum_searcher/master/option.go
# Fixes: -f is --follow (not --file-search-regexp); -g prints filenames
# matching PATTERN; -G is --file-search-regexp.

local -a arguments

arguments=(
  '(-A --after)'{-A+,--after=}'[show NUM lines after match]:lines:'
  '(-B --before)'{-B+,--before=}'[show NUM lines before match]:lines:'
  '(-C --context)'{-C+,--context=}'[show NUM lines before and after match]:lines:'
  '--color[colorize output]'
  '--nocolor[disable colorized output]'
  '--color-line-number=[color for line numbers]:color:'
  '--color-match=[color for matches]:color:'
  '--color-path=[color for paths]:color:'
  '--column[show column numbers]'
  '(-c --count)'{-c,--count}'[print count of matching lines per file]'
  '-e+[treat pattern as regular expression]:pattern:'
  '--depth=[max directory depth to search]:depth:'
  '(-f --follow)'{-f,--follow}'[follow symbolic links]'
  '(-l --files-with-matches)'{-l,--files-with-matches}'[print only filenames containing matches]'
  '-g+[print filenames matching PATTERN]:pattern:'
  '(-G --file-search-regexp)'{-G+,--file-search-regexp=}'[limit search to files matching PATTERN]:pattern:'
  '--global-gitignore[use global .gitignore]'
  '--group[group matches by file]'
  '--nogroup[do not group matches by file]'
  '--hidden[search hidden files and directories]'
  '--home-ptignore[use ~/.ptignore]'
  '--ignore=[ignore files/directories matching pattern]:pattern:'
  '(-i --ignore-case)'{-i,--ignore-case}'[case insensitive search]'
  '(-S --smart-case)'{-S,--smart-case}'[smart case search]'
  '--numbers[show line numbers]'
  '(-N --nonumbers)'{-N,--nonumbers}'[omit line numbers]'
  '(-o --output-encode)'{-o+,--output-encode=}'[output encoding]:encoding:(none jis sjis euc)'
  '(-0 --null)'{-0,--null}'[use null byte separator]'
  '--vcs-ignore=[VCS ignore file]:file:'
  '(-U --skip-vcs-ignores)'{-U,--skip-vcs-ignores}'[skip VCS ignore files]'
  '(-w --word-regexp)'{-w,--word-regexp}'[match whole words only]'
  '(-h --help)'{-h,--help}'[show help message]'
  '--version[show version information]'
  '1:pattern:'
  '*:path:_files'
)

_arguments -s -S $arguments
