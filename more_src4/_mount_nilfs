#compdef mount_nilfs
# Documentation: man mount_nilfs(8)
# Source: netbsd/src sbin/mount_nilfs — mount a NILFS file system (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-c+[mount specific checkpoint number]:checkpoint:_default' \
    '-o+[mount options (comma-separated, see mount(8))]:options:_default' \
    '-t+[timezone offset in seconds from UTC]:gmtoff:_default' \
    '1:special device:_files' \
    '2:mount point:_files -/' \
    && ret=0

return ret
