#compdef pamstretch-gen
# Documentation: man pamstretch-gen (Netpbm)
# Source: enlarge a Netpbm image by an arbitrary factor (wrapper over pamstretch + pamscale).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:scale factor N:' \
    '2:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
