#compdef peer-list
# _peer-list — Percona PXC operator sidecar that watches a headless Service's DNS endpoints and invokes on-change/on-start scripts
# upstream: https://github.com/percona/percona-xtradb-cluster-operator
# Flags from cmd/peer-list/main.go on tip.

_peer-list() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-on-change=[script to run on peer-set change (reads peers from stdin)]:script:_files' \
        '-on-start=[script to run on start (reads peers from stdin)]:script:_files' \
        '-service=[governing headless service for SRV/A lookup]:svc:' \
        '-ns=[pod namespace (else POD_NAMESPACE env)]:ns:' \
        '-domain=[cluster domain (else read from /etc/resolv.conf)]:domain:' \
        '-protocol=[SRV lookup protocol]:proto:(tcp udp)'
}

_peer-list "$@"
