#compdef otbcli_DimensionalityReduction
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_DimensionalityReduction.html
# Source: orfeotoolbox/OTB DimensionalityReduction — PCA / NA-PCA / MAF / ICA decomposition.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-in+[input image]:image:_files' \
    '-out+[output components image]:image:_files' \
    '-outinv+[reconstructed (inverse) image]:image:_files' \
    '-outmatrix+[transformation matrix CSV]:file:_files -g "*.csv(-.)"' \
    '-method+[reduction algorithm]:method:(pca napca maf ica)' \
    '-nbcomp+[components to retain (0=all, default 0)]:n:_default' \
    '-normalize+[(true/false) center+reduce before reduction]:bool:(true false)' \
    '-rescale+[output rescaling mode]:mode:(no minmax)' \
    '-rescale.minmax.outmin+[output min (default 0)]:value:_default' \
    '-rescale.minmax.outmax+[output max (default 255)]:value:_default' \
    '-bv+[background value to exclude]:value:_default' \
    '-method.pca.outeigenvalues+[eigenvalues output file]:file:_files' \
    '-method.pca.whiten+[(true/false) whitening]:bool:(true false)' \
    '-method.napca.radiusx+[NA-PCA window X radius (default 1)]:n:_default' \
    '-method.napca.radiusy+[NA-PCA window Y radius (default 1)]:n:_default' \
    '-method.ica.iter+[ICA iterations (default 20)]:n:_default' \
    '-method.ica.mu+[ICA weight increment 0..1 (default 1)]:value:_default' \
    '-method.ica.g+[ICA nonlinearity]:func:(tanh exp u3)' \
    '-ram+[available RAM (MB, default 256)]:mb:_default' \
    '-progress[show progress]' \
    '(- *)-help[show help]' \
    && ret=0

return ret
