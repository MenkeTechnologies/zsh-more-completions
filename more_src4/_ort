#compdef ort
# _ort — OSS Review Toolkit: open-source compliance suite (oss-review-toolkit/ort)
# upstream: https://github.com/oss-review-toolkit/ort
# Subcommands from plugins/commands/*.

_ort() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-c --config)'{-c+,--config=}'[path to the ORT configuration file]:file:_files -g "*.(yaml|yml)"' \
        '--error[set log level to error]' \
        '--warn[set log level to warn (default)]' \
        '--info[set log level to info]' \
        '--debug[set log level to debug]' \
        '--stacktrace[print stack traces for all exceptions]' \
        '*-P+[override a configuration key=value pair]:key=value:' \
        '--help-all[show help for all subcommands]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_ort_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                analyze|advise|scan|evaluate|report|notify)
                    _arguments \
                        '(-i --input-dir)'{-i+,--input-dir=}'[input directory containing the source project]:dir:_files -/' \
                        '(-o --output-dir)'{-o+,--output-dir=}'[directory for analysis output]:dir:_files -/' \
                        '*-f+[output format]:format:(JSON YAML)' && ret=0 ;;
                download)
                    _arguments \
                        '(-o --output-dir)'{-o+,--output-dir=}'[directory for downloaded packages]:dir:_files -/' \
                        '(-i --ort-file)'{-i+,--ort-file=}'[ORT result file]:file:_files' && ret=0 ;;
                compare)
                    _arguments \
                        '1:left ORT result file:_files' \
                        '2:right ORT result file:_files' && ret=0 ;;
                config)
                    _arguments \
                        '1: :(check fetch sources)' \
                        '*:config arg:_files' && ret=0 ;;
                migrate)
                    _arguments \
                        '1: :(directory database)' \
                        '*:migrate arg:_files' && ret=0 ;;
                plugins)
                    _arguments \
                        '1: :(list show)' \
                        '2:plugin type:' && ret=0 ;;
                requirements|upload-curations|upload-result-to-postgres) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_ort_commands] )) ||
_ort_commands() {
    local -a commands
    commands=(
        'analyze:analyze the dependencies of a source project'
        'advise:run vulnerability advisors against an analyzer result'
        'scan:run source-code scanners against analyzer results'
        'evaluate:apply policy rules to scan results'
        'report:render reports from analyzer / scanner / evaluator results'
        'notify:send notifications based on evaluator output'
        'download:download source artifacts referenced by an ORT result'
        'compare:diff two ORT result files'
        'config:check / fetch ORT configuration files'
        'migrate:migrate ORT data files or databases'
        'plugins:list installed ORT plugins'
        'requirements:show external tool / dependency requirements'
        'upload-curations:upload curations to a curations repository'
        'upload-result-to-postgres:upload an ORT result to a Postgres results database'
    )
    _describe -t commands 'ort command' commands
}

_ort "$@"
