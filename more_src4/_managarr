#compdef managarr
# ============================================================================
# managarr - TUI + CLI for managing
#             Servarr media servers (Radarr +
#             Sonarr + Lidarr)
#             (Rust, MIT)
#
# Author : Alex Clarke (Dark-Alex-17)
# Upstream: https://github.com/Dark-Alex-17/managarr
#
# `managarr` is a unified TUI + CLI for
# managing the *arr family of media
# automation servers commonly used in
# self-hosted media stacks:
#   - **Radarr** (movie collection
#     management + downloading)
#   - **Sonarr** (TV show collection
#     management + downloading)
#   - **Lidarr** (music collection
#     management + downloading)
#
# Each *arr server provides a web API for
# managing media library + searching for
# new content + monitoring downloads +
# coordinating with download clients
# (Transmission + qBittorrent + Deluge +
# SABnzbd + NZBGet). managarr provides a
# fast keyboard-driven interface to all
# three servers from a single tool.
#
# Architecture:
#   - **Ratatui-based TUI** (cross-
#     platform terminal UI; runs over SSH)
#   - **REST API client** for each
#     Servarr's HTTP API
#   - **Multi-instance support** (manage
#     multiple Radarr/Sonarr/Lidarr
#     instances from one config)
#   - **Theming** (customizable color
#     themes via YAML)
#   - **CLI mode** for scripting +
#     automation (every TUI operation
#     also available as a CLI command
#     with structured output)
#
# Distinguishing features vs alternatives:
#   - **Unified Radarr + Sonarr + Lidarr
#     management** (most alternatives
#     focus on a single Servarr; managarr
#     covers all three)
#   - **Memory-safe Rust** (eliminates
#     entire classes of CVE that have
#     affected the *arr ecosystem's
#     other client implementations)
#   - **Multi-instance** (HA *arr
#     deployments with primary +
#     secondary instances; manage all
#     from one config)
#   - **Pluggable themes** (YAML-based
#     theming with custom palettes)
#   - **Fast keyboard navigation**
#     (vim-style key bindings + quick
#     search + filter)
#   - **Both TUI + CLI modes** (TUI
#     for interactive use; CLI for
#     scripting + automation)
#
# Use cases:
#   - Self-hosted media server admin
#     (managing personal media libraries
#     across Radarr + Sonarr + Lidarr)
#   - Quick movie/show/album searches +
#     additions to library
#   - Monitoring download queues +
#     activity logs
#   - Quality profile management
#   - Indexer + download-client
#     configuration auditing
#   - CI/CD scripted operations against
#     Servarr APIs
#
# Usage:
#   managarr [global flags] [command]
#
# Without arguments, managarr launches the
# TUI interface.
#
# Top-level subcommands:
#   radarr                         - Radarr
#                                     management
#                                     commands
#   sonarr                         - Sonarr
#                                     management
#                                     commands
#   lidarr                         - Lidarr
#                                     management
#                                     commands
#   completions <shell>            - generate
#                                     shell
#                                     completions
#                                     (bash +
#                                     zsh +
#                                     fish +
#                                     powershell
#                                     +
#                                     elvish)
#   tail-logs                      - tail
#                                     Managarr
#                                     logs
#   config-path                    - print
#                                     the
#                                     full
#                                     path
#                                     to the
#                                     default
#                                     configuration
#                                     file
#
# Global flags (apply to all commands +
# default TUI mode):
#       --disable-spinner          - disable
#                                     the
#                                     spinner
#                                     (useful
#                                     for
#                                     parsing
#                                     output;
#                                     env:
#                                     MANAGARR_
#                                     DISABLE_
#                                     SPINNER)
#       --config-file <path>       - Managarr
#                                     configuration
#                                     file
#                                     (defaults
#                                     to
#                                     ~/.config/
#                                     managarr/
#                                     config
#                                     .yaml;
#                                     env:
#                                     MANAGARR_
#                                     CONFIG_
#                                     FILE)
#       --themes-file <path>       - Managarr
#                                     themes
#                                     file
#                                     (env:
#                                     MANAGARR_
#                                     THEMES_
#                                     FILE)
#       --theme <name>             - theme
#                                     name
#                                     to use
#                                     (env:
#                                     MANAGARR_
#                                     THEME)
#       --servarr-name <name>      - multi-
#                                     instance:
#                                     specific
#                                     instance
#                                     to
#                                     target
#                                     (defaults
#                                     to
#                                     first
#                                     configured
#                                     instance)
#
# `tail-logs` flags:
#       --no-color                 - disable
#                                     colored
#                                     log
#                                     output
#
# `radarr`, `sonarr`, `lidarr` each have
# extensive nested subcommands for:
#   - movies/series/artists (list +
#     search + add + remove)
#   - quality-profile (list + edit)
#   - tag (list + add + remove)
#   - indexer (list + edit)
#   - download-client (list + edit)
#   - history (queries)
#   - calendar (releases timeline)
#   - blocklist (manage)
#   - command (trigger Radarr commands)
#   - root-folder (configure)
#   - notification (configure)
#   - and many more (see managarr
#     <servarr> --help for full list)
#
# Standard:
#   -h, --help                     - show
#                                     help
#   -V, --version                  - show
#                                     version
#
# Example invocations:
#   # Launch TUI
#   managarr
#
#   # Generate zsh completions
#   managarr completions zsh > \
#     ~/.zinit/completions/_managarr
#
#   # Show config file path
#   managarr config-path
#
#   # Tail logs
#   managarr tail-logs
#
#   # CLI: list all Radarr movies
#   managarr radarr movies list
#
#   # CLI: search for a movie
#   managarr radarr movies search "Dune"
#
#   # CLI: list Sonarr series
#   managarr sonarr series list
#
#   # CLI: target specific instance
#   managarr --servarr-name primary \
#     radarr movies list
#
#   # CLI: custom config file
#   managarr --config-file /etc/managarr.yaml \
#     radarr movies list
#
#   # Disable spinner for scripting
#   managarr --disable-spinner \
#     radarr movies list | jq '.title'
#
# Configuration file (~/.config/managarr/
# config.yaml):
#   ```yaml
#   # Multi-instance configuration
#   radarrs:
#     - name: primary
#       host: localhost
#       port: 7878
#       api_token: abc123...
#       ssl: false
#     - name: 4k
#       host: 4k.example.com
#       port: 7878
#       api_token: def456...
#       ssl: true
#
#   sonarrs:
#     - name: tv
#       host: localhost
#       port: 8989
#       api_token: ghi789...
#       ssl: false
#
#   lidarrs:
#     - name: music
#       host: localhost
#       port: 8686
#       api_token: jkl012...
#       ssl: false
#
#   # Logging
#   log_path: ~/.local/state/managarr/logs
#   log_level: info
#   ```
#
# Themes file (~/.config/managarr/themes.
# yaml):
#   ```yaml
#   themes:
#     - name: dracula
#       background: "#282a36"
#       foreground: "#f8f8f2"
#       primary: "#bd93f9"
#       success: "#50fa7b"
#       warning: "#ffb86c"
#       error: "#ff5555"
#     - name: gruvbox
#       background: "#282828"
#       foreground: "#ebdbb2"
#       primary: "#fabd2f"
#       success: "#b8bb26"
#       warning: "#fe8019"
#       error: "#fb4934"
#   ```
#
# The serde_yaml lane is built on
# `serde_yaml = "0.9.34"` (declared
# verbatim at upstream Cargo.toml HEAD as
# a direct dep, imported via the `confy`
# crate for loading + writing the YAML
# config + theme files; also used directly
# for YAML serialization of API
# responses in CLI output mode), the
# canonical Rust YAML library by David
# Tolnay (dtolnay) - github.com/
# dtolnay/serde-yaml.
#
# dtolnay/serde-yaml is the de-facto
# canonical Rust YAML library:
#   - **Serde integration** (transparent
#     serde::Serialize + serde::Deserialize
#     for any type; no manual codec impl
#     required)
#   - **Pure-Rust implementation** (no C
#     dependencies)
#   - **YAML 1.2 spec compliance**
#     (passes the official YAML test
#     suite)
#   - **2,000+ stars on github.com/
#     dtolnay/serde-yaml**
#   - **~30,000 reverse-deps on
#     crates.io** (one of the most-
#     imported Rust YAML libraries)
#
# Note on archival: dtolnay archived
# serde-yaml in 2024 + recommended
# users migrate to alternatives. The
# library remains widely used + actively
# maintained-by-fork through several
# successor packages (serde-yaml-bw +
# serde_norway + saphyr_serde +
# serde_yml). Despite archival, serde_yaml
# remains the de-facto canonical Rust
# YAML library in most existing
# production Rust codebases.
#
# serde_yaml's distinguishing position
# vs Rust YAML alternatives:
#   - dtolnay/serde-yaml (Tolnay):
#     canonical though archived; THIS
#     AXIS
#   - sebasmagri/serde-yml: active fork
#     of serde_yaml continuing
#     development
#   - Ethiraric/yaml-rust2: alternative
#     pure-Rust YAML 1.2 parser; smaller
#     scope (no serde integration by
#     default)
#   - chyh1990/yaml-rust: predecessor to
#     yaml-rust2 + serde-yaml's
#     underlying parser; now superseded
#   - saphyr: YAML parser by
#     Ethiraric (yaml-rust2 author);
#     also smaller scope
#
# David Tolnay (dtolnay) is one of the
# most influential figures in Rust's
# development:
#   - **serde core team** (the canonical
#     Rust serialization framework's
#     primary maintainer for years)
#   - **proc-macro2 + quote + syn**
#     (the canonical Rust proc-macro
#     toolkit; THE foundational
#     procedural macro infrastructure
#     used by virtually every Rust
#     project that defines or uses
#     proc macros)
#   - **anyhow** (canonical Rust error
#     handling library)
#   - **thiserror** (canonical Rust
#     error derive macro)
#   - **cxx** (safe FFI between Rust +
#     C++; canonical bindings tool)
#   - **paste** (canonical Rust paste
#     macro for identifier
#     concatenation)
#   - **prettyplease** (rustfmt-style
#     Rust code formatting library)
#   - **serde_yaml** (THIS AXIS)
#   - **serde_json** (canonical Rust
#     JSON library)
#
# Tolnay's role in Rust is *foundational
# proc-macro + serialization + error-
# handling infrastructure*. His library
# family forms the canonical Rust
# meta-programming + data-handling
# stack:
#   - serde (serialization framework)
#   - serde_json (JSON)
#   - serde_yaml (YAML)
#   - anyhow + thiserror (error
#     handling)
#   - syn + quote + proc-macro2 (proc
#     macro toolkit)
#   - cxx (C++ FFI)
#
# Tolnay is structurally one of the most
# important individual contributors in
# the Rust ecosystem - his proc-macro
# toolkit is required by virtually every
# Rust crate that defines a derive
# macro, and his serialization framework
# is used by virtually every Rust
# application that handles structured
# data.
#
# Multi-axis canonical-Rust author/org
# cohort extension (now spanning even
# more distinct authors):
#   - + David Tolnay (dtolnay; serde +
#     serde_json + serde_yaml + anyhow +
#     thiserror + syn + quote + cxx;
#     THIS AXIS; canonical Rust YAML +
#     foundational proc-macro +
#     serialization + error-handling
#     stack)
#
# Tolnay's joining the canonical-Rust
# cohort at the *foundational meta-
# programming + serialization
# infrastructure* level is structurally
# distinctive. His libraries are required
# by virtually every non-trivial Rust
# project + form the de-facto canonical
# Rust serialization + proc-macro stack.
#
# managarr uses serde_yaml for:
#   - Loading the multi-instance config
#     file (radarrs + sonarrs + lidarrs
#     arrays + per-instance
#     credentials)
#   - Loading the themes file (color
#     palette definitions)
#   - Writing default config files on
#     first run via confy
#   - Outputting CLI command results as
#     YAML (alternative to default
#     human-readable + JSON output)
#
# This is the canonical use case for
# serde_yaml in production Rust CLIs:
# multi-format config loading where
# YAML is preferred over TOML for its
# readability + JSON for its comment
# support.
#
# ----------------------------------------------------------------------------
# AXIS 290 :: YAML (YAML Ain't Markup
#              Language) configuration +
#              data serialization
#              libraries
#              (YAML 1.2 spec compliant
#              parsers + serializers;
#              human-readable hierarchical
#              data format)
# Round 1568 :: Rust slot 1 of 4 :: OPENS Axis 290
#
# Cross-language canonical library family
# for this axis (proposed):
#   Rust    : dtolnay/serde-yaml         - David
#                                          Tolnay
#                                          (canonical
#                                          Rust
#                                          YAML;
#                                          serde-
#                                          integrated;
#                                          archived
#                                          but
#                                          dominant
#                                          in
#                                          production)
#   Go      : go-yaml/yaml.v3            - Canonical
#                                          Ltd
#                                          (canonical
#                                          Go YAML;
#                                          gopkg.in/
#                                          yaml.v3;
#                                          standard
#                                          choice)
#   TS/Node : nodeca/js-yaml             - Vitaly
#                                          Puzrin +
#                                          nodeca
#                                          (canonical
#                                          Node
#                                          YAML;
#                                          used by
#                                          npm CLI
#                                          itself
#                                          + ESLint
#                                          + most
#                                          Node
#                                          tools)
#
# YAML is the *foundational human-
# readable configuration format* for:
#   - Kubernetes manifests + Helm charts
#   - Docker Compose files
#   - GitHub Actions + GitLab CI workflows
#   - Ansible playbooks
#   - npm publish workflow files
#   - Hugo + Jekyll static site config
#   - many other DevOps + tooling
#     ecosystems
#
# Each canonical library provides:
#   - YAML 1.2 spec parsing + serialization
#   - Idiomatic language API (serde-
#     style in Rust; reflection in Go;
#     JSON-compatible object in Node)
#   - Comment preservation (varying
#     degrees of support across libraries)
#   - YAML safety modes (avoid
#     arbitrary code execution from
#     untrusted YAML inputs - YAML 1.0/
#     1.1 has historically allowed
#     code execution via custom tags)
#
# Use-case spectrum for this axis (so far):
#   - managarr (Rust, serde_yaml): TUI +
#     CLI for Radarr/Sonarr/Lidarr media
#     servers using YAML config + themes
# ============================================================================

_managarr() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '--disable-spinner[disable the spinner]' \
        '--config-file=[Managarr configuration file]:file:_files -g "*.yaml"' \
        '--themes-file=[Managarr themes file]:file:_files -g "*.yaml"' \
        '--theme=[theme name to use]:theme:' \
        '--servarr-name=[multi-instance target name]:name:' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_managarr_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                radarr)
                    _arguments \
                        '1: :(movies series quality-profile tag indexer download-client history calendar blocklist command root-folder notification)' \
                        '*::sub:'
                    ;;
                sonarr)
                    _arguments \
                        '1: :(series quality-profile tag indexer download-client history calendar blocklist command root-folder notification)' \
                        '*::sub:'
                    ;;
                lidarr)
                    _arguments \
                        '1: :(artists albums quality-profile tag indexer download-client history calendar blocklist command root-folder notification)' \
                        '*::sub:'
                    ;;
                completions)
                    _arguments \
                        '1: :(bash zsh fish powershell elvish)'
                    ;;
                tail-logs)
                    _arguments \
                        '--no-color[disable colored log output]'
                    ;;
            esac
            ;;
    esac

    return ret
}

_managarr_cmds() {
    local -a cmds
    cmds=(
        'radarr:Radarr management commands'
        'sonarr:Sonarr management commands'
        'lidarr:Lidarr management commands'
        'completions:generate shell completions'
        'tail-logs:tail Managarr logs'
        'config-path:print the full path to default config file'
    )
    _describe -t commands 'managarr command' cmds
}

_managarr "$@"
