#compdef plotcon
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/plotcon.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# EMBOSS plotcon: plot conservation of a sequence alignment
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequences=[aligned sequence(s)]:alignment USA:_files' \
  '-winsize=[window size for averaging]:size:' \
  '-scorefile=[scoring matrix file]:matrix:_files' \
  '-graph=[graph output format]:format:(x11 png ps cps colourps eps gif pdf hp7470 hp7580 meta data)' \
  '*:alignment USA:_files' && ret=0
return ret
