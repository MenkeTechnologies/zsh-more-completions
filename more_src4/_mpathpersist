#compdef mpathpersist
# Documentation: man mpathpersist(8)
# Source: opensvc/multipath-tools mpathpersist/main.c+main.h (master) — SCSI persistent reservation client (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-v --verbose)'{-v+,--verbose=}'[verbosity level 0-3]:level:(0 1 2 3)' \
    '(-C --clear)'{-C,--clear}'[clear all reservations]' \
    '(-d --device)'{-d+,--device=}'[multipath device]:device:_files' \
    '(-f --batch-file)'{-f+,--batch-file=}'[batch file with commands]:file:_files' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-H --hex)'{-H,--hex}'[hex output]' \
    '(-i -o --in --out)'{-i,--in}'[PR-in command]' \
    '(-i -o --in --out)'{-o,--out}'[PR-out command]' \
    '(-Y --param-alltgpt)'{-Y,--param-alltgpt}'[all-target-ports flag]' \
    '(-Z --param-aptpl)'{-Z,--param-aptpl}'[APTPL flag]' \
    '(-K --param-rk)'{-K+,--param-rk=}'[reservation key (hex)]:key:_default' \
    '(-S --param-sark)'{-S+,--param-sark=}'[service action reservation key (hex)]:key:_default' \
    '(-P --preempt)'{-P,--preempt}'[preempt service action]' \
    '(-A --preempt-abort)'{-A,--preempt-abort}'[preempt-abort service action]' \
    '(-T --prout-type)'{-T+,--prout-type=}'[PR type code (0-8)]:type:(0 1 3 5 6 7 8)' \
    '(-s --read-full-status)'{-s,--read-full-status}'[read full status]' \
    '(-k --read-keys)'{-k,--read-keys}'[read registered keys]' \
    '(-r --read-reservation)'{-r,--read-reservation}'[read current reservation]' \
    '(-G --register)'{-G,--register}'[register a key]' \
    '(-I --register-ignore)'{-I,--register-ignore}'[register ignoring existing key]' \
    '(-L --release)'{-L,--release}'[release reservation]' \
    '(-c --report-capabilities)'{-c,--report-capabilities}'[report capabilities]' \
    '(-R --reserve)'{-R,--reserve}'[reserve]' \
    '(-X --transport-id)'{-X+,--transport-id=}'[transport ID]:tid:_default' \
    '(-l --alloc-length)'{-l+,--alloc-length=}'[allocation length]:length:_default' \
    && ret=0

return ret
