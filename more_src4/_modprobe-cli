#compdef modprobe-cli
# _modprobe-cli — kmod modprobe add or remove modules from Linux kernel CLI alias (kmod team, C); custom argparse
# upstream: https://github.com/kmod-project/kmod

_modprobe-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[load all modules]' \
        '--all[load all modules]' \
        '-r[remove module]' \
        '--remove[remove module]' \
        '--remove-dependencies[remove dependencies]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-D[show dependencies]' \
        '--show-depends[show dependencies]' \
        '-c[show config]' \
        '--showconfig[show config]' \
        '--show-config[show config]' \
        '--show-modversions[show module version]' \
        '-i[ignore install/remove commands]' \
        '--ignore-install[ignore install commands]' \
        '--ignore-remove[ignore remove commands]' \
        '-n[do not commit changes]' \
        '--dry-run[do not commit changes]' \
        '--show[do not commit changes]' \
        '-C+[config file]:file:_files' \
        '--config=+[config file]:file:_files' \
        '-d+[dir]:dir:_files -/' \
        '--dirname=+[dir]:dir:_files -/' \
        '-S+[kernel set]:str:' \
        '--set-version=+[kernel set]:str:' \
        '-b[blacklist]' \
        '--use-blacklist[blacklist]' \
        '-f[force]' \
        '--force[force]' \
        '--force-modversion[force modversion]' \
        '--force-vermagic[force vermagic]' \
        '-l[list modules matching pattern]' \
        '--list[list modules matching pattern]' \
        '-t+[type]:str:' \
        '--type=+[type]:str:' \
        '-s[log to syslog]' \
        '--syslog[log to syslog]' \
        '-w[wait]' \
        '--wait[wait]' \
        '*:modules:'
}

_modprobe-cli "$@"
