#compdef ppmshadow
# Documentation: man ppmshadow (Netpbm)
# Source: produce a drop-shadowed version of a PPM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-b+[shadow blur size]:size:' \
    '-k[keep temporary files]' \
    '-t[transparent background]' \
    '-x+[shadow x offset]:xoff:' \
    '-y+[shadow y offset]:yoff:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
