#compdef panctl
# _panctl — control client for pantalaimon (matrix-org/pantalaimon)
# upstream: https://github.com/matrix-org/pantalaimon
# Subcommands from pantalaimon/panctl.py (argparse).

_panctl() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'list-servers:list known servers'
                'help:show help for a subcommand'
                'list-devices:list a user devices'
                'start-verification:start emoji verification with device'
                'cancel-verification:cancel an in-flight verification'
                'accept-verification:accept SAS verification request'
                'confirm-verification:confirm short auth string'
                'verify-device:mark device verified'
                'unverify-device:unmark device verified'
                'blacklist-device:blacklist a device'
                'unblacklist-device:unblacklist a device'
                'import-keys:import megolm keys'
                'export-keys:export megolm keys'
                'send-anyways:send message despite unverified devices'
                'cancel-sending:cancel queued sending'
                'continue-keyshare:continue key share request'
                'cancel-keyshare:cancel key share request'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_panctl "$@"
