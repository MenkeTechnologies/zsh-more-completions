#compdef n98-magerun2 magerun2
# _n98-magerun2 — netz98 n98-magerun2 CLI for Magento 2 administration extending bin/magento with shell-fast cache flush index reindex admin customer media catalog database access GraphQL config and module operations (netz98 team, PHP); Symfony Console
# upstream: https://github.com/netz98/n98-magerun2

_n98-magerun2() {
    local -a sub=(
        'admin:admin operations'
        'cache:cache operations'
        'config:config operations'
        'customer:customer operations'
        'category:category operations'
        'cron:cron operations'
        'db:database operations'
        'dev:development operations'
        'eav:EAV operations'
        'index:index operations'
        'install:install operations'
        'media:media operations'
        'module:module operations'
        'shell:run shell'
        'sys:system operations'
        'storeconfig:store config operations'
        'list:list commands'
        'help:show help'
        'completion:generate shell completion'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n[no interaction]' \
        '--no-interaction[no interaction]' \
        '--root-dir=+[dir]:dir:_files -/' \
        '--skip-config[skip config]' \
        '--skip-root-check[skip root check]' \
        '--skip-magento-compatibility-check[skip mage compat check]' \
        '--skip-core-commands=+[csv]:str:' \
        '--no-developer-mode[no developer mode]' \
        '--ansi[force ansi]' \
        '--no-ansi[disable ansi]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'n98-magerun2 subcommand' sub ;;
        args)
            case $words[1] in
                cache) _arguments \
                    '1:action:(flush clean disable enable list view)' \
                    '*:cache type:' ;;
                admin) _arguments \
                    '1:action:(user create delete list change-password)' \
                    '*:username:' ;;
                module) _arguments \
                    '1:action:(list status disable enable observer rewrite-list)' \
                    '*:module name:' ;;
                index) _arguments \
                    '1:action:(reindex list info status setMode)' \
                    '*:index code:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_n98-magerun2 "$@"
