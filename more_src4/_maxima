#compdef maxima
# Documentation: https://maxima.sourceforge.io/docs/manual/maxima_singlepage.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for maxima - Maxima computer algebra system

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(--very-quiet)--very-quiet[suppress labels and startup message]' \
  '--very-very-quiet[suppress most printed output]' \
  '(-q --quiet)'{-q,--quiet}'[suppress startup message]' \
  '--suppress-input-echo[do not print input expressions]' \
  '(-v --verbose)'{-v,--verbose}'[display lisp invocation]' \
  '(-r --run-string)'{-r+,--run-string=}'[process commands in interactive mode]:expression:' \
  '(-b --batch)'{-b+,--batch=}'[process maxima file in batch mode]:file:_files -g "*.{mac,wxm,dem}"' \
  '--batch-string=[process maxima commands in batch mode]:expression:' \
  '--batch-lisp=[process lisp file in batch mode]:file:_files -g "*.lisp"' \
  '--init=[set base name of initialization files]:base:' \
  '--no-init[skip initialization files]' \
  '--norc[skip initialization files]' \
  '--userdir=[set user directory]:dir:_directories' \
  '(-l --lisp)'{-l+,--lisp=}'[Lisp implementation]:lisp:(sbcl clisp ccl cmucl ecl gcl abcl)' \
  '(-u --use-version)'{-u+,--use-version=}'[use specific maxima version]:version:' \
  '--list-avail[list installed version/lisp combinations]' \
  '(-X --lisp-options)'{-X+,--lisp-options=}'[pass options to underlying Lisp]:options:' \
  '(-p --preload)'{-p+,--preload=}'[preload file before system initialization]:file:_files' \
  '(-s --server)'{-s+,--server=}'[connect to server on port]:port:' \
  '(-d --directories)'{-d,--directories}'[display directory information]' \
  '(-g --enable-lisp-debugger)'{-g,--enable-lisp-debugger}'[enable lisp debugger]' \
  '(-Q --quit-on-error)'{-Q,--quit-on-error}'[exit with code 1 on error]' \
  '--disable-readline[disable readline support]' \
  '--verify-html-index[verify HTML documentation consistency]' \
  '*:file:_files -g "*.{mac,wxm,dem}"' && ret=0

return ret
