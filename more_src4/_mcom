#compdef mcom
# Documentation: https://manpages.debian.org/unstable/mblaze/mcom.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mcom: mblaze mail-composition front end (compose, reply, forward, bounce)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-r[resume editing a draft]' \
  '-send[send message directly without editor]' \
  '-to+[set To header]:address' \
  '-cc+[set Cc header]:address' \
  '-subject+[set Subject header]:subject' \
  '-body+[prepopulate draft from file]:file:_files' \
  '-attach+[attach file]:file:_files' \
  '*:address or file:_files' && ret=0

return ret
