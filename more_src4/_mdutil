#compdef mdutil
# Documentation: https://www.unix.com/man-page/osx/1/mdutil/
# Source: Apple macOS — Spotlight index management for volumes.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-p[flush local caches to network device]' \
    '-E[erase local store for the volume (rebuild if needed)]' \
    '-i[set indexing on / off for volume]:state:(on off)' \
    '-d[disable Spotlight searches on volume]' \
    '-s[show indexing status for listed volumes]' \
    '-a[apply to all volumes]' \
    '-v[verbose output]' \
    '*:volume:_files -W /Volumes' \
    && ret=0

return ret
