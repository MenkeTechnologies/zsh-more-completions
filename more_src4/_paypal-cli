#compdef paypal-cli paypal
# _paypal-cli — PayPal paypal-cli CLI command-line frontend wrapping the PayPal REST API managing payments orders payouts invoices subscriptions plans webhooks disputes customer-disputes vault-tokens billing-agreements identity sandbox-token oauth2-credentials-client-id-secret partnerships-marketplace-platform-merchant-onboarding (PayPal team, Go); cobra
# upstream: https://developer.paypal.com/

_paypal-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'order:order operations'
        'payment:payment operations'
        'payout:payout operations'
        'invoice:invoice operations'
        'subscription:subscription operations'
        'plan:plan operations'
        'webhook:webhook operations'
        'dispute:dispute operations'
        'vault:vault operations'
        'billing-agreement:billing agreement operations'
        'identity:identity operations'
        'sandbox:sandbox operations'
        'partner:partner operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--client-id=+[id]:str:' \
        '--client-secret=+[secret]:str:' \
        '--access-token=+[token]:str:' \
        '--api-url=+[url]:str:' \
        '--environment=+[e]:e:(sandbox live)' \
        '--partner-id=+[id]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'paypal-cli subcommand' sub ;;
        args)
            case $words[1] in
                order|payment|payout|invoice|subscription|plan|webhook|dispute|vault|billing-agreement|partner|identity) _arguments '1:op:(list get create update delete capture refund void cancel approve revise authorize)' '*:id:' ;;
            esac
            ;;
    esac
}

_paypal-cli "$@"
