#compdef pdnssd
# _pdnssd — pdnssd (PowerDNS Service Discovery legacy daemon shipped on some PowerDNS distributions; bridges Bonjour mDNS to PowerDNS Authoritative for hybrid environments; -c config file, -f foreground, -p port, -v verbose, -V version; mostly superseded by avahi)
# upstream: legacy PowerDNS contrib
# Flags inferred from pdnssd src/pdnssd.cc on tip.

_pdnssd() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[config file]:file:_files' \
        '-f[foreground]' \
        '-p+[port]:port:' \
        '-v[verbose]'
}

_pdnssd "$@"
