#compdef metaphlan metaphlan2 metaphlan4
# _metaphlan — Huttenhower Lab Segata Lab metaphlan CLI metagenomic phylogenetic analysis tool profiling taxonomic composition of microbial communities from shotgun sequencing reads through clade-specific marker gene mapping with bowtie2 producing relative abundance trees BIOM Krona compatible (Huttenhower Lab team, Python); argparse
# upstream: https://github.com/biobakery/MetaPhlAn

_metaphlan() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--input_type=+[t]:t:(fastq fasta bowtie2out sam)' \
        '-o+[output file]:file:_files' \
        '--output_file=+[file]:file:_files' \
        '--bowtie2out=+[file]:file:_files' \
        '--samout=+[file]:file:_files' \
        '--legacy-output[legacy output format]' \
        '--CAMI_format_output[CAMI format output]' \
        '--unclassified_estimation[estimate unclassified]' \
        '--bowtie2db=+[dir]:dir:_files -/' \
        '-x+[bowtie2 index]:str:' \
        '--index=+[name]:str:' \
        '--bt2_ps=+[preset]:p:(sensitive very-sensitive sensitive-local very-sensitive-local)' \
        '--bowtie2_exe=+[path]:file:_files' \
        '--read_min_len=+[N]:n:' \
        '--min_alignment_len=+[N]:n:' \
        '--avoid_disqm[disable quasi-marker filtering]' \
        '--add_viruses[include viruses]' \
        '--ignore_eukaryotes[ignore eukaryotes]' \
        '--ignore_bacteria[ignore bacteria]' \
        '--ignore_archaea[ignore archaea]' \
        '--stat_q=+[N]:n:' \
        '--perc_nonzero=+[N]:n:' \
        '--ignore_markers=+[file]:file:_files' \
        '--avoid_disqm[avoid quasi-marker disqualification]' \
        '--stat=+[s]:s:(avg_g avg_l tavg_g tavg_l wavg_g wavg_l med)' \
        '-t+[analysis type]:t:(rel_ab rel_ab_w_read_stats reads_map clade_profiles marker_ab_table marker_pres_table marker_counts clade_specific_strain_tracker)' \
        '--nreads=+[N]:n:' \
        '--pres_th=+[N]:n:' \
        '--clade=+[clade]:str:' \
        '--min_ab=+[N]:n:' \
        '--no_map[skip mapping]' \
        '--tmp_dir=+[dir]:dir:_files -/' \
        '--mpa3[use mpa3 markers]' \
        '--mpa4[use mpa4 markers]' \
        '--nproc=+[N]:n:' \
        '--biom=+[file]:file:_files' \
        '--mdelim=+[d]:str:' \
        '--sample_id_key=+[k]:str:' \
        '--sample_id=+[id]:str:' \
        '*:input file:_files -g "*.fq *.fastq *.fa *.fasta *.sam *.bz2 *.gz"'
}

_metaphlan "$@"
