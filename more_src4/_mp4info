#compdef mp4info mp4-info mp4file-info
# _mp4info — MPEG4IP MP4v2 mp4info MP4 container inspection tool reporting tracks codec params duration ISO/IEC 14496-12 metadata (mp4v2 team, C); getopt
# upstream: https://github.com/enzo1982/mp4v2

_mp4info() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '-V[show version]' \
        '--version[show version]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-r[show raw atoms]' \
        '--raw[show raw atoms]' \
        '-t[show tracks]' \
        '--tracks[show tracks]' \
        '-T+[track ID]:n:' \
        '--track-id=+[track ID]:n:' \
        '-3+[ID3 version]:v:(1 2 2.3 2.4)' \
        '--id3=+[ID3 version]:v:(1 2 2.3 2.4)' \
        '-c[show chapters]' \
        '--chapters[show chapters]' \
        '-i[show ISO atoms]' \
        '--iso[show ISO atoms]' \
        '-s[show stsd]' \
        '--stsd[show stsd]' \
        '-x[show iTunes metadata]' \
        '--itunes[show iTunes metadata]' \
        '--list-track-types[list track types]' \
        '-A+[atom name]:str:' \
        '--atom=+[atom name]:str:' \
        '*:mp4 file:_files -g "*.mp4 *.m4a *.m4b *.m4v *.m4p *.3gp *.mov"'
}

_mp4info "$@"
