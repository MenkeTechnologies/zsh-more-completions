#compdef pcp-slabinfo
# _pcp-slabinfo — PCP-based /proc/slabinfo report (performancecopilot/pcp)
# upstream: https://github.com/performancecopilot/pcp
# Flags from src/pcp/slabinfo/pcp-slabinfo.1 SYNOPSIS.

_pcp-slabinfo() {
    _arguments \
        '-a+[PCP archive folio]:archive:_files' \
        '-s+[samples to collect]:n:' \
        '-Z+[timezone]:tz:'
}

_pcp-slabinfo "$@"
