#compdef mount_umap
# Documentation: man mount_umap(8)
# Source: netbsd/src sbin/mount_umap — uid/gid remapping file system layer (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-i+[filesystem ID instead of random]:fsid:_default' \
    '-o+[mount options (comma-separated, see mount(8))]:options:_default' \
    '-g+[group ID mapping file (required)]:gid-mapfile:_files' \
    '-u+[user ID mapping file (required)]:uid-mapfile:_files' \
    '1:target (subtree location):_files -/' \
    '2:mount point:_files -/' \
    && ret=0

return ret
