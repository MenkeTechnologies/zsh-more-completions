#compdef maas-rack-controller maas-rackd
# Documentation: https://github.com/maas/maas/blob/master/src/provisioningserver/__main__.py
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# maas-rack-controller: MAAS rack controller CLI
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'register:register this rack controller with a region'
  'install-shared-secret:install shared secret for region-rack auth'
  'config:show or set rack cluster configuration'
  'observe-arp:observe ARP traffic'
  'observe-beacons:observe MAAS beacon traffic'
  'observe-mdns:observe mDNS traffic'
  'scan-network:scan network for hosts'
  'setup-dns:set up DNS'
  'get-named-conf:get named.conf'
  'edit-named-options:edit named options'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'rack-controller command' commands && ret=0 ;;
esac
return ret
