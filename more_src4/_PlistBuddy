#compdef PlistBuddy
# Documentation: https://www.manpagez.com/man/8/PlistBuddy/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above (PLISTBUDDY(8) Apple manpage).
# Source: https://github.com/scriptingosx/mac-zsh-completions/blob/4ed520880b3a9e765524b2bdf7a043465f167ad0/completions/_PlistBuddy
# Repository: scriptingosx/mac-zsh-completions (completions/_PlistBuddy)

_PlistBuddy() {
	_arguments \
	    "-c[execute command and exit]:command:" \
		"-x[output will be in the form of an XML plist where appropriate]" \
		"-l[do not follow symlinks in the file path]" \
		"-h[print the complete help info, with command guide]" \
		"*:filename:_files"
}

_PlistBuddy "$@"
