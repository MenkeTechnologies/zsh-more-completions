#compdef mythtv-setup
# Documentation: https://github.com/MythTV/mythtv/blob/master/mythtv/programs/mythtv-setup/mythtv-setup_commandlineparser.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above; shared flags come from the
# MythCommandLineParser base class.

# mythtv-setup: MythTV backend configuration tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help,--usage}'[show help]' \
  '(- *)--version[show version]' \
  '(-nw --no-windowed)'{-nw,--no-windowed}'[do not run in window]' \
  '(-w --windowed)'{-w,--windowed}'[force windowed]' \
  '--mouse-cursor[force mouse cursor visible]' \
  '--no-mouse-cursor[force mouse cursor hidden]' \
  '-geometry[window WxH+X+Y]:geom:' \
  '--geometry=[window WxH+X+Y]:geom:' \
  '-display[QPA X11 connection name]:display:' \
  '--display=[QPA X11 connection name]:display:' \
  '-platform[Qt QPA platform]:platform:' \
  '--platform=[Qt QPA platform]:platform:' \
  '(-v --verbose)'{-v,--verbose=}'[log filtering]:level:' \
  '--logpath=[log to file]:dir:_files -/' \
  '(-q --quiet)'{-q,--quiet}'[reduce logging (-q -q for silent)]' \
  '--loglong[long log format]' \
  '--loglevel=[logging level]:level:(emerg alert crit err warning notice info debug trace)' \
  '--syslog=[syslog facility]:facility:' \
  '--expert[expert mode]' \
  '--scan[run channel scan]' \
  '--scan-list[list channel scans]' \
  '--scan-save-only[save scan only]' \
  '--scan-non-interactive[non-interactive scan]' \
  '--scan-import[import scan]' \
  '--freq-std=[frequency standard]:std:(atsc dvbc dvbt dvbs)' \
  '--modulation=[modulation]:mod:(vsb8 qam256 qam64)' \
  '--region=[region]:region:(us)' \
  '--input-name=[input name]:name:' \
  '--FTAonly[only import Free To Air channels]' \
  '--add-full-ts[add full TS]' \
  '--service-type=[service type]:type:(all tv radio data)' && ret=0
return ret
