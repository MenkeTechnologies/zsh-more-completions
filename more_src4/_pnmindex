#compdef pnmindex
# Documentation: man pnmindex (Netpbm)
# Source: build an index PPM of small versions of multiple Netpbm images.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-size=[thumbnail size in pixels]:n:' \
    '-across=[number of images per row]:n:' \
    '-black[use black background]' \
    '-title=[index title]:title:' \
    '(-quant -noquant)-quant[quantise colors]' \
    '(-quant -noquant)-noquant[no color quantisation]' \
    '-colors=[number of colors when quantising]:n:' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
