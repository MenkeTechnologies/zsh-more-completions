#compdef mrcentroid
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/mrcentroid.html
# Source: MRtrix3/mrtrix3 cmd/mrcentroid.cpp — compute centre of mass of an image (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-mask+[mask image to restrict calculation]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-voxelspace[report centre of mass in voxel space, not scanner]' \
    '1:input image:_files -g "*.{nii,nii.gz,mif}"' \
    && ret=0

return ret
