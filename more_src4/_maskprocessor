#compdef maskprocessor mp64
# _maskprocessor — Jens Atom Steube hashcat maskprocessor high-performance word generator with per-position rules for password masks (hashcat team, C); custom argparse
# upstream: https://github.com/hashcat/maskprocessor

_maskprocessor() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-1+[custom charset 1]:str:' \
        '--custom-charset1=+[custom charset 1]:str:' \
        '-2+[custom charset 2]:str:' \
        '--custom-charset2=+[custom charset 2]:str:' \
        '-3+[custom charset 3]:str:' \
        '--custom-charset3=+[custom charset 3]:str:' \
        '-4+[custom charset 4]:str:' \
        '--custom-charset4=+[custom charset 4]:str:' \
        '-i+[start position]:str:' \
        '--increment=+[start position]:str:' \
        '--increment-min=+[min]:n:' \
        '--increment-max=+[max]:n:' \
        '-o+[output file]:file:_files' \
        '--output-file=+[output file]:file:_files' \
        '-r+[seq max]:n:' \
        '--seq-max=+[seq max]:n:' \
        '-s+[start word]:str:' \
        '--start-at=+[start word]:str:' \
        '-l+[stop word]:str:' \
        '--stop-at=+[stop word]:str:' \
        '-c[print combinations]' \
        '--combinations[print combinations]' \
        '-q+[seq max queue]:n:' \
        '--seq-max-queue=+[seq max queue]:n:' \
        '*:mask:'
}

_maskprocessor "$@"
