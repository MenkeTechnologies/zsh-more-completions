#compdef polkit-mate polkit-mate-authentication-agent-1
# Documentation: https://raw.githubusercontent.com/mate-desktop/mate-polkit/master/src/main.c
# Reference accessed: 2026-05-16
# Verified: upstream mate-desktop/mate-polkit src/main.c. main() only
# invokes gtk_init(&argc, &argv); no GOptionEntry table, no app-specific
# flags. Honored args are standard GTK options (--display, --gtk-debug,
# etc.) via GTK init.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# polkit-mate: MATE Polkit authentication agent (GTK-only flags)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--display=[X display to use]:display:' \
  '--gtk-debug=[GTK debug flags]:flags:' \
  '--gtk-no-debug=[disable GTK debug flags]:flags:' \
  '--g-fatal-warnings[fatal G_LOG warnings]' \
  '--class=[program class as used by window manager]:class:' \
  '--name=[program name as used by window manager]:name:' && ret=0
return ret
