#compdef polkitd
# _polkitd — polkit polkitd daemon (system-bus authorization decision daemon backing pkexec, pkcheck and graphical agents; --version show version, --no-debug suppress debug logs, --replace replace running instance, --help show usage; reads /etc/polkit-1/rules.d/*.rules + /usr/share/polkit-1/actions/*.policy)
# upstream: https://github.com/polkit-org/polkit
# Flags from polkit-org/polkit src/polkitd/main.c on tip.

_polkitd() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--no-debug[no debug]' \
        '--replace[replace running instance]'
}

_polkitd "$@"
