#compdef pdns-control pdns_control
# Documentation: https://doc.powerdns.com/authoritative/manpages/pdns_control.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pdns_control: control running PowerDNS authoritative server
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'bind-add-zone:add BIND zone'
  'bind-domain-extended-status:extended BIND domain status'
  'bind-domain-status:BIND domain status'
  'bind-list-rejects:list BIND rejects'
  'bind-reload-now:reload BIND zone'
  'ccounts:show cache counts'
  'current-config:show current config'
  'cycle:cycle backend'
  'list:list zones'
  'list-zones:list zones with filter'
  'notify:send NOTIFY for zone'
  'notify-host:send NOTIFY to host'
  'ping:ping server'
  'rping:remote ping'
  'purge:purge cache'
  'qtypes:show query type stats'
  'quit:quit server'
  'rediscover:rediscover zones'
  'reload:reload server'
  'remotes:show recent remotes'
  'respsizes:response size stats'
  'retrieve:retrieve zone'
  'set:set config var'
  'show:show variable'
  'status:show status'
  'token-login:token login'
  'uptime:show uptime'
  'version:show version'
)
_arguments -C \
  '--help[show help]' \
  '--chroot=[chroot directory]:dir:_files -/' \
  '--config-dir=[config directory]:dir:_files -/' \
  '--config-name=[virtual configuration name]:name:' \
  '--remote-address=[remote address to query]:addr:' \
  '--remote-port=[remote port to query]:port:' \
  '--secret=[secret for remote connection]:secret:' \
  '--socket-dir=[controlsocket directory]:dir:_files -/' \
  '1: :->cmd' \
  '*::arg:_files' && ret=0
case $state in
  cmd) _describe -t commands 'pdns_control command' commands && ret=0 ;;
esac
return ret
