#compdef makemkvcon
# Zsh completion for MakeMKV command-line tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->commands' \
  '-r[enable robot (automation) mode]' \
  '--minlength=[set minimum title length in seconds]:seconds:' \
  '--messages=[output file for messages]:file:_files' \
  '--progress=[output file for progress]:file:_files' \
  '--directio=[enable direct disc access]:bool:(true false)' \
  '--noscan[do not scan for disc insert/removal]' \
  '--decrypt[decrypt stream files during backup]' \
  '--cache=[set read cache size in megabytes]:megabytes:' \
  '*:argument:' && ret=0

case $state in
  (commands)
    local -a cmds=(
      'info:display information about a disc'
      'mkv:rip selected title to MKV file'
      'backup:perform disc backup'
      'stream:stream disc content via local web server'
      'robot:enable robot mode and wait for commands'
    )
    _describe -t commands 'makemkvcon command' cmds && ret=0
    ;;
esac

return ret
