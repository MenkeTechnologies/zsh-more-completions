#compdef pure-ftpd-init
# Documentation: https://www.pureftpd.org/project/pure-ftpd/doc/README/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# pure-ftpd-init is a SysV-style init script for pure-ftpd; the accepted
# verbs follow the standard LSB init-script convention.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start pure-ftpd'
  'stop:stop pure-ftpd'
  'restart:restart pure-ftpd'
  'reload:reload configuration'
  'status:show status'
  'condrestart:restart if running'
  'force-reload:force reload'
)

_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'pure-ftpd-init command' commands && ret=0 ;;
esac

return ret
