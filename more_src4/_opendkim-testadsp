#compdef opendkim-testadsp
# Documentation: https://linux.die.net/man/8/opendkim-testadsp
# Reference accessed: 2026-05-20
# Verified: opendkim-testadsp(8) — DKIM filter ADSP evaluation tool.
# Synopsis: opendkim-testadsp domain [...] — no options, only positional
# domain arguments. Removed: fabricated -h/-v/-V flags.

# opendkim-testadsp: probe ADSP record for a domain
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:domain:' && ret=0
return ret
