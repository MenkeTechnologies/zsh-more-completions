#compdef mpot mailpot
# _mpot — mailpot mailing list manager CLI (meli/mailpot)
# upstream: https://github.com/meli/mailpot
# Subcommands from mailpot-cli/src/args.rs (clap).

_mpot() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-d --debug)'{-d,--debug}'[print logs]' \
        '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.toml"' \
        '(-q --quiet)'{-q,--quiet}'[silence all output]' \
        '(-v --verbose)*'{-v,--verbose}'[verbose mode]' \
        '(-t --ts)'{-t+,--ts=}'[debug log timestamp]:granularity:(sec ms ns none)' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'sample-config:print sample config to stdout'
                'dump-database:dump database data to stdout'
                'list-lists:list all registered mailing lists'
                'list:mailing list management'
                'create-list:create a new list'
                'post:post message from stdin to list'
                'flush-queue:flush outgoing email queue'
                'queue:processed-mail queue management'
                'import-maildir:import a maildir into an existing list'
                'update-postfix-config:update postfix maps and master.cf'
                'print-postfix-config:print postfix maps and master.cf entry'
                'accounts:list all accounts'
                'account-info:show account info'
                'add-account:add an account'
                'remove-account:remove an account'
                'update-account:update account info'
                'repair:show / fix data inconsistencies'
                'help:show help'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                sample-config) _arguments '--with-smtp[use SMTP connection]' ;;
                post|flush-queue) _arguments '--dry-run[show result without consuming]' ;;
                queue) _arguments '--queue=[queue name]:queue:(maildrop hold deferred corrupt error)' ;;
                list|account-info|remove-account|update-account|import-maildir) _arguments '1:list id or address:' ;;
            esac
            ;;
    esac
}

_mpot "$@"
