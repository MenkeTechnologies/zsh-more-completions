#compdef pluginkit
# Documentation: macOS man pluginkit(8)
# Source: Apple macOS PlugInKit subsystem manager (Objective-C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-A --all-versions)'{-A,--all-versions}'[match all versions of a plug-in]' \
    '-a[add plug-ins at given file location]' \
    '-e+[election operation]:election:_default' \
    '(-D --duplicates)'{-D,--duplicates}'[show duplicate plug-ins]' \
    '*'{-i+,--identifier=}'[match by identifier]:identifier:_default' \
    {-m,--match}'[matching operation]' \
    '(-P --platform)'{-P+,--platform=}'[platform name]:platform:_default' \
    '(-p --protocol)'{-p+,--protocol=}'[protocol name]:protocol:_default' \
    '-r[remove plug-ins at file location]' \
    '--raw[present pkd replies as raw XML]' \
    '-v[verbose output (stackable)]' \
    '*:file or key=value:_files' \
    && ret=0

return ret
