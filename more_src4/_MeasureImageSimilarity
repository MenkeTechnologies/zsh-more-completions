#compdef MeasureImageSimilarity
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/MeasureImageSimilarity.cxx — image similarity metric (C++, itk parser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-d --dimensionality)'{-d+,--dimensionality=}'[image dimensionality]:n:(2 3 4)' \
    '(-m --metric)'{-m+,--metric=}'[similarity metric (CC/MI/Mattes/MeanSquares/Demons/GC)]:spec:_default' \
    '(-x --masks)'{-x+,--masks=}'[fixed/moving mask images]:spec:_default' \
    '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
    '(- *)'{-v,--verbose}'[verbose]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
