#compdef mopd
# _mopd — OpenBSD mopd (DEC MOP load server; serves Maintenance Operations Protocol load requests over Ethernet for diskless DEC terminal servers; -3/-4 select MOP version 3 or 4)
# upstream: https://github.com/openbsd/src (usr.sbin/mopd)
# Flags from usr.sbin/mopd/mopd/mopd.8 on tip.

_mopd() {
    _arguments \
        '(-4)-3[MOP version 3]' \
        '(-3)-4[MOP version 4]' \
        '-a[listen on all interfaces]' \
        '-d[debug]' \
        '-f[foreground]' \
        '-v[verbose]' \
        '1:interface:_net_interfaces'
}

_mopd "$@"
