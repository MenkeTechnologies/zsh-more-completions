#compdef obminimize
# obminimize — minimize energy of molecular structures

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-n[specify number of steps]:steps:' \
  '-cg[use conjugate gradient algorithm]' \
  '-sd[use steepest descent algorithm]' \
  '-c[set convergence criteria]:criteria:' \
  '-ff[select force field]:force field:(MMFF94 UFF Ghemical GAFF)' \
  '*:input file:_files -g "*.{sdf,mol,mol2,pdb,xyz,smi,cml}"'
