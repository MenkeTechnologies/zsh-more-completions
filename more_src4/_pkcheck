#compdef pkcheck
# _pkcheck — polkit pkcheck (programmatic permission check that asks polkit whether the given subject is authorized to invoke an action; -a action id, -p subject as system-bus-name|unix-process|unix-session, --details key=value, -u allow user interaction, --enable-internal-agent enable internal agent, --version, --help)
# upstream: https://github.com/polkit-org/polkit
# Flags from polkit-org/polkit src/programs/pkcheck.c on tip.

_pkcheck() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-a+[action id]:action:' \
        '--action-id+[action id]:action:' \
        '-p+[subject spec]:subject:' \
        '--process+[subject spec]:subject:' \
        '*--detail+[key value]:key=value:' \
        '-u[allow user interaction]' \
        '--allow-user-interaction[allow user interaction]' \
        '--enable-internal-agent[enable internal agent]' \
        '-s[show details]'
}

_pkcheck "$@"
