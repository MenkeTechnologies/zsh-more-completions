#compdef pepwindow
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/pepwindow.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# EMBOSS pepwindow: plot hydropathy profile of a protein
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[protein sequence(s)]:protein USA:_files' \
  '-datafile=[AAINDEX entry data file]:file:_files' \
  '-window=[window size (residues), default 19]:size:' \
  '-normalize[normalize data values]' \
  '-graph=[graph output format]:format:(x11 png ps cps colourps eps gif pdf svg hp7470 hp7580 meta data none tek tekt xterm text)' \
  '*:protein USA:_files' && ret=0
return ret
