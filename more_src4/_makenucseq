#compdef makenucseq
# Documentation: https://emboss.sourceforge.net/apps/cvs/emboss/apps/makenucseq.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# EMBOSS makenucseq: create random nucleotide sequence(s)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-auto[turn off prompts]' \
  '-stdout[write to stdout]' \
  '-filter[read stdin, write stdout]' \
  '-options[prompt for all values]' \
  '-debug[write debug output]' \
  '-verbose[report command options]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-die[report dying messages]' \
  '-version[show version]' \
  '-codonfile=[codon usage input file]:file:_files' \
  '-amount=[number of sequences to generate]:n:' \
  '-length=[length of each sequence]:length:' \
  '-useinsert[enable sequence insertion]' \
  '-insert=[string to insert]:seq:' \
  '-start=[insert start position]:pos:' \
  '-outseq=[output sequence file]:file:_files' \
  '-osformat=[output sequence format]:format:(fasta embl genbank gff swiss raw)' \
  '*:output:_files' && ret=0
return ret
