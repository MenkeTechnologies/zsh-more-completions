#compdef mdbook-listings
# _mdbook-listings — managed code listings (callouts/freezes/verify) for mdbook (padamson/mdbook-listings)
# upstream: https://github.com/padamson/mdbook-listings
# Subcommands & flags from src/main.rs (clap).

_mdbook-listings() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'supports:check whether a renderer is supported'
                'install:install assets and register in book.toml'
                'freeze:freeze a source file into the listings dir'
                'verify:verify manifest ↔ frozen listings ↔ includes'
                'list:list frozen listings from listings.toml'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                supports) _arguments '1:renderer:(html epub markdown)' ;;
                install) _arguments '--book-root=[book root dir]:dir:_files -/' ;;
                freeze)
                    _arguments \
                        '--tag=[unique tag for frozen filename]:tag:' \
                        '--book-root=[book root dir]:dir:_files -/' \
                        '--force[overwrite existing frozen copy]' \
                        '1:source file:_files'
                    ;;
                verify|list) _arguments '--book-root=[book root dir]:dir:_files -/' ;;
            esac
            ;;
    esac
}

_mdbook-listings "$@"
