#compdef mailtrap
# _mailtrap — CLI for the Mailtrap email platform (mailtrap/mailtrap-cli)
# upstream: https://github.com/mailtrap/mailtrap-cli
# Subcommands + flags from cmd/root.go (cobra).

_mailtrap() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--api-token=[Mailtrap API token (env: MAILTRAP_API_TOKEN)]:token:' \
        '--account-id=[Mailtrap account ID (env: MAILTRAP_ACCOUNT_ID)]:id:' \
        '(-o --output)'{-o+,--output=}'[output format]:format:(json table text)' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_mailtrap_commands' \
        '*::arg:->args' && ret=0

    return ret
}

(( $+functions[_mailtrap_commands] )) ||
_mailtrap_commands() {
    local -a commands
    commands=(
        'configure:configure the Mailtrap CLI'
        'send:send an email through Mailtrap (production)'
        'sandbox-send:send an email through a Mailtrap sandbox'
        'domains:manage sending domains'
        'suppressions:manage suppressions'
        'stats:show sending stats'
        'templates:manage email templates'
        'email-logs:query email logs'
        'webhooks:manage webhooks'
        'projects:manage sandbox projects'
        'sandboxes:manage sandboxes'
        'messages:read sandbox messages'
        'attachments:read sandbox message attachments'
        'contacts:manage promotional contacts'
        'contact-lists:manage contact lists'
        'contact-fields:manage contact fields'
        'accounts:list / inspect accounts'
        'account-access:manage account access roles'
        'permissions:manage permissions'
        'tokens:manage API tokens'
        'billing:show billing data'
        'organizations:manage organizations'
    )
    _describe -t commands 'mailtrap command' commands
}

_mailtrap "$@"
