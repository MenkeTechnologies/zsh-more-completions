#compdef ovsdb-dot
# _ovsdb-dot — Open vSwitch ovsdb-dot generate Graphviz .dot file from an OVSDB schema for entity-relationship visualization (openvswitch team, Python); argparse
# upstream: https://github.com/openvswitch/ovs

_ovsdb-dot() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-l[print links]' \
        '--no-arrows[do not draw arrows]' \
        '*:schema:_files -g "*.ovsschema *.json"'
}

_ovsdb-dot "$@"
