#compdef memos
# Documentation: https://github.com/themagiulio/memos-cli
# Source: themagiulio/memos-cli — Python CLI for self-hosted Memos servers.
# Reference accessed: 2026-06-02
# Config stored at $HOME/.memos.json. Archived 2024-04-27 (no longer maintained).

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _memos_cmds
_memos_cmds=(
    'auth:authentication (signin)'
    'list:list your memos'
    'new:create a new memo'
    'help:show help'
)

local -a _memos_auth
_memos_auth=(
    'signin:sign in to your account'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'memos command' _memos_cmds && ret=0
        ;;
    args)
        case $line[1] in
            auth)
                _arguments -s -S \
                    '1:subcommand:->auth-sub' && ret=0
                case $state in
                    auth-sub) _describe -t auth 'auth subcommand' _memos_auth && ret=0 ;;
                esac
                ;;
        esac
        ;;
esac

return ret
