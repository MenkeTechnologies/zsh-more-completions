#compdef puppetserver
# Documentation: https://github.com/puppetlabs/puppetserver
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a subcommands=(
      'ca:certificate authority management'
      'gem:manage gems used by Puppet Server'
      'ruby:run ruby interpreter'
      'irb:interactive ruby shell'
      'foreground:start Puppet Server in the foreground'
      'start:start Puppet Server'
      'stop:stop Puppet Server'
      'restart:restart Puppet Server'
      'reload:reload Puppet Server configuration'
      'status:show Puppet Server status'
      'version:show version information'
      'help:show help'
    )
    _describe -t commands 'puppetserver subcommand' subcommands && ret=0
    ;;
  args)
    case ${words[1]} in
      ca)
        local -a ca_subcommands=(
          'list:list certificates'
          'sign:sign a certificate request'
          'revoke:revoke a certificate'
          'clean:clean certificate information'
          'generate:generate a new certificate'
          'setup:set up the CA'
          'import:import a CA certificate and CRL'
          'enable:enable the CA service'
          'migrate:migrate the CA'
        )
        _arguments -C \
          '1: :->ca_cmd' \
          '*:: :->ca_args' && ret=0
        case $state in
          ca_cmd)
            _describe -t commands 'ca subcommand' ca_subcommands && ret=0
            ;;
          ca_args)
            case ${words[1]} in
              list)
                _arguments \
                  '--all[list all certificates]' \
                  '--certname[filter by certname]:certname' \
                  '--help[show help]' && ret=0
                ;;
              sign)
                _arguments \
                  '--certname[certificate name to sign]:certname' \
                  '--all[sign all pending requests]' \
                  '--help[show help]' && ret=0
                ;;
              revoke)
                _arguments \
                  '--certname[certificate name to revoke]:certname' \
                  '--help[show help]' && ret=0
                ;;
              clean)
                _arguments \
                  '--certname[certificate name to clean]:certname' \
                  '--help[show help]' && ret=0
                ;;
              generate)
                _arguments \
                  '--certname[certificate name to generate]:certname' \
                  '--ca-client[generate a CA client certificate]' \
                  '--help[show help]' && ret=0
                ;;
              *)
                _arguments \
                  '--help[show help]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      gem)
        _arguments \
          '*:gem arguments:_default' && ret=0
        ;;
      ruby)
        _arguments \
          '*:ruby arguments:_default' && ret=0
        ;;
      *)
        _arguments \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
