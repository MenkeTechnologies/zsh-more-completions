#compdef pinky
# Documentation: man pinky(1) (GNU coreutils)
# Source: GNU coreutils pinky — lightweight finger; print user information.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-s -f -w -i -q)-l[long format output]' \
    '-b[omit home directory and shell (long format)]' \
    '-h[omit project file (long format)]' \
    '-p[omit plan file (long format)]' \
    '(-l)-s[short format (default)]' \
    '(-l)-f[omit column headings (short format)]' \
    '(-l)-w[omit full name (short format)]' \
    '(-l)-i[omit full name and remote host (short format)]' \
    '(-l)-q[omit name, remote host and idle time (short format)]' \
    '--lookup[canonicalize hostnames via DNS]' \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '*:user:_users' \
    && ret=0

return ret
