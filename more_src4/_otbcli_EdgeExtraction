#compdef otbcli_EdgeExtraction
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_EdgeExtraction.html
# Source: orfeotoolbox/OTB EdgeExtraction — gradient / Sobel / Touzi edge filters.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-in+[input image]:image:_files' \
    '-out+[output edge image]:image:_files' \
    '-channel+[channel index (default 1)]:n:_default' \
    '-filter+[edge detector]:filter:(gradient sobel touzi)' \
    '-filter.touzi.xradius+[Touzi horizontal radius (default 1)]:n:_default' \
    '-filter.touzi.yradius+[Touzi vertical radius (default 1)]:n:_default' \
    '-ram+[available RAM (MB, default 256)]:mb:_default' \
    '-progress[show progress]' \
    '(- *)-help[show help]' \
    && ret=0

return ret
