#compdef openshot
# Documentation: https://github.com/OpenShot/openshot-qt/blob/develop/src/launch.py
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[enable debug logging to console and file]' \
  '--debug-file[debug logging to log file only]' \
  '--debug-console[debug logging to console only]' \
  '(-l --lang)'{-l+,--lang=}'[set UI language code]:lang:' \
  '--list-languages[list supported language codes]' \
  '*--path=[add module search path]:dir:_files -/' \
  '--test-models[enable QAbstractItemModelTester]' \
  '*:project file:_files -g "*.osp"' && ret=0

return ret
