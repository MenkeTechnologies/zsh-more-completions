#compdef pmset
# _pmset-bin — macOS power management settings (Apple); read + modify system power preferences
# upstream: macOS

_pmset-bin() {
    _arguments \
        '-a[apply to all power sources]' \
        '-b[apply to battery]' \
        '-c[apply to AC power]' \
        '-u[apply to UPS]' \
        '-g[print current settings]' \
        '-A[print active assertions]' \
        '-V[verbose mode]' \
        '*:cmd:'
}

_pmset-bin "$@"
