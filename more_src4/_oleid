#compdef oleid

_oleid() {
    local curcontext="$curcontext" state line ret=1

    _arguments \
        '(- *)--help[show help message and exit]' \
        '(-i --indicator)'{-i,--indicator}'[display only specified indicator]:indicator:' \
        '--json[output results in JSON format]' \
        '--relaxed[do not raise errors on non-OLE files]' \
        '(-l --log-level)'{-l,--log-level}'[set logging level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
        '*:file:_files' && ret=0

    return ret
}

_oleid "$@"
