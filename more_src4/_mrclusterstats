#compdef mrclusterstats
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/mrclusterstats.html
# Source: MRtrix3/mrtrix3 cmd/mrclusterstats.cpp — voxel-wise GLM with cluster-level inference (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-threshold+[cluster-forming threshold]:value:_default' \
    '-connectivity[use 26-voxel-neighbourhood (default 6)]' \
    '-tfce_dh+[TFCE integration height increment]:value:_default' \
    '-tfce_e+[TFCE extent exponent]:value:_default' \
    '-tfce_h+[TFCE height exponent]:value:_default' \
    '-nshuffles+[number of permutations]:n:_default' \
    '-permutations+[file containing permutations]:file:_files' \
    '-notest[only generate the design output, no statistics]' \
    '-errors+[error type to assume]:type:(ee ise both)' \
    '-exchange_within+[file defining within-block exchangeability]:file:_files' \
    '-exchange_whole+[file defining whole-block exchangeability]:file:_files' \
    '-strong[use strong family-wise control]' \
    '-nonstationarity[compute nonstationary correction]' \
    '-nshuffles_nonstationarity+[shuffles for nonstationarity correction]:n:_default' \
    '-variance+[file containing variance group assignments]:file:_files' \
    '1:input (list of files):_files -g "*.txt"' \
    '2:design matrix:_files' \
    '3:contrast matrix:_files' \
    '4:mask:_files -g "*.{nii,nii.gz,mif}"' \
    '5:output prefix:_default' \
    && ret=0

return ret
