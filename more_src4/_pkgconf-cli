#compdef pkgconf-cli
# _pkgconf-cli — pkgconf modern replacement for pkg-config CLI alias (pkgconf team, C); custom argparse
# upstream: https://github.com/pkgconf/pkgconf

_pkgconf-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--about[about info]' \
        '--cflags[print cflags]' \
        '--cflags-only-I[print -I cflags]' \
        '--cflags-only-other[print other cflags]' \
        '--libs[print libs]' \
        '--libs-only-L[print -L libs]' \
        '--libs-only-l[print -l libs]' \
        '--libs-only-other[print other libs]' \
        '--modversion[show module version]' \
        '--variable=+[name]:str:' \
        '--define-variable=+[name=value]:str:' \
        '--define-prefix[define prefix]' \
        '--dont-define-prefix[do not define prefix]' \
        '--prefix-variable=+[name]:str:' \
        '--exists[check if exists]' \
        '--print-errors[print errors]' \
        '--silence-errors[silence errors]' \
        '--errors-to-stdout[errors to stdout]' \
        '--print-provides[print provided modules]' \
        '--print-requires[print required modules]' \
        '--print-requires-private[print private required modules]' \
        '--print-variables[print all variables]' \
        '--validate[validate file]' \
        '--list-all[list all known packages]' \
        '--list-package-names[list package names]' \
        '--debug[debug]' \
        '--static[static mode]' \
        '--shared[shared mode]' \
        '--short-errors[short errors]' \
        '--uninstalled[allow uninstalled]' \
        '--print-options[show known cmd options]' \
        '--atleast-version=+[version]:str:' \
        '--exact-version=+[version]:str:' \
        '--max-version=+[version]:str:' \
        '--atleast-pkgconfig-version=+[version]:str:' \
        '--with-path=+[path]:dir:_files -/' \
        '--with-system-include-path=+[path]:dir:_files -/' \
        '--with-system-library-path=+[path]:dir:_files -/' \
        '--keep-system-cflags[keep system cflags]' \
        '--keep-system-libs[keep system libs]' \
        '--digraph[print dependency digraph]' \
        '--solution[print solution]' \
        '--simulate[simulate]' \
        '--no-cache[no cache]' \
        '--ignore-conflicts[ignore conflicts]' \
        '--maximum-traverse-depth=+[depth]:n:' \
        '--minimum-version=+[version]:str:' \
        '--no-uninstalled[no uninstalled]' \
        '--pure[pure]' \
        '--env-only[env only]' \
        '--personality=+[name]:str:' \
        '--dump-personality[dump personality]' \
        '--no-provides[no provides]' \
        '*:packages:'
}

_pkgconf-cli "$@"
