#compdef molecule-cli molecule
# _molecule-cli — Red Hat Molecule Ansible role testing framework CLI alias (ansible team, Python); click
# upstream: https://github.com/ansible/molecule

_molecule-cli() {
    local -a sub=(
        'check:check syntax/lint of converge'
        'cleanup:run cleanup playbook'
        'converge:run converge playbook'
        'create:create instances'
        'dependency:install dependencies'
        'destroy:destroy instances'
        'drivers:list drivers'
        'idempotence:run idempotence test'
        'init:init scaffold'
        'init scenario:init scenario'
        'init role:init role'
        'list:list scenarios'
        'login:login to instance'
        'matrix:matrix of test steps'
        'prepare:run prepare playbook'
        'reset:reset state'
        'side-effect:run side-effect'
        'syntax:syntax check'
        'test:run full test sequence'
        'verify:run verifier'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--base-config=+[config file]:file:_files -g "molecule.yml"' \
        '-c+[config file]:file:_files -g "molecule.yml"' \
        '--env-file=+[file]:file:_files' \
        '-e+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'molecule subcommand' sub ;;
        args)
            case $words[1] in
                test|converge|create|destroy|prepare|side-effect|verify|cleanup|reset|check|syntax|idempotence|matrix|list|dependency|login) _arguments \
                    '--scenario-name=+[name]:str:' \
                    '-s+[name]:str:' \
                    '--all[all scenarios]' \
                    '-a[all scenarios]' \
                    '--driver-name=+[driver]:d:(delegated docker podman openstack vagrant ec2)' \
                    '--platform-name=+[platform]:str:' \
                    '-p+[platform]:str:' \
                    '--parallel[parallel]' \
                    '--destroy=+[mode]:m:(always never)' \
                    '--no-destroy[no destroy]' \
                    '--report[report]' \
                    '--shared-state[share state]' \
                    '--vary-shared-state[vary shared state]' ;;
                init:scenario) _arguments \
                    '1:scenario name:' \
                    '--driver-name=+[driver]:d:(delegated docker podman openstack vagrant ec2)' \
                    '-d+[driver]:d:(delegated docker podman openstack vagrant ec2)' \
                    '--role-name=+[role]:str:' \
                    '-r+[role]:str:' ;;
                init:role) _arguments \
                    '1:role name:' \
                    '--driver-name=+[driver]:d:(delegated docker podman openstack vagrant ec2)' \
                    '-d+[driver]:d:(delegated docker podman openstack vagrant ec2)' ;;
            esac
            ;;
    esac
}

_molecule-cli "$@"
