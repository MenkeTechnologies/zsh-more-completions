#compdef modin
# _modin — Modin team modin distributed pandas drop-in replacement using Ray Dask or Unidist backends (modin-project team, Python); argparse
# upstream: https://github.com/modin-project/modin

_modin() {
    local -a sub=(
        'install:install modin'
        'config:show or set configuration'
        'env:show environment info'
        'doctor:run diagnostics'
        'convert:convert file formats'
        'profile:profile pandas operations'
        'shell:python shell preloaded'
        'serve:run modin server'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--engine=+[engine]:e:(ray dask unidist python native)' \
        '--storage-format=+[format]:f:(pandas hdk pyarrow)' \
        '--cpus=+[N]:n:' \
        '--memory=+[bytes]:n:' \
        '--log-level=+[level]:l:(debug info warn error critical)' \
        '--log-file=+[log file]:file:_files' \
        '--no-color[disable color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'modin subcommand' sub ;;
        args)
            case $words[1] in
                config) _arguments '1:config cmd:(get set list reset)' ;;
                convert) _arguments \
                    '--from=+[input format]:f:(csv parquet feather hdf5 json sql)' \
                    '--to=+[output format]:f:(csv parquet feather hdf5 json sql)' \
                    '-o+[output file]:file:_files' \
                    '*:file:_files' ;;
                profile) _arguments \
                    '--operation=+[op]:str:' \
                    '--iterations=+[N]:n:' \
                    '--engine=+[engine]:e:(ray dask unidist python native)' \
                    '*:file:_files' ;;
                serve) _arguments \
                    '--host=+[bind host]:host:_hosts' \
                    '--port=+[port]:port:_ports' \
                    '--workers=+[N]:n:' ;;
            esac
            ;;
    esac
}

_modin "$@"
