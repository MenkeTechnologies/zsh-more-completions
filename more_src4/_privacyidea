#compdef privacyidea privacyidea-cli pi-manage
# _privacyidea — NetKnights privacyidea CLI command-line frontend to the privacyIDEA Open Source enterprise authentication MFA strong authentication backend providing token user realm resolver policy admin event-handler RADIUS LDAP TOTP HOTP YubiKey Webauthn Push PaperToken SAML OIDC operations (NetKnights team, Python); click
# upstream: https://www.privacyidea.org/

_privacyidea() {
    local -a sub=(
        'token:token management'
        'user:user management'
        'realm:realm management'
        'resolver:resolver management'
        'policy:policy management'
        'event:event handler'
        'system:system configuration'
        'config:configuration'
        'admin:admin operations'
        'ca:CA management'
        'audit:audit logs'
        'subscription:subscription operations'
        'application:application management'
        'app:app management alias'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-url=+[url]:str:' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '--token=+[token]:str:' \
        '-c+[config file]:file:_files -g "*.cfg *.ini *.yaml"' \
        '--config=+[file]:file:_files -g "*.cfg *.ini *.yaml"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'privacyidea subcommand' sub ;;
        args)
            case $words[1] in
                token|user|realm|resolver|policy|event|application) _arguments '1:op:(list get create update delete enable disable assign unassign reset resync)' '*:id:' ;;
            esac
            ;;
    esac
}

_privacyidea "$@"
