#compdef manweb
# Documentation: man manweb (Netpbm)
# Source: open the local copy of an HTML manual page in a web browser.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[show help]' \
    '-config=[config file]:file:_files' \
    '*:topic and subtopics:' \
    && ret=0

return ret
