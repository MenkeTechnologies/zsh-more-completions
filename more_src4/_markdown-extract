#compdef markdown-extract
# Documentation: https://github.com/sean0x42/markdown-extract
# Reference accessed: 2026-05-19
# Verified: upstream sean0x42/markdown-extract; flag set matches the
# completion published by iloveitaly/zsh-ai-completions.
# Removed from prior file: bogus man.archlinux.org URL.
# Source: https://github.com/iloveitaly/zsh-ai-completions/blob/6d8da7d9514e6b57db1b75917dd30072010968a8/completions/_markdown-extract

_arguments -S \
  '(-a --all)'{-a,--all}'[Print all matching sections (do not quit after first match)]' \
  '(-s --case-sensitive)'{-s,--case-sensitive}'[Treat pattern as case sensitive]' \
  '(-n --no-print-matched-heading)'{-n,--no-print-matched-heading}'[Do not include the matched heading in the output]' \
  '(-h --help)'{-h,--help}'[Print help]' \
  '(-V --version)'{-V,--version}'[Print version]' \
  '1:pattern: ' \
  '2:file:_files'
