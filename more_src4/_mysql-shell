#compdef mysql-shell mysqlsh
# Documentation: https://dev.mysql.com/doc/mysql-shell/8.4/en/mysqlsh.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mysql-shell (mysqlsh): MySQL Shell (X DevAPI + JS/Python/SQL modes)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--uri=[connection URI]:uri:' \
  '(-u --user)'{-u+,--user=}'[user]:user:_users' \
  '(-h --host)'{-h+,--host=}'[host]:host:_hosts' \
  '(-P --port)'{-P+,--port=}'[port]:port:' \
  '(-S --socket)'{-S+,--socket=}'[unix socket]:file:_files' \
  '(-p --password)'{-p,--password}'[ask password]' \
  '--password1=[MFA password 1]:p:' \
  '--password2=[MFA password 2]:p:' \
  '--password3=[MFA password 3]:p:' \
  '--no-password[no password]' \
  '--passwords-from-stdin[read password from stdin]' \
  '(-D --schema --database)'{-D+,--schema=,--database=}'[default schema]:schema:' \
  '--mysql[connect via classic protocol]' \
  '--mc[same as --mysql]' \
  '--mysqlx[connect via X protocol]' \
  '--mx[same as --mysqlx]' \
  '--sql[SQL mode]' \
  '--sqlc[SQL mode over classic protocol]' \
  '--sqlx[SQL mode over X protocol]' \
  '--js[JavaScript mode]' \
  '--javascript[JavaScript mode]' \
  '--py[Python mode]' \
  '--python[Python mode]' \
  '--pyc=[execute Python command and quit]:cmd:' \
  '--pym[execute Python module as script]' \
  '--auth-method=[auth method]:method:(AUTO FALLBACK FROM_CAPABILITIES MYSQL41 PLAIN SHA256_MEMORY)' \
  '--get-server-public-key[get server public key]' \
  '--server-public-key-path=[server public key file]:file:_files' \
  '--plugin-authentication-kerberos-client-mode=[kerberos mode]:m:(SSPI GSSAPI)' \
  '--plugin-authentication-webauthn-client-preserve-privacy[webauthn privacy]' \
  '--register-factor=[WebAuthn factors]:f:' \
  '--oci-config-file=[OCI config file]:file:_files' \
  '--authentication-oci-client-config-profile=[OCI profile]:name:' \
  '--ssl-mode=[SSL mode]:mode:(DISABLED PREFERRED REQUIRED VERIFY_CA VERIFY_IDENTITY)' \
  '--ssl-ca=[SSL CA]:file:_files' \
  '--ssl-capath=[SSL CA path]:dir:_files -/' \
  '--ssl-cert=[SSL cert]:file:_files' \
  '--ssl-key=[SSL key]:file:_files' \
  '--ssl-cipher=[SSL ciphers]:ciphers:' \
  '--ssl-crl=[SSL CRL]:file:_files' \
  '--ssl-crlpath=[SSL CRL path]:dir:_files -/' \
  '--tls-version=[TLS version]:ver:' \
  '--tls-ciphersuites=[TLS v1.3 ciphers]:c:' \
  '--ssh=[SSH server URI]:uri:' \
  '--ssh-config-file=[SSH config file]:file:_files' \
  '--ssh-identity-file=[SSH identity file]:file:_files' \
  '--cluster[connect to InnoDB cluster]' \
  '--replicaset[connect to InnoDB ReplicaSet]' \
  '--redirect-primary[ensure primary connection]' \
  '--redirect-secondary[ensure secondary connection]' \
  '(-C --compress)'{-C,--compress}'[compress client-server protocol]' \
  '--compression-algorithms=[algorithms csv]:algs:' \
  '--zstd-compression-level=[zstd level 1-22]:n:' \
  '--result-format=[output format]:fmt:(table tabbed vertical json ndjson json/array)' \
  '--table[tabular output]' \
  '--tabbed[tab-separated output]' \
  '(-E --vertical)'{-E,--vertical}'[vertical output]' \
  '--json=[json wrapping]:fmt:(pretty raw off)' \
  '--column-type-info[print column metadata]' \
  '--pager=[external pager]:p:' \
  '(-e --execute)'{-e+,--execute=}'[execute statement and exit]:stmt:' \
  '(-f --file)'{-f+,--file=}'[execute file]:file:_files' \
  '--force[continue on errors]' \
  '(-i --interactive)'{-i,--interactive}'[interactive mode]' \
  '--quiet-start=[suppress startup]:n:(1 2)' \
  '--verbose=[verbose level]:n:(0 1 2 3 4)' \
  '--log-file=[log file]:file:_files' \
  '--log-level=[log level]:level:(none internal error warning info debug debug2 debug3 1 2 3 4 5 6 7 8)' \
  '--log-sql=[log SQL]:opt:(off error on all unfiltered)' \
  '--dba-log-sql=[log AdminAPI SQL]:n:(0 1 2)' \
  '--syslog[log to syslog]' \
  '--connect-timeout=[connection timeout ms]:ms:' \
  '--show-warnings[show warnings]' \
  '--histignore=[history ignore strings]:s:' \
  '--name-cache[enable name cache]' \
  '(-A --no-name-cache)'{-A,--no-name-cache}'[disable name cache]' \
  '(-nw --no-wizard)'{-nw,--no-wizard}'[disable wizards]' \
  '--credential-store-helper=[credential helper]:h:' \
  '--save-passwords=[password storage]:mode:(always prompt never)' \
  '--mysql-plugin-dir=[plugin directory]:dir:_files -/' \
  '--no-defaults[ignore option files]' \
  '*::mysql-shell args:_files' && ret=0
return ret
