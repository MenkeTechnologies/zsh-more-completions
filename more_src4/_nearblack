#compdef nearblack
# Documentation: https://gdal.org/en/stable/programs/nearblack.html
# Source: OSGeo/gdal apps/nearblack_bin.cpp — convert nearly black/white border pixels to actual black/white.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '--help-general[show generic GDAL options]' \
    '--long-usage[extended usage]' \
    '(-q --quiet)'{-q,--quiet}'[suppress progress output]' \
    '-o+[output file]:file:_files' \
    '-of+[output format]:format:_default' \
    '*-co+[creation option NAME=VALUE]:option:_default' \
    '-white[search for nearly-white pixels (default is black)]' \
    '-color+[search for pixels near custom color c1,c2,c3,...]:color:_default' \
    '-near+[distance threshold (default 15)]:dist:_default' \
    '-nb+[non-black pixels before stopping (default 2)]:n:_default' \
    '-setalpha[add/set alpha band with collar=0]' \
    '-setmask[add mask band with collar=0]' \
    '-alg+[algorithm]:alg:(twopasses floodfill)' \
    '*:input file:_files' \
    && ret=0

return ret
