#compdef pamgradient
# Documentation: man pamgradient (Netpbm)
# Source: produce a PAM image with bilinear color gradient from four corner colors.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-maxval=[max sample value]:maxval:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:top-left color:' \
    '2:top-right color:' \
    '3:bottom-left color:' \
    '4:bottom-right color:' \
    '5:width:' \
    '6:height:' \
    && ret=0

return ret
