#compdef policy-tester
# Documentation: upstream cmd/tester/main.go at github.com/sigstore/policy-controller
# Reference accessed: 2026-05-30
# Sigstore policy-tester R48 — local CLI for validating ClusterImagePolicy
# objects against container images without needing a Kubernetes cluster.
# Sister-binary to existing _cosign/_rekor-cli/_gitsign coverage.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-policy=[ClusterImagePolicy path or http(s) URL]:policy:_files' \
  '-image=[container image to compare against policy]:image:' \
  '-resource=[Kubernetes resource for includeSpec/includeObjectMeta]:file:_files' \
  '-trustroot=[Kubernetes TrustRoot resource path]:file:_files' \
  '-log-level=[log level (default info)]:level:(debug info warn error)' \
  '-enable-oci11[enable experimental OCI 1.1 referrers API]' \
  '-version[show policy-controller tester version]' \
  && ret=0

return ret
