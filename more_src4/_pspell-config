#compdef pspell-config
# Documentation: man pspell-config(1) (Aspell)
# Source: GNU Aspell — pspell-config prints information about libpspell installation.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--version[output version information]' \
    '--datadir[display the data directory]' \
    '--pkgdatadir[display the aspell package directory]' \
    && ret=0

return ret
