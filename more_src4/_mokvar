#compdef mokvar
# Documentation: https://github.com/rhboot/shim/blob/main/MokVars.txt
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: There is no canonical user-facing CLI named "mokvar". The MOK
# (Machine Owner Key) UEFI variables are exposed by the Linux kernel via
# the read-only sysfs directory /sys/firmware/efi/mok-variables/ (see
# kernel commits referencing CONFIG_LOAD_UEFI_KEYS / mokvar-table). User
# space typically uses mokutil(1) to manipulate MOK keys; no separate
# "mokvar" binary is shipped upstream. This stub keeps completion silent.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*:file:_files' && ret=0
return ret
