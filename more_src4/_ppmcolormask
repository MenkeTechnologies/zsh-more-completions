#compdef ppmcolormask
# Documentation: man ppmcolormask (Netpbm)
# Source: create a mask PBM identifying pixels of given color(s) in a PPM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-color=[comma-separated colors to mask]:colors:' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:color or ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
