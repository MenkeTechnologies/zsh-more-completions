#compdef pammixinterlace
# Documentation: man pammixinterlace (Netpbm)
# Source: de-interlace a Netpbm video frame by mixing alternate fields.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-filter=[de-interlace filter]:filter:(linear fir ffmpeg)' \
    '-adaptive[adaptive de-interlacing]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:input file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
