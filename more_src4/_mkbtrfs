#compdef mkbtrfs mkfs.btrfs-mkbtrfs
# _mkbtrfs — Btrfs Project mkbtrfs CLI alias for mkfs.btrfs creating a Btrfs file system over one or more block devices supporting RAID levels metadata-data profiles compression deduplication checksum nodatacow on-multi-device (kdave team, C); getopt
# upstream: https://github.com/kdave/btrfs-progs

_mkbtrfs() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-q[quiet]' \
        '-A+[alloc start]:n:' \
        '--alloc-start=+[N]:n:' \
        '-b+[byte count]:n:' \
        '--byte-count=+[N]:n:' \
        '-d+[data profile]:p:(single dup raid0 raid1 raid1c3 raid1c4 raid5 raid6 raid10)' \
        '--data=+[data profile]:p:(single dup raid0 raid1 raid1c3 raid1c4 raid5 raid6 raid10)' \
        '-f[force]' \
        '--force[force]' \
        '-i+[inode limit]:n:' \
        '--inode-cache[enable inode cache]' \
        '-l+[leaf size]:n:' \
        '--leafsize=+[N]:n:' \
        '-L+[label]:str:' \
        '--label=+[label]:str:' \
        '-m+[metadata profile]:p:(single dup raid0 raid1 raid1c3 raid1c4 raid5 raid6 raid10)' \
        '--metadata=+[metadata profile]:p:(single dup raid0 raid1 raid1c3 raid1c4 raid5 raid6 raid10)' \
        '-M[mixed]' \
        '--mixed[mixed]' \
        '-n+[node size]:n:' \
        '--nodesize=+[N]:n:' \
        '-O+[features csv]:str:' \
        '--features=+[features csv]:str:' \
        '-r+[rootdir]:dir:_files -/' \
        '--rootdir=+[rootdir]:dir:_files -/' \
        '-s+[sector size]:n:' \
        '--sectorsize=+[N]:n:' \
        '-U+[UUID]:str:' \
        '--uuid=+[UUID]:str:' \
        '--csum=+[c]:c:(crc32c sha256 blake2 xxhash)' \
        '--shrink[shrink to fit data]' \
        '*:devices:_files'
}

_mkbtrfs "$@"
