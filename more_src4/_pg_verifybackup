#compdef pg_verifybackup
# Documentation: https://www.postgresql.org/docs/current/app-pgverifybackup.html
# Source: postgres/postgres src/bin/pg_verifybackup/pg_verifybackup.c — verify integrity of a base backup (C, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-V,--version}'[show version]' \
    '(- *)'{-\?,--help}'[show help]' \
    {-e,--exit-on-error}'[exit on first error]' \
    '*'{-i+,--ignore=}'[file to ignore]:file:_default' \
    {-m+,--manifest-path=}'[backup manifest file]:file:_files' \
    {-F+,--format=}'[backup format]:format:(plain tar)' \
    {-n,--no-parse-wal}'[do not attempt to parse WAL]' \
    {-P,--progress}'[show progress]' \
    {-q,--quiet}'[suppress all progress messages]' \
    {-s,--skip-checksums}'[skip file checksum verification]' \
    {-w+,--wal-path=}'[WAL files directory]:dir:_files -/' \
    '1::backup directory:_files -/' \
    && ret=0

return ret
