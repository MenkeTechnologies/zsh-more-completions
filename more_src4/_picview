#compdef picview
# Documentation: (no canonical upstream — non-standard tool)
# Reference accessed: 2026-05-20
# Verified: no canonical "picview" CLI exists upstream as a Linux
# image viewer. Names matching "picview" found upstream are Ruben2776/
# PicView (Windows/macOS GUI), picviewer (Snap), and similar GUI apps
# without a documented Linux CLI. STUB completing image file
# arguments only.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '*:images:_files -g "*.(jpg|jpeg|png|gif|bmp|tif|tiff|webp|avif|heic|heif|svg)"' && ret=0
return ret
