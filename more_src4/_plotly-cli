#compdef plotly-cli plotly plotly-orca plotly-dash
# _plotly-cli — Plotly plotly-cli CLI command-line frontend wrapping the Plotly graphing library Dash analytical web application framework managing figures dash apps Dash-deploy Dash-Enterprise Plotly-Studio Plotly-Express renders export PDF PNG SVG HTML JSON kaleido-orca kaleido-renderer (Plotly team, Python); click
# upstream: https://plotly.com/

_plotly-cli() {
    local -a sub=(
        'render:render a figure'
        'export:export a figure'
        'dash:Dash operations'
        'studio:Studio operations'
        'embed:embed operations'
        'config:configuration'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-f+[format]:f:(png jpg jpeg svg pdf html json eps)' \
        '--format=+[format]:f:(png jpg jpeg svg pdf html json eps)' \
        '--width=+[N]:n:' \
        '--height=+[N]:n:' \
        '--scale=+[N]:str:' \
        '--engine=+[e]:e:(kaleido orca auto)' \
        '--mathjax=+[path]:str:' \
        '--topojson=+[path]:str:' \
        '--mapbox-token=+[token]:str:' \
        '--debug[debug]' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'plotly-cli subcommand' sub ;;
        args)
            case $words[1] in
                render|export) _arguments '*:figure file:_files -g "*.json *.html *.py"' ;;
                dash) _arguments \
                    '1:op:(run deploy create init add-snapshot list status)' \
                    '--port=+[port]:n:' \
                    '--host=+[host]:_hosts' \
                    '--debug[debug mode]' \
                    '--reload[reload on changes]' \
                    '--prevent-initial-callbacks[prevent initial]' ;;
                studio) _arguments '1:op:(open list)' ;;
                embed) _arguments '*:url:' ;;
            esac
            ;;
    esac
}

_plotly-cli "$@"
