#compdef ngit
# ============================================================================
# _ngit — zsh completion for DanConwayDev/ngit-cli, "the nostr plugin for
#          git — a nostr-based github alternative for FOSS repositories"
#          (Rust=152 leader bump OPENING Axis 97 Nostr / nostr-sdk-rs
#          protocol library)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/DanConwayDev/ngit-cli
#   Maintainer : Dan Conway Dev
#   License    : MIT
#   Stars      : 56
#   Language   : Rust
#   Crate      : ngit  (Cargo.toml [package] name = "ngit")
#   Binaries   : ngit              (the project / PR / issue
#                                   / sync / account CLI)
#                git-remote-nostr  (git remote helper for
#                                   nostr:// URLs)
#   Last push  : 2026-05-26
#
# WHAT IT IS
#   ngit is "the nostr plugin for git" — a Nostr-based GitHub
#   alternative for FOSS repositories.  It ships a `git-remote-
#   nostr` helper that makes `git clone nostr://npub.../repo`
#   work natively, plus the `ngit` CLI for repository
#   publishing, PR submission, PR review, issue management,
#   account login, and chain-sync between the nostr authoritative
#   state and one or more git-server mirrors (github.com,
#   codeberg, gitea, gitlab).  Authentication is via Nostr
#   identity keys (nsec or nostr-connect / NIP-46 remote signer
#   bunker).  Repository state is persisted in Nostr events of
#   custom NIP kinds, encrypted to maintainer keys, and
#   distributed across maintainer-configured relays.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/bin/ngit/cli.rs
#                       `struct Cli` + `enum Commands` — clap
#                       derive)
#   ngit [GLOBAL OPTIONS] <SUBCOMMAND> [args...]
#
#   Global options (every subcommand):
#     -n, --nsec <KEY>               nsec or hex private key
#     -p, --password <PASS>          password to decrypt
#                                    ncryptsec (hidden in
#                                    --help)
#     -c, --customize                Show git-config-based
#                                    customization options
#     -d, --defaults                 Use defaults without
#                                    prompting (non-interactive)
#                                    [conflicts with
#                                    --interactive]
#     -i, --interactive              Enable interactive prompts
#                                    (default)
#     -f, --force                    Bypass safety guards
#     -v, --verbose                  Verbose output
#     --bunker-uri <URI>             Remote signer NIP-46 bunker
#                                    URI (hidden)
#     --bunker-app-key <KEY>         Remote signer app secret
#                                    key (hidden)
#     --disable-cli-spinners         Disable spinner animations
#                                    (hidden)
#
#   Subcommands:
#     init                           Publish repository to
#                                    nostr; signal you are a
#                                    maintainer accepting PRs
#                                    and issues
#
#     repo                           Manage repository metadata
#                                    + maintainership;  run
#                                    bare to show repo info
#       --offline                      Use local cache, skip
#                                      network fetch
#       --json                         Output as JSON
#
#     send                           Submit a PR with advanced
#                                    options
#
#     pr <SUBCMD>                    Pull-request management
#       list [<ID|nevent>]             List PRs (or show
#                                      details for one)
#         --status <CSV>                 Filter by status
#                                        (open|draft|closed|
#                                         applied)
#                                        [default: open,draft]
#         --label <LABEL>                Filter by label
#                                        (repeatable, OR
#                                        logic)
#         --json                         Output as JSON
#         (plus --offline / etc.)
#
#     issue <SUBCMD>                 Issue management
#
#     sync                           Update repo git servers to
#                                    reflect nostr state
#                                    (add / update / delete
#                                     remote refs)
#
#     account <SUBCMD>               Account management
#       login                          Login with nsec or
#                                      nostr-connect
#       logout                         Remove stored nostr
#                                      account details
#       export-keys                    Export keys for use in
#                                      other nostr clients
#       create                         Create a new nostr
#                                      account
#       whoami                         Show currently logged-in
#                                      account(s)
#
#   Standard clap auto-flags:
#     -h, --help                     Show help
#     -V, --version                  Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `nostr = "0.44.1"` (with feature
#   `nip49`), `nostr-sdk = "0.44.1"`, `nostr-connect = "0.44.0"`,
#   `nostr-database = "0.44.0"`, `nostr-lmdb = "0.44.0"`, and
#   `nostr-relay-pool = "0.44.0"` declared in Cargo.toml —
#   `nostr-sdk` is THE canonical Rust Nostr protocol SDK
#   maintained by the rust-nostr org (rust-nostr/nostr, 700+
#   stars; the predominant typed Nostr client used by every
#   major Rust Nostr application — Mostro, Damus on macOS,
#   Iris bridges, etc.).  nostr-sdk exposes the typed
#   `nostr_sdk::Client` constructor with `Client::new(&signer)`,
#   `Client::default()`, every typed `Event` / `EventId` /
#   `PublicKey` / `SecretKey` / `Keys` model, every NIP-01
#   ("kind", "tags", "content", "pubkey", "signature",
#   "created_at"), NIP-04 (encrypted DM), NIP-19 (bech32
#   identifiers — npub/nsec/note/nevent/nprofile/naddr), NIP-44
#   (encrypted payloads v2), NIP-46 (remote signer / bunker),
#   NIP-49 (encrypted private-key import/export), NIP-65
#   (relay lists), the typed `Filter` builder, `Tag` / `TagKind`
#   / `TagStandard` enums, the `Output<T>` async-stream
#   primitive returned by `client.subscribe(filters, options)`,
#   relay-pool connection management, automatic reconnect,
#   sync-time anti-replay, and the typed `EventBuilder` for
#   constructing every NIP-defined event kind.  ngit-cli's
#   `src/lib/git_events/...` constructs typed `EventBuilder`
#   instances for each Nostr-encoded git operation (publish-
#   repo, open-PR, comment-on-PR, sync-state, mark-resolved,
#   close, etc.) and signs them through the configured
#   `Keys::generate()` / `Keys::parse(nsec)` / `RemoteSigner`
#   instance.  Verified via:
#     gh api repos/DanConwayDev/ngit-cli/contents/Cargo.toml
#       → nostr = { version = "0.44.1", features = ["nip49"] }
#       → nostr-sdk = "0.44.1"
#       → nostr-connect = "0.44.0"
#       → nostr-database = "0.44.0"
#       → nostr-lmdb = "0.44.0"
#       → nostr-relay-pool = "0.44.0"
#       → [[bin]] name = "ngit"; path = "src/bin/ngit/main.rs"
#       → [[bin]] name = "git-remote-nostr"; path = "src/bin/
#           git_remote_nostr/main.rs"
#     gh api repos/DanConwayDev/ngit-cli/contents/src/bin/ngit/
#         cli.rs
#       → #[derive(Parser)] struct Cli { command, nsec,
#                                          password, bunker_uri,
#                                          bunker_app_key,
#                                          customize, defaults,
#                                          interactive, force,
#                                          verbose }
#       → enum Commands { Init, Repo, Send, Pr, Issue, Sync,
#                          Account }
#   This entry is the Rust=152 leader bump that OPENS Axis 97
#   (Nostr / nostr-sdk-rs protocol library) at 1/0/0.  Pairing
#   Go and TS-Node bumps will follow at R978 and R979 (Go=152
#   candidates nbd-wtf/go-nostr-based CLIs; TS-Node=152
#   candidates nostr-tools / NDK users).
#
#   No completion for `ngit` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_ngit() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-n --nsec)'{-n,--nsec}'=[nsec or hex private key]:nsec:' \
        '(-p --password)'{-p,--password}'=[ncryptsec decryption password]:password:' \
        '(-c --customize)'{-c,--customize}'[show customization options via git config]' \
        '(-d --defaults)'{-d,--defaults}'[use defaults without prompting]' \
        '(-i --interactive)'{-i,--interactive}'[enable interactive prompts]' \
        '(-f --force)'{-f,--force}'[bypass safety guards]' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '--bunker-uri=[NIP-46 remote signer bunker URI]:uri:' \
        '--bunker-app-key=[remote signer app secret key]:key:' \
        '1: :_ngit_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                init|send|sync)
                    _arguments '*: :' && ret=0 ;;
                repo)
                    _arguments \
                        '--offline[use local cache, skip network fetch]' \
                        '--json[output as JSON]' && ret=0 ;;
                pr)
                    _arguments \
                        '1:pr subcommand:(list)' \
                        '*::arg:->pr_args' && ret=0
                    case $state in
                        pr_args)
                            case $words[1] in
                                list)
                                    _arguments \
                                        '--status=[filter by status]:status:(open draft closed applied)' \
                                        '*--label=[filter by label (repeatable)]:label:' \
                                        '--json[output as JSON]' \
                                        '--offline[use local cache]' \
                                        '::PR id or nevent:' && ret=0 ;;
                            esac
                            ;;
                    esac
                    ;;
                issue)
                    _arguments \
                        '1:issue subcommand:(list create comment close reopen)' \
                        '*::arg:' && ret=0 ;;
                account)
                    _arguments \
                        '1:account subcommand:(login logout export-keys create whoami)' \
                        '*::arg:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_ngit_commands] )) ||
_ngit_commands() {
    local -a commands
    commands=(
        'init:publish repository to nostr'
        'repo:manage repository metadata and maintainership'
        'send:submit a PR with advanced options'
        'pr:work with pull requests'
        'issue:work with issues'
        'sync:update repo git servers to reflect nostr state'
        'account:create account, login, logout, or export keys'
    )
    _describe -t commands 'ngit command' commands
}

_ngit "$@"
