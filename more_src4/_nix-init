#compdef nix-init
# Documentation: https://github.com/nix-community/nix-init
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for nix-init (generate Nix packages from URLs)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-u --url)'{-u,--url}'[specify the URL]:url:' \
  '--rev[specify the tag or revision]:ref:' \
  '(-S --submodules)'{-S,--submodules}'[always fetch submodules when possible]' \
  '--pname[specify the pname]:pname:' \
  '--builder[specify the builder]:builder:' \
  '--cargo-vendor[how cargo dependencies are vendored]:method:' \
  '(-y --overwrite)'{-y,--overwrite}'[always overwrite files]' \
  '--headless[do not prompt for anything (requires --url)]' \
  '(-n --nixpkgs)'{-n,--nixpkgs}'[path to nixpkgs (in nix)]:path:' \
  '(-C --commit)'{-C,--commit}'[commit the changes if the output path is name-based]' \
  '(-c --config)'{-c,--config}'[specify the config file]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:output path:_files' && ret=0

return ret
