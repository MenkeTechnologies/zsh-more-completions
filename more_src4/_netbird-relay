#compdef netbird-relay
# _netbird-relay — NetBird relay server daemon (netbirdio/netbird)
# upstream: https://github.com/netbirdio/netbird
# Flags from relay/cmd/root.go (cobra).

_netbird-relay() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-l --listen-address)'{-l+,--listen-address=}'[listen address]:addr:' \
        '(-e --exposed-address)'{-e+,--exposed-address=}'[instance domain/ip:port]:addr:' \
        '--metrics-port=[metrics HTTP port]:port:' \
        '(-d --letsencrypt-data-dir)'{-d+,--letsencrypt-data-dir=}'[Let'\''s Encrypt data dir]:dir:_files -/' \
        '(-a --letsencrypt-domains)'{-a+,--letsencrypt-domains=}'[domains for Let'\''s Encrypt cert]:domains:' \
        '--letsencrypt-email=[email for Let'\''s Encrypt]:email:' \
        '--letsencrypt-aws-route53[use AWS Route 53 for DNS challenge]' \
        '(-c --tls-cert-file)'{-c+,--tls-cert-file=}'[TLS cert file]:file:_files' \
        '(-k --tls-key-file)'{-k+,--tls-key-file=}'[TLS key file]:file:_files' \
        '(-s --auth-secret)'{-s+,--auth-secret=}'[auth secret]:secret:' \
        '--log-level=[log level]:level:(panic fatal error warn info debug trace)' \
        '--log-file=[log file path]:file:_files' \
        '(-H --health-listen-address)'{-H+,--health-listen-address=}'[healthcheck listen addr]:addr:' \
        '--enable-stun[enable embedded STUN server]' \
        '--stun-ports=[STUN server ports]:ports:' \
        '--stun-log-level=[STUN log level]:level:(panic fatal error warn info debug trace)'
}

_netbird-relay "$@"
