#compdef mount_ados
# Documentation: man mount_ados(8)
# Source: netbsd/src sbin/mount_ados — mount an AmigaDOS file system (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-o+[mount options (comma-separated, see mount(8))]:options:_default' \
    '-u+[file owner uid (default directory owner)]:uid:_default' \
    '-g+[file group gid (default directory group)]:gid:_default' \
    '-m+[maximum file permissions (octal)]:mask:_default' \
    '1:special device:_files' \
    '2:mount point:_files -/' \
    && ret=0

return ret
