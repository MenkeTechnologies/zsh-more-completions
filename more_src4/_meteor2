#compdef meteor2
# _meteor2 — Meteor Software meteor2 CLI command-line frontend wrapping the Meteor JavaScript full-stack platform for building cross-platform web mobile and desktop applications open-source written in JavaScript Node TypeScript reactive data on the wire isomorphic JavaScript MongoDB-baked OAuth originally Meteor Development Group now Meteor Software run create build add remove update mongo reset shell debug deploy login logout whoami install help packages publish search show test test-packages npm-rebuild npm-install configure dump backup restore migrate atmosphere meteor3-vite (Meteor Software team Geoff Schmidt Matt DeBergalis, JavaScript); commander
# upstream: https://www.meteor.com/

_meteor2() {
    local -a sub=(
        'add:add a package'
        'admin:admin operations'
        'authorized:show authorized users'
        'build:build app for deployment'
        'bundle:bundle app'
        'configure-android:configure Android SDK'
        'create:create a new project'
        'debug:run in debug mode'
        'deploy:deploy to Meteor Cloud'
        'enginecheck:check engine version'
        'help:show help'
        'install:install Meteor'
        'install-sdk:install Cordova SDK'
        'lint:lint code'
        'list:list installed packages'
        'list-platforms:list installed platforms'
        'list-sites:list deployed sites'
        'login:authenticate to Atmosphere'
        'logout:revoke session'
        'logs:show app logs'
        'mongo:open MongoDB shell'
        'node:run node'
        'npm-install:install npm deps'
        'npm-rebuild:rebuild npm deps'
        'npm:run npm'
        'pnpm:run pnpm'
        'yarn:run yarn'
        'publish:publish a package'
        'publish-for-arch:publish for arch'
        'publish-release:publish release'
        'remove:remove a package'
        'reset:reset local DB'
        'run:run dev server'
        'search:search Atmosphere'
        'shell:open Meteor shell'
        'show:show package info'
        'test:run tests'
        'test-packages:run package tests'
        'update:update Meteor'
        'whoami:show identity'
        'self-update:update CLI'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--release=+[name]:str:' \
        '-p+[port]:n:' \
        '--port=+[port]:n:' \
        '--inspect=+[port]:n:' \
        '--inspect-brk=+[port]:n:' \
        '--mobile-server=+[url]:str:' \
        '--cordova-server-port=+[port]:n:' \
        '--platform=+[p]:p:(ios android web web.browser web.cordova)' \
        '--allow-superuser[allow superuser]' \
        '--production[production]' \
        '--raw-logs[raw logs]' \
        '-s+[settings]:file:_files -g "*.json"' \
        '--settings=+[file]:file:_files -g "*.json"' \
        '--exclude-archs=+[archs]:str:' \
        '--server-only[server only]' \
        '--directory[directory]' \
        '--debug[debug]' \
        '--once[once]' \
        '--driver-package=+[name]:str:' \
        '--test-app-path=+[path]:_files' \
        '--full-app[full app]' \
        '--app-id=+[id]:str:' \
        '--app-name=+[name]:str:' \
        '--target-arch=+[arch]:str:' \
        '-a+[architecture]:str:' \
        '--free[free tier]' \
        '--mongo[mongo]' \
        '--owner=+[owner]:str:' \
        '--protocol[show protocol]' \
        '--build[build]' \
        '--no-build[no build]' \
        '--no-release-check[no release check]' \
        '--no-update-instructions[no update instructions]' \
        '--no-publish-fail[no publish fail]' \
        '--bare[bare]' \
        '--full[full]' \
        '--minimal[minimal]' \
        '--example=+[name]:str:' \
        '--package[package]' \
        '--package-name=+[name]:str:' \
        '--list[list]' \
        '--from-checkout[from checkout]' \
        '--release-track=+[name]:str:' \
        '--skip-tests[skip tests]' \
        '--list-only[list only]' \
        '--clean[clean]' \
        '--no-mobile-server[no mobile server]' \
        '--package-manager=+[m]:m:(npm pnpm yarn)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'meteor subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments '*:name:' ;;
                add|remove|show|search) _arguments '*:package:' ;;
                deploy) _arguments '*:site:' ;;
                run) _arguments '*:target:(ios ios-device android android-device)' ;;
                test|test-packages) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_meteor2 "$@"
