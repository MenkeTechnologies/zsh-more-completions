#compdef pprof
# _pprof-bin — Google pprof profile visualizer (Go); reads pprof profile files (Go runtime, gperftools) and serves HTML/SVG flame graphs
# upstream: https://github.com/google/pprof

_pprof-bin() {
    _arguments \
        '-help[show help]' \
        '-version[show version]' \
        '-callgrind[output callgrind format]' \
        '-comments[output comments only]' \
        '-disasm+[disassemble regex]:regex:' \
        '-dot[output Graphviz dot]' \
        '-eog[render eog viewer]' \
        '-evince[render evince viewer]' \
        '-gif[GIF output]' \
        '-gv[gv viewer]' \
        '-kcachegrind[output kcachegrind format]' \
        '-list+[list regex]:regex:' \
        '-pdf[PDF output]' \
        '-peek+[show callers of regex]:regex:' \
        '-png[PNG output]' \
        '-proto[proto output]' \
        '-ps[PostScript output]' \
        '-raw[raw profile]' \
        '-svg[SVG output]' \
        '-tags[show tags]' \
        '-text[text output]' \
        '-top[top output (default)]' \
        '-topproto[top proto output]' \
        '-traces[show stack traces]' \
        '-tree[tree output]' \
        '-web[render web view]' \
        '-weblist+[weblist regex]:regex:' \
        '-output+[output file]:file:_files' \
        '-http+[serve HTTP on host:port]:host:port:' \
        '-no_browser[do not open browser]' \
        '-edgefraction+[edge fraction]:f:' \
        '-flat[flat profile]' \
        '-cum[cumulative profile]' \
        '-focus+[focus regex]:regex:' \
        '-ignore+[ignore regex]:regex:' \
        '-show+[show regex]:regex:' \
        '-show_from+[show from regex]:regex:' \
        '-hide+[hide regex]:regex:' \
        '-prune_from+[prune from regex]:regex:' \
        '-tagfocus+[tag focus]:str:' \
        '-tagignore+[tag ignore]:str:' \
        '-tagshow+[tag show]:str:' \
        '-taghide+[tag hide]:str:' \
        '-tagleaf[tag leaf]' \
        '-tagroot[tag root]' \
        '-tagignore_label[tag ignore label]' \
        '-symbolize+[symbolize mode]:mode:(none local fastlocal remote demangle)' \
        '-sample_index+[index]:str:' \
        '-mean[mean sample]' \
        '-normalize+[normalize to base profile]:file:_files' \
        '-base+[base profile]:file:_files' \
        '-diff_base+[diff base profile]:file:_files' \
        '-unit+[unit]:unit:' \
        '-source_path+[source path]:path:' \
        '-trim[trim]' \
        '-trim_path+[trim path]:path:' \
        '-nodecount+[max nodes]:n:' \
        '-nodefraction+[node fraction]:f:' \
        '-edgesfraction+[edges fraction]:f:' \
        '-relative_percentages[show relative %]' \
        '-divide_by+[divide profile by]:n:' \
        '-tools+[tools dir]:dir:_files -/' \
        '*:profile or binary:_files'
}

_pprof-bin "$@"
