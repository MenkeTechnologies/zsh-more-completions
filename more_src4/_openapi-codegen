_openapi-codegen() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '--version[show version]' \
    '1: :->cmd' \
    '*:: :->subargs'

  case $state in
    cmd)
      local -a verbs=(
        'init:initialize a new OpenAPI codegen config file'
        'generate:generate types and components from an OpenAPI file'
        'gen:generate types and components (alias for generate)'
      )
      _describe -t commands 'openapi-codegen subcommand' verbs
      ;;
    subargs)
      case $line[1] in
        init)
          _arguments -s -S \
            '(-c --config)'{-c,--config}'=[configuration file path]:file:_files -g "*.(ts|js|json)"' \
            '--dry-run[print the file to stdout]' \
            '(-h --help)'{-h,--help}'[show help]'
          ;;
        generate|gen)
          _arguments -s -S \
            '(-c --config)'{-c,--config}'=[configuration file path]:file:_files -g "*.(ts|js|json)"' \
            '--source=[spec source type]:type:(file url github)' \
            '--relativePath=[relative path of spec file (source=file)]:path:_files -g "*.(json|yaml|yml)"' \
            '--url=[URL of spec file (source=url)]:url' \
            '--method=[HTTP method (source=url)]:method:(get post)' \
            '--owner=[repository owner (source=github)]:owner' \
            '--repository=[repository name (source=github)]:repo' \
            '--repo=[repository name (alias for --repository)]:repo' \
            '--ref=[Git ref / commit / branch / tag (source=github)]:ref' \
            '--specPath=[OpenAPI spec file path (source=github)]:path' \
            '--pr=[select pull-request as ref (source=github)]:pr-number' \
            '--pull-request=[select pull-request as ref (alias)]:pr-number' \
            '(-h --help)'{-h,--help}'[show help]' \
            '1:namespace:'
          ;;
      esac
      ;;
  esac
}

_openapi-codegen "$@"
