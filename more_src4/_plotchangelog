#compdef plotchangelog
# Documentation: https://manpages.debian.org/plotchangelog
# Source: debian/devscripts scripts/plotchangelog.pl — plot Debian changelog history via gnuplot (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '--version[show version]' \
    '(-v --no-version)'{-v,--no-version}'[do not label versions]' \
    '(-m --no-maint)'{-m,--no-maint}'[do not differentiate by maintainer]' \
    '(-g --gnuplot)'{-g+,--gnuplot=}'[extra gnuplot commands]:commands:_default' \
    '(-s --save)'{-s+,--save=}'[save gnuplot script to file]:file:_files' \
    '(-d --dump)'{-d,--dump}'[dump data without plotting]' \
    '(-u --urgency)'{-u,--urgency}'[show urgency]' \
    '--verbose[verbose output]' \
    '(-l --linecount)'{-l,--linecount}'[plot line count instead of version]' \
    '(-b --bugcount)'{-b,--bugcount}'[plot bug count]' \
    '(-c --cumulative)'{-c,--cumulative}'[plot cumulative line/bug count]' \
    '(--no-conf --noconf)'{--no-conf,--noconf}'[ignore conf files]' \
    '*:changelog file:_files -g "changelog*"' \
    && ret=0

return ret
