#
# THE polykey CLI — commander + ajv + libp2p + @matrixai/logger
#
# polykey's CLI is in src/polykey.ts + src/CommandPolykey.ts.
# Uses tj/commander.js with hierarchical Command class
# inheritance (CommandPolykey base class adds shared options
# to all subcommands).
#
# Global options (added to every command via CommandPolykey):
#   --node-path PATH                  Polykey state directory
#                                     (default platform-specific)
#   --password-file FILE              read vault password from FILE
#   --format text|json                output format (default text)
#   -v / -vv / -vvv                   verbose (info/debug/silly)
#
# Command groups (9):
#   agent <subcommand>          agent (background daemon) mgmt
#                               start / stop / lock / unlock /
#                               status
#   audit <subcommand>          audit log inspection
#   auth <subcommand>           authentication (login / logout /
#                               token mgmt)
#   bootstrap [options]         initialize new Polykey node
#   identities <subcommand>     external-identity linking
#                               (GitHub / GitLab / etc.)
#   keys <subcommand>           keypair management (generate /
#                               encrypt / decrypt / sign / verify)
#   nodes <subcommand>          peer node mgmt (add / remove /
#                               connect / claim)
#   notifications <subcommand>  inter-node messaging (send /
#                               read / inbox)
#   secrets <subcommand>        secret CRUD (create / read /
#                               update / delete / list / share)
#   vaults <subcommand>         vault mgmt (create / delete /
#                               clone / pull / push / list /
#                               share)
#
# Standard:
#   -h, --help                  show help
#   -V, --version               show version
#
# Binary aliases:
#   polykey                     full name
#   pk                          short alias (same binary)
#
# ajv is used in:
#   - Wire-format validation between Polykey nodes (every
#     RPC message validated against JSON Schemas)
#   - Configuration file validation
#   - External API response validation (when interacting with
#     GitHub / GitLab / etc. for identity linking)
#
# Five-axis distinctness from Stranger6667/jsonschema (R681) +
# santhosh-tekuri/jsonschema (R682):
#
#   1. CODE-GEN JIT VALIDATORS — ajv emits JavaScript source
#      code as validator functions; unique among the three.
#
#   2. JSON TYPE DEFINITION (JTD) SUPPORT — RFC 8927;
#      currently unique to ajv among Axis 23 variants.
#
#   3. PLUGIN ECOSYSTEM — ajv-formats / -keywords / -errors /
#      -i18n / -bsontype / -merge-patch.
#
#   4. STANDALONE CODE GENERATION — ajv-cli can emit
#      standalone validator JS files (no ajv runtime needed
#      at deployment).
#
#   5. EVGENY-POBEREZKIN / ajv-validator ECOSYSTEM
#      PROVENANCE — distinct maintainer; Russian solo
#      developer.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/MatrixAI/Polykey-CLI/blob/master/src/CommandPolykey.ts
# https://github.com/MatrixAI/Polykey-CLI/blob/master/src/index.ts
# commander Command class with hierarchical option addition.)
