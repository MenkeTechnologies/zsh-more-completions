local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _polykey_cmds
_polykey_cmds=(
    'agent:agent (background daemon) management'
    'audit:audit log inspection'
    'auth:authentication (login / logout / token mgmt)'
    'bootstrap:initialize new Polykey node'
    'identities:external-identity linking (GitHub / GitLab / etc.)'
    'keys:keypair management (generate / encrypt / decrypt / sign / verify)'
    'nodes:peer node mgmt (add / remove / connect / claim)'
    'notifications:inter-node messaging'
    'secrets:secret CRUD (create / read / update / delete / list / share)'
    'vaults:vault mgmt (create / delete / clone / pull / push / list / share)'
    'help:show help for a subcommand'
)

_arguments -C \
    '--node-path=[Polykey state directory]:directory:_files -/' \
    '--password-file=[read vault password from file]:file:_files' \
    '--format=[output format]:format:(text json)' \
    '*-v[verbose (info/debug/silly)]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'polykey subcommand' _polykey_cmds && ret=0
        ;;
    args)
        case $words[1] in
            agent)
                _values 'agent subcommand' \
                    'start[start agent]' \
                    'stop[stop agent]' \
                    'lock[lock vault]' \
                    'unlock[unlock vault]' \
                    'status[show agent status]' \
                    && ret=0
                ;;
            audit)
                _values 'audit subcommand' 'show[show audit log]' && ret=0
                ;;
            auth)
                _values 'auth subcommand' \
                    'login[log in]' \
                    'logout[log out]' \
                    && ret=0
                ;;
            identities)
                _values 'identities subcommand' \
                    'add[link external identity]' \
                    'remove[unlink external identity]' \
                    'list[list identities]' \
                    && ret=0
                ;;
            keys)
                _values 'keys subcommand' \
                    'generate[generate new keypair]' \
                    'encrypt[encrypt data]' \
                    'decrypt[decrypt data]' \
                    'sign[sign data]' \
                    'verify[verify signature]' \
                    'list[list keys]' \
                    && ret=0
                ;;
            nodes)
                _values 'nodes subcommand' \
                    'add[add peer node]' \
                    'remove[remove peer node]' \
                    'connect[connect to peer]' \
                    'claim[claim node identity]' \
                    'list[list peers]' \
                    && ret=0
                ;;
            notifications)
                _values 'notifications subcommand' \
                    'send[send notification]' \
                    'read[read notification]' \
                    'inbox[list inbox]' \
                    && ret=0
                ;;
            secrets)
                _values 'secrets subcommand' \
                    'create[create secret]' \
                    'read[read secret]' \
                    'update[update secret]' \
                    'delete[delete secret]' \
                    'list[list secrets]' \
                    'share[share secret with peer]' \
                    && ret=0
                ;;
            vaults)
                _values 'vaults subcommand' \
                    'create[create vault]' \
                    'delete[delete vault]' \
                    'clone[clone vault from peer]' \
                    'pull[pull updates]' \
                    'push[push to peer]' \
                    'list[list vaults]' \
                    'share[share vault]' \
                    && ret=0
                ;;
            help)
                _describe -t commands 'subcommand' _polykey_cmds && ret=0
                ;;
        esac
        ;;
esac

return ret
