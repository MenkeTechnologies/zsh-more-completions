#compdef ppmtospu
# Documentation: man ppmtospu (Netpbm)
# Source: convert a PPM image to Spectrum 512 Smooshed (SPU) format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-d0 -d2 -d4)-d0[no dither]' \
    '(-d0 -d2 -d4)-d2[2x2 dither]' \
    '(-d0 -d2 -d4)-d4[4x4 dither]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
