#compdef meshctl bluez-meshctl
# _meshctl — BlueZ meshctl / bluez-meshctl (interactive REPL for the BlueZ Bluetooth Mesh stack; -c JSON config file, -p auto-provision mode, -t scan time seconds, -d destination address; inside the REPL: provision, scan, list, model, group, send, status)
# upstream: https://github.com/bluez/bluez (mesh/meshctl.c)
# Flags from bluez mesh/meshctl.c on tip.

_meshctl() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-c+[mesh JSON config]:file:_files -g "*.json"' \
        '-p[auto-provisioner mode]' \
        '-t+[scan time]:seconds:' \
        '-d+[destination address]:address:'
}

_meshctl "$@"
