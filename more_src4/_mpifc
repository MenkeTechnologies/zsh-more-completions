#compdef mpifc mpif77 mpif90 mpifort
# Documentation: https://manpages.debian.org/testing/mpich/mpif90.mpich.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream MPICH and Open MPI wrapper compiler docs. Covers
# both MPICH-style single-dash (-show, -compile_info) and Open MPI
# --showme:* variants since the binary name is shared.

# mpifc: MPI Fortran compiler wrapper (Intel/Cray name)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-show[show underlying compiler invocation]' \
  '-compile_info[show MPICH compile info]' \
  '-link_info[show MPICH link info]' \
  '-echo[echo commands]' \
  '-config=[MPICH config name]:name:' \
  '-cc=[underlying compiler override]:compiler:_command_names' \
  '-profile=[profiling library]:lib:' \
  '-static[use statically compiled MPI library]' \
  '-help[show help]' \
  '--showme[Open MPI: show command]' \
  '--showme:compile[Open MPI: show compile flags]' \
  '--showme:link[Open MPI: show link flags]' \
  '--showme:command[Open MPI: show underlying command]' \
  '--showme:incdirs[Open MPI: show include dirs]' \
  '--showme:libdirs[Open MPI: show library dirs]' \
  '--showme:libs[Open MPI: show libs]' \
  '--showme:version[Open MPI: show version]' \
  '--showme:help[Open MPI: show help]' \
  '*:Fortran source:_files -g "*.(f|F|f77|F77|f90|F90|f95|F95|f03|F03|f08|F08)(-.)"' && ret=0
return ret
