#compdef nixos-install
# Documentation: https://www.mankier.com/8/nixos-install
# Reference accessed: 2026-05-19
# Verified: nixos-install(8) manpage on mankier + nixpkgs source
# (nixos/modules/installer/tools/nixos-install.sh).

# nixos-install: install NixOS into target root
local curcontext="$curcontext" ret=1
_arguments -C \
  '*'{-v,--verbose}'[increase verbosity (repeatable)]' \
  '--root[treat directory as installation root (default /mnt)]:dir:_files -/' \
  '--system[pre-built system closure]:path:_files' \
  '--flake[build from flake URI]:flake:' \
  '--impure[allow impure flake evaluation]' \
  '--channel[channel derivation override]:drv:' \
  '*-I[add to Nix expression search path]:path:_files' \
  '--no-channel-copy[do not copy the channel]' \
  '(--no-root-password --no-root-passwd)--no-root-password[do not set root password]' \
  '(--no-root-password --no-root-passwd)--no-root-passwd[do not set root password]' \
  '--no-bootloader[do not install bootloader]' \
  '(--max-jobs -j)'{--max-jobs,-j}'[max parallel build jobs]:n:' \
  '--cores[CPU cores per job]:n:' \
  '--option[set Nix configuration option]:name:_default' \
  '--show-trace[print a stack trace on eval errors]' \
  '--keep-going[continue building dependencies after failure]' \
  '--help[show help]' && ret=0
return ret
