#compdef opusinfo
# _opusinfo — Opus opusinfo (display structural + tag info for Ogg Opus files: pre-skip, channel mapping, mapping family, bitrate, duration, OpusTags comments; -v verbose adds per-page packet stats, -q quiet shows only one-line summary)
# upstream: https://github.com/xiph/opus-tools
# Flags from opus-tools src/opusinfo.c on tip.

_opusinfo() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-q[quiet]' \
        '*:opus file:_files -g "*.(opus|ogg|ogv|oga|spx)"'
}

_opusinfo "$@"
