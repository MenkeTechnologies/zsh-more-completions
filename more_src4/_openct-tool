#compdef openct-tool
# Documentation: https://github.com/OpenSC/openct/blob/master/src/tools/openct-tool.c
# Reference accessed: 2026-05-20
# Verified: upstream src/tools/openct-tool.c source.

# openct-tool: smart card reader/cardstack debug tool
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'list:list all readers found'
  'atr:print ATR of card in selected reader'
  'wait:wait for card to be inserted'
  'rwait:wait for reader to be attached'
  'mf:try to select main folder of card'
  'read:dump memory of synchronous card'
)
_arguments -C \
  '-d[enable debugging (repeat to increase verbosity)]' \
  '-f[config file]:file:_files' \
  '-r[reader index]:n:' \
  '-s[slot of reader]:n:' \
  '-h[display help]' \
  '-v[display version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'openct-tool command' commands && ret=0 ;;
esac
return ret
