#compdef ntpq

local curcontext="$curcontext" state line ret=1

_arguments \
  '-4[force IPv4 DNS resolution]' \
  '-6[force IPv6 DNS resolution]' \
  '-a[authenticate requests]' \
  '-c[send command to server]:command' \
  '-d[enable debug output]' \
  '-i[run in interactive mode]' \
  '-n[output numeric addresses]' \
  '(-p --peers)'{-p,--peers}'[print list of peers]' \
  '-w[wide output format]' \
  '-u[use unconnected UDP socket]' \
  '(--help)--help[show help message]' \
  '(--version)--version[show version]' \
  '*:server host:_hosts' \
  && ret=0

return ret
