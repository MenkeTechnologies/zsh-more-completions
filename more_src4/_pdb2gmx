#compdef pdb2gmx gmx-pdb2gmx
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-pdb2gmx.html
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-f+[input PDB/GRO structure file]:input file:_files -g "*.(pdb|gro|g96)"' \
  '-o+[output structure file]:output file:_files -g "*.(gro|pdb|g96)"' \
  '-p+[output topology file]:topology file:_files -g "*.top"' \
  '-i+[output include topology file]:include file:_files -g "*.itp"' \
  '-n+[output index file]:index file:_files -g "*.ndx"' \
  '-q+[output cleaned PDB file]:cleaned pdb:_files -g "*.pdb"' \
  '-ff+[force field]:force field:' \
  '-water+[water model]:water model:(spc spce tip3p tip4p tip5p tips3p none)' \
  '-ignh[ignore hydrogen atoms in PDB file]' \
  '-missing[allow missing atoms in residues]' \
  '-v[verbose output]' \
  '-merge+[merge chains]:merge mode:(no all interactive)' \
  '-his[interactive histidine protonation assignment]' \
  '-ss[interactive disulfide bond assignment]' \
  '-chainsep+[chain separation method]:method:(id_or_ter id ter interactive)' \
  '-h[show help]' \
  '-version[show version]' \
  '-nice+[set nice level]:level:' && ret=0

return ret
