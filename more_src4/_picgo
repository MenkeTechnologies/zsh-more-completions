#compdef picgo
# Documentation: https://github.com/PicGo/PicGo-Core (src/plugins/commander + src/lib/Commander.ts)
# Reference accessed: 2026-05-29
# PicGo — image upload utility supporting many image-hosting services.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'upload:upload image(s) to the configured uploader'
  'use:select or switch the active image-hosting service or uploader'
  'install:install a PicGo plugin'
  'uninstall:uninstall a PicGo plugin'
  'update:update PicGo plugins'
  'config:edit/manage configuration settings'
  'set:set a configuration key'
  'setting:manage user settings'
  'configPath:print or manage the configuration file path'
  'proxy:configure proxy settings'
  'i18n:manage internationalization/language settings'
  'server:control the local upload server'
  'login:authenticate user credentials'
  'logout:terminate the user session'
  'uploader:manage uploader configuration'
  'help:show help for a subcommand'
)

local -a _global
_global=(
  '(-d --debug)'{-d,--debug}'[enable debug mode]'
  '(-s --silent)'{-s,--silent}'[enable silent mode]'
  '(-v --version)'{-v,--version}'[show version]'
  '(-h --help)'{-h,--help}'[show help]'
)

_arguments -C \
  $_global \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'picgo subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      upload)
        _arguments \
          $_global \
          '*:image file:_files -g "*.(png|jpg|jpeg|gif|webp|bmp|svg|ico|tiff|heic|avif)"' && ret=0
        ;;
      use)
        _arguments \
          $_global \
          ':uploader:(smms qiniu upyun tcyun github aliyun imgur)' && ret=0
        ;;
      install|uninstall|update)
        _arguments \
          $_global \
          '*:plugin name:' && ret=0
        ;;
      config|set|setting)
        _arguments \
          $_global \
          ':key:' \
          ':value:' && ret=0
        ;;
      configPath)
        _arguments \
          $_global \
          ':new config path:_files -g "*.json"' && ret=0
        ;;
      server)
        _arguments \
          $_global \
          '1:action:(start stop restart status)' \
          '--port=[server port]:port:' && ret=0
        ;;
      uploader|proxy|i18n|login|logout)
        _arguments $_global && ret=0
        ;;
    esac
    ;;
esac

return ret
