#compdef proftpd-init
# Documentation: LSB init.d wrapper for proftpd; LSB init-script actions per https://refspecs.linuxfoundation.org/LSB_5.0.0/LSB-Core-generic/LSB-Core-generic/iniscrptact.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start proftpd'
  'stop:stop proftpd'
  'restart:restart proftpd'
  'reload:reload configuration'
  'status:show status'
  'try-restart:restart if running'
  'force-reload:force reload'
)

_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'proftpd-init command' commands && ret=0 ;;
esac

return ret
