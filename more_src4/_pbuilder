#compdef pbuilder
# Documentation: https://manpages.debian.org/pbuilder
# Source: iplinux/pbuilder pbuilder — personal Debian package builder (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    '1:action:(--create create --update update --build build --clean clean --login login --execute execute --dumpconfig dumpconfig --debuild debuild help)' \
    '--basetgz=-[chroot tarball]:file:_files -g "*.{tgz,tar.gz}"' \
    '--basepath=-[chroot directory]:dir:_files -/' \
    '--buildplace=-[build directory]:dir:_files -/' \
    '--mirror=-[mirror URL]:url:_urls' \
    '--othermirror=-[additional apt sources line]:line:_default' \
    '--distribution=-[distribution]:dist:(unstable testing stable oldstable experimental)' \
    '--architecture=-[architecture]:arch:_default' \
    '--components=-[apt components]:components:(main contrib non-free non-free-firmware)' \
    '--debootstrap=-[debootstrap variant]:variant:(debootstrap qemu-debootstrap cdebootstrap)' \
    '*--debootstrapopts=-[debootstrap option]:option:_default' \
    '*--bindmounts=-[bind-mount path]:path:_files -/' \
    '*--aptconfdir=-[apt config dir]:dir:_files -/' \
    '*--debbuildopts=-[dpkg-buildpackage option]:opt:_default' \
    '--allow-untrusted[allow untrusted apt sources]' \
    '--save-after-login[save chroot after login]' \
    '--save-after-exec[save chroot after execute]' \
    '--debug[debug output]' \
    '--http-proxy=-[HTTP proxy URL]:url:_urls' \
    '--no-targz[do not use tarball]' \
    '--use-network[allow network during build]' \
    '--logfile=-[log file]:file:_files' \
    '--configfile=-[pbuilder config file]:file:_files' \
    '--inputfile=-[stdin for chroot command]:file:_files' \
    '*::action args:_default' \
    && ret=0

return ret
