#compdef pts-subscribe pts-unsubscribe
# Documentation: https://manpages.debian.org/pts-subscribe
# Source: debian/devscripts scripts/pts-subscribe.sh — subscribe to PTS by email and queue auto-unsubscribe via at(1) (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '--version[show version]' \
    '(-u --until)'{-u+,--until=}'[unsubscribe at time/duration (or 0/forever)]:until:_default' \
    '--forever[no auto-unsubscribe]' \
    '(--no-conf --noconf)'{--no-conf,--noconf}'[ignore conf files]' \
    '1:package:_default' \
    && ret=0

return ret
