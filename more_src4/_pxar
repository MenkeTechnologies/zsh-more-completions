#compdef pxar
# Documentation: https://pbs.proxmox.com/docs/pxar-tool.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pxar - tool for working with Proxmox File Archive (.pxar) archives
local curcontext="$curcontext" state line ret=1
local -a subcommands
subcommands=(
  'create:create a new .pxar archive'
  'extract:extract files from a .pxar archive'
  'list:list contents of a .pxar archive'
  'mount:mount a .pxar archive via FUSE'
  'help:show help for a subcommand'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd) _describe -t commands 'pxar subcommand' subcommands && ret=0 ;;
  args)
    case $line[1] in
      create)
        _arguments \
          '*--exclude=[exclude gitignore-style pattern]:pattern' \
          '--all-file-systems[do not cross filesystem boundaries]' \
          '--no-xattrs[skip extended attributes]' \
          '--no-fcaps[skip file capabilities]' \
          '--no-acls[skip ACLs]' \
          '1:archive file:_files -g "*.pxar"' \
          '*:source path:_files -/' && ret=0
        ;;
      extract)
        _arguments \
          '--target=[target directory]:dir:_directories' \
          '*--pattern=[restore pattern]:pattern' \
          '--files-from=[file with patterns]:file:_files' \
          '--no-xattrs[skip xattrs]' \
          '--no-fcaps[skip fcaps]' \
          '--no-acls[skip ACLs]' \
          '1:archive file:_files -g "*.pxar"' \
          '*:path:_directories' && ret=0
        ;;
      list)
        _arguments \
          '1:archive file:_files -g "*.pxar"' && ret=0
        ;;
      mount)
        _arguments \
          '--verbose[verbose output]' \
          '1:archive file:_files -g "*.pxar"' \
          '2:mount point:_directories' && ret=0
        ;;
    esac ;;
esac

return ret
