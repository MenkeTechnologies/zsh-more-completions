#compdef postgraphile
# Documentation: https://www.graphile.org/postgraphile/usage-cli/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
  '--plugins=[plugins to load before parsing CLI options]:plugins:'
  '(-c --connection)'{-c,--connection}'=[PostgreSQL connection string]:connection:'
  '(-C --owner-connection)'{-C,--owner-connection}'=[PostgreSQL owner connection string]:connection:'
  '(-s --schema)'{-s,--schema}'=[PostgreSQL schemas to use]:schemas:'
  '--websockets=[transports to use for websockets]:transports:'
  '--websocket-operations=[websocket operations allowed]:operations:'
  '--subscriptions[enable subscriptions]'
  '(-w --watch)'{-w,--watch}'[watch for schema changes]'
  '(-n --host)'{-n,--host}'=[host to bind to]:host:'
  '(-p --port)'{-p,--port}'=[port to bind to]:port:'
  '(-m --max-pool-size)'{-m,--max-pool-size}'=[max PostgreSQL connections]:size:'
  '(-r --default-role)'{-r,--default-role}'=[default PostgreSQL role]:role:'
  '--retry-on-init-fail[retry on init failure]'
  '(-j --dynamic-json)'{-j,--dynamic-json}'[use dynamic JSON]'
  '(-a --classic-ids)'{-a,--classic-ids}'[use classic global IDs]'
  '--simple-collections=[add simple collection support]:mode:(omit both only)'
  '--no-ignore-rbac[do not ignore RBAC]'
  '--no-ignore-indexes[do not ignore indexes]'
  '--include-extension-resources[include extension resources]'
  '--show-error-stack=[show error stack traces]:mode:(json string)'
  '--extended-errors=[extended error fields]:fields:'
  '--append-plugins=[plugins to append]:plugins:'
  '--prepend-plugins=[plugins to prepend]:plugins:'
  '--skip-plugins=[plugins to skip]:plugins:'
  '--read-cache=[read cache from path]:path:_files'
  '--write-cache=[write cache to path]:path:_files'
  '--export-schema-json=[export schema to JSON file]:file:_files -g "*.json"'
  '--export-schema-graphql=[export schema to GraphQL file]:file:_files -g "*.graphql"'
  '--sort-export[sort exported schema]'
  '(-q --graphql)'{-q,--graphql}'=[GraphQL endpoint path]:path:'
  '(-i --graphiql)'{-i,--graphiql}'=[GraphiQL endpoint path]:path:'
  '--enhance-graphiql[enhance GraphiQL with plugins]'
  '(-b --disable-graphiql)'{-b,--disable-graphiql}'[disable GraphiQL]'
  '(-o --cors)'{-o,--cors}'[enable CORS]'
  '(-l --body-size-limit)'{-l,--body-size-limit}'=[body size limit]:limit:'
  '--timeout=[request timeout]:ms:'
  '--cluster-workers=[number of cluster workers]:workers:'
  '--enable-query-batching[enable query batching]'
  '--disable-query-log[disable query logging]'
  '--allow-explain[allow EXPLAIN via HTTP]'
  '(-e --jwt-secret)'{-e,--jwt-secret}'=[JWT secret]:secret:'
  '--jwt-verify-algorithms=[JWT allowed algorithms]:algorithms:'
  '--jwt-verify-clock-tolerance=[JWT clock tolerance]:n:'
  '--jwt-verify-id=[JWT verify id]:id:'
  '--jwt-verify-ignore-expiration[JWT ignore expiration]'
  '--jwt-verify-ignore-not-before[JWT ignore not before]'
  '--jwt-verify-issuer=[JWT verify issuer]:issuer:'
  '--jwt-verify-subject=[JWT verify subject]:subject:'
  '--jwt-role=[JWT role claim path]:path:'
  '(-t --jwt-token-identifier)'{-t,--jwt-token-identifier}'=[JWT token identifier]:identifier:'
  '--token=[JWT token identifier alias]:identifier:'
  '--secret=[JWT secret alias]:secret:'
  '--jwt-audiences=[JWT audiences]:audiences:'
  '--legacy-functions-only[legacy functions only]'
  '--legacy-relations=[legacy relations mode]:mode:(omit deprecated only)'
  '--legacy-json-uuid[legacy JSON UUID]'
  '(-h --help)'{-h,--help}'[show help]'
  '--version[show version]'
)

_arguments -s -S $arguments
