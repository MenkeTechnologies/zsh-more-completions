#compdef msbar
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/msbar.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. EMBOSS msbar mutate sequence(s).
# Mutation operation values 0=None 1=Any 2=Insertions 3=Deletions 4=Changes
# 5=Duplications 6=Moves.

local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input sequence(s)]:sequence USA:_files' \
  '-count=[number of mutations per sequence]:n:' \
  '-point=[point-mutation operation]:op:(0 1 2 3 4 5 6)' \
  '-block=[block-mutation operation]:op:(0 1 2 3 4 5 6)' \
  '-codon=[codon-mutation operation]:op:(0 1 2 3 4 5 6)' \
  '-inframe[do codon and block operations in frame]' \
  '-minimum=[minimum size for block mutation]:n:' \
  '-maximum=[maximum size for block mutation]:n:' \
  '-outseq=[mutated sequence output file]:file:_files' \
  '*:sequence USA:_files' && ret=0
return ret
