#compdef passhole
# Documentation: source-direct extraction from upstream
# Evidlo/passhole passhole/passhole.py argparse `subparsers.add_parser(...)`
# calls (14 subcommands with 5 aliases: ls/rm/mv plus root short
# alias `ph`). Top-level + per-subcommand `add_argument()` flag
# sets extracted via source-walk.
# Reference accessed: 2026-05-30 via gh api.
# Evidlo passhole R136c — Python KeePass database manipulator with
# a `pass(1)`-like CLI surface but backed by a KeePass kdbx file
# instead of GPG-encrypted text files. The short alias `ph` also
# ships from this same Python module but is intentionally NOT
# included in this #compdef line because `ph` is already covered as
# a different binary (Pharo Smalltalk VM launcher) elsewhere in the
# corpus per anti-dup policy.

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '1:subcommand:((list\:list-entries ls\:alias-of-list add\:add-new-entry-or-group remove\:remove-an-entry rm\:alias-of-remove move\:move-an-entry-or-group mv\:alias-of-move show\:show-contents-of-an-entry edit\:edit-entry-or-group type\:select-via-dmenu-and-type init\:initialize-a-new-database grep\:list-entries-matching-regex eval\:run-arbitrary-python dump\:pretty-print-database-xml info\:print-database-information kill\:kill-background-process restart\:restart-background-process))' \
  '*::: :->subcmd' && ret=0

case "$state" in
  subcmd)
    case "${line[1]}" in
      list|ls)
        _arguments -s -S \
          '--username[show username in parentheses]' \
          '1:path:' && ret=0 ;;
      add)
        _arguments -s -S \
          '(-w --words)'{-w+,--words=}'[generate correct-horse-battery-staple password (default 6 words)]:length:' \
          '(-a --alphanumeric)'{-a+,--alphanumeric=}'[generate alphanumeric password (default 16 chars)]:length:' \
          '(-s --symbolic)'{-s+,--symbolic=}'[generate alphanumeric+symbolic password (default 16 chars)]:length:' \
          '--append=[string to append to generated password]:str:' \
          '--fields=[comma-separated list of custom fields]:fields:' \
          '1:path:' && ret=0 ;;
      remove|rm)
        _arguments -s -S '1:path:' && ret=0 ;;
      move|mv)
        _arguments -s -S \
          '1:source path:' \
          '2:destination path:' && ret=0 ;;
      show)
        _arguments -s -S \
          '--field=[show only the specified field]:field:' \
          '--totp[get TOTP code for the entry]' \
          '1:path:' && ret=0 ;;
      edit)
        _arguments -s -S \
          '--field=[edit the specified field]:field:' \
          '--set=[non-interactively set FIELD to VALUE]:field value:' \
          '--remove=[remove a field from the entry]:field:' \
          '1:path:' && ret=0 ;;
      type)
        _arguments -s -S \
          '--prog=[dmenu-like program for entry selection (default dmenu)]:program:_command_names -e' \
          '--tabbed[type username and password tab-separated]' \
          '--totp[type entry TOTP code]' \
          '--xdotool[use xdotool to type passwords]' \
          '--username[show username in parentheses during selection]' \
          '--duration=[per-key duration in seconds (default 0.012)]:sec:' \
          '--delay=[between-key delay in seconds (default 0.0)]:sec:' \
          '1:database name:' && ret=0 ;;
      init)
        _arguments -s -S \
          '--name=[name of the new database]:name:' \
          '--database=[path to the database file]:file:_files' \
          '--password=[database password (DANGER: visible in process list)]:password:' \
          '--keyfile=[path to a keyfile]:file:_files' && ret=0 ;;
      grep)
        _arguments -s -S '1:XSLT-style regex pattern:' && ret=0 ;;
      eval)
        _arguments -s -S \
          '(-j --json)'{-j,--json}'[JSON output (STR must be an expression)]' \
          '1:Python expression:' && ret=0 ;;
      dump|info)
        _arguments -s -S '1:database name:' && ret=0 ;;
      kill|restart)
        _arguments -s -S && ret=0 ;;
    esac
    ;;
esac

return ret
