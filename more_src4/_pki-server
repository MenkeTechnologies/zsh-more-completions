#compdef pki-server
# Documentation: https://github.com/dogtagpki/pki/blob/master/docs/manuals/man8/pki-server.8.md
# Reference accessed: 2026-05-16
# Verified: upstream docs/manuals/man8/pki-server.8.md.

# pki-server: Dogtag PKI server management dispatcher
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'instance:manage server instances'
  'subsystem:manage subsystems'
  'migrate:migrate config'
  'nuxwdog:nuxwdog setup'
  'cert:certificate operations'
  'ca:Certificate Authority ops'
  'kra:Key Recovery Authority ops'
  'ocsp:OCSP responder ops'
  'tks:TKS ops'
  'tps:TPS ops'
  'acme:ACME ops'
  'est:EST ops'
  'upgrade:upgrade subsystem'
)
_arguments -C \
  '--help[show help]' \
  '-d[debug output]' \
  '-v[verbose output]' \
  '1: :->cmd' \
  '*::arg:_files' && ret=0
case $state in
  cmd) _describe -t commands 'pki-server command' commands && ret=0 ;;
esac
return ret
