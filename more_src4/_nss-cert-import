#compdef nss-cert-import
# Documentation: https://github.com/dogtagpki/pki/blob/master/base/tools/src/main/java/com/netscape/cmstools/nss/NSSCertImportCLI.java
# Reference accessed: 2026-05-19
# Verified: Dogtag PKI `pki nss-cert-import` subcommand source.

# nss-cert-import: import certificate into NSS database (pki subcommand)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--cert=[certificate to import]:path:_files' \
  '--format=[certificate format]:format:(PEM DER)' \
  '--trust=[trust flags]:flags:' \
  '*:nickname:' && ret=0
return ret
