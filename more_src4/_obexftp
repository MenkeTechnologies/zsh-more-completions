#compdef obexftp
# obexftp — OBEX file transfer utility for Bluetooth/IrDA/USB

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-V,--version}'[show version]' \
  '-i[use IrDA transport]' \
  '-b[use Bluetooth transport with given address]:device address:' \
  '-B[set Bluetooth channel number]:channel:' \
  '-d[use given tty device]:device:_files -g "/dev/tty*"' \
  '-u[use USB transport with given interface number]:interface:' \
  '-t[use TCP transport with given host]:host:_hosts' \
  '-n[suppress OBEX body]' \
  '-H[use OBEX UUID]:uuid:' \
  '-S[use OBEX service UUID]:uuid:(PUSH FTP SYNC PBAP MAP)' \
  '-l[list directory]:path:' \
  '-c[change directory]:path:' \
  '-C[create directory]:path:' \
  '-g[get file from remote]:remote path:' \
  '-G[get file and delete from remote]:remote path:' \
  '-p[put file to remote]:local file:_files' \
  '-k[delete remote file]:remote path:' \
  '-o[set output file]:output file:_files' \
  '-m[move remote file]:source dest:' \
  '-X[get capability object]' \
  '-x[get extra info]' \
  '-v[be verbose]' \
  '-q[be quiet]'
