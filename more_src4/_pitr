#compdef pitr
# _pitr — Percona XtraDB Cluster point-in-time recovery sidecar (binlog collector + recoverer)
# upstream: https://github.com/percona/percona-xtradb-cluster-operator
# Source: cmd/pitr/main.go on tip; subcommand dispatcher (collect|recover) — runtime config is env-driven (caarlos0/env).

_pitr() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                'collect:tail and upload binlogs to object storage'
                'recover:replay binlogs from object storage for point-in-time restore'
            )
            _describe -t commands 'pitr command' subs
            ;;
    esac
}

_pitr "$@"
