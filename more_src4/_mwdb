#compdef mwdb
# _mwdb — CERT.PL MWDB malware-DB API client (CERT-Polska/mwdblib)
# upstream: https://github.com/CERT-Polska/mwdblib
# Subcommands from mwdblib/cli/{main,attribute,comment,fetch,get,link,list,login}.py (click).

_mwdb() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)--help[show help]' \
        '--api-url=[MWDB instance API URL]:url:' \
        '--config-path=[alternative config path]:file:_files' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'version:print mwdblib version'
                'server:print server URL and version'
                'login:set credentials'
                'logout:clear credentials'
                'attribute:manage object attributes'
                'comment:manage object comments'
                'fetch:fetch object content'
                'get:get object info'
                'link:link parent/child objects'
                'list:list objects'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                get)
                    _arguments '1:sub:(details parents children attributes)' \
                               '2:file-or-hash:_files'
                    ;;
                fetch) _arguments '1:hash:' ;;
            esac
            ;;
    esac
}

_mwdb "$@"
