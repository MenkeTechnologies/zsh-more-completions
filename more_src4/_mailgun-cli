#compdef mailgun-cli mailgun
# Documentation: https://github.com/tekwrks/mailgun-cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mailgun-cli: send mail through Mailgun HTTP API
local curcontext="$curcontext" ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--api-key=[Mailgun API key]:key:' \
  '--domain=[Mailgun domain]:domain:' \
  '--from=[sender address]:addr:' \
  '--to=[recipient addresses (comma separated)]:addr:' \
  '--cc=[CC addresses (comma separated)]:addr:' \
  '--bcc=[BCC addresses (comma separated)]:addr:' \
  '--subject=[message subject]:text:' \
  '-c+[YAML config file]:file:_files' \
  '--config=[YAML config file]:file:_files' \
  '--plain=[plain text mustache template]:file:_files' \
  '--html=[HTML mustache template]:file:_files' \
  '*:key=value pair:' && ret=0
return ret
