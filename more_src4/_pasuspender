#compdef pasuspender
# Documentation: https://manpages.debian.org/pasuspender.1
# Source: PulseAudio — temporarily suspend the daemon while a non-PA-aware program (e.g. JACK) runs.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '(-s --server)'{-s+,--server=}'[sound server to connect to]:server:' \
    '*:command to run:_command_names -e' \
    && ret=0

return ret
