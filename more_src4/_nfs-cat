#compdef nfs-cat
# Documentation: https://github.com/sahlberg/libnfs/blob/master/utils/nfs-cat.c
# Reference accessed: 2026-05-17
# Verified: libnfs utils/nfs-cat.c — takes one positional NFS URL.
# Removed from prior file: bogus man.archlinux.org search URL;
# wrong arg description (this takes an nfs:// URL, not a local file).

# nfs-cat: print contents of a file served over NFS (positional URL)
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:nfs:// URL:' && ret=0
return ret
