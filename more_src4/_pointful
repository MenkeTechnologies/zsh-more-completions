#compdef pointful
# Documentation: https://hackage.haskell.org/package/pointful
# Reference accessed: 2026-05-20
# Verified: upstream Hackage page documents only positional Haskell
# expression usage; no documented CLI flags. STUB.

local curcontext="$curcontext" ret=1

_arguments -C \
  '*:haskell expression:' && ret=0

return ret
