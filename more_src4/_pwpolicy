#compdef pwpolicy
# Documentation: pwpolicy -h (macOS)
# Source: query and set user/global password policies via Open Directory.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local context state line state_descr
local -a verbs
verbs=(
    'getglobalpolicy:get global policies (deprecated)'
    'setglobalpolicy:set global policies (deprecated)'
    'getpolicy:get user policies (deprecated)'
    'get-effective-policy:get combined global+user policies (deprecated)'
    'setpolicy:set user policies (deprecated)'
    'setpassword:set new password for a user'
    'enableuser:enable a disabled user account'
    'disableuser:disable a user account'
    'getglobalhashtypes:list password hash types stored by default'
    'setglobalhashtypes:edit list of password hash types stored by default'
    'gethashtypes:list password hashes stored for a user account'
    'sethashtypes:edit list of password hashes for a user account'
    'getaccountpolicies:get account policies'
    'setaccountpolicies:set account policies'
    'clearaccountpolicies:clear account policies'
    'removeaccountpolicies:remove account policies'
)

_arguments -C -s \
    '(- *)-h[show help]' \
    '-v[verbose]' \
    '-a+[authenticator name]:authenticator:_users' \
    '-p+[password (omit for secure prompt)]:password:' \
    '-u+[user account name]:user:_users' \
    '-c+[computer account name]:computer:' \
    '-n+[directory node to search]:node:' \
    '1:command:->verbs' \
    '*:command-arg:' \
    && ret=0

case $state in
    verbs) _describe -t verbs command verbs && ret=0 ;;
esac

return ret
