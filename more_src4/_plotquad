#compdef plotquad
# Documentation: https://astrometry.net
# Source: dstndstn/astrometry.net man/plotquad.1 — plot matched quads on an image (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-I+[input image file]:file:_files' \
    '-p[input file is PPM]' \
    '-P[output PPM]' \
    '-C+[quad color r:g:b]:color:_default' \
    '-b+[background color r:g:b]:color:_default' \
    '-c[fill quads]' \
    '-W+[output width]:n:_default' \
    '-H+[output height]:n:_default' \
    '-w+[line width]:n:_default' \
    '-R[render shape]' \
    '-o+[line opacity]:n:_default' \
    '-d+[quad dim level]:n:_default' \
    '-s+[scale image coordinates]:n:_default' \
    '-m+[match file containing quads]:file:_files' \
    && ret=0

return ret
