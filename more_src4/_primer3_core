#compdef primer3_core
# Documentation: https://primer3.org/manual.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Notes: primer3 manual allows either single- or double-dash forms and either
# `=` or space separators; --io_version only legal value is 4; no --dump_args
# is documented (removed from prior file as fabricated).

# primer3_core: PCR primer/probe design (Boulder-IO format on stdin)
local curcontext="$curcontext" ret=1

_arguments -C \
  '--about[print release info]' \
  '--format_output[user-oriented output]' \
  '--default_version=[input file default format version]:version:(1 2)' \
  '--io_version=[Boulder-IO version (4 only)]:version:(4)' \
  '--strict_tags[fail on unrecognized input tags]' \
  '--p3_settings_file=[read settings from file]:settings file:_files' \
  '--echo_settings_file[echo settings file contents to output]' \
  '--output=[write output to file]:file:_files' \
  '--error=[write errors to file]:file:_files' \
  '*:input boulder-IO file:_files' && ret=0

return ret
