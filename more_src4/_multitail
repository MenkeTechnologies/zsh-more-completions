#compdef multitail
# Documentation: https://www.mankier.com/1/multitail
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for multitail - multiple log tail viewer

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-i[add file to tail]:file:_files' \
  '-I[add file to tail in same window]:file:_files' \
  '-iw[add file with check interval]:file:' \
  '-Iw[merge wildcard monitoring]:file:' \
  '-l[execute command and tail output]:command:' \
  '-L[execute command in same window]:command:' \
  '-j[read from stdin]' \
  '-J[read from stdin in same window]' \
  '--mergeall[merge all windows]' \
  '--no-mergeall[stop merging files into one window]' \
  '--no-repeat[suppress repeated lines]' \
  '--mark-interval+[print mark line every x seconds]:seconds:' \
  '-q[check path for new files at interval]:interval:' \
  '-Q[check path and merge to one window]:interval:' \
  '--new-only[create windows only for new files]' \
  '--closeidle+[close idle windows after x seconds]:seconds:' \
  '-a[write filtered output to file]:file:_files' \
  '-A[write unfiltered output to file]:file:_files' \
  '-g[send filtered output to command]:command:' \
  '-G[send unfiltered output to command]:command:' \
  '-S[prepend merged output with subwindow number]' \
  '-t[display custom title in statusline]:title:' \
  '-T[add timestamp to marker line]' \
  '--retry[keep retrying inaccessible file]' \
  '--retry-all[retry all inaccessible files]' \
  '-s[split vertically]:columns:' \
  '-sw[set widths for split]:widths:' \
  '-sn[set windows per column]:windows:' \
  '-wh[set window height]:height:' \
  '-n[set initial number of lines]:lines:' \
  '-N[set initial number of lines for all]:lines:' \
  '-r[restart command after exit]:interval:' \
  '-R[restart with diff display]:interval:' \
  '-rc[restart and clear window]:interval:' \
  '-Rc[restart with diff and clear]:interval:' \
  '-f[follow filename]' \
  '--follow-all[follow filenames for all]' \
  '-d[do not update statusline]' \
  '-D[do not display statusline]' \
  '-du[place statusline above data window]' \
  '-z[hide closed windows]' \
  '-u[screen update interval]:seconds:' \
  '-m[set buffer size in lines]:lines:' \
  '-mb[set scrollback buffer in bytes]:bytes:' \
  '-M[set buffer size for all]:lines:' \
  '-p[set line wrap mode]:mode:' \
  '-P[set line wrap for all]:mode:' \
  '-e[regex filter for next file]:regex:' \
  '-ex[regex with command on match]:regex:' \
  '-eX[regex and pass matching substring]:regex:' \
  '-ec[regex and display matches]:regex:' \
  '-eC[regex and show inverted matches]:regex:' \
  '-E[apply regex to all]:regex:' \
  '-v[negate next regex]' \
  '-cS[apply color scheme to next file]:scheme:' \
  '-CS[apply color scheme to all]:scheme:' \
  '-cs[colorize next file (syslog)]' \
  '-Cs[colorize all (syslog)]' \
  '-c[colorize next file]' \
  '-C[colorize all]' \
  '-cf[colorize by field for next file]:field:' \
  '-Cf[colorize by field for all]:field:' \
  '-ci[use specific color]:color:' \
  '-cT[interpret terminal codes (ANSI)]' \
  '-c-[disable colors for next file]' \
  '-C-[disable colors for all]' \
  '-ts[add timestamp to each line]' \
  '-Z[set color attributes for marker line]:color:' \
  '-w[disable colors]' \
  '-b[set TAB width]:n:' \
  '--config+[custom configuration file]:file:_files' \
  '-F[use custom config file]:file:_files' \
  '--no-load-global-config[skip global config]' \
  '-x[set xterm title with format]:format:' \
  '-o[process config item]:item:' \
  '--label+[prepend text to each line]:text:' \
  '--basename[show only filename in statusline]' \
  '--beep-interval+[beep every x lines]:n:' \
  '-H[show heartbeat signal]' \
  '*:file:_files'
