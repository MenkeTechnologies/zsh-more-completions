#compdef pkfilter
# pkfilter — spatial and spectral filtering of raster images (pktools)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-i,--input}'=[input raster file]:input file:_files' \
  {-o,--output}'=[output raster file]:output file:_files' \
  '-f+[filter type]:filter:(mean median var min max sum mode stdev smooth dilate erode open close)' \
  '-dx+[filter size in x]:size:' \
  '-dy+[filter size in y]:size:' \
  '*-b+[band to filter]:band number:' \
  '-of+[output format]:format:(GTiff HFA)' \
  '*-co+[creation option]:option:' \
  '-ot+[output data type]:type:(Byte Int16 UInt16 Int32 UInt32 Float32 Float64)' \
  '-nodata+[nodata value]:value:' \
  '-circ[use circular filter window]' \
  '-class+[class to filter]:class:' \
  '-pad+[padding method]:padding:(symmetric replicate zero)' \
  '-d+[dimension for spectral filtering]:dimension:' && ret=0

return ret
