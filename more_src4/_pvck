#compdef pvck
# _pvck — LVM2 pvck check PV metadata CLI (Red Hat / LVM2 team, C); custom argparse
# upstream: https://github.com/lvmteam/lvm2

_pvck() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--dump=+[dump area]:a:(metadata metadata_search metadata_all metadata_area headers)' \
        '--repair[repair pv]' \
        '--repairtype=+[repair type]:t:(pv_header metadata label)' \
        '--labelsector=+[label sector]:n:' \
        '--metadatafile=+[metadata output file]:file:_files' \
        '-f+[metadata output file]:file:_files' \
        '--file=+[metadata output file]:file:_files' \
        '--settings=+[settings]:list:' \
        '-d[debug]' \
        '--debug[debug]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-y[yes]' \
        '--yes[yes]' \
        '--config=+[config string]:str:' \
        '--devices=+[devices]:list:' \
        '--devicesfile=+[devices file]:file:_files' \
        '*:device:_files'
}

_pvck "$@"
