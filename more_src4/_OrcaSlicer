#compdef OrcaSlicer orca-slicer
# _OrcaSlicer — 3D printing slicer fork of BambuStudio (SoftFever/OrcaSlicer)
# upstream: https://github.com/SoftFever/OrcaSlicer

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--info[write system info]' \
  '(-o --output)'{-o,--output}'=[output file]:file:_files' \
  '--export-stl[export STL]' \
  '--export-3mf[export 3MF]' \
  '--export-gcode[export G-code]' \
  '--slice[slice the model]' \
  '--repair[try to repair non-manifold meshes]' \
  '--load=[load config file]:file:_files' \
  '--save=[save config to file]:file:_files' \
  '--loglevel=[log level]:level:(0 1 2 3 4 5)' \
  '--datadir=[path to data directory]:dir:_files -/' \
  '--single-instance[allow only one running instance]' \
  '--no-gui[force command-line mode]' \
  '*:input file:_files -g "*.(stl|obj|amf|3mf|step|stp)"'
