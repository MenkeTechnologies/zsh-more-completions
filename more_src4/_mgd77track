#compdef mgd77track
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/mgd77/mgd77track.html
# Source: GenericMappingTools/gmt supplements/mgd77 — plot MGD77 cruise tracks on a map.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-J+[projection]:proj:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-A+[annotate tracks (cruise ID / file)]:opts:_default' \
    '-B+[basemap frame/axes]:basemap:_default' \
    '-Da+[exclude data before start date]:date:_default' \
    '-Db+[exclude data after stop date]:date:_default' \
    '-F[disable error bit flag for MGD77+]' \
    '-G+[track breaks (distance or time gaps)]:opts:_default' \
    '-I+[exclude file formats]:formats:(a c m t)' \
    '-L+[time/distance markers + ticks]:opts:_default' \
    '-Sa+[skip near-departure-port data]:distance:_default' \
    '-Sb+[skip far-from-port data]:distance:_default' \
    '-T+[time/distance marker attributes]:opts:_default' \
    '-U+[GMT timestamp logo]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-W+[trackline pen]:pen:_default' \
    '-X+[X offset of plot origin]:offset:_default' \
    '-Y+[Y offset of plot origin]:offset:_default' \
    '-K[multi-page: more pages follow]' \
    '-O[multi-page: this is overlay]' \
    '-P[portrait orientation]' \
    '-p+[perspective view]:perspective:_default' \
    '-t+[transparency percent]:pct:_default' \
    '*:GEODAS-ID or cruise file:_files' \
    && ret=0

return ret
