#compdef pmsignal
# _pmsignal — cross-platform signal/event sender for PCP utilities (performancecopilot/pcp)
# upstream: https://github.com/performancecopilot/pcp
# Flags from src/pmsignal/pmsignal.sh (pmgetopt usage block).

_pmsignal() {
    _arguments \
        '(- *)--help[show help]' \
        '(-a --all)'{-a,--all}'[send signal to all named processes (killall mode)]' \
        '(-l --list)'{-l,--list}'[list available signals]' \
        '(-n --dry-run)'{-n,--dry-run}'[list processes that would be affected]' \
        '(-p --program)'{-p,--program}'[extract PIDs from $PCP_RUN_DIR]' \
        '(-s --signal)'{-s+,--signal=}'[signal to send]:sig:(HUP USR1 USR2 TERM KILL)' \
        '*:PID or name:_pids'
}

_pmsignal "$@"
