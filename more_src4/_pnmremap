#compdef pnmremap
# Documentation: man pnmremap (Netpbm)
# Source: remap a Netpbm image to a given colormap palette.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-mapfile=[palette file]:file:_files -g "*.(ppm|pnm|pam)"' \
    '(-floyd -fs -nfloyd -nofs)'{-floyd,-fs}'[Floyd-Steinberg dither]' \
    '(-floyd -fs -nfloyd -nofs)'{-nfloyd,-nofs}'[no Floyd-Steinberg dither]' \
    '(-norandom -randomseed)-norandom[no random dithering]' \
    '(-norandom -randomseed)-randomseed=[random seed]:n:' \
    '-firstisdefault[use first palette entry for missing colors]' \
    '-missingcolor=[color used for unmatched pixels]:color:' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
