#compdef pmqtest
# Documentation: https://wiki.linuxfoundation.org/realtime/documentation/howto/tools/rt-tests
# Source: rt-tests src/pmqtest/pmqtest.c — POSIX message queue round-trip latency.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-\?,--help}'[show help]' \
    '(-a --affinity)'{-a+,--affinity=}'[CPU affinity (NUM pins all to CPU NUM)]:cpu:_default' \
    '(-b --breaktrace)'{-b+,--breaktrace=}'[send break trace when latency > USEC]:usec:_default' \
    '(-d --distance)'{-d+,--distance=}'[thread interval distance (us, default 500)]:us:_default' \
    '(-f --forcetimeout)'{-f+,--forcetimeout=}'[force mq_timedreceive timeout (requires -T)]:timeout:_default' \
    '(-i --interval)'{-i+,--interval=}'[base thread interval (us, default 1000)]:us:_default' \
    '(-l --loops)'{-l+,--loops=}'[number of loops (0=endless)]:n:_default' \
    '(-p --prio)'{-p+,--prio=}'[priority]:prio:_default' \
    '(-S --smp)'{-S,--smp}'[SMP testing (-a -t + same priority)]' \
    '(-t --threads)'{-t+,--threads=}'[threads per processor (NUM=count)]:n:_default' \
    '(-T --timeout)'{-T+,--timeout=}'[use mq_timedreceive with timeout (s)]:seconds:_default' \
    && ret=0

return ret
