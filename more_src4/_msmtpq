#compdef msmtpq
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-r --read)'{-r,--read}'[read/show the mail queue]' \
  '(-R --run)'{-R,--run}'[run/flush the mail queue]' \
  '(-d --display)'{-d,--display}'[display a queued mail]:mail-id' \
  '(-p --purge)'{-p,--purge}'[purge a queued mail]:mail-id' \
  '(-a --all)'{-a,--all}'[process all queued mails]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0
return ret
