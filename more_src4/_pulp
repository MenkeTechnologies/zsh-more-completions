#compdef pulp
# Documentation: https://pulpproject.org/pulp_cli/
# Reference accessed: 2026-05-20
# Verified: upstream Pulp CLI documentation at the URL above.

# pulp: Pulp 3 command-line interface (pulp-cli)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--base-url=[Pulp server address]:url:' \
  '--username=[authentication username]:user:' \
  '--password=[authentication password]:password:' \
  '--cert=[client certificate for SSL/TLS]:file:_files' \
  '--key=[private key for client certificate]:file:_files' \
  '--verify-ssl=[verify SSL certificate]:bool:(true false)' \
  '--format=[output format]:format:(json yaml none)' \
  '--background[run operations in background]' \
  '--refresh-api[refresh API schema]' \
  '--config=[configuration file]:file:_files' \
  '*::args:_default' && return 0
