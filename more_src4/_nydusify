#compdef nydusify
# _nydusify — convert OCI images to Nydus format (dragonflyoss/nydus)
# upstream: https://github.com/dragonflyoss/nydus
# Subcommands from contrib/nydusify/cmd/nydusify.go (urfave/cli).

_nydusify() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--log-level=[log level]:level:(panic fatal error warning info debug trace)' \
        '--log-file=[log output file]:file:_files' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_nydusify_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                convert)
                    _arguments \
                        '--source=[source OCI image reference]:image:' \
                        '--source-archive=[path to source OCI image-layout tar]:file:_files' \
                        '--target=[target Nydus image reference]:image:' \
                        '--target-archive=[path to target OCI image-layout tar]:file:_files' \
                        '--target-suffix=[append suffix to source ref to derive --target]:suffix:' \
                        '--source-backend-type=[source blob storage backend]:backend:(oss s3 localfs)' \
                        '--source-backend-config=[source backend JSON config string]:json:' \
                        '--source-insecure[skip TLS verification on source registry]' \
                        '--target-insecure[skip TLS verification on target registry]' \
                        '--backend-type=[blob storage backend]:backend:(oss s3 localfs)' \
                        '--backend-config=[backend JSON config string]:json:' \
                        '--backend-config-file=[backend JSON config file]:file:_files -g "*.json"' \
                        '--backend-force-push[push blobs even if they already exist]' \
                        '--build-cache=[cache image to accelerate conversion]:image:' \
                        '--build-cache-tag=[use $target\:tag as cache image]:tag:' \
                        '--build-cache-version=[cache image version filter]:version:' \
                        '--build-cache-insecure[skip TLS verification on cache registry]' \
                        '--build-cache-max-records=[max cache records in a cache image]:n:' \
                        '--chunk-dict=[chunk dict expression for deduplication]:expr:' \
                        '--chunk-dict-insecure[skip TLS on dict registry]' \
                        '--merge-platform[emit an OCI image index with both OCI and Nydus manifests]' \
                        '--all-platforms[convert all platforms]' \
                        '--platform=[platforms to convert (comma-separated)]:platforms:' \
                        '--oci-ref[convert to OCI-referenced Nydus zran image]' \
                        '--with-referrer[record source-image referrer in the artifact]' \
                        '--docker-to-oci[rewrite Docker media types to OCI media types]' \
                        '--backward[reverse-convert Nydus back to OCI (experimental)]' \
                        '--fs-version=[Nydus image format version]:version:(5 6)' && ret=0 ;;
                check)
                    _arguments \
                        '--source=[source OCI image reference]:image:' \
                        '--target=[Nydus image reference to verify]:image:' \
                        '--source-insecure[skip TLS on source registry]' \
                        '--target-insecure[skip TLS on target registry]' && ret=0 ;;
                copy)
                    _arguments \
                        '--source=[source image]:image:' \
                        '--target=[target image]:image:' \
                        '--all-platforms[copy all platforms]' \
                        '--platform=[platforms to copy]:platforms:' && ret=0 ;;
                mount|view)
                    _arguments \
                        '--target=[Nydus image reference]:image:' \
                        '--mount-point=[mount point]:dir:_files -/' && ret=0 ;;
                commit)
                    _arguments \
                        '--container=[container id to commit]:id:' \
                        '--target=[committed Nydus image reference]:image:' && ret=0 ;;
                optimize)
                    _arguments \
                        '--source=[source Nydus image]:image:' \
                        '--target=[optimized Nydus image]:image:' && ret=0 ;;
                pack|generate-chunkdict|export-blobs) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_nydusify_commands] )) ||
_nydusify_commands() {
    local -a commands
    commands=(
        'convert:convert an OCI image to a Nydus image'
        'check:verify a converted Nydus image is consistent with its source'
        'copy:copy an OCI / Nydus image between registries'
        'mount:mount a Nydus image as a FUSE filesystem'
        'view:view the contents of a Nydus image without mounting'
        'commit:commit a running container into a Nydus image'
        'optimize:optimize an existing Nydus image (re-chunk, dedup, prefetch)'
        'pack:pack a directory into a Nydus image'
        'generate-chunkdict:generate a chunk dictionary from sample images'
        'export-blobs:export blobs from a Nydus image to a directory'
    )
    _describe -t commands 'nydusify command' commands
}

_nydusify "$@"
