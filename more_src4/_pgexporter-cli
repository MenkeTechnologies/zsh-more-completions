#compdef pgexporter-cli
# _pgexporter-cli — administrative CLI for pgexporter (pgexporter/pgexporter)
# upstream: https://github.com/pgexporter/pgexporter
# Flags & commands from src/cli.c (getopt_long + command_table).

_pgexporter-cli() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-?,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.conf"' \
        '(-h --host)'{-h+,--host=}'[pgexporter host or socket dir]:host:_hosts' \
        '(-p --port)'{-p+,--port=}'[pgexporter port]:port:' \
        '(-U --user)'{-U+,--user=}'[admin user]:user:' \
        '(-P --password)'{-P+,--password=}'[admin password]:pass:' \
        '(-L --logfile)'{-L+,--logfile=}'[log file path]:file:_files' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '(-F --format)'{-F+,--format=}'[output format]:fmt:(text json raw)' \
        '(-C --compress)'{-C+,--compress=}'[compress format]:fmt:(gz zstd lz4 bz2 none)' \
        '(-E --encrypt)'{-E+,--encrypt=}'[encrypt mode]:mode:(aes aes-256 aes-192 aes-128 none)' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'ping:check pgexporter responsiveness'
                'shutdown:shut down pgexporter'
                'status:print pgexporter status'
                'conf:configuration commands'
                'clear:clear runtime state'
                'reset:reset metrics'
                'reload:reload configuration'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                status) _arguments '1:subcommand:(details)' ;;
                conf)   _arguments '1:subcommand:(reload get set ls)' ;;
            esac
            ;;
    esac
}

_pgexporter-cli "$@"
