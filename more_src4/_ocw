#compdef ocw
# Documentation: https://github.com/olliforbrands/OCW-CLI
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: ocw is an OpenCode Worker CLI (bash script). Multiple tools use the name "ocw"
# (groverlab/ocw is a microfluidic valve control language with no canonical CLI flag
# documentation). Provide a minimal stub covering documented subcommands.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'delegate:assign bounded tasks to OpenCode Go workers'
  'explore:inspect codebase areas cheaply'
  'review:analyze diffs for issues'
  'patch:draft isolated fixes'
  'scan:map repository flows'
  'cheap:quick summaries'
  'init:bootstrap project config'
  'setup:install project files and agents'
  'config:manage settings'
  'doctor:diagnose environment issues'
  'bridge:manage OpenCode Go bridge proxy'
  'keys:store and rotate API credentials'
  'last:show most recent run'
  'show:display worker output'
  'verdict:final review gate'
  'audit:quality checks'
  'apply:safe patch application'
  'bench:model performance testing'
  'tournament:multi-model comparison'
  'batch:run multiple tasks'
  'eval:lightweight evaluation'
  'pr:GitHub PR analysis'
  'mcp:Model Context Protocol server'
  'memory:project notes storage'
  'policy:compliance gates'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--model=[override model selection]:model:' \
  '--worktree[isolated patch mode]' \
  '--attach[connect to backend server]' \
  '--json[machine-readable output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'ocw command' commands && ret=0 ;;
  (args) _files && ret=0 ;;
esac

return ret
