#compdef parcel-cli
# _parcel-cli — Parcel zero-config web bundler CLI alias (Parcel team, JavaScript/Rust); custom argparse
# upstream: https://github.com/parcel-bundler/parcel

_parcel-cli() {
    local -a sub=(
        'serve:run dev server'
        'watch:watch and build'
        'build:production build'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--cache-dir=+[cache dir]:dir:_files -/' \
        '--no-cache[no cache]' \
        '--no-content-hash[no content hash]' \
        '--no-source-maps[no sourcemaps]' \
        '--no-autoinstall[no autoinstall]' \
        '--no-optimize[no optimize]' \
        '--no-scope-hoist[no scope hoisting]' \
        '--config=+[config file]:file:_files' \
        '--reporter=+[reporter]:list:' \
        '--target=+[target]:list:' \
        '--profile[enable profiling]' \
        '--log-level=+[log level]:level:(none error warn info verbose)' \
        '--no-error-on-fail[no error on fail]' \
        '--trace[enable tracing]' \
        '--detailed-report=+[detailed report n]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'parcel subcommand' sub
            _files ;;
        args)
            case $words[1] in
                serve) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--host=+[host]:host:_hosts' \
                    '--public-url=+[public url]:url:_urls' \
                    '--open=+[open browser]:str:' \
                    '-o+[open browser]:str:' \
                    '--https[https]' \
                    '--cert=+[ssl cert]:file:_files' \
                    '--key=+[ssl key]:file:_files' \
                    '--hmr-port=+[hmr port]:port:' \
                    '--hmr-host=+[hmr host]:host:_hosts' \
                    '--no-hmr[no hmr]' \
                    '--lazy[lazy mode]' \
                    '*:input:_files' ;;
                watch|build) _arguments \
                    '--dist-dir=+[dist dir]:dir:_files -/' \
                    '--public-url=+[public url]:url:_urls' \
                    '--no-cache[no cache]' \
                    '--watch-for-stdin[watch for stdin]' \
                    '*:input:_files' ;;
            esac
            ;;
    esac
}

_parcel-cli "$@"
