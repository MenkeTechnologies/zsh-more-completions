#compdef purgecss
# Documentation: https://purgecss.com/CLI.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for purgecss - Remove unused CSS

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-css --css)'{-css,--css}'[glob of CSS files]:file:_files -g "*.css"' \
  '(-con --content)'{-con,--content}'[glob of content files]:file:_files' \
  '(-o --output)'{-o,--output}'[output directory]:directory:_directories' \
  '(-c --config)'{-c,--config}'[config file]:file:_files' \
  '(-s --safelist)'{-s,--safelist}'[classes to keep]:class:' \
  '(-b --blocklist)'{-b,--blocklist}'[selectors to remove]:selector:' \
  '(-font --font-face)'{-font,--font-face}'[remove unused @font-face rules]' \
  '(-keyframes --keyframes)'{-keyframes,--keyframes}'[remove unused @keyframes rules]' \
  '(-v --variables)'{-v,--variables}'[remove unused CSS variables]' \
  '(-rejected --rejected)'{-rejected,--rejected}'[output rejected selectors]' \
  '(-rejected-css --rejected-css)'{-rejected-css,--rejected-css}'[output rejected CSS]' \
  '(-k --skippedContentGlobs)'{-k,--skippedContentGlobs}'[glob patterns to skip]:glob:' \
  '(-p --preserve-paths)'{-p,--preserve-paths}'[maintain folder hierarchy in output]'
