#compdef perfused
# Documentation: man perfused(8)
# Source: netbsd/src usr.sbin/perfused — FUSE-to-PUFFS translation daemon (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d+[debug output types]:types:(puffs fuse dump fh reclaim readdir requeue sync)' \
    '-f[run in foreground]' \
    '-i+[use socket from file descriptor]:fd:_default' \
    '-s[debug output only on SIGINFO]' \
    && ret=0

return ret
