#compdef postgrest
# Documentation: https://postgrest.org/en/stable/references/configuration.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for postgrest - REST API server for PostgreSQL databases

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Display help information]' \
  '(-v --version)'{-v,--version}'[Show version information]' \
  '--dump-config[Output configuration details]' \
  '--dump-schema[Export schema information]' \
  '--example[Display all possible configuration parameters]' \
  '*:config file:_files -g "*.conf"'
