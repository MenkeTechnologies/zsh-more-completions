#compdef nsight-compute nv-nsight-cu nv-nsight-cu-cli
# _nsight-compute — NVIDIA Nsight Compute CUDA kernel-level profiler GUI launcher and CLI launcher (NVIDIA team, C++); custom argparse
# upstream: https://developer.nvidia.com/nsight-compute

_nsight-compute() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--mode=+[mode]:m:(launch attach replay)' \
        '--target-processes=+[scope]:s:(application-only all)' \
        '--profile=+[profile name]:str:' \
        '--set=+[set name]:s:(basic detailed full source-counters MemoryWorkloadAnalysis WarpStateStatistics ComputeWorkloadAnalysis InstructionStats SchedulerStats SpeedOfLight LaunchStats Occupancy SourceCounters)' \
        '--section=+[section]:str:' \
        '--sections=+[sections csv]:str:' \
        '--metrics=+[metrics csv]:str:' \
        '-c+[count of kernels]:n:' \
        '--launch-count=+[count of kernels]:n:' \
        '--launch-skip=+[N]:n:' \
        '--launch-skip-before-match=+[N]:n:' \
        '--kernel-id=+[id]:str:' \
        '--kernel-name=+[name regex]:str:' \
        '-k+[name regex]:str:' \
        '--kernel-name-base=+[mode]:m:(function demangled mangled)' \
        '--devices=+[device id csv]:str:' \
        '--target-arguments=+[args]:str:' \
        '--working-directory=+[work dir]:dir:_files -/' \
        '--export=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--force-overwrite[force overwrite]' \
        '--csv[CSV output]' \
        '--quiet[quiet]' \
        '--verbose[verbose]' \
        '--check-exit-code[check exit code]' \
        '--apply-rules=+[bool]:b:(yes no)' \
        '--rule=+[rule]:str:' \
        '--print-summary=+[mode]:m:(none aggregated per-kernel)' \
        '--page=+[page]:p:(details source raw summary)' \
        '--list-sections[list sections]' \
        '--list-rules[list rules]' \
        '--list-sets[list sets]' \
        '--list-metrics[list metrics]' \
        '--profile-from-start=+[bool]:b:(yes no)' \
        '--replay-mode=+[mode]:m:(kernel application range)' \
        '--app-replay-buffer=+[mode]:m:(none stream)' \
        '--cache-control=+[mode]:m:(all none l1 l2)' \
        '--clock-control=+[mode]:m:(base none)' \
        '--call-stack[enable call stack]' \
        '--nvtx[enable NVTX]' \
        '--cudart-replay[CUDART replay]' \
        '--import-source=+[bool]:b:(yes no)' \
        '*:executable:_files'
}

_nsight-compute "$@"
