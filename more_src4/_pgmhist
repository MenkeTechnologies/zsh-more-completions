#compdef pgmhist
# Documentation: man pgmhist (Netpbm)
# Source: print a histogram of pixel values in a PGM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-median -quartile -decile)-median[report only the median]' \
    '(-median -quartile -decile)-quartile[report only the quartiles]' \
    '(-median -quartile -decile)-decile[report only the deciles]' \
    '-forensic[forensic-style detailed report]' \
    '-machine[machine-readable output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pgm file:_files -g "*.(pgm|pnm|pam)"' \
    && ret=0

return ret
