#compdef meterbridge
# Documentation: https://manpages.debian.org/bookworm/meterbridge/meterbridge.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream Debian man page at the URL above.

# meterbridge: JACK Audio Connection Kit metering applications (VU, PPM, DPM, JF, SCO)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-t[meter type]:type:(vu ppm dpm jf sco)' \
  '-r[reference level (dB) for 0 on the meter]:dB:' \
  '-c[columns when displaying multiple meters]:cols:' \
  '-n[JACK client identifier name]:name:' \
  '*:JACK port:' && ret=0
return ret
