#compdef mount_apfs
# Documentation: mount_apfs usage (macOS 26)
# Source: mount an APFS volume or snapshot.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-o+[mount options]:options:(rdonly nobrowse soft async sync noatime nosuid noexec)' \
    '-u+[UID for the mount]:uid:' \
    '-g+[GID for the mount]:gid:' \
    '-n[do not update the volume mount time]' \
    '(-c -C)-c[mount in compatibility mode]' \
    '(-c)-r[required compatibility recovery (with -c)]' \
    '(-c -C)-C[mount in restricted mode (no -c)]' \
    '-s+[mount a specific APFS snapshot]:snapshot uuid or name:' \
    '-P+[im4p file for personalised mount]:im4p:_files' \
    '-M+[im4m manifest file]:im4m:_files' \
    '-T+[trust type]:trust:(generic brain)' \
    '-E+[boot environment]:env:(generic supplemental pdi_nonce mobile_asset smac)' \
    '1:volume or device:_files -g "/dev/disk*"' \
    '2:mount point:_files -/' \
    && ret=0

return ret
