#compdef polonius
# _polonius — rust-lang/polonius: alternative borrow-checker engine for Rust
# upstream: https://github.com/rust-lang/polonius
# Flags from src/cli.rs (pico_args); algorithm variants from polonius-engine/src/output/mod.rs.

_polonius() {
    local -a args
    args=(
        '-a+[borrow-checking algorithm]:algorithm:(Naive DatafrogOpt LocationInsensitive Compare Hybrid)'
        '--show-tuples[show output tuples on stdout]'
        '--skip-timing[do not display timing results]'
        '(-v --verbose)'{-v,--verbose}'[show intermediate tuples and not just errors]'
        '--graphviz-file=[write a Graphviz visualization of the computation]:file:_files'
        '--dump-liveness-graph=[write a Graphviz visualization of the liveness analysis]:file:_files'
        '(-o --output)'{-o+,--output=}'[directory for output tuples]:dir:_files -/'
        '(- *)'{-h,--help}'[show help]'
        '(- *)-V[show version]'
        '*:fact directory:_files -/'
    )
    _arguments -s -S $args
}

_polonius "$@"
