#compdef makepasswd
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/makepasswd.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--chars=[exact password length]:length:' \
  '--clearfrom=[read password from file]:file:_files' \
  '--count=[number of passwords to produce]:count:' \
  '--crypt[output encrypted password]' \
  '--nocrypt[do not encrypt (default)]' \
  '--crypt-md5[encrypt with MD5]' \
  '--cryptsalt=[salt size (positive, max 4096)]:n:' \
  '--maxchars=[maximum password length]:length:' \
  '--minchars=[minimum password length]:length:' \
  '--randomseed=[random number seed]:seed:' \
  '--rerandom=[reset seed every N values]:n:' \
  '--repeatpass=[reuse each password N times]:n:' \
  '--string=[characters to draw from]:characters:' \
  '--verbose[label output]' \
  '--noverbose[do not label output (default)]' \
  '*:file:_files' && ret=0

return ret
