#compdef modulecmd envml
# Documentation: source-direct extraction from upstream
# cea-hpc/modules
#   doc/source/modulecmd.rst SYNOPSIS:
#     modulecmd <shell> [switches] [sub-command [sub-command-args]]
#   doc/source/module.rst:
#     `.. _Command line switches:` section -> 32 `.. option::` entries
#     `.. _Module Sub-Commands:` section -> 68 `.. subcmd::` entries
#   doc/source/envml.rst SYNOPSIS:
#     envml [MODULE_ACTION]... [--] COMMAND [ARG]...
#     MODULE_ACTION forms: purge, restore[=coll],
#     unload=mod1[&mod2...], switch=mod1&mod2,
#     [load=]mod1[&mod2...]
# Shell list decoded source-direct from the modulecmd.rst body
# "The following shells are supported: sh, csh, tcsh, bash, ksh,
# zsh, fish, cmd, pwsh, python, perl, ruby, tcl, cmake, r and
# lisp."
# Reference accessed: 2026-05-30 via gh api.
# cea-hpc Environment Modules R168 — `modulecmd` is the low-
# level execution engine the `module` shell function invokes
# to emit shell-specific environment-modification code.  Direct
# invocation is primarily for debugging + advanced usage; end
# users normally use `module` which is a shell function not a
# binary.  `envml` is a one-shot env-prepared command runner.
# Sister tools to the heavily-covered HPC scheduler family
# (slurmctld/slurmd/slurmdbd/slurmstepd in R162, sbatch/srun/
# scancel/squeue/sinfo/sacct/sshare/scontrol/sbcast/strigger/
# salloc/sattach, PBS qsub/qstat/qdel/qrerun/qhold/qrls/qmove/
# qmsg/qalter/qsig/qselect/qrun/qmgr, flux + flux-jobs from
# R162) already in the corpus.

case $service in

  modulecmd)
    local -a shells=(
      'sh:POSIX shell'
      'csh:C shell'
      'tcsh:TENEX C shell'
      'bash:GNU Bourne-again shell'
      'ksh:Korn shell'
      'zsh:Z shell'
      'fish:fish shell'
      'cmd:Windows CMD'
      'pwsh:PowerShell'
      'python:emit Python code'
      'perl:emit Perl code'
      'ruby:emit Ruby code'
      'tcl:emit Tcl code'
      'cmake:emit CMake code'
      'r:emit R code'
      'lisp:emit Lisp code'
    )
    local -a subcmds=(
      'add:alias for load'
      'add-any:alias for load-any'
      'aliases:list all symbolic version-names and aliases'
      'append-path:append value to environment variable'
      'apropos:alias for search'
      'avail:list all available modulefiles in MODULEPATH'
      'cachebuild:rebuild the global module cache'
      'cacheclear:clear the global module cache'
      'clear:clear loaded module list'
      'config:get/set module command configuration'
      'describe:list members of a virtual module'
      'disable:disable a modulefile'
      'display:display the contents of a modulefile (alias for show)'
      'edit:invoke EDITOR on a modulefile'
      'help:print help for a modulefile'
      'info-loaded:print which modulefile satisfies a given module designation'
      'initadd:add module to shell init file'
      'initclear:clear modules from shell init file'
      'initlist:list modules from shell init file'
      'initprepend:prepend module to shell init file'
      'initrm:remove module from shell init file'
      'initswitch:swap module in shell init file'
      'is-avail:test if a modulefile is available'
      'is-loaded:test if a modulefile is loaded'
      'is-saved:test if a saved collection exists'
      'is-used:test if a directory is in MODULEPATH'
      'keyword:search modulefiles by keyword'
      'lint:check modulefiles for syntax errors'
      'list:list loaded modules'
      'load:load a modulefile'
      'load-any:load the first available variant'
      'mod-to-sh:convert a modulefile to shell code'
      'path:print the path of a modulefile'
      'paths:print all paths to a modulefile'
      'prepend-path:prepend value to environment variable'
      'purge:unload all loaded modules'
      'refresh:re-set aliases of currently loaded modules'
      'reload:reload all loaded modulefiles'
      'remove-path:remove value from environment variable'
      'reset:purge then load default modules'
      'restore:restore a saved collection'
      'rm:alias for unload'
      'save:save current module state as a named collection'
      'savelist:list saved collections'
      'saverm:remove a saved collection'
      'saveshow:show contents of a saved collection'
      'search:search modulefiles by keyword'
      'sh-to-mod:convert shell-environment-modifying script to modulefile'
      'show:show the contents of a modulefile'
      'source:source a non-modulefile script in module context'
      'spider:spider the module tree (rich search)'
      'stash:stash currently loaded modules'
      'stashclear:clear all stashes'
      'stashlist:list available stashes'
      'stashpop:restore + delete the most recent stash'
      'stashrm:remove a specific stash'
      'stashshow:show contents of a stash'
      'state:print currently active module state'
      'swap:alias for switch'
      'switch:swap one loaded modulefile for another'
      'test:invoke modulefile self-test'
      'try-add:alias for try-load'
      'try-load:load module if available'
      'unload:unload a modulefile'
      'unuse:remove directory from MODULEPATH'
      'update:reload all auto-symbolic-version modules'
      'use:add directory to MODULEPATH'
      'whatis:print 1-line description of a modulefile'
    )
    _arguments -C \
      '(--all -a)'{--all,-a}'[apply to all modulefiles in MODULEPATH]' \
      '--auto[automatically resolve dependencies]' \
      '--color=[colored output mode]:when:(never always auto)' \
      '(--contains -C)'{--contains,-C}'[match modulefiles containing pattern]' \
      '(--debug -D -DD)'{--debug,-D,-DD}'[enable debug output]' \
      '(--default -d)'{--default,-d}'[only show default versions]' \
      '--dumpname[dump module name]' \
      '(--force -f)'{--force,-f}'[force the action (ignore conflict/prereq)]' \
      '(--help -h)'{--help,-h}'[print help and exit]' \
      '(--icase -i)'{--icase,-i}'[match patterns case-insensitively]' \
      '--ignore-cache[bypass the module cache]' \
      '--ignore-user-rc[ignore the user modulerc]' \
      '--indepth[recurse depth-first into module trees]' \
      '(--json -j)'{--json,-j}'[emit machine-readable JSON]' \
      '(--latest -L)'{--latest,-L}'[only show the latest versions]' \
      '(--long -l)'{--long,-l}'[long output]' \
      '--no-auto[disable automatic dependency resolution]' \
      '--no-indepth[do not recurse depth-first]' \
      '(--no-pager -P)'{--no-pager,-P}'[disable the output pager]' \
      '--no-redirect[do not redirect output to stderr]' \
      '(--output --output= -o)'{--output=,-o+}'[output element list]:list:' \
      '(--paginate -p)'{--paginate,-p}'[enable the output pager]' \
      '--redirect[redirect output to stderr]' \
      '(--silent -s)'{--silent,-s}'[suppress error output]' \
      '(--starts-with -S)'{--starts-with,-S}'[match modulefiles starting with pattern]' \
      '--tag=[apply only to modules with given tag list]:list:' \
      '(--terse -t)'{--terse,-t}'[terse output]' \
      '--timer[print elapsed-time profile]' \
      '(--trace -T)'{--trace,-T}'[enable trace output]' \
      '(--verbose -v -vv)'{--verbose,-v,-vv}'[verbose output]' \
      '(--version -V)'{--version,-V}'[print version and exit]' \
      '(--width -w)'{--width=,-w+}'[output width in columns]:cols:' \
      '1:shell:->shell' \
      '2:sub-command:->subcmd' \
      '*:sub-command args:->args'
    case $state in
      shell)
        _describe -t shells 'modulecmd target shell' shells
        ;;
      subcmd)
        _describe -t subcmds 'module sub-command' subcmds
        ;;
    esac
    ;;

  envml)
    # envml parses leading args as MODULE_ACTIONs until -- or until
    # a non-action arg is found.  Action forms documented:
    #   purge
    #   restore[=coll]
    #   unload=mod1[&mod2...]
    #   switch=mod1&mod2
    #   [load=]mod1[&mod2...]
    # Multiple actions can be colon-joined in one arg.
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[print help and exit]' \
      '*::module action / -- / command:_command_names -e'
    ;;

esac
