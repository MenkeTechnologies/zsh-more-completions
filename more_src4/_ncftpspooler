#compdef ncftpspooler
# Documentation: man ncftpspooler(1)
# Source: ncftp ncftpspooler (man) — global FTP background spooler (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-d -l)-d[start background processing of FTP jobs]' \
    '(-d -l)-l[list contents of job queue directory]' \
    '-q+[job queue directory]:dir:_files -/' \
    '-o+[log file]:file:_files' \
    '-s+[idle sleep seconds]:seconds:_default' \
    && ret=0

return ret
