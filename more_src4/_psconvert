#compdef psconvert
# Documentation: https://docs.generic-mapping-tools.org/latest/psconvert.html
# Source: GenericMappingTools/gmt psconvert — convert PostScript output to raster / PDF / EPS.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[crop BoundingBox + HiResBoundingBox to content]:opts:_default' \
    '-C+[extra Ghostscript option]:opts:_default' \
    '-D+[output directory]:dir:_directories' \
    '-E+[raster resolution (DPI)]:dpi:_default' \
    '-F+[output filename (no extension)]:name:_default' \
    '-G+[Ghostscript executable path]:gs:_files' \
    '-H+[temp upsampling scale]:n:_default' \
    '-I+[adjust BoundingBox by scaling/margins]:opts:_default' \
    '-L+[ASCII list file of input PostScripts]:file:_files' \
    '-M+[sandwich with background/foreground PostScript]:opts:_default' \
    '-N+[BoundingBox fill / fade / outline]:opts:_default' \
    '-Q+[anti-aliasing settings]:opts:_default' \
    '-S[print executed Ghostscript command + keep intermediates]' \
    '-T+[output format]:fmt:(b e f j g G m s t F)' \
    '*-V[verbose (stackable)]' \
    '-W+[ESRI world file (for GeoTIFF)]:opts:_default' \
    '-Z[delete input PostScript after success]' \
    '*:PostScript file:_files -g "*.(ps|eps|EPS|PS)(-.)"' \
    && ret=0

return ret
