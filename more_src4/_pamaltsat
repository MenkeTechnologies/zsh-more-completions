#compdef pamaltsat
# Documentation: man pamaltsat (Netpbm)
# Source: alter color saturation of a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-method+[saturation method]:name:(hsv hsl yuv)' \
    '-strength+[strength factor]:number:' \
    '-linear[treat samples as linear, not gamma]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:netpbm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
