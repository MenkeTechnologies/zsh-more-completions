#compdef nodeenv
# Documentation: https://github.com/ekalinin/nodeenv
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Flags taken from ekalinin/nodeenv README. Note: -p maps to
# --python-virtualenv (flag), NOT --python (which doesn't exist).
# Compilation Python path uses none of these; --make=/--make-path is -m.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-n --node)'{-n,--node=}'[Node.js version to install]:version' \
  '(-j --jobs)'{-j,--jobs=}'[number of parallel jobs]:jobs' \
  '--load-average=[max load average]:load' \
  '--prebuilt[use prebuilt binaries (default)]' \
  '--source[compile from source]' \
  '--without-ssl[build without SSL support]' \
  '--debug[build debug variant]' \
  '--profile[enable profiling]' \
  '--npm=[npm version to install]:version' \
  '--with-npm[install npm into environment]' \
  '--no-npm-clean[skip npm 0.x cleanup]' \
  '(-c --clean-src)'{-c,--clean-src}'[remove source dir after install]' \
  '(-l --list)'{-l,--list}'[list available Node.js versions]' \
  '--update[update packages without reinstalling Node]' \
  '(-p --python-virtualenv)'{-p,--python-virtualenv}'[use current Python virtualenv]' \
  '(-r --requirements)'{-r,--requirements=}'[install packages from file]:file:_files' \
  '(-C --config-file)'{-C,--config-file=}'[load custom config]:file:_files' \
  '(-m --make)'{-m,--make=}'[path to make command]:path:_files' \
  '--prompt=[custom environment prompt]:prompt' \
  '--mirror=[download mirror URL]:url' \
  '--ignore_ssl_certs[ignore SSL certificates]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '--force[install in pre-existing directory]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:environment directory:_directories' && ret=0
return ret
