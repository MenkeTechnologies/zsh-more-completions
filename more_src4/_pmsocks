#compdef pmsocks
# _pmsocks — sockify a PCP utility via tsocks (performancecopilot/pcp)
# upstream: https://github.com/performancecopilot/pcp
# Usage from src/pmsocks/pmsocks.sh: pmsocks [path]program [args ...]

_pmsocks() {
    _arguments \
        '(- *)-?[show help]' \
        '*::command:_command_names -e'
}

_pmsocks "$@"
