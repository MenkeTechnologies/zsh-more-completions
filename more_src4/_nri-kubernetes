#compdef nri-kubernetes
# Documentation: https://github.com/newrelic/nri-kubernetes
# Reference accessed: 2026-05-19
# Verified: upstream repo at the URL above. Binary is config-driven via
# config.LoadConfig (file + env vars) and exposes the infra-integrations-sdk
# DefaultArgumentList flags.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-verbose[print more information to logs]' \
  '-pretty[print pretty formatted JSON]' \
  '-metrics[publish metrics data]' \
  '-inventory[publish inventory data]' \
  '-events[publish events data]' \
  '-metadata[add customer-defined key-value attributes]' \
  '-nri_add_hostname[add hostname attribute to the samples]' \
  '-nri_cluster=[cluster name]:cluster:' \
  '-nri_service=[service name]:service:' \
  '-temp_dir=[temporal data dir]:dir:_files -/' \
  '*::nri-kubernetes args:_files' && ret=0
return ret
