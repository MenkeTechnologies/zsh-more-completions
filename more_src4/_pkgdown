#compdef pkgdown
# _pkgdown — Hadley Wickham Jenny Bryan pkgdown R package CLI for building static documentation websites from R packages with function reference articles vignettes news (rstudio team, R); R argparse
# upstream: https://github.com/r-lib/pkgdown

_pkgdown() {
    local -a sub=(
        'build-site:build full site'
        'build-home:build home page'
        'build-reference:build function reference'
        'build-reference-index:build reference index'
        'build-articles:build articles'
        'build-article:build single article'
        'build-tutorials:build tutorials'
        'build-news:build news'
        'build-search:build search index'
        'build-redirects:build redirects'
        'build-favicons:build favicons'
        'init-site:initialize site config'
        'preview-site:preview built site'
        'preview-page:preview single page'
        'deploy-site-github:deploy to GitHub Pages'
        'deploy-to-branch:deploy to a branch'
        'check-pkgdown:lint pkgdown config'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pkgdown subcommand' sub ;;
        args)
            case $words[1] in
                build-site|build-home|build-reference|build-articles|build-news|build-search) _arguments \
                    '--pkg=+[dir]:dir:_files -/' \
                    '--examples=+[b]:b:(true false)' \
                    '--run-dont-run=+[b]:b:(true false)' \
                    '--seed=+[N]:n:' \
                    '--lazy=+[b]:b:(true false)' \
                    '--override=+[csv]:str:' \
                    '--preview=+[b]:b:(true false)' \
                    '--devel=+[b]:b:(true false)' \
                    '--new-process=+[b]:b:(true false)' \
                    '--install=+[b]:b:(true false)' \
                    '*:package dir:_files -/' ;;
                deploy-site-github|deploy-to-branch) _arguments \
                    '--pkg=+[dir]:dir:_files -/' \
                    '--branch=+[branch]:str:' \
                    '--remote=+[remote]:str:' \
                    '--commit-message=+[msg]:str:' \
                    '--ssh-id=+[id]:str:' \
                    '--clean=+[b]:b:(true false)' ;;
            esac
            ;;
    esac
}

_pkgdown "$@"
