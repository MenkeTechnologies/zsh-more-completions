#compdef moonbeam
# _moonbeam — PureStake Moonbeam Substrate-based parachain node providing Ethereum-compatible execution and EVM on Polkadot for cross-chain smart contracts (moonbeam-foundation team, Rust); clap
# upstream: https://github.com/moonbeam-foundation/moonbeam

_moonbeam() {
    local -a sub=(
        'export-genesis-state:export genesis state'
        'export-genesis-wasm:export genesis wasm'
        'build-spec:build chain spec'
        'check-block:check block'
        'export-blocks:export blocks'
        'export-state:export state'
        'import-blocks:import blocks'
        'purge-chain:purge chain'
        'revert:revert chain'
        'key:key operations'
        'precompile-wasm:precompile WASM'
        'try-runtime:try runtime'
        'benchmark:benchmark'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--chain=+[chain]:c:(moonbeam moonriver moonbase-alpha moonbase-local dev)' \
        '--dev[run in dev mode]' \
        '--no-prometheus[no prometheus]' \
        '--prometheus-external[expose prometheus]' \
        '--prometheus-port=+[port]:n:' \
        '--rpc-port=+[port]:n:' \
        '--rpc-external[expose RPC]' \
        '--rpc-cors=+[origins]:str:' \
        '--rpc-methods=+[mode]:m:(auto safe unsafe)' \
        '--rpc-max-connections=+[N]:n:' \
        '--port=+[port]:n:' \
        '--validator[validator mode]' \
        '--collator[collator mode]' \
        '--name=+[name]:str:' \
        '--telemetry-url=+[url verbosity]:str:' \
        '--no-telemetry[no telemetry]' \
        '--base-path=+[dir]:dir:_files -/' \
        '-d+[dir]:dir:_files -/' \
        '--keystore-path=+[dir]:dir:_files -/' \
        '--password-filename=+[file]:file:_files' \
        '--node-key=+[key]:str:' \
        '--node-key-type=+[type]:t:(ed25519)' \
        '--node-key-file=+[file]:file:_files' \
        '--state-pruning=+[N]:str:' \
        '--blocks-pruning=+[N]:str:' \
        '--bootnodes=+[csv]:str:' \
        '--reserved-nodes=+[csv]:str:' \
        '--in-peers=+[N]:n:' \
        '--out-peers=+[N]:n:' \
        '--max-runtime-instances=+[N]:n:' \
        '--ethapi=+[apis]:str:' \
        '--ethapi-max-permits=+[N]:n:' \
        '--eth-log-block-cache=+[N]:n:' \
        '--eth-statuses-cache=+[N]:n:' \
        '--frontier-backend-type=+[type]:t:(key-value sql)' \
        '--frontier-sql-backend-pool-size=+[N]:n:' \
        '--frontier-sql-backend-num-ops-timeout=+[N]:n:' \
        '--unsafe-force-node-key-generation[unsafe key gen]' \
        '--no-hardware-benchmarks[skip hw benchmark]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'moonbeam subcommand' sub ;;
        args) ;;
    esac
}

_moonbeam "$@"
