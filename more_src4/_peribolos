#compdef peribolos
# _peribolos — GitHub organization config sync tool (kubernetes-sigs/prow)
# upstream: https://github.com/kubernetes-sigs/prow
# Flags from cmd/peribolos/main.go (flag).

_peribolos() {
    _arguments \
        '*-required-admins=[ensure these users are admins (repeat)]:user:' \
        '-min-admins=[ensure at least this many admins]:n:' \
        '-require-self=[ensure --github-token-path user is admin]:val:(true false)' \
        '-maximum-removal-delta=[fail if removing more than this fraction of members]:f:' \
        '-config-path=[org config.yaml file]:file:_files' \
        '-confirm[mutate GitHub if set]' \
        '-dump=[output current config of this org]:org:' \
        '-dump-full[dump as a valid input config file]' \
        '-ignore-invitees[do not compare missing members with active invitations]' \
        '-ignore-secret-teams[do not dump or update secret teams]' \
        '-ignore-enterprise-teams[skip enterprise teams during reconciliation]' \
        '-fix-org[change org metadata]' \
        '-fix-org-members[add/remove org members]' \
        '-fix-teams[create/delete/update teams]' \
        '-fix-team-members[add/remove team members]' \
        '-fix-team-repos[add/remove team permissions on repos]' \
        '-fix-repos[create/update repositories]' \
        '-fix-collaborators[add/remove/update repository collaborators]' \
        '-allow-repo-archival[allow archiving repos when updating]' \
        '-allow-repo-publish[allow making private repos public]' \
        '-log-level=[log level]:level:(debug info warn error)' \
        '-github-token-path=[GitHub token file]:file:_files' \
        '-github-endpoint=[GitHub API endpoint]:url:_urls'
}

_peribolos "$@"
