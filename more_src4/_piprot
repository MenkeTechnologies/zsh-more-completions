#compdef piprot
# _piprot — check how rotten Python requirements are (sesh/piprot)
# upstream: https://github.com/sesh/piprot
# Flags from piprot/piprot.py (argparse).

_piprot() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-v --verbose)*'{-v,--verbose}'[increase verbosity]' \
        '(-l --latest)'{-l,--latest}'[print latest available version for outdated reqs]' \
        '(-x --verbatim)'{-x,--verbatim}'[output full requirements file with update comments]' \
        '(-q --quiet)'{-q,--quiet}'[less verbose output]' \
        '(-o --outdated)'{-o,--outdated}'[list only outdated requirements]' \
        '(-g --github)'{-g+,--github=}'[test requirements from a GitHub repo]:repo:' \
        '(-b --branch)'{-b+,--branch=}'[branch for GitHub URL]:branch:' \
        '(-t --token)'{-t+,--token=}'[GitHub personal access token]:token:' \
        '(-p --path)'{-p+,--path=}'[path to requirements in remote repo]:path:' \
        '(-d --delay)'{-d+,--delay=}'[days before outdated triggers error]:days:' \
        '(-u --url)'{-u+,--url=}'[URL to requirements file]:url:' \
        '*:requirements file:_files -g "requirements*.txt"'
}

_piprot "$@"
