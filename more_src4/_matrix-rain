#compdef matrix-rain
# matrix-rain - The famous Matrix rain effect as a Node CLI.
#
# Upstream: https://github.com/nojvek/matrix-rain  (447+ stars, MIT)
# Author:   nojvek (Naveen Ramanathan)
# Library:  argparse 2.0 (the Python argparse port for Node) + ascii-art
#
# Source-direct extraction from index.js argParser definition block:
#   https://github.com/nojvek/matrix-rain/blob/master/index.js
#
# Cross-language CMatrix-clone family (Axis 295 closer):
#   Rust : cowboy8625/rusty-rain  (clap-derive + crossterm)
#   Go   : GeertJohan/gomatrix    (gdamore/tcell + jessevdk/go-flags)
#   Node : nojvek/matrix-rain     (argparse + ascii-art)

local curcontext=$curcontext state line ret=1
typeset -A opt_args

_matrix_rain_directions() {
    local -a dirs
    dirs=(
        'v:vertical rain (classic cmatrix top-to-bottom default)'
        'h:horizontal rain (rotated 90 degrees)'
    )
    _describe -t directions 'rain direction' dirs
}

_matrix_rain_colors() {
    local -a colors
    colors=(
        'green:classic green Matrix rain (default)'
        'red'
        'blue'
        'yellow'
        'magenta'
        'cyan'
        'white'
    )
    _describe -t colors 'rain color (NOTE: droplet head is always white)' colors
}

_matrix_rain_charranges() {
    local -a ranges
    ranges=(
        'ascii:printable ASCII characters (default)'
        'binary:ones and zeros'
        'braille:Unicode braille patterns'
        'emoji:assorted emojis'
        'katakana:Japanese half-width kana (authentic cmatrix look)'
        'lil-guys:lil-guys ASCII art glyphs'
        'picto:pictograph characters'
    )
    _describe -t ranges 'character range' ranges
}

_arguments -C \
    '(- *)'{-h,--help}'[show argparse usage banner and exit]' \
    '(- *)'{-v,--version}'[print matrix-rain version and exit]' \
    '(-d --direction)'{-d,--direction}'+[change direction of rain (h=horizontal, v=vertical)]:direction:_matrix_rain_directions' \
    '(-c --color)'{-c,--color}'+[rain color (head droplet is always white)]:color:_matrix_rain_colors' \
    '(-k --char-range)'{-k,--char-range}'+[character set used for raindrops]:char range:_matrix_rain_charranges' \
    '(-f --file-path)'{-f,--file-path}'+[read characters from FILE instead of random char-range]:file path:_files' \
    '(-m --mask-path)'{-m,--mask-path}'+[use IMAGE as a mask for the raindrops]:mask image:_files -g "*.(png|jpg|jpeg|gif|bmp)"' \
    '(-i --invert-mask)'{-i,--invert-mask}'[invert the mask specified with --mask-path]' \
    '--offset-row=[move upper-left corner of mask down N rows (default 0)]:rows:' \
    '--offset-col=[move upper-left corner of mask right N columns (default 0)]:columns:' \
    '--font-ratio=[character height/width ratio in terminal (default 2)]:ratio:' \
    '--print-mask[print the resolved mask and exit]' \
    && ret=0

return ret
