#compdef netfetch
# Documentation: https://github.com/deggja/netfetch
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'scan:scan cluster or namespace for missing network policies'
  'dash:launch the netfetch dashboard'
  'help:show help'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-d --dryrun)'{-d,--dryrun}'[dry run scan (no prompts)]' \
  '(-n --namespace)'{-n,--namespace}'[Kubernetes namespace]:namespace:' \
  '--target=[target deployment or workload]:target:' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '--cilium[scan Cilium network policies]' \
  '--native[scan native Kubernetes network policies]' \
  '--port=[dashboard port]:port:' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command) _describe -t commands 'netfetch command' commands && ret=0 ;;
esac

return ret
