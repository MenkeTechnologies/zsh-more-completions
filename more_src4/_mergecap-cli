#compdef mergecap-cli
# _mergecap-cli — Wireshark mergecap merge multiple pcap files CLI alias (wireshark team, C); custom argparse
# upstream: https://gitlab.com/wireshark/wireshark

_mergecap-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-w+[output file]:file:_files -g "*.pcap*"' \
        '-F+[file format]:f:(pcap pcapng nstrace1 nstrace2 nstrace3 ngsniffer ngsniffer-extended5)' \
        '-T+[encap type]:str:' \
        '-a[append packets]' \
        '-V[verbose]' \
        '-I+[merge mode]:m:(0 1 2 3 4)' \
        '-s+[snaplen]:n:' \
        '-c+[max packets per file]:n:' \
        '*:input files:_files -g "*.pcap*"'
}

_mergecap-cli "$@"
