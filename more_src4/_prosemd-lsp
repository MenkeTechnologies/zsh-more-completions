#compdef prosemd-lsp prosemd
# _prosemd-lsp — Markdown/prose LSP linter (kitten/prosemd-lsp)
# upstream: https://github.com/kitten/prosemd-lsp
# Flags from src/main.rs (structopt).

_prosemd-lsp() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '--stdio[serve LSP over stdio]' \
        '--socket=[serve LSP over TCP socket on PORT]:port:'
}

_prosemd-lsp "$@"
