#compdef multipath
# _multipath — Linux device-mapper multipath multipath CLI managing multipath-tools dm-multipath topology coalescing multiple SCSI iSCSI FC paths into single /dev/mapper/mpathN device showing flushing topology DM tables prio checker selectors path-grouping rr service-time queue-length (multipath-tools team, C); getopt
# upstream: https://github.com/opensvc/multipath-tools

_multipath() {
    _arguments \
        '-h[show help]' \
        '-l[show current topology]' \
        '-ll[show verbose topology]' \
        '-f+[flush map]:str:' \
        '-F[flush all maps]' \
        '-c+[check]:file:_files -g "/dev/sd* /dev/nvme*"' \
        '-C+[check WWID]:str:' \
        '-q[allow read-only]' \
        '-d[dry run]' \
        '-r[force reload]' \
        '-i[ignore wwids file]' \
        '-B[set features for boot]' \
        '-t[print internal hardware table]' \
        '-T[print embedded compiled-in table]' \
        '-h[show help]' \
        '-v+[verbosity]:l:(0 1 2 3 4 5 6)' \
        '-w+[wwid]:str:' \
        '-W[print wwids file]' \
        '-a[add wwid]' \
        '-A[scan add wwids]' \
        '-p+[policy]:p:(failover multibus group_by_serial group_by_prio group_by_node_name)' \
        '-b+[bindings]:file:_files' \
        '-u[delete wwid]' \
        '-U[remove map]' \
        '-e[reload changed maps]' \
        '-R+[max retries]:n:' \
        '*:device:_files -g "/dev/sd* /dev/nvme* /dev/mapper/*"'
}

_multipath "$@"
