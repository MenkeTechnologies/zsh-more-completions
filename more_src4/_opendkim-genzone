#compdef opendkim-genzone
# Documentation: https://manpages.debian.org/bookworm/opendkim-tools/opendkim-genzone.8.en.html
# Reference accessed: 2026-05-20
# Verified: Debian bookworm opendkim-genzone(8) manpage.

# opendkim-genzone: generate DNS zone entries for DKIM keys
local curcontext="$curcontext" ret=1
_arguments -C \
  '-C[SOA record contact]:contact:' \
  '-d[restrict output to domain]:domain:' \
  '-D[add ._domainkey suffix to selectors]' \
  '-E[SOA expiration time]:secs:' \
  '-F[add ._domainkey suffix and domain to selectors]' \
  '-M[restrict keys for email signing only]' \
  '-N[comma-separated nameserver list]:nslist:' \
  '-o[write output to file]:file:_files' \
  '-r[SOA zone refresh time]:secs:' \
  '-R[SOA zone retry time]:secs:' \
  '-s[extend -d to include subdomains]' \
  '-S[generate SOA record at top]' \
  '-t[TTL for all records]:ttl:' \
  '-T[SOA record TTL]:secs:' \
  '-u[output suitable for nsupdate]' \
  '-v[increase verbosity]' \
  '-x[opendkim.conf config file]:file:_files' \
  '*:KeyTable:_files' && ret=0
return ret
