#
# THE neovate CLI — yargs-parser + ws + MCP + NodeBridge
#
# neovate's CLI is in src/cli.ts (entry point) + src/index.ts
# (parseArgs + runNeovate).  Uses yargs-parser for argv parsing
# (lower-level than yargs or commander; allows custom help
# formatting).
#
# Options (parsed via yargs-parser):
#   -h, --help                       show help
#   -v, --version                    show version
#   -m, --model MODEL                primary model to use
#       --plan-model MODEL           model used for planning
#       --small-model MODEL          model used for quick ops
#       --vision-model MODEL         model used for image tasks
#   -r, --resume SESSION_ID          resume a session
#   -c, --continue                   continue the latest session
#   -q, --quiet                      non-interactive mode
#       --cwd PATH                   working directory
#       --system-prompt PROMPT       custom system prompt
#       --append-system-prompt P     append to system prompt
#       --output-format FMT          text|stream-json|json
#       --output-style STYLE         output style
#       --approval-mode MODE         default|autoEdit|yolo
#       --mcp-config CFG             MCP server config (repeatable)
#       --tools JSON                 tools enable/disable JSON
#       --mcp / --no-mcp             enable/disable MCP
#       --port N                     ACP WebSocket port
#       --host HOST                  ACP WebSocket bind host
#       --language LANG              UI language
#       --plugin PATH                plugin path (repeatable)
#       --plugin-dir DIR             plugin directory (repeatable)
#       --disable-context-cache      disable context caching
#
# Subcommands:
#   acp                              run as ACP agent
#   call                             call NodeBridge handlers
#   config                           manage configuration
#   commit                           commit changes
#   log [file]                       view session logs in HTML
#   mcp                              manage MCP servers
#   run                              run a command
#   skill                            manage skills
#   update                           check/apply updates
#   workspace                        manage workspaces
#
# ws is imported in src/.../acp.ts for the ACP (Agent Client
# Protocol) WebSocket server endpoint that external editors
# (VS Code, Neovim, IntelliJ, JetBrains) connect to for
# bidirectional agent communication.
#
# Five-axis distinctness from tokio-tungstenite (R657) +
# gorilla/websocket (R658):
#
#   1. EventEmitter API — ws.on('open' / 'message' / 'close' /
#      'error' / 'ping' / 'pong' / 'upgrade').  tungstenite
#      uses Stream<Message>; gorilla uses ReadMessage() blocking
#      calls.
#
#   2. createWebSocketStream — wrapper exposing ws as Node
#      Duplex stream for pipe() integration.  Unique to ws.
#
#   3. permessage-deflate DEFAULT — opt-OUT instead of opt-in.
#      tungstenite + gorilla require opt-in via features /
#      EnableCompression.
#
#   4. BROWSER-COMPATIBLE WebSocket API — ws.WebSocket matches
#      W3C/WHATWG browser WebSocket exactly, enabling
#      isomorphic code.
#
#   5. ZERO PRODUCTION DEPENDENCIES — ws has no runtime npm
#      deps.  tungstenite has tokio + futures + others;
#      gorilla has BurntSushi/toml.  Pure-implementation
#      minimalism.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/neovateai/neovate-code/blob/main/src/cli.ts
# https://github.com/neovateai/neovate-code/blob/main/src/index.ts
# yargs-parser config + printHelp() text.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _neovate_cmds _neovate_formats _neovate_approvals
_neovate_cmds=(
    'acp:run as ACP (Agent Client Protocol) agent (WebSocket server via ws)'
    'call:call NodeBridge handlers directly'
    'config:manage configuration'
    'commit:commit changes to the repository'
    'log:view session logs in HTML'
    'mcp:manage MCP servers'
    'run:run a command'
    'skill:manage skills'
    'update:check for and apply updates'
    'workspace:manage workspaces'
    'help:show help for a subcommand'
)
_neovate_formats=(
    'text:plain text output'
    'stream-json:newline-delimited JSON events'
    'json:single JSON output'
)
_neovate_approvals=(
    'default:prompt before each tool call'
    'autoEdit:auto-approve edits, prompt other tools'
    'yolo:auto-approve everything'
)

_arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '(-m --model)'{-m+,--model=}'[primary model to use]:model:_default' \
    '--plan-model=[model used for planning]:model:_default' \
    '--small-model=[model used for quick operations]:model:_default' \
    '--vision-model=[model used for image tasks]:model:_default' \
    '(-r --resume)'{-r+,--resume=}'[resume a session by ID]:session:_default' \
    '(-c --continue)'{-c,--continue}'[continue the latest session]' \
    '(-q --quiet)'{-q,--quiet}'[quiet mode (non-interactive)]' \
    '--cwd=[working directory]:directory:_files -/' \
    '--system-prompt=[custom system prompt]:prompt:_default' \
    '--append-system-prompt=[append to system prompt]:prompt:_default' \
    '--output-format=[output format]:format:->format' \
    '--output-style=[output style (name/path/JSON)]:style:_default' \
    '--approval-mode=[tool approval mode]:mode:->approval' \
    '*--mcp-config=[MCP server config (JSON or file path)]:config:_files' \
    '--tools=[tools configuration JSON]:json:_default' \
    '--mcp[enable MCP servers (default)]' \
    '--no-mcp[disable MCP servers]' \
    '--port=[ACP WebSocket port]:port:_default' \
    '--host=[ACP WebSocket bind host]:host:_default' \
    '--language=[UI language]:lang:_default' \
    '*--plugin=[plugin path (repeatable)]:plugin:_files' \
    '*--plugin-dir=[plugin directory (repeatable)]:directory:_files -/' \
    '--disable-context-cache[disable context caching]' \
    '1: :->cmd_or_prompt' \
    '*::arg:->args' \
    && ret=0

case $state in
    format)   _describe -t formats 'output format' _neovate_formats && ret=0 ;;
    approval) _describe -t approvals 'approval mode' _neovate_approvals && ret=0 ;;
    cmd_or_prompt)
        _describe -t commands 'neovate subcommand or prompt' _neovate_cmds && ret=0
        _message 'prompt' && ret=0
        ;;
    args)
        case $words[1] in
            log) _files && ret=0 ;;
            help) _describe -t commands 'subcommand' _neovate_cmds && ret=0 ;;
        esac
        ;;
esac

return ret
