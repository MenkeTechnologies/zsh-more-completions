#compdef phpcbf
# Documentation: https://github.com/PHPCSStandards/PHP_CodeSniffer/wiki/Usage
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)-h[show help]' \
  '(- *)--version[show version]' \
  '--standard=[coding standard to use]:standard' \
  '--sniffs=[list of sniffs to include]:sniffs' \
  '--exclude=[list of sniffs to exclude]:sniffs' \
  '--suffix=[use a suffix for fixed files]:suffix' \
  '--encoding=[encoding of the files]:encoding' \
  '--tab-width=[number of spaces each tab represents]:width' \
  '--severity=[minimum severity required]:severity' \
  '--error-severity=[minimum error severity]:severity' \
  '--warning-severity=[minimum warning severity]:severity' \
  '--extensions=[list of file extensions to check]:extensions' \
  '--ignore=[list of patterns to ignore]:patterns' \
  '--ignore-annotations[ignore phpcs annotations]' \
  '--file-list=[file containing a list of files to check]:file:_files' \
  '--filter=[file list filter]:filter:(GitModified GitStaged)' \
  '--basepath=[strip path prefix from file paths]:path:_directories' \
  '--stdin-path=[processing STDIN as this file path]:path:_files' \
  '--bootstrap=[file to include before processing]:file:_files' \
  '--cache=[enable result caching]:cache file:_files' \
  '--no-cache[disable caching]' \
  '--no-colors[do not use colors in output]' \
  '--colors[use colors in output]' \
  '(-p --progress)'{-p,--progress}'[show progress of the run]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '-l[check local directory only]' \
  '-d+[set php.ini value]:key=value' \
  '-n[do not print warnings]' \
  '-w[print both warnings and errors]' \
  '--parallel=[number of parallel processes]:count' \
  '--config-show[show current configuration]' \
  '--config-set[set a configuration option]:key:: :value' \
  '--config-delete[delete a configuration option]:key' \
  '--runtime-set[set a runtime configuration option]:key:: :value' \
  '*:file or directory:_files' && ret=0

return ret
