#compdef morphmcp morph-mcp
# Documentation: https://www.npmjs.com/package/@morphllm/morphmcp
# Reference accessed: 2026-05-23
# Verified: npx @morphllm/morphmcp -h.

# Zsh completion for morphmcp - Morph MCP server (@morphllm/morphmcp)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--api-key[Morph API key]:key:' \
  '*:allowed directory:_directories' && ret=0

return ret
