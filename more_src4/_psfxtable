#compdef psfxtable psfaddtable psfgettable psfstriptable
# Documentation: man psfxtable(1)
# Source: legionus/kbd src/psfxtable.c (master) — psf font table editor; multi-personality (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-V[show version]' \
    '-i+[input font file]:font:_files -g "*.{psf,psfu,psf.gz}"' \
    '-if+[input font file]:font:_files -g "*.{psf,psfu,psf.gz}"' \
    '-o+[output font file]:font:_files -g "*.{psf,psfu}"' \
    '-of+[output font file]:font:_files -g "*.{psf,psfu}"' \
    '-it+[input table file]:table:_files' \
    '-ot+[output table file]:table:_files' \
    '-nt[strip / no table]' \
    '*:font/table file:_files' \
    && ret=0

return ret
