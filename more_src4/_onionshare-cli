#compdef onionshare-cli
# Documentation: https://docs.onionshare.org/2.6.2/en/advanced.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# onionshare-cli: anonymous file sharing/chat over Tor (CLI mode)
local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--help[show help]' \
  '(-v --verbose)'{-v,--verbose}'[enable error logging]' \
  '--receive[receive files mode]' \
  '--website[website mode]' \
  '--chat[chat mode]' \
  '--public[disable private key requirement]' \
  '--auto-start-timer=[auto start timer (seconds)]:seconds:' \
  '--auto-stop-timer=[auto stop timer (seconds)]:seconds:' \
  '--no-autostop-sharing[continue sharing after files have been sent]' \
  '--data-dir=[directory for received files]:dir:_files -/' \
  '--webhook-url=[webhook notification URL]:url:' \
  '--disable-text[disable text uploads]' \
  '--disable-files[disable file uploads]' \
  '--disable_csp[remove Content Security Policy header (website)]' \
  '--custom_csp=[custom CSP header (website)]:csp:' \
  '--persistent=[persistent session file]:file:_files' \
  '--title=[custom title]:title:' \
  '--connect-timeout=[Tor connection timeout (seconds)]:seconds:' \
  '--config=[custom global settings file]:file:_files' \
  '--local-only[skip Tor (development only)]' \
  '*:files:_files' && ret=0
return ret
