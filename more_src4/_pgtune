#compdef pgtune
# Documentation: https://github.com/gregs1104/pgtune
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-i --input-config)'{-i+,--input-config=}'[input postgresql.conf file]:input file:_files' \
  '(-o --output-config)'{-o+,--output-config=}'[output config file]:output file:_files' \
  '(-M --memory)'{-M+,--memory=}'[total system memory]:memory:' \
  '(-T --type)'{-T+,--type=}'[database type]:db type:(DW OLTP Web Mixed Desktop)' \
  '(-c --connections)'{-c+,--connections=}'[max number of connections]:connections:' \
  '(-P --platform)'{-P+,--platform=}'[platform]:platform:(Windows Linux Darwin)' \
  '(-S --settings)'{-S+,--settings=}'[settings directory]:directory:_directories' \
  '(-D --debug)'{-D,--debug}'[enable debug]' && ret=0

return ret
