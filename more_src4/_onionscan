#compdef onionscan
# _onionscan — OnionScan project onionscan CLI for inspecting Tor v2 v3 hidden services discovering operational security mistakes leaked HTTP headers SSH banners Apache mod_status server-status PHP info open ports debug pages (s-rah team, Go); flag
# upstream: https://github.com/s-rah/onionscan

_onionscan() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-list=+[file]:file:_files' \
        '--list=+[file]:file:_files' \
        '-jsonReport[output JSON report]' \
        '--jsonReport[output JSON report]' \
        '-simpleReport[simple report]' \
        '--simpleReport[simple report]' \
        '-reportFile=+[file]:file:_files -g "*.json *.txt"' \
        '--reportFile=+[file]:file:_files -g "*.json *.txt"' \
        '-mode=+[m]:m:(scan dirscan webscan crawl http ftp ssh mail)' \
        '--mode=+[m]:m:(scan dirscan webscan crawl http ftp ssh mail)' \
        '-timeout=+[seconds]:n:' \
        '--timeout=+[seconds]:n:' \
        '-tor=+[socks addr]:str:' \
        '--tor=+[socks addr]:str:' \
        '-fingerprint[generate fingerprint]' \
        '--fingerprint[generate fingerprint]' \
        '-batch=+[N]:n:' \
        '--batch=+[N]:n:' \
        '-crawlconfig=+[file]:file:_files -g "*.json"' \
        '--crawlconfig=+[file]:file:_files -g "*.json"' \
        '-dbdir=+[dir]:dir:_files -/' \
        '--dbdir=+[dir]:dir:_files -/' \
        '-webport=+[port]:n:' \
        '--webport=+[port]:n:' \
        '-cookie=+[cookie]:str:' \
        '*:onion address:'
}

_onionscan "$@"
