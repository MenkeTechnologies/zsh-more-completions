#compdef mgd77info
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/mgd77/mgd77info.html
# Source: GenericMappingTools/gmt supplements/mgd77 — summarize MGD77 marine geophysical cruise files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-C[list column abbreviations]' \
    '-E[one-line summary per cruise]' \
    '-M+[show metadata/header/E77/history]:what:_default' \
    '-I+[ignore file formats]:formats:(a c m t)' \
    '-L[list GEODAS institution codes]' \
    '*-V[verbose (stackable)]' \
    '*:GEODAS-ID or cruise file:_files' \
    && ret=0

return ret
