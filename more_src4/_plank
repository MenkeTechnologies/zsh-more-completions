#compdef plank
# Documentation: https://man.archlinux.org/man/extra/plank/plank.1.en
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help options]' \
  '(- *)'{-V,--version}'[show version]' \
  '--help-all[show all help options]' \
  '--help-gapplication[show GApplication options]' \
  '--help-gtk[show GTK+ options]' \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '(-n --name)'{-n+,--name=}'[dock name (default dock1)]:name:' \
  '--preferences[display preferences dialog]' \
  '--display=[X display to use]:display:' && ret=0

return ret
