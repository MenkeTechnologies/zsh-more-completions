#compdef mbsync
# Documentation: https://man.archlinux.org/man/mbsync.1.en
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mbsync (isync) - IMAP mailbox sync

_arguments -s -S \
  '(- *)'{-h,--help}'[display help summary]' \
  '(- *)'{-v,--version}'[display version information]' \
  '(-a --all)'{-a,--all}'[select all configured channels]' \
  '(-l --list)'{-l,--list}'[list mailboxes in selected channels (no sync)]' \
  '(-ls --list-stores)'{-ls,--list-stores}'[list contents of selected stores]' \
  '(-c --config)'{-c,--config}'+[load configuration from file]:file:_files' \
  '(-C --create)'{-C,--create}'+[propagate mailbox creations]:side:(near far both none)' \
  '(-R --remove)'{-R,--remove}'+[propagate mailbox removals]:side:(near far both none)' \
  '(-X --expunge)'{-X,--expunge}'+[propagate message expunges]:side:(near far both none)' \
  '(-n --new)'{-n,--new}'+[propagate new messages]:side:(near far both none)' \
  '(-o --old)'{-o,--old}'+[sync previously skipped/failed messages]:side:(near far both none)' \
  '(-u --upgrade)'{-u,--upgrade}'+[upgrade message placeholders]:side:(near far both none)' \
  '(-g --gone)'{-g,--gone}'+[propagate message deletions]:side:(near far both none)' \
  '(-f --flags)'{-f,--flags}'+[propagate flag changes]:side:(near far both none)' \
  '(-0 --noop)'{-0,--noop}"[don't propagate anything]" \
  '(-F --full)'{-F,--full}'[full bidirectional sync (new+upgrade+gone+flags)]' \
  '(-L --pull)'{-L,--pull}'[operate on near side only]' \
  '(-H --push)'{-H,--push}'[operate on far side only]' \
  '(-y --dry-run)'{-y,--dry-run}'[simulation mode (no changes)]' \
  '(-e --ext-exit)'{-e,--ext-exit}'[return extended exit codes]' \
  '(-V --verbose)'{-V,--verbose}'[enable verbose mode]' \
  '(-D --debug)'{-D,--debug}'+[enable debugging categories]:categories' \
  '(-q --quiet)'{-q,--quiet}'[suppress progress and notices]' \
  '*:channel or group:'
