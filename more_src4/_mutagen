#compdef mutagen
# Documentation: https://github.com/mutagen-io/mutagen/tree/master/cmd/mutagen
# Reference accessed: 2026-05-19
# Verified: upstream cmd/mutagen/main.go top-level cobra commands
# (sync, forward, project, daemon, version, legal, generate) and
# cmd/mutagen/sync/main.go AddCommand list for sync subcommands.

local curcontext="$curcontext" state line ret=1

_mutagen_commands() {
  local -a commands=(
    'sync:create and manage file synchronization sessions'
    'forward:create and manage forwarding sessions'
    'project:orchestrate sessions for a Mutagen project'
    'daemon:control the lifecycle of the Mutagen daemon'
    'version:show version information'
    'legal:show legal information'
    'generate:generate scripts and other files'
  )
  _describe -t commands 'mutagen command' commands
}

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:_mutagen_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      sync)
        _arguments -s -S \
          '1:action:(create list monitor flush pause resume reset terminate)' \
          '*:session' && ret=0
        ;;
      forward)
        _arguments -s -S \
          '1:action:(create list monitor pause resume terminate)' \
          '*:session' && ret=0
        ;;
      project)
        _arguments -s -S \
          '1:action:(start run list flush pause resume reset terminate)' \
          '-f[project file]:file:_files' && ret=0
        ;;
      daemon)
        _arguments -s -S \
          '1:action:(run start stop register unregister)' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac
return ret
