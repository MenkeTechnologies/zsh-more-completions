#compdef mayastor-agent-core agent-core
# _mayastor-agent-core — Mayastor Core Agent (single control-plane brain: registry/pool/nexus/volume/node reconcilers)
# upstream: https://github.com/openebs/mayastor-control-plane
# Flags from control-plane/agents/src/bin/core/main.rs CliArgs on tip (clap).

_mayastor-agent-core() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '(-c --cache-period)'{-c,--cache-period}'=[registry cache poll period]:duration:' \
        '--reconcile-idle-period=[reconcile-loop idle period]:duration:' \
        '--reconcile-period=[reconcile-loop work period]:duration:' \
        '--faulted-child-wait-period=[wait for replica to become healthy before onlining a faulted child]:duration:' \
        '--offline-rebuild-enabled[enable the OfflineRebuildReconciler (OFFLINE_REBUILD_ENABLED)]' \
        '--offline-rebuild-grace-period=[offline-rebuild grace period (OFFLINE_REBUILD_GRACE_PERIOD)]:duration:' \
        '--pool-async-creat-tmo=[grace period before GCing a stuck async pool create]:duration:' \
        '--disable-partial-rebuild[disable partial rebuild for volume targets (DISABLE_PARTIAL_REBUILD)]' \
        '--grpc-server-addr=[gRPC server bind address]:addr:' \
        '--store=[persistent-store URL (etcd)]:url:_urls' \
        '--store-timeout=[persistent-store operation timeout]:duration:' \
        '--core-grpc=[core gRPC URL]:url:_urls' \
        '--jaeger=[Jaeger collector endpoint]:url:_urls' \
        '*--tracing-tags=[csv key=value tags for tracing (TRACING_TAGS)]:csv:' \
        '--events-url=[NATS JetStream events URL]:url:_urls' \
        '--events-replicas=[JetStream replication factor for events]:n:' \
        '--fmt-style=[log format style]:style:(default compact pretty json)' \
        '--ansi-colors=[enable ANSI colours]:bool:(true false)' \
        '--max-rebuilds=[max concurrent rebuilds]:n:' \
        '--node-stale-timeout=[node stale timeout]:duration:'
}

_mayastor-agent-core "$@"
