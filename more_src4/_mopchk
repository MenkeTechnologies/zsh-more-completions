#compdef mopchk
# Documentation: man mopchk(1)
# Source: netbsd/src usr.sbin/mopd/mopchk — MOP image and interface check (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[display all Ethernet interfaces]' \
    '-v[print mopd suite version]' \
    '1::MOP-image file:_files' \
    && ret=0

return ret
