#compdef mmg2d mmg2d_O3 mmg2d_O3d mmg2d_debug
# Documentation: https://www.mmgtools.org/
# Source: MmgTools/mmg src/mmg2d/libmmg2d_tools.c (MMG2D_usage + MMG2D_parsar) +
#         src/common/libtools.c (MMG5_mmgUsage + MMG5_paramUsage1/2 + MMG5_2d3dUsage + MMG5_advancedUsage + MMG5_lagUsage).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[print help]' \
    '-v[verbosity level -1..10]:n:' \
    '-m[maximal memory size in Mbytes]:n:' \
    '-d[turn on debug mode]' \
    '-val[print default parameter values]' \
    '-default[save local parameters file for default parameters]' \
    '-in[input triangulation file]:file:_files' \
    '-out[output triangulation file]:file:_files' \
    '-o[output triangulation file (alias)]:file:_files' \
    '-sol[load solution or metric file]:file:_files' \
    '-met[load metric file]:file:_files' \
    '-f[load parameter file]:file:_files' \
    '-ls[create mesh of isovalue val (default 0)]:val:' \
    '-lssurf[split mesh boundaries on isovalue val (default 0)]:val:' \
    '-A[enable anisotropy (without metric file)]' \
    '-ar[angle detection value]:val:' \
    '-nr[no angle detection]' \
    '-hausd[control Hausdorff distance]:val:' \
    '-hgrad[control gradation]:val:' \
    '-hmax[maximal mesh size]:val:' \
    '-hmin[minimal mesh size]:val:' \
    '-hsiz[constant mesh size]:val:' \
    '-rmc[remove components with volume fraction less than val]:val:' \
    '-noinsert[no point insertion/deletion]' \
    '-nomove[no point relocation]' \
    '-noswap[no edge or face flipping]' \
    '-nreg[normal regularization]' \
    '-xreg[vertex regularization]' \
    '-nsd[save the subdomain number val (0 = all)]:val:' \
    '-optim[mesh optimization]' \
    '-lag[lagrangian mesh displacement (0/1/2)]:mode:(0 1 2)' \
    '-opnbdy[preserve input triangles at interface of opposite-orientation domains]' \
    '-nosizreq[disable required-edge-size enforcement over required vertices]' \
    '-hgradreq[control gradation from required entities toward others]:val:' \
    '-3dMedit[Gmsh visu IO (1=output, 2=in+out, 3=in only)]:val:(1 2 3)' \
    '-nofem[do not force creation of finite element mesh]' \
    '-nosurf[no surface modifications]' \
    '*:input mesh:_files' \
    && ret=0

return ret
