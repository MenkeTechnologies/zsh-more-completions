#compdef manila-rootwrap
# Documentation: https://docs.openstack.org/oslo.rootwrap/latest/user/usage.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Usage: manila-rootwrap ROOTWRAP_CONFIG COMMAND_LINE

# OpenStack Manila rootwrap helper
local curcontext="$curcontext" ret=1
_arguments -C \
  "(- *)"{-h,--help}"[show help]" \
  '1:rootwrap config file:_files' \
  '*::command:_command_names' && ret=0
return ret
