#compdef openhpi-clients
# Documentation: https://manpages.debian.org/testing/openhpi-clients/
# Reference accessed: 2026-05-20
# Verified: openhpi-clients is a package, not a single binary. Individual
# binaries (hpiel, hpitop, hpiinv, hpisensor, hpipower, hpidomain, hpitree,
# hpireset, hpithres, hpiwdt, hpiupgrade, hpisettime, hpifan, hpionoff,
# hpisettag, hpisetsystinfo, hpixml, hpi_shell) ship in the package and each
# accepts the shared HPI client options (-D/--domain, -N/--host, -C/--cfgfile,
# -X/--debug, -h/--help). See _openhpi-utils for the shared option set.
# STUB: minimal completion retained per "do not delete files" directive.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-D --domain)'{-D+,--domain=}'[HPI domain id]:nn:' \
  '(-N --host)'{-N+,--host=}'[daemon host\:port]:host\:port:' \
  '(-C --cfgfile)'{-C+,--cfgfile=}'[client config file]:file:_files' \
  '(-X --debug)'{-X,--debug}'[enable debug output]' && ret=0
return ret
