#compdef ptw
# Documentation: https://github.com/joeyespo/pytest-watch
# Reference accessed: 2026-05-30
# ptw — pytest-watch. Watches the filesystem and re-runs pytest on changes.
# Most unknown flags pass through to pytest, but the watcher itself has 19
# of its own. -q takes precedence over -v.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(- *)'{-V,--version}'[show version and exit]' \
  '*--ignore=[directory to ignore (repeatable)]:dir:_files -/' \
  '--ext=[comma-separated file extensions that trigger a re-run (default .py; * = any)]:exts:' \
  '--config=[config file (overrides implicit lookup)]:file:_files' \
  '(-c --clear)'{-c,--clear}'[clear the screen before each run]' \
  '(-n --nobeep)'{-n,--nobeep}'[do not beep on failure]' \
  '(-w --wait)'{-w,--wait}'[wait for run to finish before re-triggering]' \
  '--beforerun=[command to run before each test run]:command:_command_names -e' \
  '--afterrun=[command to run on completion or interruption (gets pytest exit code as $1)]:command:_command_names -e' \
  '--onpass=[command to run when tests pass]:command:_command_names -e' \
  '--onfail=[command to run when tests fail]:command:_command_names -e' \
  '--onexit=[command to run when ptw exits]:command:_command_names -e' \
  '--runner=[run a custom command instead of "pytest"]:command:_command_names -e' \
  '--pdb[start pdb on errors (implies --wait)]' \
  '--spool=[re-run delay in ms (default 200)]:ms:' \
  '(-p --poll)'{-p,--poll}'[use polling instead of inotify-style events (useful in VMs)]' \
  '(-q --quiet -v --verbose)'{-q,--quiet}'[decrease verbosity (overrides -v)]' \
  '(-q --quiet -v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '*:pytest path or pytest arg:_files' \
  && ret=0

return ret
