#compdef openchrome-mcp
# Documentation: https://github.com/shaun0927/openchrome
# Reference accessed: 2026-05-23
# Verified: npx openchrome-mcp --help.

# Zsh completion for openchrome-mcp - parallel browser sessions MCP for AI agents

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--reuse[reuse existing OpenChrome daemon for oc run]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'openchrome command' \
      'vault[manage local credential vault]' \
      'install[deprecated extension install]' \
      'uninstall[deprecated extension uninstall]' \
      'setup[configure MCP for Claude Code Codex or OpenCode]' \
      'config[print MCP configuration for client]' \
      'update[update globally installed package]' \
      'serve[start MCP server]' \
      'sessions[list or clear sessions]' \
      'doctor[check installation status]' \
      'launch[start Claude Code with isolated config]' \
      'recover[recover corrupted claude.json]' \
      'status[session manager status]' \
      'cleanup[clean stale sessions and backups]' \
      'totp[manage TOTP secrets]' \
      'run[run one MCP tool via one-shot server]' \
      'navigate[navigate to URL]' \
      'tabs_create[create tab with URL]' \
      'read_page[read current page]' \
      'page_screenshot[screenshot page]' \
      'tabs_context[tabs context]' \
      'tabs_close[close tab by id]' \
      'wait_for[wait for selector]' \
      'click[click element]' \
      'interact[interact with element]' \
      'form_input[fill form input]' \
      'javascript_tool[run JavaScript]' \
      'oc_assert[run outcome contract assertion]' \
      'admin[admin commands]' \
      'contract[outcome contract helpers]' \
      'playbook[YAML/JSON scenario runner]' \
      'replay[manage session recordings]' && ret=0
    ;;
  args)
    case $line[1] in
      setup)
        _arguments \
          '--client[client to configure]:(claude codex opencode)' \
          '--dashboard[enable terminal dashboard]' \
          '--auto-launch[auto-launch Chrome]' \
          '(-s --scope)'{-s+,--scope=}'[install scope]:(user project)' && ret=0
        ;;
      serve)
        _arguments \
          '(-p --port)'{-p+,--port=}'[Chrome debugging port]:port:' \
          '--auto-launch[auto-launch Chrome]' \
          '--user-data-dir[Chrome user data directory]:directory:_directories' \
          '--profile-directory[Chrome profile name]:profile:' \
          '--chrome-binary[Chrome binary path]:file:_files' \
          '--headless-shell[use chrome-headless-shell]' \
          '--window-size[window size WxH]:size:' \
          '--window-position[window position x,y]:position:' && ret=0
        ;;
      navigate|tabs_create)
        _arguments '1:url:url:' && ret=0
        ;;
      tabs_close)
        _arguments '1:tabId:tab id:' && ret=0
        ;;
      wait_for)
        _arguments '1:selector:selector:' && ret=0
        ;;
      click|interact)
        _arguments '1:ref:element ref:' && ret=0
        ;;
      form_input)
        _arguments '1:ref:ref:' '2:value:value:' && ret=0
        ;;
      javascript_tool)
        _arguments '1:code:JavaScript code:' && ret=0
        ;;
      oc_assert)
        _arguments '1:contract:JSON contract:' && ret=0
        ;;
      page_screenshot)
        _arguments ':path:output path:_files' && ret=0
        ;;
      run)
        _arguments '1:tool:MCP tool name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
