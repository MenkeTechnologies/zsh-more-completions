#compdef pamvalidate
# Documentation: man pamvalidate (Netpbm)
# Source: pass-through filter that fails if the input is an invalid Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    && ret=0

return ret
