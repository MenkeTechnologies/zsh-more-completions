#compdef minify-js
# Documentation: https://github.com/wilsonzlin/minify-js/blob/master/cli/src/main.rs
# Reference accessed: 2026-05-19
# Verified: upstream source at the URL above. The CLI exposes only
# --output and --mode (module|global) plus standard --help/--version.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-o --output)'{-o,--output}'+[output file]:file:_files' \
  '--mode=+[mode]:mode:(global module)' \
  '*:js file:_files -g "*.js"' && ret=0

return ret
