#compdef pkinfo
# pkinfo — report raster metadata (pktools)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-i,--input}'=[input raster file]:input file:_files' \
  '-ns[report number of samples (columns)]' \
  '-nl[report number of lines (rows)]' \
  '-nb[report number of bands]' \
  {-b,--band}'=[select band]:band number:' \
  '--bbox[report bounding box]' \
  '--stats[report basic statistics]' \
  '-ct[report color table]' \
  '-nodata[report nodata value]' \
  '-d[report data type]' \
  '-geo[report geotransform]' \
  '-ref[report projection info]' \
  '-dx[report pixel size in x]' \
  '-dy[report pixel size in y]' \
  '-mm[report min/max values]' \
  '-hist[report histogram]' \
  '-min[report minimum]' \
  '-max[report maximum]' \
  '-mean[report mean]' \
  '-stdev[report standard deviation]' && ret=0

return ret
