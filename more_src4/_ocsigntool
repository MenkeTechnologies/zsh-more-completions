#compdef ocsigntool
# _ocsigntool — OpenConnect ocsigntool (helper for signing CSDProtocol / SCEP-style payloads against an ocserv X.509 server cert chain; subcommands: list, sign, verify, gencert; --cert server cert, --key signing key, --cafile CA bundle, --out output file, --in input data, --hash digest, --version)
# upstream: https://gitlab.com/openconnect/openconnect (auth-tools)
# Subcommands from openconnect/openconnect tools/ocsigntool.c on tip.

_ocsigntool() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--cert+[server cert]:file:_files' \
        '--key+[signing key]:file:_files' \
        '--cafile+[CA bundle]:file:_files' \
        '--out+[output file]:file:_files' \
        '--in+[input file]:file:_files' \
        '--hash+[digest algo]:hash:(sha256 sha384 sha512 sha1)' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'ocsigntool command' '(list sign verify gencert)' ;;
        args) _arguments '*:argument:_files' ;;
    esac
}

_ocsigntool "$@"
