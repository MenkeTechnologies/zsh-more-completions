#compdef pamlevels
# Documentation: man pamlevels (Netpbm)
# Source: Netpbm pamlevels — apply linear or quadratic "levels" color transformation.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-from1 -f1)'{-from1,-f1}'+[source color 1 (color[:scale])]:from1:' \
    '(-to1 -t1)'{-to1,-t1}'+[target color 1 (color[:scale])]:to1:' \
    '(-from2 -f2)'{-from2,-f2}'+[source color 2]:from2:' \
    '(-to2 -t2)'{-to2,-t2}'+[target color 2]:to2:' \
    '(-from3 -f3)'{-from3,-f3}'+[source color 3 (enables quadratic mapping)]:from3:' \
    '(-to3 -t3)'{-to3,-t3}'+[target color 3]:to3:' \
    '-linear[work in linear (non-gamma) light intensity]' \
    '-fitbrightness[clip output to representable range]' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:input PAM/PNM file:_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    && ret=0

return ret
