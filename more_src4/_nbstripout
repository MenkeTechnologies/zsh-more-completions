#compdef nbstripout
# Documentation: https://github.com/kynan/nbstripout
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for nbstripout - strip output from Jupyter notebooks

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--install[install nbstripout as git filter]' \
  '--uninstall[uninstall nbstripout git filter]' \
  '--is-installed[check if nbstripout is installed]' \
  '--status[show installation status and configuration]' \
  '--global[apply to global git config]' \
  '--system[apply to system git config]' \
  '--verify[fail if any files would be stripped]' \
  '--dry-run[list files that would be stripped without modifying]' \
  '--attributes=[path to .gitattributes]:attributes file:_files' \
  '--python=[Python interpreter path]:path:_files' \
  '--keep-output[preserve all notebook outputs]' \
  '--keep-count[keep execution counts]' \
  '--keep-id[preserve sequential cell IDs]' \
  '--max-size=[keep outputs smaller than size]:size' \
  '--drop-output-type=[remove specific output types]:type' \
  '--keep-output-type=[keep only specified output types]:type' \
  '*--keep-metadata-keys=[metadata keys to preserve]:keys' \
  '--extra-keys=[strip additional metadata keys]:keys' \
  '--drop-empty-cells[remove cells with empty source]' \
  '--strip-init-cells[remove cells marked init_cell: true]' \
  '--drop-tagged-cells=[remove cells with given tags]:tags' \
  '(-f --force)'{-f,--force}'[process non-.ipynb files]' \
  '(-m --mode)'{-m,--mode=}'[specify notebook format]:mode:(jupyter zeppelin)' \
  '(-t --textconv)'{-t,--textconv}'[write to stdout]' \
  '--unix-newlines[force LF line endings]' \
  '*:notebook:_files -g "*.ipynb"' && ret=0

return ret
