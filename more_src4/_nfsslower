#compdef nfsslower nfsslower-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/nfsslower.py argparse)
# Reference accessed: 2026-05-29
# nfsslower — trace slow NFS file operations (read/write/open/getattr) on the client (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-j --csv)'{-j,--csv}'[just print fields: comma-separated values]' \
  '(-p --pid)'{-p,--pid=}'[trace this PID only]:pid:_pids' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:min_ms (minimum I/O duration to trace, default 10):' \
  && ret=0

return ret
