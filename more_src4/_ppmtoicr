#compdef ppmtoicr
# Documentation: man ppmtoicr (Netpbm)
# Source: convert a PPM image to NCSA Telnet ICR (Image Capture Receive) terminal escape stream.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-windowname+[ICR window name]:name:' \
    '-expand+[pixel expansion factor]:expand:' \
    '-display+[display geometry]:display:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
