#compdef normalize-audio normalize
# _normalize-audio — Chris Vaill's normalize (RMS normalization of WAV/MP3; -b batch mode treats all files as one album, -m mix mode treats them per-track, -a target amplitude (dBFS), -p set peak, -n no overwrite, -v verbose, --no-progress)
# upstream: https://github.com/normalize-audio/normalize
# Flags from normalize src/normalize.c on tip.

_normalize-audio() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-q[quiet]' \
        '-n[no overwrite]' \
        '-b[batch (album)]' \
        '-m[mix (per-track)]' \
        '-a+[target amplitude (dBFS)]:dbfs:' \
        '-p+[set peak]:dbfs:' \
        '-T+[adjustment threshold dB]:db:' \
        '-g+[apply gain]:db:' \
        '-w+[output bit width]:bits:(8 16 24 32)' \
        '--no-progress[no progress]' \
        '--peak[peak normalize only]' \
        '--mp3-mode[MP3 lossless gain]' \
        '*:audio file:_files -g "*.(wav|mp3|flac|ogg|aiff|au)"'
}

_normalize-audio "$@"
