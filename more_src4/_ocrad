#compdef ocrad
# Documentation: https://manpages.debian.org/bookworm/ocrad/ocrad.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm ocrad(1) manpage OPTIONS.
# Removed from prior file: bogus man.archlinux.org search URL.

# ocrad: GNU OCR program
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-a --append)'{-a,--append}'[append to output file]' \
  '(-c --charset)'{-c+,--charset=}'[character set]:name:' \
  '(-e --filter)'{-e+,--filter=}'[filter name]:filter:' \
  '(-E --user-filter)'{-E+,--user-filter=}'[user filter file]:file:_files' \
  '(-f --force)'{-f,--force}'[force overwrite output]' \
  '(-F --format)'{-F+,--format=}'[output byte format]:format:(byte utf8)' \
  '(-i --invert)'{-i,--invert}'[invert image levels]' \
  '(-l --layout)'{-l,--layout}'[show page layout instead of text]' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[suppress all info messages]' \
  '(-s --scale)'{-s+,--scale=}'[scale factor]:n:' \
  '(-t --transform)'{-t+,--transform=}'[transform name]:transform:' \
  '(-T --threshold)'{-T+,--threshold=}'[threshold 0.0-1.0]:value:' \
  '(-u --cut)'{-u+,--cut=}'[cut rectangle l,t,w,h]:rect:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-x --export)'{-x+,--export=}'[export to file]:file:_files' \
  '*:image file:_files' && ret=0
return ret
