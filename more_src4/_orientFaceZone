# Source: OpenFOAM/OpenFOAM-12 applications/utilities/mesh/manipulation/orientFaceZone — flip face zone orientation away from a reference point (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[OpenFOAM case directory]:dir:_files -/' \
    '-fileHandler+[file handler]:handler:(uncollated collated masterUncollated)' \
    '-parallel[run in parallel]' \
    '-noFunctionObjects[disable function objects]' \
    '-region+[region name]:region:_default' \
    '1:faceZone:_default' \
    '2:outsidePoint:_default' \
    && ret=0

return ret
