#compdef pbmtolps
# Documentation: man pbmtolps (Netpbm)
# Source: convert a PBM image to PostScript suitable for laser printers.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-dpi=[output resolution]:n:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pbm file:_files -g "*.(pbm|pnm|pam)"' \
    && ret=0

return ret
