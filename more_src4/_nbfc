#compdef nbfc
# _nbfc — NoteBook FanControl CLI client (nbfc-linux/nbfc-linux)
# upstream: https://github.com/nbfc-linux/nbfc-linux
# Subcommands from src/client.c (cli99).

_nbfc() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_nbfc_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                set)
                    _arguments \
                        '(-f --fan)'{-f+,--fan=}'[fan index to target]:fan:' \
                        '(-s --speed)'{-s+,--speed=}'[fan speed percentage]:percent:' \
                        '(-a --auto)'{-a,--auto}'[restore automatic fan control]'
                    ;;
                config)
                    _arguments \
                        '(-s --set)'{-s+,--set=}'[set the model config by name]:model:' \
                        '(-l --list)'{-l,--list}'[list installed model configs]' \
                        '(-r --recommend)'{-r,--recommend}'[recommend matching model configs]' \
                        '(-a --apply)'{-a+,--apply=}'[apply a config from a file]:file:_files -g "*.json"'
                    ;;
                status)
                    _arguments \
                        '(-a --all)'{-a,--all}'[show full status]' \
                        '(-f --fan)'{-f+,--fan=}'[show only this fan]:fan:' \
                        '(-w --watch)'{-w+,--watch=}'[refresh every N seconds]:seconds:' \
                        '--service[show service status only]'
                    ;;
                start)
                    _arguments \
                        '(-r --read-only)'{-r,--read-only}'[start in read-only mode]'
                    ;;
                update)
                    _arguments \
                        '--from=[load configs from this directory/URL instead]:source:'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_nbfc_commands] )) ||
_nbfc_commands() {
    local -a commands
    commands=(
        'start:start the nbfc service'
        'stop:stop the nbfc service'
        'restart:restart the nbfc service'
        'status:show fan / service status'
        'set:set fan speed or restore auto'
        'config:list / set / apply model configs'
        'sensors:show available temperature sensors'
        'update:download the latest config repository'
        'help:show help for a command'
    )
    _describe -t commands 'nbfc command' commands
}

_nbfc "$@"
