#compdef ompi-iof
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/ompi-iof.1.html
# Reference accessed: 2026-05-20
# Verified: upstream Open MPI ompi-iof(1) manpage.

# ompi-iof: redirect/show stdout/stderr of OMPI MPI processes
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[display help]' \
  '(-pid --pid)'{-pid,--pid}'[pid of mpirun]:pid:' \
  '(-stdout --stdout)'{-stdout,--stdout}'[display stdout of the process]' \
  '(-stderr --stderr)'{-stderr,--stderr}'[display stderr of the process]' \
  '(-stddiag --stddiag)'{-stddiag,--stddiag}'[display stddiag of the process]' \
  '(-rank --rank)'{-rank,--rank}'[rank of the process]:rank:' \
  '(-tag-output --tag-output)'{-tag-output,--tag-output}'[tag each line with process and stream name]' \
  '*::ompi-iof args:' && ret=0
return ret
