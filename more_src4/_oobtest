#compdef oobtest
# Documentation: https://github.com/bluez/bluez/blob/master/tools/oobtest.c
# Source: BlueZ tools/oobtest.c — Out-Of-Band pairing tester (LE legacy TK / P-192 / P-256).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-B --bredr -L --le)'{-B,--bredr}'[use BR/EDR transport]' \
    '(-B --bredr -L --le)'{-L,--le}'[use LE transport]' \
    '(-S --sc -O --sconly -P --legacy)'{-S,--sc}'[use Secure Connections]' \
    '(-S --sc -O --sconly -P --legacy)'{-O,--sconly}'[use Secure Connections Only]' \
    '(-S --sc -O --sconly -P --legacy)'{-P,--legacy}'[use Legacy Pairing]' \
    '(-R --random)'{-R,--random}'[use static random address]' \
    '(-Y --privacy)'{-Y,--privacy}'[use LE privacy feature]' \
    '(-D --debug)'{-D,--debug}'[use pairing debug keys]' \
    '(-C --cross)'{-C,--cross}'[use cross-transport pairing]' \
    '(-0 --tk -1 --p192 -2 --p256)'{-0,--tk}'[provide LE legacy OOB data (TK)]' \
    '(-0 --tk -1 --p192 -2 --p256)'{-1,--p192}'[provide P-192 OOB data]' \
    '(-0 --tk -1 --p192 -2 --p256)'{-2,--p256}'[provide P-256 OOB data]' \
    '(-I --initiator -A --acceptor)'{-I,--initiator}'[initiator provides OOB data]' \
    '(-I --initiator -A --acceptor)'{-A,--acceptor}'[acceptor provides OOB data]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    && ret=0

return ret
