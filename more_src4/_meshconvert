#compdef meshconvert
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/meshconvert.html
# Source: MRtrix3/mrtrix3 cmd/meshconvert.cpp — convert meshes between formats and apply transforms (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-binary[write output mesh in binary format if supported]' \
    '-transform+[transform vertices via template image]:mode:(first2real real2first voxel2real real2voxel fs2real):image:_files -g "*.{nii,nii.gz,mif}"' \
    '1:input mesh:_files -g "*.{obj,vtk,stl,ply}"' \
    '2:output mesh:_files -g "*.{obj,vtk,stl,ply}"' \
    && ret=0

return ret
