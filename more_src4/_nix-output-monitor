#compdef nom
# Documentation: https://github.com/maralorn/nix-output-monitor
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for nix-output-monitor (nom - pretty nix build output)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--json[parse JSON-formatted log lines from stdin]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'build:build with pretty output (wraps nix build)'
      'shell:shell with pretty output (wraps nix shell)'
      'develop:develop with pretty output (wraps nix develop)'
    )
    _describe -t commands 'nom command' commands && ret=0
    ;;
  (args)
    _arguments '*:nix arguments:' && ret=0
    ;;
esac

return ret
