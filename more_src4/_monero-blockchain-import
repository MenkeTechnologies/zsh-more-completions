#compdef monero-blockchain-import
# Documentation: https://github.com/monero-project/monero/blob/master/src/blockchain_utilities/blockchain_import.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Source: https://github.com/BibXMR/monero-zsh-completions/blob/6540df4783f354863955175790dae12735e30b2d/_monero-blockchain-import
# Repository: BibXMR/monero-zsh-completions (_monero-blockchain-import)

_monero-blockchain-import() {
  _arguments \
    '(- *)--help[Produce help message]' \
    '--batch[Batch transactions for faster import]' \
    '--batch-size=[batch size]:batch size' \
    '--block-stop=[Stop at block number]:block height' \
    '--count-blocks[Count blocks in bootstrap file and exit]' \
    '--dangerous-unverified-import[Skip block verification on import (only safe for self-exported files)]' \
    '--data-dir=[Specify data directory]:data directory:_directories' \
    '--drop-hard-fork[Drop hard fork subdbs]' \
    '--input-file=[Specify input file]:input file:_files' \
    '--log-level=[0-4 or categories]:log level' \
    '--pop-blocks=[Remove blocks from end of blockchain]:number of blocks' \
    '--resume[Resume from current height if output database already exists]' \
    '(--testnet --regtest)--stagenet[Run on stagenet]' \
    '(--stagenet --regtest)--testnet[Run on testnet]' \
    '(--testnet --stagenet)--regtest[Run on regtest]'
}

_monero-blockchain-import "$@"
