#compdef pgmmedian
# Documentation: man pgmmedian (Netpbm)
# Source: apply a median filter to a PGM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-width=[filter window width]:n:' \
    '-height=[filter window height]:n:' \
    '-type=[median algorithm]:type:(histogram_sort select)' \
    '-cutoff=[switch-over cutoff between algorithms]:int:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pgm file:_files -g "*.(pgm|pnm|pam)"' \
    && ret=0

return ret
