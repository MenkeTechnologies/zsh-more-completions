#compdef pidgin-otr
# Documentation: (Pidgin plugin loaded at runtime; no standalone CLI)
# Reference accessed: 2026-05-16
# Verified: pidgin-otr is an OTR (Off-The-Record messaging) plugin loaded by
# the Pidgin IM client, not a standalone binary.

# pidgin-otr: OTR plugin for Pidgin (loaded by Pidgin runtime)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*::extra args:_files' && ret=0
return ret
