#compdef offlineimap-cli
# _offlineimap-cli — John Goerzen OfflineIMAP disconnected IMAP synchronizer CLI alias (OfflineIMAP team, Python); custom argparse
# upstream: https://github.com/OfflineIMAP/offlineimap3

_offlineimap-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-1[only one sync]' \
        '-P+[profile dir]:dir:_files -/' \
        '--profile=+[profile dir]:dir:_files -/' \
        '-a+[accounts csv]:str:' \
        '--accounts=+[accounts csv]:str:' \
        '-c+[config file]:file:_files -g ".offlineimaprc"' \
        '--config=+[config file]:file:_files -g ".offlineimaprc"' \
        '-d+[debug type]:t:(imap maildir gmail thread)' \
        '--debug=+[debug type]:t:(imap maildir gmail thread)' \
        '-l+[log file]:file:_files' \
        '--logfile=+[log file]:file:_files' \
        '-f+[folders csv]:str:' \
        '--folder=+[folders csv]:str:' \
        '-k+[key=value]:str:' \
        '--key=+[key=value]:str:' \
        '-o[once mode]' \
        '--once[once mode]' \
        '-q[quick mode]' \
        '--quick[quick mode]' \
        '-s[run in syslog]' \
        '--syslog[run in syslog]' \
        '--info[print info]' \
        '-u+[ui]:u:(quiet basic ttyui machineui blinkenlights)' \
        '--ui=+[ui]:u:(quiet basic ttyui machineui blinkenlights)' \
        '-V[show version]' \
        '--migrate-fmd5-using-nametrans[migrate fmd5 using nametrans]' \
        '*:arg:'
}

_offlineimap-cli "$@"
