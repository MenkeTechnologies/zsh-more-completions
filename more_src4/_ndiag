_ndiag() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'doc:Generate architecture document'
        'draw:Draw view'
        'coverage:Measure document coverage'
        'fetch-icons:Fetch icon set from internet'
        'list:List ndiag resources'
        'completion:Output shell completion code'
        'help:Help about any command'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[help for ndiag]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            _describe -t commands 'ndiag command' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                doc)         _ndiag_doc        && ret=0 ;;
                draw)        _ndiag_draw       && ret=0 ;;
                coverage)    _ndiag_coverage   && ret=0 ;;
                fetch-icons) _ndiag_fetchicons && ret=0 ;;
                list)        _ndiag_list       && ret=0 ;;
                completion)  _ndiag_completion && ret=0 ;;
                help)
                    _describe -t commands 'ndiag command' subcmds && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

# cmd/doc.go — Generate architecture document
_ndiag_doc() {
    _arguments \
        '--force[generate a document without checking for the existence of an existing document]' \
        '*'{-c,--config=}'[config file or directory path]:path:_files' \
        '*'{-n,--nodes=}'[real node list file path]:path:_files' \
        '--rm-dist[remove all files in the document directory before generating the documents]' \
        '--hide-details[hide details]' \
        '(-h --help)'{-h,--help}'[help for doc]'
}

# cmd/draw.go — Draw view
_ndiag_draw() {
    _arguments \
        '(-t --format)'{-t,--format=}'[output format]:format:(svg png jpg pdf)' \
        '*'{-l,--layer=}'[layer]:layer:' \
        '*'{-c,--config=}'[config file or directory path]:path:_files' \
        '*'{-n,--nodes=}'[real node list file path]:path:_files' \
        '--out=[output file path]:path:_files' \
        '--hide-details[hide details]' \
        '(-h --help)'{-h,--help}'[help for draw]'
}

# cmd/coverage.go — measure document coverage
_ndiag_coverage() {
    _arguments \
        '*'{-c,--config=}'[config file or directory path]:path:_files' \
        '(-t --format)'{-t,--format=}'[output format]:format:' \
        '(-h --help)'{-h,--help}'[help for coverage]'
}

# cmd/fetchIcons.go — Fetch icon set from internet
_ndiag_fetchicons() {
    _arguments \
        '*'{-c,--config=}'[config file or directory path]:path:_files' \
        '--prefix=[icon key prefix]:prefix:' \
        '(-h --help)'{-h,--help}'[help for fetch-icons]'
}

# cmd/list.go — parent of list descs / list icons
_ndiag_list() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a list_subcmds
    list_subcmds=(
        'descs:List description file paths'
        'icons:List available icons'
    )

    _arguments -C \
        '(-h --help)'{-h,--help}'[help for list]' \
        '1: :->lcmds' \
        '*::arg:->largs' && ret=0

    case $state in
        lcmds)
            _describe -t commands 'ndiag list command' list_subcmds && ret=0
            ;;
        largs)
            case $line[1] in
                descs)
                    _arguments \
                        '*'{-c,--config=}'[config file or directory path]:path:_files' \
                        '(-h --help)'{-h,--help}'[help for descs]' && ret=0
                    ;;
                icons)
                    _arguments \
                        '*'{-c,--config=}'[config file or directory path]:path:_files' \
                        '(-h --help)'{-h,--help}'[help for icons]' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

# cmd/completion.go — emit shell completion source for bash/zsh/fish/powershell
_ndiag_completion() {
    _arguments \
        '(-o --out)'{-o,--out=}'[output file path]:path:_files' \
        '(-h --help)'{-h,--help}'[help for completion]' \
        '1:shell:(bash zsh fish powershell)'
}

_ndiag "$@"
