#compdef pnmpsnr
# Documentation: man pnmpsnr (Netpbm)
# Source: compute Peak Signal-to-Noise Ratio between two Netpbm images.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-rgb[compute PSNR per RGB channel]' \
    '-machine[machine-readable output]' \
    '-max=[max sample value]:n:' \
    '-target=[reference PSNR target]:n:' \
    '-target1=[per-channel-1 PSNR target]:n:' \
    '-target2=[per-channel-2 PSNR target]:n:' \
    '-target3=[per-channel-3 PSNR target]:n:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pnm file 1:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    '2:pnm file 2:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
