#compdef mrmetric
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/mrmetric.html
# Source: MRtrix3/mrtrix3 cmd/mrmetric.cpp — compute dissimilarity metric between two images (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-space+[evaluation space]:method:(voxel image1 image2 average)' \
    '-interp+[interpolation method]:method:(nearest linear cubic sinc)' \
    '-metric+[dissimilarity metric]:method:(diff cc)' \
    '-mask1+[mask for image 1]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-mask2+[mask for image 2]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-nonormalisation[do not normalise the metric]' \
    '-overlap[report mask overlap]' \
    '1:image1:_files -g "*.{nii,nii.gz,mif}"' \
    '2:image2:_files -g "*.{nii,nii.gz,mif}"' \
    && ret=0

return ret
