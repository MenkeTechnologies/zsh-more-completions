#compdef namd namd2 namd3 charmrun
# _namd — UIUC Theoretical and Computational Biophysics Group NAMD scalable molecular dynamics with CHARMM AMBER force fields (TCBG team, C++/Charm++); custom argparse
# upstream: https://www.ks.uiuc.edu/Research/namd/

_namd() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '+p+[number of processors]:n:' \
        '+s+[stack size]:n:' \
        '+ppn+[procs per node]:n:' \
        '+pemap+[CPU map]:str:' \
        '+commap+[comm thread map]:str:' \
        '+isomalloc_sync[isomalloc sync]' \
        '+balancer+[load balancer]:str:' \
        '+LBPeriod+[seconds]:f:' \
        '+LBObjOnly[obj only LB]' \
        '+LBOff[disable LB]' \
        '+devices+[GPUs csv]:str:' \
        '+ignoresharing[ignore sharing]' \
        '+autoProvision[auto provision]' \
        '+disablemask[disable mask]' \
        '+stdin+[stdin file]:file:_files' \
        '+notrace[no trace]' \
        '+restart+[file]:file:_files' \
        '+restartfile+[file]:file:_files' \
        '+remoteshell[remote shell]' \
        '+nodelist+[nodelist file]:file:_files' \
        '++local[run on local node]' \
        '++remote-shell+[shell cmd]:str:' \
        '+migratable[migratable mode]' \
        '+strict-stride[strict stride]' \
        '+keep-cyc[keep cyc]' \
        '+resync+[sync]:f:' \
        '+CkPpn+[procs per node]:n:' \
        '+ckp-files+[ckp count]:n:' \
        '+restart-after+[seconds]:n:' \
        '*:input config:_files -g "*.namd *.conf *.tcl"'
}

_namd "$@"
