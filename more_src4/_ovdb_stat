#compdef ovdb_stat
# Documentation: man ovdb_stat(8)
# Source: InterNetNews/inn frontends/ovdb_stat.c — display ovdb (Berkeley DB) statistics (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-H[output as HTML]' \
    '-g[print group status entry]' \
    '-c[print article count for groups]' \
    '-i[print group info]' \
    '-r+[article range]:range:_default' \
    '-k[display lock-region info]' \
    '-l[display log-region info]' \
    '-m[display memory pool info]' \
    '-M[display memory pool info incl all DBs]' \
    '-t[display transaction-region info]' \
    '-v[display Berkeley DB version]' \
    '-d+[display info on specific database]:db:_default' \
    '*:newsgroup:_default' \
    && ret=0

return ret
