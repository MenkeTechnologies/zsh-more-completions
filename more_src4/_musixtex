#compdef musixtex
# Documentation: musixtex --help (texlua musixtex.lua version 0.23b)
# Source: MusiXTeX driver — multi-pass etex / musixflx / etex orchestrator with .xml/.mtx/.pmx/.aspc preprocessing chain.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-v,--version}'[print version]' \
    '(- *)'{-h,--help}'[print help]' \
    '-l[latex source (implied by .ltx)]' \
    '-p[direct tex→pdf (pdftex etc.)]' \
    '-F[use FMT as the TeX processor]:tex format:' \
    '-d[tex→dvi→pdf (uses dvipdfm unless -D given)]' \
    '-D[use DVIXX as the dvi processor]:dvi driver:' \
    '-P[use PS2PDFXX as the Postscript processor]:ps→pdf converter:' \
    '-c[preprocess pmx file using pmxchords]' \
    '-m[stop at pmx]' \
    '-M[use PREPMXX as the mtx preprocessor]:mtx preprocessor:' \
    '-A[use AUTOSPX as the aspc preprocessor]:aspc preprocessor:' \
    '-X[use PMXABX as the pmx preprocessor]:pmx preprocessor:' \
    '-L[use XMLX as the xml preprocessor]:xml preprocessor:' \
    '-t[stop at tex/mid]' \
    '-s[stop at dvi]' \
    '-g[stop at ps]' \
    '-i[retain intermediate and log files]' \
    '-q[quiet mode (redirect logs to musixtex.log)]' \
    '-1[one-pass [pdf][la]tex processing]' \
    '-x[run makeindex]' \
    '-f[restore default processing]' \
    '*:source file:_files -g "*.(xml|mtx|pmx|aspc|tex|ltx)"' \
    && ret=0

return ret
