#compdef ng-update
# _ng-update — Angular `ng update` package migrator shim; updates dependencies + runs registered migration schematics
# upstream: https://github.com/angular/angular-cli

_ng-update() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--all[update all packages]' \
        '--allow-dirty[allow dirty working tree]' \
        '--create-commits[commit each migration]' \
        '--force[allow incompatible peer deps]' \
        '--from+[from version]:ver:' \
        '--to+[to version]:ver:' \
        '--migrate-only[only run migrations]' \
        '--name+[migration name]:name:' \
        '--next[use prerelease versions]' \
        '--package-manager+[package manager]:pm:(npm yarn pnpm cnpm)' \
        '--verbose[verbose log]' \
        '*:package:'
}

_ng-update "$@"
