#compdef mp4chaps
# _mp4chaps — manage QuickTime/Nero chapters in MP4 files (enzo1982/mp4v2)
# upstream: https://github.com/enzo1982/mp4v2
# Flags from util/mp4chaps.cpp (_actionGroup + _parmGroup).

_mp4chaps() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-A --chapter-any)'{-A,--chapter-any}'[act on any chapter type (default)]' \
        '(-Q --chapter-qt)'{-Q,--chapter-qt}'[act on QuickTime chapters]' \
        '(-N --chapter-nero)'{-N,--chapter-nero}'[act on Nero chapters]' \
        '--format-native[export in native format (default)]' \
        '(-C --format-common)'{-C,--format-common}'[export in common format]' \
        '(-l --list)'{-l,--list}'[list available chapters]' \
        '(-c --convert)'{-c,--convert}'[convert available chapters]' \
        '(-e --every)'{-e+,--every=}'[create chapters every NUM seconds]:secs:' \
        '(-x --export)'{-x,--export}'[export chapters to mp4file.chapters.txt]' \
        '(-i --import)'{-i,--import}'[import chapters from mp4file.chapters.txt]' \
        '(-r --remove)'{-r,--remove}'[remove all chapters]' \
        '*:MP4 file:_files -g "*.(m4a|m4b|m4v|mp4)"'
}

_mp4chaps "$@"
