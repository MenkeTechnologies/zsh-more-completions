#compdef openring
# Documentation: https://git.sr.ht/~sircmpwn/openring
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-n[number of articles to fetch]:count' \
  '*-s[feed URL to aggregate]:url' \
  '-S[file with feed URLs, one per line]:file:_files' \
  '<[template file]:file:_files' \
  '>[output file]:file:_files'
