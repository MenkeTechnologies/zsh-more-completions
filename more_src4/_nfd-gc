#compdef nfd-gc
# _nfd-gc — Node Feature Discovery garbage-collector (kubernetes-sigs/node-feature-discovery)
# upstream: https://github.com/kubernetes-sigs/node-feature-discovery
# Flags from cmd/nfd-gc/main.go on tip.

_nfd-gc() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-gc-interval=[NodeFeature/NRT GC interval]:dur:' \
        '-kubeconfig=[kubeconfig file]:file:_files' \
        '-port=[health/metrics bind port]:port:' \
        '-v[klog verbosity level]:n:' \
        '-logtostderr[log to stderr]'
}

_nfd-gc "$@"
