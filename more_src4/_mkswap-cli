#compdef mkswap-cli
# _mkswap-cli — util-linux mkswap Linux swap area setup CLI alias (util-linux team, C); custom argparse
# upstream: https://github.com/util-linux/util-linux

_mkswap-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c[check device for bad blocks]' \
        '--check[check device for bad blocks]' \
        '-f[force]' \
        '--force[force]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-L+[label]:str:' \
        '--label=+[label]:str:' \
        '-p+[page size]:n:' \
        '--pagesize=+[page size]:n:' \
        '-U+[uuid]:str:' \
        '--uuid=+[uuid]:str:' \
        '-e[allow swap on systems with errors]' \
        '--lock=+[mode]:m:(yes no nonblock)' \
        '--swap-pages=+[count]:n:' \
        '*:device size:_files'
}

_mkswap-cli "$@"
