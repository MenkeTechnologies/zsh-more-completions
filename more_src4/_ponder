#compdef ponder
# Documentation: https://www.npmjs.com/package/ponder
# Reference accessed: 2026-05-23
# Verified: npx ponder --help.

# Zsh completion for ponder - Ethereum indexing framework CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'dev:start development server with hot reloading'
  'start:start production server'
  'serve:start production HTTP server without indexer'
  'db:database management commands'
  'codegen:generate ponder-env.d.ts'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--root=[project root directory]:dir:_directories' \
  '--config=[config file path]:file:_files' \
  '(-v --debug)'{-v,--debug}'[enable debug logs]' \
  '(-vv --trace)'{-vv,--trace}'[enable trace logs]' \
  '--log-level=[minimum log level]:level:(error warn info debug trace)' \
  '--log-format=[log format]:format:(pretty json)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'ponder command' commands && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
