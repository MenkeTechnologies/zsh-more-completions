#compdef modstat
# Documentation: man modstat(8)
# Source: netbsd/src sbin/modstat — kernel module status display (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A[check autoload considering kern.module.autoload]' \
    '-a[check autoload ignoring the sysctl]' \
    '-e[check permission to load a module now]' \
    '-k[show kernel address of module text segment]' \
    '-n+[display status for named module]:name:_default' \
    '1::module name:_default' \
    && ret=0

return ret
