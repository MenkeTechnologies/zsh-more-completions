#compdef obnam
# Documentation: https://manpages.debian.org/jessie/obnam/obnam.1.en.html
# Reference accessed: 2026-05-19
# Verified: obnam upstream Debian jessie manpage. Real subcmds:
# backup, restore, verify, ls, generations, genids, forget,
# client-keys, clients, diff, nagios-last-backup-age, mount, fsck,
# add-key, remove-key, list-keys, list-toplevels, remove-client,
# force-lock, lock, dump-repo, help, help-all.
# Corrected from prior file: 'list-generations' is really
# 'generations'; 'kdirstat' is not in upstream; removed bogus
# man.archlinux.org URL.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'backup:make a backup'
  'restore:restore some or all files from a backup'
  'generations:list backup generations'
  'genids:list generation IDs (scripting-friendly)'
  'ls:list files in a backup generation'
  'forget:remove old generations'
  'verify:verify backup integrity'
  'diff:show differences between two generations'
  'mount:mount a backup as a FUSE filesystem'
  'nagios-last-backup-age:check last backup age (Nagios)'
  'fsck:check repository for errors'
  'force-lock:break a leftover lock'
  'lock:lock the repository'
  'add-key:add encryption key to the repository'
  'remove-key:remove encryption key'
  'client-keys:list client encryption keys'
  'list-keys:list encryption keys'
  'list-toplevels:list toplevels with key access'
  'remove-client:remove a client from the repository'
  'dump-repo:dump repository structure'
  'help:show help'
  'help-all:show full help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-r --repository)'{-r,--repository}'+[repository URL]:url:' \
  '(-c --config)'{-c,--config}'+[config file]:file:_files' \
  '--client-name=[client name]:name:' \
  '--encrypt-with=[GnuPG key ID]:keyid:' \
  '--root=[backup root directory]:dir:_files -/' \
  '--lock-timeout=[lock timeout sec]:sec:' \
  '--log=[log file]:file:_files' \
  '--log-level=[log level]:level:(debug info warning error critical fatal)' \
  '--trace=[trace messages from MODULE]:module:' \
  '--quiet[suppress output]' \
  '--verbose[verbose output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'obnam command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (restore|mount)
        _arguments \
          '--to=[restore destination]:dir:_files -/' \
          '--generation=[generation id]:gen:' && ret=0 ;;
    esac ;;
esac

return ret
