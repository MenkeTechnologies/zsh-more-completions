#compdef osrm-extract
# Documentation: https://github.com/Project-OSRM/osrm-backend
# Source: Project-OSRM/osrm-backend src/tools/extract.cpp — extract OSRM graph from .osm/.pbf data.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--version[show version]' \
    '(- *)--help[show help]' \
    '--list-inputs[list required/optional input file extensions]' \
    '--verbosity=[log verbosity]:level:_default' \
    '(-p --profile)'{-p+,--profile=}'[Lua routing profile path]:file:_files -g "*.lua(-.)"' \
    '--data_version=[data version (or osmosis for file timestamp)]:value:_default' \
    '(-t --threads)'{-t+,--threads=}'[number of threads]:n:_default' \
    '--small-component-size=[node threshold for "big" SCC]:n:_default' \
    '--with-osm-metadata[use OSM metadata during parsing]' \
    '--parse-conditional-restrictions[save conditional restrictions]' \
    '--location-dependent-data=[GeoJSON files for location-dependent data]:file:_files -g "*.geojson(-.)"' \
    '--disable-location-cache[disable internal location cache]' \
    '--dump-nbg-graph[dump raw node-based graph (.osrm) for debug]' \
    '--output=[output base path]:path:_files' \
    '*:OSM input file:_files -g "*.(osm|osm.bz2|osm.pbf)(-.)"' \
    && ret=0

return ret
