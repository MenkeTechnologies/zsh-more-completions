#compdef pgmbentley
# Documentation: man pgmbentley (Netpbm)
# Source: apply a Wilfred Bentley horizontal-shift effect to a PGM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pgm file:_files -g "*.(pgm|pnm|pam)"' \
    && ret=0

return ret
