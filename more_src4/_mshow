#compdef mshow
# Documentation: https://manpages.debian.org/testing/mblaze/mshow.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. mblaze mshow render messages.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h+[display only given colon-separated headers]:headers:' \
  '-A+[mixed/alternative preference colon list]:mimetypes:' \
  '-n[do not update current message link]' \
  '-q[do not render body, stop after headers]' \
  '-r[do not render body, print raw body]' \
  '-B[decode encoded-words in MIME parameters (violates RFC 2047)]' \
  '-F[do not apply filters to MIME parts]' \
  '-H[do not decode headers, print raw]' \
  '-L[do not filter headers, print all decoded]' \
  '-N[do not show MIME structure markers]' \
  '-x[extract MIME parts to files from msg]:msg:' \
  '-O[extract MIME parts to stdout from msg]:msg:' \
  '-t[list mode - list MIME parts of each msg]' \
  '-R[render text parts of msg for reply]:msg:' \
  '*:message:_files' && ret=0

return ret
