#compdef PTBatcherGUI
# Documentation: https://wiki.panotools.org/PTBatcherGUI
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# PTBatcherGUI: Hugin batch processor (wxWidgets GUI, accepts / or -- switches)
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-b --batch)'{-b,--batch}'[run batch immediately]' \
  '(-d --delete)'{-d,--delete}'[delete *.pto files after stitching]' \
  '(-o --overwrite)'{-o,--overwrite}'[overwrite previous files without asking]' \
  '(-s --shutdown)'{-s,--shutdown}'[shutdown computer after batch is complete]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output when processing projects]' \
  '(-a --assistant)'{-a,--assistant}'[run the assistant on the given projects]' \
  '(-u --user-defined)'{-u+,--user-defined=}'[user defined sequence file]:file:_files' \
  '*:project file:_files -g "*.pto"' && ret=0

return ret
