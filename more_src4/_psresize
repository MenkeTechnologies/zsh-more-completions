#compdef psresize
# Documentation: psresize usage (psutils 1.23)
# Source: scale a PostScript document to a new paper size.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-q[quiet operation]' \
    '-w+[input page width]:width:' \
    '-h+[input page height]:height:' \
    '-p+[input paper name]:paper:(a3 a4 a5 b5 letter legal tabloid)' \
    '-W+[output page width]:width:' \
    '-H+[output page height]:height:' \
    '-P+[output paper name]:paper:(a3 a4 a5 b5 letter legal tabloid)' \
    '1:input ps:_files -g "*.ps"' \
    '2:output ps:_files -g "*.ps"' \
    && ret=0

return ret
