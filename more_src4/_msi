#compdef msi
# Documentation: https://github.com/EarthScope/msi
# Source: EarthScope/msi src/msi.c — miniSEED inspector (print details of seismic miniSEED records).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-V[show version]' \
    '(- *)-h[show help]' \
    '*-v[verbose (stackable)]' \
    '*-H+[add custom header for URL reads]:header:_default' \
    '-u+[username:password for URL reads]:credentials:_default' \
    '-ts+[limit to records starting after time]:time:_default' \
    '-te+[limit to records ending before time]:time:_default' \
    '-m+[limit to records matching pattern]:pattern:_default' \
    '-r+[limit to records NOT matching pattern]:pattern:_default' \
    '-n+[only process first N records]:count:_default' \
    '-snd[skip non-miniSEED data]' \
    '*-p[print header details (stackable)]' \
    '-O[include file offset in header details]' \
    '-L[include latency in header details]' \
    '-s[print summary after processing]' \
    '-d[unpack and print first 6 samples/record]' \
    '-D[unpack and print all samples]' \
    '-z[validate and print records raw]' \
    '-t[print sorted trace list after processing]' \
    '-T[only print sorted trace list]' \
    '-tg[include gap estimates in trace list]' \
    '-tt+[time tolerance for continuous traces]:secs:_default' \
    '-rt+[sample rate tolerance for continuous traces]:diff:_default' \
    '-g[print sorted gap/overlap list]' \
    '-G[only print sorted gap/overlap list]' \
    '-gmin+[only gaps/overlaps >= secs]:secs:_default' \
    '-gmax+[only gaps/overlaps <= secs]:secs:_default' \
    '-S[print SYNC trace summary]' \
    '-P[group traces by publication version]' \
    '-tf+[time string format for trace/gap lists]:format:_default' \
    '-b+[write binary samples to file]:binfile:_files' \
    '-o+[write processed records to file]:outfile:_files' \
    '*:miniseed file:_files' \
    && ret=0

return ret
