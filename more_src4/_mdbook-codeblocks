#compdef mdbook-codeblocks
# _mdbook-codeblocks — label/badge language-tagged code blocks in mdbook (Roms1383/mdbook-codeblocks)
# upstream: https://github.com/Roms1383/mdbook-codeblocks
# Subcommands from src/cli.rs (clap).

_mdbook-codeblocks() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'supports:check whether a renderer is supported'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                supports) _arguments '1:renderer:(html epub markdown)' ;;
            esac
            ;;
    esac
}

_mdbook-codeblocks "$@"
