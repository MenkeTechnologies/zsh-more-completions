#compdef mqtt2prometheus
# _mqtt2prometheus — MQTT → Prometheus bridge (hikhvar/mqtt2prometheus)
# upstream: https://github.com/hikhvar/mqtt2prometheus
# Flags from cmd/mqtt2prometheus.go (flag).

_mqtt2prometheus() {
    _arguments \
        '(- *)-h[show help]' \
        '(- *)-version[show version]' \
        '-config=[YAML config file]:file:_files -g "*.(yml|yaml)"' \
        '-listen-port=[HTTP bind port]:port:' \
        '-listen-address=[HTTP bind address]:addr:' \
        '-log-format=[log format]:fmt:(console json)' \
        '-web-config-file=[exporter-toolkit web config]:file:_files -g "*.(yml|yaml)"' \
        '-treat-mqtt-password-as-file-name[read MQTT password from file]'
}

_mqtt2prometheus "$@"
