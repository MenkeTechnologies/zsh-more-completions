#compdef milter-manager
# Documentation: https://www.gsp.com/cgi-bin/man.cgi?section=1&topic=MILTER-MANAGER
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# milter-manager: unified milter management daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--connection-spec=[milter socket spec]:spec:' \
  '--config-dir=[configuration directory]:dir:_files -/' \
  '--pid-file=[PID file]:file:_files' \
  '--user-name=[run as user]:user:_users' \
  '--group-name=[run as group]:group:_groups' \
  '--socket-group-name=[socket group name]:group:_groups' \
  '--daemon[run in daemon mode]' \
  '--no-daemon[do not run in daemon mode]' \
  '--show-config[print current configuration]' \
  '--log-level=[log severity levels (pipe-separated)]:level:' \
  '--log-path=[log file path or - for stdout]:path:_files' \
  '--event-loop-backend=[event loop backend]:backend:(glib libev)' \
  '--verbose[verbose output]' && ret=0
return ret
