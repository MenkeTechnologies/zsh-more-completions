#compdef pdfetex pdftex-dev
# Documentation: pdfetex (pdftex) --help
# Source: TeX pdfetex — pdfTeX with e-TeX extensions.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-cnf-line=[parse STRING as configuration line]:string:' \
    '-draftmode[switch on draft mode (no PDF)]' \
    '-enc[enable encTeX extensions]' \
    '-etex[enable e-TeX extensions]' \
    '(-file-line-error -no-file-line-error)-file-line-error[file\:line\:error style]' \
    '(-file-line-error -no-file-line-error)-no-file-line-error[disable file\:line\:error style]' \
    '-fmt=[format file]:name:' \
    '-halt-on-error[stop at first error]' \
    '-ini[be pdfinitex (dumping formats)]' \
    '-interaction=[interaction mode]:mode:(batchmode nonstopmode scrollmode errorstopmode)' \
    '(-ipc -ipc-start)-ipc[also send DVI to a socket]' \
    '(-ipc -ipc-start)-ipc-start[as -ipc and start the server]' \
    '-jobname=[job name]:string:' \
    '-kpathsea-debug=[kpathsea debug bitmask]:n:' \
    '(--mktex --no-mktex)-mktex=[enable mktexFMT]:fmt:(tex tfm)' \
    '(--mktex --no-mktex)-no-mktex=[disable mktexFMT]:fmt:(tex tfm)' \
    '-mltex[enable MLTeX extensions]' \
    '-output-comment=[DVI file comment string]:string:' \
    '-output-directory=[output directory]:dir:_files -/' \
    '-output-format=[output format]:format:(dvi pdf)' \
    '(-parse-first-line -no-parse-first-line)-parse-first-line[parse first line of input]' \
    '(-parse-first-line -no-parse-first-line)-no-parse-first-line[do not parse first line]' \
    '-progname=[program (and fmt) name]:string:' \
    '-recorder[enable filename recorder]' \
    '(-shell-escape -no-shell-escape -shell-restricted)-shell-escape[enable \\write18]' \
    '(-shell-escape -no-shell-escape -shell-restricted)-no-shell-escape[disable \\write18]' \
    '(-shell-escape -no-shell-escape -shell-restricted)-shell-restricted[restrict \\write18]' \
    '-synctex=[enable SyncTeX (bitmask)]:n:' \
    '(- *)-help[show help]' \
    '(- *)-version[show version]' \
    '*:TeX source:_files -g "*.tex"' \
    && ret=0

return ret
