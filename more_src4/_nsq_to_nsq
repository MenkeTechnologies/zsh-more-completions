#compdef nsq_to_nsq
# Documentation: https://nsq.io/components/utilities.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-version[print version]' \
  '-topic=[source NSQ topic]:topic:' \
  '-destination-topic=[destination topic]:topic:' \
  '-channel=[NSQ channel]:channel:' \
  '*-nsqd-tcp-address=[nsqd TCP address (repeatable)]:address:' \
  '*-lookupd-http-address=[lookupd HTTP address (repeatable)]:address:' \
  '*-destination-nsqd-tcp-address=[destination nsqd TCP address (repeatable)]:address:' \
  '-mode=[connection mode]:mode:(round-robin multicast hostpool epsilon-greedy)' \
  '-status-every=[duration between status updates]:duration:' \
  '-max-in-flight=[max in-flight messages]:n:' \
  '-require-json-field=[require message JSON to have the named field]:field:' \
  '-require-json-value=[required value for the JSON field]:value:' \
  '*-whitelist-json-field=[message JSON field to relay (repeatable)]:field:' \
  '*-consumer-opt=[consumer config option key=value (repeatable)]:opt:' \
  '*-producer-opt=[producer config option key=value (repeatable)]:opt:' && ret=0

return ret
