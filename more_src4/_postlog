#compdef postlog
# _postlog — Postfix-compatible logging interface for shell scripts (sends text to syslogd or postlogd with chosen tag + priority; reads stdin if no text given)
# upstream: https://github.com/vdukhovni/postfix
# Flags from postfix/man/man1/postlog.1 on tip.

_postlog() {
    _arguments \
        '-c+[config directory]:dir:_files -/' \
        '-i[include PID in tag (obsolete; always-on since 3.4)]' \
        '-p+[log priority]:priority:(info warn error fatal panic)' \
        '-t+[log tag (default: postlog)]:tag:' \
        '*-v[verbose logging (repeat for more)]' \
        '*::text:'
}

_postlog "$@"
