#compdef pgroll
# Documentation: https://github.com/xataio/pgroll/blob/main/cli-definition.json
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_pgroll() {
    local line state
    local -a commands
    commands=(
        'analyze:Analyze database schema'
        'baseline:Baseline the database against an existing schema'
        'init:Initialize pgroll internal state'
        'status:Show migration status'
        'create:Create a new migration file interactively'
        'convert:Convert migrations between formats'
        'migrate:Apply outstanding migrations from a directory'
        'start:Start a new migration'
        'complete:Complete a migration'
        'rollback:Rollback a migration'
        'update:Update pgroll metadata'
        'pull:Pull migrations'
        'validate:Validate a migration file'
        'latest:Show latest migration info (migration|schema|url)'
    )

    _arguments -C \
        '--postgres-url=[PostgreSQL connection string]:url:' \
        '--schema=[target schema]:schema:' \
        '--pgroll-schema=[internal state schema]:schema:' \
        '--lock-timeout=[DDL lock timeout ms]:timeout:' \
        '--use-version-schema[enable version-specific schemas]' \
        '--verbose[verbose logging]' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'pgroll command' commands
            ;;
        args)
            case $line[1] in
                latest)
                    _arguments '1:subcommand:(migration schema url)'
                    ;;
            esac
            ;;
    esac
}

_pgroll "$@"
