#compdef process-compose
# Documentation: https://github.com/F1bonacc1/process-compose
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for process-compose - process orchestrator

_process-compose_commands() {
  local -a commands=(
    'analyze:analyze project dependency graph'
    'attach:attach to a running project'
    'docs:generate documentation'
    'down:stop all running processes'
    'get:get process information'
    'graph:generate dependency graph'
    'info:show process info'
    'is-ready:check if process is ready'
    'list:list processes'
    'logs:show process logs'
    'namespace:manage namespaces'
    'ports:get the ports a process is listening on'
    'process:manage processes'
    'project:manage projects'
    'recipe:list or run a recipe'
    'restart:restart a running process'
    'run:run single process'
    'scale:scale a process replicas'
    'start:start a stopped process'
    'state:get project state'
    'stop:stop a running process'
    'truncate:truncate process logs'
    'up:run process compose project'
    'update:update processes from a project file'
    'version:show version information'
    'help:show help for a command'
  )
  _describe -t commands 'process-compose command' commands
}

_process-compose_up() {
  _arguments \
    '*'{-f+,--config=}'[specify config file]:file:_files' \
    '(-p --port)'{-p+,--port=}'[port to listen on]:port' \
    '(-t --tui)'{-t,--tui}'[enable TUI]' \
    '--no-tui[disable TUI]' \
    '(-L --log-file)'{-L+,--log-file=}'[specify log file]:file:_files' \
    '--ordered-shutdown[shut down processes in reverse order]' \
    '--no-server[disable HTTP server]' \
    '--hide-disabled[hide disabled processes in TUI]' \
    '*--env=[specify env file]:file:_files' \
    '--ref-rate=[TUI refresh rate]:duration' \
    '--detached[run in detached mode]' \
    '--detached-with-tui[run detached with TUI]' \
    '--read-only[run in read-only mode]' \
    '*'{-n+,--namespace=}'[namespace to run]:namespace' \
    '(-U --unix-socket)'{-U+,--unix-socket=}'[unix socket path]:path:_files' \
    '--disable-dotenv[disable .env file loading]' \
    '--log-level=[set log level]:level:(trace debug info warn error fatal panic)' \
    '--log-length=[set max log length]:length' \
    '--is-strict[enable strict mode]' \
    '--sort=[sort by column]:column:(name namespace status age cpu mem)' \
    '--reverse[reverse sort order]' \
    '--theme=[TUI theme]:theme' \
    '--no-deps[do not start dependent processes]' \
    '*:process'
}

_process-compose_logs() {
  _arguments \
    '(-f --follow)'{-f,--follow}'[follow log output]' \
    '(-t --tail)'{-t+,--tail=}'[number of lines to show]:lines' \
    '1:process name'
}

_process-compose() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '1:command:_process-compose_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        up)
          _process-compose_up
          ;;
        logs)
          _process-compose_logs
          ;;
        restart|start|stop|attach|info|ports|truncate|is-ready)
          _arguments '*:process name'
          ;;
        *)
          _arguments '--help[show help]'
          ;;
      esac
      ;;
  esac
}

_process-compose "$@"
