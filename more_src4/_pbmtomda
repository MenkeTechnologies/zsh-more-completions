#compdef pbmtomda
# Documentation: man pbmtomda (Netpbm)
# Source: convert PBM to Microdesign MDA bitmap format (Amstrad PCW).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-dscale[scale image down to fit MDA page]' \
    '-invert[invert black/white]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pbm file:_files -g "*.(pbm|pnm|pam)"' \
    && ret=0

return ret
