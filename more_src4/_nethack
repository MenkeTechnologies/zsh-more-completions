#compdef nethack
# Documentation: https://www.unix.com/man-page/debian/6/nethack/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for nethack (roguelike dungeon exploration game)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-u+[player name]:name:' \
  '-p+[character role/profession]:role:(Archeologist Barbarian Caveman Healer Knight Monk Priest Ranger Rogue Samurai Tourist Valkyrie Wizard)' \
  '-r+[character race]:race:(human elf dwarf gnome orc)' \
  '-s[print scores]' \
  '-v[show versions present in score file]' \
  '-d+[playground directory]:directory:_files -/' \
  '-n[suppress news]' \
  '-D[start in debug (wizard) mode]' \
  '-X[start in explore (discovery) mode]' \
  '-dec[equivalent to decgraphics run-time option]' \
  '-ibm[equivalent to ibmgraphics run-time option]' \
  '-windowtype+[use specified window type]:type:(tty curses x11 qt Gnome)' && ret=0

return ret
