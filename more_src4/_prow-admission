#compdef prow-admission
# _prow-admission — Prow admission webhook for ProwJob validation (kubernetes-sigs/prow)
# upstream: https://github.com/kubernetes-sigs/prow
# Flags from cmd/admission/main.go (flag).

_prow-admission() {
    _arguments \
        '-tls-cert-file=[x509 certificate file]:file:_files' \
        '-tls-private-key-file=[matching x509 private key]:file:_files' \
        '-config-path=[config file]:file:_files' \
        '-job-config-path=[job config file]:file:_files' \
        '-kubeconfig=[kubeconfig file]:file:_files'
}

_prow-admission "$@"
