#compdef opensm
# Documentation: https://manpages.debian.org/testing/opensm/opensm.8.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# opensm: InfiniBand subnet manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,'-?',--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-F --config)'{-F+,--config=}'[config file]:file:_files' \
  '(-c --create-config)'{-c+,--create-config=}'[generate config template]:file:_files' \
  '(-g --guid)'{-g+,--guid=}'[bind to port GUID]:guid:' \
  '(-p --priority)'{-p+,--priority=}'[SM priority 0-15]:n:' \
  '(-l --lmc)'{-l+,--lmc=}'[set LMC 0-7]:n:' \
  '--subnet_prefix=[subnet prefix]:prefix:' \
  '--smkey=[management key]:hex:' \
  '--sm_sl=[service level for SM/SA]:sl:' \
  '(-R --routing_engine)'{-R+,--routing_engine=}'[routing algorithm]:engine:' \
  '(-r --reassign_lids)'{-r,--reassign_lids}'[reassign all LIDs]' \
  '(-a --root_guid_file)'{-a+,--root_guid_file=}'[root nodes file]:file:_files' \
  '(-u --cn_guid_file)'{-u+,--cn_guid_file=}'[compute nodes file]:file:_files' \
  '(-G --io_guid_file)'{-G+,--io_guid_file=}'[I/O nodes file]:file:_files' \
  '(-M --lid_matrix_file)'{-M+,--lid_matrix_file=}'[min-hop tables file]:file:_files' \
  '(-U --lfts_file)'{-U+,--lfts_file=}'[forwarding tables file]:file:_files' \
  '(-s --sweep)'{-s+,--sweep=}'[sweep interval seconds]:s:' \
  '(-t --timeout)'{-t+,--timeout=}'[transaction timeout ms]:ms:' \
  '--retries=[retry count]:n:' \
  '--maxsmps=[outstanding SMP limit]:n:' \
  '(-o --once)'{-o,--once}'[configure once then exit]' \
  '(-f --log_file)'{-f+,--log_file=}'[log file]:file:_files' \
  '(-L --log_limit)'{-L+,--log_limit=}'[max log file size MB]:mb:' \
  '(-e --erase_log_file)'{-e,--erase_log_file}'[delete existing log]' \
  '-D+[verbosity flags]:flags:' \
  '(-d --debug)'{-d+,--debug=}'[debug options]:n:' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-P --Pconfig)'{-P+,--Pconfig=}'[partition config]:file:_files' \
  '(-Q --qos)'{-Q,--qos}'[enable QoS]' \
  '(-Y --qos_policy_file)'{-Y+,--qos_policy_file=}'[QoS policy file]:file:_files' \
  '(-Z --part_enforce)'{-Z+,--part_enforce=}'[partition enforcement]:mode:(both in out off)' \
  '(-W --allow_both_pkeys)'{-W,--allow_both_pkeys}'[allow dual P_Key membership]' \
  '(-B --daemon)'{-B,--daemon}'[run as daemon]' \
  '(-J --pidfile)'{-J+,--pidfile=}'[PID file]:file:_files' \
  '(-I --inactive)'{-I,--inactive}'[start in inactive state]' \
  '(-y --stay_on_fatal)'{-y,--stay_on_fatal}"[don't exit on fatal errors]" \
  '--console=[console mode]:mode:(off local socket loopback)' \
  '--perfmgr[enable performance manager]' \
  '--prefix_routes_file=[off-subnet path records]:file:_files' \
  '--congestion_control[enable congestion control]' \
  '(-i --ignore_guids)'{-i+,--ignore_guids=}'[exclude ports from load balancing]:file:_files' \
  '(-w --hop_weights_file)'{-w+,--hop_weights_file=}'[port weighting factors]:file:_files' \
  '(-O --port_search_ordering_file)'{-O+,--port_search_ordering_file=}'[port ordering]:file:_files' \
  '*::opensm args:_files' && ret=0
return ret
