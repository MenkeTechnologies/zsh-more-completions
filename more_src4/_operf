#compdef operf
# _operf — OProfile operf system-wide and per-process Linux performance profiler using perf_events with hardware/software/tracepoint event sampling (oprofile team, C++); getopt
# upstream: https://oprofile.sourceforge.io/

_operf() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-s[system-wide]' \
        '--system-wide[system-wide]' \
        '-p+[pid]:n:_pids' \
        '--pid=+[pid]:n:_pids' \
        '-l[lazy]' \
        '--lazy-conversion[lazy]' \
        '-g[callgraph]' \
        '--callgraph[callgraph]' \
        '-e+[event]:str:' \
        '--events=+[event]:str:' \
        '-d+[session dir]:dir:_files -/' \
        '--session-dir=+[session dir]:dir:_files -/' \
        '-V+[level]:l:(stats stats_extended debug)' \
        '-k+[kernel image]:file:_files' \
        '--vmlinux=+[kernel image]:file:_files' \
        '-a[append]' \
        '--append[append]' \
        '-t+[N threads]:n:' \
        '-T+[N threads]:n:' \
        '-c[CPU buffer size MiB]' \
        '--cpu-buf-size=+[MiB]:n:' \
        '-r+[priority]:n:' \
        '--realtime[realtime]' \
        '-u[disable userspace]' \
        '--no-vmlinux[no vmlinux]' \
        '*:command:_command_names -e'
}

_operf "$@"
