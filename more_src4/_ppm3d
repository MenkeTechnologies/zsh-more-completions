#compdef ppm3d
# Documentation: man ppm3d (Netpbm)
# Source: produce a red/cyan anaglyph stereogram from two PPM images.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-color[color anaglyph (preserve hue)]' \
    '-offset=[horizontal offset pixels]:horizontal_offset:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:left ppm:_files -g "*.(ppm|pnm|pam)"' \
    '2:right ppm:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
