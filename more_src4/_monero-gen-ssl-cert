#compdef monero-gen-ssl-cert
# Documentation: https://github.com/monero-project/monero/tree/master/src/gen_ssl_cert
# Reference accessed: 2026-05-19
# Verified: upstream gen_ssl_cert directory in the monero source tree.
# Source: https://github.com/BibXMR/monero-zsh-completions/blob/6540df4783f354863955175790dae12735e30b2d/_monero-gen-ssl-cert
# Repository: BibXMR/monero-zsh-completions (_monero-gen-ssl-cert)

_monero-gen-ssl-cert() {
  _arguments \
    '(- *)--help[Produce help message]' \
    '(- *)--version[Output version information]' \
    '--certificate-filename=[Filename to save the certificate]:certificate file:_files' \
    '--passphrase=[Passphrase with which to encrypt the private key]:passphrase' \
    '--passphrase-file=[File containing the passphrase with which to encrypt the private key]:passphrase file:_files' \
    '--private-key-filename=[Filename to save the private key]:key file:_files' \
    '--prompt-for-passphrase[Prompt for a passphrase with which to encrypt the private key]'
}

_monero-gen-ssl-cert "$@"
