#compdef ooniprobe ooni
# _ooniprobe — Open Observatory of Network Interference ooniprobe CLI for running network-measurement tests detecting internet censorship blocking circumvention status web connectivity DNS HTTP TCP performance NDT Dash STUN reachability (ooni team, Go); cobra
# upstream: https://github.com/ooni/probe-cli

_ooniprobe() {
    local -a sub=(
        'run:run measurements'
        'list:list measurements'
        'show:show measurement'
        'reset:reset OONI Probe'
        'upload:upload pending measurements'
        'rm:remove measurements'
        'onboard:run onboarding'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--home=+[dir]:dir:_files -/' \
        '--config=+[file]:file:_files -g "*.json"' \
        '--no-collector[do not submit results]' \
        '--no-color[no color]' \
        '--batch[batch mode]' \
        '--probe-services-url=+[url]:str:' \
        '--tunnel=+[t]:t:(none tor torsf snowflake psiphon)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ooniprobe subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments \
                    '1:test group:(im websites performance middlebox circumvention experimental web_connectivity all unattended)' \
                    '--max-runtime=+[sec]:n:' \
                    '--input=+[csv]:str:' \
                    '--input-file=+[file]:file:_files' \
                    '--annotation=+[KEY=VALUE]:str:' \
                    '--random[random order]' ;;
                list) _arguments \
                    '--limit=+[N]:n:' \
                    '--filter=+[group]:str:' ;;
                show|rm) _arguments '*:measurement id:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_ooniprobe "$@"
