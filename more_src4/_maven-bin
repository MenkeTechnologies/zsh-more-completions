#compdef mvn
# _maven-bin — Apache Maven Java build tool (Apache, Java); convention-over-configuration build for JVM
# upstream: https://github.com/apache/maven

_maven-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '-am[also make]' \
        '--also-make[also make]' \
        '-amd[also make dependents]' \
        '--also-make-dependents[also make dependents]' \
        '-B[batch mode]' \
        '--batch-mode[batch mode]' \
        '-b+[builder id]:id:' \
        '--builder+[builder id]:id:' \
        '-c[strict checksum]' \
        '--strict-checksums[strict checksum]' \
        '-C[strict checksum (fail)]' \
        '-D+[system property]:KEY=VAL:' \
        '--define+[system property]:KEY=VAL:' \
        '-e[show errors]' \
        '--errors[show errors]' \
        '-emp[encrypt master password]' \
        '--encrypt-master-password[encrypt master password]' \
        '-ep[encrypt password]' \
        '--encrypt-password[encrypt password]' \
        '-f+[pom file]:file:_files -g "pom.xml"' \
        '--file+[pom file]:file:_files -g "pom.xml"' \
        '-fae[fail at end]' \
        '--fail-at-end[fail at end]' \
        '-ff[fail fast]' \
        '--fail-fast[fail fast]' \
        '-fn[never fail]' \
        '--fail-never[never fail]' \
        '-gs+[global settings file]:file:_files' \
        '--global-settings+[global settings file]:file:_files' \
        '-gt+[global toolchains file]:file:_files' \
        '--global-toolchains+[global toolchains file]:file:_files' \
        '-l+[log file]:file:_files' \
        '--log-file+[log file]:file:_files' \
        '-llr[legacy local repo]' \
        '--legacy-local-repository[legacy local repo]' \
        '-N[non-recursive]' \
        '--non-recursive[non-recursive]' \
        '-npr[no plugin registry]' \
        '--no-plugin-registry[no plugin registry]' \
        '-npu[no plugin updates]' \
        '--no-plugin-updates[no plugin updates]' \
        '-nsu[no snapshot updates]' \
        '--no-snapshot-updates[no snapshot updates]' \
        '-ntp[no transfer progress]' \
        '--no-transfer-progress[no transfer progress]' \
        '-o[offline]' \
        '--offline[offline]' \
        '-P+[profiles]:profile:' \
        '--activate-profiles+[profiles]:profile:' \
        '-pl+[projects]:str:' \
        '--projects+[projects]:str:' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-rf+[resume from project]:str:' \
        '--resume-from+[resume from project]:str:' \
        '-s+[user settings]:file:_files' \
        '--settings+[user settings]:file:_files' \
        '-t+[user toolchains]:file:_files' \
        '--toolchains+[user toolchains]:file:_files' \
        '-T+[threads]:n:' \
        '--threads+[threads]:n:' \
        '-U[update snapshots]' \
        '--update-snapshots[update snapshots]' \
        '-up[update plugins]' \
        '--update-plugins[update plugins]' \
        '-V[show version + build]' \
        '--show-version[show version + build]' \
        '-X[debug]' \
        '--debug[debug]' \
        '*:phase or goal:'
}

_maven-bin "$@"
