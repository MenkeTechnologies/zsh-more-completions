#compdef pem
# _pem — fastlane pem APNs push certificate generator (fastlane, Ruby); commander
# upstream: https://github.com/fastlane/fastlane

_pem() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--development[development cert]' \
        '-d[development cert]' \
        '--generate-p12=+[generate p12]:b:(true false)' \
        '-g+[generate p12]:b:(true false)' \
        '--active-days-limit=+[active days limit]:n:' \
        '-l+[active days limit]:n:' \
        '--force=+[force]:b:(true false)' \
        '-f+[force]:b:(true false)' \
        '--save-private-key=+[save private key]:b:(true false)' \
        '-s+[save private key]:b:(true false)' \
        '--app-identifier=+[app identifier]:str:' \
        '-a+[app identifier]:str:' \
        '--username=+[apple ID username]:str:_users' \
        '-u+[apple ID username]:str:_users' \
        '--team-id=+[team id]:str:' \
        '-q+[team id]:str:' \
        '--team-name=+[team name]:str:' \
        '-r+[team name]:str:' \
        '--p12-password=+[p12 password]:str:' \
        '-p+[p12 password]:str:' \
        '--pem-name=+[pem filename]:str:' \
        '-o+[pem filename]:str:' \
        '--output-path=+[output path]:dir:_files -/' \
        '-w+[output path]:dir:_files -/' \
        '--new-profile=+[new profile]:b:(true false)' \
        '-n+[new profile]:b:(true false)' \
        '--platform=+[platform]:p:(ios macos)' \
        '*:arg:'
}

_pem "$@"
