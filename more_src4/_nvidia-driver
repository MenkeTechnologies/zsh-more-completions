#compdef nvidia-driver
# Documentation: https://wiki.debian.org/NvidiaGraphicsDrivers
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. No canonical `nvidia-driver`
# CLI; the name is the distro package and the binary, if present, is a
# vendor-specific wrapper. STUB.

# nvidia-driver: distro wrapper (varies by vendor) - STUB
local curcontext="$curcontext" ret=1
_arguments -C \
  '*::nvidia-driver args:_files' && ret=0
return ret
