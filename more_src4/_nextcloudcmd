#compdef nextcloudcmd
# Documentation: https://docs.nextcloud.com/server/32/admin_manual/desktop/commandline.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for nextcloudcmd - Nextcloud command-line sync client

_arguments -s -S \
  '--path=[override remote root folder to a server subfolder]:path:' \
  '(-u --user)'{-u,--user}'+[login name]:user:' \
  '(-p --password)'{-p,--password}'+[password]:password:' \
  '-n[use netrc(5) for login]' \
  '--non-interactive[read credentials from NC_USER/NC_PASSWORD]' \
  '(-s --silent)'{-s,--silent}'[inhibit verbose log output]' \
  '--trust[trust any SSL certificate, including invalid ones]' \
  '--httpproxy=[HTTP proxy URL]:url:' \
  '--exclude=[exclude list file]:file:_files' \
  '--unsyncedfolders=[file listing unsynced folders]:file:_files' \
  '--max-sync-retries=[max sync retries (default 3)]:n:' \
  '-h[sync hidden files, do not ignore them]' \
  '1:source directory:_files -/' \
  '2:nextcloud url:'
