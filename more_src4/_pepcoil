#compdef pepcoil
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/pepcoil.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# EMBOSS pepcoil: predict coiled-coil regions in protein (Lupas method)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[protein sequence(s)]:protein USA:_files' \
  '-window=[scanning window size 7-28 residues]:size:' \
  '-coil[report coiled-coil regions]' \
  '-frame[show coil frameshifts]' \
  '-other[report non coiled-coil regions]' \
  '-outfile=[report output file]:file:_files' \
  '*:protein USA:_files' && ret=0
return ret
