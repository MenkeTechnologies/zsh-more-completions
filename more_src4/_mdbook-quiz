#compdef mdbook-quiz
# _mdbook-quiz — embed interactive quizzes into mdbook (cognitive-engineering-lab/mdbook-quiz)
# upstream: https://github.com/cognitive-engineering-lab/mdbook-quiz
# Subcommands from mdbook_preprocessor_utils::main framework.

_mdbook-quiz() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'supports:check whether a renderer is supported'
                'install:install required assets into book directory'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                supports) _arguments '1:renderer:(html epub markdown)' ;;
                install) _arguments '1:book dir:_files -/' ;;
            esac
            ;;
    esac
}

_mdbook-quiz "$@"
