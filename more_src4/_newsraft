#compdef newsraft
# Documentation: https://newsraft.codeberg.page/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-f+[feeds file]:file:_files' \
  '-c+[config file]:file:_files' \
  '-d+[database file]:file:_files' \
  '-l+[log file]:file:_files' \
  '-e+[execute one-time action]:action:(convert-opml-to-feeds convert-feeds-to-opml reload-all print-unread-items-count purge-abandoned)' \
  && ret=0

return ret
