#compdef ovn-ic-nbctl
# _ovn-ic-nbctl — OVN ovn-ic-nbctl control utility for managing the OVN Interconnect Northbound database (ovn-org team, C); custom argparse
# upstream: https://github.com/ovn-org/ovn

_ovn-ic-nbctl() {
    local -a sub=(
        'init:init IC NB database'
        'show:show ic nb information'
        'transit-switch-add:add transit switch'
        'transit-switch-del:delete transit switch'
        'transit-switch-list:list transit switches'
        'set:set IC NB database column'
        'get:get column value'
        'find:find rows by condition'
        'list:list table rows'
        'create:create row'
        'destroy:destroy row'
        'add:append set element'
        'remove:remove set element'
        'clear:clear set'
        'wait-until:wait until condition'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v+[verbose modules]:str:' \
        '--verbose=+[verbose modules]:str:' \
        '--db=+[IC NB DB]:str:' \
        '--commands[list commands]' \
        '--options[list options]' \
        '-t+[timeout secs]:n:' \
        '--timeout=+[timeout secs]:n:' \
        '-d+[date format]:f:(iso raw local)' \
        '--data=+[data format]:f:(string bare json)' \
        '--pretty[pretty json]' \
        '--leader-only[connect only to leader]' \
        '--no-leader-only[no leader only]' \
        '--shuffle-remotes[shuffle remotes]' \
        '--no-shuffle-remotes[no shuffle]' \
        '--bootstrap-ca-cert=+[ca cert]:file:_files' \
        '--ca-cert=+[ca cert]:file:_files' \
        '--certificate=+[cert]:file:_files' \
        '--private-key=+[key]:file:_files' \
        '--ssl-protocols=+[protocols]:str:' \
        '--ssl-ciphers=+[ciphers]:str:' \
        '--oneline[one line]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ovn-ic-nbctl subcommand' sub ;;
    esac
}

_ovn-ic-nbctl "$@"
