#compdef pkgetmask
# pkgetmask — create raster mask from thresholds (pktools)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-i,--input}'=[input raster file]:input file:_files' \
  {-o,--output}'=[output raster file]:output file:_files' \
  '*-min+[minimum threshold value]:value:' \
  '*-max+[maximum threshold value]:value:' \
  '-data+[valid data value in output]:value:' \
  '-nodata+[nodata value in output]:value:' \
  '*-b+[band to use]:band number:' \
  '-of+[output format]:format:(GTiff HFA)' \
  '*-co+[creation option]:option:' \
  '-ot+[output data type]:type:(Byte Int16 UInt16 Int32 UInt32 Float32 Float64)' \
  '-p+[operator for multiple bands]:operator:(AND OR)' && ret=0

return ret
