#compdef mmstat
# Documentation: https://www.sleuthkit.org/sleuthkit/man/mmstat.html
# Source: sleuthkit/sleuthkit man/mmstat.1 — display details about the volume system (media management).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-t[specify the media management type]:mmtype:(dos mac bsd sun gpt)' \
    '-o[offset into image where volume containing partition system starts]:offset:' \
    '-b[underlying device sector size in bytes]:sector size:(512 1024 2048 4096)' \
    '-i[identify type of image file]:imgtype:(raw aff afd afm afflib ewf split)' \
    '-v[verbose output of debugging statements to stderr]' \
    '-V[display version]' \
    '*:image file:_files' \
    && ret=0

return ret
