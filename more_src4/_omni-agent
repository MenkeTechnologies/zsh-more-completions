#compdef omni-agent
# Documentation: https://github.com/siderolabs/omni
# Reference accessed: 2026-05-20
# Verified: no canonical standalone omni-agent CLI surface found.
# STUB: name claimed by multiple unrelated agents (SideroLabs Omni, 3DiVi OMNI,
# Microsoft SCOM, etc.); fall back to generic help/version only.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*::args:_files' && ret=0
return ret
