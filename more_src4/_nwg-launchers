#compdef nwggrid nwgbar nwgdmenu
# Documentation: https://github.com/nwg-piotr/nwg-launchers
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

case $service in
  (nwggrid)
    _arguments -C \
      '(- *)-h[show help]' \
      '-f[display favourites]' \
      '-p[display pinned entries]' \
      '-d[look for .desktop files in custom paths]' \
      '-o+[background opacity 0.0-1.0]:opacity:' \
      '-b+[background color RRGGBB or RRGGBBAA]:rgba:' \
      '-n+[number of grid columns]:n:' \
      '-s+[button image size]:px:' \
      '-c+[css file name]:file:_files' \
      '-l+[force language]:locale:' \
      '-g+[GTK theme name]:theme:' \
      '-wm+[window manager name]:wm:(sway hyprland river openbox i3 awesome)' \
      '-no-categories[disable categories display]' \
      '-oneshot[run in foreground, exit on close]' \
      '-layer-shell-layer=[layer]:layer:(BACKGROUND BOTTOM TOP OVERLAY)' \
      '-layer-shell-exclusive-zone=[exclusive zone]:zone:' && ret=0 ;;
  (nwgbar)
    _arguments -C \
      '(- *)-h[show help]' \
      '-v[arrange buttons vertically]' \
      '-ha+[horizontal alignment]:align:(l r)' \
      '-va+[vertical alignment]:align:(t b)' \
      '-t+[template file name]:tpl:' \
      '-c+[css file name]:file:_files' \
      '-o+[background opacity 0.0-1.0]:opacity:' \
      '-b+[background color RRGGBB or RRGGBBAA]:rgba:' \
      '-s+[button image size]:px:' \
      '-g+[GTK theme name]:theme:' \
      '-wm+[window manager name]:wm:(sway hyprland river openbox i3 awesome)' \
      '-layer-shell-layer=[layer]:layer:(BACKGROUND BOTTOM TOP OVERLAY)' \
      '-layer-shell-exclusive-zone=[exclusive zone]:zone:' && ret=0 ;;
  (nwgdmenu)
    _arguments -C \
      '(- *)-h[show help]' \
      '-n[no search box]' \
      '-ha+[horizontal alignment]:align:(l r)' \
      '-va+[vertical alignment]:align:(t b)' \
      '-r+[number of rows]:n:' \
      '-c+[css file name]:file:_files' \
      '-o+[background opacity 0.0-1.0]:opacity:' \
      '-b+[background color RRGGBB or RRGGBBAA]:rgba:' \
      '-g+[GTK theme name]:theme:' \
      '-wm+[window manager name]:wm:(sway hyprland river openbox i3 awesome)' \
      '-run[ignore stdin, build from commands in $PATH]' \
      '-layer-shell-layer=[layer]:layer:(BACKGROUND BOTTOM TOP OVERLAY)' \
      '-layer-shell-exclusive-zone=[exclusive zone]:zone:' && ret=0 ;;
esac

return ret
