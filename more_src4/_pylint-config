#compdef pylint-config
# Documentation: https://github.com/pylint-dev/pylint/tree/main/pylint/config/_pylint_config
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'generate:generate a pylint configuration'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'pylint-config subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (generate)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--interactive[interactive configuration generation]' && ret=0
        ;;
    esac
    ;;
esac

return ret
