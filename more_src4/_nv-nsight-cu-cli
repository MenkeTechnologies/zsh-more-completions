#compdef nv-nsight-cu-cli ncu
# Documentation: https://docs.nvidia.com/nsight-compute/NsightComputeCli/index.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Nsight Compute CLI (kernel profiler)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '-o[output report]:file:_files' \
  '--export=[output report]:file:_files' \
  '-i[import report]:file:_files' \
  '--import=[import report]:file:_files' \
  '-c[kernel count]:n:' \
  '--launch-count=[kernel count]:n:' \
  '-s[skip launches]:n:' \
  '--launch-skip=[skip launches]:n:' \
  '-k[kernel name filter regex]:regex:' \
  '--kernel-name=[kernel name filter regex]:regex:' \
  '--kernel-id=[kernel filter id (ctx:stream:[op:]name:invocation)]:id:' \
  '-f[force overwrite of existing output files]' \
  '--force-overwrite[force overwrite of existing output files]' \
  '--set=[metric set]:set:(default basic full source roofline)' \
  '--section=[metric section]:section:' \
  '--metrics=[metrics to collect]:list:' \
  '--target-processes=[target processes]:procs:(application-only all)' \
  '--replay-mode=[replay mode]:mode:(kernel application range app-range)' \
  '--profile-from-start=[start profiling]:val:(on off)' \
  '--app-replay-mode=[app replay mode (kernel matching mode)]:mode:(strict balanced relaxed)' \
  '--csv[output CSV]' \
  '--page=[report page]:page:' \
  '--print-summary=[print summary]:val:(none per-gpu per-kernel per-nvtx)' \
  '*:program:_files' && ret=0
return ret
