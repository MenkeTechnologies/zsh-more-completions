#compdef plumed
# plumed — enhanced sampling and free energy calculation plugin

local -a subcommands=(
  'driver:analyze trajectories offline'
  'sum_hills:integrate metadynamics hills file'
  'info:print information about PLUMED'
  'manual:generate the manual'
  'gen_template:generate a template input file'
  'check:check the input file'
  'simplemd:run a simple MD simulation'
  'benchmark:run a benchmark'
  'config:print PLUMED configuration info'
  'completion:generate shell completions'
  'kt:convert between temperature and kT'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--no-mpi[disable MPI]' \
  '--mpi[enable MPI]' \
  '1:command:->command' \
  '*::args:->args'

case $state in
  (command)
    _describe -t commands 'plumed command' subcommands
    ;;
  (args)
    case ${words[1]} in
      driver)
        _arguments \
          '--plumed[plumed input file]:file:_files' \
          '--ixyz[trajectory in xyz format]:file:_files -g "*.xyz"' \
          '--igro[trajectory in gro format]:file:_files -g "*.gro"' \
          '--ixtc[trajectory in xtc format]:file:_files -g "*.xtc"' \
          '--itrr[trajectory in trr format]:file:_files -g "*.trr"' \
          '--timestep[integration timestep]:dt:' \
          '--trajectory-stride[stride for reading trajectory]:stride:' \
          '--multi[number of replicas]:nrep:'
        ;;
      sum_hills)
        _arguments \
          '--hills[hills file]:file:_files' \
          '--outfile[output file]:file:_files' \
          '--min[minimum boundary]:min:' \
          '--max[maximum boundary]:max:' \
          '--bin[number of bins]:nbins:' \
          '--stride[stride for summation]:stride:' \
          '--kt[temperature in kT units]:kT:' \
          '--idw[variables for reweighting]:vars:' \
          '--mintozero[shift minimum to zero]'
        ;;
    esac
    ;;
esac
