#compdef odgi
# _odgi — Erik Garrison odgi CLI Optimized Dynamic Genome Implementation pangenome graph manipulation toolkit converting GFA into compressed succinct representation supporting query path manipulation viz visualization sort topology bin matrix layout pav PangenomeAssistedVariation extract subgraph linear-projection pipelines (Erik Garrison team, C++); custom argparse
# upstream: https://github.com/pangenome/odgi

_odgi() {
    local -a sub=(
        'build:build odgi index from GFA'
        'sort:sort topology'
        'view:view graph subset'
        'stats:graph statistics'
        'paths:list paths'
        'extract:extract subgraph'
        'crush:crush bubbles'
        'unchop:unchop nodes'
        'chop:chop nodes'
        'flip:flip orientations'
        'flatten:flatten to FASTA'
        'viz:render to PNG'
        'layout:compute 2D layout'
        'draw:draw layout to PNG/SVG'
        'pav:compute presence/absence variation'
        'matrix:export matrix representation'
        'bin:compute binned coverage'
        'depth:compute depth on a path'
        'pathindex:build path index'
        'overlap:list path overlaps'
        'tension:tension between paths'
        'kmers:kmer enumeration'
        'normalize:normalize graph'
        'panpos:pan-positional translation'
        'position:project positions onto paths'
        'prune:prune graph'
        'squeeze:squeeze multiple graphs'
        'tips:list tips'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-t+[threads]:n:' \
        '--threads=+[N]:n:' \
        '-P[progress]' \
        '--progress[progress]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'odgi subcommand' sub ;;
        args)
            case $words[1] in
                build) _arguments \
                    '-g+[input gfa]:file:_files -g "*.gfa"' \
                    '-o+[output og]:file:_files -g "*.og"' \
                    '-O[do not optimize ids]' \
                    '-s[sort topology]' ;;
                view|stats|paths|extract|sort|viz|layout|draw|depth) _arguments \
                    '-i+[input og]:file:_files -g "*.og"' \
                    '-o+[output]:file:_files' ;;
            esac
            ;;
    esac
}

_odgi "$@"
