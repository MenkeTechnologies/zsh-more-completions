#compdef pamchannel
# Documentation: man pamchannel (Netpbm)
# Source: extract one or more channels (planes) from a PAM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-infile=[input file]:file:_files' \
    '-tupletype=[output tuple type]:type:(BLACKANDWHITE GRAYSCALE GRAYSCALE_ALPHA RGB RGB_ALPHA CMYK)' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:channel number:' \
    && ret=0

return ret
