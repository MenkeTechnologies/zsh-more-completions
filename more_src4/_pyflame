#compdef pyflame
# _pyflame — Ptracing profiler for Python (uber-archive/pyflame)
# upstream: https://github.com/uber-archive/pyflame
# Flags from src/prober.cc (getopt_long).

_pyflame() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-a --abi)'{-a+,--abi=}'[force Python ABI]:abi:(26 27 34 36)' \
        '(-d --dump)'{-d,--dump}'[dump current stack and exit]' \
        '(-r --rate)'{-r+,--rate=}'[sampling rate (seconds)]:rate:' \
        '(-s --seconds)'{-s+,--seconds=}'[total sampling time (seconds)]:seconds:' \
        '(-L --threads)'{-L,--threads}'[profile all threads]' \
        '(-n --no-line-numbers)'{-n,--no-line-numbers}'[omit source line numbers]' \
        '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
        '(-p --pid)'{-p+,--pid=}'[PID to trace]:pid:_pids' \
        '(-t --trace)'{-t,--trace}'[trace mode (run target then sample)]' \
        '(-T --flamechart)'{-T,--flamechart}'[output flamechart format]' \
        '(-x --exclude-idle)'{-x,--exclude-idle}'[exclude idle samples]' \
        '*:trace target:_command_names -e'
}

_pyflame "$@"
