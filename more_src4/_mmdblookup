#compdef mmdblookup
# _mmdblookup — MaxMind libmaxminddb lookup CLI (queries an .mmdb file for an IP and prints the matching record + optional benchmark)
# upstream: https://github.com/maxmind/libmaxminddb
# Flags from bin/mmdblookup.c options on tip; --file + --ip are typically required.

_mmdblookup() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-n,--version}'[show version and exit]' \
        '(-f --file)'{-f+,--file=}'[.mmdb file path]:file:_files' \
        '(-i --ip)'{-i+,--ip=}'[IP address to look up]:ip:' \
        '(-v --verbose)'{-v,--verbose}'[also dump database metadata]' \
        '(-b --benchmark)'{-b+,--benchmark=}'[run benchmark with N iterations]:n:' \
        '(-t --threads)'{-t+,--threads=}'[benchmark thread count (POSIX only)]:n:' \
        '(-I --ip-file)'{-I+,--ip-file=}'[file with one IP per line]:file:_files' \
        '*:lookup-path:'
}

_mmdblookup "$@"
