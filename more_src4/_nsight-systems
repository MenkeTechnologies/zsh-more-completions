#compdef nsight-systems nsys
# Documentation: https://docs.nvidia.com/nsight-systems/UserGuide/index.html
# Reference accessed: 2026-05-19
# Verified: upstream Nsight Systems User Guide at the URL above.

# Nsight Systems CLI (system-wide profiler).
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'analyze:post-process .nsys-rep/SQLite to generate expert systems reports'
  'export:generate an export file from an .nsys-rep'
  'launch:launch an application in an environment supporting profile options'
  'profile:fully-formed profiling description'
  'recipe:post-process results to generate statistics and plots'
  'sessions:provide information about all active sessions'
  'shutdown:disconnect CLI process and exit'
  'start:start a collection in interactive mode'
  'stats:post-process results to generate statistical information'
  'status:report collection status or environment suitability'
  'stop:stop a collection started in interactive mode'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show Nsight Systems CLI version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'nsight-systems command' commands && ret=0 ;;
esac
return ret
