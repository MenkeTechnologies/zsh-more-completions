#compdef mate-disk-image-mounter
# Documentation: https://github.com/mate-desktop/mate-utils/blob/master/mate-disk-image-mounter/src/main.c
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mate-disk-image-mounter: mount an .iso/.img with udisks2
# Only application-defined option is -w/--writable per main.c GOptionEntry; standard GTK options
# are accepted via the GApplication option group.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options including GTK]' \
  '(- *)--help-gtk[show GTK options]' \
  '(-w --writable)'{-w,--writable}'[allow writing to the image]' \
  '--display=[X display]:display:' \
  '*:image file:_files' && ret=0
return ret
