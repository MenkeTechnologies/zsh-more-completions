#compdef otelcol
# Documentation: https://opentelemetry.io/docs/collector/configuration/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for OpenTelemetry Collector
local curcontext="$curcontext" state line ret=1

local -a commands=(
  'components:list available components and their stability'
  'validate:validate the configuration without starting the collector'
  'featuregate:display feature gate information'
  'config-print:print effective merged config (experimental)'
  'help:show help'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*--config=[config source URI]:uri:_files -g "*.{yaml,yml}"' \
  '*--set=[set config item (key=value)]:setter:' \
  '*--feature-gates=[feature gate IDs]:gates:' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'otelcol command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (validate)
        _arguments -s -S \
          '*--config=[config source URI]:uri:_files -g "*.{yaml,yml}"' \
          '*--set=[set config item]:setter:' \
          '*--feature-gates=[feature gate IDs]:gates:' && ret=0
        ;;
      (config-print)
        _arguments -s -S \
          '*--config=[config source URI]:uri:_files -g "*.{yaml,yml}"' \
          '--mode=[output mode]:mode:(redacted unredacted)' \
          '--validate[validate before printing]' && ret=0
        ;;
      (featuregate)
        _arguments '1:feature-id:' && ret=0
        ;;
    esac ;;
esac

return ret
