#compdef pt-mext
# Documentation: https://docs.percona.com/percona-toolkit/pt-mext.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '-r[subtract each column from previous]' \
  '*:command:_command_names' && ret=0

return ret
