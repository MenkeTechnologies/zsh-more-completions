#compdef md2html
# Documentation: md2html --help (md4c)
# Source: Markdown→HTML compiler (CommonMark by default).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    {-o+,--output=}'[output file]:file:_files' \
    {-f,--full-html}'[generate full HTML document]' \
    {-x,--xhtml}'[generate XHTML]' \
    {-s,--stat}'[measure parse time]' \
    '(--github)--commonmark[CommonMark dialect (default)]' \
    '(--commonmark)--github[Github Flavored Markdown]' \
    '--fcollapse-whitespace[collapse non-trivial whitespace]' \
    '--flatex-math[enable LaTeX-style math spans]' \
    '--fpermissive-atx-headers[allow ATX headers without delimiting space]' \
    '--fpermissive-url-autolinks[allow URL autolinks without <>]' \
    '--fpermissive-www-autolinks[allow WWW autolinks without scheme]' \
    '--fpermissive-email-autolinks[allow email autolinks without <>/mailto:]' \
    '--fpermissive-autolinks[all permissive autolinks]' \
    '--fhard-soft-breaks[soft line breaks become hard breaks]' \
    '--fno-html[disable raw HTML]' \
    '--fno-html-blocks[disable raw HTML blocks]' \
    '--fno-html-spans[disable raw HTML spans]' \
    '--fno-indented-code[disable indented code blocks]' \
    '--ftables[enable tables]' \
    '--ftasklists[enable task lists]' \
    '--fstrikethrough[enable strikethrough]' \
    '--fwiki-links[enable wiki links]' \
    '--funderline[enable underline _underline_]' \
    ':markdown file:_files -g "*.(md|markdown)"' \
    && ret=0

return ret
