#compdef mysqlsh
# Documentation: https://dev.mysql.com/doc/mysql-shell/8.4/en/mysqlsh.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mysqlsh - MySQL Shell

_arguments -s -S \
  '--uri=[connection URI]:URI:' \
  '(-h --host)'{-h+,--host=}'[server hostname]:host:_hosts' \
  '(-P --port)'{-P+,--port=}'[server port]:port:' \
  '(-u --user)'{-u+,--user=}'[user name]:user:_users' \
  '(-p --password)'{-p,--password}'[prompt for password]' \
  '--password1=[MFA password 1]:p:' \
  '--password2=[MFA password 2]:p:' \
  '--password3=[MFA password 3]:p:' \
  '--no-password[no password]' \
  '--passwords-from-stdin[read passwords from stdin]' \
  '(-D --schema --database)'{-D+,--schema=,--database=}'[default schema]:database:' \
  '(-S --socket)'{-S+,--socket=}'[socket file path]:socket:_files' \
  '--mysql[connect via classic protocol]' \
  '--mc[same as --mysql]' \
  '--mysqlx[connect via X protocol]' \
  '--mx[same as --mysqlx]' \
  '--ssl-mode=[SSL mode]:mode:(DISABLED PREFERRED REQUIRED VERIFY_CA VERIFY_IDENTITY)' \
  '--ssl-ca=[path to SSL CA file]:CA file:_files' \
  '--ssl-capath=[CA directory]:dir:_files -/' \
  '--ssl-cert=[path to SSL certificate file]:cert file:_files' \
  '--ssl-key=[path to SSL key file]:key file:_files' \
  '--ssl-cipher=[allowed ciphers]:c:' \
  '--ssl-crl=[CRL file]:file:_files' \
  '--ssl-crlpath=[CRL dir]:dir:_files -/' \
  '--tls-version=[TLS protocol versions]:v:' \
  '--tls-ciphersuites=[TLSv1.3 ciphers]:c:' \
  '--ssh=[SSH server URI]:uri:' \
  '--ssh-config-file=[SSH config file]:file:_files' \
  '--ssh-identity-file=[SSH key file]:file:_files' \
  '--connect-timeout=[connection timeout ms]:timeout:' \
  '--auth-method=[authentication method]:method:(AUTO FALLBACK FROM_CAPABILITIES MYSQL41 PLAIN SHA256_MEMORY)' \
  '--plugin-authentication-kerberos-client-mode=[kerberos mode]:m:(SSPI GSSAPI)' \
  '--plugin-authentication-webauthn-client-preserve-privacy[webauthn privacy]' \
  '--register-factor=[WebAuthn factors]:f:' \
  '--oci-config-file=[OCI config file]:file:_files' \
  '--authentication-oci-client-config-profile=[OCI profile]:name:' \
  '(-i --interactive)'{-i,--interactive}'[start in interactive mode]' \
  '--js[start in JavaScript mode]' \
  '--javascript[start in JavaScript mode]' \
  '--py[start in Python mode]' \
  '--python[start in Python mode]' \
  '--pyc=[execute Python command and quit]:cmd:' \
  '--pym[execute Python module]' \
  '--sql[start in SQL mode]' \
  '--sqlc[SQL mode over classic protocol]' \
  '--sqlx[SQL mode over X protocol]' \
  '--json=[json wrapping]:fmt:(pretty raw off)' \
  '--table[tabular output]' \
  '--tabbed[tab-separated output]' \
  '(-E --vertical)'{-E,--vertical}'[vertical output]' \
  '--result-format=[result format]:format:(table tabbed vertical json ndjson json/array)' \
  '(-e --execute)'{-e+,--execute=}'[execute statement and quit]:statement:' \
  '(-f --file)'{-f+,--file=}'[process file and quit]:file:_files' \
  '--force[continue on errors]' \
  '--log-level=[log level]:level:(none internal error warning info debug debug2 debug3 1 2 3 4 5 6 7 8)' \
  '--log-file=[path to log file]:log file:_files' \
  '--log-sql=[SQL logging level]:level:(off error on all unfiltered)' \
  '--dba-log-sql=[DBA SQL logging level]:level:(0 1 2)' \
  '--syslog[log SQL to syslog]' \
  '--verbose=[verbose level]:n:(0 1 2 3 4)' \
  '--show-warnings[show warnings after each statement]' \
  '--column-type-info[show column type information]' \
  '(-C --compress)'{-C,--compress}'[compress client-server protocol]' \
  '--compression-algorithms=[algorithms csv]:algs:' \
  '--zstd-compression-level=[zstd level 1-22]:n:' \
  '--get-server-public-key[request RSA public key from server]' \
  '--server-public-key-path=[server public key file]:key file:_files' \
  '--quiet-start=[suppress startup messages]:level:(1 2)' \
  '--redirect-primary[redirect to primary member]' \
  '--redirect-secondary[redirect to secondary member]' \
  '--cluster[connect to InnoDB cluster]' \
  '--replicaset[connect to InnoDB ReplicaSet]' \
  '--credential-store-helper=[credential store helper]:helper:' \
  '--save-passwords=[password save mode]:mode:(always prompt never)' \
  '--pager=[external pager]:p:' \
  '--histignore=[history ignore strings]:s:' \
  '--name-cache[enable name cache]' \
  '(-A --no-name-cache)'{-A,--no-name-cache}'[disable name cache]' \
  '(-nw --no-wizard)'{-nw,--no-wizard}'[disable wizard mode]' \
  '--mysql-plugin-dir=[plugin directory]:dir:_files -/' \
  '--no-defaults[ignore option files]' \
  '(-V --version)'{-V,--version}'[show version information]' \
  '(- *)'{-\?,--help}'[show help]' \
  '*:URI:_urls'
