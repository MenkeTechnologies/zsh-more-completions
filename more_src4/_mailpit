#compdef mailpit
# Documentation: https://mailpit.axllent.org/docs/configuration/runtime-options/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mailpit email testing server

_arguments \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-d --database)'{-d,--database=}'[local database file]:file:_files' \
  '--disable-wal[disable SQLite WAL]' \
  '--disable-version-check[skip update check]' \
  '--disable-auto-vacuum[disable SQLite auto vacuum]' \
  '--compression=[message compression level 0-3]:level:(0 1 2 3)' \
  '--label=[instance label]:label:' \
  '--tenant-id=[table prefix for tenant isolation]:id:' \
  '--max=[max number of messages to store]:count:' \
  '--max-age=[maximum message age (h/d suffix)]:age:' \
  '--max-message-size=[maximum message size in MB]:mb:' \
  '--use-message-dates[use Date header instead of receive time]' \
  '--ignore-duplicate-ids[ignore duplicate Message-IDs]' \
  '--log-file=[log to file instead of stdout]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[quiet logging (errors only)]' \
  '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
  '(-l --listen)'{-l,--listen=}'[HTTP bind address]:addr:' \
  '--webroot=[set the webroot for UI and API]:path:' \
  '--ui-auth-file=[basic auth password file]:file:_files' \
  '--ui-tls-cert=[HTTPS certificate]:file:_files' \
  '--ui-tls-key=[HTTPS key]:file:_files' \
  '--api-cors=[CORS allowed origins]:origin:' \
  '--block-remote-css-and-fonts[block remote CSS and fonts in preview]' \
  '--allow-untrusted-tls[skip TLS verification]' \
  '--allow-internal-http-requests[allow internal IP link checks]' \
  '--enable-spamassassin=[SpamAssassin address]:addr:' \
  '--disable-http-compression[disable HTTP compression]' \
  '--hide-delete-all-button[hide delete-all UI button]' \
  '--send-api-auth-file=[Send API auth file]:file:_files' \
  '--send-api-auth-accept-any[accept any Send API credentials]' \
  '(-s --smtp)'{-s,--smtp=}'[SMTP bind address]:addr:' \
  '--smtp-auth-file=[SMTP auth password file]:file:_files' \
  '--smtp-auth-accept-any[accept any SMTP credentials]' \
  '--smtp-tls-cert=[STARTTLS certificate]:file:_files' \
  '--smtp-tls-key=[STARTTLS key]:file:_files' \
  '--smtp-require-starttls[require STARTTLS]' \
  '--smtp-require-tls[require implicit TLS]' \
  '--smtp-auth-allow-insecure[allow plain SMTP auth]' \
  '--smtp-strict-rfc-headers[enforce RFC line endings]' \
  '--smtp-max-recipients=[max recipients per message]:n:' \
  '--smtp-allowed-recipients=[regex of allowed recipients]:pattern:' \
  '--smtp-ignore-rejected-recipients[silently drop rejected recipients]' \
  '--smtp-disable-rdns[disable reverse DNS lookups]' \
  '--smtp-relay-config=[SMTP relay config file]:file:_files' \
  '--smtp-relay-all[relay every message]' \
  '--smtp-relay-matching=[relay matching recipients regex]:pattern:' \
  '--smtp-forward-config=[forward config file]:file:_files' \
  '--pop3=[POP3 bind address]:addr:' \
  '--pop3-auth-file=[POP3 auth password file]:file:_files' \
  '--pop3-tls-cert=[POP3 TLS certificate]:file:_files' \
  '--pop3-tls-key=[POP3 TLS key]:file:_files' \
  '--tag=[auto-tag matching messages]:filter:' \
  '--tags-config=[tags YAML config]:file:_files' \
  '--tags-title-case[enforce TitleCase tag names]' \
  '--tags-disable=[disable specific auto-tags]:tags:' \
  '--tags-username[tag messages with authenticated username]' \
  '--enable-chaos[enable Chaos integration testing]' \
  '--chaos-triggers=[runtime Chaos trigger config]:cfg:' \
  '--enable-prometheus[enable Prometheus endpoint]' \
  '--webhook-url=[POST new messages to webhook]:url:' \
  '--webhook-limit=[webhook rate limit per second]:n:' \
  '--webhook-delay=[webhook delay (seconds)]:n:' \
  && return 0
