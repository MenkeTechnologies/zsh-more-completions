#compdef pbmtopsg3
# Documentation: man pbmtopsg3 (Netpbm)
# Source: convert a PBM image to PostScript with G3 fax compression.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--title=[document title]:title:' \
    '--dpi=[output resolution]:dpi:' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:pbm file:_files -g "*.(pbm|pnm|pam)"' \
    && ret=0

return ret
