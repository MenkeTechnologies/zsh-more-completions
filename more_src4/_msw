#compdef msw
# Documentation: https://mswjs.io/docs/cli/init/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# msw: Mock Service Worker CLI. Only documented subcommand is `init`.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:copy worker script into a public directory'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'msw command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (init)
        _arguments \
          '--save[save public directory in package.json for future updates]' \
          '--no-save[do not save to package.json]' \
          '1:public directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
