#compdef otbcli_OrthoRectification
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_OrthoRectification.html
# Source: orfeotoolbox/OTB OrthoRectification — DEM-based orthorectification of satellite imagery.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-io.in+[input source image]:image:_files' \
    '-io.out+[ortho-rectified output]:image:_files' \
    '-map+[map projection type]:proj:(utm lambert2 lambert93 wgs epsg)' \
    '-map.utm.zone+[UTM zone (1-60)]:zone:_default' \
    '-map.utm.northhem+[(true/false) northern hemisphere]:bool:(true false)' \
    '-map.epsg.code+[EPSG code]:code:_default' \
    '-outputs.mode+[grid estimation mode]:mode:(auto autosize autospacing outputroi orthofit)' \
    '-outputs.ulx+[upper-left X]:value:_default' \
    '-outputs.uly+[upper-left Y]:value:_default' \
    '-outputs.sizex+[output width (px)]:n:_default' \
    '-outputs.sizey+[output height (px)]:n:_default' \
    '-outputs.spacingx+[pixel size X]:value:_default' \
    '-outputs.spacingy+[pixel size Y]:value:_default' \
    '-outputs.lrx+[lower-right X]:value:_default' \
    '-outputs.lry+[lower-right Y]:value:_default' \
    '-outputs.ortho+[reference ortho image for fitting]:image:_files' \
    '-outputs.isotropic+[(true/false) force uniform spacing]:bool:(true false)' \
    '-outputs.default+[default fill value]:value:_default' \
    '-elev.dem+[DEM directory or VRT]:path:_files' \
    '-elev.geoid+[geoid file]:file:_files' \
    '-elev.default+[default elevation (m)]:m:_default' \
    '-interpolator+[interpolation method]:method:(bco nn linear)' \
    '-interpolator.bco.radius+[bicubic filter size]:n:_default' \
    '-opt.rpc+[RPC control points per axis]:n:_default' \
    '-opt.ram+[available RAM (MB)]:mb:_default' \
    '-opt.gridspacing+[resampling grid resolution]:value:_default' \
    '-progress[show progress]' \
    '(- *)-help[show help]' \
    && ret=0

return ret
