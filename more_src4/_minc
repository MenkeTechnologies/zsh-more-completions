#compdef minc
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/minc.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. minc(1) from maildir-utils;
# accepts only -q (quiet) plus one or more maildir directories.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-q[quiet mode, do not print new messages]' \
  '*:maildir:_files -/' && ret=0

return ret
