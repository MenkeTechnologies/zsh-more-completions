#compdef otbcli_Rasterization
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_Rasterization.html
# Source: orfeotoolbox/OTB Rasterization — burn vector geometries into a raster grid.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-in+[input vector dataset]:vector:_files' \
    '-out+[output rasterized image]:image:_files' \
    '-im+[reference image (grid + projection)]:image:_files' \
    '-szx+[output X size]:n:_default' \
    '-szy+[output Y size]:n:_default' \
    '-orx+[upper-left X]:value:_default' \
    '-ory+[upper-left Y]:value:_default' \
    '-spx+[spacing X (GSD)]:value:_default' \
    '-spy+[spacing Y (GSD)]:value:_default' \
    '-epsg+[output EPSG code]:code:_default' \
    '-mode+[rasterization mode]:mode:(binary attribute)' \
    '-background+[background pixel value (default 0)]:value:_default' \
    '-mode.binary.foreground+[foreground value (default 255)]:value:_default' \
    '-mode.attribute.field+[attribute field for burn-in (default DN)]:field:_default' \
    '-ram+[available RAM (MB, default 256)]:mb:_default' \
    '-progress[show progress]' \
    '(- *)-help[show help]' \
    && ret=0

return ret
