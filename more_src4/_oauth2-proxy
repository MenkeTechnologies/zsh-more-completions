#compdef oauth2-proxy
# Documentation: https://oauth2-proxy.github.io/oauth2-proxy/configuration/overview/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for oauth2-proxy (pflag + massive legacy flag surface).
# Only boot-time / high-signal flags are listed here; full flags: oauth2-proxy --help

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--config[path to legacy TOML config]:file:_files' \
  '--alpha-config[path to alpha YAML config]:file:_files' \
  '--convert-config-to-alpha[emit alpha YAML to stdout and exit]' \
  '--config-test[validate config and exit]' \
  '--version[print version and exit]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--http-address[HTTP listen address]:addr' \
  '--https-address[HTTPS listen address]:addr' \
  '--provider[OAuth provider id]:provider' \
  '--client-id[OAuth client id]:id' \
  '--client-secret[OAuth client secret]:secret' \
  '--cookie-secret[cookie signing secret]:secret' \
  '--email-domain[authenticated email domains]:domain' \
  '--redirect-url[callback URL]:url' \
  '--upstream[upstream URL (repeatable)]:url' \
  '--skip-auth-regex[regex for paths to skip auth (repeatable)]:pattern' \
  '--force-https[redirect HTTP to HTTPS]' \
  '--ssl-insecure-skip-verify[skip TLS verify to provider]' \
  '*:extra:_message "see oauth2-proxy --help"' && ret=0

return ret
