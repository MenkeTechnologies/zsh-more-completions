#compdef phoenix arize-phoenix
# Documentation: https://github.com/Arize-ai/phoenix
# Reference accessed: 2026-05-22
# Verified: phoenix.server.main argparse (arize-phoenix PyPI package).

# Zsh completion for phoenix - Arize Phoenix LLM observability server CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'phoenix command' \
      'serve[start Phoenix server]' \
      'db[database management commands]' && ret=0
    ;;
esac

return ret
