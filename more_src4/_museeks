#compdef museeks
# _museeks — Museeks cross-platform music player (Electron + React); local library scanner with smart playlists
# upstream: https://github.com/martpie/museeks

_museeks() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--debug[debug log]' \
        '--user-data-dir+[user data dir]:dir:_files -/' \
        '--no-update[skip update check]' \
        '--proxy-server+[proxy]:host:port:' \
        '--disable-gpu[disable GPU acceleration]' \
        '*:music file:_files'
}

_museeks "$@"
