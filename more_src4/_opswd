#compdef opswd
# Documentation: https://github.com/ohmyzsh/ohmyzsh/blob/master/plugins/1password/1password.plugin.zsh
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Source: ohmyzsh/plugins/1password (MIT)
# opswd: ohmyzsh helper that prints/uses a 1Password Login item password
# via `op item list --categories Login`.

local -a services

services=( "${(@f)$(command op item list --categories Login --cache 2>/dev/null | command awk 'NR != 1 { print $2 }')}" )
[[ -z "$services" ]] || compadd -a -- services
