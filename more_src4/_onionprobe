#compdef onionprobe
# _onionprobe — Tor Project onionprobe CLI for monitoring availability of v3 onion services querying HSDirs measuring descriptor fetch time onion reachability HTTP status with optional Prometheus metric output (torproject team, Python); argparse
# upstream: https://gitlab.torproject.org/tpo/onion-services/onionprobe

_onionprobe() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '-e+[endpoint URL]:str:' \
        '--endpoint=+[endpoint URL]:str:' \
        '-r+[rounds]:n:' \
        '--rounds=+[rounds]:n:' \
        '-i+[interval seconds]:n:' \
        '--interval=+[interval seconds]:n:' \
        '-t+[timeout seconds]:n:' \
        '--timeout=+[timeout seconds]:n:' \
        '--tor-socks-host=+[host]:str:' \
        '--tor-socks-port=+[port]:n:' \
        '--tor-control-host=+[host]:str:' \
        '--tor-control-port=+[port]:n:' \
        '--tor-data-dir=+[dir]:dir:_files -/' \
        '--prometheus-enabled[enable Prometheus metrics]' \
        '--prometheus-port=+[port]:n:' \
        '--prometheus-addr=+[addr]:str:' \
        '--http-timeout=+[seconds]:n:' \
        '--randomize[randomize order]' \
        '--no-color[no color]' \
        '--log-level=+[level]:l:(debug info warn error critical)' \
        '*:onion URLs:'
}

_onionprobe "$@"
