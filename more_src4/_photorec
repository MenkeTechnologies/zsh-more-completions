#compdef photorec
# Documentation: https://www.cgsecurity.org/wiki/Scripted_run
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '/log[create a photorec.log file]' \
  '/debug[add debug info]' \
  '/d+[set destination directory for recovered files]:directory:_files -/' \
  '/logname+[direct log to file]:file:_files' \
  '/cmd[introduce scripted command section]' \
  '*:disk or image:_files' && ret=0

return ret
