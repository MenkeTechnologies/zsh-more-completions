#compdef particle
# particle — Particle IoT device cloud CLI

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'login:log in to Particle Cloud'
  'logout:log out from Particle Cloud'
  'list:list your devices'
  'setup:set up a new device'
  'serial:interact with device over serial'
  'flash:flash firmware to a device'
  'compile:compile firmware in the cloud'
  'call:call a function on a device'
  'get:get a variable from a device'
  'subscribe:subscribe to event stream'
  'publish:publish an event'
  'keys:manage device keys'
  'cloud:manage cloud connection'
  'function:call a function on a device'
  'variable:get a variable from a device'
  'webhook:manage webhooks'
  'token:manage access tokens'
  'device:manage devices'
  'binary:manage firmware binaries'
  'library:manage firmware libraries'
  'project:manage projects'
  'update:update CLI to latest version'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--target=[target device name or ID]:device:' \
  '--saveTo=[save output to file]:file:_files' \
  '--port=[serial port]:port:_files -g "/dev/tty*(-.)"' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'particle subcommand' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
