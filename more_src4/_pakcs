#    case $1 in
#      cypm | frontend ) check_and_exec_tool ${1+"$@"} ;;
#    esac
#
#    for i in $* ; do
#      case $i in
#        --help | -h | -? | --version | -V | \
#        --numeric-version | --compiler-name | \
#        --base-version ) USECPM=no ; USERLWRAP=no ;;
#        --nocypm | -n     ) USECPM=no ;;
#        --noreadline      ) USERLWRAP=no ;;
#        --quiet  | -q     ) QUIET=yes ;;
#      esac
#    done
#
#    # CPM integration: compute CURRYPATH from CPM
#    # (Curry Package Manager) if available
#    if [ -n "$CYPMBIN" ] ; then
#      CPMPATH=`"$CYPMBIN" -v quiet deps -p`
#      export CURRYPATH="$CURRYPATH:$CPMPATH"
#    fi
#
#    # Hand off remaining argv to the actual PAKCS REPL binary
#    REPL="$PAKCSHOME/src/pakcs"
#    if [ "$USERLWRAP" = yes ] ; then
#      exec rlwrap "$REPL" $NOCOLOR "$@"
#    else
#      exec "$REPL" $NOCOLOR "$@"
#    fi
#
#  PAKCS launcher distinctive features:
#    - SHELL-SCRIPT WRAPPER pattern — common for compilers/REPLs
#      that need to set up environment variables (CURRYPATH for
#      module load path), wire in optional readline support
#      (via rlwrap), and dispatch to companion tools (cypm,
#      frontend) BEFORE the REPL binary runs
#    - SUBCOMMAND DISPATCH for cypm + frontend — first positional
#      arg matched against `cypm`/`frontend` keywords; if matched,
#      shell exec's `pakcs-cypm` or `pakcs-frontend` binary
#      directly with remaining argv (bypassing REPL)
#    - META-FLAG DETECTION — flags that affect the launcher itself
#      (`--nocypm` / `--noreadline` / `--quiet` / `--help` /
#      `--version`) are detected via shell `case` matching;
#      remaining flags are passed through to the REPL
#    - RLWRAP INTEGRATION — if `rlwrap` is on PATH and stdin is
#      a TTY and `$HOME` exists, the REPL is wrapped with rlwrap
#      to provide readline (history + line editing) support;
#      bypassed by `--noreadline` flag
#    - CPM (CURRY PACKAGE MANAGER) INTEGRATION — if `cypm` is
#      installed, the launcher runs `cypm deps -p` to compute
#      the project's CURRYPATH and prepends it to the environment;
#      bypassed by `--nocypm` / `-n` flag
#    - NOCOLOR DETECTION — if stdin isn't a TTY (e.g. piped
#      input), automatically add `--nocolor` to suppress ANSI
#      escape codes in REPL output
#    - VERSION INTROSPECTION — `--numeric-version` / `--compiler-
#      name` / `--base-version` are recognized as version-query
#      flags that should bypass CPM integration (faster startup
#      when scripts just need version info)
#    - REPL COMMANDS dispatched by the actual `pakcs` binary
#      (not the shell wrapper) include classic Haskell-style REPL
#      commands: `:type expr` / `:load Module` / `:reload` /
#      `:quit` / `:set option` / `:info Symbol` (added in 3.8.0)
#      / `:browse Module` / `+show` / `-show` (added in 3.9.0)
#      / `:eval expr` for explicit evaluation
#  PAKCS's launcher pattern is shared with: GHC's `ghci` shell
#  wrapper, Clojure's `clj` script, Racket's `racket` wrapper,
#  many other REPL-based compiler/interpreter projects where
#  environment setup happens in shell before the REPL boots.
#  Curry is the FIRST DOCUMENTED Curry CLI library in the
#  corpus's cross-language taxonomy.  Curry joins the 37 other
#  documented languages (Rust, Go, TypeScript-Node, Python,
#  Ruby, Perl, Haskell, OCaml, Elixir, R, Bash, Deno, Lua,
#  Scheme, Clojure, Common Lisp, Racket, Crystal, Nim, Zig,
#  Odin, V, Mojo, Roc, Hare, Standard ML, Erlang, Pony, Prolog,
#  Pike, F#, Janet, D, Picat, BQN, Frege, Lobster) as the 38th
#  represented language.  Brings cross-language CLI library
#  taxonomy variant count to 182 (181 + hand-rolled-PAKCS = 182).
#
#  Surface (verbatim from `scripts/pakcs.sh` case-match flag
#  detection + subcommand dispatch):
#
#  Usage:
#    pakcs [launcher-flags] [REPL-flags] [Module.curry]
#    pakcs cypm <CPM-args>          # Curry Package Manager
#    pakcs frontend <front-end-args> # Curry frontend (parser/typecheck)
#
#  Launcher meta-flags (recognized by the wrapper script):
#    -h, --help, -?                 Show help and exit
#    -V, --version                  Show PAKCS version (full)
#        --numeric-version          Show just version number
#                                   (e.g. "3.10.0")
#        --compiler-name            Print compiler identifier
#                                   ("PAKCS" for this impl;
#                                   useful for scripts to detect
#                                   whether they're running on
#                                   PAKCS or KICS2)
#        --base-version             Show Curry base library
#                                   version (the base/prelude
#                                   versions can differ from
#                                   PAKCS version)
#    -n, --nocypm                   Don't use CPM (Curry Package
#                                   Manager) to compute CURRYPATH
#                                   (faster startup, but
#                                   project-local dependencies
#                                   not auto-included)
#        --noreadline               Don't use rlwrap for readline
#                                   support in the REPL (useful
#                                   in emacs/CI/non-TTY contexts)
#    -q, --quiet                    Don't print informational
#                                   messages from the launcher
#                                   (CPM computation, etc.)
#        --nocolor                  Disable ANSI colors in REPL
#                                   output (auto when stdin is
#                                   not a TTY)
#
#  Subcommands (dispatched to companion tools before REPL):
#    cypm <args>                    Curry Package Manager —
#                                   `pakcs cypm install <pkg>`
#                                   adds a Curry package; sub-
#                                   commands include install /
#                                   list / search / update /
#                                   uninstall / info / config
#    frontend <args>                Curry frontend — `pakcs
#                                   frontend Module.curry`
#                                   runs ONLY parsing + type-
#                                   checking, producing FlatCurry
#                                   .fcy files; useful for
#                                   integration with external
#                                   tools that consume FlatCurry
#
#  REPL flags (forwarded by launcher to the actual pakcs REPL):
#    Many — see `pakcs --help` for the full list.  Common ones
#    include `--no-base`, `--no-debug`, `--debug-search`,
#    `--time`, `--profiling`, etc.  Most users will set these
#    via REPL commands `:set <flag>` rather than CLI args.
#
#  Positional:
#    Module.curry                   Curry source file to load
#                                   into the REPL on startup
#                                   (similar to `ghci Foo.hs`)
#
#  REPL commands (typed at the `Prelude>` prompt after launch;
#  NOT shell CLI flags):
#    :type <expr> / :t <expr>       Show type of expression
#    :load <Module> / :l <Module>   Load Curry module
#    :reload / :r                   Reload current module
#    :quit / :q                     Exit the REPL
#    :set <option>                  Set REPL option (verbose,
#                                   search, profile, etc.)
#    :info <Symbol> / :i            Show info about symbol
#                                   (signature, definition,
#                                   location) — added 3.8.0
#    :browse <Module>               Browse module exports
#    :eval <expr>                   Evaluate expression explicitly
#    +show                          Turn on show-mode (wraps
#                                   results in Prelude.show)
#                                   — added 3.9.0
#    -show                          Turn off show-mode
#    :help / :?                     Show REPL command help
#
#  Examples:
#    pakcs                                       # Start REPL with empty Prelude
#    pakcs Hello.curry                           # Start REPL + load Hello.curry
#    pakcs --version                             # Print PAKCS version
#    pakcs --numeric-version                     # Just "3.10.0"
#    pakcs --compiler-name                       # Print "PAKCS"
#    pakcs --base-version                        # Print Curry base library version
#    pakcs --nocypm Hello.curry                  # Skip CPM (fast start)
#    pakcs --noreadline                          # No rlwrap (for emacs)
#    pakcs --quiet                               # No CPM-computation messages
#    pakcs cypm install json                     # Install Curry "json" package
#    pakcs cypm list                             # List installed packages
#    pakcs cypm search XML                       # Search packages matching "XML"
#    pakcs frontend Hello.curry                  # Parse+typecheck (FlatCurry output)
#    # At the Prelude> REPL prompt:
#    Prelude> :load Hello                        # Load Hello module
#    Prelude> :type 1 + 2                        # Type: Int
#    Prelude> :info map                          # Info on map function
#    Prelude> :quit                              # Exit
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  similar shell-wrapper-launchers for academic languages):
#    - kics2 (KICS2 — Kiel Curry System 2; Haskell-backend
#      Curry impl; FUTURE candidate for documenting the alternate
#      Curry implementation)
#    - swipl / sicstus (Prolog implementations PAKCS uses as
#      backend; swipl IN CORPUS via _swipl + STOCK; sicstus
#      commercial)
#    - ghc / runghc (Haskell — IN CORPUS + STOCK; PAKCS frontend
#      depends on Haskell Stack for compilation)
#    - cypm (Curry Package Manager — separate binary `pakcs-
#      cypm` dispatched via `pakcs cypm` subcommand; FUTURE
#      separate completion candidate)
#    - mercury / mmc (IN CORPUS via _mercury — Mercury logic+
#      functional language; closely related to Curry but
#      strongly typed in different ways; FUTURE formal Mercury
#      language entry)
#    - cau-placc/pakcs repo itself (15 stars language not CLI)
# ============================================================================

_pakcs() {
  local context state state_descr line
  typeset -A opt_args
  local curcontext="$curcontext"

  _arguments -C \
    '(-h --help -\?)'{-h,--help,'-\?'}'[show help and exit]' \
    '(-V --version)'{-V,--version}'[show PAKCS version]' \
    '--numeric-version[show just version number]' \
    '--compiler-name[print compiler identifier (PAKCS)]' \
    '--base-version[show Curry base library version]' \
    '(-n --nocypm)'{-n,--nocypm}'[do not use CPM to compute CURRYPATH]' \
    '--noreadline[do not use rlwrap for readline support]' \
    '(-q --quiet)'{-q,--quiet}'[do not print informational messages]' \
    '--nocolor[disable ANSI colors in REPL output]' \
    '1: :->subcommand' \
    '*:: :->args' && return

  case "$state" in
    subcommand)
      local -a subcmds
      subcmds=(
        'cypm:Curry Package Manager (install/list/search/update packages)'
        'frontend:Curry frontend (parser/typecheck producing FlatCurry .fcy)'
      )
      _describe -t subcommands 'pakcs subcommand' subcmds
      _files -g "*.curry"
      ;;
    args)
      case "${words[1]}" in
        cypm)
          local -a cypmcmds
          cypmcmds=(
            'install:install a Curry package'
            'list:list installed packages'
            'search:search for packages'
            'update:update package index'
            'uninstall:remove a package'
            'info:show package info'
            'config:CPM configuration'
            'deps:compute dependency CURRYPATH'
          )
          _describe -t subcommands 'cypm subcommand' cypmcmds
          ;;
        frontend)
          _arguments -s -S \
            '*:file:_files -g "*.curry"'
          ;;
      esac
      ;;
  esac
}

_pakcs "$@"
