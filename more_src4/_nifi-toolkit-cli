#compdef nifi-toolkit-cli nifi-toolkit nifi-cli2
# _nifi-toolkit-cli — Apache NiFi nifi-toolkit-cli CLI command-line frontend wrapping the Apache NiFi Toolkit CLI providing nifi nifi-registry session login logout currentUser flow process group import export upgrade variables version-control-publication parameter context controller-services flow-files monitoring registry buckets users groups (Apache NiFi team, Java); custom argparse
# upstream: https://nifi.apache.org/

_nifi-toolkit-cli() {
    local -a sub=(
        'session:session management'
        'nifi:NiFi operations'
        'nifi-registry:NiFi Registry operations'
        'demo:run demo'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--properties=+[file]:file:_files -g "*.properties"' \
        '-p+[properties file]:file:_files -g "*.properties"' \
        '--baseUrl=+[url]:str:' \
        '-u+[user]:str:' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '--keystore=+[file]:file:_files -g "*.jks *.p12"' \
        '--keystoreType=+[t]:t:(JKS PKCS12)' \
        '--keystorePasswd=+[password]:str:' \
        '--truststore=+[file]:file:_files -g "*.jks *.p12"' \
        '--truststoreType=+[t]:t:(JKS PKCS12)' \
        '--truststorePasswd=+[password]:str:' \
        '--proxiedEntity=+[entity]:str:' \
        '--basicAuthUsername=+[user]:str:' \
        '--basicAuthPassword=+[password]:str:' \
        '--bearerToken=+[token]:str:' \
        '--protocol=+[p]:p:(HTTP HTTPS)' \
        '--output-type=+[fmt]:f:(simple json yaml)' \
        '-ot+[fmt]:f:(simple json yaml)' \
        '--connectionTimeout=+[ms]:n:' \
        '--readTimeout=+[ms]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'nifi-toolkit-cli subcommand' sub ;;
        args)
            case $words[1] in
                session) _arguments '1:op:(set keys clear show)' ;;
                nifi|nifi-registry) _arguments '1:op:(current-user list-buckets list-flows list-versioned-flows list-process-groups list-controller-services list-registries upload-flow-version stop-process-group start-process-group delete-process-group export-flow-version flow-version-control register-flow-version-control)' '*:id:' ;;
            esac
            ;;
    esac
}

_nifi-toolkit-cli "$@"
