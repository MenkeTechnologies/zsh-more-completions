#compdef okdb
# ============================================================================
# okdb - embedded LMDB-backed document database with
#         FTS + vector search + sync + HTTP API
#         (JavaScript -> Node, source-available)
#
# Author : kedemd
# Upstream: https://github.com/kedemd/okdb
# npm    : @kedem/okdb (binary: okdb)
#
# `okdb` is the operator CLI for the OKDB embedded
# document database. The Node.js library wraps LMDB +
# layers on typed collections, composite secondary
# indexes, full-text search (inverted index), vector
# embeddings, multi-node sync, durable job queue,
# blob storage, point-in-time queries, materialized
# views, and a built-in HTTP API + admin UI - all in
# one in-process database.
#
# Usage:
#   okdb <command> [flags]
#
# The CLI launches OKDB's embedded HTTP server +
# admin UI, exposes the REST API, and provides
# operator commands for sync setup, snapshot
# management, and migration. The binary is intended
# to be invoked directly OR via `npx okdb` (for
# project-local use).
#
# Common commands (inferred from upstream docs):
#   serve / start          - launch HTTP server +
#                             admin UI on the
#                             configured port
#   sync                   - manage sync peer
#                             relationships
#   admin                  - admin-token management
#   snapshot               - take a point-in-time
#                             snapshot
#   restore                - restore from a snapshot
#
# Common flags (inferred from getting-started.md +
# http-api.md):
#   --db <path>            - database root directory
#                             (default ./mydb)
#   --port <n>             - HTTP API listen port
#                             (default 8080)
#   --host <addr>          - HTTP API bind address
#                             (default 0.0.0.0)
#   --durability <preset>  - durability preset:
#                             strict / balanced (default)
#                             / fast
#   --map-size <bytes>     - LMDB map size in bytes
#                             (default 4 GiB)
#   --token <secret>       - admin bearer token
#                             (alternative: env
#                             OKDB_ADMIN_TOKEN)
#   --help, -h             - print help
#   --version, -V          - print version
#
# The roaring lane is built on `roaring ^2.7.0`
# (declared at upstream package.json HEAD as a direct
# dep), the canonical Node Roaring Bitmap library by
# Salvatore Previti - github.com/SalvatorePreviti/
# roaring-node, 200+ stars on the Node binding alone;
# the underlying RoaringBitmap umbrella spans ~12
# language implementations + 14,000+ aggregate stars.
#
# SalvatorePreviti/roaring-node is a napi-rs binding
# to CRoaring - the C reference implementation of the
# Roaring Bitmap data structure by Daniel Lemire (the
# algorithm's co-inventor). Per-platform pre-built
# binaries cover Linux x64 / arm64 / musl, macOS x64
# / arm64, and Windows x64. The N-API stability
# promise means the binding survives Node major-
# version upgrades without recompile.
#
# By wrapping CRoaring rather than reimplementing the
# data structure in pure JS, roaring-node inherits:
#   - the spec-author-maintained reference impl
#     (RoaringFormatSpec)
#   - SIMD-tuned hot paths (CRoaring uses AVX-512,
#     AVX2, ARM NEON intrinsics in C)
#   - byte-for-byte interop with the Rust + Go + Java
#     + Python + Swift implementations under the
#     RoaringBitmap umbrella
#
# okdb uses roaring bitmaps for full-text search
# posting lists: every term in the inverted index
# maps to a roaring bitmap of document IDs, and
# query evaluation (AND / OR / NOT predicates over
# multiple terms) becomes a sequence of bitmap
# intersections / unions / differences. This is the
# same operational model as bleve (Axis 250's Go slot)
# and Apache Lucene.
#
# ----------------------------------------------------------------------------
# AXIS 250 :: Roaring Bitmap compressed bitmap index
#              data structure (LANDMARK AXIS)
# Round 1450 :: TS-Node slot 3 of 4 :: CLOSES Axis 250
#                                       (243rd axis closed,
#                                        round-number landmark)
#
# Cross-language canonical library family for this axis:
#   Rust    : RoaringBitmap/roaring-rs   [R1448 _stoolap]
#   Go      : RoaringBitmap/roaring      [R1449 _bleve]
#             (Lemire's reference impl)
#   TS/Node : SalvatorePreviti/roaring-node
#                                         [R1450 THIS FILE]
#             (napi-rs binding to CRoaring)
#
# SalvatorePreviti/roaring-node closes Axis 250 with
# the *napi-rs-binding-to-the-C-spec-author-impl*
# pattern. The three lanes form a clean spectrum:
#
#   - Rust (roaring-rs): pure-Rust implementation under
#     the RoaringBitmap umbrella; not by Lemire
#     personally but spec-tracked against Lemire's
#     RoaringFormatSpec; canonical Rust slot
#   - Go (RoaringBitmap/roaring): Daniel Lemire's
#     personal Go reference implementation; unique
#     algorithm-author = library-author root-of-trust
#     position
#   - Node (SalvatorePreviti/roaring-node): napi-rs
#     binding to Lemire's CRoaring C reference impl;
#     inherits the spec-author's C canonical with
#     N-API ergonomics + cross-platform pre-built
#     binaries
#
# The Node-binds-to-C pattern is structurally
# different from the Node-binds-to-Rust pattern seen
# at @node-rs/argon2 (Axis 244) and @chainsafe/libp2p-
# quic (Axis 249) - those bind to Rust implementations
# of canonical algorithms, but roaring-node binds
# directly to the spec-author's own C reference impl.
# This makes the Node slot's wire-format-correctness
# guarantee even stronger: it's literally the spec
# author's own code, just wrapped in a JS-callable
# interface.
#
# Cross-language interop at the wire format level -
# the RoaringFormatSpec byte string round-trips
# byte-identically through roaring-rs + RoaringBitmap/
# roaring + roaring-node (and CRoaring + the C++
# wrapper + the Java impl + Python + Swift + ...).
# Lemire's umbrella governance + the spec doc keeps
# this byte-format interop stable across the 10+ year
# library lifetime.
#
# Use-case spectrum across the three lanes:
#   - stoolap (Rust, roaring-rs): embedded SQL +
#     MVCC database with roaring inverted indexes for
#     per-column value -> row-ID mapping
#   - bleve (Go, RoaringBitmap/roaring): full-text +
#     geo-spatial + vector indexing CLI used by
#     Couchbase + zincsearch + ~700 other Go projects
#     for inverted-index posting lists
#   - okdb (Node, SalvatorePreviti/roaring-node):
#     embedded document database with roaring FTS
#     posting lists + LMDB-backed storage
#
# Three lanes, three use-case shapes (embedded SQL /
# full-text search engine / embedded document DB),
# three implementation strategies (pure-Rust under
# umbrella / algorithm-co-inventor's pure-Go impl /
# napi-rs binding to algorithm-co-inventor's C
# reference), all converging on the RoaringFormatSpec
# wire format.
#
# Axis 250 closes the round 1450 cycle - 243rd axis
# closed total with the round-1450 landmark at the
# milestone Axis-250-LANDMARK closure.
# ============================================================================

_okdb() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '--db[database root directory (default ./mydb)]:dir:_files -/' \
        '--port[HTTP API listen port (default 8080)]:port:' \
        '--host[HTTP API bind address]:addr:' \
        '--durability[durability preset]:preset:(strict balanced fast)' \
        '--map-size[LMDB map size in bytes (default 4 GiB)]:bytes:' \
        '--token[admin bearer token (or env OKDB_ADMIN_TOKEN)]:secret:' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :_okdb_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                serve|start)
                    _arguments \
                        '--db[database root directory]:dir:_files -/' \
                        '--port[HTTP API listen port]:port:' \
                        '--host[HTTP API bind address]:addr:' \
                        '(- *)'{-h,--help}'[print subcommand help]'
                    ;;
                sync|admin|snapshot|restore)
                    _arguments \
                        '--db[database root directory]:dir:_files -/' \
                        '--token[admin bearer token]:secret:' \
                        '(- *)'{-h,--help}'[print subcommand help]'
                    ;;
            esac
            ;;
    esac

    return ret
}

_okdb_cmds() {
    local -a cmds
    cmds=(
        'serve:launch HTTP server + admin UI'
        'start:alias for serve'
        'sync:manage sync peer relationships'
        'admin:admin token management'
        'snapshot:take a point-in-time snapshot'
        'restore:restore from a snapshot'
    )
    _describe -t commands 'okdb command' cmds
}

_okdb "$@"
