#compdef nps npc
# Documentation: https://github.com/ehang-io/nps
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (cmd/nps/nps.go and cmd/npc/npc.go).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'install:install nps as system service'
  'uninstall:uninstall nps service'
  'start:start service'
  'stop:stop service'
  'restart:restart service'
  'reload:reload service'
  'update:update binary'
  'status:show status (npc, requires -config)'
  'register:register local IP with server (npc)'
  'nat:detect NAT type and public address (npc)'
  'service:internal service-mode argument'
)

_arguments -C \
  '(- *)-version[show version]' \
  '-config=[config file]:file:_files' \
  '-server=[server addr ip:port]:host:_hosts' \
  '-vkey=[verify key]:key:' \
  '-type=[connection type]:t:(tcp kcp)' \
  '-proxy=[upstream SOCKS5 proxy]:url:' \
  '-log=[log target]:t:(stdout file)' \
  '-log_path=[log path]:file:_files' \
  '-log_level=[log level 0-7]:lvl:(0 1 2 3 4 5 6 7)' \
  '-debug=[debug bool]:bool:(true false)' \
  '-pprof_addr=[pprof debug address]:addr:' \
  '-stun_addr=[STUN server address]:addr:' \
  '-disconnect_timeout=[disconnect timeout seconds]:secs:' \
  '-time=[register time hours]:h:' \
  '-local_port=[P2P local port]:port:' \
  '-local_type=[P2P target type]:t:' \
  '-password=[P2P password]:pw:' \
  '-target=[P2P target]:target:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'nps/npc command' commands && ret=0 ;;
esac

return ret
