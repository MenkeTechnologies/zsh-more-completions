# Zsh completion for Next LS (Elixir language server)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(--port)--stdio[use stdio as the transport mechanism]' \
  '(--stdio)--port=[use TCP transport on port]:port:' && ret=0

return ret
