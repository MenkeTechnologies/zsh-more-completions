#compdef piodebuggdb
# Documentation: https://docs.platformio.org/en/latest/core/userguide/cmd_debug.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# piodebuggdb is a shortcut for `pio debug --interface=gdb`; trailing args
# after `--` are forwarded to GDB.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-d --project-dir)'{-d+,--project-dir=}'[project directory]:dir:_directories' \
  '(-c --project-conf)'{-c+,--project-conf=}'[project config file]:file:_files' \
  '*'{-e+,--environment=}'[environment to debug]:env:' \
  '--load-mode=[debug load mode]:mode:(always modified manual)' \
  '*'{-v,--verbose}'[verbose output]' \
  '(- *)'{-h,--help}'[show help]' \
  '*:GDB args:_files' && ret=0

return ret
