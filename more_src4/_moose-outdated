#compdef moose-outdated
# Documentation: https://metacpan.org/dist/Moose/source/script/moose-outdated
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# moose-outdated only accepts --verbose|-v (Dist::Zilla::Plugin::Conflicts)
local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(-v --verbose)'{-v,--verbose}'[run full conflict check verbosely]' && ret=0

return ret
