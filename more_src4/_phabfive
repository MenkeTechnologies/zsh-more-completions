#compdef phabfive
# Documentation: https://github.com/dynamist/phabfive
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'diffusion:manage diffusion repositories'
  'edit:edit a phabricator object'
  'maniphest:manage maniphest tasks'
  'passphrase:manage passphrase credentials'
  'paste:manage pastes'
  'repl:open interactive REPL'
  'user:manage users'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--log-level=[set log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '--format=[output format]:format:(json yaml table)' \
  '--ascii=[ASCII instead of Unicode]:when:(auto always never)' \
  '--hyperlink=[terminal hyperlinks]:when:(auto always never)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'phabfive command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (paste|passphrase|maniphest|diffusion|user)
        _arguments '*::sub:(show list create edit search comment)' && ret=0 ;;
    esac ;;
esac

return ret
