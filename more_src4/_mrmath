#compdef mrmath
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/mrmath.html
# Source: MRtrix3/mrtrix3 cmd/mrmath.cpp — summary statistic across images or along an axis (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-axis+[axis to operate along (single input image)]:index:_default' \
    '-keep_unary_axes[keep unary axes prior to stats]' \
    '-datatype+[output datatype]:dtype:(float16 cfloat16 float32 cfloat32 float64 cfloat64 int8 uint8 int16 uint16 int32 uint32 int64 uint64 bit)' \
    '*:images, operation, output:_files -g "*.{nii,nii.gz,mif}"' \
    && ret=0

return ret
