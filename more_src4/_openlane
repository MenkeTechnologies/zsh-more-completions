#compdef openlane flow.tcl openlane-rs openlane2
# _openlane — Efabless OpenLane open-source ASIC implementation flow RTL-to-GDSII built on OpenROAD (efabless team, Python/Tcl); argparse
# upstream: https://github.com/efabless/openlane

_openlane() {
    local -a sub=(
        'run:run the flow'
        'test:run regression tests'
        'config:configure a design'
        'docs:open docs'
        'inspect:inspect run'
        'cleanup:cleanup designs'
        'export:export results'
        'compare:compare runs'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--design=+[design dir]:dir:_files -/' \
        '-design=+[design dir]:dir:_files -/' \
        '--config-file=+[config file]:file:_files -g "config.json config.tcl *.json *.tcl"' \
        '-c+[config file]:file:_files -g "config.json config.tcl *.json *.tcl"' \
        '--run-tag=+[tag]:str:' \
        '-tag+[tag]:str:' \
        '--threads=+[N]:n:' \
        '--no-rm[no remove]' \
        '--from=+[step]:str:' \
        '--to=+[step]:str:' \
        '--skip=+[step]:str:' \
        '--only=+[step]:str:' \
        '--save-views-to=+[dir]:dir:_files -/' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--last-run[continue last run]' \
        '--list-runs[list runs]' \
        '--init-default-config[init default config]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'openlane subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments \
                    '--design=+[design dir]:dir:_files -/' \
                    '--tag=+[tag]:str:' \
                    '--threads=+[N]:n:' \
                    '--from=+[step]:str:' \
                    '--to=+[step]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_openlane "$@"
