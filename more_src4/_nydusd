#compdef nydusd
# _nydusd — Nydus FUSE/virtio-fs/fscache daemon (dragonflyoss/nydus)
# upstream: https://github.com/dragonflyoss/nydus
# Subcommands from src/bin/nydusd/main.rs (clap).

_nydusd() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'fuse:run nydusd as a FUSE server'
                'virtiofs:run nydusd as a virtio-fs server'
                'singleton:host multiple blobcache/fscache/fuse/virtio-fs services'
                'daemon:run as a managed daemon (legacy)'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                fuse)
                    _arguments \
                        '(-M --mountpoint)'{-M+,--mountpoint=}'[FUSE mountpoint]:dir:_files -/' \
                        '--failover-policy=[failover policy]:policy:(none resend flush)' \
                        '--fuse-threads=[FUSE worker thread count]:n:' \
                        '--writable[mount FUSE filesystem rw]' \
                        '(-B --bootstrap)'{-B+,--bootstrap=}'[RAFS bootstrap]:file:_files' \
                        '(-D --localfs-dir)'{-D+,--localfs-dir=}'[localfs dir]:dir:_files -/' \
                        '(-s --shared-dir)'{-s+,--shared-dir=}'[passthrough shared dir]:dir:_files -/' \
                        '--prefetch-files=[prefetch list file]:file:_files'
                    ;;
                virtiofs)
                    _arguments \
                        '--hybrid-mode[enable both RAFS and passthroughfs drivers]' \
                        '--sock=[vhost-user API socket]:file:_files'
                    ;;
                singleton)
                    _arguments \
                        '(-F --fscache)'{-F+,--fscache=}'[fscache working dir]:dir:_files -/' \
                        '--fscache-tag=[fscache daemon tag]:tag:' \
                        '--fscache-threads=[fscache worker threads]:n:'
                    ;;
            esac
            ;;
    esac
}

_nydusd "$@"
