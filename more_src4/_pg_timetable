#compdef pg_timetable
# Documentation: source-direct extraction from upstream
# cybertec-postgresql/pg_timetable
#   internal/config/cmdparser.go: 5 jessevdk/go-flags struct
#   blocks (LoggingOpts, StartOpts, ResourceOpts, RestAPIOpts,
#   CmdOptions) with `long:"..."` / `short:"..."` / `choice:"..."`
#   tags decoded source-direct.  Hidden flag --no-help skipped
#   (upstream-suppressed-flag precedent).
# Reference accessed: 2026-05-30 via gh api.
# cybertec-postgresql pg_timetable R172 — PostgreSQL-native
# job scheduler implemented as a standalone Go daemon that
# stores chains-of-tasks in the database itself (no Cron, no
# Quartz, no Airflow).  Sister tool to the heavily-covered
# PostgreSQL family (psql/createdb/dropdb/pg_dump/pg_restore/
# pg_basebackup/pg_ctl/pg_isready/pgbench/pgbouncer + timescale
# tools timescaledb-tune/timescaledb-parallel-copy) already in
# the corpus.

_arguments -s -S \
  '(-c --clientname)'{-c+,--clientname=}'[unique name for application instance ($PGTT_CLIENTNAME)]:name:' \
  '--config=[YAML configuration file]:file:_files -g "*.(yml|yaml)"' \
  '--connstr=[PostgreSQL connection string ($PGTT_CONNSTR)]:connstr:' \
  '--no-program-tasks[disable executing of PROGRAM tasks ($PGTT_NOPROGRAMTASKS)]' \
  '(-v --version)'{-v,--version}'[output detailed version information]' \
  '--log-level=[verbosity level for stdout and log file]:level:(debug info error)' \
  '--log-database-level=[verbosity level for database storing]:level:(debug info error none)' \
  '--log-file=[file name to store logs]:file:_files' \
  '--log-file-format=[format of file logs]:fmt:(json text)' \
  '--log-file-rotate[rotate log files]' \
  '--log-file-size=[max log file size in MB before rotation (default 100)]:mb:' \
  '--log-file-age=[days to retain old log files (0=forever)]:days:' \
  '--log-file-number=[max number of old log files to retain (0=all)]:n:' \
  '(-f --file)'{-f+,--file=}'[SQL script or YAML chain definition to execute at startup]:file:_files -g "*.(sql|yml|yaml)"' \
  '--replace[replace existing chains when loading YAML files]' \
  '--validate[only validate YAML file without importing chains]' \
  '--init[initialize database schema to the latest version and exit (can pair with --upgrade)]' \
  '--upgrade[upgrade database to the latest version]' \
  '--debug[run in debug mode (only asynchronous chains will execute)]' \
  '--cron-workers=[parallel workers for scheduled chains (default 16)]:n:' \
  '--interval-workers=[parallel workers for interval chains (default 16)]:n:' \
  '--chain-timeout=[abort any chain that exceeds N milliseconds]:ms:' \
  '--task-timeout=[abort any task in a chain that exceeds N milliseconds]:ms:' \
  '--rest-port=[REST API port (0 disables, $PGTT_RESTPORT)]:port:' \
  '*::connection-string positional fallback:'
