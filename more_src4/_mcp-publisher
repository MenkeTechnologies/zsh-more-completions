#compdef mcp-publisher
# Documentation: https://github.com/modelcontextprotocol/registry
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mcp-publisher: cobra-based Go CLI for publishing MCP servers to the registry

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:generate server.json templates with auto-detection'
  'login:authenticate (github, dns, http, none)'
  'logout:clear stored credentials'
  'publish:validate and upload servers to registry'
  'status:update server lifecycle status'
  'help:help about any command'
)

_arguments -C -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '--version[version]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'mcp-publisher command' commands && ret=0 ;;
  args) _default && ret=0 ;;
esac

return ret
