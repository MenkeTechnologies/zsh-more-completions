#compdef pd-region-bench
# _pd-region-bench — TiKV PD region API benchmark
# upstream: https://github.com/tikv/pd
# Flags from tools/pd-region-bench/main.go on tip.

_pd-region-bench() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-pd=[PD address]:host\:port:' \
        '-region-count=[number of regions to prepare]:n:' \
        '-client=[PD clients per benchmark]:n:' \
        '-c=[request concurrency per client]:n:' \
        '-round=[benchmark round count]:n:' \
        '-duration=[benchmark duration]:dur:' \
        '-cacert=[trusted CA cert file (PEM)]:file:_files' \
        '-cert=[client X509 cert file (PEM)]:file:_files' \
        '-key=[client X509 key file (PEM)]:file:_files' \
        '-enable-router-client=[use router client batch QueryRegion]:bool:(true false)' \
        '-interval=[stats output interval]:dur:'
}

_pd-region-bench "$@"
