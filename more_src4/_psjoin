#compdef psjoin
# Documentation: psjoin --help (psutils)
# Source: concatenate PostScript files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[print help]' \
    '(- *)'{-V,--version}'[print version]' \
    '(-a --even)'{-a,--even}'[force each file to take an even number of pages]' \
    '(-s --save)'{-s,--save}'[try to close unclosed save operators]' \
    '(-p --strip)'{-p,--strip}'[do not strip prolog or trailer from input files]' \
    '*:ps file:_files -g "*.ps"' \
    && ret=0

return ret
