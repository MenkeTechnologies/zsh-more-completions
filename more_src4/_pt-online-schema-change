#compdef pt-online-schema-change
# Documentation: https://docs.percona.com/percona-toolkit/pt-online-schema-change.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--alter=[ALTER TABLE statement]:alter:' \
  '--alter-foreign-keys-method=[FK handling method]:method:(auto rebuild_constraints drop_swap none)' \
  '(--analyze-before-swap --no-analyze-before-swap)'{--analyze-before-swap,--no-analyze-before-swap}'[ANALYZE TABLE before swap]' \
  '--ask-pass[prompt for password]' \
  '--binary-index[use BLOB for history table boundaries]' \
  '(--buffer-stdout --no-buffer-stdout)'{--buffer-stdout,--no-buffer-stdout}'[enable/disable STDOUT buffering]' \
  '--channel=[replication channel name]:channel:' \
  '--charset=[default character set]:charset:' \
  '(--check-alter --no-check-alter)'{--check-alter,--no-check-alter}'[verify ALTER is safe]' \
  '(--check-foreign-keys --no-check-foreign-keys)'{--check-foreign-keys,--no-check-foreign-keys}'[check for self-referencing FKs]' \
  '--check-interval=[check interval]:seconds:' \
  '(--check-plan --no-check-plan)'{--check-plan,--no-check-plan}'[check query plan]' \
  '--check-replica-lag=[monitor specific replica for lag]:DSN:' \
  '(--check-replication-filters --no-check-replication-filters)'{--check-replication-filters,--no-check-replication-filters}'[check replication filters]' \
  '(--check-unique-key-change --no-check-unique-key-change)'{--check-unique-key-change,--no-check-unique-key-change}'[prevent adding unique indexes]' \
  '--chunk-index=[index for chunking]:index:' \
  '--chunk-index-columns=[columns of chunk index]:count:' \
  '--chunk-size=[rows per chunk]:rows:' \
  '--chunk-size-limit=[max chunk size factor]:factor:' \
  '--chunk-time=[time per chunk]:seconds:' \
  '--config=[config files]:files:_files' \
  '--critical-load=[abort at this load]:load spec:' \
  '--data-dir=[create table on different partition]:dir:_directories' \
  '--database=[database name]:database:' \
  '--default-engine[remove ENGINE specification]' \
  '--defaults-file=[MySQL defaults file]:file:_files' \
  '(--drop-new-table --no-drop-new-table)'{--drop-new-table,--no-drop-new-table}'[drop new table on error]' \
  '(--drop-old-table --no-drop-old-table)'{--drop-old-table,--no-drop-old-table}'[drop old table after rename]' \
  '(--drop-triggers --no-drop-triggers)'{--drop-triggers,--no-drop-triggers}'[drop triggers after rename]' \
  '--dry-run[dry run - do not alter]' \
  '--execute[actually perform the ALTER]' \
  '(--fail-on-stopped-replication --no-fail-on-stopped-replication)'{--fail-on-stopped-replication,--no-fail-on-stopped-replication}'[fail if replication stopped]' \
  '--force[bypass confirmation prompts]' \
  '--history[write progress to history table]' \
  '--history-table=[history table name]:name:' \
  '--host=[MySQL host]:hostname:_hosts' \
  '--max-flow-ctl=[PXC flow control threshold]:val:' \
  '--max-lag=[max replication lag]:seconds:' \
  '--max-load=[max load before throttling]:load spec:' \
  '--mysql_ssl=[create SSL connection]:n:' \
  '--new-table-name=[name for new table]:name:' \
  '--null-to-not-null[allow converting NULL to NOT NULL]' \
  '--only-same-schema-fks[check FKs in same schema only]' \
  '--password=[MySQL password]:password:' \
  '--pause-file=[pause while file exists]:file:_files' \
  '--pid=[PID file]:pid file:_files' \
  '--plugin=[Perl module plugin]:module:_files' \
  '--port=[MySQL port]:port:' \
  '--preserve-triggers[preserve existing triggers]' \
  '--print[print SQL instead of executing]' \
  '--progress=[print progress]:spec:' \
  '--quiet[quiet output]' \
  '--recurse=[recurse to find replicas]:depth:' \
  '--recursion-method=[method to find replicas]:method:(processlist hosts dsn none)' \
  '--remove-data-dir[remove DATA DIRECTORY specification]' \
  '--remove-tablespace[remove TABLESPACE specification]' \
  '--replica-password=[user for replica connections]:password:' \
  '--replica-user=[user for replica connections]:username:' \
  '--resume=[resume from history job ID]:id:' \
  '--reverse-triggers[copy triggers in reverse order]' \
  '--set-vars=[set MySQL variables]:vars:' \
  '--skip-check-replica-lag=[skip lag check on DSN]:DSN:' \
  '--sleep=[seconds to sleep after each chunk]:sec:' \
  '--socket=[MySQL socket]:socket file:_files' \
  '--statistics[print internal event counts]' \
  '(--swap-tables --no-swap-tables)'{--swap-tables,--no-swap-tables}'[swap old and new tables]' \
  '--tries=[retry critical operations]:spec:' \
  '--user=[MySQL user]:username:' \
  '(--version-check --no-version-check)'{--version-check,--no-version-check}'[check for latest versions]' \
  '--where=[copy only rows matching WHERE clause]:where:' \
  '1:DSN (D=db,t=table):' && ret=0

return ret
