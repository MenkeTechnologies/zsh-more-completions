#compdef mthread
# Documentation: https://manpages.ubuntu.com/manpages/noble/man1/mthread.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mthread: arrange messages into discussions (mailutils).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-v[do not prune unresolved Message-IDs at top level]' \
  '-p[with -S, only add parents, not unrelated subthreads]' \
  '-r[sort top-level threads in reverse order]' \
  '-S[treat given messages as optional]:messages:' \
  '*:message:_files' && ret=0

return ret
