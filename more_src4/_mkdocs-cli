#compdef mkdocs-cli
# _mkdocs-cli — MkDocs Material/Mkdocs static site generator CLI alias (MkDocs team, Python); click
# upstream: https://github.com/mkdocs/mkdocs

_mkdocs-cli() {
    local -a sub=(
        'build:build the site'
        'gh-deploy:deploy to gh-pages'
        'new:scaffold project'
        'serve:run dev server'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mkdocs subcommand' sub ;;
        args)
            case $words[1] in
                serve) _arguments \
                    '--dev-addr=+[dev address]:addr:' \
                    '-a+[dev address]:addr:' \
                    '--no-livereload[no livereload]' \
                    '--livereload[livereload]' \
                    '--dirtyreload[dirty reload]' \
                    '--dirty[dirty]' \
                    '--clean[clean]' \
                    '--no-strict[no strict]' \
                    '--strict[strict]' \
                    '-s[strict]' \
                    '--watch=+[watch path]:list:_files' \
                    '-w+[watch path]:list:_files' \
                    '--no-watch=+[no watch path]:list:_files' \
                    '--config-file=+[config file]:file:_files -g "mkdocs.yml"' \
                    '-f+[config file]:file:_files -g "mkdocs.yml"' \
                    '--theme=+[theme]:str:' \
                    '-t+[theme]:str:' \
                    '--use-directory-urls[use directory urls]' \
                    '--no-directory-urls[no directory urls]' \
                    '--open[open browser]' \
                    '-o[open browser]' ;;
                build) _arguments \
                    '--clean[clean]' \
                    '--dirty[dirty]' \
                    '--no-strict[no strict]' \
                    '--strict[strict]' \
                    '-s[strict]' \
                    '--config-file=+[config file]:file:_files -g "mkdocs.yml"' \
                    '-f+[config file]:file:_files -g "mkdocs.yml"' \
                    '--theme=+[theme]:str:' \
                    '-t+[theme]:str:' \
                    '--site-dir=+[site dir]:dir:_files -/' \
                    '-d+[site dir]:dir:_files -/' \
                    '--use-directory-urls[use directory urls]' \
                    '--no-directory-urls[no directory urls]' ;;
                gh-deploy) _arguments \
                    '--clean[clean]' \
                    '--dirty[dirty]' \
                    '--message=+[commit message]:str:' \
                    '-m+[commit message]:str:' \
                    '--remote-branch=+[remote branch]:str:' \
                    '-b+[remote branch]:str:' \
                    '--remote-name=+[remote name]:str:' \
                    '-r+[remote name]:str:' \
                    '--force[force push]' \
                    '-f[force push]' \
                    '--ignore-version[ignore version]' \
                    '--shell[use shell git command]' \
                    '--no-history[shallow]' \
                    '--config-file=+[config file]:file:_files -g "mkdocs.yml"' \
                    '--site-dir=+[site dir]:dir:_files -/' \
                    '-d+[site dir]:dir:_files -/' \
                    '--strict[strict]' \
                    '-s[strict]' ;;
                new) _arguments \
                    '1:project-name:' ;;
            esac
            ;;
    esac
}

_mkdocs-cli "$@"
