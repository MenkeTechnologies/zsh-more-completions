#compdef osm-preinstall
# _osm-preinstall — Open Service Mesh Helm pre-install hook (enforces single-mesh + namespace sanity before chart install)
# upstream: https://github.com/openservicemesh/osm
# Flags from cmd/osm-preinstall/osm-preinstall.go on tip.

_osm-preinstall() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-v --verbosity)'{-v,--verbosity}'=[log verbosity level]:level:(debug info warn error fatal)' \
        '--enforce-single-mesh=[enforce only deploying one mesh in the cluster]:bool:(true false)' \
        '--namespace=[namespace where the new mesh is being installed]:ns:'
}

_osm-preinstall "$@"
