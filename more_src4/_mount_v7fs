#compdef mount_v7fs
# Documentation: man mount_v7fs(8)
# Source: netbsd/src sbin/mount_v7fs — mount a 7th Edition file system (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-B+[metadata byte order]:byte order:(be le pdp)' \
    '-o+[mount options (comma-separated, see mount(8))]:options:_default' \
    '1:special device:_files' \
    '2:mount point:_files -/' \
    && ret=0

return ret
