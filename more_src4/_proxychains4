#compdef proxychains4 proxychains
# Documentation: proxychains-ng strings + upstream
# Source: redirect TCP traffic of any program through a chain of SOCKS/HTTP proxies.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '-q[quiet (overrides config setting)]' \
    '-f+[config file path]:file:_files -g "*.conf"' \
    '*:command and args:_command_names -e' \
    && ret=0

return ret
