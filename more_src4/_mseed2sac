#compdef mseed2sac
# Documentation: https://github.com/iris-edu/mseed2sac
# Source: iris-edu/mseed2sac src/mseed2sac.c — convert miniSEED seismic data to SAC format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-V[show version]' \
    '(- *)-h[show help]' \
    '-H[show extended help]' \
    '*-v[verbose (stackable)]' \
    '-O[overwrite existing output files]' \
    '-k+[station coordinates lat/lon]:coords:_default' \
    '-m+[channel metadata file]:file:_files' \
    '*-M+[channel metadata line]:line:_default' \
    '-msi[convert inclination/dip from SEED to SAC convention]' \
    '-E+[event parameters Time[/Lat][/Lon][/Depth][/Name]]:event:_default' \
    '-l+[selection list file]:file:_files' \
    '-f+[SAC format (1=alpha 2=binary-host 3=binary-le 4=binary-be)]:format:(1 2 3 4)' \
    '-N+[override network code]:network:_default' \
    '-S+[override station code]:station:_default' \
    '-L+[override location code]:location:_default' \
    '-C+[override channel code]:channel:_default' \
    '-r+[SEED record length (bytes, autodetected)]:bytes:_default' \
    '-i[process each input file individually]' \
    '-ic[process each channel individually]' \
    '-dr[use timestamp-derived sampling rate]' \
    '-z+[write SAC files to ZIP archive]:zipfile:_files' \
    '-z0+[write SAC files to uncompressed ZIP]:zipfile:_files' \
    '*:miniseed file:_files' \
    && ret=0

return ret
