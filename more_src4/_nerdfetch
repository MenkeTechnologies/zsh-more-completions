#compdef nerdfetch
# Documentation: https://github.com/ThatOneCalculator/NerdFetch
# Reference accessed: 2026-05-19
# Verified: upstream nerdfetch script's case statement parses -h/--help,
# -v, -c (Cozette), -p (Phosphor), -e (Emoji).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-v[show version]' \
  '-c[use Cozette font icons]' \
  '-p[use Phosphor font icons]' \
  '-e[use Emoji icons]' && ret=0

return ret
