#compdef pstopnm
# Documentation: man pstopnm (Netpbm)
# Source: convert a PostScript or PDF file to PNM via Ghostscript.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-stdout[write image data to stdout]' \
    '-forceplain[force plain (ASCII) PNM output]' \
    '(- *)-help[show help]' \
    '-dpi=[output resolution dpi]:dpi:' \
    '-xsize=[output width pixels]:pixels:' \
    '-ysize=[output height pixels]:pixels:' \
    '-xborder=[horizontal border fraction]:frac:' \
    '-yborder=[vertical border fraction]:frac:' \
    '(-landscape -portrait)-landscape[landscape orientation]' \
    '(-landscape -portrait)-portrait[portrait orientation]' \
    '-nocrop[do not crop output to image area]' \
    '(-pbm -pgm -ppm)-pbm[PBM output]' \
    '(-pbm -pgm -ppm)-pgm[PGM output]' \
    '(-pbm -pgm -ppm)-ppm[PPM output]' \
    '-llx=[lower-left x in points]:s:' \
    '-lly=[lower-left y in points]:s:' \
    '-urx=[upper-right x in points]:s:' \
    '-ury=[upper-right y in points]:s:' \
    '-verbose[verbose output]' \
    '-xmax=[max output width pixels]:pixels:' \
    '-ymax=[max output height pixels]:pixels:' \
    '-textalphabits=[Ghostscript text-alpha bits]:bits:(1 2 4)' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:ps or pdf file:_files -g "*.(ps|eps|pdf)"' \
    && ret=0

return ret
