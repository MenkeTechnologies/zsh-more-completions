#compdef maim
# Documentation: https://github.com/naelstrof/maim
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (maim.1 manpage).

# Zsh completion for maim — X11 screenshot utility

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-x --xdisplay)'{-x,--xdisplay=}'[set X display HOSTNAME:NUMBER.SCREEN_NUMBER]:display:' \
  '(-f --format)'{-f,--format=}'[output format]:format:(png jpg bmp webp)' \
  '(-i --window)'{-i,--window=}'[capture specific window by ID]:window:' \
  '(-g --geometry)'{-g,--geometry=}'[capture region wxh+x+y]:geometry:' \
  '(-w --parent)'{-w,--parent=}'[make geometry relative to window]:window:' \
  '(-B --capturebackground)'{-B,--capturebackground}'[capture elements behind window]' \
  '(-d --delay)'{-d,--delay=}'[wait seconds before capture]:seconds:' \
  '(-u --hidecursor)'{-u,--hidecursor}'[hide cursor in screenshot]' \
  '(-m --quality)'{-m,--quality=}'[compression quality 1-10]:level:' \
  '(-s --select)'{-s,--select}'[interactive region selection]' \
  '(-b --bordersize)'{-b,--bordersize=}'[selection rectangle thickness]:size:' \
  '(-p --padding)'{-p,--padding=}'[selection padding]:size:' \
  '(-t --tolerance)'{-t,--tolerance=}'[mouse-movement tolerance in pixels]:pixels:' \
  '(-c --color)'{-c,--color=}'[selection rectangle color R,G,B[,A]]:color:' \
  '(-r --shader)'{-r,--shader=}'[GLSL shader file]:file:_files' \
  '(-n --nodecorations)'{-n,--nodecorations=}'[decoration removal level]:level:(0 1 2)' \
  '(-l --highlight)'{-l,--highlight}'[highlight selection instead of outline]' \
  '(-D --nodrag)'{-D,--nodrag}'[click-click selection instead of drag]' \
  '(-q --quiet)'{-q,--quiet}'[disable unnecessary output]' \
  '(-k --nokeyboard)'{-k,--nokeyboard}'[disable keyboard cancellation]' \
  '(-o --noopengl)'{-o,--noopengl}'[disable hardware acceleration]' \
  ':output file:_files'
