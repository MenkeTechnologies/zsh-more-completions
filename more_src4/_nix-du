#compdef nix-du
# Documentation: https://github.com/symphorien/nix-du
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for nix-du (disk usage analysis for nix store)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-s --min-size)'{-s,--min-size}'[hide nodes below this size]:size:' \
  '(-n --nodes)'{-n,--nodes}'[only keep the approximately N biggest nodes]:count:' \
  '(-r --root)'{-r,--root}'[consider dependencies of PATH instead of all gc roots]:path:_files' \
  '--dump[dump the unaltered graph to file (debug)]:file:_files' \
  '(-O --opt-level)'{-O,--opt-level}'[store optimisation level]:level:(0 1 2)' \
  '(-q --quiet)'{-q,--quiet}'[do not print informational messages on stderr]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
