#compdef pw-top
# Documentation: https://docs.pipewire.org/page_man_pw-top_1.html
# Source: PipeWire — top-like per-node DSP load / xrun / rate display.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(-b --batch-mode)'{-b,--batch-mode}'[non-interactive batch mode]' \
    '(-n --iterations)'{-n+,--iterations=}'[exit after N batch iterations (with -b)]:n:' \
    '(-r --remote)'{-r+,--remote=}'[remote instance name (default: local PipeWire)]:name:' \
    '(- *)'{-V,--version}'[show version]' \
    && ret=0

return ret
