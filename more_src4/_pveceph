#compdef pveceph
# _pveceph — Proxmox Server Solutions pveceph Proxmox VE manage Ceph cluster services CLI (proxmox team, Perl); custom argparse
# upstream: https://git.proxmox.com/?p=pve-manager.git

_pveceph() {
    local -a sub=(
        'install:install Ceph packages'
        'init:initialize Ceph cluster'
        'createosd:create a Ceph OSD'
        'destroyosd:destroy a Ceph OSD'
        'osd:OSD subcommands'
        'mon:monitor subcommands'
        'createmon:create a Ceph monitor'
        'destroymon:destroy a Ceph monitor'
        'mgr:manager subcommands'
        'createmgr:create a Ceph manager'
        'destroymgr:destroy a Ceph manager'
        'mds:metadata server subcommands'
        'createmds:create a Ceph MDS'
        'destroymds:destroy a Ceph MDS'
        'fs:filesystem subcommands'
        'createpool:create a pool'
        'destroypool:destroy a pool'
        'pool:pool subcommands'
        'lspools:list pools'
        'purge:purge Ceph cluster'
        'start:start Ceph services'
        'stop:stop Ceph services'
        'status:show Ceph status'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '--output-format=+[format]:f:(text json json-pretty)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pveceph subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments \
                    '--cluster-network=+[network CIDR]:str:' \
                    '--network=+[public network CIDR]:str:' \
                    '--disable-cephx[disable cephx]' \
                    '--min-size=+[min size]:n:' \
                    '--size=+[size]:n:' \
                    '--pg-bits=+[PG bits]:n:' ;;
                createosd) _arguments \
                    '--crush-device-class=+[class]:str:' \
                    '--db-dev=+[block dev]:file:_files -g "/dev/*"' \
                    '--db-size=+[GiB]:n:' \
                    '--encrypted=+[bool]:b:(0 1)' \
                    '--wal-dev=+[block dev]:file:_files -g "/dev/*"' \
                    '--wal-size=+[GiB]:n:' \
                    '*:device:_files -g "/dev/*"' ;;
                pool) _arguments '1:pool cmd:(create get destroy ls set)' ;;
                osd) _arguments '1:osd cmd:(create destroy out in details ls reweight)' ;;
                mon|mgr|mds) _arguments '1:cmd:(create destroy ls)' ;;
                fs) _arguments '1:fs cmd:(create destroy ls)' ;;
                createpool|destroypool) _arguments \
                    '--add_storages=+[bool]:b:(0 1)' \
                    '--application=+[app]:a:(rbd cephfs rgw)' \
                    '--crush_rule=+[rule]:str:' \
                    '--erasure_coding=+[ec spec]:str:' \
                    '--min_size=+[min size]:n:' \
                    '--pg_autoscale_mode=+[mode]:m:(off on warn)' \
                    '--pg_num=+[N]:n:' \
                    '--size=+[N]:n:' \
                    '*:pool name:' ;;
                purge) _arguments \
                    '--crash[purge crash data]' \
                    '--logs[purge logs]' ;;
            esac
            ;;
    esac
}

_pveceph "$@"
