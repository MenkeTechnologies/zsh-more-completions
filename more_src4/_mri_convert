#compdef mri_convert
# mri_convert — convert between neuroimaging file formats (FreeSurfer)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--in_type[input file type]:input type:(cor mgh mgz minc analyze nifti1 nii dicom)' \
  '--out_type[output file type]:output type:(cor mgh mgz minc analyze nifti1 nii dicom)' \
  '--out_orientation[output orientation]:orientation string:' \
  '-vs[set voxel size (mm)]:x size: :y size: :z size:' \
  '--conform[conform volume to 1mm isotropic 256^3]' \
  '--resample_type[resampling method]:resample type:(interpolate nearest weighted sinc cubic)' \
  '-tr[set TR (ms)]:TR (ms):' \
  '-te[set TE (ms)]:TE (ms):' \
  '-ti[set TI (ms)]:TI (ms):' \
  '--no_scale[do not rescale output values]' \
  '--force_ras_good[force valid RAS coordinates]' \
  '-i[input volume]:input volume:_files -g "*.{nii,nii.gz,mgz,mgh,mnc,img,hdr,dcm}"' \
  '-o[output volume]:output volume:_files -g "*.{nii,nii.gz,mgz,mgh,mnc,img,hdr}"' \
  '1:input volume:_files -g "*.{nii,nii.gz,mgz,mgh,mnc,img,hdr,dcm}"' \
  '2:output volume:_files -g "*.{nii,nii.gz,mgz,mgh,mnc,img,hdr}"'
