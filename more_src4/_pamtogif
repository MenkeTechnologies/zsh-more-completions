#compdef pamtogif
# Documentation: man pamtogif (Netpbm)
# Source: convert a Netpbm PAM/PNM to GIF.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-interlace[write interlaced GIF]' \
    '-sort[sort palette by hue]' \
    '-mapfile=[colormap file]:file:_files' \
    '-transparent=[transparent color (=color or color)]:color:' \
    '-alphacolor=[color treated as transparent via alpha]:color:' \
    '-comment=[add Comment Extension text]:text:' \
    '-noclear[omit Clear codes (smaller, may not decode)]' \
    '-nolzw[do not use LZW (uncompressed GIF)]' \
    '-aspect=[pixel aspect ratio (fraction)]:fraction:' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:netpbm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
