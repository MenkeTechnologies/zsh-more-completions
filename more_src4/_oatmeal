#compdef oatmeal
# Documentation: https://github.com/dustinblackman/oatmeal
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-b --backend)'{-b,--backend=}'[AI backend]:backend:(ollama openai claude gemini langchain)' \
  '(-m --model)'{-m,--model=}'[model name]:model:' \
  '(-c --config-file)'{-c,--config-file=}'[path to configuration file]:file:_files' \
  '(-e --editor)'{-e,--editor=}'[text editor]:editor:(neovim clipboard none)' \
  '(-t --theme)'{-t,--theme=}'[syntax highlighting theme]:theme:' \
  '--theme-file=[custom theme file]:file:_files' \
  '--ollama-url=[Ollama base URL]:url:' \
  '--open-ai-token=[OpenAI API token]:token:' \
  '--claude-token=[Claude API token]:token:' \
  '--gemini-token=[Gemini API token]:token:' \
  '1:command:->commands' && ret=0

case $state in
  commands)
    local -a commands=(
      'chat:start a new chat session'
      'sessions:manage past chat sessions'
      'config:configuration file options'
      'completions:generate shell completions'
      'manpages:generate manpages and output to stdout'
    )
    _describe -t commands 'oatmeal command' commands && ret=0
    ;;
esac

return ret
