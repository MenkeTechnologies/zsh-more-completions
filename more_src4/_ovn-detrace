#compdef ovn-detrace
# _ovn-detrace — OVN ovn-detrace decode OVN trace output and pretty-print Logical_Flow Logical_Datapath Datapath_Binding (ovn-org team, Python); argparse
# upstream: https://github.com/ovn-org/ovn

_ovn-detrace() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-p+[private key file]:file:_files' \
        '--private-key=+[private key file]:file:_files' \
        '-c+[certificate file]:file:_files' \
        '--certificate=+[certificate file]:file:_files' \
        '-C+[ca certificate file]:file:_files' \
        '--ca-cert=+[ca certificate file]:file:_files' \
        '--ovnsb=+[OVN SB database]:str:' \
        '--ovnnb=+[OVN NB database]:str:' \
        '--ovn-runtime-dir=+[runtime dir]:dir:_files -/' \
        '--ovs=+[OVS database]:str:' \
        '*:trace input file:_files'
}

_ovn-detrace "$@"
