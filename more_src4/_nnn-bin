#compdef nnn
# _nnn-bin — nnn n3 power-user file manager (Arun Prakash Jana, C); blazing-fast TUI file manager with plugins
# upstream: https://github.com/jarun/nnn

_nnn-bin() {
    _arguments \
        '-a[auto-create session id]' \
        '-A[disable directory auto-enter]' \
        '-b+[bookmark key]:key:' \
        '-c[cli-only opener]' \
        '-C[force 16-color]' \
        '-d[detail view]' \
        '-D[show directories in context color]' \
        '-e[open text files in editor]' \
        '-E[use EDITOR for [+/-] entry]' \
        '-f[use FREEFILE for unknown types]' \
        '-F[show fortune]' \
        '-g[regex selection]' \
        '-H[show hidden]' \
        '-i[show file info on cursor]' \
        '-J[no autoproceed on selection]' \
        '-K[show keys + exit]' \
        '-l+[lines per col]:n:' \
        '-n[type-to-nav mode]' \
        '-o[open files only on Enter]' \
        '-p+[selection file path]:file:_files' \
        '-P+[run plugin key]:key:' \
        '-Q[skip exit prompt]' \
        '-r[show 8-color]' \
        '-R[disable rollover at top/bottom]' \
        '-s+[load session]:session:' \
        '-S[disk usage in app]' \
        '-t+[timeout seconds]:sec:' \
        '-T+[sort order]:order:(a c d e r s t v)' \
        '-u[use selection in cp/mv]' \
        '-U[show user/group columns]' \
        '-V[show version]' \
        '-w[wild loader]' \
        '-x[notis, sel to system clipboard, X1 button]' \
        '-h[show help]' \
        '*:dir:_files -/'
}

_nnn-bin "$@"
