#compdef ossec-logtest
# Documentation: https://www.ossec.net/docs/docs/programs/ossec-logtest.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# ossec-logtest: test rules/decoders against sample log lines
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-d[debug output (repeatable)]' \
  '-c[config file]:file:_files' \
  '-D[chroot directory]:dir:_files -/' \
  '-a[analyze input lines as live events]' \
  '-t[test configuration]' \
  '-U[require rule-id:alert-level:decoder-name to match]:spec:' \
  '-v[full output of all details and matches]' \
  '*::ossec-logtest args:_files' && ret=0
return ret
