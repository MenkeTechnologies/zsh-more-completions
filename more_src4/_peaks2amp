#compdef peaks2amp
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/peaks2amp.html
# Source: MRtrix3/mrtrix3 cmd/peaks2amp.cpp — convert peak directions image to amplitudes image (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '1:directions (input):_files -g "*.{nii,nii.gz,mif}"' \
    '2:amplitudes (output):_files' \
    && ret=0

return ret
