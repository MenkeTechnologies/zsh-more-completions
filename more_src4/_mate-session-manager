#compdef mate-session mate-session-manager
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/mate-session.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help,-\?}'[show help]' \
  '(- *)--help-all[show all command line options]' \
  '(- *)--version[show version]' \
  '*'{-a,--autostart=}'[autostart dir]:dir:_files -/' \
  '(-f --failsafe)'{-f,--failsafe}'[run in fail-safe mode]' \
  '--debug[enable debugging code]' \
  '--disable-acceleration-check[disable hardware acceleration check]' \
  '--display=[X display]:display:' && ret=0

return ret
