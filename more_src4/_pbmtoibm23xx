#compdef pbmtoibm23xx
# Documentation: man pbmtoibm23xx (Netpbm)
# Source: convert a PBM image to IBM Proprinter 23xx printer commands.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-xres=[horizontal resolution dpi]:dpi:' \
    '-yres=[vertical resolution dpi]:dpi:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:slow flag or pbm file:_files -g "*.(pbm|pnm|pam)"' \
    '*:pbm files:_files -g "*.(pbm|pnm|pam)"' \
    && ret=0

return ret
