#compdef mergechanges
# Documentation: https://manpages.debian.org/mergechanges
# Source: debian/devscripts scripts/mergechanges.sh — merge .changes files for multi-architecture upload (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '--version[show version]' \
    '-d[delete input .changes files after merge]' \
    '(-S --source)'{-S,--source}'[only include source files]' \
    '(-i --indep)'{-i,--indep}'[only include architecture-independent files]' \
    '-f[force; ignore version mismatch]' \
    '*:changes file:_files -g "*.changes"' \
    && ret=0

return ret
