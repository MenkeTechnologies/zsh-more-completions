#compdef nntpget
# Documentation: man nntpget(8)
# Source: InterNetNews/inn backends/nntpget.c — retrieve articles from remote NNTP (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-f -t -u)-f+[since-file: use mtime as start time]:file:_files' \
    '(-f -t -u)-t+[since GMT timestamp (yyyymmdd HHMMSS GMT)]:timestamp:_default' \
    '(-f -t -u)-u+[update mtime of file after success]:file:_files' \
    '-n+[newsgroups (active-style pattern)]:groups:_default' \
    '-o[use IHAVE before TAKETHIS via history]' \
    '-v[verbose]' \
    '1:host:_hosts' \
    && ret=0

return ret
