#compdef openzeppelin
# Documentation: https://www.npmjs.com/package/@openzeppelin/cli
# Reference accessed: 2026-05-23
# Verified: npx openzeppelin --help (@openzeppelin/cli bin alias).

# Zsh completion for openzeppelin - OpenZeppelin SDK CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'accounts:list accounts of selected network'
  'add:add contract to project'
  'balance:query account balance'
  'bump:bump project version'
  'call:call contract method'
  'check:check contracts for issues'
  'compile:compile all contracts'
  'create:deploy upgradeable contract instance'
  'create2:deploy with CREATE2'
  'deploy:deploy contracts'
  'freeze:freeze current version'
  'init:initialize project'
  'link:link library'
  'publish:publish project'
  'push:push project to network'
  'remove:remove contract'
  'send-tx:send transaction'
  'session:manage session'
  'set-admin:set contract admin'
  'transfer:transfer ownership'
  'unlink:unlink library'
  'unpack:unpack project'
  'upgrade:upgrade contract'
  'verify:verify contracts'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
  '(-s --silent)'{-s,--silent}'[silent mode]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'openzeppelin command' commands && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
