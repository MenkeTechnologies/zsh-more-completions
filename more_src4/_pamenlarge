#compdef pamenlarge
# Documentation: man pamenlarge (Netpbm)
# Source: Netpbm pamenlarge — enlarge a Netpbm image N times by duplicating pixels.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-scale=[uniform scale factor]:N:' \
    '-xscale=[X scale factor]:N:' \
    '-yscale=[Y scale factor]:N:' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:Netpbm file (or N then file):_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    && ret=0

return ret
