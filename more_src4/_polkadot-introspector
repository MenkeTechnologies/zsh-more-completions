#compdef polkadot-introspector
# _polkadot-introspector — Paritytech polkadot-introspector tools for monitoring Polkadot relay chain parachain and node performance (paritytech team, Rust); clap-derive
# upstream: https://github.com/paritytech/polkadot-introspector

_polkadot-introspector() {
    local -a sub=(
        'block-time-monitor:track block times'
        'parachain-tracer:track parachain progress'
        'kvdb:dump kvdb'
        'jaeger:run jaeger collector'
        'whois:lookup peer info'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--node=+[node URL]:url:_urls' \
        '-n+[node URL]:url:_urls' \
        '--retry-delay-ms=+[ms]:n:' \
        '--ws-max-payload-bytes=+[bytes]:n:' \
        '--log-level=+[level]:l:(trace debug info warn error)' \
        '--no-color[disable color]' \
        '--prometheus-port=+[port]:port:_ports' \
        '--prometheus-host=+[host]:host:_hosts' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'polkadot-introspector subcommand' sub ;;
        args)
            case $words[1] in
                block-time-monitor) _arguments \
                    '--chart-format=+[format]:f:(svg png ascii)' \
                    '--avg-window=+[seconds]:n:' \
                    '--show-online[show online status]' ;;
                parachain-tracer) _arguments \
                    '--para-id=+[para id]:n:' \
                    '-p+[para id]:n:' \
                    '--show-block-times[show block times]' \
                    '--show-utilization[show utilization]' \
                    '--show-disputes[show disputes]' ;;
                kvdb) _arguments \
                    '--db=+[path]:dir:_files -/' \
                    '--db-type=+[type]:t:(rocksdb paritydb)' ;;
                jaeger) _arguments \
                    '--listen=+[addr]:str:' \
                    '--service-name=+[name]:str:' ;;
                whois) _arguments \
                    '--peer=+[peer id]:str:' \
                    '*:peer:' ;;
            esac
            ;;
    esac
}

_polkadot-introspector "$@"
