#compdef meshlab
# Documentation: https://manpages.debian.org/bookworm/meshlab/meshlab.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: meshlab is a Qt GUI for editing 3D triangular meshes. The
# manpage documents only -h/--help plus positional mesh/project files;
# batch processing is handled by PyMeshLab (separate Python library).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*:mesh/project file:_files -g "*.(mlp|obj|ply|stl|off|3ds|dae|wrl|x3d|xml)(-.)"' && ret=0

return ret
