#compdef offwaketime offwaketime-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/offwaketime.py argparse)
# Reference accessed: 2026-05-29
# offwaketime — sample off-CPU time with waker stacks. Flame-graph-ready folded output. BCC/eBPF.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --pid)'{-p,--pid=}'[trace these PIDs only (CSV; dest=tgid)]:pids:' \
  '(-t --tid)'{-t,--tid=}'[trace these TIDs only (CSV; dest=pid)]:tids:' \
  '(-u --user-threads-only -k --kernel-threads-only)'{-u,--user-threads-only}'[user threads only (no kernel threads)]' \
  '(-u --user-threads-only -k --kernel-threads-only)'{-k,--kernel-threads-only}'[kernel threads only (no user threads)]' \
  '(-U --user-stacks-only -K --kernel-stacks-only)'{-U,--user-stacks-only}'[show stacks from user space only]' \
  '(-U --user-stacks-only -K --kernel-stacks-only)'{-K,--kernel-stacks-only}'[show stacks from kernel space only]' \
  '(-d --delimited)'{-d,--delimited}'[insert delimiter between kernel/user stacks]' \
  '(-f --folded)'{-f,--folded}'[output folded format (for flame graphs)]' \
  '--stack-storage-size=[number of unique stack traces stored (default 16384)]:N:' \
  '(-m --min-block-time)'{-m,--min-block-time=}'[min time in microseconds over which to store traces (default 1)]:us:' \
  '(-M --max-block-time)'{-M,--max-block-time=}'[max time in microseconds under which to store traces (default U64_MAX)]:us:' \
  '--state=[filter on this thread state bitmask (e.g. 2 = TASK_UNINTERRUPTIBLE; see include/linux/sched.h)]:bitmask:' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:duration (seconds, default unlimited):' \
  && ret=0

return ret
