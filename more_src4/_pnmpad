#compdef pnmpad
# Documentation: man pnmpad (Netpbm)
# Source: extend a Netpbm image with padding rows/columns.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-color -detect-background -extend-edge -white -black)-color=[pad color]:color:' \
    '-promote=[depth promotion mode]:mode:(none format all)' \
    '(-color -detect-background -extend-edge -white -black)-detect-background[detect background from image]' \
    '(-color -detect-background -extend-edge -white -black)-extend-edge[repeat edge pixels]' \
    '(-color -detect-background -extend-edge -white -black)-white[pad with white]' \
    '(-color -detect-background -extend-edge -white -black)-black[pad with black]' \
    '-width=[target width pixels]:pixels:' \
    '-halign=[horizontal alignment ratio 0..1]:ratio:' \
    '-mwidth=[minimum width pixels]:pixels:' \
    '-left=[left pad]:pixels:' \
    '-right=[right pad]:pixels:' \
    '-height=[target height pixels]:pixels:' \
    '-valign=[vertical alignment ratio 0..1]:ratio:' \
    '-mheight=[minimum height pixels]:pixels:' \
    '-top=[top pad]:pixels:' \
    '-bottom=[bottom pad]:pixels:' \
    '-reportonly[report resulting dimensions, do not pad]' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
