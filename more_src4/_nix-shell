#compdef nix-shell
# Documentation: https://nix.dev/manual/nix/stable/command-ref/nix-shell
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-p --packages)'{-p,--packages}'[install packages into shell environment]' \
  '(-A --attr)'{-A,--attr}'[select attribute from top-level expression]:attribute:' \
  '--command[run command in interactive shell]:command:' \
  '--run[run command in non-interactive shell then exit]:command:' \
  '--exclude[regex of packages to exclude]:regex:' \
  '--pure[clear environment before entering shell]' \
  '--impure[allow impure environment]' \
  '*--keep[retain environment variable when using --pure]:name:' \
  '-i[interpreter for shebang usage]:interpreter:_files' \
  '(-I --include)'{-I,--include}'[add path to Nix expression search path]:path:_files' \
  '*--option[set a Nix option]:name: :value:' \
  '--arg[pass argument to Nix expression]:name: :value:' \
  '--argstr[pass string argument to Nix expression]:name: :value:' \
  '(-E --expr)'{-E,--expr}'[interpret arguments as Nix expressions]:expr:' \
  '(-j --max-jobs)'{-j,--max-jobs}'[maximum number of parallel build jobs]:jobs:' \
  '--cores[number of CPU cores per build]:cores:' \
  '(-k --keep-going)'{-k,--keep-going}'[keep going on build failure]' \
  '(-K --keep-failed)'{-K,--keep-failed}'[keep build directory on failure]' \
  '--fallback[fall back to building from source]' \
  '--no-build-output' \
  '-Q[suppress build output]' \
  '--show-trace[show Nix expression evaluation trace]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity level]' \
  '--quiet[decrease verbosity level]' \
  '*:Nix expression or package:_files' && ret=0

return ret
