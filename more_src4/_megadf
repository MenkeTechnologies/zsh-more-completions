#compdef megadf
# megadf — show MEGA storage usage

local curcontext="$curcontext" ret=1

_arguments -s -S \
  {-h,--human}'[human-readable sizes]' \
  '--mb[show values in megabytes]' \
  '--gb[show values in gigabytes]' \
  '--total[show only total storage]' \
  '--used[show only used storage]' \
  '--free[show only free storage]' \
  '--config=[load configuration from a file]:config file:_files' \
  '--ignore-config-file[do not load configuration file]' \
  '--debug=[enable debugging output]:debug flags:' \
  '(- *)--version[show version]' \
  '--reload[reload filesystem cache]' \
  '--no-ask-password[never ask interactively for a password]' \
  '--disable-previews[do not generate previews on upload]' && ret=0

return ret
