#compdef opendoor
# Documentation: https://opendoor.readthedocs.io/
# Reference accessed: 2026-05-17
# Verified: stanislav-web/OpenDoor (OWASP web directory scanner) docs.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated scan/crawl/enumerate/bruteforce/report subcommands (real
# OpenDoor has no subcommands — all flag-driven).

# opendoor: OWASP web directory/subdomain scanner
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--host=[target host]:host:_hosts' \
  '--hostlist=[file with hosts]:file:_files' \
  '--stdin[read from stdin]' \
  '--scan=[scan type]:type:(directories subdomains)' \
  '--wordlist=[wordlist]:file:_files' \
  '--extensions=[file extensions]:list:' \
  '--ignore-extensions=[extensions to ignore]:list:' \
  '--include-status=[include HTTP statuses]:list:' \
  '--exclude-status=[exclude HTTP statuses]:list:' \
  '--exclude-size-range=[exclude size range]:range:' \
  '--match-regex=[match regex]:regex:' \
  '--auto-calibrate[auto-calibrate]' \
  '--calibration-samples=[calibration samples]:n:' \
  '--calibration-threshold=[calibration threshold]:n:' \
  '--fingerprint[fingerprint target]' \
  '--waf-detect[detect WAF]' \
  '--waf-safe-mode[WAF-safe mode]' \
  '--header-bypass[bypass via headers]' \
  '--header-bypass-limit=[bypass header limit]:n:' \
  '--transport=[transport]:t:' \
  '--proxy=[proxy URL]:url:' \
  '--transport-profile=[transport profile]:p:' \
  '--session-save=[save session]:file:_files' \
  '--session-load=[load session]:file:_files' \
  '--reports=[report formats]:fmt:' \
  '--reports-dir=[reports dir]:dir:_files -/' \
  '--fail-on-bucket[fail on bucket finding]' && ret=0
return ret
