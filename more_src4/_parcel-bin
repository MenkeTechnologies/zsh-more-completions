#compdef parcel
# _parcel-bin — Parcel zero-config web bundler v2 (Devon Govett); auto-detects entry, supports HMR, Rust-powered transformers
# upstream: https://github.com/parcel-bundler/parcel

_parcel-bin() {
    local -a sub=(
        'serve:run dev server (default)'
        'watch:watch and rebuild'
        'build:production build'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'parcel subcommand' sub ;;
        args)
            _arguments \
                '(-p --port)'{-p,--port}'+[serve port]:port:' \
                '--host+[serve host]:host:_hosts' \
                '--https[serve over HTTPS]' \
                '--cert+[TLS cert]:file:_files' \
                '--key+[TLS key]:file:_files' \
                '--cache-dir+[cache dir]:dir:_files -/' \
                '--no-cache[disable cache]' \
                '--config+[config]:file:_files' \
                '--reporter+[reporter]:name:' \
                '--target:+[target]:name:' \
                '--public-url+[public URL prefix]:url:' \
                '--dist-dir+[output dir]:dir:_files -/' \
                '--detailed-report+[detailed report count]:n:' \
                '--no-source-maps[disable sourcemaps]' \
                '--no-content-hash[disable content hashing]' \
                '--no-scope-hoist[disable scope hoisting]' \
                '--no-optimize[disable optimization]' \
                '--no-autoinstall[disable autoinstall]' \
                '--open[open browser]' \
                '--log-level+[log level]:level:(none error warn info verbose)' \
                '--profile[profile build]' \
                '--watch-for-stdin[exit on stdin close]' \
                '--watch-dir+[watch dir]:dir:_files -/' \
                '--lazy[lazy build (serve)]' \
                '*:entry:_files'
            ;;
    esac
}

_parcel-bin "$@"
