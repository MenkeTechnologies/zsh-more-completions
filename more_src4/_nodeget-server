#compdef nodeget-server
# =============================================================================
# nodeget-server — server component of NodeGet, "the next-generation server
#                  monitoring and management tools" by the NodeSeek
#                  developer community.  Provides a self-hosted monitoring +
#                  management backend that pairs with `nodeget-agent` (the
#                  per-node agent) to deliver server uptime tracking,
#                  resource metrics, JS-runtime task execution, crontab-
#                  style scheduling, token-based agent authentication, and
#                  a Postgres or SQLite-backed state store.  Architectural
#                  workspace split into ~13 crates (ng-config, ng-core,
#                  ng-db, ng-token, ng-kv, ng-task, ng-crontab, ng-js-
#                  runtime, ng-js-worker, ng-static, ng-monitoring, ng-
#                  terminal, ng-infra) — server binary orchestrates these
#                  via the ng-config crate's `palc`-derived argv parsing.
#
# Author:  NodeSeekDev developer community (NodeSeek is a Chinese-language
#          server-renting / VPS-trading community; NodeGet is their
#          successor monitoring suite to traditional Beszel / NetData /
#          Uptime-Kuma deployments)
# Source:  https://github.com/NodeSeekDev/NodeGet
# CLI:     crates/ng-config/src/args_parse/server.rs (uses oxalica/palc)
# Library: oxalica/palc
#          ("Prototype of a command line argument parser with several
#           opposite design goals from clap" — clap-derive-API-compatible
#           drop-in replacement with smaller compile time and binary size)
# License: AGPL-3.0
# Status:  Active — 242+ stars on NodeSeekDev/NodeGet; alpha-stage palc
#          parser (48+ stars on oxalica/palc); production-deployed by
#          NodeSeek community members for fleet monitoring.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — RUST CROSSES TO 34 SOLO LEAD
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents the
# 34TH Rust CLI library variant.  Rust climbs from 33 to 34 documented
# libraries (oxalica/palc via nodeget-server).  New leaderboard: Rust=34
# SOLO LEAD, Go=33, TypeScript-Node=33 (three-way tie at 33 from R504
# broken — Rust now sole top).  Taxonomy now spans 245 cross-language CLI
# library variants across 59 documented languages.
# -----------------------------------------------------------------------------
#
# WHAT IS oxalica/palc AND WHY IS IT A DISTINCT 34TH RUST CLI LIBRARY?
#
# oxalica/palc (https://github.com/oxalica/palc, 48+ stars) is **Oxalica's
# "Prototype of a command line argument parser with several opposite
# design goals from clap"**.  Oxalica is a well-known Rust + Nix
# developer best known for `oxalica/rust-overlay` (the canonical
# Nixpkgs overlay for Rust toolchains — used by tens of thousands of
# Nix users).  palc is Oxalica's attempt to demonstrate that a
# **drop-in clap-derive replacement can ship with materially smaller
# binary size and faster compile times** while remaining compatible
# enough to swap on a per-project basis without rewriting CLI surfaces.
#
# palc is DISTINCT from every documented Rust CLI library on FIVE
# specific axes:
#
#   1. clap-derive-API-COMPATIBLE DROP-IN REPLACEMENT — palc REUSES the
#      EXACT SAME ATTRIBUTE GRAMMAR as clap 4.x derive:
#         use palc::{Parser, Subcommand, ValueEnum};
#         #[derive(Parser, Debug, Clone)]
#         #[command(version, long_about = "...", after_long_help = "...")]
#         pub struct ServerArgs {
#             #[command(subcommand)]
#             pub command: ServerCommand,
#         }
#         #[derive(Subcommand, Debug, Clone, Eq, PartialEq)]
#         pub enum ServerCommand {
#             /// Start server normally.
#             Serve { #[arg(long, short)] config: String, },
#             /// Initialize database and super token, then exit.
#             Init  { #[arg(long, short)] config: String, },
#             // ...
#         }
#         let args = ServerArgs::parse();
#      The derive macros, attribute syntax, doc-comment-as-help mapping,
#      and `parse()` / `try_parse_from()` runtime API are deliberately
#      identical to clap.  Switching a project from clap-derive to palc
#      is documented as "change `Cargo.toml` dependency line and the
#      `use clap::` statements to `use palc::`".  Compare:
#        clap-derive (R??):     proc-macro derive, full feature set
#        structopt (R??):       precursor of clap-derive, same idea
#        argh (Google):         smaller code-size derive
#        gumdrop (R??):         minimalist derive
#        palc (THIS):           clap-derive-COMPATIBLE drop-in with
#                                deliberately opposite design goals.
#      **First documented Rust CLI library to position itself as a
#      drop-in BINARY-COMPATIBILITY replacement for clap-derive while
#      pursuing different non-functional trade-offs.**
#
#   2. OPPOSITE DESIGN GOALS: COMPILE-TIME + BINARY-SIZE OPTIMIZATION —
#      palc's stated design intent (from README) is **"un-opinionated"**
#      with focus on the dimensions where clap is most criticized:
#        ┌──────────────────┬─────────────────┬─────────────────┐
#        │ Dimension        │ clap 4.x        │ palc            │
#        ├──────────────────┼─────────────────┼─────────────────┤
#        │ Compile time     │ ~3-15s for full │ "Speedy"        │
#        │                  │ feature set     │ (no figures yet)│
#        │ Binary size      │ +120-300 KiB    │ Smaller         │
#        │ Dep tree         │ ~25 crates      │ Minimal         │
#        │ Non-UTF-8 (OsStr)│ Partial support │ First-class     │
#        │ API surface      │ Extensive       │ Subset, growing │
#        └──────────────────┴─────────────────┴─────────────────┘
#      The "opposite design goals" framing reflects a long-standing
#      Rust community discussion about clap's compile-time / binary-size
#      cost.  palc is an EXPLICIT attempt to demonstrate that the
#      clap-derive API can be implemented with materially different
#      trade-offs.  Compare:
#        argh (Google):         smaller binary via Code-size optimization
#                                — but uses its OWN derive grammar, not
#                                clap's, so adoption requires CLI rewrite.
#        gumdrop:               smaller binary, own derive grammar.
#        palc:                  smaller binary + same derive grammar as
#                                clap — switching is one-line change.
#      **First documented Rust CLI library to combine COMPILE-TIME
#      OPTIMIZATION with BINARY-COMPATIBILITY-WITH-CLAP-DERIVE as
#      explicit dual design goals.**
#
#   3. OSSTR-FIRST NON-UTF-8 ARGUMENT HANDLING — palc treats
#      `OsStr`/`OsString` as the **PRIMARY argument value type**, with
#      UTF-8 `String` as a derived convenience.  Magic argument types
#      supported in derive structs:
#         T where T: TryFrom<&OsStr> || TryFrom<&str> || FromStr
#         bool                                 (named)
#         Option<T>                            (named)
#         Option<Option<T>>                    (named — optional value)
#         Vec<T>                               (named & positional)
#         Option<Vec<T>>                       (named & positional)
#      The `TryFrom<&OsStr>` path is preferred when implementable;
#      `FromStr` is the UTF-8 fallback.  Compare:
#        clap 4.x:              `OsString` is a special-case via
#                                `OsString` field type, with separate
#                                code paths
#        argh:                  String-only, no OsStr support
#        gumdrop:               String-only
#        palc:                  OsStr is the type system's PRIMARY
#                                citizen; String is the special case.
#      Relevant on Windows (where filenames may not be valid UTF-8)
#      and on Linux/macOS for arguments that are filename paths with
#      arbitrary byte sequences.
#
#   4. EXPLICIT "YET IMPLEMENTED FEATURES" LIST IN README — palc's
#      README contains a 70+ item checklist documenting which clap
#      features are implemented (mostly checked) vs not yet (mostly
#      unchecked).  This is a UNIQUELY HONEST documentation style:
#         - [x] Boolean flags `--verbose`.
#         - [x] Named arguments `--long value`, `-svalue`
#           - [x] Bundled short arguments `-czf`
#           - [x] '='-separator `--long=v` `-f=v`.
#           - [x] Aliases.
#           - [x] Reject hyphen values.
#           - [x] Allow hyphen values.
#           - [ ] Space-delimited multi-values.
#           - [x] Custom-delimited multi-values.
#           - [ ] Multi-values with value-terminator.
#         - [x] Positional/unnamed/free arguments `FILE`.
#           - [x] Force no named arguments `--`.
#           - [x] Greedy/tail arguments (`arg(trailing_var_arg)`).
#           - [x] Last arguments after `--` (`arg(last)`).
#           - [ ] Allow hyphen values.
#         - [ ] Counting number of occurrence (`ArgAction::Count`).
#         - [ ] Custom ArgAction.
#         - [ ] Custom number of values (`arg(num_args)`).
#         ...
#      The README *quantifies* the API gap relative to clap, making it
#      trivial for users to evaluate whether palc covers their use case.
#      Compare clap (huge feature set, no explicit "what we have")
#      and argh (Google's design doc rationalization).  **First Rust
#      CLI library with a feature-checkbox README documenting its
#      explicit clap-compatibility subset.**
#
#   5. RUSTFLAG-PROFILED CODEGEN — palc's derived code is **optimized
#      for minimal generated-code surface** rather than maximal
#      ergonomics.  The proc-macro emits minimal-allocations argument
#      iteration that produces small unwind tables and minimal panic
#      paths.  Notable in palc's design:
#        - `arg(default_value)`:  uses runtime string-parse with panic
#          handling for type conversion (causes "codegen degradation
#          due to panic handling, and typos cannot be caught
#          statically" — README explicitly recommends `default_value_t`
#          for static typo detection).
#        - `arg(default_value_t)`: emits CONSTANT-EVALUATED default,
#          avoids runtime parse.
#      Compare:
#        clap-derive:           uses `default_value` and produces
#                                similar codegen
#        argh:                  uses const eval where possible.
#        palc:                  EXPLICITLY DOCUMENTS the codegen
#                                trade-off and recommends the
#                                cheap-codegen variant.
#      This is the level of attention to compile-time / generated-code
#      detail that distinguishes palc as a "compile-cost-aware fork"
#      of the clap-derive idea.
#
# THE oxalica/palc API SURFACE (verbatim from upstream)
#
#   // Cargo.toml: palc = "0.1.0-alpha.5"
#   use palc::{Parser, Subcommand, ValueEnum};
#   #[derive(Parser, Debug, Clone)]
#   #[command(version, long_about = "...", after_long_help = "...")]
#   pub struct ServerArgs {
#       #[command(subcommand)] pub command: ServerCommand,
#   }
#   #[derive(Subcommand, Debug, Clone, Eq, PartialEq)]
#   pub enum ServerCommand {
#       /// Start server normally.
#       Serve { #[arg(long, short)] config: String },
#       /// Initialize database and super token, then exit.
#       Init  { #[arg(long, short)] config: String },
#   }
#   let args = ServerArgs::parse();
#
# Derive macros provided by palc (clap-API-COMPATIBLE):
#   - Parser            : struct-level — entry-point derive
#   - Subcommand        : enum-level — subcommand dispatch
#   - Args              : struct-level — args composition (subset)
#   - ValueEnum         : enum-level — enum-valued arguments
#
# Attributes (subset of clap 4.x):
#   #[command(version)]            #[command(long_about = "...")]
#   #[command(after_long_help)]    #[command(subcommand)]
#   #[arg(long, short)]            #[arg(default_value_t = ...)]
#   #[arg(default_value = "...")]  #[arg(trailing_var_arg)]
#   #[arg(last)]                   #[arg(value_enum)]
#
# Runtime API (clap-COMPATIBLE):
#   ServerArgs::parse()                    // panics on error, like clap
#   ServerArgs::try_parse_from(vec)        // result-returning variant
#
# CONTRAST WITH OTHER RUST CLI LIBRARIES DOCUMENTED IN THE CORPUS
#
#   * clap / clap-derive          — proc-macro derive, full feature set
#   * structopt                   — predecessor of clap-derive
#   * argh (Google)               — derive parser optimized for code size,
#                                    own grammar (NOT clap-compatible)
#   * gumdrop                     — derive parser, minimalist, own grammar
#   * pico-args                   — hand-rolled minimal parser
#   * lexopt                      — argument-iterator pattern
#   * bpaf                        — applicative-functor combinators
#   * xflags (matklad)            — proc-macro minimal parser
#   * argparse (tailhook)         — Python-argparse-style runtime API
#   * seahorse                    — fluent builder
#   * docopt.rs                   — USAGE-string-is-spec
#   * paw                         — argument-wrapping trait pattern
#   * getopts                     — getopt(3) port
#   * argfile (R498)              — pre-parser argv preprocessor
#   * argv                        — argument iteration helpers
#   * abscissa (R502)             — application microframework
#   * redox-os/arg-parser         — Redox OS native parser
#   * palc (THIS)                 — clap-derive-API-compatible drop-in
#                                    with opposite design goals:
#                                    compile-time + binary-size + OsStr-
#                                    first + explicit clap-subset
#                                    checklist + codegen-aware defaults
#
# palc occupies a UNIQUE NICHE — it is the **first Rust CLI library that
# DELIBERATELY MAINTAINS CLAP API COMPATIBILITY as a primary design goal**.
# argh, gumdrop, bpaf, and others all offer their own grammars.  palc is
# the first to say "use the clap derive grammar but pay less in compile
# time and binary size."
#
# REAL-WORLD palc USERS (early-adopter community):
#
#   * NodeSeekDev/NodeGet (THIS, 242*) — server monitoring + management
#       suite from NodeSeek community; uses palc in both nodeget-server
#       and nodeget-agent binaries via the ng-config workspace crate
#   * GenshinMinecraft/komari-monitor-rs (120*) — Komari Monitor Agent
#       in Rust (server-status agent), uses palc for argv parsing
#   * SaltyKitkat/xsz (17*) — `compsize` rewrite-in-Rust with multi-
#       thread support (btrfs compression size reporter)
#   * lxl66566/aos_up — aos archive format unpacker / packer
#   * zooeywm/zloxer — Lox interpreter (from Crafting Interpreters)
#   * mokurin000/res-dedup — resource deduplication tool
#
# Adoption pattern: palc is being adopted by **small-to-mid Rust CLI
# projects where compile-time matters** (Komari Monitor Agent, NodeGet
# Agent, system-level tooling like xsz).  Large projects (ruff, uv, bat,
# eza, ripgrep, fd) still use clap because palc is alpha and subset.
# The taxonomy entry recognizes palc as a distinct *prototype variant*
# pushing Rust's CLI library design space.
#
# -----------------------------------------------------------------------------
# NODEGET-SERVER'S CLI SURFACE (verbatim from crates/ng-config/.../server.rs)
# -----------------------------------------------------------------------------
#
# USAGE:
#   nodeget-server [SUBCOMMAND] [OPTIONS]
#
# Subcommands:
#   serve              Start server normally (the default operational
#                      mode — binds to HTTP + WS, registers agents,
#                      schedules crons, executes JS tasks).
#                      Required:  -c, --config <PATH>
#
#   init               Initialize database and super token, then exit.
#                      Run ONCE on first deployment to set up the
#                      Postgres/SQLite schema, generate the initial
#                      super-admin token (printed to stdout), and seed
#                      the server's UUID.
#                      Required:  -c, --config <PATH>
#
#   roll-super-token   Rotate the super token (token-id = 1) after
#                      interactive confirmation, then exit.  Use when
#                      the initial super token has been leaked or for
#                      regular key-rotation hygiene.  Prints the new
#                      token to stdout once.
#                      Required:  -c, --config <PATH>
#
#   get-uuid           Print the server UUID from config and exit.
#                      Useful for scripting agent enrollment.
#                      Required:  -c, --config <PATH>
#
#   version            Get version JSON (machine-readable; emits
#                      {"version":"x.y.z","git":"..."} on stdout).
#
# Subcommand-shared options:
#   -c, --config <PATH>           Path to the server configuration TOML
#                                  (used by serve / init / roll-super-token
#                                  / get-uuid; not used by version).
#
# Built-in palc flags (always reserved):
#   -h, --help                    Show context-sensitive help
#       --version                 Show version (palc built-in)
#
# Typical usage:
#   $ nodeget-server init --config /etc/nodeget/server.toml
#     → prints super-admin token; record it
#
#   $ nodeget-server serve -c /etc/nodeget/server.toml
#     → starts server; daemonize as needed via systemd
#
#   $ nodeget-server get-uuid -c /etc/nodeget/server.toml
#     → prints server UUID; use to register agents
#
#   $ nodeget-server roll-super-token -c /etc/nodeget/server.toml
#     → prompts for confirmation; rotates token-id=1
#
#   $ nodeget-server version
#     → {"version":"0.5.1","git":"..."}
#
# Companion binary:
#   nodeget-agent — the per-node agent that reports system metrics to
#   nodeget-server.  Different binary (also uses palc) — has a flat
#   options surface: --config / --version / --dry-run.
#
# =============================================================================

_nodeget-server() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a subcommands

    subcommands=(
        'serve:start server normally'
        'init:initialize database and super token, then exit'
        'roll-super-token:rotate super token (id=1) after confirmation'
        'get-uuid:print server UUID from config and exit'
        'version:get version JSON'
    )

    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        (cmd)
            _describe -t commands 'nodeget-server command' subcommands && ret=0
            ;;
        (args)
            case $line[1] in
                (serve|init|roll-super-token|get-uuid)
                    _arguments \
                        '(-c --config)'{-c,--config}'[path to configuration file]:config:_files -g "*.toml"' \
                        '(-h --help)'{-h,--help}'[show help]' \
                        && ret=0
                    ;;
                (version)
                    _arguments \
                        '(-h --help)'{-h,--help}'[show help]' \
                        && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_nodeget-server "$@"
