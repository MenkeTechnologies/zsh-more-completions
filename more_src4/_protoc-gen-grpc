#compdef protoc-gen-grpc protoc-gen-go-grpc protoc-gen-grpc-go
# _protoc-gen-grpc — protoc gRPC Go code generator plugin CLI alias (gRPC team / Google, Go); flag
# upstream: https://github.com/grpc/grpc-go

_protoc-gen-grpc() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--require_unimplemented_servers=+[require unimplemented servers]:b:(true false)' \
        '--use_generic_streams_experimental=+[use generic streams]:b:(true false)' \
        '--paths=+[paths]:p:(source_relative import)' \
        '--module=+[module path]:str:' \
        '*:proto:_files -g "*.proto"'
}

_protoc-gen-grpc "$@"
