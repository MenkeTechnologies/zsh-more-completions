#compdef mhbuild
# Documentation: man mhbuild(1)
# Source: nmh uip/mhbuild.c (master) — build a MIME message from a draft (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-auto -noauto)-auto[auto-build composition]' \
    '(-auto -noauto)-noauto[manual build]' \
    '(-check -nocheck)-check[check construction]' \
    '(-check -nocheck)-nocheck[no check]' \
    '(-directives -nodirectives)-directives[honor directives]' \
    '(-directives -nodirectives)-nodirectives[ignore directives]' \
    '(-headers -noheaders)-headers[include headers]' \
    '(-headers -noheaders)-noheaders[skip headers]' \
    '(-list -nolist)-list[list parts]' \
    '(-list -nolist)-nolist[do not list]' \
    '(-realsize -norealsize)-realsize[show real size]' \
    '(-realsize -norealsize)-norealsize[no real size]' \
    '(-rfc934mode -norfc934mode)-rfc934mode[encapsulate per RFC 934]' \
    '(-rfc934mode -norfc934mode)-norfc934mode[no RFC 934]' \
    '(-verbose -noverbose)-verbose[verbose]' \
    '(-verbose -noverbose)-noverbose[no verbose]' \
    '(-disposition -nodisposition)-disposition[add Content-Disposition]' \
    '(-disposition -nodisposition)-nodisposition[skip Content-Disposition]' \
    '-rcache+[read cache policy]:policy:(public private never ask)' \
    '-wcache+[write cache policy]:policy:(public private never ask)' \
    '(-contentid -nocontentid)-contentid[add Content-ID]' \
    '(-contentid -nocontentid)-nocontentid[no Content-ID]' \
    '-headerencoding+[header encoding]:encoding:(quoted-printable base64 8bit none)' \
    '-autoheaderencoding[auto-detect header encoding]' \
    '-maxunencoded+[max unencoded length]:N:_default' \
    '-version[show version]' \
    '-help[show help]' \
    '-debug[debug output]' \
    '-dist[dist mode]' \
    '*:file:_files' \
    && ret=0

return ret
