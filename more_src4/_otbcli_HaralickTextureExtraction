#compdef otbcli_HaralickTextureExtraction
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_HaralickTextureExtraction.html
# Source: orfeotoolbox/OTB HaralickTextureExtraction — GLCM-based texture feature extractor.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-in+[input image]:image:_files' \
    '-channel+[channel index to process (default 1)]:n:_default' \
    '-step+[pixel step for texture computation (default 1)]:n:_default' \
    '-out+[output image with texture features]:image:_files' \
    '-parameters.xrad+[horizontal neighborhood radius (default 2)]:n:_default' \
    '-parameters.yrad+[vertical neighborhood radius (default 2)]:n:_default' \
    '-parameters.xoff+[horizontal offset (default 1)]:n:_default' \
    '-parameters.yoff+[vertical offset (default 1)]:n:_default' \
    '-parameters.min+[image minimum value (default 0)]:value:_default' \
    '-parameters.max+[image maximum value (default 255)]:value:_default' \
    '-parameters.nbbin+[histogram bin count (default 8)]:n:_default' \
    '-texture+[texture set]:set:(simple advanced higher)' \
    '-ram+[available RAM (MB, default 256)]:mb:_default' \
    '-progress[show progress]' \
    '(- *)-help[show help]' \
    && ret=0

return ret
