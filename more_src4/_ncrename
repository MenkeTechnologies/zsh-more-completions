#compdef ncrename
# Documentation: https://nco.sourceforge.net/nco.html#ncrename
# Source: nco/nco src/nco/ncrename.c — netCDF variable/dimension/attribute/group renamer.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-a+[rename attribute (old_name,new_name)]:rename_spec:_default' \
    '*-d+[rename dimension (old_name,new_name)]:rename_spec:_default' \
    '*-g+[rename group (old_name,new_name)]:rename_spec:_default' \
    '*-v+[rename variable (old_name,new_name)]:rename_spec:_default' \
    '-D+[debug level]:lvl:_default' \
    '-H[toggle printing data]' \
    '-h[do not append to history attribute]' \
    '-i[interactive, prompt before overwriting]' \
    '-O[overwrite existing output file]' \
    '-o+[output file]:file:_files' \
    '-R[retain remotely-retrieved files after use]' \
    '-r[print version info]' \
    '--hdr_pad=[header padding]:bytes:_default' \
    '--gaa=[global attribute append]:spec:_default' \
    '--gad=[global attribute delete]:names:_default' \
    '--ram_all[buffer entire file in RAM before write]' \
    '*:netcdf file:_files -g "*.(nc|nc4|cdf|hdf|h5)(-.)"' \
    && ret=0

return ret
