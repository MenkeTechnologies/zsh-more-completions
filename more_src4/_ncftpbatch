#compdef ncftpbatch
# Documentation: https://www.ncftp.com/ncftp/doc/ncftpbatch.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-d[begin background processing of FTP jobs in spool dir]' \
  '-D[same as -d but does not become a background daemon]' \
  '-l[list contents of the job queue]' && ret=0

return ret
