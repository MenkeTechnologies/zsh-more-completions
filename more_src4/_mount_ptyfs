#compdef mount_ptyfs
# Documentation: man mount_ptyfs(8)
# Source: netbsd/src sbin/mount_ptyfs — mount the pseudo-terminal file system (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-g+[group ownership of slave pseudo-tty]:group or gid:_groups' \
    '-m+[default mode of slave pseudo-tty]:mode:_default' \
    '-o+[mount options (group and mode supported)]:options:_default' \
    '1:filesystem type (ptyfs):_default' \
    '2:mount point:_files -/' \
    && ret=0

return ret
