#compdef pylama
# Documentation: https://klen.github.io/pylama/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
  '(-f --format)'{-f+,--format=}'[output format]:format:(pydocstyle pycodestyle pylint parsable json)' \
  '(-l --linters)'{-l+,--linters=}'[select linters (comma-separated)]:linters:_values -s , linter eradicate mccabe mypy pycodestyle pydocstyle pyflakes pylint isort' \
  '(-i --ignore)'{-i+,--ignore=}'[ignore errors and warnings]:codes' \
  '(-s --select)'{-s+,--select=}'[select errors and warnings]:codes' \
  '--sort=[sort results by error types, e.g. E,W,D]:order' \
  '(-o --options)'{-o+,--options=}'[set configuration file]:config:_files' \
  '--skip=[skip files by masks]:patterns' \
  '(-m --max-line-length)'{-m+,--max-line-length=}'[max line length]:length' \
  '--concurrent[async mode]' \
  '--async[async mode]' \
  '(-a --abspath)'{-a,--abspath}'[show absolute paths]' \
  '--from-stdin[read from stdin]' \
  '(-r --report)'{-r+,--report=}'[send report to file]:file:_files' \
  '--hook[install Git/Mercurial hook]' \
  '--max-complexity=[complexity threshold]:n' \
  '--pydocstyle-convention=[documentation convention]:c:(pep257 numpy google)' \
  '--pylint-confidence=[pylint confidence level]:c:(HIGH INFERENCE INFERENCE_FAILURE UNDEFINED)' \
  '*:path:_files' && return 0
