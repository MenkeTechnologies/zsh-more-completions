#compdef patroni-cli patroni
# _patroni-cli — Zalando Patroni patroni-cli CLI command-line frontend wrapping the Patroni high-availability PostgreSQL DCS-based ETCD Consul ZooKeeper Kubernetes-API failover-leader-election automatic-replica-promotion synchronous-replication standby-cluster pg_rewind initdb bootstrap pg_basebackup-pgupgrade-restore (Zalando team, Python); argparse
# upstream: https://patroni.readthedocs.io/

_patroni-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--validate-config[validate config]' \
        '--ignore-listen-port-conflict[ignore listen port conflict]' \
        '--scope=+[name]:str:' \
        '--name=+[name]:str:' \
        '--listen=+[host:port]:str:' \
        '--connect-address=+[host:port]:str:' \
        '--data-dir=+[dir]:dir:_files -/' \
        '--config-dir=+[dir]:dir:_files -/' \
        '--restapi-port=+[port]:n:' \
        '--restapi-listen=+[host:port]:str:' \
        '--etcd-host=+[host]:_hosts' \
        '--etcd-port=+[port]:n:' \
        '--etcd-protocol=+[p]:p:(http https)' \
        '--etcd-prefix=+[prefix]:str:' \
        '--zookeeper-host=+[host]:_hosts' \
        '--zookeeper-port=+[port]:n:' \
        '--consul-host=+[host]:_hosts' \
        '--consul-port=+[port]:n:' \
        '--consul-scheme=+[s]:s:(http https)' \
        '--consul-token=+[token]:str:' \
        '--postgres-listen=+[host:port]:str:' \
        '--postgres-data-dir=+[dir]:dir:_files -/' \
        '*:config file:_files -g "*.yml *.yaml"'
}

_patroni-cli "$@"
