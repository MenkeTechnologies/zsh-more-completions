#compdef mintlify-cli mintlify mint
# _mintlify-cli — Mintlify modern documentation platform CLI alias (mintlify team, TypeScript); commander
# upstream: https://github.com/mintlify/mint

_mintlify-cli() {
    local -a sub=(
        'dev:start dev server'
        'broken-links:check broken links'
        'install:install dependencies'
        'init:initialize new mint project'
        'rename:rename file'
        'update:update mintlify cli'
        'help:show help'
        'version:show version'
        'login:login to mintlify'
        'logout:logout'
        'whoami:show current user'
        'deploy:trigger deploy'
        'preview:preview deployment'
        'sites:list:list sites'
        'metadata:check:check metadata'
        'validate:validate docs.json'
        'feedback:submit feedback'
        'openapi-check:check openapi spec'
        'analytics:show analytics'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mintlify subcommand' sub ;;
        args)
            case $words[1] in
                dev) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--no-open[no auto-open]' \
                    '--debug[debug]' ;;
                broken-links) _arguments \
                    '--debug[debug]' ;;
                rename) _arguments \
                    '1:old name:_files' \
                    '2:new name:_files' \
                    '--debug[debug]' ;;
                openapi-check) _arguments \
                    '1:openapi spec:_files -g "*.{json,yaml,yml}"' ;;
            esac
            ;;
    esac
}

_mintlify-cli "$@"
