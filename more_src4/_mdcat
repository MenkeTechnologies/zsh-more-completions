#compdef mdcat
# Documentation: https://github.com/swsnr/mdcat/blob/main/mdcat.1.adoc
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-p --paginate -P --no-pager)'{-p,--paginate}'[paginate the output with a pager]' \
  '(-p --paginate -P --no-pager)'{-P,--no-pager}'[do not paginate output]' \
  '(-c --no-colour)'{-c,--no-colour}'[disable all colours and other styles]' \
  '--ansi[skip terminal detection and use ANSI formatting]' \
  '--columns=[maximum number of columns to use]:columns:' \
  '(-l --local)'{-l,--local}'[do not access remote resources]' \
  '--fail[fail immediately on first unreadable file]' \
  '--detect-terminal[detect terminal program, print name, and exit]' \
  '--completions=[generate shell completions]:shell:(bash zsh fish powershell elvish)' \
  '*:markdown file:_files -g "*.(md|markdown|mkd|mdown)"' && ret=0

return ret
