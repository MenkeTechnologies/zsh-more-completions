#compdef pwgen-cli
# _pwgen-cli — Theodore Ts'o pwgen password generator CLI alias (tytso team, C); custom argparse
# upstream: https://github.com/tytso/pwgen

_pwgen-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c[include capitals]' \
        '--capitalize[include capitals]' \
        '-A[no capitals]' \
        '--no-capitalize[no capitals]' \
        '-n[include at least one number]' \
        '--numerals[include at least one number]' \
        '-0[no numerals]' \
        '--no-numerals[no numerals]' \
        '-y[include symbol]' \
        '--symbols[include symbol]' \
        '-s[secure random]' \
        '--secure[secure random]' \
        '-B[no ambiguous chars]' \
        '--ambiguous[no ambiguous chars]' \
        '-H+[sha1 hash file]:file:_files' \
        '--sha1=+[sha1 hash file]:file:_files' \
        '-C[print in columns]' \
        '-1[one password per line]' \
        '-N+[number to generate]:n:' \
        '--num-passwords=+[number to generate]:n:' \
        '-v[do not include any vowels]' \
        '--no-vowels[do not include any vowels]' \
        '-r+[remove these chars]:str:' \
        '--remove-chars=+[remove these chars]:str:' \
        '*:length number:'
}

_pwgen-cli "$@"
