#compdef ntp-wait
# _ntp-wait — ntp-project ntp-wait (Perl helper that polls the local ntpd until it has synchronized to an upstream server; useful in boot scripts that depend on a stepped clock)
# upstream: https://github.com/ntp-project/ntp
# Flags from scripts/ntp-wait/ntp-wait-opts.def on tip (AutoOpts).

_ntp-wait() {
    _arguments \
        '(- *)'{-?,--help}'[show help]' \
        '(- *)--version[show version and exit]' \
        '(-n --tries)'{-n+,--tries=}'[number of tries before giving up]:n:' \
        '(-s --sleep)'{-s+,--sleep=}'[sleep seconds between tries]:sec:' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
}

_ntp-wait "$@"
