#compdef mylg
# =============================================================================
# mylg — myLG (My Looking Glass): network diagnostic tool combining ping,
#        traceroute, BGP looking glass, dig, hping, whois, port scanning, LAN
#        discovery, packet dump, speedtest, and peering DB lookup in one
#        interactive REPL with tab completion and vi/emacs editing modes.
#
# Author:  Mehrdad Arshad Rad (mehrdadrad)
# Source:  https://github.com/mehrdadrad/mylg
# CLI:     mylg.go (entry point) + cli/cli.go (REPL via chzyer/readline)
# Library: github.com/chzyer/readline  (pure Go GNU-Readline implementation,
#                                       PrefixCompleter, NewEx config)
# License: MIT
# Status:  Stable (v0.2.7) — 2,718+ stars, widely used at NANOG / OARC events
#          for on-the-fly network troubleshooting from a unified shell.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY — myLG documents the FIRST chzyer/readline
# interactive REPL driver in the cross-language CLI library taxonomy.  As of
# this completion the taxonomy spans 41 documented languages and 194 CLI
# library variants total. myLG is documented as the 23rd Go CLI library variant
# (restoring the three-way tie at the top: Rust=23 / Go=23 / TypeScript-Node=23).
# -----------------------------------------------------------------------------
#
# WHY chzyer/readline IS DISTINCT FROM EVERY OTHER GO CLI LIBRARY DOCUMENTED
#
#   chzyer/readline is NOT a flag parser at all — it is an interactive line
#   editor library that provides the SAME SET OF FEATURES as GNU Readline
#   (history, completion, vi/emacs editing modes, multiline input, masked
#   password input, bracketed paste) but implemented in PURE GO with NO CGO
#   dependency on the actual GNU Readline C library.  This means chzyer/readline
#   binaries cross-compile cleanly to any Go target including Windows where
#   GNU Readline is not natively available.
#
#   The other Go CLI libraries documented in the corpus all answer the question
#   "how do I parse argv into structured flags and values?":
#     * flag (stdlib)                     — flat -flag value parser
#     * spf13/cobra                       — subcommand tree + flag wiring
#     * spf13/pflag                       — POSIX --long-flag for flag stdlib
#     * urfave/cli (v1, v2)               — subcommand+flag with config files
#     * alecthomas/kingpin                — fluent DSL like Python click
#     * jessevdk/go-flags                 — struct tag parser like Rust clap
#     * mitchellh/cli                     — Hashicorp's interface-based dispatcher
#     * akamensky/argparse                — Python argparse clone
#     * urfave/negroni                    — middleware (not a CLI library proper)
#     * google/subcommands                — flag-tree wrapper
#     * tj/docopt.go                      — docopt for Go
#     * pborman/getopt                    — getopt(3) port
#     * docopt-go                         — docopt language
#     * cmdr-go                           — getopt-style with builders
#     * teris-io/cli                      — micro-DSL command builder
#     * bytecode/clap-rs-equivalent (n/a) — see Rust column for clap analogue
#     * containerd/cli                    — Hashicorp-style flag dispatcher
#     * muesli/coral                      — fork of cobra
#     * gosuri/uitable                    — output formatting (not arg parsing)
#     * urfave/cli/v3                     — major rewrite distinct from v1/v2
#     * c-bata/go-prompt                  — interactive prompt (R451)
#
#   chzyer/readline answers a COMPLETELY DIFFERENT QUESTION: "how do I build an
#   interactive REPL with tab completion, history, and editing keybindings
#   when my CLI is fundamentally a long-running interactive shell rather than
#   a one-shot argv-parsing transformer?"  Network looking glass tools
#   (mylg, mtr-like tools), database shells (treesql, ego), language REPLs
#   (starlark-go, wenerme/pie), debug consoles (juun, abperiasamy/pinata) all
#   share this REPL-first interaction model where argv parsing is incidental.
#
# CHZYER/READLINE'S CORE API SURFACE (from cli/cli.go in mylg)
#
#   readline.NewEx(&readline.Config{
#       Prompt:          "local> ",
#       HistoryFile:     "/tmp/.mylg.history",
#       InterruptPrompt: "^C",
#       EOFPrompt:       "exit",
#       AutoComplete:    completer,
#   })
#
#   readline.NewPrefixCompleter(pcItems...)  — hierarchical completion tree
#   readline.PcItem("ping", readline.PcItem("ipv4"), readline.PcItem("ipv6"))
#                                            — nested completion items
#   readline.PrefixCompleterInterface         — interface for custom completers
#   instance.Readline()                        — blocking read of one line
#   instance.SetPrompt(prompt string)          — runtime prompt change
#   instance.Close()                           — restore terminal mode
#
#   vi/emacs mode is enabled by Config.VimMode bool field; when true the editor
#   accepts hjkl/dw/cc-style commands. emacs mode (default) accepts standard
#   Ctrl-A/Ctrl-E/Ctrl-K bindings shared with bash and GNU Readline.
#
# WHY MYLG CHOSE CHZYER/READLINE OVER ALTERNATIVES (REPL LIBRARY LANDSCAPE)
#
#   Other Go REPL libraries that mylg could have chosen instead:
#     * c-bata/go-prompt    — heavy completion UI with floating boxes; mylg
#                             wanted classic GNU Readline aesthetic instead
#     * peterh/liner        — older simpler GNU Readline port (no vi mode)
#     * golang/term         — stdlib terminal control (no completion/history)
#     * google/goterm       — too low-level (raw terminal escape sequences)
#     * jroimartin/gocui    — full-screen TUI library (overkill for REPL)
#     * gdamore/tcell       — full-screen TUI library (overkill for REPL)
#
#   chzyer/readline strikes the balance: classic GNU Readline behavior (matching
#   what network engineers expect from Cisco/Juniper CLI shells and bash) with
#   modern Go ergonomics (struct config, channel-friendly Readline() loop, no
#   CGO dependency, cross-platform terminal handling via golang.org/x/term).
#
# HISTORICAL POSITIONING
#
#   chzyer/readline first appeared in 2015 written by Chen Yang (chzyer) as a
#   pure Go alternative to GNU Readline.  The library predates the modern Go
#   modules ecosystem and was originally vendored.  By 2017 it had become THE
#   standard interactive REPL library across the Go ecosystem, used by:
#
#     * cockroachdb/cockroach  — interactive SQL shell
#     * google/starlark-go     — Starlark language REPL
#     * google/cel-go          — CEL expression evaluator REPL
#     * spf13/viper            — debug REPL
#     * mehrdadrad/mylg        — network diagnostic REPL (this completion)
#     * abperiasamy/pinata     — IPFS pinning shell
#     * vilterp/treesql        — tree-structured SQL REPL
#     * tucats/ego             — Ego language interpreter
#     * jackdoe/juun           — shell history search UI
#     * wenerme/pie            — Postgres exploration shell
#     * wtfutil/wtf            — TUI dashboard config
#     * google/starlark-go/repl — official Starlark REPL
#
#   The library has been periodically marked "maintenance mode" by the original
#   author but continues to accept community PRs.  Forks like reeflective/readline
#   exist but chzyer/readline remains the dominant choice for new projects
#   because of its install base.
#
# -----------------------------------------------------------------------------
# MYLG'S COMMAND STRUCTURE — argv parsing is HAND-ROLLED in mylg.go around
# the cmdFunc map[string]func() table.  When mylg is invoked with no args it
# starts the readline-driven REPL.  When invoked with `mylg <cmd> [args...]`
# it looks up cmd in cmdFunc and calls the function with the joined args.
# The REPL and direct CLI invocation share the SAME command set.
# -----------------------------------------------------------------------------
#
# COMMANDS (extracted verbatim from cmdFunc map in mylg.go and usage const in cli/cli.go)
#
#   ping       — ICMP ping ip address or domain name (CIDR ranges supported)
#   trace      — traceroute (real-time mode with -r option)
#   bgp        — BGP route lookup via current looking glass provider
#   hping      — HTTP/HTTPS ping with GET/POST/HEAD method selection
#   dig        — DNS nameserver lookup
#   whois      — resolve AS number / IP / CIDR to holder via RIPE NCC
#   scan       — TCP port scan with min/max port range
#   dump       — packet dump (libpcap-style) with BPF filter expression
#   disc       — LAN discovery: ARP table + ping sweep + OUI lookup
#   peering    — peering DB lookup via peeringdb.com API
#   nms        — quick NMS dashboard for interface/port monitoring
#   speedtest  — internet speed test via Ookla-compatible servers
#   web        — open web dashboard at default browser
#   connect    — connect to external looking glass (telia/level3/cogent/ntt/kpn)
#   node       — change to specific city/country node within current LG
#   local      — return to local mode (default)
#   lg         — change mode to external looking glass
#   ns         — change mode to nameserver lookup
#   mode       — editor mode (vi/emacs)
#   show       — show running config (config|interface)
#   set        — set config value (key value)
#   help       — show usage banner
#   version    — print mylg version
#   exit       — exit mylg
#   quit       — alias for exit
#
# LOOKING GLASS PROVIDERS (registered in providers map in mylg.go)
#
#   telia     — Telia Carrier (formerly Telia International Carrier)
#   level3    — CenturyLink/Lumen Level 3 looking glass
#   cogent    — Cogent Communications looking glass
#   ntt       — NTT Communications looking glass
#   kpn       — KPN International looking glass
#
# COMPLETION STRATEGY
#
#   * First word: complete from the top-level command set (cmdFunc keys)
#   * After `connect`: complete from provider names (telia/level3/cogent/ntt/kpn)
#   * After `set` / `show`: complete from known config keys
#   * After `mode`: complete with vi/emacs
#   * After ping/trace/whois/scan/dig/hping: free host/IP/AS arg (no completion)
#   * After `dump`: BPF filter expression (no completion)
#   * After `disc`: optional CIDR range (no completion)
#
# =============================================================================

_mylg() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a commands providers config_keys mode_kinds show_kinds

    commands=(
        'ping:ICMP ping target host or CIDR range'
        'trace:traceroute to target (real-time with -r)'
        'bgp:BGP route lookup via current looking glass'
        'hping:HTTP/HTTPS ping with GET/POST/HEAD'
        'dig:DNS nameserver lookup'
        'whois:resolve AS/IP/CIDR via RIPE NCC'
        'scan:TCP port scan (host minport maxport)'
        'dump:packet dump with BPF filter'
        'disc:LAN discovery via ARP + ping sweep'
        'peering:peering DB lookup via peeringdb.com'
        'nms:network management system dashboard'
        'speedtest:internet speed test'
        'web:open web dashboard in browser'
        'connect:connect to external looking glass provider'
        'node:change to specific city/country node'
        'local:return to local mode (default)'
        'lg:change mode to external looking glass'
        'ns:change mode to nameserver lookup'
        'mode:set editor mode (vi/emacs)'
        'show:show running config'
        'set:set config key/value'
        'help:show usage banner'
        'version:print mylg version'
        'exit:exit mylg'
        'quit:alias for exit'
    )

    providers=(
        'telia:Telia Carrier looking glass'
        'level3:CenturyLink/Lumen Level 3 looking glass'
        'cogent:Cogent Communications looking glass'
        'ntt:NTT Communications looking glass'
        'kpn:KPN International looking glass'
    )

    config_keys=(
        'config:running configuration'
        'interface:network interface stats (nms mode)'
    )

    mode_kinds=(
        'vi:vi/vim editing keybindings'
        'emacs:emacs editing keybindings (default)'
    )

    show_kinds=(
        'config:show running configuration'
        'interface:show interface stats (nms mode)'
    )

    _arguments -C \
        '1: :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        (cmd)
            _describe -t commands 'mylg command' commands && ret=0
            ;;
        (args)
            case $line[1] in
                (connect)
                    _describe -t providers 'looking glass provider' providers && ret=0
                    ;;
                (show)
                    _describe -t show 'show subitem' show_kinds && ret=0
                    ;;
                (set)
                    _describe -t config 'config key' config_keys && ret=0
                    ;;
                (mode)
                    _describe -t mode 'editor mode' mode_kinds && ret=0
                    ;;
                (ping|trace|whois|hping|dig)
                    _message 'target host / IP / domain' && ret=0
                    ;;
                (scan)
                    _message 'host [min-port] [max-port]' && ret=0
                    ;;
                (dump)
                    _message 'BPF filter expression' && ret=0
                    ;;
                (disc)
                    _message 'optional CIDR range' && ret=0
                    ;;
                (bgp)
                    _message 'IP or AS number' && ret=0
                    ;;
                (node)
                    _message 'city or country name (tab in REPL for menu)' && ret=0
                    ;;
                (peering)
                    _message 'AS number or organization' && ret=0
                    ;;
                (*)
                    _default && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_mylg "$@"
