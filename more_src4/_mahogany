#compdef mahogany
# ============================================================================
#  _mahogany — Mahogany: a StumpWM-like Wayland compositor in Common Lisp
#
#  Source-direct extraction from
#    https://github.com/stumpwm/mahogany/blob/main/lisp/main.lisp
#    https://github.com/sjl/adopt (the adopt library)
#
#  Maintained by the StumpWM project (stumpwm/mahogany).  364 GH stars.
#  Mahogany is a TILING window manager for Wayland, modeled after StumpWM
#  (the venerable Common Lisp tiling WM for X11).  Keyboard-driven, with
#  a Common Lisp REPL embedded in the compositor for live customization.
#  Sister tools: stumpwm (X11 CL tiling WM), sway (Wayland C tiling WM,
#  in corpus), river (Wayland Zig tiling WM, in corpus), hyprland (in
#  corpus).
#
#  CLI library taxonomy update: 3rd Common Lisp CLI library — Steve Losh's
#  sjl/adopt.  Common Lisp ecosystem now has 3 documented CLI libraries
#  (R291 unix-opts + R295 clingon + R351 adopt) joining the multi-library
#  leaders.  adopt is "A Damn OPTion parsing library" by Steve Losh (also
#  author of bobbin/cl-losh/cacl/temperance/cl-chip8 and many other CL
#  tools).  adopt's design philosophy: SMALL + COMPOSABLE + PARTIAL-
#  APPLICATION-FRIENDLY.  34 GH stars on sjl/adopt; used by mahogany,
#  clpm (Common Lisp Package Manager), and many of Steve Losh's tools.
#
#  adopt API:
#    (adopt:make-interface
#       :name "X" :summary "Y" :usage "[OPTIONS]" :help "Z"
#       :contents (list option-a option-b option-c))
#    (adopt:make-option 'symbol-name
#       :long "long-name" :short #\x
#       :help "..."
#       :parameter "[ARG]"           ; parameter placeholder in help
#       :initial-value VALUE         ; default value
#       :reduce REDUCER-FN)          ; (constantly t) for boolean,
#                                    ; (lambda (prev cur) cur) for
#                                    ; last-wins string, etc.
#    (adopt:parse-options interface argv) → (values arguments-table free-args)
#
#  Distinct from R291 unix-opts (DECLARATIVE list of plists), R295 clingon
#  (CLASS-INSTANCE-based with `clingon:make-command`).  adopt's
#  differentiator: REDUCER FUNCTION per option — caller specifies how to
#  COMBINE multiple occurrences of a flag (e.g. `(constantly t)` for
#  boolean = "any occurrence sets true", `(lambda (prev cur) cur)` for
#  "last-occurrence wins", `(lambda (prev cur) (cons cur prev))` for
#  "accumulate into list").  This makes adopt VERY COMPOSABLE — caller
#  controls the merge semantics.  Brings cross-language CLI library
#  taxonomy variant count to 90 (MILESTONE) — Common Lisp ecosystem now
#  has 3 documented CLI libraries.
#
#  Surface (verbatim from lisp/main.lisp `%build-cmd-line-parser`):
#    -h, --help                  Display help and exit
#    -q, --no-init-file          Do not evaluate an init file on startup
#    -d, --enable-debugger       Enable interactive CLI debugger
#    -l, --loglevel [LEVEL]      Specify loglevel
#                                (TRACE|DEBUG|INFO|WARN|ERROR|FATAL|IGNORE,
#                                 default TRACE)
#
#  Reads $XDG_CONFIG_HOME/mahogany/init.lisp or
#  $HOME/.config/mahogany/init.lisp for user customization (skipped via -q).
#
#  Dup-skipped neighbors during hunt (smaller surface or unrelated):
#    - clpm (lisp-mirror/clpm 11 stars CL package manager — would be a
#      sister adopt demo; HOLD for future round)
#    - ssb-consum-up (Orange-OpenSource 2 stars — too narrow)
#    - Steve Losh's bobbin/cl-losh/cacl tools — use adopt but most are
#      libraries not standalone CLIs
# ============================================================================

_mahogany() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-h --help)'{-h,--help}'[display help and exit]' \
    '(-q --no-init-file)'{-q,--no-init-file}'[do not evaluate init file on startup]' \
    '(-d --enable-debugger)'{-d,--enable-debugger}'[enable interactive CLI debugger]' \
    '(-l --loglevel)'{-l,--loglevel}'=[specify loglevel]:level:(TRACE DEBUG INFO WARN ERROR FATAL IGNORE)'
}

_mahogany "$@"
