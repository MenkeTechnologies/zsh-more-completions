#compdef sponge ts vidir vipe ifdata ifne pee zrun chronic errno lckdo parallel-moreutils
# Documentation: https://joeyh.name/code/moreutils/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for the moreutils collection; flags taken from upstream manpages.

case "$service" in
  sponge)
    _arguments \
      '-a[append instead of overwrite]' \
      '1:output file:_files'
    ;;
  ts)
    _arguments \
      '(-i -s)-r[convert existing timestamps to relative]' \
      '(-r -s)-i[incremental timestamps since last line]' \
      '(-r -i)-s[incremental timestamps since program start]' \
      '-m[use system monotonic clock]' \
      '1:format string:'
    ;;
  vidir)
    _arguments \
      '--verbose[verbosely display the actions taken]' \
      '*:directory or file or -:_files'
    ;;
  vipe)
    _arguments \
      '--suffix=[temp file extension (e.g. csv)]:suffix'
    ;;
  ifdata)
    _arguments \
      '-h[print help summary]' \
      '-e[exit nonzero if interface does not exist]' \
      '-p[print whole interface configuration]' \
      '-pe[print yes or no based on interface existence]' \
      '-pa[print IPv4 address]' \
      '-pn[print netmask]' \
      '-pN[print network address]' \
      '-pb[print broadcast address]' \
      '-pm[print MTU]' \
      '-ph[print hardware address (Linux only)]' \
      '-pf[print interface flags (Linux only)]' \
      '-si[print all input statistics (Linux only)]' \
      '-sip[print input packet count (Linux only)]' \
      '-sib[print input byte count (Linux only)]' \
      '-sie[print input error count (Linux only)]' \
      '-sid[print dropped input packet count (Linux only)]' \
      '-sif[print input FIFO overrun count (Linux only)]' \
      '-sic[print compressed input packet count (Linux only)]' \
      '-sim[print input multicast packet count (Linux only)]' \
      '-so[print all output statistics (Linux only)]' \
      '1:interface:'
    ;;
  ifne)
    _arguments \
      '-n[reverse: run command only if stdin is empty]' \
      '*:command:_command_names -e'
    ;;
  pee)
    _arguments \
      '--ignore-sigpipe[ignore SIGPIPE (default)]' \
      '--no-ignore-sigpipe[do not ignore SIGPIPE]' \
      '--ignore-write-errors[ignore write errors (default)]' \
      '--no-ignore-write-errors[do not ignore write errors]' \
      '*:command'
    ;;
  zrun)
    _arguments \
      '*:command and compressed file:_files'
    ;;
  chronic)
    _arguments \
      '-e[also trigger on stderr output]' \
      '-v[verbose: distinguish STDOUT/STDERR and report RETVAL]' \
      '*:command:_command_names -e'
    ;;
  errno)
    _arguments \
      '(-l --list)'{-l,--list}'[list all errno values]' \
      '(-s --search)'{-s,--search}'[search descriptions for words]' \
      '(-S --search-all-locales)'{-S,--search-all-locales}'[search descriptions across all installed locales]' \
      '*:error name or number:'
    ;;
  lckdo)
    _arguments \
      '-w[wait for lock to be released instead of failing]' \
      '-W+[wait at most N seconds]:seconds' \
      '-e[exec the program directly without forking]' \
      '-E+[file descriptor number to keep open (implies -e)]:fd' \
      '-n[do not create the lock file if missing]' \
      '-q[produce no output if lock already held]' \
      '-s[lock in shared (read) mode]' \
      '1:lockfile:_files' \
      '2:program:_command_names -e' \
      '*::arguments:_normal'
    ;;
  parallel-moreutils|parallel)
    _arguments \
      '-j+[maximum number of jobs to run in parallel]:maxjobs' \
      '-l+[load average limit before starting new jobs]:maxload' \
      '-i[replace {} in command with the argument]' \
      '-n+[number of arguments per command (default 1)]:n' \
      '*:command and arguments:'
    ;;
esac
