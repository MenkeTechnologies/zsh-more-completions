#compdef ppmtoarbtxt
# Documentation: man ppmtoarbtxt (Netpbm)
# Source: render a PPM as text using user-supplied head/body/tail templates.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-hd+[head template]:file:_files' \
    '-tl+[tail template]:file:_files' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:body template:_files' \
    '2:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
