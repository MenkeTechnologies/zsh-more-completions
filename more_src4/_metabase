#compdef metabase
# Documentation: https://www.metabase.com/docs/latest/installation-and-operation/commands
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Metabase is shipped as a JAR; commands are positional after the JAR.
# Real subcommands per upstream CLI reference:
#   api-documentation, command-documentation, config-template,
#   driver-methods, drop-entity-ids, dump-to-h2, environment-variables-documentation,
#   export, generate-openapi-spec, help, import, load-from-h2, migrate,
#   remove-encryption, reset-password, rotate-encryption-key, seed-entity-ids,
#   version.
# Database configuration is via MB_DB_* environment variables, not CLI flags.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'api-documentation:generate HTML/JSON Scalar API docs'
  'command-documentation:produce markdown CLI command docs'
  'config-template:create markdown YAML config template'
  'driver-methods:list driver multimethods'
  'drop-entity-ids:remove entity IDs from serializable models'
  'dump-to-h2:dump application database to an H2 file'
  'environment-variables-documentation:document environment variables'
  'export:serialize a Metabase instance to a directory'
  'generate-openapi-spec:create OpenAPI specification file'
  'help:show available commands'
  'import:import a serialized Metabase instance'
  'load-from-h2:load an H2 dump into the app database'
  'migrate:run application database migration'
  'remove-encryption:decrypt previously encrypted database fields'
  'reset-password:reset a user password by email'
  'rotate-encryption-key:rotate the encryption key'
  'seed-entity-ids:add entity IDs to serializable models'
  'version:show Metabase version'
)

_arguments -C \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'metabase command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (dump-to-h2)
        _arguments \
          '1:h2 filename:_files' \
          '(-k --keep-existing)'{-k,--keep-existing}'[keep existing dump file]' \
          '(-p --dump-plaintext)'{-p,--dump-plaintext}'[dump unencrypted]' && ret=0
        ;;
      (export)
        _arguments \
          '1:export path:_files -/' \
          '(-c --collection)'{-c,--collection=}'[collection ID]:id:' \
          '(-C --no-collections)'{-C,--no-collections}'[exclude collections]' \
          '(-S --no-settings)'{-S,--no-settings}'[exclude settings]' \
          '(-D --no-data-model)'{-D,--no-data-model}'[exclude data model]' \
          '(-f --include-field-values)'{-f,--include-field-values}'[include field values]' \
          '(-s --include-database-secrets)'{-s,--include-database-secrets}'[include DB secrets]' \
          '(-e --continue-on-error)'{-e,--continue-on-error}'[continue on error]' \
          '--full-stacktrace[show full stacktraces]' && ret=0
        ;;
      (import)
        _arguments \
          '1:import path:_files -/' \
          '(-e --continue-on-error)'{-e,--continue-on-error}'[continue on error]' \
          '--full-stacktrace[show full stacktraces]' && ret=0
        ;;
      (migrate)
        _arguments \
          '1:direction:(up force down down-force print release-locks)' && ret=0
        ;;
      (reset-password)
        _arguments \
          '1:email address:' && ret=0
        ;;
      (rotate-encryption-key)
        _arguments \
          '1:new key (>=16 chars):' && ret=0
        ;;
      (load-from-h2)
        _arguments \
          '1:h2 connection string:' && ret=0
        ;;
      (help)
        _arguments \
          '1:command name:(api-documentation command-documentation config-template driver-methods drop-entity-ids dump-to-h2 environment-variables-documentation export generate-openapi-spec import load-from-h2 migrate remove-encryption reset-password rotate-encryption-key seed-entity-ids version)' && ret=0
        ;;
    esac
    ;;
esac

return ret
