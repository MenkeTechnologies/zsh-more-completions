#compdef ppmtowinicon
# Documentation: man ppmtowinicon (Netpbm)
# Source: convert one or more PPM images into a Windows .ico file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-andpgms[interpret extra arguments as AND-mask PGM files]' \
    '-output=[output ico file]:file:_files -g "*.ico"' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:ppm and-mask files:_files -g "*.(ppm|pnm|pam|pgm)"' \
    && ret=0

return ret
