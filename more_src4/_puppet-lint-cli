#compdef puppet-lint-cli
# _puppet-lint-cli — Tim Sharpe puppet-lint Puppet style checker CLI alias (puppetlabs team, Ruby); custom argparse
# upstream: https://github.com/puppetlabs/puppet-lint

_puppet-lint-cli() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--with-context[show context]' \
        '-c[show context]' \
        '--with-filename[include filename]' \
        '--fix[fix violations]' \
        '-f[fix violations]' \
        '--error-level=+[level]:l:(all warning error)' \
        '--show-ignored[show ignored]' \
        '--show-changes[show changes]' \
        '--show-warnings[show warnings]' \
        '--display-token[display tokens]' \
        '--json[json output]' \
        '--no-fix[no fix]' \
        '--load=+[plugin]:str:' \
        '--load-plugins[load plugins]' \
        '--no-load-plugins[no load plugins]' \
        '--ignore-check=+[check]:str:' \
        '--ignore-paths=+[patterns csv]:str:' \
        '--log-format=+[format]:str:' \
        '--only-checks=+[check csv]:str:' \
        '--codeclimate-report-file=+[file]:file:_files' \
        '--checkstyle-report-file=+[file]:file:_files' \
        '--relative[use relative paths]' \
        '--show-rules[show all rules]' \
        '--show-context-where=+[where]:w:(stdout stderr none)' \
        '*:file:_files -g "*.pp"'
}

_puppet-lint-cli "$@"
