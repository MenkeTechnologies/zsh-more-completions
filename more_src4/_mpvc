#compdef mpvc
# Documentation: https://github.com/lwilletts/mpvc
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mpvc - an mpc-like control interface for mpv

local curcontext="$curcontext" state line ret=1

_mpvc_commands() {
  local -a commands=(
    'add:add media to playlist'
    'play:always start playback'
    'pause:pause playback'
    'toggle:toggle playback'
    'stop:always stop playback'
    'next:jump to next entry in playlist'
    'prev:jump to previous entry in playlist'
    'remove:remove media by id from playlist'
    'rm:remove media by id from playlist'
    'playlist:print filenames of tracks to fit terminal'
    'fullplaylist:print all filenames of tracks in current playlist'
    'repeat:loop the playlist'
    'single:loop a single file'
    'vol:increase/decrease volume relative to current volume'
  )
  _describe -t commands 'mpvc command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show short help]' \
  '(-H --help-long)'{-H,--help-long}'[show long help]' \
  '-a[add media to playlist]' \
  '-P[always start playback]' \
  '-s[always stop playback]' \
  '-p[toggle playback]' \
  '-r[remove media by id from playlist]' \
  '-i[print filenames of tracks to fit terminal]' \
  '-I[print all filenames of tracks in current playlist]' \
  '-v[increase/decrease volume relative to current]' \
  '1: :_mpvc_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      add)
        _files
        ;;
      *)
        _message 'no more arguments'
        ;;
    esac
    ;;
esac

return ret
