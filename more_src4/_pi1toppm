#compdef pi1toppm
# Documentation: man pi1toppm (Netpbm)
# Source: convert an Atari Degas PI1 image to PPM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pi1 file:_files -g "*.pi1"' \
    && ret=0

return ret
