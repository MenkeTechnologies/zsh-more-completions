#compdef mmv mcp mln
# Documentation: https://manpages.debian.org/bookworm/mmv/mmv.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Zsh completion for mmv/mcp/mln (mass move/copy/link files)

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-m --move)'{-m,--move}'[move source to target]' \
  '(-x --copydel)'{-x,--copydel}'[copy then delete source]' \
  '(-r --rename)'{-r,--rename}'[rename within same directory]' \
  '(-c --copy)'{-c,--copy}'[copy preserving source permissions]' \
  '(-o --overwrite)'{-o,--overwrite}'[overwrite preserving target permissions]' \
  '(-l --hardlink)'{-l,--hardlink}'[hardlink target to source]' \
  '(-s --symlink)'{-s,--symlink}'[symlink target to source]' \
  '(-d --force)'{-d,--force}'[no confirmation on delete/overwrite]' \
  '(-p --protect)'{-p,--protect}'[treat delete/overwrite as errors]' \
  '(-g --go)'{-g,--go}'[skip erroneous actions]' \
  '(-t --terminate)'{-t,--terminate}'[erroneous actions are errors]' \
  '(-v --verbose)'{-v,--verbose}'[report all actions]' \
  '(-n --dryrun)'{-n,--dryrun}'[report only, no execute]' \
  '(-h --hidden)'{-h,--hidden}'[treat dot files normally]' \
  '--help[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:from pattern:_files' \
  '2:to pattern:' && ret=0
return ret
