#compdef polygraphy
# Documentation: https://github.com/NVIDIA/TensorRT/tree/main/tools/Polygraphy
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# polygraphy: NVIDIA NN debugging toolkit
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'run:run a model and compare results across runtimes'
  'inspect:inspect a model or data'
  'convert:convert between formats (onnx/tensorrt)'
  'data:utility commands for data files'
  'surgeon:run ONNX surgery operations (extract, sanitize)'
  'check:check models or runtimes for issues'
  'template:print template config files'
  'plugin:plugin commands'
  'debug:debug commands'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-v[verbose]' \
  '-q[quiet]' \
  '--silent[silent]' \
  '--log-format=[log format]:fmt:' \
  '--log-file=[log file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'polygraphy command' commands && ret=0 ;;
esac
return ret
