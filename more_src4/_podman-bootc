#compdef podman-bootc
# Documentation: https://github.com/bootc-dev/podman-bootc
# Source: https://github.com/bootc-dev/podman-bootc/tree/main/cmd
# Reference accessed: 2026-06-01
# macOS/Windows: requires rootful Podman Machine. Linux: pair with --remote.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _pb_cmds
_pb_cmds=(
    'run:create a new VM from a bootc container image with persistent disk'
    'list:display all running VMs'
    'ssh:connect to an existing VM'
    'rm:remove a VM'
    'stop:stop an existing VM'
    'images:list bootc images in the local containers store'
    'help:show help'
)

_arguments -C \
    '--log-level=[set log level]:level:(trace debug info warn error fatal)' \
    '(- *)'{-h,--help}'[show help]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'podman-bootc command' _pb_cmds && ret=0
        ;;
    args)
        case $line[1] in
            run)
                _arguments -s -S \
                    '(-u --user)'{-u+,--user=}'[user name (default root)]:user:_default' \
                    '--cloudinit=[cloud-init data directory]:dir:_files -/' \
                    '--filesystem=[override root filesystem]:fs:(xfs btrfs ext4)' \
                    '(-B --background)'{-B,--background}'[do not spawn SSH, run in background]' \
                    '--rm[remove VM + disk when SSH exits]' \
                    '--quiet[suppress disk creation + boot console output]' \
                    '--root-size-max=[max root filesystem size (M/G/T suffixes)]:size:_default' \
                    '--disk-size=[disk image size (M/G/T suffixes)]:size:_default' \
                    '1:image:_default' \
                    && ret=0
                ;;
            ssh)
                _arguments -s -S \
                    '(-u --user)'{-u+,--user=}'[user name (default root)]:user:_default' \
                    '1:VM ID:_default' \
                    && ret=0
                ;;
            rm)
                _arguments -s -S \
                    '--all[remove all non-running bootc VMs]' \
                    '(-f --force)'{-f,--force}'[terminate a running VM]' \
                    '1:VM ID:_default' \
                    && ret=0
                ;;
            stop)
                _arguments -s -S '1:VM ID:_default' && ret=0
                ;;
        esac
        ;;
esac

return ret
