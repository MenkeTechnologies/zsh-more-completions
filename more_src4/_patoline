#compdef patoline
# _patoline — patoline patoline CLI typesetting compiler OCaml-based modern alternative to LaTeX TeX consuming .txp Patoline source files producing PDF documents through embedded high-level OCaml programs reading custom macro-defined extensible package format ConTeXt-inspired (Pierre Hyvernat team, OCaml); custom argparse
# upstream: https://patoline.github.io/

_patoline() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-c+[OCaml command]:str:' \
        '--ml[output .ml file only]' \
        '--bin[create executable]' \
        '--noml[do not generate .ml]' \
        '--driver=+[driver]:d:(Pdf SVG Bin DriverGL Patonet Web)' \
        '--format=+[format]:f:(DefaultFormat FormatArticle FormatMemoire FormatLetter FormatSlides FormatLivre FormatThese)' \
        '--package=+[package]:str:' \
        '--unsafe[unsafe mode]' \
        '--pp+[preprocessor]:file:_files' \
        '--cflags=+[cflags]:str:' \
        '--lflags=+[lflags]:str:' \
        '--ccopts=+[cc opts]:str:' \
        '--meta[meta mode]' \
        '--quick[quick build]' \
        '--build-dir=+[dir]:dir:_files -/' \
        '*:txp file:_files -g "*.txp"'
}

_patoline "$@"
