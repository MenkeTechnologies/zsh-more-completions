#compdef pamhue
# Documentation: man pamhue (Netpbm)
# Source: rotate the hue of a PAM image by a given angle in degrees.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-huechange=[hue rotation in degrees]:degrees:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pam file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
