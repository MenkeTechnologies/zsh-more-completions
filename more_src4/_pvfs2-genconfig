#compdef pvfs2-genconfig
# Documentation: https://www.mankier.com/1/pvfs2-genconfig
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pvfs2-genconfig: generate a PVFS2 config file
local curcontext="$curcontext" ret=1
_arguments -C \
  '--protocol=[transport protocol]:protocol:(gm tcp)' \
  '--port=[server bind port]:port:' \
  '*--ioservers=[data servers, comma-delimited]:servers:' \
  '*--metaservers=[metadata servers, comma-delimited]:servers:' \
  '--logfile=[log file directory]:dir:_files -/' \
  '--storage=[storage directory]:dir:_files -/' \
  '--quiet[generate without screen output]' \
  '*:config file:_files' && ret=0
return ret
