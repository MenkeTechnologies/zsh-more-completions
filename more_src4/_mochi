#compdef mochi
# ============================================================================
# _mochi — zsh completion for the Mochi programming language toolchain
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/mochilang/mochi
#   License    : MIT
#   Language   : Go (compiler) / Mochi (.mochi source files)
#   Binary     : mochi  (.goreleaser.yaml builds[0].binary = "mochi"
#                       from cmd/mochi/main.go)
#   Last push  : 2026-06-01
#
# WHAT IT IS
#   Mochi is "a small, fast, embeddable programming language designed
#   for agents, data, and AI.  It combines functional syntax, stream-
#   first semantics, and native support for datasets, graphs, and
#   simulation."  Mochi compiles `.mochi` source into one of several
#   target backends:  Go (default), C (transpile-and-cc), C ahead-of-
#   time (single-binary build), BEAM escript (Erlang VM), Python
#   source / wheel / sdist / IPython kernel, or via cosmocc into an
#   "Actually Portable Executable" that runs unmodified on Linux,
#   macOS, Windows, and BSD.  The same toolchain runs Mochi in an
#   interpreter (`mochi run`), as a REPL (`mochi repl`), through the
#   Model Context Protocol over stdio (`mochi serve`), and against the
#   built-in LLM facade (`mochi llm`).
#
# CLI ARGUMENT GRAMMAR  (verbatim from cmd/mochi/main.go go-arg
#                       CLI struct + per-subcommand struct definitions)
#   mochi <subcommand> [args...]
#
#   Subcommands:
#     run [FILE]                Run a Mochi source file
#       -e, --expr <EXPR>         Run an inline Mochi expression
#       --ast                     Print parsed AST in Lisp format
#       --debug                   Enable debug output
#       --memo                    Enable memoization of pure functions
#       --aot                     Fold pure calls before execution
#       --ir                      Print VM assembly and exit
#
#     build <FILE>              Compile to a target language
#       --target <T>              go | c | c-aot | beam-escript |
#                                 python-source | python-wheel |
#                                 python-sdist | python-ipykernel |
#                                 python-publish                 [default: go]
#       --emit <SHAPE>            executable | go-library | c
#                                                          [default: executable]
#       --out <PATH>              Output dir/path
#       --keep-emit               Retain emitted source files after build
#       --module <PATH>           Module path baked into go.mod
#                                 (REQUIRED for --emit=go-library)
#       --package <NAME>          Package name override
#       --runtime-replace <PATH>  Local replace directive for mochi runtime
#       --cc <CC>                 C compiler (env MOCHI_CC, default 'cc')
#       --binary <PATH>           Output binary path (--target=c only)
#       --portable                Statically link the binary (musl/glibc)
#       --triple <TRIPLE>         Target triple (e.g. x86_64-linux-musl,
#                                 aarch64-macos, wasm32-wasi) — when set
#                                 the driver defaults to `zig cc`
#       --profile <P>             release | debug  (--target=c-aot only)
#                                                          [default: release]
#       --apex                    Build Actually Portable Executable via
#                                 cosmocc (Linux/macOS/Windows/BSD)
#
#     test <PATH>               Run test blocks inside a Mochi file/dir
#       --debug                   Debug output
#       --memo                    Memoize pure functions
#       --aot                     Fold pure calls before execution
#
#     init [PATH]               Initialize a new Mochi module
#                               (defaults to current directory)
#
#     get                       Download module dependencies
#
#     repl                      Start an interactive REPL session
#
#     llm [PROMPT]              Send a prompt to the default LLM
#       -f <FILE>                 Read prompt from file ('-' for stdin)
#
#     infer <LANGUAGE> <PACKAGE>
#                               Infer externs from a package
#       LANGUAGE: python | typescript | go
#       -f, --format <FMT>        json | mochi               [default: mochi]
#
#     serve                     Start an MCP server over stdio
#     cheatsheet                Print the Mochi language cheatsheet
#
#   Top-level flag:
#     --version                 Print version, gitCommit, buildTime; exit
#
# LANGUAGE-CORPUS POSITION
#   Mochi is the 147th programming language entry in this completion corpus,
#   closing the 3+1 micro-cycle that began at R857 (_displex/serenity+poise
#   Rust=122 opens Axis 67) and continued through R858 (_pingme/discordgo
#   Go=122) and R859 (_dayz-server-manager/discord.js TS-Node=122 CLOSES
#   Axis 67 Discord Bot Library at 1/1/1 + triple-122 landmark + THREE-
#   SCORE 60-AXES round-number landmark — 60 axes at 1/1/1 three-language
#   symmetry).  Mochi joins the roster of exotic languages already in
#   the corpus including Oden (R856 146th), Hop (R852 145th), Lustre
#   (R848 144th), Ravi (R844 143rd), ZetZ (R840 142nd), Granule (R836
#   141st), Sixten (R832 140th — round-number language milestone), Imba
#   (R828 139th), Tao (R824 138th), Dada (R820 137th), Acton (R816
#   136th), Stanza (R812 135th), Rune, Egel, Mlatu, Gwion, Silq
#   (quantum), Mirth, Lawvere/bill, Cognac/Cognate, and Scrapscript.
#
#   No completion for `mochi` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_mochi() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)--version[print version info and exit]' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_mochi_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                run)         _mochi_run     && ret=0 ;;
                build)       _mochi_build   && ret=0 ;;
                test)        _mochi_test    && ret=0 ;;
                init)        _mochi_init    && ret=0 ;;
                get)         _arguments '(- *)'{-h,--help}'[help]' && ret=0 ;;
                repl)        _arguments '(- *)'{-h,--help}'[help]' && ret=0 ;;
                llm)         _mochi_llm     && ret=0 ;;
                infer)       _mochi_infer   && ret=0 ;;
                serve)       _arguments '(- *)'{-h,--help}'[help]' && ret=0 ;;
                cheatsheet)  _arguments '(- *)'{-h,--help}'[help]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_mochi_commands] )) ||
_mochi_commands() {
    local -a commands
    commands=(
        'run:run a Mochi source file or inline expression'
        'build:compile a Mochi source to a target language (go/c/c-aot/beam-escript/python/apex)'
        'test:run test blocks inside a Mochi source file or directory'
        'init:initialize a new Mochi module'
        'get:download module dependencies'
        'repl:start an interactive REPL session'
        'llm:send a prompt to the default LLM provider'
        'infer:infer externs from a python/typescript/go package'
        'serve:start an MCP (Model Context Protocol) server over stdio'
        'cheatsheet:print the Mochi language cheatsheet'
    )
    _describe -t commands 'mochi command' commands
}

(( $+functions[_mochi_run] )) ||
_mochi_run() {
    _arguments \
        '(-e --expr)'{-e+,--expr=}'[run an inline Mochi expression]:expression:' \
        '--ast[print parsed AST in Lisp format]' \
        '--debug[enable debug output]' \
        '--memo[enable memoization of pure functions]' \
        '--aot[fold pure calls before execution]' \
        '--ir[print VM assembly and exit]' \
        '(- *)'{-h,--help}'[help for run]' \
        ':source file:_files -g "*.mochi"'
}

(( $+functions[_mochi_build] )) ||
_mochi_build() {
    _arguments \
        '--target=[target language (default go)]:target:(go c c-aot beam-escript python-source python-wheel python-sdist python-ipykernel python-publish)' \
        '--emit=[emit shape]:shape:(executable go-library c)' \
        '--out=[output dir/path]:output:_files' \
        '--keep-emit[retain emitted source files after build]' \
        '--module=[module path baked into go.mod (REQUIRED for --emit=go-library)]:module path:' \
        '--package=[package name override]:package name:' \
        '--runtime-replace=[local replace directive for mochi runtime]:path:_files -/' \
        '--cc=[C compiler to invoke (env MOCHI_CC, default cc)]:cc binary:_files' \
        '--binary=[output binary path (--target=c only)]:binary path:_files' \
        '--portable[statically link binary (musl/glibc-static)]' \
        '--triple=[target triple (drives zig cc when set)]:triple:(x86_64-linux-musl aarch64-macos wasm32-wasi)' \
        '--profile=[build profile for --target=c-aot]:profile:(release debug)' \
        '--apex[build Actually Portable Executable via cosmocc]' \
        '(- *)'{-h,--help}'[help for build]' \
        ':source file:_files -g "*.mochi"'
}

(( $+functions[_mochi_test] )) ||
_mochi_test() {
    _arguments \
        '--debug[enable debug output]' \
        '--memo[memoize pure functions]' \
        '--aot[fold pure calls before execution]' \
        '(- *)'{-h,--help}'[help for test]' \
        ':path to file or dir:_files'
}

(( $+functions[_mochi_init] )) ||
_mochi_init() {
    _arguments \
        '(- *)'{-h,--help}'[help for init]' \
        ':module path (default current dir):_files -/'
}

(( $+functions[_mochi_llm] )) ||
_mochi_llm() {
    _arguments \
        '-f+[read prompt from file (- for stdin)]:file:_files' \
        '(- *)'{-h,--help}'[help for llm]' \
        ':prompt:'
}

(( $+functions[_mochi_infer] )) ||
_mochi_infer() {
    _arguments \
        '(-f --format)'{-f+,--format=}'[output format (default mochi)]:format:(json mochi)' \
        '(- *)'{-h,--help}'[help for infer]' \
        ':language:(python typescript go)' \
        ':package or module path:'
}

_mochi "$@"
