#compdef pcp-uptime
# Documentation: https://man7.org/linux/man-pages/man1/pcp-uptime.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-\?[show help]' \
  '(- *)--help[show help]' \
  '-V[show version]' \
  '--version[show version]' \
  '-a+[archive source]:archive:_files' \
  '--archive=[archive source]:archive:_files' \
  '-h+[target host]:host:_hosts' \
  '--host=[target host]:host:_hosts' \
  '-O+[time origin]:time:' \
  '--origin=[time origin]:time:' \
  '-S+[start time]:time:' \
  '--start=[start time]:time:' \
  '-Z+[timezone specification]:tz:' \
  '--timezone=[timezone specification]:tz:' && ret=0

return ret
