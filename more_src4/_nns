#compdef nns
# Documentation: https://www.systutorials.com/docs/linux/man/n-nns/
# Reference accessed: 2026-05-17
# Verified: Tcllib nameserv client (`nns`/`nnsd`) — the most
# common Linux packaging of a `nns` binary. Supports `bind`,
# `search`, `who`, `protocol`, `cget`, `configure` subcommands;
# common option flags -host, -port, -localonly, -help.
# Removed from prior file: bogus man.archlinux.org search URL.
# NOTE: multiple homonyms exist (Tcllib, DFINITY ICP, NEAR
# namespace) — this completion targets the Tcllib variant.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'bind:bind a name to a value'
  'search:search names matching pattern'
  'who:list bound names'
  'protocol:show wire protocol version'
  'cget:read configuration option'
  'configure:set configuration option'
  'help:show help'
)

_arguments -C \
  '-host+[name service host]:host:_hosts' \
  '-port+[name service port]:port:' \
  '-localonly+[local-only mode]:flag:(true false)' \
  '-help[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'nns command' commands && ret=0 ;;
esac
return ret
