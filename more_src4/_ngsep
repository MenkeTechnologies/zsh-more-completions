#compdef ngsep NGSEP
# _ngsep — Jorge Duitama Andrea Aguilar NGSEP Next Generation Sequencing Eclipse Plugin variant detection alignment library (NGSEP team, Java); custom argparse
# upstream: https://github.com/NGSEP/NGSEPcore

_ngsep() {
    local -a sub=(
        'AlignmentsSummary:summarize alignments'
        'AssembleAlignments:assemble alignments'
        'AssemblyGraphTool:build assembly graph'
        'BaseCounter:count bases'
        'CoverageStatistics:coverage statistics'
        'DeNovoAssembler:de novo assembly'
        'DeNovoAssembler:de novo assembly'
        'FilterVCF:filter VCF'
        'GenotypeImputation:genotype imputation'
        'IndividualGenomeBuilder:build individual genome'
        'KmersExtractor:extract kmers'
        'KmerSpectrum:kmer spectrum'
        'MergeVCF:merge VCFs'
        'PopulationVariantsDetector:variant detection'
        'QualStats:quality statistics'
        'ReadsFileErrorCorrector:read error correction'
        'RelativeAlleleCounts:allele counts'
        'SingleSampleVariantsDetector:single sample variants'
        'SyntheticReadsSimulator:simulate reads'
        'TransposonsFinder:find transposons'
        'VariantsAnnotation:annotate variants'
        'VariantsCompare:compare variants'
        'VariantsDetector:detect variants'
        'VariantsFilter:filter variants'
        'VCFConverter:convert VCF format'
        'VCFFilter:filter VCF'
        'VCFGenotypeImputation:impute VCF'
        'VCFGenotypeReport:VCF genotype report'
        'VCFIntrogressionAnalysis:introgression analysis'
        'VCFMerge:merge VCFs'
        'VCFSplit:split VCF'
        'VCFStatsExporter:export VCF stats'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-Xmx+[Java max heap]:str:' \
        '-Xms+[Java min heap]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ngsep subcommand' sub ;;
        args)
            case $words[1] in
                *) _arguments \
                    '-r+[reference fasta]:file:_files -g "*.fa *.fasta *.fna"' \
                    '-i+[input file]:file:_files' \
                    '-o+[output prefix]:str:' \
                    '-t+[threads]:n:' \
                    '-s+[sample id]:str:' \
                    '-p+[ploidy]:n:' \
                    '-q+[quality]:n:' \
                    '-c+[coverage]:n:' \
                    '-h+[heterozygosity]:f:' \
                    '*:input file:_files' ;;
            esac
            ;;
    esac
}

_ngsep "$@"
