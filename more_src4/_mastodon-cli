#compdef mastodon-cli
# ============================================================================
# _mastodon-cli — zsh completion for MellonScholarlyCommunication's
#                  mastodon-cli, a Mastodon-notifications-to-AS2-Linked-
#                  Data-Notification bridge built on megalodon
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/MellonScholarlyCommunication/mastodon-cli
#   Maintainer : The Mellon Scholarly Communication project
#                (https://github.com/MellonScholarlyCommunication)
#   License    : MIT
#   Language   : JavaScript (Node)
#   Package    : mastodon-cli v1.1.13
#   Binary     : mastodon-cli  (package.json bin: ./bin/mastodon-cli.js)
#   Last push  : 2026-02-14
#
# WHAT IT IS
#   mastodon-cli is "a demonstration mastodon client" that acts as a
#   one-way bridge from Mastodon timeline / notification events into
#   ActivityStreams 2.0 (AS2) "Linked Data Notifications" — JSON-LD
#   files dropped into an inbox directory for downstream processing
#   by the Mellon Scholarly Communication infrastructure.  The CLI
#   wraps the megalodon Fediverse client to fetch notifications,
#   accounts, and statuses from any megalodon-supported server
#   (Mastodon, Pleroma, Friendica, Gotosocial, Firefish), then
#   serializes each item as either a native Mastodon JSON record or
#   a dereferenced AS2 representation pulled from the source post's
#   `application/activity+json` representation.
#
# CLI ARGUMENT GRAMMAR  (verbatim from bin/mastodon-cli.js
#                       commander.js program builder)
#   mastodon-cli <COMMAND> [args]
#
#   Subcommands:
#     account <USERNAME>             Look up an account by acct
#                                    (calls /api/v1/accounts/lookup)
#       --url <URL>                    Mastodon host
#                                      [default: $MASTODON_URL]
#       -t, --timeout <SECONDS>        HTTP timeout [default: 1]
#
#     fetch                          Fetch and serialize notifications
#                                    into the configured inbox
#                                    (megalodon client.getNotification,
#                                    .getAccountStatuses, .userStreaming)
#       --account <ACCOUNT>            Mastodon account
#       --url <URL>                    Mastodon host
#       --token <TOKEN>                Access token
#       --inbox <PATH>                 Inbox directory for output
#                                      JSON-LD files (or "stdout")
#       --exclude <TYPES>              Comma-separated notification
#                                      types to exclude
#       --limit <N>                    Limit fetched notifications
#       --history <FILE>               Persist last-seen id between
#                                      runs (cursor file)
#       --id <ID>                      Fetch a single notification
#                                      by id
#       --streaming                    Use Mastodon Server-Sent
#                                      Events streaming endpoint
#       --since <ID>                   Return results more recent
#                                      than this id
#       --older <ID>                   Return results older than
#                                      this id
#       --type <native|as2>            Output serializer
#                                      [default: $MASTODON_SERIALIZE_TYPE
#                                                / native]
#       --handler <HANDLER>            Notification handler module
#                                      (dynamic require for AS2
#                                      conversion)
#
#     generate <TOOT>                Generate an AS2 announcement
#                                    document for a toot
#       --account-id <URL>             Account RDF id
#                                      [default: http://localhost/
#                                                profile/card#me]
#       --account-inbox <URL>          Account inbox URL
#                                      [default: http://localhost/inbox/]
#       --account-name <NAME>          Account display name
#                                      [default: Test Account]
#       --handler <HANDLER>            Notification handler module
#       --inbox <PATH>                 Inbox directory (or "stdout")
#
#     post <TOOT>                    Post a toot via megalodon
#                                    client.postStatus
#       --url <URL>                    Mastodon host
#       --token <TOKEN>                Access token
#       --visibility <V>               Status visibility:
#                                      public / private / unlisted /
#                                      direct  [default: public]
#
#     profile <URL>                  Fetch a remote profile
#       -a, --attachment <REGEX>       Attachment field regex (when
#                                      set, return matching profile
#                                      attachment value instead of
#                                      full profile)
#
#   Environment variables (read by bin/mastodon-cli.js):
#     MASTODON_URL                  Default Mastodon host
#     MASTODON_ACCESS_TOKEN         Default access token
#     MASTODON_INBOX_PATH           Default inbox directory (./inbox)
#     MASTODON_EXCLUDE_TYPES        Default exclude types
#     MASTODON_LIMIT_NUM            Default limit (10)
#     MASTODON_HISTORY_FILE         Default history cursor file
#     MASTODON_SERIALIZE_TYPE       Default serializer (native/as2)
#     MASTODON_HANDLER              Default notification handler
#     LOG4JS                        log4js log level
#
# AXIS / CORPUS POSITION
#   Direct dependency on `megalodon =10.0.2` declared in package.json
#   — the canonical Node.js Fediverse client maintained by h3poteto
#   (h3poteto/megalodon).  megalodon is a "use one interface, talk to
#   every Fediverse server" client:  Mastodon / Pleroma / Friendica /
#   Gotosocial / Firefish are all dispatched through a generator
#   factory (`megalodon.default('mastodon', url, token)`) that
#   returns a unified async client.  mastodon-cli's `lib/index.js`
#   uses `client.postStatus`, `client.getNotification`,
#   `client.getAccountStatuses`, and the streaming endpoints
#   directly.  Verified via:
#     gh api repos/MellonScholarlyCommunication/mastodon-cli/contents/package.json
#       → "megalodon": "=10.0.2"
#     gh api repos/MellonScholarlyCommunication/mastodon-cli/contents/lib/index.js
#       → const megalodon = require('megalodon');
#         const generator = megalodon.default;
#         const client = generator('mastodon', url, opts.token);
#   This entry is the TS-Node=129 leader bump that CLOSES Axis 74
#   (Mastodon / Fediverse Client Library) at 1/1/1 three-language
#   symmetry — pairing Rust=megalodon-rs (R885 _musket),
#   Go=mattn/go-mastodon (R886 _mstdn), and TS-Node=megalodon
#   =10.0.2 (this entry).  Triple-129 landmark on commit.
#
#   No completion for `mastodon-cli` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_mastodon-cli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_mastodon-cli_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                account)
                    _arguments \
                        '--url=[Mastodon host URL]:url:' \
                        '(-t --timeout)'{-t+,--timeout=}'[HTTP timeout (seconds, default 1)]:seconds:' \
                        ':username:' && ret=0 ;;
                fetch)
                    _arguments \
                        '--account=[Mastodon account]:account:' \
                        '--url=[Mastodon host URL]:url:' \
                        '--token=[Mastodon access token]:token:' \
                        '--inbox=[inbox directory for JSON-LD output (or "stdout")]:inbox:_files -/' \
                        '--exclude=[comma-separated notification types to exclude]:types:' \
                        '--limit=[limit fetched notifications]:n:' \
                        '--history=[history cursor file]:file:_files' \
                        '--id=[fetch a single notification by id]:id:' \
                        '--streaming[use Mastodon SSE streaming endpoint]' \
                        '--since=[return results more recent than id]:id:' \
                        '--older=[return results older than id]:id:' \
                        '--type=[output serializer]:serializer:(native as2)' \
                        '--handler=[notification handler module]:handler:_files' && ret=0 ;;
                generate)
                    _arguments \
                        '--account-id=[account RDF id]:url:' \
                        '--account-inbox=[account inbox URL]:url:' \
                        '--account-name=[account display name]:name:' \
                        '--handler=[notification handler module]:handler:_files' \
                        '--inbox=[inbox directory (or "stdout")]:inbox:_files -/' \
                        ':toot:' && ret=0 ;;
                post)
                    _arguments \
                        '--url=[Mastodon host URL]:url:' \
                        '--token=[Mastodon access token]:token:' \
                        '--visibility=[status visibility]:visibility:(public private unlisted direct)' \
                        ':toot:' && ret=0 ;;
                profile)
                    _arguments \
                        '(-a --attachment)'{-a+,--attachment=}'[attachment field regex]:regex:' \
                        ':account URL:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_mastodon-cli_commands] )) ||
_mastodon-cli_commands() {
    local -a commands
    commands=(
        'account:look up an account by acct'
        'fetch:fetch and serialize notifications into the inbox'
        'generate:generate an AS2 announcement document for a toot'
        'post:post a toot via megalodon'
        'profile:fetch a remote profile'
    )
    _describe -t commands 'mastodon-cli command' commands
}

_mastodon-cli "$@"
