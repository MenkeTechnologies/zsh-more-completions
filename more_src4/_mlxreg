#compdef mlxreg
# Documentation: https://docs.nvidia.com/networking/display/mftv4340/mlxreg-utility
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --device)'{-d+,--device=}'[mst device]:dev:' \
  '(-a --adb_file)'{-a+,--adb_file=}'[external ADB file]:file:_files' \
  '--reg_name=[known access register name]:reg:' \
  '--reg_id=[access register id]:id:' \
  '--reg_len=[register layout length in bytes]:n:' \
  '(-i --indexes)'{-i+,--indexes=}'[register indexes]:idx:' \
  '(-g --get)'{-g,--get}'[register access GET]' \
  '(-s --set)'{-s+,--set=}'[register access SET]:kv:' \
  '--show_reg[print fields of a given reg access]' \
  '--show_regs[list all available access registers]' \
  '--yes[non-interactive mode]' \
  '--i2c_secondary[I2C secondary address]' \
  '(-w --overwrite)'{-w,--overwrite}'[set only specified fields, zero others]' \
  '--full_path[show fields with full hierarchical path]' && ret=0
return ret
