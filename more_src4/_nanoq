#compdef nanoq
# Documentation: https://github.com/esteinig/nanoq
# Source: esteinig/nanoq src/cli.rs — fast quality control for nanopore reads (Rust, structopt).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-i --input)'{-i+,--input=}'[input file (Fast{a,q}.{gz,xz,bz}); stdin if absent]:file:_files' \
    '(-o --output)'{-o+,--output=}'[output file; stdout if absent]:file:_files' \
    '(-l --min-len)'{-l+,--min-len=}'[minimum read length filter (bp)]:n:_default' \
    '(-m --max-len)'{-m+,--max-len=}'[maximum read length filter (bp)]:n:_default' \
    '(-q --min-qual)'{-q+,--min-qual=}'[minimum average read quality]:q:_default' \
    '(-w --max-qual)'{-w+,--max-qual=}'[maximum average read quality]:q:_default' \
    '*'{-v,--verbose}'[verbose stats (up to -vvv)]' \
    '(-H --header)'{-H,--header}'[print summary header]' \
    '(-t --top)'{-t+,--top=}'[number of top reads in verbose summary]:n:_default' \
    '(-s --stats)'{-s,--stats}'[summary report only (stdout)]' \
    '(-r --report)'{-r+,--report=}'[summary report file]:file:_files' \
    '(-j --json)'{-j,--json}'[summary report in JSON]' \
    '(-S --trim-start)'{-S+,--trim-start=}'[trim bases from read start]:n:_default' \
    '(-E --trim-end)'{-E+,--trim-end=}'[trim bases from read end]:n:_default' \
    '(-L --read-lengths)'{-L+,--read-lengths=}'[read lengths output file]:file:_files' \
    '(-Q --read-qualities)'{-Q+,--read-qualities=}'[read qualities output file]:file:_files' \
    '(-f --fast)'{-f,--fast}'[ignore quality values if present]' \
    '(-O --output-type)'{-O+,--output-type=}'[output compression]:type:(u b g l)' \
    '(-c --compress-level)'{-c+,--compress-level=}'[compression level 1-9 (default 6)]:n:_default' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[print version]' \
    && ret=0

return ret
