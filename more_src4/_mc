#compdef mc
# Documentation: https://manpages.debian.org/mc.1
# Source: GNU Midnight Commander — visual file manager.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-a --stickchars)'{-a,--stickchars}'[disable graphic chars for line drawing]' \
    '(-b --nocolor -c --color)'{-b,--nocolor}'[force black-and-white display]' \
    '(-b --nocolor -c --color)'{-c,--color}'[force color mode]' \
    '(-C --colors)'{-C,--colors=}'[custom color set]:colorspec:' \
    '--configure-options[show configure options]' \
    '(-d --nomouse)'{-d,--nomouse}'[disable mouse support]' \
    '(-e --edit)'{-e,--edit=}'[start internal editor (optionally on FILE)]::file:_files' \
    '(-f --datadir)'{-f,--datadir}'[print compiled-in search paths]' \
    '(-F --datadir-info)'{-F,--datadir-info}'[print extended path information]' \
    '(-g --oldmouse)'{-g,--oldmouse}'[force normal tracking mouse mode]' \
    '(-k --resetsoft)'{-k,--resetsoft}'[reset softkeys to termcap/terminfo defaults]' \
    '(-K --keymap)'{-K,--keymap=}'[keymap file]:keymap-file:_files' \
    '(-l --ftplog)'{-l,--ftplog=}'[save FTP dialog to file]:logfile:_files' \
    '--nokeymap[skip loading key bindings from files]' \
    '(-P --printwd)'{-P,--printwd=}'[print last working dir to FILE on exit]:file:_files' \
    '(-s --slow)'{-s,--slow}'[enable slow-terminal mode]' \
    '(-S --skin)'{-S,--skin=}'[skin name]:skin:' \
    '(-t --termcap)'{-t,--termcap}'[use TERMCAP variable for terminal info]' \
    '(-u --nosubshell -U --subshell)'{-u,--nosubshell}'[disable concurrent shell support]' \
    '(-u --nosubshell -U --subshell)'{-U,--subshell}'[enable concurrent shell support]' \
    '(-v --view)'{-v,--view=}'[open file in internal viewer]:file:_files' \
    '(- *)'{-V,--version}'[display program version]' \
    '(-x --xterm)'{-x,--xterm}'[force xterm mode]' \
    '(-X --no-x11)'{-X,--no-x11}'[disable X11 modifier state detection]' \
    '*:directory:_files -/' \
    && ret=0

return ret
