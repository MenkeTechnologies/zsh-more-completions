#compdef pk4
# Documentation: https://manpages.debian.org/testing/pk4/pk4.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# pk4 ships its own zsh completion via `pk4 -complete` (see Debian/pk4 source).

_pk4() {
    reply=(${(f)"$(=pk4 -complete ${words[@]:1})"})
    compadd -a "$@" reply
}

_pk4
