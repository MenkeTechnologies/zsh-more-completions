#compdef metar_copy
# Documentation: https://confluence.ecmwf.int/display/ECC/metar_copy
# Source: ecmwf/eccodes tools/metar_copy.cc — copy METAR messages by filter (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f[force, do not fail on error]' \
    '-p+[keys to print]:keys:_default' \
    '-P+[append keys to default list]:keys:_default' \
    '-w+[where clause filter]:filter:_default' \
    '(- *)-V[show version]' \
    '-W+[minimum column width]:n:_default' \
    '-T+[message type]:type:(T B M A)' \
    '-7[do not fail on wrong message length]' \
    '*:metar file:_files' \
    && ret=0

return ret
