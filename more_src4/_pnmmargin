#compdef pnmmargin
# Documentation: man pnmmargin (Netpbm)
# Source: add a border of given size and color around a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-white -black -color)-white[white border]' \
    '(-white -black -color)-black[black border]' \
    '(-white -black -color)-color[border color]:colorspec:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:border size in pixels:' \
    '2:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
