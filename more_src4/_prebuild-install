#compdef prebuild-install
# _prebuild-install — download prebuilt native modules from GitHub (prebuild/prebuild-install)
# upstream: https://github.com/prebuild/prebuild-install
# Flags from help.txt.

_prebuild-install() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '(-d --download)'{-d+,--download=}'[prebuild download URL (default GitHub)]:url:' \
        '(-t --target)'{-t+,--target=}'[target version to install for]:ver:' \
        '(-r --runtime)'{-r+,--runtime=}'[Node runtime to install for]:runtime:(node electron node-api napi)' \
        '(-p --path)'{-p+,--path=}'[install path]:dir:_files -/' \
        '(-T --token)'{-T+,--token=}'[GitHub token for private repos]:token:' \
        '--arch=[target CPU architecture]:arch:(x64 ia32 arm arm64 ppc64 s390x)' \
        '--platform=[target platform]:platform:(linux darwin win32 freebsd openbsd sunos aix android)' \
        '--tag-prefix=[GitHub tag prefix (default v)]:prefix:' \
        '--force[always use prebuilt binaries]' \
        '--build-from-source[skip prebuild download]' \
        '--verbose[log verbosely]' \
        '--libc=[libc variant]:libc:(glibc musl)' \
        '--debug[set Debug configuration]'
}

_prebuild-install "$@"
