#compdef objconv
# Documentation: https://www.agner.org/optimize/objconv-instructions.pdf
# Reference accessed: 2026-05-19
# Verified: objconv upstream cmdline.cpp (mirror at
# github.com/tpn/agner/blob/master/objconv/source/cmdline.cpp).
# Real options: -f<format>[ws] output format; -d<flags> dump;
# -v<level> verbosity; -nu+/- underscore mgmt; -nr:old:new
# rename; -np:from:to prefix; -ns:from:to suffix; -nw:sym weaken;
# -nl:sym localize; -nd dot/underscore section mgmt;
# -lib library; -la/-lx/-ld lib member ops; -ls short names;
# -im=BASE imagebase; -wN/-eN warning/error mgmt; -h/-?.
# Corrected from prior file: -d "dump only" was wrong (real
# takes flags like -dfhsrnc); -l "list contents" fabricated;
# -y/-u/-na fabricated; -wd/-we wrong syntax (real is -w<n>/-e<n>).

# objconv: object file converter (Agner Fog)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-\?[show help]' \
  '-fcof[output COFF]' \
  '-fcof32[output COFF 32-bit]' \
  '-fcof64[output COFF 64-bit]' \
  '-fpe[output PE]' \
  '-felf[output ELF]' \
  '-felf32[output ELF 32-bit]' \
  '-felf64[output ELF 64-bit]' \
  '-fmacho[output Mach-O]' \
  '-fmacho32[output Mach-O 32-bit]' \
  '-fmacho64[output Mach-O 64-bit]' \
  '-fomf[output OMF]' \
  '-fasm[disassemble (MASM syntax)]' \
  '-fmasm[disassemble to MASM]' \
  '-fnasm[disassemble to NASM]' \
  '-fyasm[disassemble to YASM]' \
  '-fgas[disassemble to GAS]' \
  '-d-[dump flags (f=hdr h=sects s=syms r=relocs n=strings c=cmts)]:flags:' \
  '-v-[verbosity level]:level:(0 1 2)' \
  '-nu+[add underscores to symbols]' \
  '-nu-[remove underscores from symbols]' \
  '-nr\:[rename symbol]:old\:new:' \
  '-np\:[change name prefix]:from\:to:' \
  '-ns\:[change name suffix]:from\:to:' \
  '-nw\:[weaken symbol]:symbol:' \
  '-nl\:[localize symbol]:symbol:' \
  '-nd[section name dot/underscore conversion]' \
  '-lib[create or manipulate library]' \
  '-la\:[add member to library]:member\:objfile:' \
  '-lx\:[extract member from library]:member:' \
  '-ld\:[delete member from library]:member:' \
  '-ls[use short member names]' \
  '-im=[set image base address]:base:' \
  '-imagebase=[set image base address]:base:' \
  '-w-[warning control]:n:' \
  '-e-[error control]:n:' \
  '*:input output:_files' && ret=0
return ret
