#compdef prealloc
# Documentation: https://github.com/alexkohler/prealloc
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-simple[skip non-trivial]' \
  '-set_exit_status[exit non-zero on findings]' \
  '-rangeloops[check range loops]' \
  '-forloops[check for loops]' \
  '*: :_files' && ret=0

return ret
