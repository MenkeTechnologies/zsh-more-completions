#compdef newfs_fskit
# Documentation: man newfs_fskit(8) on macOS 15+ (FSKit)
# Reference accessed: 2026-05-19
# Verified: local man page on macOS 15 plus `newfs_fskit -h` output.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--progress[display the progress of newfs]' \
  '-t+[file system type]:fstype:(msdos exfat hfs apfs)' \
  '*:device:_files -g "/dev/(r)disk*"' && ret=0

return ret
