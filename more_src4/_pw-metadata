#compdef pw-metadata
# Documentation: https://docs.pipewire.org/page_man_pw-metadata_1.html
# Source: PipeWire metadata key-value CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-r --remote)'{-r+,--remote=}'[remote instance name]:name:' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '(-l --list)'{-l,--list}'[list available metadata objects]' \
    '(-m --monitor)'{-m,--monitor}'[keep running and log changes]' \
    '(-d --delete)'{-d,--delete}'[delete all metadata for id (or for key of id)]' \
    '(-n --name)'{-n+,--name=}'[metadata name (default "default")]:name:' \
    '*:id key value:' \
    && ret=0

return ret
