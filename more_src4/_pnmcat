#compdef pnmcat pamcat
# Documentation: pamcat(1) (Netpbm)
# Source: concatenate Netpbm images left-to-right or top-to-bottom.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-leftright -lr -tb)-topbottom[concatenate vertically]' \
    '(-leftright -lr -tb)-tb[concatenate vertically]' \
    '(-topbottom -tb -lr)-leftright[concatenate horizontally]' \
    '(-topbottom -tb -lr)-lr[concatenate horizontally]' \
    '(-jright -jcenter)-jleft[left-justify in TB concatenation]' \
    '(-jleft -jcenter)-jright[right-justify in TB concatenation]' \
    '(-jbottom -jcenter)-jtop[top-justify in LR concatenation]' \
    '(-jtop -jcenter)-jbottom[bottom-justify in LR concatenation]' \
    '(-jleft -jright -jtop -jbottom)-jcenter[center-justify]' \
    '(-white)-black[pad with black]' \
    '(-black)-white[pad with white]' \
    '-listfile=[file containing input file names]:file:_files' \
    '-pad[allow padding with non-uniform color]' \
    '-extendplane[zero-extend planes to depth]' \
    '-quiet[suppress informational messages]' \
    '-verbose[verbose output]' \
    '*:image:_files' \
    && ret=0

return ret
