#compdef pdftrim
# Documentation: https://github.com/ciffelia/pdftrim
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Source: cargo binstall pdftrim@1.0.2
# Probed via: --generate-completion zsh
# Repository: https://github.com/ciffelia/pdftrim

autoload -U is-at-least

_pdftrim() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--gscmd=[The Ghostscript command to use]:command:_command_names -e' \
'--generate-completion=[If provided, outputs the completion file for given shell and exits]:shell:(bash elvish fish powershell zsh)' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::input -- The input PDF file to crop:_files' \
'::output -- The output PDF file to write:_files' \
&& ret=0
}

(( $+functions[_pdftrim_commands] )) ||
_pdftrim_commands() {
    local commands; commands=()
    _describe -t commands 'pdftrim commands' commands "$@"
}

if [ "$funcstack[1]" = "_pdftrim" ]; then
    _pdftrim "$@"
else
    compdef _pdftrim pdftrim
fi
