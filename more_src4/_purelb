#compdef purelb purelbctl
# _purelb — Acnodal PureLB purelb CLI command-line frontend to PureLB Kubernetes bare-metal load-balancer service implementation supporting Local-mode L2 advertisement Routed-mode BGP-EBGP-iBGP-route-reflector PureNode-PureBGP-allocation IPv4 IPv6 dual-stack address-pool L2 announcer integration with klipper-lb-k3s out-of-cluster (Acnodal team, Go); cobra
# upstream: https://purelb.gitlab.io/

_purelb() {
    local -a sub=(
        'install:install PureLB'
        'uninstall:uninstall PureLB'
        'status:show status'
        'pool:address-pool management'
        'serviceadvertisement:serviceadvertisement management'
        'announcement:announcement operations'
        'logs:fetch logs'
        'config:configuration'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--context=+[ctx]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '-o+[output]:f:(json yaml table wide)' \
        '--output=+[format]:f:(json yaml table wide)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'purelb subcommand' sub ;;
        args)
            case $words[1] in
                pool|serviceadvertisement) _arguments '1:op:(list get create update delete)' '*:name:' ;;
                logs) _arguments \
                    '--component=+[c]:c:(allocator lbnodeagent)' \
                    '-f[follow]' \
                    '--follow[follow]' ;;
            esac
            ;;
    esac
}

_purelb "$@"
