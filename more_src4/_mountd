#compdef mountd
# _mountd — OpenBSD mountd (NFS mount server; consults /etc/exports for which file systems may be mounted by which clients; re-reads exports on SIGHUP)
# upstream: https://github.com/openbsd/src (sbin/mountd)
# Flags from sbin/mountd/mountd.8 on tip.

_mountd() {
    _arguments \
        '-d[debug (foreground + stderr)]' \
        '1:exports file:_files'
}

_mountd "$@"
