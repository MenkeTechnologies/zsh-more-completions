#compdef photorec
# _photorec-bin — PhotoRec file recovery (CGSecurity, ships with TestDisk); recovers ~480 file types from disks/images
# upstream: https://www.cgsecurity.org/wiki/PhotoRec

_photorec-bin() {
    _arguments \
        '/log[create log]' \
        '/debug[debug mode]' \
        '/cmd+[command sequence]:cmd:' \
        '/d+[output dir]:dir:_files -/' \
        '/all[scan all partitions]' \
        '*:image or device:_files'
}

_photorec-bin "$@"
