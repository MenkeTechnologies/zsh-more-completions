#compdef nsd-checkconf
# Documentation: https://nsd.docs.nlnetlabs.nl/en/latest/manpages/nsd-checkconf.html
# Reference accessed: 2026-05-19
# Verified: upstream manpage at the URL above.

_arguments -s \
  '-v[print options to stdout in configfile format]' \
  '-f[print full pathnames when used with files]' \
  '(- *)-h[show help]' \
  '-o+[return a specific option from the config (also: zones, patterns)]:option:' \
  '-z+[zone name (used with -o)]:zone:' \
  '-p+[pattern name (used with -o)]:pattern:' \
  '-s+[print key secret for keyname]:keyname:' \
  '-t+[print tls-auth domain for tlsauthname]:tls-auth:' \
  ':config file:_files'
