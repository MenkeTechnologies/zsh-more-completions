#compdef monokle
# Documentation: https://github.com/kubeshop/monokle-cli
# Reference accessed: 2026-05-19
# Verified: upstream Monokle CLI README documents subcommands and flags.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'validate:validate Kubernetes resources in a given path'
  'init:generate local configuration file'
  'login:login to Monokle Cloud or Enterprise'
  'logout:logout from Monokle Cloud or Enterprise'
  'whoami:show currently authenticated user'
  'config:configuration commands'
  'sync:sync remote configuration locally'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'monokle command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (validate)
        _arguments \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.{yaml,yml,json}"' \
          '(-f --framework)'{-f+,--framework=}'[validation framework]:framework:(pss-restricted pss-baseline nsa)' \
          '--output=[output format]:format:(pretty sarif json yaml)' \
          '(-r --origin)'{-r+,--origin=}'[Monokle Cloud origin URL]:url:' \
          '(-p --project)'{-p+,--project=}'[project id]:id:' \
          '(-t --token)'{-t+,--token=}'[automation token]:token:' \
          '--api-token=[api token]:token:' \
          '--ignore=[ignore globs]:globs:' \
          '*::path:_files -/' && ret=0 ;;
      (login)
        _arguments \
          '--origin=[Monokle Cloud or Enterprise origin URL]:url:' \
          '--method=[auth method]:method:(token sso)' && ret=0 ;;
      (config)
        _arguments \
          '*::sub:(show)' \
          '--origin=[Monokle origin URL]:url:' \
          '*::path:_files -/' && ret=0 ;;
      (init)
        _arguments \
          '(-c --config)'{-c+,--config=}'[output config file]:file:_files' \
          '(-f --framework)'{-f+,--framework=}'[framework]:framework:(pss-restricted pss-baseline nsa)' && ret=0 ;;
    esac ;;
esac

return ret
