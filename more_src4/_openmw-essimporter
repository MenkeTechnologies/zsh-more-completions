#compdef openmw-essimporter
# _openmw-essimporter — convert Morrowind .ess saves to OpenMW .omwsave (OpenMW/openmw)
# upstream: https://github.com/OpenMW/openmw
# Flags from apps/essimporter/main.cpp (boost::program_options).

_openmw-essimporter() {
    _arguments \
        '(- *)'{-h,--help}'[produce help message]' \
        '(-m --mwsave)'{-m+,--mwsave=}'[Morrowind .ess save file]:file:_files' \
        '(-o --output)'{-o+,--output=}'[output file (.omwsave)]:file:_files' \
        '(-c --compare)'{-c,--compare}'[compare two .ess files]' \
        '--encoding=[encoding of the save file]:enc:(win1250 win1251 win1252)' \
        '1:mwsave:_files -g "*.(ess|ESS)"' \
        '2:output:_files'
}

_openmw-essimporter "$@"
