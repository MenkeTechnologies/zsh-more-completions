#compdef melody
# Documentation: https://yoav-lavi.github.io/melody/book/cli.html
# Reference accessed: 2026-05-19
# Verified: upstream Melody book CLI page. Prior file was completely
# wrong — it documented pcap-style flags belonging to a different tool.
# Melody is a regex-language compiler with a small CLI surface.

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-f --test-file)'{-f,--test-file}'=[test compiled regex against file contents]:file:_files' \
  '(-o --output)'{-o,--output}'=[write output to file]:file:_files' \
  '(-t --test)'{-t,--test}'=[test compiled regex against a string]:string:' \
  '(-r --repl)'{-r,--repl}'[start the REPL]' \
  '(-n --no-color)'{-n,--no-color}'[disable colored output]' \
  '--generate-completions=[generate shell completions]:shell:(bash zsh fish powershell elvish)' \
  '*:input file:_files'
