#compdef neomutt-cli
# _neomutt-cli — NeoMutt mutt with extensions terminal mail client CLI alias (neomutt team, C); custom argparse
# upstream: https://github.com/neomutt/neomutt

_neomutt-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-vv[verbose version]' \
        '-A+[alias to expand]:str:' \
        '-a+[attachment]:file:_files' \
        '-b+[bcc]:str:' \
        '-c+[cc]:str:' \
        '-D[dump config]' \
        '-DS[dump config with stats]' \
        '-d+[debug level]:n:' \
        '-E[edit draft]' \
        '-e+[command]:str:' \
        '-F+[muttrc]:file:_files -g "muttrc*"' \
        '-f+[mailbox]:file:_files' \
        '-G[news mode]' \
        '-g+[news server]:host:_hosts' \
        '-H+[draft file]:file:_files' \
        '-i+[include file]:file:_files' \
        '-l+[log file]:file:_files' \
        '-m+[mailbox type]:str:' \
        '-n[no system config]' \
        '-p[resume postponed]' \
        '-Q+[query variable]:str:' \
        '-R[read-only]' \
        '-s+[subject]:str:' \
        '-y[start with browser]' \
        '-Z[check for new mail]' \
        '-z[check for new mail (silent)]' \
        '-O[old config compat]' \
        '*:address:'
}

_neomutt-cli "$@"
