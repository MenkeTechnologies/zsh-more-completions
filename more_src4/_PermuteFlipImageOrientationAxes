#compdef PermuteFlipImageOrientationAxes
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/PermuteFlipImageOrientationAxes.cxx — permute axes / flip orientation (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:ImageDimension:(2 3 4)' \
    '2:inputImageFile:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3:outputImageFile:_files' \
    '4:xperm:(0 1 2 3)' \
    '5:yperm:(0 1 2 3)' \
    '6::zperm (3D only):(0 1 2 3)' \
    '7:xflip:(0 1)' \
    '8:yflip:(0 1)' \
    '9::zflip (3D only):(0 1)' \
    '10::FlipAboutOrigin (default 0):(0 1)' \
    && ret=0

return ret
