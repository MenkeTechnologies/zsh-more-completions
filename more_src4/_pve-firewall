#compdef pve-firewall
# _pve-firewall — Proxmox Server Solutions pve-firewall Proxmox VE host- and guest-level Linux iptables firewall daemon CLI (proxmox team, Perl); custom argparse
# upstream: https://git.proxmox.com/?p=pve-firewall.git

_pve-firewall() {
    local -a sub=(
        'start:start firewall service'
        'stop:stop firewall service'
        'restart:restart firewall service'
        'status:show firewall status'
        'compile:compile and show ruleset'
        'localnet:show local network'
        'simulate:simulate a packet'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '--output-format=+[format]:f:(text json json-pretty)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pve-firewall subcommand' sub ;;
        args)
            case $words[1] in
                simulate) _arguments \
                    '--from=+[from address or alias]:str:' \
                    '--to=+[to address or alias]:str:' \
                    '--dport=+[destination port]:port:_ports' \
                    '--sport=+[source port]:port:_ports' \
                    '--protocol=+[protocol]:p:(tcp udp icmp icmpv6)' \
                    '--vmid=+[VM id]:n:' \
                    '--verbose[verbose]' ;;
            esac
            ;;
    esac
}

_pve-firewall "$@"
