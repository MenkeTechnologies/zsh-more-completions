#compdef pslegend
# Documentation: https://docs.generic-mapping-tools.org/latest/legend.html
# Source: GenericMappingTools/gmt classic-mode pslegend — draw a legend box from a specfile.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-D+[reference point + width/height]:opts:_default' \
    '-B+[basemap frame/axes]:basemap:_default' \
    '-F+[border + fill + pen styling]:opts:_default' \
    '-J+[projection]:proj:_default' \
    '-M+[auto vs explicit legend ordering (modern)]:opts:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-S+[scale all symbol sizes by factor]:factor:_default' \
    '-T+[write hidden legend specfile (modern)]:file:_files' \
    '-U+[GMT timestamp logo]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-X+[X offset of plot origin]:offset:_default' \
    '-Y+[Y offset of plot origin]:offset:_default' \
    '-K[multi-page: more pages follow]' \
    '-O[multi-page: this is overlay]' \
    '-P[portrait orientation]' \
    '-p+[perspective view]:perspective:_default' \
    '-qi+[input row selection]:opts:_default' \
    '-t+[transparency percent]:pct:_default' \
    '*:specfile:_files' \
    && ret=0

return ret
