#compdef pnmtile
# Documentation: man pnmtile (Netpbm)
# Source: tile a small Netpbm image into a larger one of given dimensions.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:width:' \
    '2:height:' \
    '3:tile pnm:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
