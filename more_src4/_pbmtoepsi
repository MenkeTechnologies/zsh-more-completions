#compdef pbmtoepsi
# Documentation: man pbmtoepsi (Netpbm)
# Source: convert a PBM image to an Encapsulated PostScript Interchange preview.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-dpi=[output resolution N or NxN]:dpi:' \
    '-bbonly[print bounding box only]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pbm file:_files -g "*.(pbm|pnm|pam)"' \
    && ret=0

return ret
