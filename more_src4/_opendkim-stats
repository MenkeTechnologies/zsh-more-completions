#compdef opendkim-stats
# Documentation: https://manpages.debian.org/bookworm/opendkim-tools/opendkim-stats.8.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm opendkim-stats(8) manpage - no options, single
# positional file arg.

# opendkim-stats: display OpenDKIM statistics database
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:database file:_files' && ret=0
return ret
