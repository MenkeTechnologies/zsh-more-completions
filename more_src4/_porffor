#compdef porffor porf
# Documentation: https://github.com/CanadaHonk/porffor (runtime/index.js argv scanner)
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'run:execute a script (explicit variant)'
  'wasm:compile to a Wasm binary'
  'c:compile to C source code'
  'native:compile to a native binary'
  'lambda:compile lambda code to a deployable zip'
  'profile:view detailed func-by-func performance'
  'debug:debug the source of a file'
  'precompile:internal compiler precompilation'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help (use --help all for niche flags)]' \
  '(-O0 -O1 -O2 -O3)-O0[optimization level 0]' \
  '(-O0 -O1 -O2 -O3)-O1[optimization level 1]' \
  '(-O0 -O1 -O2 -O3)-O2[optimization level 2]' \
  '(-O0 -O1 -O2 -O3)-O3[optimization level 3]' \
  '-t[parse input as TypeScript]' \
  '-d[debug mode]' \
  '--module[parse as module]' \
  '--secure[strict mode (block unsafe features)]' \
  '(-e --eval)'{-e,--eval=}'[evaluate inline code]:code:' \
  '(-p --print)'{-p,--print=}'[evaluate and print result]:code:' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _alternative \
      'commands:porffor subcommand:(($_subcmds))' \
      'files:input file:_files -g "*.(js|ts|mjs|cjs)"' && ret=0
    ;;
  args)
    case $line[1] in
      run|wasm|c|native|lambda|profile|debug|precompile)
        _files -g '*.(js|ts|mjs|cjs)' && ret=0
        ;;
    esac
    ;;
esac

return ret
