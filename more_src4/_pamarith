#compdef pamarith pnmarith
# Documentation: man pamarith (Netpbm)
# Source: pixel-wise arithmetic / logical operation between two or more Netpbm images.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-add -subtract -multiply -divide -difference -minimum -maximum -mean -equal -compare -and -or -nand -nor -xor -shiftleft -shiftright)-add[pixel addition]' \
    '(-add -subtract -multiply -divide -difference -minimum -maximum -mean -equal -compare -and -or -nand -nor -xor -shiftleft -shiftright)-subtract[pixel subtraction]' \
    '(-add -subtract -multiply -divide -difference -minimum -maximum -mean -equal -compare -and -or -nand -nor -xor -shiftleft -shiftright)-multiply[pixel multiplication]' \
    '(-add -subtract -multiply -divide -difference -minimum -maximum -mean -equal -compare -and -or -nand -nor -xor -shiftleft -shiftright)-divide[pixel division]' \
    '(-add -subtract -multiply -divide -difference -minimum -maximum -mean -equal -compare -and -or -nand -nor -xor -shiftleft -shiftright)-difference[absolute difference]' \
    '(-add -subtract -multiply -divide -difference -minimum -maximum -mean -equal -compare -and -or -nand -nor -xor -shiftleft -shiftright)-minimum[per-pixel minimum]' \
    '(-add -subtract -multiply -divide -difference -minimum -maximum -mean -equal -compare -and -or -nand -nor -xor -shiftleft -shiftright)-maximum[per-pixel maximum]' \
    '(-add -subtract -multiply -divide -difference -minimum -maximum -mean -equal -compare -and -or -nand -nor -xor -shiftleft -shiftright)-mean[per-pixel mean]' \
    '(-add -subtract -multiply -divide -difference -minimum -maximum -mean -equal -compare -and -or -nand -nor -xor -shiftleft -shiftright)-equal[per-pixel equality test]' \
    '(-add -subtract -multiply -divide -difference -minimum -maximum -mean -equal -compare -and -or -nand -nor -xor -shiftleft -shiftright)-compare[per-pixel comparison]' \
    '(-add -subtract -multiply -divide -difference -minimum -maximum -mean -equal -compare -and -or -nand -nor -xor -shiftleft -shiftright)-and[bitwise AND]' \
    '(-add -subtract -multiply -divide -difference -minimum -maximum -mean -equal -compare -and -or -nand -nor -xor -shiftleft -shiftright)-or[bitwise OR]' \
    '(-add -subtract -multiply -divide -difference -minimum -maximum -mean -equal -compare -and -or -nand -nor -xor -shiftleft -shiftright)-nand[bitwise NAND]' \
    '(-add -subtract -multiply -divide -difference -minimum -maximum -mean -equal -compare -and -or -nand -nor -xor -shiftleft -shiftright)-nor[bitwise NOR]' \
    '(-add -subtract -multiply -divide -difference -minimum -maximum -mean -equal -compare -and -or -nand -nor -xor -shiftleft -shiftright)-xor[bitwise XOR]' \
    '(-add -subtract -multiply -divide -difference -minimum -maximum -mean -equal -compare -and -or -nand -nor -xor -shiftleft -shiftright)-shiftleft[bitwise shift left]' \
    '(-add -subtract -multiply -divide -difference -minimum -maximum -mean -equal -compare -and -or -nand -nor -xor -shiftleft -shiftright)-shiftright[bitwise shift right]' \
    '-closeness=[match-closeness for -equal/-compare]:n:' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:netpbm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
