#compdef pamtotiff
# Documentation: man pamtotiff (Netpbm)
# Source: convert a Netpbm PAM/PNM to TIFF.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-none -packbits -lzw -g3 -g4 -flate -adobeflate)-none[no compression]' \
    '(-none -packbits -lzw -g3 -g4 -flate -adobeflate)-packbits[PackBits compression]' \
    '(-none -packbits -lzw -g3 -g4 -flate -adobeflate)-lzw[LZW compression]' \
    '(-none -packbits -lzw -g3 -g4 -flate -adobeflate)-g3[CCITT Group 3 compression]' \
    '(-none -packbits -lzw -g3 -g4 -flate -adobeflate)-g4[CCITT Group 4 compression]' \
    '(-none -packbits -lzw -g3 -g4 -flate -adobeflate)-flate[Deflate compression]' \
    '(-none -packbits -lzw -g3 -g4 -flate -adobeflate)-adobeflate[Adobe Deflate compression]' \
    '-2d[use 2D coding (with g3)]' \
    '-fill[byte-fill each scanline (with g3)]' \
    '-predictor=[LZW/Flate predictor]:n:' \
    '(-msb2lsb -lsb2msb)-msb2lsb[fill MSB to LSB]' \
    '(-msb2lsb -lsb2msb)-lsb2msb[fill LSB to MSB]' \
    '-rowsperstrip=[rows per strip]:n:' \
    '(-minisblack -miniswhite -mb -mw)-minisblack[MinIsBlack photometric]' \
    '(-minisblack -miniswhite -mb -mw)-miniswhite[MinIsWhite photometric]' \
    '(-minisblack -miniswhite -mb -mw)-mb[same as -minisblack]' \
    '(-minisblack -miniswhite -mb -mw)-mw[same as -miniswhite]' \
    '-truecolor[write a TrueColor TIFF]' \
    '-color[write a color TIFF]' \
    '-indexbits=[bit widths for palette indices]:list:' \
    '-xresolution=[horizontal resolution]:xres:' \
    '-yresolution=[vertical resolution]:yres:' \
    '-resolutionunit=[resolution unit]:unit:(inch centimeter none in cm no)' \
    '-append[append to existing TIFF]' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:pam/pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
