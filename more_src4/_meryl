#compdef meryl
# _meryl — Brian Walenz meryl CLI k-mer counter and database manipulation tool from the Celera Assembler ecosystem producing canonical-k-mer indexed databases supporting union intersection difference greater-than less-than print histogram operations for trio-binning Merqury VerityMap PacBio HiFi assembly QC (Brian Walenz team, C++); custom argparse
# upstream: https://github.com/marbl/meryl

_meryl() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-q[quiet]' \
        '-V[verbose]' \
        '-t+[threads]:n:' \
        '--threads=+[N]:n:' \
        '-m+[memory GB]:n:' \
        '--memory=+[GB]:n:' \
        '-k+[kmer size]:n:' \
        '-s+[segments]:n:' \
        '--segments=+[N]:n:' \
        '-o+[output db]:file:_files -g "*.meryl"' \
        '--output=+[db]:file:_files -g "*.meryl"' \
        '*:cmd:(count count-forward count-reverse less-than greater-than equal-to not-equal-to at-least at-most divide-round divide-frac divide multiply min max add subtract intersect union difference symmetric-difference union-sum union-max union-min print printout statistics dumpProperties stats histogram print-frequency print-mers print-pair compare nearest-distinct increasing decreasing)'
}

_meryl "$@"
