#compdef nk2info
# Documentation: https://github.com/libyal/libnk2
# Source: libyal/libnk2 manuals/nk2info.1 — display info about a Microsoft Outlook Nickname (NK2) auto-complete file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[show allocation information]' \
    '-h[show help]' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '*:.nk2 file:_files' \
    && ret=0

return ret
