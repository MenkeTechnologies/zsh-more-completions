#compdef mondoo
# Documentation: https://mondoo.com/docs/cnspec/cli/
# Zsh completion for Mondoo CLI — security and compliance platform.

_mondoo() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a global_flags
    global_flags=(
        '(-h --help)'{-h,--help}'[show help]'
        '(-c --config)'{-c+,--config=}'[config file path]:path:_files'
        '--log-level=[set log level]:level:(error warn info debug trace)'
        '--api-proxy=[proxy URL for API calls]:url:'
        '--auto-update[enable automatic updates]'
        '--no-colors[disable colored output]'
    )

    _arguments -C \
        $global_flags \
        '1: :_mondoo_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                scan)
                    _arguments -s -S \
                        $global_flags \
                        '(-p --policy)'{-p+,--policy=}'[specify policy to run]:policy:' \
                        '--policy-bundle=[path to policy bundle file]:path:_files' \
                        '(-o --output)'{-o+,--output=}'[output format]:format:(compact full json csv yaml junit report)' \
                        '--score-threshold=[minimum score threshold (0-100)]:score:' \
                        '--asset-name=[override asset name]:name:' \
                        '--annotation=[add annotation]:key=value:' \
                        '--props=[set property value]:key=value:' \
                        '--inventory-file=[inventory file path]:path:_files' \
                        '--detect-cicd[detect CI/CD environment]' \
                        '--incognito[run without sending data to Mondoo Platform]' \
                        '(-t --target)'{-t+,--target=}'[connection target]:target:' && ret=0
                    ;;
                shell)
                    _arguments -s -S \
                        $global_flags \
                        '(-t --target)'{-t+,--target=}'[connection target]:target:' \
                        '(-c --command)'{-c+,--command=}'[execute command]:command:' && ret=0
                    ;;
                login)
                    _arguments -s -S \
                        $global_flags \
                        '(-t --token)'{-t+,--token=}'[authentication token]:token:' \
                        '--registration-token=[registration token]:token:' && ret=0
                    ;;
                logout|status|version|serve|migrate)
                    _arguments -s -S $global_flags && ret=0
                    ;;
                vault)
                    _arguments -s -S \
                        $global_flags \
                        '*:args:' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_mondoo_commands] )) ||
_mondoo_commands() {
    local -a commands
    commands=(
        'scan:scan a target for vulnerabilities and misconfigurations'
        'shell:interactive security shell'
        'login:log in to Mondoo Platform'
        'logout:log out from Mondoo Platform'
        'status:display status of Mondoo client'
        'version:display version'
        'serve:start the Mondoo API server'
        'migrate:migrate Mondoo client configuration'
        'vault:manage vault configuration'
    )
    _describe -t commands 'mondoo command' commands
}

_mondoo "$@"
