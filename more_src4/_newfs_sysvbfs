#compdef newfs_sysvbfs
# Documentation: man newfs_sysvbfs(8)
# Source: netbsd/src sbin/newfs_sysvbfs — construct a System V Boot File System (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-F[create file system to a regular file]' \
    '-s+[file system size in disk sectors]:sectors:_default' \
    '-Z[fill with zeroes instead of sparse file]' \
    '1:special device:_files' \
    && ret=0

return ret
