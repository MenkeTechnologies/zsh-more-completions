#compdef mutmut
# Documentation: https://mutmut.readthedocs.io/en/latest/
# Reference accessed: 2026-05-19
# Verified: upstream mutmut documentation at the URL above (subcommands
# run, results, show, apply, browse, export-cicd-stats,
# print-time-estimates, tests-for-mutant).

# boxed/mutmut mutation testing — subcommands differ; flags mostly live on `run`.

if (( CURRENT == 1 )); then
  _values 'mutmut command' \
    run results show apply browse export-cicd-stats print-time-estimates tests-for-mutant
  return
fi

case $words[1] in
  run)
    _arguments -s -S \
      '--max-children=[parallel workers]:int:' \
      '*:mutant filter globs:_default'
    ;;
  results)
    _arguments -s -S '--all[include killed mutants]'
    ;;
  show|apply)
    _arguments -s -S '1:mutant name:_default'
    ;;
  browse)
    _arguments -s -S '--show-killed[include killed in UI]'
    ;;
  print-time-estimates)
    _arguments -s -S '*:mutant patterns:_default'
    ;;
  tests-for-mutant)
    _arguments -s -S '1:mutant name:_default'
    ;;
  export-cicd-stats)
    _message -e 'exports mutants/mutmut-cicd-stats.json after a run'
    ;;
  *)
    _default
    ;;
esac
