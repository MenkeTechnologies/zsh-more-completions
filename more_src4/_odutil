#compdef odutil
# Documentation: odutil(1) macOS manpage
# Reference accessed: 2026-05-19
# Verified: macOS odutil(1) man page (Darwin 25.4.0 system).

local curcontext="$curcontext" state line ret=1
local -a verbs

verbs=(
  'show:show OpenDirectory state'
  'set:set OpenDirectory configuration'
  'reset:reset OpenDirectory state'
)

_arguments -C \
  '1: :->verb' \
  '*::arg:->args' && ret=0

case $state in
  (verb)
    _describe -t verbs 'odutil verb' verbs && ret=0
    ;;
  (args)
    case $line[1] in
      (show)
        _values 'show target' \
          'cache' 'sessions' 'nodes' 'modules' 'requests' \
          'nodenames' 'statistics' 'all' 'configuration' && ret=0
        ;;
      (set)
        _values 'set target' 'log' 'statistics' 'configuration' && ret=0
        ;;
      (reset)
        _values 'reset target' 'cache' 'statistics' && ret=0
        ;;
    esac
    ;;
esac

return ret
