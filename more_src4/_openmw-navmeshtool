#compdef openmw-navmeshtool
# _openmw-navmeshtool — pre-generate navmesh database for OpenMW (OpenMW/openmw)
# upstream: https://github.com/OpenMW/openmw
# Flags from apps/navmeshtool/main.cpp (boost::program_options).

_openmw-navmeshtool() {
    _arguments \
        '--help[print help message]' \
        '--version[print version information and quit]' \
        '*--data=[set data directories]:dir:_files -/' \
        '--data-local=[set local data directory (highest priority)]:dir:_files -/' \
        '*--fallback-archive=[fallback archive (bsa)]:archive:' \
        '*--content=[content file(s): esm/esp/omwgame/omwaddon/omwscripts]:file:_files' \
        '--encoding=[character encoding for OpenMW messages]:enc:(win1250 win1251 win1252)' \
        '*--fallback=[fallback config entries]:kv:' \
        '--threads=[number of threads for parallel processing]:n:' \
        '--process-interior-cells[build navmesh for interior cells]' \
        '--remove-unused-tiles[remove unused tiles from cache]' \
        '--write-binary-log[write progress in binary messages for the launcher]' \
        '--collect-stats[collect statistics for generated navmesh tiles]' \
        '--worldspace-filter=[regex to filter worldspaces]:regex:'
}

_openmw-navmeshtool "$@"
