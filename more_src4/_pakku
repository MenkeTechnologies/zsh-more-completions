#compdef pakku
# Documentation: https://github.com/kitsunyan/pakku/blob/master/src/pacman.nim
# Documentation: https://github.com/kitsunyan/pakku/blob/master/doc/pakku.8.txt
# Reference accessed: 2026-05-27
# Verified: upstream src/pacman.nim option tables (commonOptions, transactionOptions,
# upgradeOptions, queryOptions, removeOptions, syncOptions, databaseOptions,
# filesOptions, syncConflictingOptions) and main.nim handleSync flag handling.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-D --database)'{-D,--database}'[operate on package database]' \
  '(-F --files)'{-F,--files}'[operate on package files]' \
  '(-Q --query)'{-Q,--query}'[query installed packages]' \
  '(-R --remove)'{-R,--remove}'[remove packages from the system]' \
  '(-S --sync)'{-S,--sync}'[synchronize packages from sync repositories and the AUR]' \
  '(-T --deptest)'{-T,--deptest}'[check dependencies are satisfied]' \
  '(-U --upgrade)'{-U,--upgrade}'[install packages from local files]' \
  '(- *)'{-V,--version}'[display version and exit]' \
  '(-h --help)'{-h,--help}'[show help for the current operation]' \
  '(-b --dbpath)'{-b+,--dbpath=}'[set alternate database location]:directory:_directories' \
  '(-r --root)'{-r+,--root=}'[set alternate installation root]:directory:_directories' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--arch=[set alternate architecture]:arch:' \
  '*--cachedir=[set alternate package cache location]:directory:_directories' \
  '--color=[colorize output]:when:(always never auto)' \
  '--config=[set alternate config file]:file:_files' \
  '--debug[display debug messages]' \
  '--disable-download-timeout[use a longer connection timeout]' \
  '--gpgdir=[set alternate GnuPG directory]:directory:_directories' \
  '*--hookdir=[set alternate hook location]:directory:_directories' \
  '--logfile=[set alternate log file]:file:_files' \
  '--noconfirm[do not ask for any confirmation]' \
  '--confirm[always ask for confirmation]' \
  '--sysroot=[operate on a mounted guest system]:directory:_directories' \
  '--ask=[pre-specify answers to questions]:number:' \
  '(-d --nodeps)'{-d,--nodeps}'[skip dependency version checks (-dd to skip all)]' \
  '*--assume-installed=[add virtual package to satisfy dependencies]:package:' \
  '--dbonly[only modify database entries, not package files]' \
  '--noprogressbar[do not show progress bar when downloading files]' \
  '--noscriptlet[do not execute install scriptlet]' \
  '(-p --print)'{-p,--print}'[print targets instead of performing the operation]' \
  '--print-format=[specify format for the output of --print]:format:' \
  '--force[bypass file conflict checks (use with care)]' \
  '--asdeps[install packages as non-explicitly installed]' \
  '--asexplicit[install packages as explicitly installed]' \
  '*--ignore=[ignore a package upgrade (comma-separated)]:package:' \
  '*--ignoregroup=[ignore a group upgrade (comma-separated)]:group:' \
  '--needed[do not reinstall up-to-date packages]' \
  '*--overwrite=[overwrite conflicting files (glob)]:glob:' \
  '(-c --changelog)'{-c,--changelog}'[(Q) view changelog for a package]' \
  '(-e --explicit)'{-e,--explicit}'[(Q) list explicitly installed packages]' \
  '(-g --groups)'{-g,--groups}'[view all members of a package group]' \
  '(-i --info)'{-i,--info}'[view package information]' \
  '(-k --check)'{-k,--check}'[(Q/D) check package integrity]' \
  '(-l --list)'{-l,--list}'[list files owned by the queried package]' \
  '(-m --foreign)'{-m,--foreign}'[(Q) list packages without a sync repo]' \
  '(-n --native)'{-n,--native}'[(Q) list installed packages only found in sync db]' \
  '(-o --owns)'{-o,--owns}'[query the package that owns a file]' \
  '--file[(Q) file is a path to a package file]' \
  '(-q --quiet)'{-q,--quiet}'[show less information for query and search]' \
  '(-s --search)'{-s,--search}'[search remote/local repositories for matching strings]' \
  '*'{-t,--unrequired}'[(Q) list packages not required by any other package]' \
  '(-u --upgrades --sysupgrade)'{-u,--upgrades,--sysupgrade}'[(Q/S) list/install package upgrades]' \
  '--cascade[(R) remove packages and all packages that depend on them]' \
  '--nosave[(R) remove configuration files]' \
  '--recursive[(R) remove unneeded dependencies]' \
  '--unneeded[(R) only remove targets not required by other packages]' \
  '--clean[(S) remove old packages from cache (-cc clears all)]' \
  '(-w --downloadonly)'{-w,--downloadonly}'[(S) download packages but do not install/upgrade]' \
  '(-y --refresh)'{-y,--refresh}'[(S) download fresh package databases]' \
  '--build[(S) build targets from source (pakku/AUR)]' \
  '--keyserver=[(S) use specified keyserver for PGP key retrieval]:keyserver:' \
  '--noaur[(S) disable all AUR operations]' \
  '(-z --source)'{-z,--source}'[(S) retrieve PKGBUILD source]' \
  '*--regex[(F) interpret each query as a regex]' \
  '--machinereadable[(F) produce machine-readable output]' \
  '*:package:' && ret=0

return ret
