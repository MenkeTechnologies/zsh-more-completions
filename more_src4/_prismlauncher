#compdef prismlauncher prism-launcher
# Documentation: https://github.com/PrismLauncher/PrismLauncher/blob/develop/launcher/Application.cpp
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --dir)'{-d+,--dir=}'[use a custom path as application root]:directory:_files -/' \
  '(-l --launch)'{-l+,--launch=}'[launch the specified instance by instance ID]:instance' \
  '(-s --server)'{-s+,--server=}'[join the specified server on launch]:address' \
  '(-w --world)'{-w+,--world=}'[join the specified world on launch]:world' \
  '(-a --profile)'{-a+,--profile=}'[use the account specified by profile name]:profile' \
  '(-o --offline)'{-o+,--offline=}'[launch offline with player name]:offline name' \
  '--alive[write a launch-alive file after the launcher starts]' \
  '--show-window[show the main launcher window]' \
  '(-I --import)'{-I+,--import=}'[import instance or resource from local path or URL]:url:_files' \
  '--show=[open the window for the specified instance by ID]:instance' \
  '*:URL:_files' && ret=0

return ret
