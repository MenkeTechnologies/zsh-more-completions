#compdef plaympeg
# Documentation: plaympeg --help (SMPEG)
# Source: SDL MPEG video/audio player.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '--noaudio[do not play audio stream]' \
    '--novideo[do not play video stream]' \
    '--fullscreen[play in fullscreen mode]' \
    '(-2 --double)'{-2,--double}'[play at double size]' \
    '(-l --loop)'{-l,--loop}'[loop playback]' \
    '--bilinear[use software bilinear filtering]' \
    {-v+,--volume=}'[audio volume 0-100]:volume:' \
    {-t+,--title=}'[window title]:title:' \
    {-s+,--scale=}'[play at WxH resolution]:resolution:' \
    {-S+,--seek=}'[skip N bytes]:n:' \
    '*:mpeg file:_files -g "*.(mpg|mpeg|m1v|m2v|mp2|mp3)"' \
    && ret=0

return ret
