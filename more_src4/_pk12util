#compdef pk12util
# Documentation: man pk12util(1)
# Source: nss-dev/nss cmd/pk12util/pk12util.c (master) — NSS PKCS#12 import/export utility (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d+[NSS certificate database directory]:dir:_files -/' \
    '-h+[token name]:token:_default' \
    '-i+[import p12 file]:p12file:_files -g "*.{p12,pfx}"' \
    '-l+[list p12 file contents]:p12file:_files -g "*.{p12,pfx}"' \
    '-o+[export to p12 file]:p12file:_files -g "*.{p12,pfx}"' \
    '-n+[nickname of cert to export]:nickname:_default' \
    '-k+[file containing slot password]:file:_files' \
    '-K+[slot password literal]:password:_default' \
    '-w+[file containing p12 file password]:file:_files' \
    '-W+[p12 file password literal]:password:_default' \
    '-P+[database prefix]:prefix:_default' \
    '-r[raw print]' \
    '-c+[key encryption cipher]:cipher:(PKCS12V2PBEWithSHA1AndDESTripleCBC AES-128-CBC AES-256-CBC)' \
    '-C+[certificate encryption cipher]:cipher:(PKCS12V2PBEWithSHA1AndRC2CBC AES-128-CBC AES-256-CBC)' \
    '-M+[MAC algorithm]:algo:(SHA-1 SHA-256 SHA-384 SHA-512)' \
    '(-m --key_len)'{-m+,--key_len=}'[key length]:len:_default' \
    '--cert_key_len=[cert key length]:len:_default' \
    '-I[ignore integrity check]' \
    '-v[verbose]' \
    && ret=0

return ret
