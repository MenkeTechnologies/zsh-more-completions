#compdef mkpasswd-cli
# _mkpasswd-cli — Marco d'Itri mkpasswd password generator/hasher CLI alias (whois team, C); custom argparse
# upstream: https://github.com/rfc1036/whois

_mkpasswd-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-m+[method]:m:(bcrypt-a bcrypt-b bcrypt sha-512 sha-256 md5 des sunmd5 nt yescrypt gost-yescrypt scrypt)' \
        '--method=+[method]:m:(bcrypt-a bcrypt-b bcrypt sha-512 sha-256 md5 des sunmd5 nt yescrypt gost-yescrypt scrypt)' \
        '-5[md5 method]' \
        '-S+[salt]:str:' \
        '--salt=+[salt]:str:' \
        '-R+[rounds]:n:' \
        '--rounds=+[rounds]:n:' \
        '-P+[fd to read password from]:n:' \
        '--password-fd=+[fd to read password from]:n:' \
        '-s[read password from stdin]' \
        '--stdin[read password from stdin]' \
        '*:password:'
}

_mkpasswd-cli "$@"
