#compdef psvelo
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/geodesy/psvelo.html
# Source: GenericMappingTools/gmt supplements/geodesy — plot GPS velocity vectors / strain crosses / anisotropy bars.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-J+[projection]:proj:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-S+[symbol type + scaling (ellipse/anisotropy/wedge/cross)]:symbol:_default' \
    '-A+[vector head params]:opts:_default' \
    '-B+[basemap frame/axes]:basemap:_default' \
    '-C+[CPT for symbol coloring]:cpt:_files -g "*.cpt(-.)"' \
    '-D+[rescale uncertainty values]:scale:_default' \
    '-E+[uncertainty-region fill]:color:_default' \
    '-G+[symbol fill]:color:_default' \
    '-H+[per-record symbol scaling]:opts:_default' \
    '-I+[intensity modulation]:value:_default' \
    '-L[draw ellipse/wedge outlines]' \
    '-N[plot outside frame]' \
    '-U+[GMT timestamp logo]:opts:_default' \
    '-W+[arrow/edge pen]:pen:_default' \
    '-X+[X offset of plot origin]:offset:_default' \
    '-Y+[Y offset of plot origin]:offset:_default' \
    '-Z+[CPT lookup quantity]:opts:_default' \
    '-K[multi-page: more pages follow]' \
    '-O[multi-page: this is overlay]' \
    '-P[portrait orientation]' \
    '*-V[verbose (stackable)]' \
    '-di+[nodata replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-t+[transparency percent]:pct:_default' \
    '-:[swap first two columns]' \
    '*:input table:_files' \
    && ret=0

return ret
