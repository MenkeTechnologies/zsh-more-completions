#compdef papertrail-cli papertrail
# _papertrail-cli — SolarWinds Papertrail papertrail-cli CLI command-line frontend wrapping the Papertrail cloud-hosted log management aggregation search syslog forwarding platform CLI providing search tail saved-search system group account create archive role user destination event-detail historical-search real-time-tail follow-color time-range min-time max-time delay grep-pattern (SolarWinds Papertrail team, Ruby); custom argparse
# upstream: https://www.papertrail.com/

_papertrail-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g ".papertrail.yml *.yml"' \
        '--configfile=+[file]:file:_files -g ".papertrail.yml *.yml"' \
        '-f[follow tail]' \
        '--follow[follow tail]' \
        '--color=+[c]:c:(auto on off)' \
        '--force-color[force color]' \
        '-d+[delay sec]:n:' \
        '--delay=+[sec]:n:' \
        '-s+[search id]:str:' \
        '--search=+[id]:str:' \
        '-g+[group name]:str:' \
        '--group=+[name]:str:' \
        '-S+[system name]:str:' \
        '--system=+[name]:str:' \
        '--min-time=+[ts]:str:' \
        '--max-time=+[ts]:str:' \
        '--min-id=+[id]:str:' \
        '--max-id=+[id]:str:' \
        '-j[output JSON]' \
        '--json[JSON output]' \
        '--token=+[token]:str:' \
        '--api-url=+[url]:str:' \
        '*:search query:'
}

_papertrail-cli "$@"
