#compdef mpdcleanup
# Documentation: https://www.mpich.org/documentation/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Note: mpdcleanup is part of MPICH (parallel computing MPD process manager),
#   NOT Music Player Daemon. Minimal stub — STUB.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-a[kill all MPD processes]' \
  '*::mpdcleanup args:_files' && ret=0
return ret
