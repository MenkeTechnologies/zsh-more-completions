#compdef pdf2dcm
# Documentation: https://support.dcmtk.org/docs-snapshot/pdf2dcm.html
# Documentation: https://github.com/DCMTK/dcmtk/blob/master/dcmdata/apps/pdf2dcm.cc
# Reference accessed: 2026-05-27
# Verified: upstream DCMTK dcmdata/apps/pdf2dcm.cc (proxy stub) + dcmdata/libsrc/dcencdoc.cc
# (DcmEncapsulatedDocument::addCommandlineOptions) + docs/man/pdf2dcm.man.
# pdf2dcm is a deprecated proxy that prepends --filetype-pdf and invokes dcmencap;
# all dcmencap command line options apply.

local -a _log_levels
_log_levels=(fatal error warn info debug trace)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help text and exit]' \
  '--version[print version information and exit]' \
  '--arguments[print expanded command line arguments]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, print no warnings and errors]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode, print processing details]' \
  '(-d --debug)'{-d,--debug}'[debug mode, print debug information]' \
  '(-ll --log-level)'{-ll+,--log-level=}'[set logger level]:level:('"${_log_levels[*]}"')' \
  '(-lc --log-config)'{-lc+,--log-config=}'[use logger config file]:file:_files' \
  '(+fa --filetype-auto)'{+fa,--filetype-auto}'[automatically determine file type (default)]' \
  '(+fp --filetype-pdf)'{+fp,--filetype-pdf}'[expect PDF file]' \
  '(+fc --filetype-cda)'{+fc,--filetype-cda}'[expect CDA file]' \
  '(+fs --filetype-stl)'{+fs,--filetype-stl}'[expect STL file]' \
  '(+fm --filetype-mtl)'{+fm,--filetype-mtl}'[expect MTL file]' \
  '(+fo --filetype-obj)'{+fo,--filetype-obj}'[expect OBJ file]' \
  '(+t --title)'{+t+,--title=}'[document title (default: empty)]:title:' \
  '(+cn --concept-name)'{+cn+,--concept-name=}'[document title as coded entry: CSD CV CM]:CSD CV CM:' \
  '(+pn --patient-name)'{+pn+,--patient-name=}'[patient name in DICOM PN syntax]:name:' \
  '(+pi --patient-id)'{+pi+,--patient-id=}'[patient identifier]:id:' \
  '(+pb --patient-birthdate)'{+pb+,--patient-birthdate=}'[patient birth date YYYYMMDD]:date:' \
  '(+ps --patient-sex)'{+ps+,--patient-sex=}'[patient sex]:sex:(M F O)' \
  '(+mn --manufacturer)'{+mn+,--manufacturer=}'[manufacturer name]:name:' \
  '(+mm --manufacturer-model)'{+mm+,--manufacturer-model=}'[manufacturer model name]:name:' \
  '(+ds --device-serial)'{+ds+,--device-serial=}'[device serial number]:number:' \
  '(+sv --software-versions)'{+sv+,--software-versions=}'[software versions]:versions:' \
  '(+mu --measurement-units)'{+mu+,--measurement-units=}'[measurement units as coded entry: CSD CV CM]:CSD CV CM:' \
  '(+sg --generate)'{+sg,--generate}'[generate new study and series UIDs (default)]' \
  '(+st --study-from)'{+st+,--study-from=}'[read patient/study data from DICOM file]:file:_files' \
  '(+se --series-from)'{+se+,--series-from=}'[read patient/study/series data from DICOM file]:file:_files' \
  '(+i1 --instance-one)'{+i1,--instance-one}'[use instance number 1 (default, not with +se)]' \
  '(+ii --instance-inc)'{+ii,--instance-inc}'[increment instance number (only with +se)]' \
  '(+is --instance-set)'{+is+,--instance-set=}'[use specified instance number]:instance number:' \
  '(+an --annotation-yes)'{+an,--annotation-yes}'[document contains patient identifying data (default)]' \
  '(-an --annotation-no)'{-an,--annotation-no}'[document does not contain patient identifying data]' \
  '(-ov --no-override)'{-ov,--no-override}'[CDA data must match study/series/manual info (default)]' \
  '(+ov --override)'{+ov,--override}'[overwrite CDA data with study/series/manual info]' \
  '*'{-k+,--key=}'[add further attribute]:gggg,eeee="str" or dict name="str":' \
  '(+te --write-xfer-little)'{+te,--write-xfer-little}'[write with explicit VR little endian (default)]' \
  '(+tb --write-xfer-big)'{+tb,--write-xfer-big}'[write with explicit VR big endian TS]' \
  '(+ti --write-xfer-implicit)'{+ti,--write-xfer-implicit}'[write with implicit VR little endian TS]' \
  '(-g --group-length-remove)'{-g,--group-length-remove}'[write without group length elements (default)]' \
  '(+g --group-length-create)'{+g,--group-length-create}'[write with group length elements]' \
  '(+e --length-explicit)'{+e,--length-explicit}'[write with explicit lengths (default)]' \
  '(-e --length-undefined)'{-e,--length-undefined}'[write with undefined lengths]' \
  '(-p= --padding-retain)'{-p=,--padding-retain}'[do not change padding (default)]' \
  '(-p --padding-off)'{-p,--padding-off}'[no padding (implicit if --write-dataset)]' \
  '(+p --padding-create)'{+p+,--padding-create=}'[align file and items on specified byte multiples]:file-pad and item-pad:' \
  '1:pdffile-in:_files -g "*.(pdf|PDF)"' \
  '2:dcmfile-out:_files'
