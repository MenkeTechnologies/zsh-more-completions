#compdef pelican-import
# Documentation: https://github.com/getpelican/pelican/blob/main/pelican/tools/pelican_import.py
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '--blogger[Blogger XML export]' \
  '--dotclear[Dotclear export]' \
  '--medium[Medium export]' \
  '--tumblr[Tumblr API]' \
  '--wpfile[WordPress XML export]' \
  '--feed[feed to parse]' \
  '(-o --output)'{-o,--output=}'[output path]:dir:_files -/' \
  '(-m --markup)'{-m,--markup=}'[output markup]:markup:(rst markdown)' \
  '--dir-cat[place files in category dirs]' \
  '--dir-page[place pages in pages/ subdir]' \
  '--filter-author=[only import from author]:author:' \
  '--strip-raw[strip raw HTML]' \
  '--wp-custpost[organize WordPress custom post types]' \
  '--wp-attach[download WordPress attachments]' \
  '--disable-slugs[disable storing slugs]' \
  '(-b --blogname)'{-b,--blogname=}'[blog name (Tumblr)]:name:' \
  '*:input:_files'
