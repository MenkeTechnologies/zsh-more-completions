#compdef pdm-cli
# _pdm-cli — PDM modern Python dependency manager CLI alias (Frost Ming, Python); click
# upstream: https://github.com/pdm-project/pdm

_pdm-cli() {
    local -a sub=(
        'add:add dependencies'
        'remove:remove dependencies'
        'install:install all dependencies'
        'sync:sync packages with lockfile'
        'lock:update lockfile'
        'update:update packages'
        'list:list packages'
        'show:show package info'
        'tree:show dependency tree'
        'init:scaffold pyproject.toml'
        'build:build sdist+wheel'
        'publish:publish to PyPI'
        'run:run script'
        'use:set python interpreter'
        'venv:manage venvs'
        'cache:manage cache'
        'config:manage config'
        'export:export requirements.txt'
        'import:import from another tool'
        'info:show project info'
        'self:manage pdm itself'
        'fix:apply fixes'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--pep582[no shim required]' \
        '--config=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--no-cache[no cache]' \
        '--ignore-python[ignore python requirement]' \
        '-I[ignore python requirement]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pdm subcommand' sub ;;
        args)
            case $words[1] in
                add|remove|update|install) _arguments \
                    '--dev[dev dependency]' \
                    '-d[dev dependency]' \
                    '--group=+[group]:str:' \
                    '-G+[group]:str:' \
                    '--save-compatible[save compatible]' \
                    '--save-exact[save exact]' \
                    '--save-wildcard[save wildcard]' \
                    '--save-minimum[save minimum]' \
                    '--update-eager[update eager]' \
                    '--update-reuse[update reuse]' \
                    '--update-all[update all]' \
                    '--unconstrained[unconstrained]' \
                    '-u[unconstrained]' \
                    '--no-editable[no editable]' \
                    '--editable=+[editable package]:str:' \
                    '-e+[editable package]:str:' \
                    '--no-sync[no sync]' \
                    '--no-lock[no lock]' \
                    '--no-isolation[no isolation]' \
                    '--skip=+[skip hooks]:list:' \
                    '*:package:' ;;
                run) _arguments \
                    '--list[list scripts]' \
                    '-l[list scripts]' \
                    '--site-packages[use site packages]' \
                    '--no-isolation[no isolation]' \
                    '--venv=+[venv]:str:' \
                    '*:script:' ;;
                config) _arguments \
                    '1:key:' \
                    '2:value:' \
                    '--delete[delete value]' \
                    '-d[delete value]' \
                    '--global[global config]' \
                    '-g[global config]' \
                    '--local[local config]' \
                    '-l[local config]' \
                    '--edit[edit config]' \
                    '-e[edit config]' ;;
                lock) _arguments \
                    '--refresh[refresh lockfile]' \
                    '-r[refresh lockfile]' \
                    '--check[check lockfile]' \
                    '--update-eager[update eager]' \
                    '--update-reuse[update reuse]' \
                    '--strategy=+[strategy]:s:(static_urls direct_minimal_versions inherit_metadata)' \
                    '-S+[strategy]:s:(static_urls direct_minimal_versions inherit_metadata)' ;;
                use) _arguments \
                    '1:python:_files' \
                    '--ignore-remembered[ignore remembered]' \
                    '-i[ignore remembered]' \
                    '--first[first interpreter found]' \
                    '-f[first interpreter found]' \
                    '--auto-install[auto install]' \
                    '--no-auto-install[no auto install]' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_pdm-cli "$@"
