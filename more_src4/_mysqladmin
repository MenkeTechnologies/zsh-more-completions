#compdef mysqladmin
# Documentation: https://dev.mysql.com/doc/refman/en/mysqladmin.html
# Source: mysql/mysql-server client/mysqladmin.cc — MySQL server administration client (C++, my_getopt).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--bind-address=-[interface IP for connection]:ip:_default' \
    {-c+,--count=}'[iterations for --sleep/--relative]:n:_default' \
    '--debug=-[debug log spec]:spec:_default' \
    '--debug-check[check memory/file usage at exit]' \
    '--debug-info[print debug info on exit]' \
    {-f,--force}'[do not prompt; continue on errors]' \
    {-C,--compress}'[use compression]' \
    '--character-sets-dir=-[directory with character sets]:dir:_files -/' \
    '--default-character-set=-[default character set]:charset:_default' \
    {-\?,--help}'[show help]' \
    {-h+,--host=}'[server host]:host:_hosts' \
    {-b,--no-beep}'[suppress error beep]' \
    {-W,--pipe}'[use named pipes]' \
    {-P+,--port=}'[port]:port:_default' \
    '--protocol=-[connection protocol]:protocol:(TCP SOCKET PIPE MEMORY)' \
    {-r,--relative}'[show diff between iterations]' \
    '--shared-memory-base-name=-[shared memory connection name]:name:_default' \
    {-s,--silent}'[silent mode]' \
    {-S+,--socket=}'[socket file]:file:_files' \
    {-i+,--sleep=}'[seconds between iterations]:seconds:_default' \
    {-u+,--user=}'[login user]:user:_users' \
    {-v,--verbose}'[verbose mode]' \
    {-V,--version}'[show version]' \
    {-E,--vertical}'[vertical output]' \
    {-w,--wait}'[wait if server is unavailable]' \
    '--connect-timeout=-[connection timeout]:seconds:_default' \
    '--shutdown-timeout=-[shutdown timeout]:seconds:_default' \
    '--compression-algorithms=-[connection compression algorithms]:algo:_default' \
    '--zstd-compression-level=-[zstd compression level]:level:_default' \
    {-p-,--password=-}'[password]::pass:_default' \
    '*:command (status|shutdown|reload|flush-*|kill|create|drop|...):(create drop debug extended-status flush-binary-log flush-engine-logs flush-error-log flush-general-log flush-hosts flush-logs flush-privileges flush-relay-log flush-slow-log flush-status flush-tables flush-threads flush-user-resources kill old-password password ping processlist refresh reload shutdown start-replica start-slave status stop-replica stop-slave variables version)' \
    && ret=0

return ret
