#compdef pmprobe
# _pmprobe — Performance Co-Pilot pmprobe (probe metric availability + per-instance values from a pmcd(1) namespace; -h host, -a archive, -L local context, -v verbose, -I print instance identifiers, -V dump value, -n namespace file, positional metric name selectors)
# upstream: https://github.com/performancecopilot/pcp
# Flags from PCP src/pmprobe/pmprobe.c on tip.

_pmprobe() {
    _arguments \
        '-h+[host]:host:_hosts' \
        '-a+[archive]:file:_files' \
        '-L[local context]' \
        '-v[verbose]' \
        '-I[print instance identifiers]' \
        '-V[dump current values]' \
        '-n+[namespace]:file:_files' \
        '-O+[sample offset]:offset:' \
        '-z[archive timezone]' \
        '-Z+[timezone]:tz:' \
        '-q[quiet]' \
        '*:metric:'
}

_pmprobe "$@"
