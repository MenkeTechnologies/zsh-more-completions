#compdef PrintTRXHeader
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/PrintTRXHeader.cxx — print header of a TRX tractogram (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '--verbose-fields[print verbose fields]' \
    '1:tractogram.trx:_files -g "*.trx"' \
    && ret=0

return ret
