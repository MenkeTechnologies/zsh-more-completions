#compdef mps-control-daemon
# _mps-control-daemon — NVIDIA k8s device-plugin MPS (Multi-Process Service) control daemon
# upstream: https://github.com/NVIDIA/k8s-device-plugin
# Flags from cmd/mps-control-daemon/main.go on tip (urfave/cli/v2); env vars also bind to each flag.

_mps-control-daemon() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config-file=[path to a config file]:file:_files' \
        '--mig-strategy=[MIG device exposure strategy]:strategy:(none single mixed)' \
        '-v[klog verbosity level]:n:'
}

_mps-control-daemon "$@"
