#compdef pnmtorast
# Documentation: man pnmtorast (Netpbm)
# Source: convert a Netpbm image to Sun rasterfile format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-standard -rle)-standard[standard rasterfile encoding]' \
    '(-standard -rle)-rle[RLE encoding]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
