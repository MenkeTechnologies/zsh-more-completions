#compdef osrm-customize
# Documentation: https://github.com/Project-OSRM/osrm-backend
# Source: Project-OSRM/osrm-backend src/tools/customize.cpp — MLD customization preprocessing.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--version[show version]' \
    '(- *)--help[show help]' \
    '--list-inputs[list required/optional input file extensions]' \
    '--verbosity=[log verbosity]:level:_default' \
    '(-t --threads)'{-t+,--threads=}'[number of threads]:n:_default' \
    '--segment-speed-file=[nodeA,nodeB,speed CSV]:file:_files -g "*.(csv|txt)(-.)"' \
    '--turn-penalty-file=[from,to,via,penalty CSV]:file:_files -g "*.(csv|txt)(-.)"' \
    '--edge-weight-updates-over-factor=[log edges updated by >x factor]:factor:_default' \
    '--parse-conditionals-from-now=[UTC timestamp for conditional restrictions]:timestamp:_default' \
    '--time-zone-file=[time-zone boundaries GeoJSON]:file:_files -g "*.geojson(-.)"' \
    '*:input base path:_files -g "*.osrm(-.)"' \
    && ret=0

return ret
