#compdef pg-god
# ============================================================================
# _pg-god — zsh completion for ivawzh's pg-god, a TypeScript CLI that
#            creates and drops PostgreSQL databases via node-postgres (pg)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/ivawzh/pg-god
#   Author     : Ivan Wang  (ivawzh)
#   License    : MIT
#   Language   : TypeScript
#   Package    : pg-god v1.0.12  (npm)
#   Binary     : pg-god  (package.json bin: ./bin/run — oclif entry)
#   Last push  : 2023-07-11
#
# WHAT IT IS
#   pg-god is "a tiny TypeScript library that helps you create or kill
#   PostgreSQL databases" — Ivan Wang's oclif-based two-command CLI
#   that sidesteps the awkwardness of having to use `psql` to
#   `CREATE DATABASE` / `DROP DATABASE` against a running instance.
#   It connects to a configured initial database (default `postgres`),
#   issues the management statement against it, and (for drop) can
#   optionally terminate live connections via
#   `pg_terminate_backend(pg_stat_activity.pid)` before issuing
#   `DROP DATABASE`.  All flags accept env-var equivalents so the
#   tool drops into CI test setup/teardown unchanged.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/commands/{db-create,
#                       db-drop}.ts @oclif/command Command static
#                       `flags` blocks)
#   pg-god <SUBCOMMAND> [OPTIONS]
#
#   Subcommands (with aliases):
#     db-create | db:create     Create an empty database
#       -h, --help                Show help
#       -e, --errorIfExist        Throw error if DB already exists
#                                 [env: DB_ERROR_IF_EXIST]
#       -i, --initialDb <NAME>    Initial DB to connect to
#                                 [default: postgres]
#                                 [env: DB_INITIAL]
#       -n, --databaseName <DB>   New DB name
#                                 [env: DB_NAME]
#                                 (exclusive with --url)
#       -u, --userName <USER>     DB user name
#                                 [default: postgres]
#                                 [env: DB_USERNAME]
#       -p, --port <PORT>         DB port
#                                 [default: 5432]
#                                 [env: DB_PORT]
#       -o, --host <HOST>         DB host
#                                 [default: localhost]
#                                 [env: DB_HOST]
#       -w, --password <PASS>     DB password
#                                 [env: DB_PASSWORD]
#       -l, --url <URL>           DB URL (e.g.
#                                 postgres://user:pass@host:port/db)
#                                 [env: DB_URL]
#                                 (exclusive with --databaseName,
#                                  --userName, --port, --host,
#                                  --password)
#
#     db-drop   | db:drop       Drop a database
#       (Same flags as db-create plus:)
#       -e, --errorIfNonExist     Throw error if DB doesn't exist
#                                 [env: DB_ERROR_IF_NON_EXIST]
#       -d, --dropConnections     Automatically drop DB connections
#                                 before issuing DROP DATABASE
#                                 [default: true;  --no-dropConnections
#                                 disables]
#                                 [env: DROP_CONNECTIONS]
#
# AXIS / CORPUS POSITION
#   Direct dependency on `pg ^8.3.0` declared in package.json —
#   the canonical Node.js PostgreSQL client maintained by Brian
#   Carlson (brianc/node-postgres, npm package `pg`).  node-postgres
#   is the reference JS PostgreSQL driver:  typed `Client` / `Pool`
#   constructors over the official wire protocol, full set of
#   PostgreSQL types (including JSON, JSONB, arrays, ranges,
#   hstore via pg-hstore), prepared-statement caching, COPY
#   support, LISTEN/NOTIFY, connection pooling via pg-pool, and a
#   pluggable `pg-native` backend for libpq parity.  pg-god's
#   `src/god-stuff.ts` constructs a `new Client(opts)`, connects
#   to the initial DB, runs `CREATE DATABASE "${name}"` /
#   `DROP DATABASE "${name}"` (preceded by
#   `pg_terminate_backend` when --dropConnections is on), and
#   closes the client.  Verified via:
#     curl https://registry.npmjs.org/pg-god
#       → "pg": "^8.3.0"
#       → "bin": {"pg-god": "./bin/run"}
#     gh api repos/ivawzh/pg-god/contents/src/commands/db-create.ts
#       → import {Command, flags} from '@oclif/command'
#         export default class DbCreate extends Command {
#             static aliases = ['db:create'];
#             static flags = {help, errorIfExist, initialDb,
#                              databaseName, userName, port, host,
#                              password, url};
#         }
#   This entry is the TS-Node=136 leader bump that CLOSES Axis 81
#   (PostgreSQL Driver Library) at 1/1/1 three-language symmetry
#   — pairing Rust=tokio-postgres 0.7 (R913 _rpg), Go=jackc/pgx v5
#   (R914 _dbaker), and TS-Node=node-postgres ^8.3.0 (this entry).
#   Triple-136 landmark on commit.
#
#   No completion for `pg-god` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_pg-god() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_pg-god_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                db-create|db:create)
                    _arguments \
                        '(-e --errorIfExist)'{-e,--errorIfExist}'[throw error if DB already exists]' \
                        '(-i --initialDb)'{-i+,--initialDb=}'[initial DB name (default postgres)]:initialDb:' \
                        '(-n --databaseName -l --url)'{-n+,--databaseName=}'[new DB name]:databaseName:' \
                        '(-u --userName)'{-u+,--userName=}'[DB user name (default postgres)]:userName:_users' \
                        '(-p --port)'{-p+,--port=}'[DB port (default 5432)]:port:' \
                        '(-o --host)'{-o+,--host=}'[DB host (default localhost)]:host:_hosts' \
                        '(-w --password)'{-w+,--password=}'[DB password]:password:' \
                        '(-n --databaseName -u --userName -p --port -o --host -w --password -l --url)'{-l+,--url=}'[DB URL (e.g. postgres\://user\:pass@host\:port/db)]:url:' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                db-drop|db:drop)
                    _arguments \
                        '(-e --errorIfNonExist)'{-e,--errorIfNonExist}'[throw error if DB does not exist]' \
                        '(-d --dropConnections)'{-d,--dropConnections}'[drop DB connections before DROP DATABASE (default true)]' \
                        '--no-dropConnections[do NOT drop DB connections before DROP DATABASE]' \
                        '(-i --initialDb)'{-i+,--initialDb=}'[initial DB name (default postgres)]:initialDb:' \
                        '(-n --databaseName -l --url)'{-n+,--databaseName=}'[name of DB to drop]:databaseName:' \
                        '(-u --userName)'{-u+,--userName=}'[DB user name (default postgres)]:userName:_users' \
                        '(-p --port)'{-p+,--port=}'[DB port (default 5432)]:port:' \
                        '(-o --host)'{-o+,--host=}'[DB host (default localhost)]:host:_hosts' \
                        '(-w --password)'{-w+,--password=}'[DB password]:password:' \
                        '(-n --databaseName -u --userName -p --port -o --host -w --password -l --url)'{-l+,--url=}'[DB URL]:url:' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_pg-god_commands] )) ||
_pg-god_commands() {
    local -a commands
    commands=(
        'db-create:create an empty database'
        'db\:create:create an empty database (oclif-style alias)'
        'db-drop:drop a database'
        'db\:drop:drop a database (oclif-style alias)'
    )
    _describe -t commands 'pg-god command' commands
}

_pg-god "$@"
