#compdef otbcli_Segmentation
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_Segmentation.html
# Source: orfeotoolbox/OTB Segmentation — image segmentation (meanshift, cc, watershed, mprofiles).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-in+[input image]:image:_files' \
    '-filter+[segmentation algorithm]:algo:(meanshift cc watershed mprofiles)' \
    '-mode+[output mode]:mode:(vector raster)' \
    '-filter.meanshift.spatialr+[mean-shift spatial radius (default 5)]:n:_default' \
    '-filter.meanshift.ranger+[mean-shift range radius (default 15)]:value:_default' \
    '-filter.meanshift.thres+[mean-shift convergence threshold (default 0.1)]:value:_default' \
    '-filter.meanshift.maxiter+[max iterations (default 100)]:n:_default' \
    '-filter.meanshift.minsize+[min region size px (default 100)]:n:_default' \
    '-filter.cc.expr+[CC mathematical expression]:expr:_default' \
    '-filter.watershed.threshold+[watershed depth threshold (default 0.01)]:value:_default' \
    '-filter.watershed.level+[watershed merge level (default 0.1)]:value:_default' \
    '-filter.mprofiles.size+[mprofiles profile size (default 5)]:n:_default' \
    '-filter.mprofiles.start+[mprofiles initial SE radius (default 1)]:n:_default' \
    '-filter.mprofiles.step+[mprofiles radius increment (default 1)]:n:_default' \
    '-filter.mprofiles.sigma+[mprofiles decision threshold (default 1)]:value:_default' \
    '-mode.vector.out+[output vector file/db]:file:_files' \
    '-mode.vector.outmode+[vector write behavior]:behavior:(ulco ovw ulovw ulu)' \
    '-mode.vector.tilesize+[vector tile size (default 1024)]:n:_default' \
    '-mode.vector.stitch+[(true/false) stitch polygons]:bool:(true false)' \
    '-mode.vector.simplify+[polygon simplification tolerance]:value:_default' \
    '-mode.vector.minsize+[minimum object size]:n:_default' \
    '-mode.vector.fieldname+[geometry index field (default DN)]:field:_default' \
    '-mode.raster.out+[output labeled image]:image:_files' \
    '-ram+[available RAM (MB, default 256)]:mb:_default' \
    '-progress[show progress]' \
    '(- *)-help[show help]' \
    && ret=0

return ret
