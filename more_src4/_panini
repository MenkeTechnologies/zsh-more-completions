#compdef panini
# ============================================================================
#  _panini — panini: a super simple flat-file generator powered
#            by Handlebars, Vinyl-FS streaming, and Foundation's
#            front-end framework integrations.  Compiles
#            templates + layouts + partials into static HTML
#            pages.  (ZURB Foundation team — foundation/panini)
#
#  Source-direct extraction from
#    https://github.com/foundation/panini/blob/master/bin/panini.js
#      (the panini CLI script — uses nopt for argv parsing)
#    https://github.com/npm/nopt (the npm/nopt library by Isaac
#    Schlueter — npm creator + Node.js TSC member)
#
#  Maintained by ZURB / Foundation team (Foundation is the
#  responsive front-end framework that competes with Bootstrap;
#  ZURB is the design consultancy behind it, acquired by Get
#  Foundation Inc.).  foundation/panini: 593 GH stars.  Panini
#  is a SUPER SIMPLE FLAT-FILE GENERATOR — given a directory of
#  Handlebars page templates, layout files, partials, helpers,
#  and JSON/YAML data files, panini compiles each page into a
#  standalone HTML output through the Handlebars templating
#  engine.  Used primarily by the Foundation for Sites
#  (responsive web) and Foundation for Emails (responsive email
#  HTML) project scaffolding to render their documentation
#  websites + email-template starter kits.  Distinct from
#  bigger static site generators (Jekyll/Hugo/11ty/Astro) by
#  focusing on MINIMAL FEATURE SET — just Handlebars compilation
#  + Vinyl-FS streaming; no plugin system, no incremental
#  builds, no built-in dev server.  Use cases: ZURB Foundation
#  starter projects, simple email-template authoring, lightweight
#  HTML-prototype workflows.  Sister tools: 11ty (in corpus via
#  _11ty — Eleventy SSG), jekyll (in corpus + STOCK Ruby SSG),
#  hugo (in corpus + STOCK Go SSG), gatsby (in corpus via
#  _gatsby — React SSG), astro (in corpus via _astro), pelican
#  (in corpus + STOCK Python SSG), R445 compile-typst-site
#  (Typst SSG — corpus's other recently-documented SSG).
#
#  CLI library taxonomy update: 22nd TypeScript/Node CLI
#  library — Isaac "isaacs" Schlueter's **nopt** (npm/nopt).
#  TypeScript-Node ecosystem now has 22 documented CLI
#  libraries — RE-TAKING THE SOLO LEAD as the MOST-DOCUMENTED
#  CLI LANGUAGE in the cross-language taxonomy ahead of Rust
#  (21) and Go (21).  🎉 TypeScript-Node BREAKS the THREE-WAY
#  TIE — TypeScript-Node REACHES 22 documented CLI libraries.
#
#  nopt (npm/nopt, 542 GH stars) is "Node/npm Option Parsing"
#  by Isaac "isaacs" Schlueter — npm creator (the package
#  manager itself ships with nopt), longtime Node.js Technical
#  Steering Committee member, founder of npm Inc. (sold to
#  GitHub in 2020).  Distinguishing philosophy: TYPE-COERCION-
#  FIRST option parsing — caller defines a SCHEMA OBJECT
#  mapping flag names to TYPE CONSTRUCTORS (String, Number,
#  Boolean, Array, Date, URL, Path) and SHORTHAND mappings;
#  nopt walks argv, coerces each value through the schema, and
#  returns a flat parsed-args object.  Distinctive features
#  include: ARRAY of types per flag (e.g. `[String, Array]`
#  means the flag accepts a string AND can be repeated to
#  accumulate into an array); PATH coercion (resolves to
#  absolute paths via `path.resolve()`); URL coercion (validates
#  via URL constructor); custom validator functions; abbreviation
#  matching (`--ver` matches `--version` if unambiguous).  USED
#  BY NPM ITSELF — every `npm install`/`npm publish`/etc. call
#  goes through nopt for argv parsing.  Distributed widely:
#  npm/nopt is one of the FOUR ORIGINAL Node.js OPTION PARSERS
#  alongside minimist (substack), commander (TJ Holowaychuk),
#  and yargs (Bash Cooper); released in 2011, predating most
#  modern alternatives.  Used by gruntjs/grunt (Grunt task
#  runner 12,238 stars — IN CORPUS via _grunt; FLAGSHIP nopt
#  user), nodejs/node-gyp (Node.js native addon build tool
#  10,631 stars — IN CORPUS via _node-gyp), ember-cli/ember-cli
#  (Ember.js CLI 3,238 stars — IN CORPUS via _ember-cli),
#  apache/cordova-android (Apache Cordova 3,785 stars),
#  foundation/panini (593 stars), microsoft/BotFramework-WebChat,
#  oracle/graaljs (GraalJS V8-compatible JavaScript engine),
#  pstadler/flightplan (deployment orchestration), enyojs/ares-
#  project (LG Enyo framework), webos-tools/cli (LG webOS CLI),
#  veo-labs/cas-server-mock, JonAbrams/synth, legoflow/legoflow,
#  zaach/selfie.  nopt is also bundled into `npm` itself (which
#  ships with Node.js core distribution since 2011).
#
#  nopt API:
#    const nopt = require('nopt')
#    const path = require('path')
#    const url  = require('url')
#
#    // SCHEMA: object mapping long-flag-name → type constructor
#    const knownOpts = {
#      'foo':    [String, null],              // string, default null
#      'bar':    [Stream, Number, null],      // Stream OR Number
#      'baz':    [path],                      // PATH — resolves to absolute
#      'bloo':   [String, Array],             // STRING + ARRAY = repeatable
#      'flag':   Boolean,                     // boolean
#      'pick':   ['a', 'b', 'c'],            // enum of allowed strings
#      'url':    url,                         // URL — validated via URL constructor
#      'date':   Date,                        // Date — parsed via Date.parse
#    }
#
#    // SHORTHANDS: object mapping short-form → expansion
#    const shortHands = {
#      'f':       ['--foo'],
#      'fooble':  ['--foo', '-f'],            // expands to multiple flags
#      'nofoo':   ['--no-foo'],               // negation
#    }
#
#    // Parse process.argv starting at index 2 (skip node, script)
#    const parsed = nopt(knownOpts, shortHands,
#                        process.argv, 2)
#
#    // parsed = {
#    //   foo: 'value',      // parsed flags by long name
#    //   bar: 42,
#    //   baz: '/absolute/path',
#    //   bloo: ['a', 'b'],
#    //   flag: true,
#    //   argv: {
#    //     remain: [...],   // positional args
#    //     cooked: [...],   // argv with expansions applied
#    //     original: [...], // raw argv
#    //   }
#    // }
#
#  nopt distinctive features:
#    - TYPE-COERCION via SCHEMA — `knownOpts['flag']: Type`
#      where Type is one of: String / Number / Boolean / Array /
#      Date / Stream / url / path (these are the JS class
#      constructors themselves used as TYPE MARKERS; nopt
#      coerces argv strings to instances of these types)
#    - MULTIPLE TYPES per flag via array — `[String, Array]`
#      means "this flag is a STRING that can be REPEATED (each
#      occurrence appends to an Array)"; `[Number, Stream]`
#      means "either a Number or a Stream object"
#    - SPECIAL TYPES:
#      * `path` — coerces value to absolute path via `path.
#        resolve()` from process.cwd() (so `--config ./file.json`
#        becomes `/cwd/file.json`)
#      * `url` — coerces value via URL constructor (validates
#        format)
#      * `Date` — coerces via Date.parse + new Date() (accepts
#        many string formats)
#      * `Stream` — reads value from a file path or stdin
#    - ENUM types — array of strings as the type means the flag
#      must match one of those strings (e.g. `['a', 'b', 'c']`)
#    - SHORTHAND EXPANSION via separate shortHands object —
#      `'-f': ['--foo']` expands `-f` to `--foo` before parsing;
#      shorthands can expand to MULTIPLE flags (`'fooble':
#      ['--foo', '-f']`)
#    - ABBREVIATION MATCHING — `--ver` matches `--version` if
#      unambiguous (like Perl's Getopt::Long); turn off via
#      `clean` parsing mode
#    - NEGATION via `--no-flag` syntax — automatically generated
#      for Boolean flags
#    - `argv.remain` — positional args (non-flag elements after
#      parsing); `argv.cooked` — argv with shorthand expansions
#      applied; `argv.original` — raw argv input
#    - CUSTOM TYPE FUNCTIONS — beyond built-in types, caller can
#      provide custom type functions (objects with a `t` and `e`
#      method) for project-specific coercion
#    - NO BUILT-IN HELP / VERSION generation (caller writes
#      manually); nopt is pure argv-parsing
#    - NO SUBCOMMAND framework — flat schema only (caller
#      dispatches manually based on `argv.remain[0]`)
#    - INSPIRED BY Perl's Getopt::Long (abbreviation matching,
#      multi-type validation); released in 2011 alongside
#      minimist/commander/yargs as one of the foundational
#      Node.js CLI parsers
#  Distinct from R236 commander (TJ chained-builder — released
#  same era as nopt but different style; commander uses
#  chained method calls while nopt uses schema-object), R237
#  oclif/yargs (yargs is the BIGGEST sibling — bash-style with
#  ~12k stars), R398 meow (Sindre zero-config wrapping
#  minimist; meow is what Sindre Sorhus picked when he wanted
#  ZERO-CONFIG, vs nopt requiring explicit schema), R399
#  substack/minimist (the ORIGINAL micro-arg parser by James
#  Halliday/substack — CLOSEST RIVAL in age/era; minimist is
#  even more minimal than nopt — no type coercion, no
#  shorthand mappings, just `--foo=bar` → `{foo: 'bar'}`;
#  nopt adds the type-coercion+shorthand layer on top of
#  minimist's philosophy), R400 cac, R403 clipanion, R406
#  vercel/arg, R409 mri (lukeed's 5-8x faster minimist
#  replacement), R412 citty, R415 cmd-ts, R418 gluegun, R422
#  cleye, R428 @caporal/core, R432 @effect/cli, R433
#  @stricli/core, R439 vadimdemedes/pastel, R442 dthree/vorpal,
#  R446 75lb/command-line-args (CONCEPTUALLY CLOSE — both use
#  schema objects + JS-constructor-as-type; command-line-args
#  uses array-of-definitions while nopt uses object-by-name).
#  TypeScript-Node documented libraries so far: commander,
#  oclif, yargs, meow, minimist, cac, clipanion, arg, mri,
#  sade, citty, cmd-ts, gluegun, cleye, @caporal/core, @effect/
#  cli, @stricli/core, pastel, vorpal, command-line-args, nopt
#  (this round)... 22 total.  🎉 TypeScript-Node crosses 22
#  documented CLI libraries.  nopt's distinguishing feature vs
#  all other TS-Node libs: nopt is the ONLY one BUNDLED WITH
#  npm ITSELF — every `npm install`/`npm publish` invocation
#  goes through nopt; nopt's deployment footprint is at least
#  as large as Node.js's (which ships npm bundled).  nopt's
#  approach: TYPE-COERCION-FIRST schema with `nopt(knownOpts,
#  shortHands, argv, slice)` function + object mapping long-
#  flag → type-constructor + ARRAY of types for multi-type or
#  String+Array=repeatable + SPECIAL TYPES (path/url/Date/
#  Stream/enum-arrays) + SHORTHAND EXPANSION via separate
#  object + ABBREVIATION MATCHING (Perl Getopt::Long style) +
#  NEGATION via `--no-flag` for Boolean flags + `argv.remain/
#  cooked/original` access to positionals + no built-in help +
#  no subcommands + INSPIRED BY Perl Getopt::Long + BUNDLED
#  WITH npm — corpus's **first documented npm-bundled
#  TypeScript-Node CLI library** (and the most-deployed
#  documented option-parser by sheer install count, since
#  every Node.js install includes npm which includes nopt).
#  Brings cross-language CLI library taxonomy variant count to
#  188; TypeScript-Node ecosystem now has 22 documented CLI
#  libraries — RE-TAKING THE SOLO LEAD as the MOST-DOCUMENTED
#  CLI LANGUAGE in the cross-language taxonomy ahead of Rust
#  (21) and Go (21).
#
#  Surface (verbatim from `bin/panini.js` nopt knownOpts +
#  shorthands):
#
#  Usage:
#    panini [options] <input...>
#    panini <command>
#
#  Options:
#    -r, --root <PATH>              Path to the root pages
#                                   directory containing
#                                   Handlebars page templates
#                                   (default: src/pages/)
#    -l, --layouts <PATH>           Path to the layouts
#                                   directory (Handlebars
#                                   layout templates that wrap
#                                   page content; default:
#                                   src/layouts/)
#    -p, --partials <PATH>          Path to the partials
#                                   directory (reusable
#                                   Handlebars fragments;
#                                   default: src/partials/)
#    -d, --data <PATH>              Path to the data directory
#                                   (JSON/YAML files made
#                                   available as variables
#                                   in templates; default:
#                                   src/data/)
#    -h, --helpers <PATH>           Path to the Handlebars
#                                   helpers directory (JavaScript
#                                   helper functions; default:
#                                   src/helpers/)
#    -o, --output <PATH>            Output directory for
#                                   compiled HTML (default:
#                                   dist/)
#    -v, --version                  Show Panini version and exit
#
#  Commands (positional first arg):
#    new                            Scaffold a new Panini project
#                                   (interactive)
#    help                           Show usage help
#
#  Positional:
#    <input...>                     Vinyl-FS glob patterns for
#                                   input files to compile
#                                   (e.g. "src/pages/**/*.html"
#                                   or "templates/about.hbs")
#
#  Examples:
#    panini src/pages/**/*.html                                     # Compile all pages
#    panini -o dist -l src/layouts src/pages/**/*.html             # Custom layouts dir
#    panini -d src/data -p src/partials src/pages/**/*.html        # Custom data + partials
#    panini -r src -o dist src/pages/**/*.html                     # Set root
#    panini --root src --output dist src/pages/about.html          # Long form
#    panini new                                                    # Scaffold new project
#    panini help                                                   # Show help
#    panini -v                                                     # Print version
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also npm/nopt users):
#    - grunt (IN CORPUS via _grunt — Grunt JavaScript task
#      runner 12,238 stars; FLAGSHIP nopt user since 2012;
#      previously documented but nopt library not formally
#      entered into taxonomy)
#    - node-gyp (IN CORPUS via _node-gyp — Node.js native
#      addon build tool 10,631 stars; uses nopt)
#    - ember-cli (IN CORPUS via _ember-cli — Ember.js CLI
#      3,238 stars; uses nopt)
#    - npm (IN CORPUS + STOCK Node.js — npm itself bundles
#      and uses nopt for every `npm install`/etc. command;
#      the most-deployed nopt user by sheer count of Node.js
#      installations)
#    - cordova-android (apache/cordova-android 3,785 stars —
#      Apache Cordova Android tooling; FUTURE candidate)
#    - graaljs (oracle/graaljs — GraalJS V8-compatible JS
#      engine; uses nopt in graal-nodejs/deps/npm; FUTURE)
#    - webos-tools/cli (LG webOS CLI tools; FUTURE candidate)
#    - microsoft/BotFramework-WebChat (Microsoft Bot Framework
#      WebChat — uses nopt in support packages)
#    - flightplan (pstadler/flightplan — deployment orchestration;
#      FUTURE candidate)
#    - npm/nopt repo itself (542 stars library not CLI)
# ============================================================================

_panini() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-v --version)'{-v,--version}'[show Panini version and exit]' \
    '(-r --root)'{-r,--root}'[path to root pages directory]:path:_directories' \
    '(-l --layouts)'{-l,--layouts}'[path to layouts directory]:path:_directories' \
    '(-p --partials)'{-p,--partials}'[path to partials directory]:path:_directories' \
    '(-d --data)'{-d,--data}'[path to data directory]:path:_directories' \
    '(-h --helpers)'{-h,--helpers}'[path to Handlebars helpers directory]:path:_directories' \
    '(-o --output)'{-o,--output}'[output directory for compiled HTML]:path:_directories' \
    '*:input:_files -g "*.(html|hbs|handlebars)"'
}

_panini "$@"
