#compdef pstext
# Documentation: https://docs.generic-mapping-tools.org/latest/text.html
# Source: GenericMappingTools/gmt classic-mode text — plot text labels on a map.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-R+[region west/east/south/north]:region:_default' \
    '-J+[projection]:proj:_default' \
    '-A[convert azimuths to projected directions]' \
    '-B+[basemap frame/axes]:basemap:_default' \
    '-C+[text/box clearance]:clearance:_default' \
    '-D+[text offset dx/dy from point]:offset:_default' \
    '-F+[font/angle/justification (+a +f +j +t)]:opts:_default' \
    '-G+[text-box fill color]:fill:_default' \
    '-L[list available fonts and exit]' \
    '-M[paragraph mode (multi-line)]' \
    '-N[do not clip text at map boundary]' \
    '-Q+[case conversion]:case:(l u)' \
    '-S+[offset shaded region under text box]:shade:_default' \
    '-U+[GMT timestamp logo]:opts:_default' \
    '-W+[rectangle outline pen]:pen:_default' \
    '-X+[X offset of plot origin]:offset:_default' \
    '-Y+[Y offset of plot origin]:offset:_default' \
    '-Z[3-D mode: per-item level]' \
    '-K[multi-page: more pages follow]' \
    '-O[multi-page: this is overlay]' \
    '-P[portrait orientation]' \
    '*-V[verbose (stackable)]' \
    '-t+[transparency percent]:pct:_default' \
    '*:text file:_files' \
    && ret=0

return ret
