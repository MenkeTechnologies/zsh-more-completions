#compdef matchbox
# _matchbox — network boot config service (poseidon/matchbox)
# upstream: https://github.com/poseidon/matchbox
# Flags from cmd/matchbox/main.go.

_matchbox() {
    _arguments \
        '-help[show help]' \
        '-version[show version]' \
        '-address=[HTTP listen address]:addr:' \
        '-rpc-address=[RPC listen address]:addr:' \
        '-data-path=[path to data directory]:dir:_files -/' \
        '-assets-path=[path to static assets]:dir:_files -/' \
        '-log-level=[logging level]:level:(debug info warn error)' \
        '-cert-file=[server TLS certificate file]:file:_files' \
        '-key-file=[server TLS key file]:file:_files' \
        '-ca-file=[CA file to verify client certs]:file:_files' \
        '-key-ring-path=[private keyring file]:file:_files' \
        '-web-cert-file=[HTTPS server TLS cert]:file:_files' \
        '-web-key-file=[HTTPS server TLS key]:file:_files' \
        '-web-ssl[enable HTTPS]'
}

_matchbox "$@"
