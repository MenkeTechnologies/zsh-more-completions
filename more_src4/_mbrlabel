#compdef mbrlabel
# Documentation: man mbrlabel(8)
# Source: netbsd/src sbin/mbrlabel — update disklabel from MBR/EBR partitions (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f[force update even if no changes]' \
    '-q[quiet operation]' \
    '-r[with -w, also update on-disk label]' \
    '-s+[logical sector containing the MBR (default 0)]:sector:_default' \
    '-w[update in-core label if changed]' \
    '1:disk device:_files' \
    && ret=0

return ret
