#compdef primer3_masker
# Documentation: https://github.com/bioinfo-ut/primer3_masker
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# primer3_masker: mask repetitive regions before primer design
local curcontext="$curcontext" ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[display usage information and exit]' \
  '(-p --probability_cutoff)'{-p+,--probability_cutoff=}'[probability cutoff 0-1]:cutoff:' \
  '(-lh --kmer_lists_path)'{-lh+,--kmer_lists_path=}'[directory with k-mer list files]:dir:_files -/' \
  '(-lp --list_prefix)'{-lp+,--list_prefix=}'[prefix for k-mer lists]:prefix:' \
  '(-a --absolute_value_cutoff)'{-a+,--absolute_value_cutoff=}'[k-mer count threshold (requires -l)]:count:' \
  '(-l --list)'{-l+,--list=}'[single k-mer list file]:file:_files' \
  '(-m5 --mask_5p)'{-m5+,--mask_5p=}'[bases to mask at 5p end]:n:' \
  '(-m3 --mask_3p)'{-m3+,--mask_3p=}'[bases to mask at 3p end]:n:' \
  '(-c --masking_char)'{-c+,--masking_char=}'[character for masking]:char:' \
  '(-s --soft_mask)'{-s,--soft_mask}'[enable soft masking]' \
  '(-d --masking_direction)'{-d+,--masking_direction=}'[strand selection]:direction:(fwd rev both)' \
  '*:input file:_files' && ret=0

return ret
