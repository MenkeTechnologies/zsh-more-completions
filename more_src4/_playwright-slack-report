_playwright-slack-report() {
    _arguments -s \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-c --config)'{-c,--config}'=[configuration file for the CLI app (e.g. ./config.json)]:config:_files -g "*.json"' \
        '(-j --json-results)'{-j,--json-results}'=[generated Playwright json results file (e.g. ./results.json)]:json:_files -g "*.json"'
}

_playwright-slack-report "$@"
