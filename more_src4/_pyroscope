#compdef pyroscope
# Documentation: https://github.com/grafana/pyroscope/blob/main/cmd/pyroscope/main.go
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Note: Pyroscope 1.0 stripped all client-side subcommands
# (exec/connect/adhoc/agent/admin). The pyroscope binary is now a
# server-only command that takes flags directly.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show basic help]' \
  '(- *)--help-all[show all flags including experimental]' \
  '(- *)--version[show version]' \
  '--modules[list available modules and exit]' \
  '--config.file=[path to YAML config file]:file:_files -g "*.(yaml|yml)"' \
  '--target=[comma-separated module names to run]:modules' \
  '*: :_default' && ret=0

return ret
