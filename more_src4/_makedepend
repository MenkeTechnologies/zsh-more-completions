#compdef makedepend
# Documentation: man makedepend(1) (X.Org)
# Source: X.Org makedepend — create #include dependencies in makefiles.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-D-[define preprocessor symbol]:NAME[=VALUE]:' \
    '*-I-[add include directory]:dir:_files -/' \
    '*-Y-[replace standard include path with directory]:dir:_files -/' \
    '-a[append output instead of replacing it]' \
    '-f-[output makefile]:file:_files' \
    '-include-[insert include FILE before source]:file:_files' \
    '-o-[object filename suffix (default .o)]:suffix:' \
    '-p-[object filename prefix (default empty)]:prefix:' \
    '-s-[boundary line marker string]:string:' \
    '-w-[maximum line width]:width:' \
    '-v[verbose]' \
    '-m[warn about multiple inclusions]' \
    '*:source file:_files -g "*.{c,cc,cpp,cxx,h,hh,hpp,m}"' \
    && ret=0

return ret
