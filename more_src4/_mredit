#compdef mredit
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/mredit.html
# Source: MRtrix3/mrtrix3 cmd/mredit.cpp — directly modify image voxel intensities (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '*-plane+[fill voxels on axis]:axis:(0 1 2):coord:_default:value:_default' \
    '*-sphere+[draw sphere with radius in mm]:position:_default:radius:_default:value:_default' \
    '*-voxel+[change single voxel value]:position:_default:value:_default' \
    '-scanner[coordinates are in scanner space, not voxel coords]' \
    '1:input image:_files -g "*.{nii,nii.gz,mif}"' \
    '2::output image:_files' \
    && ret=0

return ret
