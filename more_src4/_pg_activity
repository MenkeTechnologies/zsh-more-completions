#compdef pg_activity
# Documentation: https://github.com/dalibo/pg_activity
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for pg_activity - PostgreSQL top-like monitor

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-P --profile)'{-P+,--profile=}'[configuration profile]:profile:' \
  '(-U --username)'{-U+,--username=}'[database user]:user:_users' \
  '(-p --port)'{-p+,--port=}'[database port]:port:' \
  '(-h --host)'{-h+,--host=}'[database host or socket dir]:host:_hosts' \
  '(-d --dbname)'{-d+,--dbname=}'[database name]:database:' \
  '(-w --wrap-query)'{-w,--wrap-query}'[wrap query column instead of truncating]' \
  '--blocksize=[filesystem block size]:size:' \
  '--rds[enable AWS RDS compatibility]' \
  '--output=[output file for non-interactive mode]:file:_files' \
  '--pid[show PID column]' \
  '--no-pid[hide PID column]' \
  '--database[show database column]' \
  '--no-database[hide database column]' \
  '--user[show user column]' \
  '--no-user[hide user column]' \
  '--client[show client column]' \
  '--no-client[hide client column]' \
  '--cpu[show CPU column]' \
  '--no-cpu[hide CPU column]' \
  '--mem[show memory column]' \
  '--no-mem[hide memory column]' \
  '--read[show read column]' \
  '--no-read[hide read column]' \
  '--write[show write column]' \
  '--no-write[hide write column]' \
  '--time[show time column]' \
  '--no-time[hide time column]' \
  '--wait[show wait column]' \
  '--no-wait[hide wait column]' \
  '--app-name[show application name column]' \
  '--no-app-name[hide application name column]' \
  '--duration-mode=[duration mode]:mode:(1 2 3)' \
  '--min-duration=[minimum query duration]:seconds:' \
  '--filter=[filter by field]:filter:' \
  '--debug-file=[debug file]:file:_files' \
  '--refresh=[refresh interval]:seconds:' && ret=0

return ret
