#compdef mailpost
# Documentation: man mailpost(8)
# Source: InterNetNews/inn frontends/mailpost.in — post mail to newsgroups (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[print help]' \
    '-a+[Approved header address]:address:_email_addresses' \
    '-b+[database directory]:dir:_files -/' \
    '-c+[wait seconds before posting]:secs:_default' \
    '-d+[Distribution header]:dist:_default' \
    '-f+[envelope sender address]:address:_email_addresses' \
    '-m+[Mailing-List header]:list:_default' \
    '-n[no-op test mode]' \
    '-o+[output command pipeline]:cmd:_default' \
    '-p+[NNTP port]:port:_default' \
    '-r+[envelope sender (alias of -f)]:address:_email_addresses' \
    '-t+[temp directory]:dir:_files -/' \
    '-x+[extra headers to strip]:headers:_default' \
    '-z+[headers to keep instead of strip]:headers:_default' \
    '*:newsgroup:_default' \
    && ret=0

return ret
