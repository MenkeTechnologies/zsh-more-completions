#compdef neroAacDec
# Documentation: https://wiki.hydrogenaudio.org/index.php?title=Nero_AAC
# Reference accessed: 2026-05-16
# Verified: Nero AAC Codec package. Proprietary binary, archived 2010.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# neroAacDec: Nero AAC decoder (proprietary, archived 2010)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-if[MP4 source file (- for stdin)]:file:_files -g "*.(m4a|mp4|aac)(-.)"' \
  '-of[WAV output file (- for stdout)]:file:_files -g "*.wav(-.)"' \
  '-chapter[chapter mark to decode]:number' \
  '-ignorelength[ignore length header]' && ret=0
return ret
