#compdef mwm
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/mwm.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-help[show help]' \
  '-display+[X display]:display:' \
  '-xrm+[X resource]:resource:' \
  '-multiscreen[manage all screens]' \
  '-name+[application name]:name:' \
  '-screens+[screen names]:screens:' && ret=0

return ret
