#compdef pulseview
# Documentation: man pulseview(1)
# Source: sigrokproject/pulseview main.cpp (master) — GUI logic analyzer (C++, Qt).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h -? --help)'{-h,-\\?,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '(-l --loglevel)'{-l+,--loglevel=}'[libsigrok/libsigrokdecode loglevel]:level:(0 1 2 3 4 5)' \
    '(-d --driver)'{-d+,--driver=}'[device driver]:driver:_default' \
    '(-D --dont-scan)'{-D,--dont-scan}'[do not auto-scan for devices]' \
    '(-i --input-file)'{-i+,--input-file=}'[load input file]:file:_files' \
    '(-s --settings)'{-s+,--settings=}'[load session setup file]:file:_files -g "*.pvs"' \
    '(-I --input-format)'{-I+,--input-format=}'[input format]:format:_default' \
    '(-c --clean)'{-c,--clean}'[do not restore previous sessions on startup]' \
    '--log-to-stdout[also log to stdout]' \
    '*:input file:_files' \
    && ret=0

return ret
