#compdef mkenvimage
# Documentation: https://github.com/u-boot/u-boot/blob/master/tools/mkenvimage.c
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-r[redundant environment (two copies)]' \
  '-b[big-endian byte order]' \
  '-p+[padding byte (default 0xff)]:byte:' \
  '-s+[environment partition size (required)]:size:' \
  '-o+[output file]:file:_files' \
  ':input:_files'
