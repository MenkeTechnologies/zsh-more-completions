#compdef paperkey
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/paperkey.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--secret-key=[secret key file]:file:_files' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '--output-type=[output type]:type:(base16 raw)' \
  '--output-width=[output line width for base16]:width:' \
  '--input-type=[input type]:type:(auto base16 raw)' \
  '--pubring=[public keyring]:file:_files' \
  '--secrets=[secret data file]:file:_files' \
  '--ignore-crc-error[ignore CRC errors]' \
  '--comment=[add comment]:comment:' \
  '--file-format[show file format and exit]' \
  '*'{-v,--verbose}'[verbose output, repeatable]' && ret=0

return ret
