#compdef otbcli_TrainImagesClassifier
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_TrainImagesClassifier.html
# Source: orfeotoolbox/OTB TrainImagesClassifier — train a classifier on labeled raster + vector samples.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-io.il+[input image list]:images:_files' \
    '-io.vd+[vector training samples]:vector:_files' \
    '-io.valid+[vector validation samples]:vector:_files' \
    '-io.imstat+[image stats XML]:file:_files -g "*.xml(-.)"' \
    '-io.out+[output model file]:file:_files' \
    '-io.confmatout+[confusion matrix output CSV]:file:_files -g "*.csv(-.)"' \
    '-cleanup+[(true/false) clean temporary files]:bool:(true false)' \
    '-sample.mt+[max training samples per class (default 1000)]:n:_default' \
    '-sample.mv+[max validation samples per class (default 1000)]:n:_default' \
    '-sample.bm+[bound samples by smallest class (default 1)]:n:_default' \
    '-sample.vtr+[training/validation ratio (default 0.5)]:value:_default' \
    '-sample.vfn+[field with class labels]:field:_default' \
    '-elev.dem+[DEM directory]:path:_files' \
    '-elev.geoid+[geoid file]:file:_files' \
    '-elev.default+[default elevation]:m:_default' \
    '-classifier+[classifier algorithm]:algo:(libsvm boost dt ann bayes rf knn sharkrf sharkkm)' \
    '-classifier.libsvm.k+[libsvm kernel type]:kernel:(linear rbf poly sigmoid)' \
    '-classifier.libsvm.m+[libsvm SVM type]:type:(csvc nusvc oneclass)' \
    '-classifier.libsvm.c+[libsvm cost C (default 1)]:value:_default' \
    '-classifier.libsvm.gamma+[libsvm gamma (default 1)]:value:_default' \
    '-classifier.libsvm.coef0+[libsvm coef0 (default 0)]:value:_default' \
    '-classifier.libsvm.degree+[libsvm poly degree (default 3)]:n:_default' \
    '-classifier.libsvm.nu+[libsvm nu (default 0.5)]:value:_default' \
    '-classifier.libsvm.opt+[(true/false) optimize parameters]:bool:(true false)' \
    '-classifier.libsvm.prob+[(true/false) probability estimation]:bool:(true false)' \
    '-classifier.boost.t+[boost variant]:variant:(discrete real logit gentle)' \
    '-classifier.boost.w+[weak classifiers count (default 100)]:n:_default' \
    '-classifier.boost.r+[weight trim rate (default 0.95)]:value:_default' \
    '-classifier.boost.m+[max tree depth (default 1)]:n:_default' \
    '-classifier.dt.max+[DT max depth (default 10)]:n:_default' \
    '-classifier.dt.min+[DT min samples per node (default 10)]:n:_default' \
    '-classifier.dt.ra+[DT regression accuracy (default 0.01)]:value:_default' \
    '-classifier.dt.cat+[DT categorical clusters (default 10)]:n:_default' \
    '-classifier.dt.r+[(true/false) DT 1SE rule pruning]:bool:(true false)' \
    '-classifier.dt.t+[(true/false) DT truncate pruned tree]:bool:(true false)' \
    '-classifier.ann.t+[ANN training method]:method:(back reg)' \
    '-classifier.ann.sizes+[neurons per intermediate layer]:sizes:_default' \
    '-classifier.ann.f+[ANN activation function]:func:(ident sig gau)' \
    '-classifier.ann.term+[ANN termination]:term:(iter eps all)' \
    '-classifier.ann.iter+[ANN max iterations (default 1000)]:n:_default' \
    '-classifier.ann.eps+[ANN epsilon (default 0.01)]:value:_default' \
    '-classifier.rf.max+[RF max depth (default 5)]:n:_default' \
    '-classifier.rf.min+[RF min node samples (default 10)]:n:_default' \
    '-classifier.rf.ra+[RF regression accuracy]:value:_default' \
    '-classifier.rf.cat+[RF categorical clusters]:n:_default' \
    '-classifier.rf.var+[RF feature subset size (0=sqrt)]:n:_default' \
    '-classifier.rf.nbtrees+[RF tree count (default 100)]:n:_default' \
    '-classifier.rf.acc+[RF OOB error threshold (default 0.01)]:value:_default' \
    '-classifier.knn.k+[KNN neighbours (default 32)]:n:_default' \
    '-classifier.sharkrf.nbtrees+[Shark RF tree count (default 100)]:n:_default' \
    '-classifier.sharkrf.nodesize+[Shark RF min node size (default 25)]:n:_default' \
    '-classifier.sharkrf.mtry+[Shark RF features per node (0=sqrt)]:n:_default' \
    '-classifier.sharkrf.oobr+[Shark RF OOB ratio (default 0.66)]:value:_default' \
    '-classifier.sharkkm.maxiter+[Shark K-means max iterations (default 10)]:n:_default' \
    '-classifier.sharkkm.k+[Shark K-means clusters (default 2)]:n:_default' \
    '-classifier.sharkkm.incentroids+[Shark K-means initial centroids]:file:_files' \
    '-classifier.sharkkm.outcentroids+[Shark K-means output centroids]:file:_files' \
    '-rand+[random seed]:seed:_default' \
    '-ram+[available RAM (MB, default 256)]:mb:_default' \
    '-progress[show progress]' \
    '(- *)-help[show help]' \
    && ret=0

return ret
