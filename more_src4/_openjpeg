#compdef opj_compress opj_decompress opj_dump openjpeg
# _openjpeg — OpenJPEG opj_compress opj_decompress opj_dump reference JPEG 2000 codec implementation (uclouvain team, C); getopt
# upstream: https://github.com/uclouvain/openjpeg

_openjpeg() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-i+[input file]:file:_files -g "*.jp2 *.j2k *.jpf *.jpx *.mj2 *.tif *.tiff *.png *.bmp *.pgm *.ppm *.pgx *.raw *.rawl *.tga"' \
        '-o+[output file]:file:_files -g "*.jp2 *.j2k *.jpf *.jpx *.mj2 *.tif *.tiff *.png *.bmp *.pgm *.ppm *.pgx *.raw"' \
        '-r+[compression ratios csv]:str:' \
        '-q+[quality dB csv]:str:' \
        '-n+[N resolutions]:n:' \
        '-c+[code block size csv]:str:' \
        '-t+[tile size]:str:' \
        '-T+[tile origin]:str:' \
        '-O+[reference origin]:str:' \
        '-p+[progression order]:p:(LRCP RLCP RPCL PCRL CPRL)' \
        '-S+[subsampling x:y]:str:' \
        '-M+[mode]:n:' \
        '-EPH[end of packet header markers]' \
        '-SOP[start of packet markers]' \
        '-PLT[packet length tile-part]' \
        '-TLM[tile length main header]' \
        '-cpu+[N threads]:n:' \
        '-threads+[N threads]:n:' \
        '-z+[index file]:file:_files' \
        '-mct+[multi component transform]:n:(0 1 2)' \
        '-poc+[progression order changes]:str:' \
        '-tcp_mct+[N]:n:' \
        '-IMF+[profile]:p:(2K 4K 8K 8KSF 2K_S 4K_S)' \
        '-OutFor+[format]:f:(JP2 J2K JPT BMP PGM PNG PPM PNX RAW RAWL TGA TIF)' \
        '-d+[image area to decode csv]:str:' \
        '-l+[layers to decode]:n:' \
        '-x+[layer to extract]:n:' \
        '-y+[tile to decode]:n:' \
        '-jpwl[JPWL mode]' \
        '-jpwlmh[JPWL max hamming]' \
        '-jpwlspc[JPWL spurious packets]' \
        '-jpwlmc[JPWL max corruption]' \
        '-disable-random-access[disable random access]' \
        '-disable-multithreading[disable threading]' \
        '-quiet[quiet]' \
        '-v[verbose]' \
        '-W+[width]:n:' \
        '-H+[height]:n:' \
        '*:image file:_files -g "*.jp2 *.j2k *.tif *.tiff *.png *.bmp *.pgm *.ppm *.raw"'
}

_openjpeg "$@"
