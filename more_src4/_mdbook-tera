#compdef mdbook-tera
# _mdbook-tera — render Tera templates inside mdbook chapters (avitex/mdbook-tera)
# upstream: https://github.com/avitex/mdbook-tera
# Subcommands & flags from src/main.rs (clap).

_mdbook-tera() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--json=[context from JSON file]:file:_files -g "*.json"' \
        '--toml=[context from TOML file]:file:_files -g "*.toml"' \
        '--template-root=[directory to include templates from]:dir:_files -/' \
        '--template-include=[glob expression for templates]:glob:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'supports:check whether a renderer is supported'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                supports) _arguments '1:renderer:(html epub markdown)' ;;
            esac
            ;;
    esac
}

_mdbook-tera "$@"
