#compdef opm-cli opmctl
# _opm-cli — Operator Framework opm-cli CLI command-line frontend wrapping the OPM Operator Package Manager building registry image index bundle catalog file-based catalogs FBC for Operator Lifecycle Manager OLM CatalogSource catalog migration validation linting render generate-CSV-bundle-update-graph-replaces-skips-stable-channel (Operator Framework team, Go); cobra
# upstream: https://github.com/operator-framework/operator-registry

_opm-cli() {
    local -a sub=(
        'alpha:alpha unstable commands'
        'index:index commands legacy SQLite'
        'init:initialize FBC catalog'
        'render:render FBC catalog'
        'serve:serve a catalog'
        'validate:validate a catalog'
        'migrate:migrate SQLite catalog to FBC'
        'generate:generate FBC files'
        'registry:registry commands legacy SQLite'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '--skip-tls[skip TLS verify]' \
        '--cache-dir=+[dir]:dir:_files -/' \
        '--cache-enforce-integrity[enforce cache integrity]' \
        '--use-http[use HTTP]' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'opm-cli subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments \
                    '--default-channel=+[name]:str:' \
                    '--description=+[file]:file:_files' \
                    '--icon=+[file]:file:_files' \
                    '*:package name:' ;;
                render) _arguments \
                    '--output=+[fmt]:f:(json yaml)' \
                    '*:bundle|index|catalog:_files' ;;
                serve) _arguments \
                    '--port=+[port]:n:' \
                    '--termination-log=+[file]:file:_files' \
                    '*:catalog dir:_files -/' ;;
                validate|migrate) _arguments '*:catalog dir:_files -/' ;;
            esac
            ;;
    esac
}

_opm-cli "$@"
