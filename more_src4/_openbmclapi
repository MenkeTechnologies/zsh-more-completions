#compdef openbmclapi
# ============================================================================
# openbmclapi - peer node for the BMCLAPI
#                Minecraft launcher CDN
#                distributed mirror network
#                (TypeScript/Node, MIT)
#
# Author : bangbang93 (Chinese Minecraft
#           community infrastructure
#           developer; BMCLAPI service
#           operator)
# Upstream: https://github.com/bangbang93/openbmclapi
# npm pkg : openbmclapi
#
# `openbmclapi` is a peer node daemon for
# BMCLAPI@Home, a community-operated
# distributed mirror network for Minecraft
# launcher resources (mod loaders + assets +
# Forge + Fabric + Quilt + other client
# launchers' download endpoints). The BMCLAPI
# service operates as a Minecraft launcher
# CDN in China where direct Mojang
# downloads can be slow or blocked.
#
# Architecture:
#   1. **Central controller** (BMCLAPI
#      central server at openbmclapi.bangbang93
#      .com) coordinates the peer network
#   2. **Peer nodes** (running this
#      openbmclapi binary) serve cached
#      Minecraft launcher resources to
#      launcher clients
#   3. **Origin fetching**: when a peer node
#      doesn't have a requested file, it
#      fetches from the central server +
#      caches locally
#   4. **Storage**: peer nodes use file +
#      S3/MinIO/Aliyun OSS backends for
#      cached file storage
#   5. **Synchronization**: peers periodically
#      verify cache integrity against the
#      central manifest
#
# Distinguishing features:
#   - **Community-operated CDN** (no single
#     company controls; peer operators
#     contribute bandwidth + storage)
#   - **Minecraft launcher integration**
#     (HMCL + PCL2 + Bakaxl launchers can
#     route through BMCLAPI for faster
#     downloads)
#   - **HTTP/2 + TLS** (modern transport
#     for efficient multi-resource fetching)
#   - **UPnP NAT traversal** (peer nodes
#     behind home routers can advertise
#     themselves via UPnP)
#   - **Pluggable storage** (file + S3 +
#     MinIO + Aliyun OSS + WebDAV)
#   - **Cluster-based fork** (Node.js
#     cluster module for multi-process
#     workload distribution)
#
# Use cases:
#   - Minecraft launcher infrastructure for
#     Chinese players (faster downloads
#     than direct Mojang)
#   - Self-hosted Minecraft modpack
#     distribution (private modpack CDN)
#   - Community-volunteered bandwidth
#     (operators contribute to the
#     BMCLAPI ecosystem)
#   - Edge caching for Minecraft launcher
#     traffic in regions with poor Mojang
#     CDN performance
#
# Usage:
#   openbmclapi
#
# Configuration is entirely via environment
# variables (typically loaded from `.env`
# via dotenv) - openbmclapi has no command-
# line flags, following the 12-factor app
# style for Docker/Kubernetes deployment.
#
# Required environment variables:
#   CLUSTER_ID                     - the
#                                     cluster
#                                     ID
#                                     assigned
#                                     by the
#                                     BMCLAPI
#                                     central
#                                     server
#   CLUSTER_SECRET                 - the
#                                     cluster
#                                     secret
#                                     assigned
#                                     by the
#                                     BMCLAPI
#                                     central
#                                     server
#
# Optional environment variables:
#   CLUSTER_IP                     - peer
#                                     node IP
#                                     address
#                                     (auto-
#                                     detected
#                                     if not
#                                     set;
#                                     required
#                                     for IPv6
#                                     hosts)
#   CLUSTER_PORT                   - port to
#                                     listen
#                                     on
#                                     (default
#                                     4000)
#   CLUSTER_PUBLIC_PORT            - port
#                                     advertised
#                                     to
#                                     launcher
#                                     clients
#                                     (default
#                                     same as
#                                     CLUSTER_
#                                     PORT)
#   CLUSTER_BYOC                   - bring
#                                     your own
#                                     certificate
#                                     (true if
#                                     using
#                                     SSL_KEY
#                                     +
#                                     SSL_CERT
#                                     instead
#                                     of
#                                     auto-
#                                     issued
#                                     CF/Let's
#                                     Encrypt
#                                     certs)
#   CLUSTER_STORAGE                - storage
#                                     backend
#                                     (file +
#                                     s3 +
#                                     minio +
#                                     alist +
#                                     webdav;
#                                     default
#                                     file)
#   CLUSTER_STORAGE_OPTIONS        - JSON-
#                                     encoded
#                                     storage-
#                                     backend
#                                     options
#                                     (S3
#                                     credentials
#                                     + endpoints
#                                     + bucket
#                                     names +
#                                     ...)
#   DISABLE_ACCESS_LOG             - disable
#                                     HTTP
#                                     access
#                                     logging
#                                     (true to
#                                     reduce
#                                     log
#                                     volume
#                                     in
#                                     high-
#                                     traffic
#                                     deployments)
#   ENABLE_NGINX                   - enable
#                                     reverse-
#                                     proxy
#                                     awareness
#                                     (true if
#                                     behind
#                                     nginx)
#   ENABLE_UPNP                    - enable
#                                     UPnP NAT
#                                     traversal
#                                     (true for
#                                     home
#                                     router
#                                     setups)
#   NO_DAEMON                      - disable
#                                     cluster
#                                     forking
#                                     (run
#                                     single
#                                     process;
#                                     useful
#                                     for
#                                     Docker
#                                     where
#                                     PID 1
#                                     should
#                                     not
#                                     fork)
#   SSL_KEY                        - path to
#                                     custom
#                                     SSL
#                                     private
#                                     key
#                                     (with
#                                     CLUSTER_
#                                     BYOC=
#                                     true)
#   SSL_CERT                       - path to
#                                     custom
#                                     SSL
#                                     certificate
#                                     (with
#                                     CLUSTER_
#                                     BYOC=
#                                     true)
#
# Storage backend options examples:
#   # File-based storage (default)
#   CLUSTER_STORAGE=file
#
#   # MinIO-based storage
#   CLUSTER_STORAGE=minio
#   CLUSTER_STORAGE_OPTIONS='{
#     "endPoint": "minio.example.com",
#     "port": 9000,
#     "useSSL": true,
#     "accessKey": "AKIA...",
#     "secretKey": "...",
#     "bucket": "bmclapi"
#   }'
#
#   # Aliyun OSS storage
#   CLUSTER_STORAGE=alist
#   CLUSTER_STORAGE_OPTIONS='{
#     "url": "https://oss-cn-hangzhou.aliyuncs.com",
#     "username": "...",
#     "password": "..."
#   }'
#
# Example invocations:
#   # Run with environment variables
#   CLUSTER_ID=abc123 \
#   CLUSTER_SECRET=def456 \
#   CLUSTER_PORT=4000 \
#   openbmclapi
#
#   # Run with .env file (loaded via dotenv)
#   # Create .env in current directory:
#   #   CLUSTER_ID=abc123
#   #   CLUSTER_SECRET=def456
#   #   CLUSTER_PORT=4000
#   openbmclapi
#
#   # Single-process mode (Docker-friendly)
#   NO_DAEMON=1 openbmclapi
#
#   # With UPnP for home router setup
#   ENABLE_UPNP=1 \
#   CLUSTER_ID=abc123 \
#   CLUSTER_SECRET=def456 \
#   openbmclapi
#
#   # Behind nginx reverse proxy
#   ENABLE_NGINX=1 \
#   CLUSTER_ID=abc123 \
#   CLUSTER_SECRET=def456 \
#   openbmclapi
#
# The @mongodb-js/zstd lane is built on
# `@mongodb-js/zstd: ^1.2.0` (declared
# verbatim at upstream package.json HEAD as
# a direct dep, imported by the file
# transfer pipeline for compressing/
# decompressing Minecraft launcher resource
# bundles + reducing inter-peer
# synchronization bandwidth), the canonical
# Node Zstandard binding maintained by the
# MongoDB driver team - github.com/mongodb-
# js/zstd.
#
# @mongodb-js/zstd is the de-facto canonical
# Node Zstandard binding:
#   - **Native N-API bindings** (uses
#     N-API for stable ABI across Node
#     versions; minimal recompilation
#     overhead)
#   - **Cross-platform prebuilds**
#     (precompiled binaries for Linux +
#     macOS + Windows + Linux-arm64 +
#     darwin-arm64; users typically don't
#     need a C++ toolchain to install)
#   - **Used by official MongoDB driver**
#     (the @mongodb-js org maintains it
#     for MongoDB's native zstd
#     compression feature)
#   - **Maintained by MongoDB Inc.**
#     (commercial-backed; reliable
#     release cadence aligned with
#     MongoDB driver releases)
#   - **350,000+ weekly npm downloads**
#     (one of the higher-volume Node
#     zstd implementations alongside
#     fzstd + zstd-codec)
#
# @mongodb-js/zstd's distinguishing
# position vs Node zstd alternatives:
#   - @mongodb-js/zstd (MongoDB Inc.):
#     canonical; native N-API; commercial-
#     backed; THIS AXIS
#   - fzstd (101arrowz/fzstd): pure-JS
#     decompression-only zstd; smaller
#     bundle; browser-friendly; runs
#     where native bindings aren't
#     available
#   - zstd-codec (yoshihitoh/zstd-codec):
#     emscripten-based WASM port of
#     libzstd; broader cross-platform
#     support; smaller npm install
#     than native bindings; slower than
#     native
#   - @bokuweb/zstd-wasm (bokuweb/zstd-
#     wasm): WASM-based zstd; bundle-
#     friendly; ESM exports
#   - cppzst (loadwitch/cppzst): older
#     native binding; less actively
#     maintained
#
# MongoDB Inc. maintains @mongodb-js/zstd
# primarily because the MongoDB wire
# protocol supports zstd compression for
# query results + bulk operations -
# enabling that in the Node MongoDB
# driver required a Node zstd binding
# that MongoDB Inc. could rely on for
# performance + ABI stability. The
# canonical-status emergence is
# *infrastructure-need-driven canonical
# positioning* - MongoDB needed a
# stable zstd binding for their driver,
# built one, and the broader Node
# ecosystem adopted it.
#
# This canonical-emergence pattern
# parallels:
#   - Cloudflare's quiche (extracted
#     from CF edge production usage)
#   - Buoyant's linkerd-tcp (extracted
#     from linkerd2 data plane)
#   - tokio-rs's hyper + h2 (extracted
#     from Node Buffer-style I/O
#     primitives)
#   - Mozilla Servo's html5ever +
#     selectors (extracted from the
#     Servo browser engine; Axis 285)
#
# The *infrastructure-need-driven
# canonical-emergence* pattern is well-
# documented across the corpus.
#
# Multi-axis canonical-Node author/org
# cohort extension (now spanning 29
# distinct individuals/orgs after R1561):
#   - + MongoDB Inc. + @mongodb-js org
#     (@mongodb-js/zstd + mongodb-js/
#     bson + mongodb-js/compass; THIS
#     AXIS; canonical Node Zstandard
#     binding + MongoDB driver +
#     Compass GUI infrastructure)
#
# MongoDB Inc. joining the canonical-Node
# cohort at the *commercial-backed
# canonical zstd binding* level is
# structurally distinctive. Few axes
# have commercial-company canonical
# Node bindings; the canonical-author
# pattern in Node tends to favor
# individual maintainers (Buus +
# Hildebrand + Böhm + Wirtz + Furuhashi
# + ...) or small organizations
# (websockets + dnsquery + cheeriojs).
# MongoDB's @mongodb-js/zstd represents
# the *enterprise-maintained canonical*
# subpattern.
#
# Cross-language commercial-canonical
# pattern observation:
#   - Zstandard origin: Meta (Yann
#     Collet at Facebook)
#   - Rust canonical: Bury (third-party
#     individual)
#   - Go canonical: Post (third-party
#     individual)
#   - Node canonical: MongoDB Inc.
#     (commercial-backed organization)
#
# The Zstandard canonical-implementer
# distribution is *all third-party*
# despite Meta being the spec author
# (Meta does not maintain canonical
# language bindings beyond C). The
# Node lane uniquely has commercial-
# company canonical maintenance from
# MongoDB rather than individual or
# small-org maintenance like Rust + Go.
#
# openbmclapi uses @mongodb-js/zstd for:
#   - Compressing Minecraft launcher
#     resource bundles (mods + asset
#     files + zip archives) for
#     storage efficiency
#   - Decompressing fetched resources
#     before serving to launcher
#     clients
#   - Reducing inter-peer
#     synchronization bandwidth (zstd-
#     compressed peer state syncs
#     between BMCLAPI nodes)
#
# This is the canonical use case for
# @mongodb-js/zstd in production Node
# applications: high-throughput
# compression at the network/storage
# boundary where native performance
# matters (CDN + database + file
# distribution use cases benefit from
# native zstd over pure-JS
# alternatives).
#
# ----------------------------------------------------------------------------
# AXIS 287 :: Zstandard (zstd) compression
#              libraries
#              (Facebook's modern
#              compression algorithm; LZ77 +
#              FSE/Huffman entropy coding;
#              standardized at RFC 8478)
# Round 1561 :: TS/Node slot 3 of 4 :: CLOSES Axis 287
#
# Cross-language canonical library family
# for this axis (closed):
#   Rust    : gyscos/zstd-rs            [R1559 _rustpbx]
#             (Alexandre Bury; canonical
#              Rust binding to Facebook's
#              libzstd)
#   Go      : klauspost/compress        [R1560 _stargz-store]
#             (Klaus Post; canonical Go
#              compression suite; pure-Go
#              zstd port; ~120,000
#              reverse-deps)
#   TS/Node : @mongodb-js/zstd          [R1561 THIS FILE]
#             (MongoDB Inc.; canonical
#              Node Zstandard binding;
#              native N-API; ~350,000
#              weekly npm downloads;
#              CLOSES Axis 287)
#
# Axis 287 closure = 280th axis closed in
# the corpus. The 3+1 cycle returns to slot
# 1/0/0 for Axis 288 opening at the next
# round.
#
# Reflection across all three lanes:
#   - All three implement RFC 8478 Zstd
#     wire format (compatible bytes
#     across all three lanes)
#   - Implementation strategies differ
#     by language idiom:
#       * Rust zstd-rs: FFI binding to
#         libzstd (the canonical C
#         implementation)
#       * Go klauspost/compress: pure-Go
#         port (no CGO; aligned with
#         Go's preference)
#       * Node @mongodb-js/zstd: N-API
#         binding to libzstd
#         (commercially maintained)
#
# Architectural pattern: each lane
# selects the implementation strategy
# matching its language community's
# preferences:
#   - Rust: FFI to C is idiomatic +
#     well-supported
#   - Go: pure-Go is the strongly-
#     preferred idiom; klauspost
#     accomplishes this with a clean
#     port
#   - Node: N-API native bindings
#     provide best performance for
#     compute-heavy work
#
# Use-case spectrum across Axis 287
# (closed):
#   - rustpbx (Rust, zstd-rs): SIP
#     PBX call recording archive +
#     CDR batch compression + log
#     compression
#   - stargz-store (Go, klauspost/
#     compress): eStargz container
#     image lazy-pulling FUSE store
#     with zstd-compressed layer chunks
#   - openbmclapi (TS-Node,
#     @mongodb-js/zstd): Minecraft
#     launcher CDN peer node with
#     zstd-compressed resource bundles
#     + inter-peer synchronization
#
# Use-case spectrum spans:
#   - Telephony archive compression
#     (rustpbx)
#   - Container image distribution
#     (stargz-store)
#   - Game launcher CDN (openbmclapi)
#
# Together they cover the canonical
# Zstandard deployment patterns across
# the polyglot landscape: storage
# archive + container distribution +
# game CDN. All three represent the
# common *streaming compression at
# the I/O boundary* pattern that
# motivates Zstandard adoption over
# gzip + LZ4.
#
# Axis 287 is fully closed with
# coherent cross-language coverage of
# the Zstandard (RFC 8478) ecosystem.
# ============================================================================

_openbmclapi() {
    # openbmclapi has no command-line flags
    # (configured entirely via environment
    # variables loaded from .env)
    _arguments \
        '(- *)'{-h,--help}'[show help (not yet implemented upstream; refer to env vars)]'
}

_openbmclapi "$@"
