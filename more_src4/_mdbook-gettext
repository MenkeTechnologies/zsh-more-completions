#compdef mdbook-gettext
# _mdbook-gettext — i18n preprocessor translating mdbook content via PO files (google/mdbook-i18n-helpers)
# upstream: https://github.com/google/mdbook-i18n-helpers
# Subcommands from i18n-helpers/src/bin/mdbook-gettext.rs.

_mdbook-gettext() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'supports:check whether a renderer is supported'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                supports) _arguments '1:renderer:(html epub markdown)' ;;
            esac
            ;;
    esac
}

_mdbook-gettext "$@"
