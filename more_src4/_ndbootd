#compdef ndbootd
# Documentation: man ndbootd(8)
# Source: netbsd/src usr.sbin/ndbootd — Sun Network Disk boot server (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-s+[second-stage boot program (file or directory)]:boot2:_files' \
    '-i+[listen only on interface]:interface:_net_interfaces' \
    '-w+[ND window size in 1KB packets (default 6)]:windowsize:_default' \
    '-d[debug mode, stderr output, no fork]' \
    '1:first-stage boot program:_files' \
    && ret=0

return ret
