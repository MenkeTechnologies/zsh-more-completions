#compdef pinecone
# _pinecone — Pinecone vector database CLI (Pinecone, Go); spf13/cobra
# upstream: https://github.com/pinecone-io/cli

_pinecone() {
    local -a sub=(
        'login:authenticate via browser'
        'logout:logout'
        'whoami:show current user'
        'config:manage config'
        'target:set/show current project/org'
        'organization:manage organizations'
        'project:manage projects'
        'api-key:manage API keys'
        'index:manage indexes'
        'collection:manage collections'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--json[json output]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pinecone subcommand' sub ;;
        args)
            case $words[1] in
                organization|project|api-key|collection) _arguments \
                    '1:cmd:(list create delete describe)' \
                    '*:arg:' ;;
                index) _arguments \
                    '1:cmd:(list create create-for-model delete describe configure stats embed query upsert fetch delete-vectors)' \
                    '--name=+[name]:str:' \
                    '--dimension=+[dimension]:n:' \
                    '--metric=+[metric]:metric:(cosine euclidean dotproduct)' \
                    '--cloud=+[cloud]:cloud:(aws gcp azure)' \
                    '--region=+[region]:region:' \
                    '*:arg:' ;;
                target) _arguments \
                    '--project=+[project]:str:' \
                    '--organization=+[organization]:str:' \
                    '*:arg:' ;;
                config) _arguments \
                    '1:cmd:(get set list unset)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_pinecone "$@"
