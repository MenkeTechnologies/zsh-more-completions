#compdef ompi_timing_post
# Documentation: https://docs.open-mpi.org/
# Source: open-mpi/ompi ompi/tools/mpisync/ompi_timing_post — post-process OMPI timing log (bash).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '1:timing input file:_files' \
    '2:output file:_files' \
    && ret=0

return ret
