#compdef mraa-spi
# _mraa-spi — Intel mraa-spi CLI command-line wrapper around Intel libmraa I/O abstraction library performing list version transfer mode frequency on SPI buses across Intel Galileo Edison Joule MinnowBoard ARM Raspberry Pi Beaglebone single board computers (Intel team, C); custom argparse
# upstream: https://github.com/intel-iot-devkit/mraa

_mraa-spi() {
    local -a sub=(
        'list:list available spi buses'
        'version:print versions'
        'transfer:transfer bytes on SPI bus'
        'mode:set SPI mode'
        'frequency:set SPI bus frequency'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mraa-spi subcommand' sub ;;
        args)
            case $words[1] in
                transfer) _arguments '1:bus:' '*:bytes:' ;;
                mode) _arguments '1:bus:' '2:mode:(0 1 2 3)' ;;
                frequency) _arguments '1:bus:' '2:hz:' ;;
            esac
            ;;
    esac
}

_mraa-spi "$@"
