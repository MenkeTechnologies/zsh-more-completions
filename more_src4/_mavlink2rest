#compdef mavlink2rest
# Documentation: source-direct extraction from upstream
# mavlink/mavlink2rest src/cli.rs `clap::App::new(env!("CARGO_PKG_NAME"))`
# + `.arg(clap::Arg::with_name("X").short("Y").long("LONG").
# value_name("...").default_value("...").possible_values(&["..."]))`
# chain (uses clap-builder v2 API, NOT clap-derive).
# Reference accessed: 2026-05-30 via gh api.
# mavlink mavlink2rest R155b — REST API + WebSocket bridge to a
# MAVLink autopilot (PX4 / ArduPilot etc.). Sister tool to the
# broader drone/MAVLink ecosystem; canonical upstream is at
# mavlink/mavlink2rest.

_arguments -s -S \
  '(-c --connect)'{-c+,--connect=}'[MAVLink connection string (default udpin\:0.0.0.0\:14550)]:TYPE\:IP/SERIAL\:PORT/BAUD:' \
  '(-s --server)'{-s+,--server=}'[IP\:PORT for the REST/WebSocket server (default 0.0.0.0\:8088)]:host\:port:' \
  '--mavlink=[MAVLink protocol version]:version:(1 2)' \
  '--system-id=[MAVLink system ID for this service (1-255; default 255)]:id:' \
  '--component-id=[MAVLink component ID for this service (default 0)]:id:' \
  '--default-api-version=[REST API default version (currently only 1 is supported)]:version:(1)' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--send-initial-heartbeats[burst initial heartbeats spaced 0.1s apart (wakes up PX4-like autopilots)]'
