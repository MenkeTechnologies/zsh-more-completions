#compdef nightwatch-cli nightwatch
# _nightwatch-cli — BrowserStack Nightwatch.js nightwatch-cli CLI command-line frontend wrapping the Nightwatch.js open-source end-to-end testing framework powered by Node.js and W3C WebDriver for desktop browsers and mobile websites and apps written in Node JavaScript by Andrei Rusu now BrowserStack JavaScript-based End-to-End E2E testing framework Selenium WebDriver based test config env test-suite group skiptags tags reporter retries suiteRetries timeout headless headed open parallel workers chrome firefox safari edge mobile-config-cucumber selenium standalone test-runner mocha cucumber jasmine jest install-driver (BrowserStack Nightwatch team Andrei Rusu Pavel Beierl, JavaScript); commander
# upstream: https://nightwatchjs.org/

_nightwatch-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "nightwatch.conf.* *.conf.js *.json"' \
        '--config=+[file]:file:_files -g "nightwatch.conf.* *.conf.js *.json"' \
        '-e+[env]:str:' \
        '*-e+[env]:str:' \
        '--env=+[name]:str:' \
        '*--env=+[name]:str:' \
        '-t+[test path]:file:_files' \
        '--test=+[file]:file:_files' \
        '--testcase=+[name]:str:' \
        '-T+[test case]:str:' \
        '--group=+[name]:str:' \
        '*--group=+[name]:str:' \
        '--skipgroup=+[names]:str:' \
        '--tag=+[name]:str:' \
        '*--tag=+[name]:str:' \
        '*-a+[tag]:str:' \
        '--skiptags=+[names]:str:' \
        '*--skiptags=+[name]:str:' \
        '-f+[filter pattern]:str:' \
        '--filter=+[pattern]:str:' \
        '-r+[reporter]:n:(default html junit json mochawesome teamcity tap dot)' \
        '--reporter=+[r]:n:(default html junit json mochawesome teamcity tap dot)' \
        '-o+[output dir]:dir:_files -/' \
        '--output=+[dir]:dir:_files -/' \
        '--output-folder=+[dir]:dir:_files -/' \
        '--retries=+[N]:n:' \
        '--suiteRetries=+[N]:n:' \
        '--reporter-options=+[opts]:str:' \
        '--testdir=+[dir]:dir:_files -/' \
        '--testsuite=+[file]:_files' \
        '--workers=+[N]:n:' \
        '--parallel[parallel]' \
        '--use-xvfb[use Xvfb]' \
        '--xvfb-args=+[args]:str:' \
        '--use-selenium-cli-args[use selenium CLI args]' \
        '--use-chrome-launcher[use chrome launcher]' \
        '--use-edge-launcher[use edge launcher]' \
        '--standalone[standalone]' \
        '--devtools[devtools]' \
        '--debug[debug]' \
        '--headless[headless]' \
        '--no-headless[no headless]' \
        '--open[open report]' \
        '--timeout=+[ms]:n:' \
        '--start-process=+[v]:v:(true false)' \
        '--screenshots-on-failure[screenshots on failure]' \
        '--persist_globals[persist globals]' \
        '--unit-tests[unit tests]' \
        '--mocha[use mocha runner]' \
        '--cucumber=+[file]:file:_files' \
        '--cucumber-feature-files=+[glob]:str:' \
        '--test-runner=+[r]:r:(default mocha cucumber jasmine)' \
        '--silent[silent]' \
        '--no-color[no color]' \
        '--color[force color]' \
        '--include=+[glob]:str:' \
        '*--include=+[glob]:str:' \
        '--exclude=+[glob]:str:' \
        '*--exclude=+[glob]:str:' \
        '--unit-test[unit test]' \
        '--use-test-fixtures[use fixtures]' \
        '--list-suites[list suites]' \
        '--browser=+[name]:n:(chrome firefox safari edge ie opera)' \
        '*-b+[browser]:n:(chrome firefox safari edge ie opera)' \
        '--app=+[name]:str:' \
        '--app-up-timeout=+[sec]:n:' \
        '--app-action-timeout=+[sec]:n:' \
        '--imports-dir=+[dir]:dir:_files -/' \
        '*:tests:_files'
}

_nightwatch-cli "$@"
