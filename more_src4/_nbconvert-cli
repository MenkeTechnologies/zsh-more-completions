#compdef nbconvert-cli nbconvert2
# _nbconvert-cli — Jupyter nbconvert-cli CLI command-line frontend wrapping the nbconvert Jupyter notebook conversion tool providing to-html to-pdf to-latex to-markdown to-rst to-script to-asciidoc to-webpdf to-slides to-notebook execute embed preprocessor template-file output-dir clear-output stdin (Jupyter team, Python); traitlets
# upstream: https://nbconvert.readthedocs.io/

_nbconvert-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--to=+[fmt]:f:(html latex pdf markdown rst slides script python asciidoc webpdf qtpdf notebook custom)' \
        '--from=+[fmt]:str:' \
        '--template=+[name]:str:' \
        '--template-file=+[file]:file:_files' \
        '--writer=+[name]:str:' \
        '--post=+[name]:str:' \
        '--output=+[file]:file:_files' \
        '-o+[output]:file:_files' \
        '--output-dir=+[dir]:dir:_files -/' \
        '--input-dir=+[dir]:dir:_files -/' \
        '--stdout[stdout output]' \
        '--stdin[stdin input]' \
        '--execute[execute notebook]' \
        '--allow-errors[allow errors]' \
        '--allow-chromium-download[allow chromium download]' \
        '--debug[debug]' \
        '--clear-output[clear output cells]' \
        '--no-input[hide input cells]' \
        '--no-prompt[hide prompts]' \
        '--inplace[inplace mode]' \
        '--embed-images[embed images]' \
        '--sanitize-html[sanitize HTML]' \
        '--ExecutePreprocessor.timeout=+[sec]:n:' \
        '--ExecutePreprocessor.kernel_name=+[name]:str:' \
        '--ExecutePreprocessor.startup_timeout=+[sec]:n:' \
        '--CSSHTMLHeaderPreprocessor.style=+[name]:str:' \
        '--HighlightMagicsPreprocessor.languages=+[map]:str:' \
        '--HighlightMagicsPreprocessor.javascript_languages=+[map]:str:' \
        '--TagRemovePreprocessor.remove_cell_tags=+[tag]:str:' \
        '--TagRemovePreprocessor.remove_input_tags=+[tag]:str:' \
        '--TagRemovePreprocessor.remove_all_outputs_tags=+[tag]:str:' \
        '--HTMLExporter.theme=+[t]:t:(light dark)' \
        '--reveal-prefix=+[prefix]:str:' \
        '--no-config[no config]' \
        '--allow-prerelease[allow prerelease]' \
        '*:notebook:_files -g "*.ipynb *.md *.py *.r"'
}

_nbconvert-cli "$@"
