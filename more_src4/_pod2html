#compdef pod2html
# Documentation: pod2html --help
# Source: Perl POD pod2html — convert POD to HTML.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(--backlink --nobacklink)--backlink[head1 links to top]' \
    '(--backlink --nobacklink)--nobacklink[no head1-to-top links]' \
    '--cachedir=[directory cache dir]:dir:_files -/' \
    '--css=[stylesheet URL]:url:' \
    '--flush[flush directory cache]' \
    '(--header --noheader)--header[block header / footer]' \
    '(--header --noheader)--noheader[no block header / footer]' \
    '--htmldir=[output HTML directory]:dir:_files -/' \
    '--htmlroot=[HTTP server base URL]:url:' \
    '(--index --noindex)--index[generate top-of-page index]' \
    '(--index --noindex)--noindex[no top-of-page index]' \
    '--infile=[input POD file]:file:_files -g "*.{pod,pm,pl}"' \
    '--outfile=[output HTML file]:file:_files -g "*.html"' \
    '(--poderrors --nopoderrors)--poderrors[include POD ERRORS section]' \
    '(--poderrors --nopoderrors)--nopoderrors[skip POD ERRORS section]' \
    '--podpath=[colon-separated POD search dirs]:paths:' \
    '--podroot=[base directory for podpath]:dir:_files -/' \
    '(--quiet --noquiet)--quiet[suppress benign warnings]' \
    '(--quiet --noquiet)--noquiet[show all warnings]' \
    '(--recurse --norecurse)--recurse[recurse into podpath subdirs]' \
    '(--recurse --norecurse)--norecurse[do not recurse]' \
    '--title=[HTML title]:string:' \
    '(--verbose --noverbose)--verbose[verbose]' \
    '(--verbose --noverbose)--noverbose[no verbose]' \
    && ret=0

return ret
