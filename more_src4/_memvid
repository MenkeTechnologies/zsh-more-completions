    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '*'{-v,--verbose}'[increase logging verbosity (repeatable)]' \
        '(-m --embedding-model --model)'{-m,--embedding-model,--model}'=[default embedding model]:model:(bge-small bge-base nomic gte-large openai openai-small openai-ada nvidia)' \
        '--parallel-segments[enable parallel segment builder globally]' \
        '--global-no-parallel-segments[force legacy ingestion (conflicts with --parallel-segments)]' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _mv_cmds=(
                'create:create a new .mv2 memory file'
                'open:inspect metadata + manifests of a memory'
                'put:append a frame (file/dir/URL)'
                'correct:store a correction with retrieval-priority boost'
                'put-many:batch ingest with pre-computed embeddings (parallel_segments)'
                'api-fetch:fetch remote content + ingest as frames'
                'view:display frame content + metadata'
                'update:modify frame metadata'
                'delete:remove frames by URI or ID'
                'timeline:query frames by time range'
                'ask:RAG Q&A with retrieval + synthesis'
                'audit:audit report with full source provenance'
                'find:lexical search over the memory'
                'vec-search:vector similarity search'
                'debug-segment:dump raw vector segment bytes'
                'when:resolve temporal phrase (temporal_track)'
                'stats:show memory statistics'
                'verify:integrity verification'
                'doctor:repair + rebuild indices'
                'process-queue:process the enrichment queue'
                'verify-single-file:assert no auxiliary files alongside memory'
                'tables:extract / list / export / view tables'
                'tickets:manage access tickets via API'
                'plan:view + manage subscription'
                'binding:show memory binding info'
                'config:manage persistent CLI configuration'
                'status:show config + system status'
                'who:show the active writer holding the lock'
                'nudge:request flush + release'
                'enrich:run enrichment engines for memory cards'
                'memories:view extracted memory cards'
                'state:O(1) entity-state lookup'
                'facts:audit fact changes with provenance'
                'export:export facts to N-Triples / JSON / CSV'
                'schema:infer + manage predicate schemas'
                'models:manage LLM models for enrichment'
                'follow:traverse the Logic-Mesh entity graph'
                'sketch:build sketch track for fast candidate generation'
                'session:manage time-travel replay sessions (replay)'
                'lock:encrypt .mv2 into .mv2e capsule (encryption)'
                'unlock:decrypt .mv2e back to .mv2 (encryption)'
                'version:print version'
            )
            _describe -t commands 'memvid command' _mv_cmds && ret=0
            ;;
        args)
            case $words[1] in
                create)
                    _arguments \
                        '1:memory file to create:_files -g "*.mv2"' \
                        '--help[show help]' && ret=0
                    ;;
                open|verify|verify-single-file|doctor|stats|debug-segment|process-queue|binding|who|nudge|state)
                    _arguments \
                        '1:memory file:_files -g "*.mv2"' \
                        '--help[show help]' && ret=0
                    ;;
                put|put-many|correct|api-fetch)
                    _arguments \
                        '1:memory file:_files -g "*.mv2"' \
                        '--input=[input file or directory]:path:_files' \
                        '--embeddings[generate embeddings during ingest]' \
                        '--url=[URL to fetch (api-fetch)]:url:' \
                        '--help[show help]' && ret=0
                    ;;
                find|vec-search)
                    _arguments \
                        '1:memory file:_files -g "*.mv2"' \
                        '--query=[search query]:query:' \
                        '--limit=[result limit]:n:' \
                        '--json[JSON output]' \
                        '--help[show help]' && ret=0
                    ;;
                ask)
                    _arguments \
                        '1:memory file:_files -g "*.mv2"' \
                        '--question=[question to ask]:question:' \
                        '--model=[LLM model override]:model:' \
                        '--help[show help]' && ret=0
                    ;;
                view|update|delete)
                    _arguments \
                        '1:memory file:_files -g "*.mv2"' \
                        '--frame-id=[frame id]:id:' \
                        '--uri=[frame URI]:uri:' \
                        '--json[JSON output]' \
                        '--help[show help]' && ret=0
                    ;;
                timeline)
                    _arguments \
                        '1:memory file:_files -g "*.mv2"' \
                        '--since=[unix timestamp (start)]:ts:' \
                        '--until=[unix timestamp (end)]:ts:' \
                        '--limit=[result limit]:n:' \
                        '--help[show help]' && ret=0
                    ;;
                when)
                    _arguments \
                        '1:memory file:_files -g "*.mv2"' \
                        '2:temporal phrase:' \
                        '--help[show help]' && ret=0
                    ;;
                lock)
                    _arguments \
                        '1:memory file:_files -g "*.mv2"' \
                        '--help[show help]' && ret=0
                    ;;
                unlock)
                    _arguments \
                        '1:encrypted capsule:_files -g "*.mv2e"' \
                        '--help[show help]' && ret=0
                    ;;
                config|status|tickets|plan|models|session|enrich|memories|facts|export|schema|follow|sketch|audit|tables)
                    _arguments \
                        '*: :_files' \
                        '--help[show help]' && ret=0
                    ;;
                version)
                    _arguments '--help[show help]' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_memvid "$@"
