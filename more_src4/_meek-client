#compdef meek-client
# Documentation: https://man.archlinux.org/man/extra/meek/meek-client.1.en
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# meek-client: Tor pluggable transport client using domain fronting
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--url=[URL to correspond with]:url:' \
  '--front=[front domain name]:domain:_hosts' \
  '--utls=[uTLS ClientHello fingerprint]:fingerprint:(hellochrome_auto hellofirefox_auto helloios_auto helloedge_auto)' \
  '--proxy=[upstream proxy URL]:url:' \
  '--helper=[HTTP helper browser extension address]:address:' \
  '--log=[log file]:file:_files' && ret=0
return ret
