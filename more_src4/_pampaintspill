#compdef pampaintspill
# Documentation: man pampaintspill (Netpbm)
# Source: fill the background of a Netpbm image with spread (spilling) colors from foreground pixels.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--bgcolor=[background color to fill]:color:' \
    '--wrap[wrap around image edges]' \
    '--all[treat every pixel as fg]' \
    '--downsample=[downsample factor]:number:' \
    '--near=[nearness threshold]:number:' \
    '--power=[falloff exponent]:number:' \
    '-randomseed=[random seed]:integer:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
