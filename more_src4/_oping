#compdef oping noping
# Documentation: https://manpages.debian.org/testing/oping/noping.8.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-4[force IPv4]' \
  '-6[force IPv6]' \
  '-c+[number of ICMP packets to send]:count:' \
  '-i+[interval between sends seconds]:interval:' \
  '-w+[wait timeout for replies seconds]:secs:' \
  '-t+[IP time to live 1-255]:ttl:' \
  '-Q+[Quality of Service (DSCP/TOS) of outgoing packets]:qos:' \
  '-I+[source address]:srcaddr:' \
  '-D+[outgoing interface]:device:_net_interfaces' \
  '-m+[mark on outgoing packets (Linux only)]:mark:' \
  '-f+[read hosts from file]:file:_files' \
  '-O+[write CSV measurements file]:file:_files' \
  '-u[force UTF-8 output (noping)]' \
  '-U[disable UTF-8 output (noping)]' \
  '-g+[graph style (noping)]:style:(none prettyping boxplot histogram)' \
  '-H+[graph height 1-5 (noping)]:height:(1 2 3 4 5)' \
  '-b[audible bell when packet received before timeout (noping)]' \
  '-P+[latency percentile percent (noping)]:percent:' \
  '-Z+[exit non-zero if drop rate exceeds percent (noping)]:percent:' \
  '*:host:_hosts' && ret=0

return ret
