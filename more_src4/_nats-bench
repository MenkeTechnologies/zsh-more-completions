_arguments -s \
  '-s[server URLs (comma separated)]:urls:' \
  '-tls[enable TLS secure connection]' \
  '-np[number of concurrent publishers]:n:' \
  '-ns[number of concurrent subscribers]:n:' \
  '-n[number of messages to publish]:n:' \
  '-ms[message size in bytes]:n:' \
  '-csv[CSV output file]:file:_files' \
  '-creds[user credentials file]:file:_files' \
  '-h[show help]' \
  '*:subject:'
