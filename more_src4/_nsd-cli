#compdef nsd-cli
# _nsd-cli — NLnet Labs NSD authoritative DNS name server CLI alias (NLnetLabs team, C); custom argparse
# upstream: https://github.com/NLnetLabs/nsd

_nsd-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-4[ipv4 only]' \
        '-6[ipv6 only]' \
        '-a+[bind address]:str:' \
        '-c+[config file]:file:_files -g "nsd.conf"' \
        '-d[do not detach]' \
        '-f+[database file]:file:_files' \
        '-i+[identity]:str:' \
        '-I+[server-id]:str:' \
        '-l+[log file]:file:_files' \
        '-N+[server count]:n:' \
        '-n+[tcp count]:n:' \
        '-P+[pid file]:file:_files' \
        '-p+[port]:port:' \
        '-s+[stats interval]:n:' \
        '-t+[chroot dir]:dir:_files -/' \
        '-u+[user]:_users' \
        '-V+[verbosity]:n:' \
        '-x+[xfrd dir]:dir:_files -/' \
        '*:arg:'
}

_nsd-cli "$@"
