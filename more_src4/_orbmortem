#compdef orbmortem
# _orbmortem — orbuculum project orbmortem CLI post-mortem ARM Cortex-M ETM ETMv4 ETMv3 instruction trace decoder client connecting to orbuculum daemon decoding routed branches exception entries with elf symbol resolution capturing call-history rolling buffer at faults (Dave Marples team, C); custom argparse
# upstream: https://github.com/orbcode/orbuculum

_orbmortem() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v+[verbose level]:l:(0 1 2 3 4)' \
        '-d+[delete after]:n:' \
        '-e+[elf file]:file:_files -g "*.elf *.axf *.out"' \
        '-E[exception detail]' \
        '-l+[history depth]:n:' \
        '-O+[objdump path]:file:_files' \
        '-p+[protocol]:p:(etm4 etm3 itm tpiu)' \
        '-r[reset]' \
        '-s+[server:port]:host:port:' \
        '-t+[tag]:str:' \
        '-T[TPIU framing]' \
        '-w+[output dir]:dir:_files -/' \
        '-x+[exception mask]:n:' \
        '*:elf file:_files -g "*.elf *.axf"'
}

_orbmortem "$@"
