#compdef mythfilldatabase
# Documentation: https://github.com/MythTV/mythtv/blob/master/mythtv/programs/mythfilldatabase/mythfilldatabase_commandlineparser.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mythfilldatabase: populate MythTV program guide from grabber data
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help,--usage}'[show help]' \
  '(- *)--version[show version]' \
  '--manual[interactive configuration]' \
  '--preset[use channel preset values]' \
  '--file[bypass grabber; read SD-XML]' \
  '--sourceid=[operate on single source]:id:' \
  '--offset=[day offset]:days:' \
  '--xmlfile=[XML file to import]:file:_files -g "*.xml"' \
  '--only-update-guide[only update guide]' \
  '--do-channel-updates[update channel table]' \
  '--do-not-filter-new-channels[do not filter new channels]' \
  '--cardtype=[card type]:type:' \
  '--refresh=[refresh list]:list:' \
  '--max-days=[force max days to update]:days:' \
  '--refresh-today[refresh today]' \
  '--dont-refresh-tomorrow[do not refresh tomorrow]' \
  '--refresh-second[refresh second day]' \
  '--refresh-day[refresh day]' \
  '--dont-refresh-tba[do not refresh TBA]' \
  '--refresh-all[refresh all]' \
  '--no-allatonce[disable all-at-once]' \
  '--only-update-channels[only update channels]' \
  '--no-mark-repeats[do not mark repeats]' \
  '--no-resched[do not reschedule]' \
  '(-v --verbose)'{-v,--verbose=}'[log filtering]:level:' \
  '--logpath=[log to file]:dir:_files -/' \
  '(-q --quiet)'{-q,--quiet}'[reduce logging]' \
  '--loglevel=[logging level]:level:(emerg alert crit err warning notice info debug trace)' \
  '--syslog=[syslog facility]:facility:' && ret=0
return ret
