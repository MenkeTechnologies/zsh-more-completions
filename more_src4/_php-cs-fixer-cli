#compdef php-cs-fixer-cli
# _php-cs-fixer-cli — PHP-CS-Fixer PHP coding standards fixer CLI alias (PHP-CS-Fixer team / Fabien Potencier, PHP); custom argparse via Symfony Console
# upstream: https://github.com/PHP-CS-Fixer/PHP-CS-Fixer

_php-cs-fixer-cli() {
    local -a sub=(
        'fix:apply fixes to files'
        'check:check files without fixing'
        'describe:describe a rule or rule set'
        'list-files:list files'
        'list-sets:list rule sets'
        'self-update:self update'
        'help:show help'
        'list:list commands'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[force ansi]' \
        '--no-ansi[no ansi]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'php-cs-fixer subcommand' sub ;;
        args)
            case $words[1] in
                fix|check) _arguments \
                    '--config=+[config file]:file:_files -g ".php-cs-fixer.php .php-cs-fixer.dist.php"' \
                    '--rules=+[rules]:str:' \
                    '--using-cache=+[use cache]:b:(yes no)' \
                    '--cache-file=+[cache file]:file:_files' \
                    '--dry-run[dry run]' \
                    '--allow-risky=+[allow risky]:b:(yes no)' \
                    '--stop-on-violation[stop on violation]' \
                    '--show-progress=+[show progress]:p:(none dots)' \
                    '--diff[show diff]' \
                    '--format=+[format]:f:(checkstyle gitlab json junit txt xml)' \
                    '--path-mode=+[path mode]:m:(override intersection)' \
                    '*:path:_files' ;;
                describe) _arguments '*:rule:' ;;
                list-files|list-sets) _arguments \
                    '--config=+[config file]:file:_files' ;;
                self-update) _arguments \
                    '--major[major version]' ;;
            esac
            ;;
    esac
}

_php-cs-fixer-cli "$@"
