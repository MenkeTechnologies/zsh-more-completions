#compdef p11tool-cli p11tool
# Documentation: https://manpages.debian.org/bookworm/gnutls-bin/p11tool.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm p11tool(1) manpage. Real binary is p11tool.

# p11tool: GnuTLS PKCS#11 utility
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-d --debug)'{-d,--debug=}'[debug level]:level:' \
  '--list-tokens[list all available tokens]' \
  '--list-token-urls[list URLs of available tokens]' \
  '--list-mechanisms[list mechanisms in a token]' \
  '--initialize[initialize a PKCS#11 token]' \
  '--initialize-pin[initialize user PIN]' \
  '--initialize-so-pin[initialize SO PIN]' \
  '--set-pin=[user PIN]:pin:' \
  '--set-so-pin=[SO PIN]:pin:' \
  '--list-all[list all objects]' \
  '--list-all-certs[list all certificates]' \
  '--list-certs[list certificates]' \
  '--list-all-privkeys[list all private keys]' \
  '--list-all-trusted[list trusted objects]' \
  '--export[export object]' \
  '--export-stapled[export with stapled extensions]' \
  '--export-chain[export certificate chain]' \
  '--export-pubkey[export public key]' \
  '--info[show object info]' \
  '--generate-privkey=[generate key pair of type]:type:(rsa dsa ecdsa)' \
  '--bits=[key size in bits]:n:' \
  '--curve=[ECC curve]:curve:' \
  '--sec-param=[security parameter]:level:(low legacy medium high ultra future)' \
  '--set-id=[set ID]:id:' \
  '--set-label=[set label]:label:' \
  '--write[write to token]' \
  '--delete[delete from token]' \
  '--label=[object label]:label:' \
  '--id=[object ID]:id:' \
  '--load-privkey=[private key file]:file:_files' \
  '--load-pubkey=[public key file]:file:_files' \
  '--load-certificate=[certificate file]:file:_files' \
  '--outfile=[output file]:file:_files' \
  '--login[login as user]' \
  '--so-login[login as SO]' \
  '--admin-login[admin login (alias for --so-login)]' \
  '--test-sign[test signing]' \
  '--hash=[hash algorithm]:hash:' \
  '--generate-random=[generate random bytes]:n:' \
  '(-8 --pkcs8)'{-8,--pkcs8}'[PKCS#8 format]' \
  '--inder[input DER format]' \
  '--inraw[input raw format]' \
  '--outder[output DER format]' \
  '--outraw[output raw format]' \
  '--provider=[provider library]:file:_files' \
  '--detailed-url[show detailed URLs]' \
  '--only-urls[show only URLs]' \
  '--batch[batch mode]' \
  '--mark-wrap[mark as wrap key]' \
  '--mark-trusted[mark as trusted]' \
  '--mark-distrusted[mark as distrusted]' \
  '--mark-decrypt[mark as decrypt key]' \
  '--mark-sign[mark as sign key]' \
  '--mark-ca[mark as CA]' \
  '--mark-private[mark as private]' \
  '--mark-always-authenticate[mark as always-authenticate]' && ret=0
return ret
