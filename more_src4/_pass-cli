#compdef pass-cli
# _pass-cli — pass-cli CLI Go-based command-line cross-platform password manager wrapping the standard UNIX password manager pass interface providing insert generate show edit list copy move sync git clone init grep adds usability commands for the gopass-incompatible-tree GPG-based store (pass-cli authors team, Go); cobra
# upstream: https://github.com/ayoisaiah/pass-cli

_pass-cli() {
    local -a sub=(
        'init:initialize a password store'
        'ls:list entries'
        'show:show entry'
        'insert:insert an entry'
        'generate:generate a random password'
        'edit:edit an entry'
        'rm:remove an entry'
        'mv:rename an entry'
        'cp:copy an entry'
        'grep:search content'
        'find:find entries by name'
        'git:git operations'
        'sync:sync remote'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--store=+[dir]:dir:_files -/' \
        '--gpg-id=+[key id]:str:' \
        '--gpg=+[path]:file:_files' \
        '--length=+[N]:n:' \
        '--no-symbols[no symbols]' \
        '--qrcode[show as QR code]' \
        '-c[copy to clipboard]' \
        '--clip[copy to clipboard]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pass-cli subcommand' sub ;;
        args)
            case $words[1] in
                show|insert|generate|edit|rm|mv|cp|find) _arguments '*:entry path:' ;;
                grep) _arguments '*:search term:' ;;
            esac
            ;;
    esac
}

_pass-cli "$@"
