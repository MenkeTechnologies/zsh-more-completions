#compdef nsssd-nslcd
# _nsssd-nslcd — skarnet nsssd backend over nslcd (LDAP-via-nslcd backend; talks the nslcd protocol on a Unix socket and translates results back to nsss requests for libnsss callers)
# upstream: https://github.com/skarnet/nsss
# Flags from src/nsssd/nsssd-nslcd.c on tip.

_nsssd-nslcd() {
    _arguments \
        '-t+[per-request timeout (ms)]:ms:' \
        '1:nslcd-socket-path:_files'
}

_nsssd-nslcd "$@"
