#compdef weston-debug
# Documentation: https://manpages.debian.org/bookworm/weston/weston-debug.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# weston-debug: bind to Weston debug streams
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-l --list)'{-l,--list}'[list available debug streams]' \
  '(-a --all)'{-a,--all}'[bind all debug streams]' \
  '(-o --output)'{-o,--output=}'[output file (- for stdout)]:file:_files' \
  '(-f --outfd)'{-f,--outfd=}'[output file descriptor]:fd:' \
  '*:stream name:' && ret=0
return ret
