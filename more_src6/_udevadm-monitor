#compdef udevadm-monitor
# _udevadm-monitor — systemd udevadm monitor subcommand CLI for receiving and printing kernel and user-space uevents from udev allowing real-time tracking of device add change remove subsystem filter property tag matching (systemd team, C); getopt
# upstream: https://github.com/systemd/systemd

_udevadm-monitor() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-k[print kernel events]' \
        '--kernel[print kernel events]' \
        '-u[print user-space events]' \
        '--udev[print user-space events]' \
        '-p[print properties]' \
        '--property[print properties]' \
        '-s+[subsystem]:str:' \
        '--subsystem-match=+[subsystem]:str:' \
        '-t+[tag]:str:' \
        '--tag-match=+[tag]:str:' \
        '--no-pager[no pager]'
}

_udevadm-monitor "$@"
