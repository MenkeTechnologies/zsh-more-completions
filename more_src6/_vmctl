#compdef vmctl
# _vmctl — VictoriaMetrics vmctl CLI tool for migrating time-series data between Prometheus InfluxDB OpenTSDB Graphite VictoriaMetrics Promscale and external monitoring systems supporting native vmnative format batch import-export remote-write filtering with per-source-target migration profiles (VictoriaMetrics team, Go); cobra
# upstream: https://docs.victoriametrics.com/vmctl.html

_vmctl() {
    local -a sub=(
        'prometheus:migrate from Prometheus'
        'opentsdb:migrate from OpenTSDB'
        'influx:migrate from InfluxDB'
        'graphite:migrate from Graphite'
        'remote-read:migrate via remote-read'
        'vm-native:migrate native VictoriaMetrics format'
        'verify-block:verify VictoriaMetrics block'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--disable-progress-bar[disable progress bar]' \
        '--enable-tcp6[enable TCP6]' \
        '--http.connTimeout=+[duration]:str:' \
        '--http.maxIdleConns=+[N]:n:' \
        '--httpListenAddr=+[host:port]:str:' \
        '--insecureSkipVerify[insecure skip TLS verify]' \
        '--loggerFormat=+[fmt]:f:(default json)' \
        '--loggerLevel=+[l]:l:(INFO WARN ERROR FATAL PANIC)' \
        '--loggerOutput=+[o]:o:(stderr stdout)' \
        '--loggerTimezones=+[timezone]:str:' \
        '--memory.allowedPercent=+[N]:n:' \
        '--memory.allowedBytes=+[size]:str:' \
        '--rateLimit=+[bytes/sec]:str:' \
        '--vm-account-id=+[id]:str:' \
        '--vm-addr=+[host:port]:str:' \
        '--vm-batch-size=+[N]:n:' \
        '--vm-cert-file=+[file]:file:_files' \
        '--vm-key-file=+[file]:file:_files' \
        '--vm-CA-file=+[file]:file:_files' \
        '--vm-server-name=+[name]:str:' \
        '--vm-compress[compress]' \
        '--vm-concurrency=+[N]:n:' \
        '--vm-disable-progress-bar[disable progress bar]' \
        '--vm-extra-label=+[k=v]:str:' \
        '--vm-significant-figures=+[N]:n:' \
        '--vm-round-digits=+[N]:n:' \
        '--vm-user=+[user]:str:' \
        '--vm-password=+[password]:str:' \
        '--vm-bearer-token=+[token]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vmctl subcommand' sub ;;
    esac
}

_vmctl "$@"
