#compdef virt-edit-cli
# _virt-edit-cli — libguestfs virt-edit edit file inside VM image CLI alias (libguestfs team, C); custom argparse
# upstream: https://github.com/libguestfs/libguestfs

_virt-edit-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--add=+[disk]:file:_files' \
        '-a+[disk]:file:_files' \
        '--backup=+[backup ext]:str:' \
        '-b+[backup ext]:str:' \
        '--connect=+[libvirt URI]:str:' \
        '-c+[libvirt URI]:str:' \
        '--domain=+[VM domain]:str:' \
        '-d+[VM domain]:str:' \
        '--echo-keys[echo keys]' \
        '--editor=+[editor]:str:' \
        '--expr=+[perl expression]:str:' \
        '-e+[perl expression]:str:' \
        '--format=+[image format]:f:(raw qcow2 vmdk)' \
        '--key=+[key]:str:' \
        '--keys-from-stdin[read keys from stdin]' \
        '--mount-options=+[options]:str:' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--inspector[use inspector]' \
        '-i[use inspector]' \
        '--no-inspector[no inspector]' \
        '*:files:_files'
}

_virt-edit-cli "$@"
