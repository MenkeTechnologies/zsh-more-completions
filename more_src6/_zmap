#compdef zmap
# _zmap — ZMap (University of Michigan) Internet-wide fast stateless single-port scanner; pluggable probe + output modules
# upstream: https://github.com/zmap/zmap
# Flags from src/zopt.ggo.in (gengetopt) on tip.

_zmap() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version and exit]' \
        '(-p --target-ports)'{-p+,--target-ports=}'[target ports (comma/ranges)]:ports:' \
        '(-o --output-file)'{-o+,--output-file=}'[output file]:file:_files' \
        '(-b --blocklist-file)'{-b+,--blocklist-file=}'[CIDR blocklist file]:file:_files' \
        '(-w --allowlist-file)'{-w+,--allowlist-file=}'[CIDR allowlist file]:file:_files' \
        '(-I --list-of-ips-file)'{-I+,--list-of-ips-file=}'[explicit IP list file]:file:_files' \
        '(-r --rate)'{-r+,--rate=}'[send rate (pps)]:n:' \
        '(-B --bandwidth)'{-B+,--bandwidth=}'[send rate (bps, K/M/G suffixes)]:bw:' \
        '--batch=[packets per syscall]:n:' \
        '(-n --max-targets)'{-n+,--max-targets=}'[cap targets (N or N%)]:n:' \
        '(-t --max-runtime)'{-t+,--max-runtime=}'[max send duration (sec)]:sec:' \
        '(-N --max-results)'{-N+,--max-results=}'[cap result count]:n:' \
        '(-P --probes)'{-P+,--probes=}'[probes per IP/port pair]:n:' \
        '(-c --cooldown-time)'{-c+,--cooldown-time=}'[receive window after last probe (sec)]:sec:' \
        '(-e --seed)'{-e+,--seed=}'[address-permutation seed]:n:' \
        '--retries=[max send retries on failure]:n:' \
        '(-d --dryrun)'{-d,--dryrun}'[do not send packets]' \
        '--fast-dryrun[binary dryrun for tests (not user-facing)]' \
        '--shards=[total shards]:n:' \
        '--shard=[shard index (0-based)]:n:' \
        '(-s --source-port)'{-s+,--source-port=}'[source port (or range)]:port:' \
        '--validate-source-port=[validate response src ports]:mode:(enable disable)' \
        '(-S --source-ip)'{-S+,--source-ip=}'[source IP (or range)]:ip:' \
        '(-G --gateway-mac)'{-G+,--gateway-mac=}'[gateway MAC address]:mac:' \
        '--source-mac=[source MAC address]:mac:' \
        '(-i --interface)'{-i+,--interface=}'[network interface]:iface:_net_interfaces' \
        '(-X --iplayer)'{-X,--iplayer}'[send IP packets instead of Ethernet (VPN)]' \
        '--netmap-wait-ping=[wait for IP to respond to ping (netmap)]:ip:' \
        '(-M --probe-module)'{-M+,--probe-module=}'[probe module]:name:(tcp_synscan tcp_synopt tcp_synackscan udp icmp_echoscan icmp_echo_time bacnet dns)' \
        '--probe-args=[probe module args]:args:' \
        '--probe-ttl=[probe IP TTL]:n:' \
        '--list-probe-modules[list probe modules and exit]' \
        '(-f --output-fields)'{-f+,--output-fields=}'[output fields]:fields:' \
        '(-O --output-module)'{-O+,--output-module=}'[output module]:name:(csv default extended_file json mongodb redis_csv redis_module redis_packed)' \
        '--output-args=[output module args]:args:' \
        '--output-filter=[response-field filter expression]:filter:' \
        '--list-output-modules[list output modules and exit]' \
        '--list-output-fields[list output fields for selected probe module]' \
        '--no-header-row[skip CSV header row]' \
        '--dedup-method=[response dedup method]:method:(default none full window)' \
        '--dedup-window-size=[window size for dedup (targets)]:n:' \
        '(-v --verbosity)'{-v+,--verbosity=}'[log detail level 0-5]:n:' \
        '(-l --log-file)'{-l+,--log-file=}'[log file]:file:_files' \
        '(-L --log-directory)'{-L+,--log-directory=}'[timestamped log directory]:dir:_files -/' \
        '(-m --metadata-file)'{-m+,--metadata-file=}'[scan metadata JSON output]:file:_files' \
        '(-u --status-updates-file)'{-u+,--status-updates-file=}'[scan progress CSV]:file:_files' \
        '(-q --quiet)'{-q,--quiet}'[suppress status updates]' \
        '--disable-syslog[disable syslog logging]' \
        '--notes=[notes string baked into metadata]:notes:' \
        '--user-metadata=[user JSON injected into metadata]:json:' \
        '(-C --config)'{-C+,--config=}'[config file]:file:_files' \
        '--max-sendto-failures=[max NIC sendto failures before abort]:n:' \
        '--min-hitrate=[min hit-rate before abort]:rate:' \
        '(-T --sender-threads)'{-T+,--sender-threads=}'[number of sender threads]:n:' \
        '--cores=[comma-separated list of CPU cores to pin to]:list:' \
        '--ignore-blocklist-errors[ignore invalid blocklist/allowlist entries]' \
        '*:target:'
}

_zmap "$@"
