#compdef wavpack
# Documentation: wavpack --help (WavPack 5.x)
# Source: WavPack wavpack — create or transcode WavPack (.wv) files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[Adobe Audition (CoolEdit) mode for 32-bit floats]' \
    '--allow-huge-tags[allow tag data up to 16 MB]' \
    '-b+[hybrid compression bitrate (bits/sample or kbps)]:n:' \
    '--blocksize=[block size in samples]:n:' \
    '-c[hybrid lossless mode (use with -b<n> for .wvc)]' \
    '-cc[maximum hybrid lossless compression]' \
    '--channel-order=[comma-separated channel order]:list:' \
    '--cross-decorr[cross-channel correlation in hybrid mode]' \
    '-d[delete source file if successful]' \
    '(-f -g -h -hh)-f[fast mode]' \
    '(-f -g -h -hh)-g[normal mode (cancels -f / -h)]' \
    '(-f -g -h -hh)-h[high quality]' \
    '(-f -g -h -hh)-hh[very high quality]' \
    '--force-even-byte-depth[round non-whole-byte depths up]' \
    '(- *)--help[extended help display]' \
    '-i[ignore length in header (read to EOF)]' \
    '--import-id3[import ID3v2 tags from trailer]' \
    '-j+[joint-stereo override (0=L/R, 1=M/S)]:n:(0 1)' \
    '-m[compute & store MD5 of raw audio]' \
    '--merge-blocks[merge consecutive equal-redundancy blocks]' \
    '-n[average + peak quantization noise (hybrid only)]' \
    '--no-overwrite[never overwrite existing files]' \
    '(--no-threads --threads)--no-threads[single-threaded (equivalent --threads=1)]' \
    '(--no-threads --threads)--threads=[N worker threads (1..12)]:n:' \
    '--no-utf8-convert[assume tags already UTF-8]' \
    '-o+[output filename or path]:file:_files' \
    '--optimize-int32[optimizations for some 32-bit integer files]' \
    '-p[practical float storage (.wv only, equiv -bp)]' \
    '--pair-unassigned-chans[pair unassigned channels into stereo pairs]' \
    '--pre-quantize=+[reduce bit depth to N (1-32) before encoding]:n:' \
    '-q[quiet]' \
    '-r+[generate riff WAV header]' \
    '--raw-pcm[input is raw PCM]' \
    '--raw-pcm-skip=[skip N samples at start of raw input]:n:' \
    '-s[no output, just stats]' \
    '-t[copy input time stamp to output]' \
    '-v[verify (encode then decompress to compare)]' \
    '--version[print version]' \
    '-w+[write specific extra-data]:str:' \
    '-x+[extra processing level (0..6)]:n:(0 1 2 3 4 5 6)' \
    '-y[supress all overwrite prompts (overwrite)]' \
    '-z[do not store extra wrappers (RIFF/AIFF junk)]' \
    '*:input audio file:_files -g "*.{wav,wv,aif,aiff,caf,w64,dff,dsf}"' \
    && ret=0

return ret
