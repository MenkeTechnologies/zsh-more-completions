#compdef zeronet zeronet.py
# _zeronet — Tamas Kocsis ZeroNet decentralized peer-to-peer web with BitTorrent and Bitcoin crypto (HelloZeroNet team, Python); argparse
# upstream: https://github.com/HelloZeroNet/ZeroNet

_zeronet() {
    local -a sub=(
        'main:run zeronet'
        'siteCreate:create a new site'
        'siteSign:sign site files'
        'sitePublish:publish site updates'
        'siteVerify:verify site files'
        'siteUpdate:update site from web'
        'siteCmd:remote site command'
        'siteAnnounce:announce to trackers'
        'siteDownload:download a site'
        'siteNeedFile:request a file'
        'sitePeerExchange:peer exchange'
        'siteFindPeers:find more peers'
        'dbRebuild:rebuild content.db'
        'dbQuery:query content.db'
        'peerPing:ping a peer'
        'peerGetFile:fetch a file from peer'
        'cryptSign:sign data'
        'cryptVerify:verify signature'
        'cryptGetPrivatekey:derive private key'
        'getConfig:print configuration'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--config-file=+[config file]:file:_files -g "*.conf"' \
        '--ui-ip=+[ui address]:host:_hosts' \
        '--ui-port=+[ui port]:port:_ports' \
        '--ui-restrict=+[restrict to IPs]:str:' \
        '--ui-host=+[allowed hosts]:str:' \
        '--ui-password=+[ui password]:str:' \
        '--fileserver-ip=+[fileserver ip]:host:_hosts' \
        '--fileserver-port=+[fileserver port]:port:_ports' \
        '--fileserver-port-range=+[range]:str:' \
        '--proxy=+[socks proxy]:str:' \
        '--bind=+[bind address]:host:_hosts' \
        '--trackers=+[trackers]:str:' \
        '--trackers-file=+[trackers file]:file:_files' \
        '--trackers-proxy=+[mode]:m:(disable tor proxy)' \
        '--data-dir=+[data dir]:dir:_files -/' \
        '--log-dir=+[log dir]:dir:_files -/' \
        '--log-level=+[level]:l:(DEBUG INFO WARNING ERROR CRITICAL)' \
        '--tor=+[mode]:m:(disable enable always)' \
        '--tor-controller=+[controller addr]:host:_hosts' \
        '--tor-proxy=+[proxy addr]:host:_hosts' \
        '--tor-password=+[tor password]:str:' \
        '--ip-external=+[external ip]:host:_hosts' \
        '--offline[offline mode]' \
        '--debug[debug mode]' \
        '--silent[silent mode]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zeronet subcommand' sub ;;
    esac
}

_zeronet "$@"
