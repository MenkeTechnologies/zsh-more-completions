#compdef worktrunk
# Documentation: https://github.com/max-sixty/worktrunk
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: upstream binary is invoked as `wt`, not `worktrunk`; this name appears
# to be an alias/wrapper. Subcommands per README: switch (-c, -x), list (--full),
# merge, remove.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:(switch list merge remove)' \
  '*:: : _files' && ret=0

return ret
