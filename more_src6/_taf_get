#compdef taf_get
# Documentation: https://confluence.ecmwf.int/display/ECC/taf_get
# Source: ecmwf/eccodes tools/taf_get.cc — read key values from TAF messages (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f[force, do not fail on error]' \
    '-p+[keys to print]:keys:_default' \
    '-F+[C-style float format (default %g)]:format:_default' \
    '-l+[value at nearest lat,lon]:lat,lon:_default' \
    '-P+[append keys to default list]:keys:_default' \
    '-w+[where clause filter]:filter:_default' \
    '-n+[print all keys in namespace]:namespace:_default' \
    '-s+[key=value pairs to set]:kvs:_default' \
    '(- *)-V[show version]' \
    '-W+[minimum column width (default 8)]:n:_default' \
    '-m[print MARS keys]' \
    '-M[turn off multi-field support]' \
    '-S[strict, only messages matching all constraints]' \
    '-g[copy GTS header]' \
    '-G[GRIBEX compatibility mode]' \
    '-T+[message type]:type:(T B M A)' \
    '-7[do not fail on wrong message length]' \
    '-v[verbose]' \
    '-i+[data value at given index]:index:_default' \
    '*:taf file:_files' \
    && ret=0

return ret
