#compdef wraith
# _wraith — N0MoreSecr3ts wraith CLI git repository secrets scanner sweeping for hardcoded API keys credentials private keys PEM hashes RSA AWS Azure GCP-keys-token in all branches commit history blobs on GitHub GitLab Bitbucket reading repo-list mode through APIs producing JSON output (N0MoreSecr3ts team, Go); cobra
# upstream: https://github.com/N0MoreSecr3ts/wraith

_wraith() {
    local -a sub=(
        'scanLocalGitRepo:scan a local git repo'
        'scanLocalFiles:scan local files'
        'scanGithub:scan github.com'
        'scanGithubEnterprise:scan ghe'
        'scanGitlab:scan gitlab.com'
        'scanBitbucket:scan bitbucket'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--config-file=+[file]:file:_files -g "*.yml *.yaml"' \
        '--rules-file=+[file]:file:_files -g "*.yml *.yaml"' \
        '--rules-url=+[url]:str:' \
        '--token=+[token]:str:' \
        '--user-dirs=+[list]:str:' \
        '--repo-dirs=+[list]:str:' \
        '--exclude-orgs=+[list]:str:' \
        '--exclude-repos=+[list]:str:' \
        '--include-orgs=+[list]:str:' \
        '--include-repos=+[list]:str:' \
        '--scan-fork[scan forked repos]' \
        '--no-cleanup[do not cleanup clones]' \
        '--commit-since=+[date]:str:' \
        '--commit-until=+[date]:str:' \
        '--threads=+[N]:n:' \
        '--max-file-size=+[KB]:n:' \
        '--max-go-routines=+[N]:n:' \
        '--silent[silent]' \
        '--scan-tests[scan test files]' \
        '--json[json output]' \
        '--csv[csv output]' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wraith subcommand' sub ;;
    esac
}

_wraith "$@"
