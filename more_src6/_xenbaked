#compdef xenbaked
# Documentation: https://github.com/xen-project/xen/blob/master/tools/xenmon/xenbaked.c
# Reference accessed: 2026-05-21
# Verified: upstream xenbaked.c parse_args() getopt_long quoted from source.
# Real flags: -t/--log-thresh, -s/--poll-sleep, -m/--ms_per_sample,
# -?/--help, -V/--version. No -v/--verbose, no -h short option.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)-\?[show help]' \
  '(- *)-V[print program version]' \
  '(- *)--version[print program version]' \
  '(-t --log-thresh)'{-t+,--log-thresh=}'[new records required to trigger write]:records:' \
  '(-s --poll-sleep)'{-s+,--poll-sleep=}'[ms between polling the trace buffer]:ms:' \
  '(-m --ms_per_sample)'{-m+,--ms_per_sample=}'[milliseconds per sample]:ms:' && ret=0
return ret
