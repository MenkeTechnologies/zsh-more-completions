#compdef xpython xeus-python
# _xeus-python — QuantStack Xeus Jupyter kernel for Python with debugger and async support based on ptvsd debugpy (jupyter-xeus team, C++/Python); custom argparse
# upstream: https://github.com/jupyter-xeus/xeus-python

_xeus-python() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-f+[connection file]:file:_files -g "*.json"' \
        '--file=+[connection file]:file:_files -g "*.json"' \
        '--connection-file=+[connection file]:file:_files -g "*.json"' \
        '-c+[execute code]:str:' \
        '--code=+[execute code]:str:' \
        '-m+[module]:str:' \
        '--module=+[module]:str:' \
        '--no-debugger[disable debugger]' \
        '--ip=+[ip address]:host:_hosts' \
        '--port=+[port]:port:_ports' \
        '--debugpy-host=+[debugpy host]:host:_hosts' \
        '--debugpy-port=+[debugpy port]:port:_ports' \
        '--debugger-wait-for-client[wait for debugger client]' \
        '--no-color[disable color]' \
        '--log-level=+[level]:l:(debug info warning error critical)' \
        '--log-file=+[log file]:file:_files' \
        '--inspect[inspect mode]' \
        '*:python file:_files -g "*.py"'
}

_xeus-python "$@"
