#compdef vault-secrets-operator
# _vault-secrets-operator — HashiCorp Vault Secrets Operator (reconciles VaultStaticSecret / VaultDynamicSecret / VaultPKISecret + HCPVaultSecretsApp into native Kubernetes Secrets)
# upstream: https://github.com/hashicorp/vault-secrets-operator
# Flags from main.go on tip + controller-runtime zap.Options.

_vault-secrets-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print operator version and exit]' \
        '--output=[version output format]:fmt:(yaml json json-pretty)' \
        '--metrics-bind-address=[metric endpoint bind address]:addr:' \
        '--health-probe-bind-address=[probe endpoint bind address]:addr:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--client-cache-size=[max number of cached Vault clients]:n:' \
        '--client-cache-num-locks=[number of cached-client mutex shards]:n:' \
        '--client-cache-persistence-model=[persist cached Vault tokens]:model:(none direct-encrypted direct-unencrypted)' \
        '--max-concurrent-reconciles-vds=[VaultDynamicSecret concurrent reconciles]:n:' \
        '--max-concurrent-reconciles=[default concurrent reconciles for syncable secrets]:n:' \
        '--uninstall[run in uninstall mode (delete all VSO-managed resources)]' \
        '--pre-delete-hook-timeout-seconds=[Helm pre-delete hook timeout (s)]:s:' \
        '--min-refresh-after-hvsa=[minimum refresh interval for HCPVaultSecretsApp]:duration:' \
        '--global-transformation-options=[csv of global transformation options]:csv:' \
        '--global-vault-auth-options=[csv of global VaultAuth options]:csv:' \
        '--backoff-initial-interval=[backoff initial interval]:duration:' \
        '--backoff-max-interval=[backoff max interval]:duration:' \
        '--backoff-max-elapsed-time=[backoff max elapsed time (0 = no cap)]:duration:' \
        '--backoff-randomization-factor=[backoff randomization factor]:f:' \
        '--backoff-multiplier=[backoff multiplier]:f:' \
        '--kube-client-qps=[Kubernetes client QPS]:qps:' \
        '--kube-client-burst=[Kubernetes client burst]:n:' \
        '--zap-devel[zap development-mode encoder]' \
        '--zap-encoder=[zap log encoder]:enc:(json console)' \
        '--zap-log-level=[zap log level]:level:(debug info warn error dpanic panic fatal)' \
        '--zap-stacktrace-level=[zap log level that triggers a stacktrace]:level:(info error panic)' \
        '--zap-time-encoding=[zap time encoding]:enc:(epoch millis nano iso8601 rfc3339 rfc3339nano)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_vault-secrets-operator "$@"
