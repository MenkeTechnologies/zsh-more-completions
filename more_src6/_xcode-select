#compdef xcode-select
# Documentation: https://www.unix.com/man-page/osx/1/xcode-select/
# Source: Apple Xcode — select the active developer directory.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[print usage]' \
    '(- *)'{-v,--version}'[print version]' \
    '(- *)'{-p,--print-path}'[print current developer directory]' \
    '(- *)'{-s+,--switch=}'[set the active developer directory]:path:_directories' \
    '(- *)'{-r,--reset}'[unset user override; restore default search]' \
    '(- *)--install[open dialog to install Command Line Developer Tools]' \
    && ret=0

return ret
