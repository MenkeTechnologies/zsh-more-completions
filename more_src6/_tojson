#compdef tojson
# _tojson — Tom Hudson tojson CLI for converting line-delimited stdin or file input into a JSON array of strings useful for piping recon output into jq or HTTP APIs (tomnomnom team, Go); flag
# upstream: https://github.com/tomnomnom/hacks

_tojson() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c[compact JSON]' \
        '--compact[compact JSON]' \
        '-i[parse input as ints]' \
        '--int[parse input as ints]' \
        '-f[parse input as floats]' \
        '--float[parse input as floats]' \
        '-b[parse input as bools]' \
        '--bool[parse input as bools]' \
        '-k+[wrap as object key]:str:' \
        '--key=+[wrap as object key]:str:' \
        '*:input file:_files'
}

_tojson "$@"
