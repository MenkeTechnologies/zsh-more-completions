#compdef yafscii
# _yafscii — CERT yaf yafscii CLI for converting YAF IPFIX flow files into ASCII or CSV human-readable flow logs with optional payload deep-packet-inspection labels Bro-Zeek style output (CMU CERT team, C); getopt
# upstream: https://tools.netsa.cert.org/yaf/

_yafscii() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-i+[input file]:file:_files -g "*.yaf *.ipfix"' \
        '--in=+[input file]:file:_files -g "*.yaf *.ipfix"' \
        '-o+[output file]:file:_files' \
        '--out=+[output file]:file:_files' \
        '-f+[format]:f:(text csv json bin tab)' \
        '--print-tabular[tabular output]' \
        '--print-tcp-flags[print TCP flags]' \
        '--print-payload[print payload]' \
        '--no-frag[ignore fragments]' \
        '--no-stats[no stats]' \
        '--no-octets[no octets]' \
        '--print-mac[print MAC]' \
        '--print-mpls[print MPLS labels]' \
        '--print-vlan[print VLAN]' \
        '--print-rtt[print round-trip time]' \
        '--print-flow-stats[print flow stats]' \
        '--print-dpi[print DPI]' \
        '--print-uniflow[print uniflow]' \
        '--print-record-version[print record version]' \
        '--print-cert-dpi[print TLS cert DPI]' \
        '--no-ssl-cert[no SSL cert]' \
        '--no-banner-stats[no banner stats]' \
        '--lock[lock file]' \
        '*:yaf file:_files -g "*.yaf *.ipfix"'
}

_yafscii "$@"
