#compdef vue-list
# Documentation: https://www.npmjs.com/package/vue-cli
# Reference accessed: 2026-05-23
# Verified: npx vue-cli vue-list.

# Zsh completion for vue-list - list official Vue CLI templates

local curcontext="$curcontext" state line ret=1

_arguments -C   '(-h --help)'{-h,--help}'[show help]'   '*::args:' && ret=0

return ret
