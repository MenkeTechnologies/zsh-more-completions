#compdef zephyr-build zephyr-build-tool
# _zephyr-build — Zephyr Project zephyr-build CLI helper wrapping west build invoking CMake Ninja Make for Zephyr RTOS applications board selection toolchain conf-overlay device-tree-overlay shield (zephyrproject-rtos team, Python); argparse
# upstream: https://github.com/zephyrproject-rtos/zephyr

_zephyr-build() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-b+[board]:str:' \
        '--board=+[board]:str:' \
        '-d+[build dir]:dir:_files -/' \
        '--build-dir=+[build dir]:dir:_files -/' \
        '-s+[source dir]:dir:_files -/' \
        '--source-dir=+[source dir]:dir:_files -/' \
        '-t+[target]:t:(all run flash debug clean menuconfig usage help install rom_report ram_report)' \
        '--target=+[target]:t:(all run flash debug clean menuconfig usage help install rom_report ram_report)' \
        '-p+[pristine]:p:(auto always never)' \
        '--pristine=+[pristine]:p:(auto always never)' \
        '-c[cmake]' \
        '--cmake[cmake]' \
        '-f+[forced flag]:str:' \
        '--force[force]' \
        '--cmake-only[cmake only]' \
        '--domain=+[name]:str:' \
        '--shield=+[shields csv]:str:' \
        '--snippet=+[snippets csv]:str:' \
        '-DBOARD=+[board]:str:' \
        '-DCONF_FILE=+[file]:file:_files -g "*.conf"' \
        '-DOVERLAY_CONFIG=+[file]:file:_files -g "*.conf *.overlay"' \
        '-DEXTRA_CONF_FILE=+[file]:file:_files -g "*.conf"' \
        '-DDTC_OVERLAY_FILE=+[file]:file:_files -g "*.overlay *.dts"' \
        '-DEXTRA_DTC_OVERLAY_FILE=+[file]:file:_files -g "*.overlay *.dts"' \
        '*:application dir:_files -/'
}

_zephyr-build "$@"
