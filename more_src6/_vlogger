#compdef vlogger
# Documentation: https://manpages.ubuntu.com/manpages/jammy/en/man1/vlogger.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-a[do not autoflush files]' \
  '-e[enable ErrorLog mode]' \
  '-n[disable rotation]' \
  '-f+[max open filehandles (default 100)]:count:' \
  '-u+[change user to UID]:user:_users' \
  '-g+[change group to GID]:group:_groups' \
  '-t+[filename template (Date::Format codes)]:template:' \
  '-s+[symlink name to current file]:symlink:_files' \
  '-r+[rotate files when reaching SIZE bytes]:bytes:' \
  '-d+[enable DBI usage tracker with config]:config:_files' \
  '*:log_dir:_files -/' && ret=0

return ret
