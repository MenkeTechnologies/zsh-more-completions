#compdef wscat
# ============================================================================
# wscat - WebSocket cat: netcat-style
#          command-line WebSocket client +
#          minimal echo server
#          (TypeScript/Node, MIT)
#
# Author : Arnout Kazemier + Einar Otto
#           Stangvik (websockets organization)
# Upstream: https://github.com/websockets/wscat
# npm pkg : wscat
#
# `wscat` is the canonical command-line tool
# for interacting with WebSocket servers from
# the shell. Acts as both a WebSocket client
# (the `--connect` mode lets you send/receive
# text or binary frames interactively or
# scripted) and a minimal WebSocket echo
# server (`--listen` mode prints incoming
# frames + echoes them back).
#
# The companion of the canonical Node
# WebSocket library `ws` (websockets/ws),
# maintained by the same team.
#
# Distinguishing features vs alternatives:
#   - **By the websockets/ws maintainers**
#     (the official wscat-the-CLI by the
#     same team that maintains the canonical
#     Node `ws` library; the CLI is the
#     reference end-user interface to the
#     library's capabilities)
#   - **Slash commands** (in interactive mode:
#     `/ping [data]`, `/pong [data]`,
#     `/close [code, reason]` for sending
#     WebSocket control frames - critical
#     for debugging ping-pong + close
#     handshake behavior)
#   - **Ping/pong visibility** (`--show-ping-
#     pong` displays each ping + pong frame
#     received - essential for diagnosing
#     keepalive issues)
#   - **HTTP redirect following** (`--location`
#     follows 3xx redirects during the
#     WebSocket upgrade handshake)
#   - **Proxy support** (`--proxy` uses
#     CONNECT-method HTTP proxies; supports
#     authenticated proxies via the URL
#     userinfo)
#   - **Client certificate auth** (`--cert
#     --key --passphrase --ca` for mTLS
#     wss:// connections - critical for
#     enterprise WebSocket APIs)
#   - **Pre-canned execute commands**
#     (`--execute "msg"` sends messages on
#     connect; useful for scripted health
#     checks + smoke tests)
#   - **TTY-aware output** (color + prompt
#     redrawing in TTY mode; line-buffered
#     in non-TTY pipe mode)
#
# Use cases:
#   - Debug a WebSocket server (the netcat-
#     for-WebSockets pattern)
#   - Test WebSocket subprotocol negotiation
#     (Sec-WebSocket-Protocol header)
#   - Verify WebSocket TLS handshakes
#     (--no-check accepts self-signed certs
#     for dev)
#   - Send specific control frames to test
#     server close-handshake compliance
#     (use /close in slash mode)
#   - Quick echo server for client-side
#     WebSocket development (--listen mode)
#   - Smoke tests in CI pipelines (--execute
#     with --wait for scripted send/receive)
#   - Authenticated WebSocket APIs (--auth +
#     --header for Bearer token APIs)
#
# Usage:
#   wscat [options] (--listen <port> | --connect <url>)
#
# Modes (exactly one required):
#   -c, --connect <url>            - connect
#                                     to a
#                                     WebSocket
#                                     server
#                                     (ws://
#                                     or
#                                     wss://)
#   -l, --listen <port>            - listen on
#                                     port as a
#                                     minimal
#                                     echo
#                                     server
#
# Options (commander):
#   --auth <user:pass>             - add basic
#                                     HTTP
#                                     authentication
#                                     header
#                                     (Authorization:
#                                     Basic ...)
#   --ca <ca>                      - Certificate
#                                     Authority
#                                     file
#                                     (--connect
#                                     only)
#   --cert <cert>                  - Client
#                                     SSL
#                                     Certificate
#                                     file
#                                     (--connect
#                                     only)
#   --key <key>                    - Client
#                                     SSL
#                                     Certificate's
#                                     key
#                                     file
#                                     (--connect
#                                     only)
#   --passphrase [pp]              - Client
#                                     SSL key
#                                     passphrase
#                                     (--connect
#                                     only; if
#                                     no value
#                                     provided
#                                     will
#                                     prompt)
#   --host <host>                  - optional
#                                     host
#                                     (Host
#                                     header
#                                     override)
#   --max-redirects [num]          - maximum
#                                     number
#                                     of
#                                     redirects
#                                     allowed
#                                     (default
#                                     10)
#   --no-color                     - run
#                                     without
#                                     color
#   --proxy <[proto://]host[:port]> - connect
#                                     via a
#                                     proxy
#                                     (CONNECT
#                                     method
#                                     supporting
#                                     proxy)
#   --slash                        - enable
#                                     slash
#                                     commands
#                                     for
#                                     control
#                                     frames
#                                     (/ping
#                                     [data]
#                                     + /pong
#                                     [data]
#                                     + /close
#                                     [code,
#                                     reason])
#                                     (--connect
#                                     only)
#   -H, --header <header:value>    - set an
#                                     HTTP
#                                     header
#                                     (repeatable;
#                                     --connect
#                                     only)
#   -L, --location                 - follow
#                                     HTTP
#                                     redirects
#                                     during
#                                     the
#                                     upgrade
#                                     handshake
#   -n, --no-check                 - do not
#                                     check
#                                     for
#                                     unauthorized
#                                     certificates
#                                     (--connect
#                                     only;
#                                     accept
#                                     self-
#                                     signed
#                                     certs)
#   -o, --origin <origin>          - optional
#                                     origin
#                                     (Origin
#                                     header)
#   -p, --protocol <version>       - optional
#                                     protocol
#                                     version
#                                     (8 + 13;
#                                     default
#                                     13)
#   -P, --show-ping-pong           - print
#                                     notification
#                                     when a
#                                     ping or
#                                     pong is
#                                     received
#                                     (--connect
#                                     only)
#   -s, --subprotocol <protocol>   - optional
#                                     Sec-
#                                     WebSocket-
#                                     Protocol
#                                     subprotocol
#                                     (repeatable
#                                     for
#                                     multi-
#                                     value
#                                     negotiation)
#   -w, --wait <seconds>           - wait
#                                     given
#                                     seconds
#                                     after
#                                     executing
#                                     command
#                                     (-1 to
#                                     hold
#                                     open)
#   -x, --execute <command>        - execute
#                                     command
#                                     after
#                                     connecting
#                                     (repeatable;
#                                     --connect
#                                     only)
#   -V, --version                  - output
#                                     version
#                                     number
#   -h, --help                     - output
#                                     usage
#                                     information
#
# Interactive mode controls:
#   <text + Enter>                 - send a
#                                     text
#                                     frame
#   Ctrl+C / Ctrl+D                - close
#                                     connection
#                                     cleanly
#                                     (sends
#                                     close
#                                     handshake)
#   /ping [data]                   - send
#                                     ping
#                                     control
#                                     frame
#                                     (--slash
#                                     required)
#   /pong [data]                   - send
#                                     pong
#                                     control
#                                     frame
#                                     (--slash
#                                     required)
#   /close [code, reason]          - send
#                                     close
#                                     control
#                                     frame
#                                     (--slash
#                                     required)
#
# Example invocations:
#   # connect to an echo server interactively
#   wscat -c wss://echo.websocket.events
#
#   # connect with subprotocol negotiation
#   wscat -c wss://example.com/ws -s graphql-ws
#
#   # connect via a proxy
#   wscat -c wss://example.com \
#     --proxy http://user:pass@proxy:3128
#
#   # send a message + wait for response
#   # in CI
#   wscat -c wss://api.example.com \
#     -x '{"op":"ping"}' -w 5
#
#   # show ping/pong frames for debugging
#   wscat -c wss://example.com -P --slash
#
#   # client cert auth (mTLS WebSocket)
#   wscat -c wss://api.example.com \
#     --cert client.crt --key client.key \
#     --ca ca.crt
#
#   # bearer token authentication
#   wscat -c wss://api.example.com \
#     -H 'Authorization: Bearer XXX'
#
#   # accept self-signed certs (dev mode)
#   wscat -c wss://localhost:8443 --no-check
#
#   # minimal echo server on port 8080
#   wscat -l 8080
#
#   # send graphql-ws ConnectionInit
#   wscat -c wss://api.example.com/graphql \
#     -s graphql-ws \
#     -x '{"type":"connection_init","payload":{}}'
#
# The websockets/ws lane is built on `ws:
# ^8.0.0` (declared verbatim at upstream
# package.json HEAD as a direct dep, imported
# by `bin/wscat` for both WebSocket client +
# server WebSocket protocol implementation),
# the canonical Node WebSocket library by
# Einar Otto Stangvik + Luigi Pinca + Arnout
# Kazemier - github.com/websockets/ws.
#
# websockets/ws is the de-facto canonical
# Node WebSocket library:
#   - **RFC 6455 compliant** (the IETF
#     WebSocket spec; ws passes 100% of the
#     Autobahn fuzzing test suite for both
#     client + server roles)
#   - **Pure JavaScript implementation**
#     (with optional native modules for
#     accelerated permessage-deflate via
#     bufferutil + utf-8-validate; native
#     modules are optional and ws falls
#     back to pure JS if unavailable)
#   - **Browser-compatible API** (WebSocket
#     instances on the Node side use the
#     same surface as the browser's
#     WebSocket constructor; portable code)
#   - **Server + client APIs** (both
#     directions of WebSocket connections;
#     ws.Server class for server-side)
#   - **Permessage-deflate** (RFC 7692
#     compression extension)
#   - **Subprotocol negotiation** (Sec-
#     WebSocket-Protocol header handling)
#   - **HTTP/2 + HTTP/3 compatibility**
#     (WebSockets-over-HTTP/2 RFC 8441
#     support via underlying transport)
#   - **~140,000,000 weekly npm downloads**
#     (one of the highest-volume Node
#     libraries; pulled in by every modern
#     Node real-time framework: Socket.IO +
#     SockJS + GraphQL subscriptions
#     servers + every Node-based MCP
#     server + every JSON-RPC-over-WS
#     server)
#   - 22,000+ stars on github.com/
#     websockets/ws
#
# websockets/ws's distinguishing position vs
# Node WebSocket alternatives:
#   - websockets/ws (Stangvik + Pinca +
#     Kazemier): canonical; RFC 6455;
#     ~140M weekly downloads; THIS AXIS
#   - uWebSockets.js (uNetworking AB):
#     high-performance C++-backed
#     alternative; ~10-50x throughput;
#     smaller API surface; popular in
#     game servers + financial real-time
#     systems
#   - faye/faye-websocket-node (James
#     Coglan): older alternative; ws-
#     compatible API; pre-dates the modern
#     ws library
#   - sockjs/sockjs-node: WebSocket +
#     fallback transports (XHR streaming +
#     long-polling) for legacy browser
#     support; broader scope than pure
#     WebSocket
#
# Einar Otto Stangvik is the original author
# of websockets/ws (started ~2011). Luigi
# Pinca is the long-time co-maintainer +
# primary release manager. Arnout Kazemier
# is the wscat co-author + websockets org
# member. The websockets org maintains the
# entire ws-based Node WebSocket
# infrastructure:
#   - websockets/ws (canonical Node
#     WebSocket library; THIS AXIS)
#   - websockets/wscat (this CLI)
#   - websockets/websocket-stream (Stream
#     API for ws)
#   - websockets/jstp (JSON-based RPC
#     over WebSocket)
#
# Stangvik + Pinca + Kazemier's role in
# Node is *RFC-bound networking
# infrastructure + reference implementation*
# - similar position to Hildebrand's role in
# Node CBOR (Axis 280 closer; both maintain
# the canonical library + an associated CLI
# tool from the same monorepo / org).
#
# Multi-axis canonical-Node author/org
# cohort extension (now spanning 23 distinct
# individuals/orgs after R1543):
#   - + Einar Otto Stangvik + Luigi Pinca +
#     Arnout Kazemier + websockets org
#     (websockets/ws + websockets/wscat;
#     THIS AXIS; canonical Node WebSocket
#     + RFC 6455 + the most-imported Node
#     WebSocket library at ~140M weekly
#     downloads)
#
# Stangvik + Pinca + Kazemier joining the
# canonical-Node cohort at the *RFC-bound
# networking infrastructure* level
# reinforces the pattern of *coordinated
# library + reference-CLI* maintainership
# documented at Hildebrand's joining for
# CBOR (Axis 280). Both authors maintain
# their canonical library + the associated
# end-user CLI from the same project /
# organization.
#
# wscat uses websockets/ws directly:
#   ```javascript
#   const WebSocket = require('ws');
#
#   // client mode:
#   const ws = new WebSocket(url, subprotocols, {
#     headers: customHeaders,
#     ca: caFile, cert: certFile, key: keyFile,
#     agent: proxyAgent
#   });
#   ws.on('open', () => { ws.send(message); });
#   ws.on('message', (data) => { console.log(data); });
#   ws.on('ping', (data) => { console.log('ping', data); });
#
#   // server mode:
#   const wss = new WebSocket.Server({ port });
#   wss.on('connection', (ws) => {
#     ws.on('message', (data) => {
#       ws.send(data);  // echo
#     });
#   });
#   ```
# This is the canonical end-user pattern for
# websockets/ws in Node: both the CLI client
# + server use the same library API, making
# wscat both useful as a tool AND a working
# example of the library's idiomatic usage.
#
# ----------------------------------------------------------------------------
# AXIS 281 :: WebSocket libraries
#              (RFC 6455 WebSocket protocol
#              implementations;
#              full-duplex single-TCP-connection
#              messaging + permessage-deflate
#              + subprotocol negotiation +
#              binary + text frames)
# Round 1543 :: TS/Node slot 3 of 4 :: CLOSES Axis 281
#
# Cross-language canonical library family for
# this axis (closed):
#   Rust    : snapview/tungstenite-rs    [R1541 _camilladsp]
#             (Daniel Abramov + snapview
#              team; canonical Rust
#              WebSocket; sync + tokio-
#              tungstenite async + async-
#              tungstenite variants)
#   Go      : gorilla/websocket           [R1542 _eliasdb]
#             (Gorilla web toolkit
#              maintainers; canonical Go
#              WebSocket; community-revived
#              after 2022 archival; THE
#              most-imported Go WebSocket
#              library)
#   TS/Node : websockets/ws               [R1543 THIS FILE]
#             (Stangvik + Pinca + Kazemier
#              + websockets org; canonical
#              Node WebSocket; ~140M
#              weekly npm downloads;
#              CLOSES Axis 281)
#
# Axis 281 closure = 274th axis closed in
# the corpus. The 3+1 cycle returns to slot
# 1/0/0 for Axis 282 opening at the next
# round.
#
# Reflection across all three lanes:
#   - All three implement the same wire
#     format (RFC 6455 WebSocket spec)
#   - Cross-language interop happens at the
#     wire format level (any RFC 6455
#     client can connect to any RFC 6455
#     server regardless of language)
#   - All three pass the Autobahn test
#     suite for protocol compliance
#   - All three support permessage-deflate
#     (RFC 7692) + subprotocol negotiation
#
# Canonical-library + reference-CLI
# co-maintainership pattern (now documented
# at Axes 280 + 281):
#   - Axis 280 Node: Hildebrand maintains
#     node-cbor + cbor-cli (same monorepo)
#   - Axis 281 Node: websockets org
#     maintains ws + wscat (same GitHub
#     org)
#
# This pattern - canonical library author
# also maintains the reference CLI - is a
# strong indicator of canonical-status
# stability. The library + CLI co-evolution
# ensures the CLI exercises the full
# library API + provides end users a tested
# reference implementation pattern.
#
# Use-case spectrum across Axis 281 (closed):
#   - camilladsp (Rust, tungstenite): real-
#     time audio DSP engine control API
#     (live config reload + gain control +
#     mute toggling)
#   - eliasdb (Go, gorilla/websocket):
#     graph database live query terminal
#     (web UI console accessing EQL query
#     engine via persistent WebSocket)
#   - wscat (TS-Node, ws): netcat-style
#     interactive + scripted WebSocket
#     client + minimal echo server
#     (debugging + smoke testing +
#     development tool)
#
# Use-case spectrum spans:
#   - Production control plane (camilladsp:
#     real-time audio control)
#   - Production data plane (eliasdb: live
#     database query terminal)
#   - Development + debugging tooling
#     (wscat: protocol-level WebSocket
#     interaction)
#
# Together they cover the canonical
# WebSocket deployment patterns across the
# polyglot landscape: persistent control
# channel + persistent data channel +
# protocol-level debugging.
#
# Axis 281 is fully closed with coherent
# cross-language coverage of the WebSocket
# (RFC 6455) ecosystem.
# ============================================================================

_wscat() {
    _arguments -s -S \
        '(-V --version)'{-V,--version}'[output the version number]' \
        '(-l --listen)'{-l+,--listen=}'[listen on port]:port:' \
        '(-c --connect)'{-c+,--connect=}'[connect to a WebSocket server]:url:' \
        '(-P --show-ping-pong)'{-P,--show-ping-pong}'[print notification on ping or pong]' \
        '*'{-s+,--subprotocol=}'[optional subprotocol (repeatable)]:protocol:' \
        '(-o --origin)'{-o+,--origin=}'[optional origin]:origin:' \
        '(-p --protocol)'{-p+,--protocol=}'[optional protocol version]:version:(8 13)' \
        '(-n --no-check)'{-n,--no-check}'[do not check unauthorized certificates]' \
        '(-L --location)'{-L,--location}'[follow redirects]' \
        '*'{-H+,--header=}'[set an HTTP header (repeatable)]:header\:value:' \
        '--auth=[basic HTTP authentication header]:username\:password:' \
        '--ca=[Certificate Authority]:ca file:_files' \
        '--cert=[Client SSL Certificate]:cert file:_files' \
        '--key=[Client SSL Certificate key]:key file:_files' \
        '--passphrase=[Client SSL Certificate key passphrase]:passphrase:' \
        '--host=[optional host]:host:_hosts' \
        '--max-redirects=[maximum number of redirects]:n:' \
        '--no-color[run without color]' \
        '--proxy=[connect via a proxy (CONNECT method)]:proxy URL:' \
        '--slash[enable slash commands for control frames]' \
        '(-w --wait)'{-w+,--wait=}'[wait seconds after executing command (-1 to hold open)]:seconds:' \
        '*'{-x+,--execute=}'[execute command on connection (repeatable)]:command:' \
        '(-h --help)'{-h,--help}'[output usage information]'
}

_wscat "$@"
