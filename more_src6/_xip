#compdef xip
# Documentation: https://www.manpagez.com/man/1/xip/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed: --no-timestamp (not in upstream man page; correct form is
# --timestamp=none), --expand (not in upstream man page).

local -a arguments

arguments=(
    '--sign[identity name to use for signing the archive]:signing identity:'
    '--keychain[keychain to search for signing identity]:keychain:_files'
    '--timestamp[include a trusted timestamp]'
    '*:file:_files -g "*.xip"'
)

_arguments -s -S $arguments
