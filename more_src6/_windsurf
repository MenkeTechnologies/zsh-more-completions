#compdef windsurf
# Documentation: https://docs.windsurf.com/windsurf/getting-started
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Note: Windsurf is a VSCode-based IDE; its CLI accepts the same flag family as VSCode (code).
# Only the common, vendor-documented options are listed.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-n,--new-window}'[force to open a new window]' \
  {-r,--reuse-window}'[force to open a file in an already opened window]' \
  {-w,--wait}'[wait for the files to be closed before returning]' \
  {-g,--goto}'[open file at path on specific line and column (path\:line\:column)]:file\:line\:column' \
  '--list-extensions[list installed extensions]' \
  '--install-extension=[install an extension]:extension id' \
  '--uninstall-extension=[uninstall an extension]:extension id' \
  '--locale=[locale to use]:locale' \
  '--verbose[print verbose output]' \
  '*:file or folder:_files' && ret=0

return ret
