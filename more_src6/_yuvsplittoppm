#compdef yuvsplittoppm
# Documentation: man yuvsplittoppm (Netpbm)
# Source: combine basename.Y, basename.U, basename.V YUV plane files into PPM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-ccir601[apply CCIR-601 (Rec.601) scaling]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:basename:' \
    '2:width:' \
    '3:height:' \
    && ret=0

return ret
