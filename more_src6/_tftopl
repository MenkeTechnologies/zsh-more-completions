#compdef tftopl
# Documentation: tftopl -help (TeX Live 2026)
# Source: kpathsea — translate a TFM font metric file into a human-readable Property List (.pl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[display help]' \
    '(- *)-version[output version information]' \
    '-verbose[display progress reports]' \
    '-charcode-format=[character-code radix in output]:format:(octal ascii)' \
    '1:tfm input:_files -g "*.tfm"' \
    '2:pl output:_files -g "*.pl"' \
    && ret=0

return ret
