#compdef tuic-cli tuic
# _tuic-cli — EAimTy TUIC QUIC-based proxy protocol CLI alias (EAimTy team, Rust); clap-rs
# upstream: https://github.com/EAimTy/tuic

_tuic-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-c+[config file]:file:_files -g "*.{json,toml,yaml,yml}"' \
        '--config=+[config file]:file:_files -g "*.{json,toml,yaml,yml}"' \
        '--log-level=+[level]:l:(trace debug info warn error)' \
        '*:arg:'
}

_tuic-cli "$@"
