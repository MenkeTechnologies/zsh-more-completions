#compdef tyk-cli
# _tyk-cli — Tyk open-source API gateway CLI alias (Tyk Technologies, Go); spf13/cobra
# upstream: https://github.com/TykTechnologies/tyk

_tyk-cli() {
    local -a sub=(
        'bundle:create plugin bundles'
        'start:start tyk gateway'
        'plugin:plugin commands'
        'config:print config'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
        'lint:lint config'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--conf=+[config file]:file:_files -g "tyk.conf"' \
        '-c+[config file]:file:_files -g "tyk.conf"' \
        '--port=+[bind port]:port:' \
        '-p+[bind port]:port:' \
        '--memprofile[memory profile]' \
        '--cpuprofile[cpu profile]' \
        '--httpprofile[http profile]' \
        '--debug=+[debug categories]:str:' \
        '--log-instrumentation[enable instrumentation]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'tyk subcommand' sub ;;
        args)
            case $words[1] in
                bundle) _arguments \
                    '1:cmd:(build sign validate)' \
                    '-y[skip signing]' \
                    '-k+[private key]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '--manifest=+[manifest file]:file:_files' ;;
                plugin) _arguments \
                    '1:cmd:(build load test)' \
                    '*:arg:' ;;
                start) _arguments \
                    '--conf=+[config file]:file:_files -g "tyk.conf"' \
                    '-c+[config file]:file:_files -g "tyk.conf"' \
                    '--port=+[bind port]:port:' \
                    '-p+[bind port]:port:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                lint) _arguments \
                    '--conf=+[config file]:file:_files -g "tyk.conf"' \
                    '-c+[config file]:file:_files -g "tyk.conf"' ;;
            esac
            ;;
    esac
}

_tyk-cli "$@"
