#compdef winfetch

local curcontext="$curcontext" state line ret=1

_arguments \
  '(-v --version)'{-v,--version}'[display version]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '--noimage[disable image display]' \
  '--ascii[use ASCII art instead of image]' \
  '--image[specify image file]:image file:_files -g "*.{png,jpg,jpeg,bmp,gif}"' \
  '--genconf[generate default config file]' \
  '--config[specify config file]:config file:_files' \
  '--cpuname[display CPU name]' \
  '--gpuname[display GPU name]' \
  '--diskusage[display disk usage]' \
  '--packagecount[display package count]' \
  '--showdisks[show all disks]' \
  '--showpkgs[show all package managers]' \
  && ret=0

return ret
