#compdef xgettext
# Documentation: xgettext --help (GNU gettext)
# Source: extract translatable strings to PO template.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '*'{-f+,--files-from=}'[input file list]:file:_files' \
    '*'{-D+,--directory=}'[search dir for input files]:dir:_files -/' \
    {-d+,--default-domain=}'[output as NAME.po]:name:' \
    {-o+,--output=}'[output file]:file:_files' \
    {-p+,--output-dir=}'[output directory]:dir:_files -/' \
    {-L+,--language=}'[source language]:lang:(C C++ ObjectiveC PO Python Java JavaProperties C# JavaScript TypeScript TSX Scheme Guile Lisp EmacsLisp librep Rust Go Ruby Shell awk Lua Modula-2 D OCaml Smalltalk Vala Tcl Perl PHP GCC-source YCP NXStringTable RST RSJ Glade GSettings Desktop)' \
    {-C,--c++}'[shorthand for --language=C++]' \
    '--from-code=[encoding of input files]:encoding:' \
    {-j,--join-existing}'[join messages with existing file]' \
    {-x+,--exclude-file=}'[entries from FILE.po are not extracted]:file:_files -g "*.po"' \
    '*'{-c+,--add-comments=}'[place comment blocks with TAG]:tag:' \
    '--check=[syntax check]:check:(ellipsis-unicode space-ellipsis quote-unicode bullet-unicode)' \
    '--no-check=[skip syntax check]:check:(url email)' \
    '--sentence-end=[end-of-sentence type]:type:(single-space double-space)' \
    {-a,--extract-all}'[extract all strings]' \
    '*'{-k+,--keyword=}'[additional keyword to look for]:word:' \
    '*--flag=[set flags for keyword]:wordspec:' \
    '*-T[strings are C trigraphs]' \
    '--qt[recognise Qt format strings]' \
    '--kde[recognise KDE format strings]' \
    '--boost[recognise Boost format strings]' \
    '--debug[more detailed formatstring recognition]' \
    {-e,--no-escape}'[do not use C escapes (default)]' \
    {-E,--escape}'[use C escapes]' \
    '--force-po[write PO even if empty]' \
    {-i,--indent}'[indented output style]' \
    '--no-location[suppress #: lines]' \
    {-n,--add-location=-}'[generate #: lines]::value:(full file never)' \
    '--strict[strict Uniforum output]' \
    '*--properties-output[output Java .properties syntax]' \
    '--stringtable-output[output NeXTstep .strings]' \
    {-w+,--width=}'[page width]:cols:' \
    '--no-wrap[do not wrap long message lines]' \
    {-s,--sort-output}'[sort output and remove duplicates]' \
    {-F,--sort-by-file}'[sort output by file location]' \
    '--omit-header[do not write header]' \
    '--copyright-holder=[copyright holder string]:string:' \
    '--foreign-user[no FSF copyright in output]' \
    '--package-name=[package name]:name:' \
    '--package-version=[package version]:version:' \
    '--msgid-bugs-address=[email address for bug reports]:address:' \
    '*-m+[message prefix]:string:' \
    '*-M+[message suffix]:string:' \
    '--color=-[colorize output]::when:(always never auto html)' \
    '--style=[CSS style rule file]:file:_files -g "*.css"' \
    '*:input file:_files' \
    && ret=0

return ret
