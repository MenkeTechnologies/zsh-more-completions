#compdef wajig
# Documentation: man wajig(1)
# Source: gjwgit/wajig wajig/bash_completion.d/wajig.bash (master) — Debian apt simplified wrapper (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a cmds=(
    'addcdrom:add CD-ROM source to apt sources'
    'addgroup:add a group to the system'
    'addkey:add a GPG key for apt'
    'addrepo:add a PPA repository to apt'
    'aptlog:show apt log'
    'autoalts:show automatic alternatives'
    'autoclean:remove old downloaded archive files'
    'autodownload:do an update then download packages'
    'autoremove:remove packages no longer needed'
    'build:build a debian package'
    'builddeps:install build-deps for a package'
    'changelog:show changelog for a package'
    'clean:remove all downloaded archive files'
    'commands:list common wajig commands'
    'contents:show file contents of a package'
    'dailyupgrade:perform an update then a dist-upgrade'
    'dependents:list packages that depend on this package'
    'describe:show one-line description'
    'detail:show package details'
    'distupgrade:do an upgrade including new dependencies'
    'download:download packages without installing'
    'editsources:edit /etc/apt/sources.list'
    'extract:extract files from a package archive'
    'fixconfigure:resume a previously interrupted configure'
    'fixinstall:try to fix install errors'
    'fixmissing:fix missing files in a package'
    'force:install a package even if it requires removal of another'
    'hold:place a package on hold'
    'info:show high-level information about a package'
    'init:initialize wajig configuration'
    'install:install packages'
    'installsuggested:install package plus suggested packages'
    'integrity:check integrity of installed packages'
    'large:list size of installed packages'
    'lastupdate:show time of last apt update'
    'listall:list all known packages'
    'listalternatives:list alternatives'
    'listcache:list contents of apt cache'
    'listdaemons:list installed daemons'
    'listfiles:list files contained in a package'
    'listhold:list packages on hold'
    'listinstalled:list installed packages'
    'listlog:list package change log'
    'listnames:list all package names'
    'listpackages:list all packages'
    'listscripts:list maintainer scripts of a package'
    'listsection:list packages in a section'
    'liststatus:list status of all packages'
    'localupgrade:upgrade using local archive (no fetch)'
    'madison:show available versions/archives'
    'move:move files in apt cache'
    'new:list new packages since last update'
    'newdetail:show details of new packages'
    'news:show recent NEWS for installed packages'
    'newupgrades:list new upgrades since last update'
    'nonfree:list non-free packages'
    'orphans:list orphaned packages'
    'passwords:generate a random password'
    'policy:show installation policy'
    'purge:remove package and config files'
    'purgeorphans:purge orphaned packages'
    'purgeremoved:purge already-removed packages'
    'rbuilddeps:list reverse build dependencies'
    'readme:show README for an installed package'
    'reboot:reboot the system'
    'recdownload:recursively download package and deps'
    'recommended:list recommended packages'
    'reconfigure:reconfigure a package via debconf'
    'reinstall:reinstall the package'
    'reload:reload a system service'
    'remove:remove a package'
    'removeorphans:remove orphaned packages'
    'repackage:repackage an installed package'
    'reportbug:report a bug in a package'
    'repos:list configured repos'
    'restart:restart a system service'
    'rmrepo:remove a PPA repository'
    'rpm2deb:convert an RPM to a deb'
    'rpminstall:install an RPM as a deb'
    'safeupgrade:safely upgrade'
    'search:search for packages'
    'searchapt:search apt sources'
    'show:show information about a package'
    'sizes:show installed package sizes'
    'snapshot:save current packages to a file'
    'source:download source for a package'
    'start:start a system service'
    'status:show status of named packages'
    'stop:stop a system service'
    'sysinfo:show system information'
    'tasksel:run tasksel'
    'todo:show open issues'
    'toupgrade:list packages available for upgrade'
    'tutorial:show wajig tutorial'
    'unhold:remove hold on a package'
    'unofficial:list unofficially-sourced packages'
    'update:update apt package lists'
    'updatealternatives:update an alternative'
    'updatepciids:update PCI device id list'
    'updateusbids:update USB device id list'
    'upgradable:list upgradable packages'
    'upgrade:upgrade installed packages'
    'upgradesecurity:upgrade only security updates'
    'verify:verify a package'
    'version:show wajig version'
    'versions:list versions of installed packages'
    'whichpackage:find which package owns a file'
)

_arguments -s -C \
    '(- *)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '-y[assume yes for prompts]' \
    '-q[quiet]' \
    '-v[verbose]' \
    '-s[simulate (do not run)]' \
    '-n[no-act]' \
    '--noauth[do not check authentication]' \
    '1:command:->cmd' \
    '*::cmd args:_default' \
    && ret=0

case $state in
    cmd) _describe -t commands 'wajig command' cmds && ret=0 ;;
esac

return ret
