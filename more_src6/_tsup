#compdef tsup
# Documentation: https://tsup.egoist.dev/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Source: https://github.com/egoist/tsup/blob/main/src/cli-main.ts (cac CLI definition)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--entry.*=[use a key-value pair as entry files]:entry files:_files' \
  '(-d --out-dir)'{-d,--out-dir}'=[output directory]:directory:_directories' \
  '--format=[bundle format]:format:(cjs iife esm)' \
  '--minify=[minify bundle (optionally with terser)]' \
  '--minify-whitespace[minify whitespace]' \
  '--minify-identifiers[minify identifiers]' \
  '--minify-syntax[minify syntax]' \
  '--keep-names[keep original function and class names in minified code]' \
  '--target=[bundle target, "es20XX" or "esnext"]:target' \
  '--legacy-output[output different formats to different folders]' \
  '--dts=[generate declaration file]' \
  '--dts-resolve[resolve externals types used for d.ts files]' \
  '--dts-only[emit declaration files only]' \
  '--experimental-dts=[generate declaration file (experimental)]' \
  '--sourcemap=[generate external sourcemap (or inline)]' \
  '*--watch=[watch mode]:path' \
  '*--ignore-watch=[ignore custom paths in watch mode]:path' \
  '--onSuccess=[execute command after successful build]:command' \
  '--env.*=[define compile-time env variables]:value' \
  '*--inject=[replace global variable with import from file]:file:_files' \
  '--define.*=[define compile-time constants]:value' \
  '*--external=[mark packages as external]:name' \
  '--global-name=[global variable name for iife format]:name' \
  '--jsxFactory=[name of JSX factory function]:name' \
  '--jsxFragment=[name of JSX fragment function]:name' \
  '--replaceNodeEnv[replace process.env.NODE_ENV]' \
  '--no-splitting[disable code splitting]' \
  '--clean[clean output directory]' \
  '--silent[suppress non-error logs]' \
  '*--pure=[mark specific expressions as pure]:expr' \
  '--metafile[emit esbuild metafile JSON]' \
  '--platform=[target platform]:platform:(browser node neutral)' \
  '*--loader=[specify loader for file extension]:ext=loader' \
  '--tsconfig=[use a custom tsconfig]:tsconfig:_files' \
  '--config=[use a custom config file]:config:_files' \
  '--no-config[disable config file]' \
  '--shims[enable cjs and esm shims]' \
  '--inject-style[inject style tag to document head]' \
  '--treeshake=[use Rollup for treeshaking]:strategy:(recommended smallest safest)' \
  '--publicDir=[copy public directory to output directory]:dir:_directories' \
  '--killSignal=[signal to kill child process]:signal:(SIGTERM SIGKILL)' \
  '--cjsInterop[enable cjs interop]' \
  '*:entry files:_files' && ret=0

return ret
