#compdef wasmtime
# _wasmtime-bin — Wasmtime Bytecode-Alliance WebAssembly runtime (Rust); Cranelift-backed standalone Wasm runner + WASI implementation
# upstream: https://github.com/bytecodealliance/wasmtime

_wasmtime-bin() {
    local -a sub=(
        'run:run a wasm module'
        'compile:compile a module to .cwasm'
        'config:show or set config'
        'serve:run a wasm module as HTTP server (wasi-http)'
        'settings:print enabled cranelift settings'
        'wast:run a .wast spec test'
        'explore:explore a wasm module in browser'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wasmtime subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments \
                    '(-W --wasm-features)'{-W,--wasm-features}'+[feature flags]:flags:' \
                    '(-S --wasi)'{-S,--wasi}'+[wasi config]:val:' \
                    '(-O --optimize)'{-O,--optimize}'+[optimize level]:n:' \
                    '(-C --config)'{-C,--config}'+[config flag]:str:' \
                    '(-D --debug)'{-D,--debug}'+[debug flag]:str:' \
                    '--dir+[guest=host dir map]:str:' \
                    '--env+[env var]:KEY=VAL:' \
                    '--invoke+[invoke function]:func:' \
                    '--allow-precompiled[allow precompiled]' \
                    '--profile+[profile]:profile:(jitdump perfmap vtune)' \
                    '*:wasm or args:_files -g "*.wasm"' ;;
                compile) _arguments \
                    '(-o --output)'{-o,--output}'+[output cwasm]:file:_files' \
                    '(-W --wasm-features)'{-W,--wasm-features}'+[feature flags]:flags:' \
                    '(-O --optimize)'{-O,--optimize}'+[optimize level]:n:' \
                    '*:wasm:_files -g "*.wasm"' ;;
                serve) _arguments \
                    '(-a --addr)'{-a,--addr}'+[bind addr]:addr:' \
                    '*:wasm:_files -g "*.wasm"' ;;
                wast) _arguments '*:wast:_files -g "*.wast"' ;;
                explore) _arguments '*:wasm:_files -g "*.wasm"' ;;
            esac
            ;;
    esac
}

_wasmtime-bin "$@"
