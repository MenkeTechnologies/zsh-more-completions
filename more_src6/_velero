#compdef velero
# Documentation: https://velero.io/docs/ (source: github.com/vmware-tanzu/velero pkg/cmd/velero/velero.go)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_velero_commands() {
  local -a commands=(
    'backup:work with backups'
    'backup-location:work with backup storage locations'
    'bug:report a Velero bug'
    'client:Velero client related commands'
    'completion:generate completion script'
    'create:create Velero resources'
    'datamover:data mover commands'
    'debug:generate debug bundle'
    'delete:delete Velero resources'
    'describe:describe Velero resources'
    'get:get Velero resources'
    'install:install Velero'
    'node-agent:node agent commands'
    'plugin:work with plugins'
    'pod-volume:pod volume backup/restore commands'
    'repo:work with backup repositories'
    'repo-maintenance:repo maintenance commands'
    'restore:work with restores'
    'run-plugin:run a plugin'
    'schedule:work with schedules'
    'server:run the Velero server'
    'snapshot-location:work with snapshot locations'
    'uninstall:uninstall Velero'
    'version:print the version'
  )
  _describe -t commands 'velero command' commands
}

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--alsologtostderr[log to stderr as well]' \
  '--colorized=[show colored output]:bool:(true false)' \
  '--features=[comma-separated feature flags]:features:' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '--kubecontext=[kubeconfig context to use]:context:' \
  '(-n --namespace)'{-n,--namespace=}'[namespace for Velero server]:namespace:' \
  '--log-level=[log level]:level:(trace debug info warning error fatal panic)' \
  '1: :_velero_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      backup)
        local -a backup_cmds=(
          'create:create a backup'
          'delete:delete backups'
          'describe:describe backups'
          'download:download a backup'
          'get:get backups'
          'logs:get backup logs'
        )
        _describe -t backup-commands 'backup command' backup_cmds
        ;;
      restore)
        local -a restore_cmds=(
          'create:create a restore'
          'delete:delete restores'
          'describe:describe restores'
          'get:get restores'
          'logs:get restore logs'
        )
        _describe -t restore-commands 'restore command' restore_cmds
        ;;
      schedule)
        local -a schedule_cmds=(
          'create:create a schedule'
          'delete:delete schedules'
          'describe:describe schedules'
          'get:get schedules'
          'pause:pause a schedule'
          'unpause:unpause a schedule'
        )
        _describe -t schedule-commands 'schedule command' schedule_cmds
        ;;
      plugin)
        local -a plugin_cmds=(
          'add:add a plugin'
          'get:get plugins'
          'remove:remove a plugin'
        )
        _describe -t plugin-commands 'plugin command' plugin_cmds
        ;;
    esac
    ;;
esac

return ret
