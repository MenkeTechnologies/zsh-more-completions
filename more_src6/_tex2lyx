#compdef tex2lyx
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/tex2lyx.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above. LyX tex2lyx uses single-dash
# long options (e.g. -skipchildren, -systemdir, -roundtrip).

local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[print usage information]' \
  '-version[display version information]' \
  '-c+[document class]:class:' \
  '-e+[default encoding (may switch)]:encoding:' \
  '-fixedenc+[fixed encoding (ignores encoding commands)]:encoding:' \
  '-f[force overwrite existing .lyx files]' \
  '-n[translate noweb files]' \
  '-m+[load modules]:modules:' \
  '-s+[additional syntax file]:file:_files' \
  '-skipchildren[skip child documents via \\include and \\input]' \
  '-roundtrip[re-export output back to LaTeX]' \
  '-copyfiles[copy included files to output directory]' \
  '-userdir+[user directory]:dir:_files -/' \
  '-systemdir+[system directory]:dir:_files -/' \
  '*:tex file:_files -g "*.tex"' && ret=0

return ret
