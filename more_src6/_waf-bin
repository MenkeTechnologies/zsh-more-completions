#compdef waf
# _waf-bin — Waf Python-based build framework (Thomas Nagy, Python); plug-in-driven configure/build/install for C/C++/etc
# upstream: https://gitlab.com/ita1024/waf

_waf-bin() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--prefix+[prefix]:dir:_files -/' \
        '--top+[top dir]:dir:_files -/' \
        '--out+[output dir]:dir:_files -/' \
        '-j+[jobs]:n:' \
        '--jobs+[jobs]:n:' \
        '-k[keep going]' \
        '--keep[keep going]' \
        '-p[progress bar]' \
        '--progress[progress bar]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--zones+[debug zones]:zones:' \
        '--targets+[targets]:str:' \
        '--no-msvc-lazy[disable msvc lazy detection]' \
        '--color+[color]:when:(yes no auto)' \
        '--notify[notify completion]' \
        '--profile[profile build]' \
        '-T+[type]:type:(default debug release)' \
        '--debug-info[debug info]' \
        '-x[do not run shell scripts]' \
        '--prefix+[install prefix]:dir:_files -/' \
        '--destdir+[install destdir]:dir:_files -/' \
        '--force[force]' \
        '*:command:(configure build install uninstall clean dist distcheck list step update)'
}

_waf-bin "$@"
