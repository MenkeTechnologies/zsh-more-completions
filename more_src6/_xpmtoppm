#compdef xpmtoppm
# Documentation: man xpmtoppm (Netpbm)
# Source: convert an X Pixmap (XPM) file to a PPM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--alphaout=[alpha output file (- for stdout)]:file:_files' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:xpm file:_files -g "*.xpm"' \
    && ret=0

return ret
