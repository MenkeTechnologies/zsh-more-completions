#compdef velero-plugin-for-aws
# _velero-plugin-for-aws — Velero AWS provider plugin (registers velero.io/aws ObjectStore + VolumeSnapshotter)
# upstream: https://github.com/vmware-tanzu/velero-plugin-for-aws
# Plugins are run as go-plugin gRPC servers by velero; the only flags exposed via the plugin framework Config are --log-level and --features. The S3 endpoint, region, KMS key, IAM role etc. come from the BackupStorageLocation / VolumeSnapshotLocation spec.

_velero-plugin-for-aws() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--log-level=[plugin log level]:level:(trace debug info warning error fatal panic)' \
        '--features=[csv of velero feature flags]:csv:'
}

_velero-plugin-for-aws "$@"
