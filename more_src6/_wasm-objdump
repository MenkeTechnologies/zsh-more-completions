#compdef wasm-objdump
# _wasm-objdump — WABT WebAssembly objdump (Andrew Belt et al); dumps sections, code, headers, relocations from .wasm files
# upstream: https://github.com/WebAssembly/wabt

_wasm-objdump() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-j --section)'{-j,--section}'+[show section]:section:(Type Import Function Table Memory Global Export Start Element Code Data Custom Name)' \
        '(-x --details)'{-x,--details}'[show section details]' \
        '(-d --disassemble)'{-d,--disassemble}'[disassemble code]' \
        '(-r --reloc)'{-r,--reloc}'[show relocations]' \
        '(-s --full-contents)'{-s,--full-contents}'[hex dump sections]' \
        '(-h --headers)'{-h,--headers}'[show headers]' \
        '*:wasm file:_files -g "*.wasm"'
}

_wasm-objdump "$@"
