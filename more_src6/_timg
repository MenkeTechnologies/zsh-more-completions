#compdef timg
# Documentation: https://github.com/hzeller/timg
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-g+[output geometry WxH (character cells)]:geometry' \
  '--grid=[arrange images in cols\[xrows\] grid]:cols[xrows]' \
  '-p+[pixelation mode]:mode:((h\:half\ blocks q\:quarter\ blocks k\:kitty\ graphics i\:iTerm2\ graphics s\:sixel\ graphics))' \
  '-C[center image horizontally]' \
  '--center[center image horizontally]' \
  '-W[fit width even if exceeds height]' \
  '--fit-width[fit width even if exceeds height]' \
  '-U[allow upscaling]' \
  '--upscale=[allow upscaling]:mode:(i)' \
  '-b+[background color for alpha: name, #rrggbb, auto, none]:color' \
  '-B+[checkerboard background color for transparency]:color' \
  '--pattern-size=[checkerboard pattern size]:size' \
  '--auto-crop=[crop same-color pixels around image]:pre-crop' \
  '--rotate=[rotate per EXIF or disable]:mode:(exif off)' \
  '-a[disable anti-aliasing]' \
  '-t+[stop after seconds]:seconds' \
  '--title=[show title with format string]:format' \
  '--frames=[only show first N frames]:count' \
  '--frame-offset=[start at given frame]:offset' \
  '--loops=[loop count for animations (-1=forever)]:count' \
  '-w+[wait time between images]:seconds' \
  '-V[force video subsystem]' \
  '-I[image-only, no video decoding]' \
  '--compress=[compress kitty/iterm2 data]:level' \
  '--threads=[parallel decoder threads]:threads' \
  '--color8[use 8-bit color for half/quarter blocks]' \
  '-o+[write to file instead of stdout]:output file:_files' \
  '--clear=[clear screen before display]:mode:(every)' \
  '-E[do not hide cursor]' \
  '-f+[read newline-separated file list]:file list:_files' \
  '-F+[read newline-separated file list]:file list:_files' \
  '*:file:_files' && ret=0

return ret
