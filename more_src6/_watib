local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# 18 named flags (with -O0/-O1 + 7 -f/-fno- pairs
# = 14 derived) decoded source-direct from args-
# parse spec at watib.scm:42-128.
_arguments -s -S \
  '(- *)'{-h,--help}'[display help and quit]' \
  '(-k --keep-going)'{-k,--keep-going}'[continue when encountering an error]' \
  '--stop-after=[stop after encountering N errors]:N:' \
  '-s[display less verbose error messages]' \
  '-j+[use N threads]:N:' \
  '(-v --validate-only)'{-v,--validate-only}'[validate only]' \
  '(-O1)-O0[disable all optimisations]' \
  '(-O0)-O1[enable all optimisations (default)]' \
  '(-ftestbr)-fno-testbr[disable type-based control flow rewriting]' \
  '(-fno-testbr)-ftestbr[enable type-based control flow rewriting]' \
  '(-fcopyprop)-fno-copyprop[disable copy propagation]' \
  '(-fno-copyprop)-fcopyprop[enable copy propagation]' \
  '(-funcast)-fno-uncast[disable redundant type tests and casts elimination]' \
  '(-fno-uncast)-funcast[enable redundant type tests and casts elimination]' \
  '(-funreachable)-fno-unreachable[disable unreachable code elimination]' \
  '(-fno-unreachable)-funreachable[enable unreachable code elimination]' \
  '(-fconst)-fno-const[disable constant folding]' \
  '(-fno-const)-fconst[enable constant folding]' \
  '(-fpuredrop)-fno-puredrop[disable redundant drop elimination]' \
  '(-fno-puredrop)-fpuredrop[enable redundant drop elimination]' \
  '(-fpeephole)-fno-peephole[disable peephole elimination]' \
  '(-fno-peephole)-fpeephole[enable peephole elimination]' \
  '-o+[output binary format to FILE (default: a.out.wasm)]:output file:_files -g "*.wasm"' \
  '--dump-cfg=[print CFG of FUNC in graphviz DOT format]:function name:' \
  '--dump-cfg-wat=[print CFG of FUNC in CFGWAT format]:function name:' \
  '--read-cfg=[read CFG from FILE and dump it]:CFG file:_files' \
  '*:WAT input file:_files -g "*.wat"' && ret=0

return ret
