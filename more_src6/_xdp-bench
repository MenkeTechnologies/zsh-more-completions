#compdef xdp-bench
# _xdp-bench — XDP packet-processing benchmark suite (xdp-project/xdp-tools)
# upstream: https://github.com/xdp-project/xdp-tools
# Subcommands + per-command flags from xdp-bench/xdp-bench.8.

_xdp-bench() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a common
    common=(
        '(-p --packet-operation)'{-p+,--packet-operation=}'[per-packet operation]:action:(no-touch read-data parse-ip swap-macs)'
        '(-l --load-mode)'{-l+,--load-mode=}'[program load mode]:mode:(dpa load-bytes)'
        '(-r --rxq-stats)'{-r,--rxq-stats}'[report per-RXQ statistics]'
        '(-i --interval)'{-i+,--interval=}'[stats interval in seconds]:seconds:'
        '(-e --extended)'{-e,--extended}'[print extended (per-CPU) stats]'
        '(-m --mode)'{-m+,--mode=}'[XDP attach mode]:mode:(native skb hw unspecified)'
        '*'{-v,--verbose}'[increase verbosity]'
        '--version[show version]'
        '(- *)'{-h,--help}'[show help]'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_xdp-bench_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                drop|pass|tx|xsk-drop|xsk-tx)
                    _arguments $common \
                        '1:ifname:_net_interfaces' && ret=0 ;;
                redirect|redirect-cpu|redirect-map|redirect-multi)
                    _arguments $common \
                        '(-c --cpu)'{-c+,--cpu=}'[CPU to redirect to (redirect-cpu)]:cpu:' \
                        '(-r --redirect-device)'{-r+,--redirect-device=}'[output interface]:ifname:_net_interfaces' \
                        '(-q --qsize)'{-q+,--qsize=}'[CPU map queue size in packets]:n:' \
                        '1:input ifname:_net_interfaces' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_xdp-bench_commands] )) ||
_xdp-bench_commands() {
    local -a commands
    commands=(
        'drop:drop all packets on an interface'
        'pass:pass all packets to the network stack'
        'tx:transmit packets back out (hairpin forwarding)'
        'redirect:XDP redirect using bpf_redirect()'
        'redirect-cpu:XDP CPU redirect via BPF_MAP_TYPE_CPUMAP'
        'redirect-map:XDP redirect via BPF_MAP_TYPE_DEVMAP'
        'redirect-multi:XDP multi-redirect via DEVMAP + BPF_F_BROADCAST'
        'xsk-drop:AF_XDP socket-based drop'
        'xsk-tx:AF_XDP socket-based hairpin forwarding'
    )
    _describe -t commands 'xdp-bench command' commands
}

_xdp-bench "$@"
