#compdef vigil
# ============================================================================
# _vigil — zsh completion for Valerian Saliou's vigil, the
#           Rust microservices status page (lettre SMTP notifier)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/valeriansaliou/vigil
#   Author     : Valerian Saliou  <valerian@valeriansaliou.name>
#   License    : MPL-2.0
#   Language   : Rust
#   Crate      : vigil-server v1.29.0
#   Binary     : vigil  (Cargo.toml [[bin]] name = "vigil",
#                        path = "src/main.rs")
#   Last push  : 2026-05-03
#
# WHAT IT IS
#   Vigil is "a microservices status page that monitors a
#   distributed infrastructure and sends alerts (Slack, SMS, etc.)"
#   — Valerian Saliou's actix-web-backed monitor that probes every
#   configured service over HTTP / TCP / ICMP / script, aggregates
#   health into a public-facing status page, and dispatches
#   notifications through pluggable notifier backends:  Slack /
#   Telegram / Twilio / Discord / Pushover / Microsoft Teams / XMPP
#   / Matrix / Webhook / WebEx / email (SMTP via lettre).  The
#   `vigil` binary loads a TOML configuration, spawns one background
#   thread per role (poll prober, script prober, aggregator,
#   responder), and serves the status page on the configured port.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/main.rs `make_app_args`
#                       clap Command builder)
#   vigil [OPTIONS]
#
#   Options:
#     -c, --config <PATH>     Path to configuration file
#                               [default: ./config.cfg]
#
#   Standard clap auto-flags (from `crate_name!() / crate_version!()
#                                   / crate_authors!() /
#                                   crate_description!()`):
#     -h, --help              Show help
#     -V, --version           Show version
#
#   vigil has no subcommands — the binary is a long-running daemon
#   driven entirely by the contents of `config.cfg`.  All notifier
#   targets, prober rules, aggregator thresholds, and responder
#   port/bind settings live in TOML inside that file.
#
# AXIS / CORPUS POSITION
#   Direct dependency on `lettre = { version = "0.11", features =
#   ["smtp-transport", "native-tls", "hostname", "builder"],
#   default-features = false, optional = true }` declared in
#   Cargo.toml — the canonical async Rust SMTP client maintained by
#   the lettre community (lettre/lettre).  lettre provides a typed
#   `Message::builder()`, `SmtpTransport` / `AsyncSmtpTransport`,
#   STARTTLS + native-TLS + rustls TLS, SASL/PLAIN/LOGIN/CRAM-MD5
#   authentication, IDNA / SMTPUTF8 envelope address handling, and
#   `mail-builder` integration for RFC 5322 / RFC 6531 message
#   construction.  Vigil's `src/notifier/email.rs` builds a
#   `lettre::Message`, opens an `SmtpTransport::starttls_relay`,
#   authenticates, and `transport.send(&email)` on every monitor
#   state change.  The lettre dep is gated behind the
#   `notifier-email` cargo feature so operators who only use Slack
#   / Telegram can disable SMTP entirely.  Verified via:
#     gh api repos/valeriansaliou/vigil/contents/Cargo.toml
#       → lettre = { version = "0.11", features = [...],
#                    optional = true }
#       → notifier-email = ["lettre"]
#     gh api search/code repo:valeriansaliou/vigil lettre
#       → src/notifier/email.rs, Cargo.toml, Cargo.lock
#   This entry is the Rust=132 leader bump that OPENS Axis 77
#   (SMTP / Email Client Library), pairing with future Go=
#   wneessen/go-mail and TS-Node=nodemailer poles to close the
#   axis at 1/1/1.
#
#   No completion for `vigil` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_vigil() {
    _arguments -s \
        '(-c --config)'{-c+,--config=}'[path to configuration file (default ./config.cfg)]:config file:_files -g "*.{cfg,toml,conf}"' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]'
}

_vigil "$@"
