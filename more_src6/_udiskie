#compdef udiskie
# Documentation: https://raw.githubusercontent.com/coldfix/udiskie/master/doc/udiskie.8.txt
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-c --config)'{-c,--config=}'[config file]:file:_files' \
  '(-C --no-config)'{-C,--no-config}'[do not use config file]' \
  '(-a --automount)'{-a,--automount}'[enable automatic device mounting]' \
  '(-A --no-automount)'{-A,--no-automount}'[disable automatic device mounting]' \
  '(-n --notify)'{-n,--notify}'[enable notifications]' \
  '(-N --no-notify)'{-N,--no-notify}'[disable notifications]' \
  '(-t --tray)'{-t,--tray}'[show tray icon]' \
  '(-s --smart-tray)'{-s,--smart-tray}'[show auto-hiding tray icon]' \
  '(-T --no-tray)'{-T,--no-tray}'[disable tray icon]' \
  '(-f --file-manager)'{-f,--file-manager=}'[file manager program]:program:_command_names -e' \
  '(-F --no-file-manager)'{-F,--no-file-manager}'[disable directory browsing]' \
  '--terminal=[terminal command]:program:_command_names -e' \
  '--no-terminal[disable terminal action]' \
  '(-p --password-prompt)'{-p,--password-prompt=}'[password prompt command]:program:' \
  '(-P --no-password-prompt)'{-P,--no-password-prompt}'[disable LUKS device unlocking]' \
  '--password-cache=[cache LUKS passwords (minutes)]:minutes:' \
  '--no-password-cache[disable password caching]' \
  '--event-hook=[execute command on device events]:command:' \
  '--no-event-hook[disable event hook]' \
  '--appindicator[use AppIndicator3 for status icon]' \
  '--no-appindicator[use Gtk.StatusIcon]' && ret=0

return ret
