#compdef vector2
# _vector2 — Datadog Vector vector2 CLI command-line frontend wrapping the Vector open-source ultra-fast high-performance observability data pipeline written in Rust providing sources transforms sinks aggregator agent VRL-vector-remap-language tap top list config-validate generate convert-config graph kubernetes-logs file-tail journald docker-host syslog amqp prometheus-scrape http-server hot-reload (Datadog Vector team, Rust); clap
# upstream: https://vector.dev/

_vector2() {
    local -a sub=(
        'config:configuration ops'
        'generate:generate config template'
        'graph:render config graph'
        'list:list sources/transforms/sinks'
        'tap:tap events flowing through'
        'top:visualize topology'
        'validate:validate config'
        'vrl:VRL REPL'
        'convert-config:convert config format'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[config file]:file:_files -g "vector.toml *.toml *.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "vector.toml *.toml *.yaml *.yml *.json"' \
        '*-C+[config dir]:dir:_files -/' \
        '--config-dir=+[dir]:dir:_files -/' \
        '--config-toml=+[file]:file:_files -g "*.toml"' \
        '--config-json=+[file]:file:_files -g "*.json"' \
        '--config-yaml=+[file]:file:_files -g "*.yaml *.yml"' \
        '-r[require healthy on startup]' \
        '--require-healthy[require healthy]' \
        '-t+[threads]:n:' \
        '--threads=+[N]:n:' \
        '--log-format=+[fmt]:f:(text json)' \
        '--internal-log-rate-limit=+[N]:n:' \
        '--color=+[c]:c:(auto always never)' \
        '--watch-config[watch config]' \
        '-w[watch config]' \
        '--allow-empty-config[allow empty]' \
        '--no-graceful-shutdown-limit[no shutdown limit]' \
        '--graceful-shutdown-limit-secs=+[N]:n:' \
        '--openssl-no-probe[no openssl probe]' \
        '--openssl-legacy-provider[openssl legacy]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vector subcommand' sub ;;
        args)
            case $words[1] in
                config) _arguments '1:op:(generate-schema)' '*:arg:' ;;
                list) _arguments '1:type:(sources transforms sinks)' ;;
                generate) _arguments '*:expression:' ;;
                tap) _arguments '*:component-id:' ;;
                validate) _arguments '*:config file:_files' ;;
                convert-config) _arguments '1:from-format:(toml yaml json)' '2:to-format:(toml yaml json)' '*:file:_files' ;;
            esac
            ;;
    esac
}

_vector2 "$@"
