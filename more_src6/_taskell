#compdef taskell
# Documentation: https://github.com/smallhadroncollider/taskell
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above; argument parser in src/Taskell/IO.hs.

local curcontext="$curcontext" state line ret=1

_arguments \
  '(- *)-h[show usage]' \
  '(- *)-v[show version]' \
  '-t[import Trello board: -t <boardID> <file>]' \
  '-g[import GitHub project: -g <identifier> <file>]' \
  '-i[show information about a taskell file]:file:_files -g "*.md"' \
  '*:taskell file:_files -g "*.md"' && ret=0

return ret
