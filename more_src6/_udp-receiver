#compdef udp-receiver
# Documentation: https://www.udpcast.linux.lu/cmd.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '--file=[write received data to file]:file:_files' \
  '-f+[write received data to file]:file:_files' \
  '--pipe=[run received data through pipe command]:cmd:' \
  '--log=[log statistics to file]:file:_files' \
  '--nosync[open target in asynchronous mode]' \
  '--sync[write target in synchronous mode]' \
  '--nokbd[do not read start signal from keyboard]' \
  '--start-timeout=[abort if sender not detected (sec)]:sec:' \
  '--receive-timeout=[abort if no packet received (sec)]:sec:' \
  '--portbase=[base UDP port]:port:' \
  '--interface=[network interface]:iface:_net_interfaces' \
  '--ttl=[multicast time-to-live]:ttl:' \
  '--mcast-rdv-address=[rendezvous multicast address]:addr:' \
  '--exit-wait=[wait time after final ack (ms)]:ms:' \
  '--ignore-lost-data[continue reception on data loss]' \
  '--stat-period=[statistics print interval (sec)]:sec:' \
  '--print-uncompressed-position=[show uncompressed position]:flag:(0 1)' && ret=0

return ret
