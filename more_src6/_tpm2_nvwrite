#compdef tpm2_nvwrite
# _tpm2_nvwrite — tpm2-software tpm2_nvwrite write data to a TPM2 NV index from file or stdin (tpm2-software team, C); custom argparse
# upstream: https://github.com/tpm2-software/tpm2-tools

_tpm2_nvwrite() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-C+[hierarchy or index]:str:' \
        '--hierarchy=+[hierarchy or index]:str:' \
        '-P+[auth password]:str:' \
        '--auth=+[auth password]:str:' \
        '-p+[auth password]:str:' \
        '-i+[input data file]:file:_files' \
        '--input=+[input data file]:file:_files' \
        '--offset=+[offset]:n:' \
        '-S+[session]:str:' \
        '--session=+[session]:str:' \
        '-Q[do not output anything]' \
        '--cphash=+[cp hash file]:file:_files' \
        '*:NV index:'
}

_tpm2_nvwrite "$@"
