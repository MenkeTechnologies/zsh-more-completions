#compdef xfd
# Documentation: man xfd (X.Org)
# Source: display all characters of an X font.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-fn -fa)-fn+[font name (core protocol)]:font:' \
    '(-fn -fa)-fa+[font family (Xft)]:font:' \
    '-box[outline each character cell]' \
    '-center[centre each glyph]' \
    '-start+[character code to start at]:n:' \
    '-bc+[box color]:color:' \
    '-rows+[number of rows]:n:' \
    '-columns+[number of columns]:n:' \
    '-bg+[background color]:color:' \
    '-fg+[foreground color]:color:' \
    '-bd+[border color]:color:' \
    '-bw+[border width]:n:' \
    '-rv[reverse video]' \
    '-geometry+[window geometry]:geom:' \
    '-display+[X display]:display:' \
    && ret=0

return ret
