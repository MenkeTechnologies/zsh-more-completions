#compdef zanata-cli
# Documentation: https://github.com/zanata/zanata-platform
# Reference accessed: 2026-05-21
# Verified: upstream repo - command-line client for the Zanata translation platform.
# STUB: zanata.org TLS broken; upstream docs not accessible for full flag verification.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*:: :_files' && ret=0

return ret
