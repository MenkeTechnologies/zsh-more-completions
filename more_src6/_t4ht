#compdef t4ht
# Documentation: t4ht --help (TeX4ht 2018)
# Source: TeX4ht t4ht — post-process tex4ht output (DVI -> HTML/CSS).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f-[dir/char prefix on input filename]:prefix:' \
    '-b[ignore -d/-m/-M for bitmaps]' \
    '-c-[named segment in env file]:segment:' \
    '-d-[directory for output files]:dir:_files -/' \
    '-e-[tex4ht.env location]:file:_files' \
    '-i[debugging info]' \
    '-g[ignore system-call errors]' \
    '-m-[chmod for new output files (excl. reused bitmaps)]:mode:' \
    '-p[do not convert pictures]' \
    '-r[replace bitmaps for all glyphs]' \
    '-M-[chmod for all output files]:mode:' \
    '-Q[quit if tex4ht.c had problems]' \
    '-S-[permission for system calls (e.g. *-always, filter)]:perm:' \
    '-X-[content for field %%3 in X scripts]:content:' \
    '*:DVI / .lg / .idv / .tmp file:_files -g "*.{dvi,lg,idv,tmp}"' \
    && ret=0

return ret
