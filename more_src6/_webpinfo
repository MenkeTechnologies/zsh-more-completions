#compdef webpinfo webpmux
# Documentation: source-direct extraction from upstream
# webmproject/libwebp examples/webpinfo.c + examples/webpmux.c
# `printf(...)` Help() bodies + the `for c = 1; c < argc; c++`
# argv-walking strcmp chain. Both binaries use **hand-rolled
# `strcmp(argv[c], "-flag")` argv loops** (NOT getopt or
# getopt_long), so the flag set was extracted by reading BOTH the
# Help() printf strings AND the strcmp dispatch in main().
# Reference accessed: 2026-05-30 via gh api.
# Google libwebp R142b — 2 WebP utility binaries from
# webmproject/libwebp not previously covered (cwebp / dwebp /
# gif2webp / img2webp / vwebp are already covered as multi=1
# elsewhere). Sister tools to the broader WebP toolchain.

case $service in

  webpinfo)
    # Print chunk-level structure and parsing diagnostics for one
    # or more WebP files.
    _arguments -s -S \
      '(-h -help -H -longhelp)-h[show help]' \
      '(-h -help -H -longhelp)-help[show help (synonym)]' \
      '(-h -help -H -longhelp)-H[show extended help]' \
      '(-h -help -H -longhelp)-longhelp[show extended help (synonym)]' \
      '-version[print version number and exit]' \
      '-quiet[do not show chunk parsing information]' \
      '-diag[show parsing error diagnosis]' \
      '-summary[show chunk stats summary]' \
      '-bitstream_info[parse bitstream header]' \
      '*:WebP input file:_files -g "*.webp"'
    ;;

  webpmux)
    # Multiplex / demultiplex WebP container metadata and frames.
    # Six top-level "mode" flags drive different argument shapes
    # downstream (-get / -set / -duration / -strip / -frame /
    # -info) per the multi-form Usage block in upstream Help().
    _arguments -s -S \
      '(-set -duration -strip -frame -info)-get[extract data]:thing:(icc exif xmp frame)' \
      '(-get -duration -strip -frame -info)-set[set color profile / metadata / parameters]:thing:(loop bgcolor icc exif xmp)' \
      '(-get -set -strip -frame -info)*-duration[set duration of selected frames (repeatable)]:duration-spec:' \
      '(-get -set -duration -frame -info)-strip[strip data]:thing:(icc exif xmp)' \
      '(-get -set -duration -strip -info)*-frame[add a frame (repeatable)]:frame-spec:' \
      '(-get -set -duration -strip -frame)-info[print info about a WebP file]' \
      '-loop+[set loop count (used with -frame)]:n:' \
      '-bgcolor+[set animation background color RRGGBBAA (used with -frame)]:hex:' \
      '-o+[output WebP file path]:file:_files -g "*.webp"' \
      '(-h -help)-h[show help]' \
      '(-h -help)-help[show help (synonym)]' \
      '-version[show version]' \
      '*:input file:_files'
    ;;

esac
