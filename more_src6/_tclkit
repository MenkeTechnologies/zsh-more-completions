#compdef tclkit
# Documentation: https://wiki.tcl-lang.org/page/tclkit
# Reference accessed: 2026-05-21
# Verified: upstream wiki at the URL above. tclkit is a self-contained Tcl
# runtime; no dedicated flag set is documented. Invocation form is
# `tclkit script.tcl arg ...`, matching tclsh.
# STUB: no documented flags beyond Tcl script invocation.

local curcontext="$curcontext" ret=1
_arguments -C \
  '*:script:_files -g "*.{tcl,tk,kit}"' && ret=0
return ret
