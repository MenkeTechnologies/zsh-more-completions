#compdef wslusc
# wslusc — create Windows shortcuts from WSL
# Part of wslu (https://github.com/wslutilities/wslu)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-v,--version}'[show version]' \
  '-n[set shortcut name]:name:' \
  '-i[set shortcut icon]:icon file:_files -g "*.ico"' \
  '-g[create shortcut and add to Start Menu]' \
  '-G[create shortcut and add to Start Menu in specified directory]:directory:' \
  '-d[create shortcut on Windows Desktop]' \
  '-D[create shortcut in specified Windows directory]:directory:' \
  '*:command:_command_names -e'
