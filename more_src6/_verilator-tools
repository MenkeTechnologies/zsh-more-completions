#compdef verilator-tools verilator-config verilator-coverage verilator-gantt verilator_includer
# _verilator-tools — Wilson Snyder Verilator tool-suite CLI dispatching to verilator verilator_coverage verilator_gantt verilator_includer for Verilog SystemVerilog converting compiling profiling coverage merging include flattening (verilator team, C++); getopt
# upstream: https://github.com/verilator/verilator

_verilator-tools() {
    local -a sub=(
        'config:show Verilator configuration'
        'coverage:merge or process coverage data'
        'gantt:generate gantt timing chart'
        'includer:flatten includes for distribution'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'verilator-tools subcommand' sub ;;
        args)
            case $words[1] in
                config) _arguments \
                    '--prefix[show install prefix]' \
                    '--libdir[show lib dir]' \
                    '--includedir[show include dir]' \
                    '--cflags[show CFLAGS]' \
                    '--libs[show LIBS]' \
                    '--datarootdir[show data root dir]' ;;
                coverage) _arguments \
                    '--write=+[file]:file:_files -g "*.dat *.info *.txt"' \
                    '--write-info=+[file]:file:_files -g "*.info"' \
                    '--annotate=+[dir]:dir:_files -/' \
                    '--annotate-all[annotate all]' \
                    '--annotate-min=+[N]:n:' \
                    '*:coverage file:_files -g "*.dat"' ;;
                gantt) _arguments \
                    '-o+[output file]:file:_files -g "*.html *.json"' \
                    '*:trace dat:_files -g "*.dat"' ;;
                includer) _arguments \
                    '-o+[output file]:file:_files' \
                    '-DPCF=+[name]:str:' \
                    '*:source files:_files -g "*.v *.sv *.vh"' ;;
            esac
            ;;
    esac
}

_verilator-tools "$@"
