#compdef varnishtop
# Documentation: https://manpages.debian.org/testing/varnish/varnishtop.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-1[print statistics once and exit (implies -d)]' \
  '-f[sort/group only on first field of each log entry]' \
  '-i+[include tags (comma-separated tag globs)]:taglist:' \
  '-I+[include by regex on tag content]:taglist:regex:' \
  '-x+[exclude tags (comma-separated tag globs)]:taglist:' \
  '-X+[exclude by regex on tag content]:taglist:regex:' \
  '-n+[varnish working directory of instance]:workdir:' \
  '-T+[transaction timeout in seconds]:sec:' \
  '-q+[VSL query]:query:' \
  '-r+[read log in binary file format]:file:_files' \
  '-c[only client communication transactions]' \
  '-b[only backend communication transactions]' \
  '-d[process log records at head of log]' \
  '-p+[seconds to measure over (default 60)]:sec:' && ret=0

return ret
