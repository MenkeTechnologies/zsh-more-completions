#compdef tolka
# Documentation: https://www.npmjs.com/package/@tolka/cli
# Reference accessed: 2026-05-23
# Verified: npm view @tolka/cli bin tolka.

# Zsh completion for tolka - @tolka/cli npm binary

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*::args:' && ret=0

return ret
