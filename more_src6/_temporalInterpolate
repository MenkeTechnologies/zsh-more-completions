#compdef temporalInterpolate
# Documentation: https://cfd.direct/openfoam/user-guide/
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/postProcessing/miscellaneous/temporalInterpolate — interpolate stored fields between time directories (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[OpenFOAM case directory]:dir:_files -/' \
    '-fileHandler+[file handler]:handler:(uncollated collated masterUncollated)' \
    '-parallel[run in parallel]' \
    '-noFunctionObjects[disable function objects]' \
    '-time+[restrict to selected times]:times:_default' \
    '-latestTime[use latest time]' \
    '-newTimes[only new times]' \
    '-fields+[wordReList of fields to interpolate]:list:_default' \
    '-divisions+[number of temporal sub-divisions]:integer:_default' \
    '-interpolationType+[interpolation type]:word:(linear spline)' \
    '-region+[region name]:region:_default' \
    && ret=0

return ret
