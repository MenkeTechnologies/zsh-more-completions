#compdef unocss
# Documentation: https://unocss.dev/integrations/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for unocss - instant on-demand atomic CSS engine CLI

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[show help information]'
  '(-v --version)'{-v,--version}'[show unocss version]'
  '(-c --config)'{-c,--config}'[config file path]:file:_files -g "*.(js|ts|mjs|cjs)"'
  '(-o --out-file)'{-o,--out-file}'[output file (default uno.css)]:file:_files'
  '(-w --watch)'{-w,--watch}'[watch files found by glob pattern]'
  '--preflights[activate preflight styling]'
  '(-m --minify)'{-m,--minify}'[minify generated CSS]'
  '--stdout[emit generated CSS to stdout, disables watch and out-file]'
  '--rewrite[update source files with transformed utilities]'
  '--write-transformed[deprecated alias for --rewrite]'
  '--debug[activate debugging output]'
  '--split-css[CSS file output mode]:mode:(true false multi single)'
  '--preset[switch default preset]:preset:(wind3 wind4)'
  '*:glob pattern:'
)

_arguments -s -S $arguments
