#compdef virt-who
# Documentation: https://github.com/candlepin/virt-who/blob/main/virt-who.8
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# virt-who: reports virtual guest IDs to subscription-manager / Satellite
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-d --debug)'{-d,--debug}'[enable debugging output]' \
  '(-o --one-shot)'{-o,--one-shot}'[send guest IDs once and exit]' \
  '(-i --interval)'{-i+,--interval=}'[acquire and send each N seconds]:seconds:' \
  '(-p --print)'{-p,--print}'[print host/guest association as JSON to stdout]' \
  '*'{-c+,--config=}'[configuration file (repeatable)]:file:_files' \
  '(-s --status)'{-s,--status}'[validate configurations and test connections]' \
  '(-j --json)'{-j,--json}'[with --status: machine-readable JSON report]' && ret=0
return ret
