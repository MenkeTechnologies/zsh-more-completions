#compdef venv pyvenv
# Documentation: https://docs.python.org/3/library/venv.html
# Source: cpython Lib/venv/__init__.py — Python virtualenv creation (argparse).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '--system-site-packages[give venv access to system site-packages]' \
    '(--copies)--symlinks[use symlinks instead of copies]' \
    '(--symlinks)--copies[use copies instead of symlinks]' \
    '--clear[delete env dir contents first]' \
    '--upgrade[upgrade env dir to use current Python]' \
    '--without-pip[skip installing pip]' \
    '--prompt=-[alternative prompt prefix]:prompt:_default' \
    '--upgrade-deps[upgrade core deps (pip) to latest]' \
    '--without-scm-ignore-files[skip adding SCM ignore files]' \
    '*:env dir:_files -/' \
    && ret=0

return ret
