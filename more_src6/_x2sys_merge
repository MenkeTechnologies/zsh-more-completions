#compdef x2sys_merge
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/x2sys/x2sys_merge.html
# Source: GenericMappingTools/gmt supplements/x2sys — merge an updated crossover-error database into a main one.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[primary COE database]:file:_files -g "*.txt(-.)"' \
    '-M+[file with newly computed COEs to merge]:file:_files -g "*.txt(-.)"' \
    '*-V[verbose (stackable)]' \
    '(- *)-\?[show help]' \
    && ret=0

return ret
