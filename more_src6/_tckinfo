#compdef tckinfo
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/tckinfo.html
# Source: MRtrix3/mrtrix3 cmd/tckinfo.cpp — print information about track file headers (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-count[count tracks explicitly, ignoring header]' \
    '*:tracks:_files -g "*.{tck,trk}"' \
    && ret=0

return ret
