#compdef wpactl
# Documentation: https://manpages.opensuse.org/Tumbleweed/wireplumber/wpctl.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# wpactl is an alias for wpctl (WirePlumber control)

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'status:display current state of objects in PipeWire'
  'get-volume:retrieve volume information about a node'
  'inspect:display detailed information about an object'
  'set-default:set device node as default for its category'
  'set-volume:set volume of a node'
  'set-mute:set mute state of a node'
  'set-profile:set profile of a device'
  'set-route:set route of a device'
  'clear-default:remove default node configuration'
  'settings:show, change, or remove WirePlumber settings'
  'set-log-level:set WirePlumber log level'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'wpctl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (set-volume|get-volume|set-mute|set-default|set-profile|set-route|inspect|clear-default)
        _arguments \
          '*::node_id_or_name:' && ret=0 ;;
      (set-log-level)
        _arguments \
          '*::level:' && ret=0 ;;
    esac ;;
esac

return ret
