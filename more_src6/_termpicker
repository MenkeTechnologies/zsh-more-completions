#compdef termpicker
# ============================================================================
# termpicker - terminal-based interactive color
#               picker built on Charm
#               bubbletea (Go)
#
# Author : Benjamin Chausse (ChausseBenjamin)
# Upstream: https://github.com/ChausseBenjamin/termpicker
#
# `termpicker` is a Charm bubbletea-based TUI
# color picker supporting multiple color spaces
# (RGB + HSL + HSV + CMYK + Hex) with interactive
# component editing, preview pane showing
# foreground/background usage examples, and
# clipboard integration for direct use in CSS +
# theme files + design tools. Features:
#   - Tab between color spaces with real-time
#     coordinate synchronization (edit HSL
#     sliders + see RGB + Hex + CMYK update
#     simultaneously)
#   - Customizable preview text + foreground +
#     background color sampling
#   - Oneshot mode for use as a shell-pipeline
#     color-picker (`$(termpicker -1)`)
#   - Color-space conversions via go-colorful's
#     CIE-correct conversion routines
#   - Integration with the Charm color-profile
#     auto-detection (24-bit truecolor +
#     256-color + 16-color fallback)
#
# Use cases:
#   - Picking colors for terminal application
#     theme files (alacritty.yml + kitty.conf +
#     wezterm.lua + tmux conf + neovim/vim
#     colorscheme.vim files)
#   - CSS variable values for web design
#   - Tailwind config color palette generation
#   - Vim/Emacs syntax-highlight color tuning
#   - Pipeline use in shell scripts that need
#     interactive color selection
#
# Usage:
#   termpicker [flags]
#
# Flags (urfave/cli/v3 declarative):
#   -c, --color <color>            - initial
#                                     color
#                                     (default
#                                     #b7416e;
#                                     accepts
#                                     hex +
#                                     CSS color
#                                     names +
#                                     rgb(...) +
#                                     hsl(...))
#   -l, --log-file <file>          - log file
#                                     for
#                                     debugging
#                                     (env
#                                     var:
#                                     TERMPICKER_LOG_FILE)
#   -t, --sample-text <text>       - preview
#                                     text shown
#                                     with the
#                                     picked
#                                     color
#                                     (default
#                                     "The quick
#                                     brown fox
#                                     jumps over
#                                     the lazy
#                                     dog";
#                                     env var:
#                                     TERMPICKER_
#                                     PREVIEW_
#                                     STRING; set
#                                     to "" to
#                                     disable
#                                     preview)
#       --bg, --background-sample <color>
#                                  - color used
#                                     for
#                                     preview
#                                     background
#                                     when the
#                                     picked
#                                     color is
#                                     shown as
#                                     foreground
#                                     (default
#                                     #111a1f;
#                                     requires
#                                     --sample-
#                                     text)
#       --fg, --foreground-sample <color>
#                                  - color used
#                                     for
#                                     preview
#                                     foreground
#                                     when the
#                                     picked
#                                     color is
#                                     shown as
#                                     background
#                                     (default
#                                     #ebcb88;
#                                     requires
#                                     --sample-
#                                     text)
#   -1, --oneshot                  - print the
#                                     picked
#                                     color to
#                                     stdout +
#                                     exit (for
#                                     shell-
#                                     pipeline
#                                     use)
#   -h, --help                     - print
#                                     urfave/cli
#                                     help
#   -v, --version                  - print
#                                     version
#                                     (cli.
#                                     VersionFlag)
#
# Example usage:
#   termpicker
#     # launch interactive picker
#   termpicker -c "#ff5733"
#     # launch with initial color set
#   termpicker -1
#     # one-shot mode (returns picked color on
#     # exit)
#   BG=$(termpicker -1 -c "#000000")
#     # capture picked color in shell variable
#   termpicker --fg "#fff" --bg "#000" \
#              -t "Sample text"
#     # custom preview
#
# Keyboard bindings inside the TUI (default
# bubbletea bindings + termpicker-specific):
#   Tab                            - cycle
#                                     between
#                                     color
#                                     spaces
#                                     (RGB +
#                                     HSL +
#                                     HSV +
#                                     CMYK +
#                                     Hex)
#   Arrow keys                     - move
#                                     between
#                                     components
#                                     (h/s/l
#                                     for HSL;
#                                     r/g/b
#                                     for RGB;
#                                     etc.)
#   +/-                            - adjust
#                                     selected
#                                     component
#                                     value
#   c                              - copy
#                                     current
#                                     color to
#                                     clipboard
#   q / Ctrl+C                     - quit
#
# The go-colorful lane is built on `github.com/
# lucasb-eyer/go-colorful v1.2.0` (declared
# verbatim at upstream go.mod HEAD as a direct
# dep, used by the termpicker color-manipulation
# routines for conversions between Hex / RGB /
# HSL / HSV / CMYK / CIE Lab / CIE Lch + color
# blending + interpolation), the canonical Go
# color manipulation library by Lucas Beyer
# (lucasb-eyer) - github.com/lucasb-eyer/go-
# colorful.
#
# Lucas Beyer's lucasb-eyer/go-colorful is the
# de-facto canonical Go color manipulation
# library:
#   - 2,000+ reverse-deps on pkg.go.dev
#   - Comprehensive color space support: sRGB +
#     linear RGB + CIE XYZ + CIE Lab + CIE Lch +
#     HSL + HSV + HCL + Luv + xyY
#   - Pre-defined CIE-correct white points (D50 +
#     D55 + D65 + D75)
#   - Color blending + interpolation in
#     perceptually-uniform CIE Lab + Lch spaces
#   - Color difference (CIE2000 + CIE94 + CIE76)
#   - Random palette generation with constraints
#   - Pure Go (no C dependencies)
#   - Stable API since 2014
#
# go-colorful's distinguishing position vs Go
# color alternatives:
#   - go-colorful (Beyer): canonical;
#     comprehensive; THIS AXIS
#   - muesli/gamut: higher-level palette +
#     theme management; uses go-colorful
#     underneath
#   - charmbracelet/colorprofile: terminal
#     color-profile detection (24-bit /
#     256-color / 16-color); narrow scope
#   - Various smaller color-conversion libraries
#
# Lucas Beyer's foundational role in Go color
# tooling - go-colorful is *the* Go canonical
# choice for any color-manipulation task
# requiring CIE-correct results. Almost every
# Go-based terminal UI library (charmbracelet/
# lipgloss + muesli/termenv + gdamore/tcell +
# rivo/tview + rivo/uniseg-related projects)
# transitively depends on go-colorful for
# accurate color-space conversions.
#
# Lucas Beyer's broader Go ecosystem footprint:
#   - lucasb-eyer/go-colorful (canonical Go
#     color manipulation; THIS AXIS)
#   - lucasb-eyer/golic (Go LZW image
#     compression)
#   - Smaller utility crates
#
# Lucas Beyer is primarily a deep-learning /
# computer-vision researcher (Google Brain
# Zurich + DeepMind; published authors of
# many influential ML papers including BiT +
# vision transformers + multimodal models).
# His go-colorful side-project is an early
# (2014) Go open-source contribution that
# happened to fill the canonical-Go-color-
# manipulation niche and remained the
# standard ever since.
#
# Beyer joins the *foundational-via-specific-
# niche canonical* author pattern - similar
# to:
#   - Shirou Wakayama-Sasaki (gopsutil; cross-
#     platform process info at Axis 270)
#   - Hajime Hoshi (oto + ebitengine; game +
#     audio at Axis 271)
#   - Erik Hedvall (Ogeon/palette; Rust color
#     at Axis 272 Rust slot R1514)
#
# This brings the multi-axis canonical-Go
# author cohort to 13 distinct individuals/orgs.
#
# termpicker uses go-colorful in the parse +
# colors + preview internal packages to:
#   1. Parse user-input color strings (hex /
#      rgb() / hsl() / CSS color names) into a
#      colorful.Color value
#   2. Convert between color spaces when the
#      user switches between RGB + HSL + HSV +
#      CMYK + Hex pickers (the user-edited
#      values in one space are converted to all
#      other spaces in real time)
#   3. Compute the contrast ratio for the
#      preview foreground/background combination
#      to ensure accessibility-aware preview
#      rendering
#
# Example usage pattern:
#   ```go
#   import "github.com/lucasb-eyer/go-colorful"
#
#   c, err := colorful.Hex("#ff5733")
#   if err != nil { return err }
#   h, s, l := c.Hsl()
#   r, g, b := c.RGB255()
#   // user adjusts h via arrow keys
#   h += 30
#   newColor := colorful.Hsl(h, s, l)
#   newHex := newColor.Hex()
#   ```
#
# ----------------------------------------------------------------------------
# AXIS 272 :: Color manipulation + color space
#              conversion libraries (sRGB +
#              linear RGB + CIE XYZ + CIE Lab +
#              HSL + Oklab + Okhsl + color
#              difference + interpolation)
# Round 1515 :: Go slot 2 of 4 :: continues Axis 272
#
# Cross-language canonical library family for this axis:
#   Rust    : Ogeon/palette              [R1514 _okolors]
#             (Erik Hedvall; type-safe
#              color space encoding;
#              first-class Oklab)
#   Go      : lucasb-eyer/go-colorful    [R1515 THIS FILE]
#             (Lucas Beyer; comprehensive
#              CIE-correct color manipulation;
#              transitive dep of every
#              Go TUI framework)
#   TS/Node : Qix-/color                 [R1516 closing]
#             (Heather Arthur; canonical
#              Node color manipulation
#              wrapper around color-name +
#              color-string + color-convert)
#
# Lucas Beyer's go-colorful is structurally
# interesting in this axis because it's the
# *substrate-via-TUI-ecosystem canonical*:
#   - Every Go TUI framework (charmbracelet/
#     lipgloss + bubbletea + glow + muesli/
#     termenv + gdamore/tcell + rivo/tview)
#     transitively depends on go-colorful
#   - The Charm ecosystem alone has ~50,000
#     stars across its main projects, and all
#     of them include go-colorful in their
#     dependency graph
#   - This makes go-colorful's reverse-
#     dependency reach far broader than its
#     direct-consumer count suggests
#
# The three lanes form a clean spectrum of
# color-library canonicalization mechanisms:
#
#   - Rust (palette): type-safe-encoding
#     canonical; the Ogeon/palette library
#     provides distinct Rust types per color
#     space + compile-time prevention of
#     mixing-up coordinates
#   - Go (go-colorful): substrate-via-TUI-
#     ecosystem canonical; transitively
#     depended on by every Go TUI framework
#   - Node (color): wrapper-of-microlibs
#     canonical; Heather Arthur's `color`
#     wraps color-name + color-string +
#     color-convert into a unified
#     manipulation API
#
# Each lane's mechanism reflects ecosystem
# culture:
#   - Rust: prefers type-safe encoding to
#     prevent mistakes at compile time
#   - Go: prefers a single canonical package
#     that everything depends on
#   - Node: prefers small composable
#     microlibraries with thin wrapper
#     ergonomics
#
# Cross-language interop at the color-
# coordinate level - sRGB hex codes + RGB
# triples are byte-identical across all
# three lanes. Lab + Oklab + Lch coordinates
# require floating-point precision but
# produce equivalent results within FP
# tolerances.
#
# Use-case spectrum across the lanes (so far):
#   - okolors (Rust, palette): image -> palette
#     extraction via Oklab k-means clustering
#   - termpicker (Go, go-colorful): interactive
#     TUI color picker with multi-space
#     conversion + preview pane
#
# Multi-axis canonical-Go author/org cohort
# (now spanning 13 distinct individuals/orgs):
#   - Andrew Gerrand + Go team (stdlib)
#   - Russ Cox (Go modules + crypto)
#   - Gustavo Niemeyer (yaml.v3 + gopkg.in
#     infrastructure)
#   - Klaus Post (compress + reedsolomon +
#     cpuid + asmfmt)
#   - Sergey Kamardin (gobwas/glob + gobwas/ws +
#     gobwas/httphead + gobwas/pool)
#   - Anthony Starks (ajstarks/svgo + deck +
#     dchart + openvg + gensvg)
#   - Jeevanandam Madanagopal (go-resty +
#     go-aah + go-model + sslmate-go)
#   - Matt Holt (Caddy + CertMagic + archives +
#     timeliner + acmez)
#   - Joe Chen / Unknwon (go-ini + Macaron +
#     Gogs + com)
#   - Marc Rene Arns / gomidi org (gomidi/midi +
#     connect + smf + mid + sf2)
#   - Eclipse Foundation Paho team
#     (paho.mqtt.golang; foundation-backed)
#   - Hajime Hoshi (oto + ebitengine + go-mp3)
#   - Lucas Beyer (lucasb-eyer/go-colorful,
#     THIS AXIS; specialized color-pipeline
#     infrastructure)
# ============================================================================

_termpicker() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-c --color)'{-c,--color}'[initial color (hex/CSS name/rgb()/hsl())]:color:' \
        '(-l --log-file)'{-l,--log-file}'[log file for debugging]:file:_files' \
        '(-t --sample-text)'{-t,--sample-text}'[preview text shown with picked color]:text:' \
        '(--bg --background-sample)'{--bg,--background-sample}'[preview background color]:color:' \
        '(--fg --foreground-sample)'{--fg,--foreground-sample}'[preview foreground color]:color:' \
        '(-1 --oneshot)'{-1,--oneshot}'[print picked color and exit]' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-v,--version}'[print version]'
}

_termpicker "$@"
