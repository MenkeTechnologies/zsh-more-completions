#compdef wsconsctl
# Documentation: man wsconsctl(8)
# Source: netbsd/src sbin/wsconsctl — wscons driver variable control (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[display all variables for the device]' \
    '(-k -m)-d[select display portion of device]' \
    '-f+[alternative control device]:control device:_files' \
    '(-d -m)-k[select keyboard portion (default)]' \
    '(-d -k)-m[select mouse portion of device]' \
    '-n[suppress variable names, values only]' \
    '-w[set variables (name=value or name+=value)]' \
    '*:variable:_default' \
    && ret=0

return ret
