#compdef wcs-match
# Documentation: https://astrometry.net
# Source: dstndstn/astrometry.net man/wcs-match.1 — print invariant-point coordinates of two WCS files (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-1+[first WCS input file]:file:_files -g "*.{wcs,fits,fit}"' \
    '-2+[second WCS input file]:file:_files -g "*.{wcs,fits,fit}"' \
    '(- *)-h[show help]' \
    '-v[verbose]' \
    && ret=0

return ret
