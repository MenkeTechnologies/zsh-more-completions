#compdef xdg-mime
# _xdg-mime — XDG xdg-mime (manage system and per-user MIME associations; query default opener / mimetype, set default app for MIME types, install/uninstall MIME XML definitions; --mode system|user)
# upstream: https://gitlab.freedesktop.org/xdg/xdg-utils
# Subcommands from xdg-utils scripts/xdg-mime.in on tip.

_xdg-mime() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--manual[show full manual]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'xdg-mime command' '(query:query default/mimetype default:set default install:install MIME XML uninstall:uninstall MIME XML)' ;;
        args)
            case $line[1] in
                query) _arguments '1:type:(default filetype)' '*:arg:_files' ;;
                default) _arguments '1:desktop file:_files -g "*.desktop"' '*:mimetype:' ;;
                install|uninstall) _arguments '--mode+[scope]:scope:(user system)' '--novendor[allow no-vendor xml]' '1:xml file:_files -g "*.xml"' ;;
            esac
            ;;
    esac
}

_xdg-mime "$@"
