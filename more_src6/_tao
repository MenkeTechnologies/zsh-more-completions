#compdef tao
# ============================================================================
# _tao — zsh completion for the Tao programming language compiler
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/zesterer/tao
#   Author     : Joshua Barretto (zesterer)  — author of ariadne, chumsky,
#                veloren engine
#   License    : MPL-2.0
#   Language   : Rust  (compiler) / Tao  (.tao source files)
#
# WHAT IT IS
#   Tao is "a statically-typed functional language with generics, typeclasses,
#   sum types, pattern-matching, first-class functions, currying, algebraic
#   effects, associated types, good diagnostics, etc."  It is an experimental
#   ML-family programming language by Joshua Barretto (zesterer) with focus
#   on excellent diagnostics (rendered through ariadne, the same source-span
#   error formatter zesterer authored), Hindley-Milner-style inference with
#   typeclasses, sum / product types, exhaustive pattern matching, currying
#   by default, and first-class algebraic effects.  The compiler stack is a
#   Rust cargo workspace organized into separate `syntax`, `analysis`,
#   `middle`, `cir`, and `vm` crates, with the top-level `compiler` crate
#   producing the `tao` binary that ties them together.  Compiled programs
#   currently execute on a bytecode VM (`tao_vm`).
#
# CLI ARGUMENT GRAMMAR  (verbatim from compiler/src/main.rs Args struct +
#                       compiler/src/lib.rs Options struct + middle/src/context.rs
#                       OptMode FromStr impl)
#   tao [OPTIONS] <FILE>
#
#   Positional:
#     <FILE>                     the .tao source file to compile and run
#
#   Options  (from Options structopt block, flattened into Args):
#     --debug <LAYER>            add a debugging layer to stdout
#                                (repeatable; values:
#                                   ast | hir | call_graph | mir | bytecode)
#     -o, --opt <MODE>           optimisation mode:  none | fast | size
#                                [default: none]
#
#   Standard structopt auto-flags:
#     -h, --help                 print help
#     -V, --version              print version
#
# LANGUAGE-CORPUS POSITION
#   Tao is the 138th programming language entry in this completion corpus,
#   closing the 3+1 micro-cycle that began at R821 (_chaz/matrix-sdk
#   Rust=113 opens Axis 58) and continued through R822 (_bbctl/mautrix-go
#   Go=113) and R823 (_polkadot-basic-notifications/matrix-js-sdk
#   TS-Node=113 CLOSES Axis 58 Matrix Federated Chat Protocol Library at
#   1/1/1 + triple-113 landmark).  Tao joins the roster of exotic languages
#   already in the corpus including Dada (R820 137th), Acton (R816 136th),
#   Stanza (R812 135th), Rune, Egel, Mlatu, Gwion, Silq (quantum), Mirth,
#   Lawvere/bill, Cognac/Cognate, and Scrapscript.
#
#   No completion for `tao` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_tao() {
    _arguments -s \
        '*--debug=[add a debugging layer to stdout (repeatable)]:layer:(ast hir call_graph mir call-graph bytecode)' \
        '(-o --opt)'{-o+,--opt=}'[optimisation mode]:mode:(none fast size)' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        ':source file:_files -g "*.tao"'
}

_tao "$@"
