#compdef vshadowmount
# Documentation: https://github.com/libyal/libvshadow
# Source: libyal/libvshadow manuals/vshadowmount.1 — FUSE-mount Windows Volume Shadow Copy (VSS) stores.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[show help]' \
    '-o[volume offset in bytes]:offset:' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '-X[extended options to pass to FUSE]:fuse opts:' \
    '*:image or volume then mountpoint:_files' \
    && ret=0

return ret
