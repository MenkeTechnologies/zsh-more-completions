#compdef uvg266
# _uvg266 — VVC/H.266 video encoder (ultravideo/uvg266)
# upstream: https://github.com/ultravideo/uvg266
# Flags from src/cli.c (getopt_long long_options[]).

_uvg266() {
    _arguments \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '(-i --input)'{-i+,--input=}'[input file (YUV/Y4M)]:file:_files' \
        '(-o --output)'{-o+,--output=}'[output bitstream]:file:_files -g "*.(vvc|266|bin)"' \
        '(-d --debug)'{-d+,--debug=}'[debug file]:file:_files' \
        '(-n --frames)'{-n+,--frames=}'[frame count]:n:' \
        '(-q --qp)'{-q+,--qp=}'[QP value]:qp:' \
        '(-p --period)'{-p+,--period=}'[intra period]:n:' \
        '(-r --ref)'{-r+,--ref=}'[reference frames]:n:' \
        '--input-res=[input resolution WxH or auto]:res:' \
        '--input-fps=[input framerate]:fps:' \
        '--input-bitdepth=[input bit depth]:n:(8 10 12)' \
        '--input-format=[input chroma format]:fmt:(P400 P420 P422 P444)' \
        '--input-file-format=[input file format]:fmt:(auto yuv y4m)' \
        '--preset=[encoder preset]:preset:(ultrafast superfast veryfast faster fast medium slow slower veryslow placebo)' \
        '--bitrate=[target bitrate (bits/s)]:n:' \
        '--threads=[number of threads]:n:' \
        '--owf=[number of overlapping frames]:n:' \
        '--wpp[enable WPP]' \
        '--no-wpp[disable WPP]' \
        '--tiles=[tile grid WxH]:grid:' \
        '--slices=[slice mode]:mode:' \
        '--gop=[GOP structure]:gop:' \
        '--level=[VVC level]:lvl:' \
        '--high-tier[encode as high tier]' \
        '--psnr[enable PSNR reporting]' \
        '--seek=[skip N input frames]:n:' \
        '--loop-input[loop the input forever]' \
        '--lossless[lossless coding]' \
        '--info[encode encoder version info SEI]' \
        '--rc-algorithm=[rate-control algorithm]:algo:(lambda oba)' \
        '--vaq=[variance-adaptive QP strength]:s:' \
        '--hash=[picture hash]:hash:(none checksum md5)' \
        '--crypto=[selective encryption]:bits:' \
        '--key=[encryption key (hex)]:hex:' \
        '--cqmfile=[custom-quant-matrix file]:file:_files' \
        '--scaling-list=[scaling list]:mode:(default off custom)' \
        '--roi-file=[ROI map file]:file:_files' \
        '--stats-file-prefix=[stats file prefix]:prefix:' \
        '*:input file:_files'
}

_uvg266 "$@"
