#compdef vitepress-cli vitepress
# _vitepress-cli — Evan You VitePress Vue-powered static site generator CLI alias (vuejs team, TypeScript); cac
# upstream: https://github.com/vuejs/vitepress

_vitepress-cli() {
    local -a sub=(
        'dev:start dev server'
        'build:build for production'
        'preview:preview production build'
        'serve:preview production build'
        'init:scaffold a new vitepress site'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vitepress subcommand' sub ;;
        args)
            case $words[1] in
                dev) _arguments \
                    '1:root dir:_files -/' \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--host=+[host]:host:_hosts' \
                    '--open=+[url to open]:url:_urls' \
                    '-o+[url to open]:url:_urls' \
                    '--cors[enable cors]' \
                    '--strictPort[strict port]' \
                    '--force[force optimizer]' \
                    '--clearScreen[clear screen]' \
                    '--debug[debug]' \
                    '-d[debug]' \
                    '--filter=+[filter]:str:' \
                    '-f+[filter]:str:' \
                    '--logLevel=+[level]:l:(info warn error silent)' \
                    '-l+[level]:l:(info warn error silent)' \
                    '--mode=+[mode]:m:(development production)' \
                    '--base=+[base path]:str:' \
                    '--config=+[config file]:file:_files -g "{vitepress.config,.vitepress/config}.{js,ts,mjs,mts}"' \
                    '-c+[config file]:file:_files -g "{vitepress.config,.vitepress/config}.{js,ts,mjs,mts}"' ;;
                build) _arguments \
                    '1:root dir:_files -/' \
                    '--mpa[multi-page mode]' \
                    '--base=+[base path]:str:' \
                    '--outDir=+[output dir]:dir:_files -/' \
                    '--target=+[target]:t:(es2020 esnext modules)' \
                    '--watch[watch mode]' \
                    '--debug[debug]' \
                    '--clearScreen[clear screen]' \
                    '--logLevel=+[level]:l:(info warn error silent)' \
                    '-l+[level]:l:(info warn error silent)' \
                    '--mode=+[mode]:m:(development production)' \
                    '--config=+[config file]:file:_files -g "{vitepress.config,.vitepress/config}.{js,ts,mjs,mts}"' \
                    '-c+[config file]:file:_files -g "{vitepress.config,.vitepress/config}.{js,ts,mjs,mts}"' ;;
                preview|serve) _arguments \
                    '1:root dir:_files -/' \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--host=+[host]:host:_hosts' \
                    '--open=+[url to open]:url:_urls' \
                    '-o+[url to open]:url:_urls' \
                    '--strictPort[strict port]' \
                    '--base=+[base path]:str:' ;;
                init) _arguments \
                    '1:root dir:_files -/' \
                    '--no-install[skip install]' ;;
            esac
            ;;
    esac
}

_vitepress-cli "$@"
