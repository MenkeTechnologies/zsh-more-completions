#compdef x2sys_init
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/x2sys/x2sys_init.html
# Source: GenericMappingTools/gmt supplements/x2sys — initialize a TAG for crossover-analysis databases.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-D+[format definition file prefix]:file:_files' \
    '-E+[data file extension]:suffix:_default' \
    '-F[force overwrite existing TAG]' \
    '-G+[geographic coordinates discontinuity]:disc:(d g)' \
    '-I+[track bin-index grid spacing (dx/dy)]:spacing:_default' \
    '-N+[distance/speed units]:opts:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '*-V[verbose (stackable)]' \
    '-W+[max time or distance gap]:opts:_default' \
    '-j+[spherical distance calc mode]:mode:_default' \
    '1:TAG:_default' \
    && ret=0

return ret
