#compdef tusk
# Documentation: https://github.com/rliebz/tusk
# Reference accessed: 2026-05-21
# Verified: appcli/app.go flag definitions in rliebz/tusk.

_tusk() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-f --file)'{-f,--file}'[set config file]:config:_files -g "*.yml *.yaml"' \
    '(-q --quiet)'{-q,--quiet}'[only print command output and errors]' \
    '(-s --silent)'{-s,--silent}'[print no output]' \
    '(-v --verbose)'{-v,--verbose}'[print verbose output]' \
    '(-V --version)'{-V,--version}'[print version and exit]' \
    '(-h --help)'{-h,--help}'[show help and exit]' \
    '--install-completion=[install tab completion]:shell:(bash zsh fish)' \
    '--uninstall-completion=[uninstall tab completion]:shell:(bash zsh fish)' \
    '--clean-cache[delete all cached files]' \
    '--clean-project-cache[delete cache for current config]' \
    '--clean-task-cache=[delete cached files for task]:task:' \
    '1:task:->tasks' \
    '*::arg:->args'

  case $state in
    tasks)
      local -a tasks
      if [[ -f tusk.yml ]]; then
        tasks=(${(f)"$(tusk --help 2>/dev/null | sed -n '/^Tasks:/,/^$/{ /^  /s/^  \([^ ]*\) *\(.*\)/\1:\2/p }')"})
      fi
      _describe 'task' tasks
      ;;
  esac
}

_tusk "$@"
