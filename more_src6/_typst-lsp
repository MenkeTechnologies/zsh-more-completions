#compdef typst-lsp
# Documentation: https://github.com/nvarner/typst-lsp
# Reference accessed: 2026-05-21
# Verified: upstream src/main.rs uses bpaf with empty Args struct;
# only auto-generated --help and --version are available. Repo is
# archived; superseded by Myriad-Dreamin/tinymist.
# Removed from prior file: --log-level, --log-file (not in upstream
# argument parser).

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' && ret=0

return ret
