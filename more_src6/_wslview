#compdef wslview
# wslview — open files/URLs in Windows default application from WSL
# Part of wslu (https://github.com/wslutilities/wslu)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)'{-u,--unregister}'[remove wslview as the default WSL web browser]' \
  '(- *)'{-r,--register}'[register wslview as the default WSL web browser]' \
  '*:file or URL:_urls'
