#compdef zoekt
# Documentation: https://github.com/sourcegraph/zoekt (cmd/zoekt/main.go)
# Reference accessed: 2026-05-21
# Verified: upstream source at the URL above.

_zoekt() {
    _arguments \
        '-shard=[search in a specific shard]:shard:_files' \
        '-index_dir=[directory holding zoekt index files]:directory:_directories' \
        '-cpu_profile=[write cpu profile to file]:file:_files' \
        '-full_profile=[write full profile to file]:file:_files' \
        '-profile_time=[duration to run for profiling]:duration' \
        '-debug[show debugscore output]' \
        '-v[print background data]' \
        '-r[print the repo before the file name]' \
        '-l[print matching filenames only]' \
        '-jsonl[print results in jsonl format]' \
        '-sym[experimental symbol search]' \
        '*:query'
}

_zoekt "$@"
