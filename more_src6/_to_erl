#compdef to_erl
# Documentation: to_erl -h
# Source: Erlang/OTP to_erl — attach to detached run_erl Erlang shell.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '-F[force connection even when pipe locked by another to_erl]' \
    '1:pipe_name or pipe_dir:_files -/' \
    && ret=0

return ret
