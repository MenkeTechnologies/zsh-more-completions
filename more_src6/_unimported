#compdef unimported
# Documentation: https://github.com/smeijer/unimported
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help / output all options]' \
  '--init[write default ignore patterns to .unimportedrc.json]' \
  '--update[write current results to ignore lists after verification]' \
  '--fix[automatically remove unimported files (destructive)]' \
  '--flow[strip Flow types from all files regardless of @flow pragma]' \
  '--no-cache[disable caching]' \
  '--clear-cache[delete the cache file then exit]' \
  '--show-config[show runtime config then exit]' \
  '--show-preset=[show preset configuration]:preset' \
  '*:cwd:_files -/' && ret=0

return ret
