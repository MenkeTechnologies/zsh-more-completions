#compdef xscreensaver-command
# _xscreensaver-command — xscreensaver controller; sends ClientMessage to the running xscreensaver daemon
# upstream: https://www.jwz.org/xscreensaver

_xscreensaver-command() {
    _arguments \
        '-display+[X display]:display:' \
        '-help[show help]' \
        '-version[show version]' \
        '-activate[activate now]' \
        '-deactivate[deactivate]' \
        '-cycle[cycle to next saver]' \
        '-next[next saver in list]' \
        '-prev[previous saver]' \
        '-select+[select Nth saver]:n:' \
        '-exit[kill daemon]' \
        '-restart[restart daemon]' \
        '-watch[watch state changes]' \
        '-time[print idle time]' \
        '-lock[lock now]' \
        '-suspend[suspend (sleep)]' \
        '-hibernate[hibernate]' \
        '-throttle[throttle (reduce CPU)]' \
        '-unthrottle[unthrottle]' \
        '-version-no-x[show version without contacting X]'
}

_xscreensaver-command "$@"
