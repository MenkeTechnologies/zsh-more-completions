#compdef zic
# Documentation: man zic(8)
# Source: eggert/tz zic.c (main) — timezone compiler (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--version[show version]' \
    '--help[show help]' \
    '-v[verbose]' \
    '-b+[output bloat mode]:mode:(slim fat)' \
    '-d+[output directory]:dir:_files -/' \
    '-D[do not create symlinks for related zones]' \
    '-g+[group for output files]:group:_groups' \
    '-l+[localtime zone name]:zone:_default' \
    '-L+[leap second file]:file:_files' \
    '-m+[mode for new directories]:mode:_default' \
    '-p+[posixrules zone]:zone:_default' \
    '-r+[trim ranges (@lo[/@hi])]:range:_default' \
    '-R+[upper time range (@hi)]:time:_default' \
    '-s[(deprecated) strict mode]' \
    '-t+[localtime link target]:file:_files' \
    '-u+[owner[:group] for output files]:owner:_users' \
    '-y+[(obsolete) year-istype]:istype:_default' \
    '*:zone file:_files' \
    && ret=0

return ret
