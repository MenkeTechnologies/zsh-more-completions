#compdef wlr-randr
# Documentation: https://github.com/emersion/wlr-randr/blob/master/main.c
# Reference accessed: 2026-05-21
# Verified: upstream source usage() lists only the options below.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '--dryrun[perform all actions except applying changes]' \
  '--output=[select an output to reconfigure]:output name' \
  '--on[enable the output]' \
  '--off[disable the output]' \
  '--mode=[set output resolution and refresh rate]:WxH@rate' \
  '--custom-mode=[set output custom resolution and refresh rate]:WxH@rate' \
  '--preferred[use preferred mode]' \
  '--pos=[position the output]:X,Y' \
  '--transform=[set output transform]:transform:(normal 90 180 270 flipped flipped-90 flipped-180 flipped-270)' \
  '--scale=[scale output by a factor]:factor' && ret=0

return ret
