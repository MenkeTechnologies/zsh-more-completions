#compdef tubeup
# Documentation: https://github.com/bibanon/tubeup
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--quiet[only print errors]' \
  '--debug[print all logs to stdout]' \
  '*--metadata=[custom metadata key:value for archive.org item]:kv:' \
  '--cookies=[cookies file]:file:_files' \
  '--proxy=[proxy URL]:url:' \
  '--username=[site username]:user:' \
  '--password=[site password]:password:' \
  '--dir=[directory for downloads and metadata]:dir:_directories' \
  '--output=[yt-dlp output template]:template:' \
  '--ignore-existing-item[do not check if item exists on archive.org]' \
  '--use-download-archive[use yt-dlp download archive]' \
  '*::url:' && ret=0

return ret
