#compdef viu
# Documentation: https://github.com/atanunq/viu
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for viu - terminal image viewer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-H --help)'{-H,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-w --width)'{-w,--width}'+[resize to width]:width:' \
  '(-h --height)'{-h,--height}'+[resize to height]:height:' \
  '-x+[horizontal offset]:x:' \
  '-y+[vertical offset]:y:' \
  '(-a --absolute-offset)'{-a,--absolute-offset}'[offset relative to terminal corner]' \
  '(-n --name)'{-n,--name}'[print filename above the image]' \
  '(-c --caption)'{-c,--caption}'[print filename below the image]' \
  '(-t --transparent)'{-t,--transparent}'[display transparent images with transparent background]' \
  '(-s --static)'{-s,--static}'[show only first frame of animated images]' \
  '(-b --blocks)'{-b,--blocks}'[force block output]' \
  '(-f --frame-rate)'{-f,--frame-rate}'+[GIF frame rate in frames per second]:fps:' \
  '(-1 --once)'{-1,--once}'[play GIF only once]' \
  '(-r --recursive)'{-r,--recursive}'[recurse into directories]' \
  '*:image file:_files' && ret=0

return ret
