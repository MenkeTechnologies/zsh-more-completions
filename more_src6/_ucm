#compdef ucm
# Documentation: https://www.unison-lang.org/docs/ucm-commands/
# Source: unisonweb/unison — Unison Codebase Manager.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _ucm_cmds
_ucm_cmds=(
    'add:add definitions from a typechecked file to the namespace'
    'alias:create an alias (alias.many/.term/.type variants)'
    'api:show the Codebase HTTP API URL'
    'auth:manage Unison Share authentication'
    'back:go back to the previous namespace'
    'branch:manage branches'
    'clear:clear the screen'
    'clone:clone a Unison repository'
    'compile:compile a term to a standalone binary'
    'create:create a new branch or project'
    'debug:internal debugging commands'
    'delete:delete definitions or branches'
    'dependencies:show dependencies of a term'
    'dependents:show dependents of a term'
    'diff:diff namespaces'
    'display:display a term value'
    'docs:show docs for a name'
    'edit:open a definition in $EDITOR'
    'find:search definitions by name or shape'
    'fork:fork a project or branch'
    'help:show help'
    'history:show namespace history'
    'io:misc IO subcommands'
    'lib:project-library management'
    'load:load a Unison source file'
    'ls:list namespace contents'
    'merge:merge a branch into the current branch'
    'move:rename a term/namespace'
    'project:project-management subcommands'
    'projects:list projects'
    'pull:pull definitions from a remote codebase'
    'push:push definitions to a remote codebase'
    'quit:exit ucm'
    'reflog:show recent operations'
    'reset:reset to a previous namespace state'
    'run:evaluate a term with the IO ability'
    'switch:switch the active project/branch'
    'test:run tests (test.all + test.passes)'
    'text:text-mode helpers'
    'todo:list outstanding tasks'
    'ui:open the local Codebase UI'
    'undo:undo the last operation'
    'unsafe:dangerous internal commands'
    'update:update definitions and their dependents'
    'upgrade:upgrade libraries'
    'version:show ucm version'
    'view:show a definition source'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'ucm command' _ucm_cmds && ret=0
        ;;
esac

return ret
