#compdef tdb2.tdbstats
# Documentation: https://jena.apache.org/documentation/tdb2/tdb2_cmds.html
# Source: apache/jena jena-cmds/src/main/java/tdb2/tdbstats.java — produce TDB2 dataset statistics for optimizer.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '--loc=[TDB2 database directory]:dir:_directories' \
    '--graph=[act on named graph]:iri:_urls' \
    && ret=0

return ret
