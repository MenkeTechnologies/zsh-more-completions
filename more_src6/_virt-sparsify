#compdef virt-sparsify
# _virt-sparsify — libguestfs virt-sparsify (re-sparsify a disk image so unused regions become holes again; --in-place modifies file in place, --convert raw|qcow2, --machine-readable, --ignore vol, --tmp tmpdir, --check-tmpdir, --zero-blocks block size; positional source then optional destination)
# upstream: https://github.com/libguestfs/libguestfs (sparsify)
# Flags from libguestfs sparsify/sparsify.ml on tip.

_virt-sparsify() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-x[trace libguestfs calls]' \
        '-q[quiet]' \
        '--in-place[modify in place]' \
        '--convert=*[output format]:fmt:(raw qcow2 vmdk vdi)' \
        '--compress[compress qcow2]' \
        '*--ignore+[volume]:vol:' \
        '--tmp+[tmpdir]:dir:_files -/' \
        '--check-tmpdir=*[strategy]:strategy:(ignore continue warn fail)' \
        '--machine-readable[machine-readable output]' \
        '--no-zero[do not zero unallocated]' \
        '1:source image:_files' \
        '2:destination image:_files'
}

_virt-sparsify "$@"
