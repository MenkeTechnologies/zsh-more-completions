#compdef tlsdate
# Documentation: man tlsdate(1)
# Source: ioerror/tlsdate src/tlsdate.c (master) — set system time over SSL/TLS handshake (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-s --skip-verification)'{-s,--skip-verification}'[do not verify the certificate]' \
    '(-n --dont-set-clock)'{-n,--dont-set-clock}'[do not set the clock]' \
    '(-H --host)'{-H+,--host=}'[remote host or IP]:host:_hosts' \
    '(-p --port)'{-p+,--port=}'[remote port]:port:_default' \
    '(-P --protocol)'{-P+,--protocol=}'[SSL/TLS protocol]:protocol:(sslv23 sslv3 tlsv1)' \
    '(-C --certcontainer)'{-C+,--certcontainer=}'[CA cert dir or file]:path:_files' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-V --showtime)'{-V+,--showtime=}'[print result time]:format:(human raw)' \
    '(-t --timewarp)'{-t,--timewarp}'[allow timewarp protection bypass]' \
    '(-l --leap)'{-l,--leap}'[allow leap-second adjustment]' \
    '(-x --proxy)'{-x+,--proxy=}'[proxy URL]:url:_default' \
    '(-w --http)'{-w,--http}'[use HTTP instead of HTTPS]' \
    && ret=0

return ret
