#compdef totp
# ============================================================================
# totp - RusTOTPony: CLI manager of TOTP generators (Rust, MIT)
#
# Author : German Lashevich (zebradil)
# Upstream: https://github.com/Zebradil/rustotpony
# crates : rustotpony (binary: totp)
#
# RusTOTPony is a CLI / TUI password-less authenticator. Stores
# Google-Authenticator-style TOTP secrets in an age-encrypted
# JSON database (`~/.rustotpony/totp.safe`), unlocked at runtime
# via the OS keyring (`keyring` crate). The default invocation
# is the realtime TUI dashboard - a continuously-updated table
# of every configured (Name -> 6-digit code) entry with a 30-
# second progress bar tracking each token's TTL.
#
# Subcommands:
#   dash       - realtime TUI dashboard (default)
#   list       - list all generators (names only)
#   add        - add a new generator interactively
#   delete     - delete a generator by name
#   rename     - rename a generator
#   eradicate  - delete the entire database
#   export     - dump all generators as JSON
#
# The TOTP lane is built on `totp-lite = "2.0.1"` (declared
# verbatim at upstream Cargo.toml HEAD), one of the two canonical
# Rust TOTP libraries. totp-lite is the minimal RFC 6238
# implementation (just the TOTP algorithm: HMAC-SHA1/SHA256/SHA512
# + truncate + mod 10^digits) without the higher-level URL parser
# / QR generator / vault-format extras of constantoine/totp-rs.
# Either library implements the same RFC 6238 byte-level
# algorithm, so any TOTP code generated by either is identical
# to a code from `oathtool`, Google Authenticator, Authy, Aegis,
# or any other RFC-6238-compliant authenticator.
#
# ----------------------------------------------------------------------------
# AXIS 218 :: TOTP (RFC 6238 Time-based One-Time Password Algorithm)
# Round 1352 :: Rust slot 1 of 4 :: OPENS Axis 218
#
# Cross-language canonical library family for this axis (proposed):
#   Rust    : constantoine/totp-rs + storyfeet/totp-lite
#   Go      : pquerna/otp                                - canonical Go OTP library
#   TS/Node : yeojz/otplib                               - canonical Node OTP library
#
# All three implement RFC 6238 (TOTP, 2011) layered on RFC 4226
# (HOTP, 2005). The byte-level algorithm dictates the output
# digits exactly, so cross-language interop is guaranteed at the
# token level. Where libraries diverge is on auxiliary surface:
# `otpauth://` URI parsing, QR code emission, secret generation,
# step / drift / time tolerance configuration, and Base32 secret
# encoding.
#
# Note: TOTP is structurally a sub-axis of multi-factor auth
# alongside WebAuthn (Axis 213) and JWT (Axis 202). TOTP is the
# universal "lowest common denominator" 2FA - every WebAuthn-
# enabled service usually also accepts a TOTP authenticator app
# as fallback for users without hardware-key support.
# ============================================================================

_totp() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :_totp_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                dash)       _arguments '(- *)'{-h,--help}'[help]' ;;
                list)       _arguments '(- *)'{-h,--help}'[help]' ;;
                add)        _arguments '(- *)'{-h,--help}'[help]' '1:name:' '2:username:' ;;
                delete)     _arguments '(- *)'{-h,--help}'[help]' '1:name:' ;;
                rename)     _arguments '(- *)'{-h,--help}'[help]' '1:current name:' '2:new name:' ;;
                eradicate)  _arguments '(- *)'{-h,--help}'[help]' ;;
                export)     _arguments '(- *)'{-h,--help}'[help]' ;;
            esac
            ;;
    esac

    return ret
}

_totp_cmds() {
    local -a cmds
    cmds=(
        'dash:Show realtime TUI dashboard with all generators'
        'list:List all generator names'
        'add:Add a new generator interactively'
        'delete:Delete a generator by name'
        'rename:Rename a generator'
        'eradicate:Delete all generators (whole database)'
        'export:Export all generators as JSON'
    )
    _describe -t commands 'totp command' cmds
}

_totp "$@"
