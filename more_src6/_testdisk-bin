#compdef testdisk
# _testdisk-bin — TestDisk partition / boot recovery (CGSecurity); recover lost partitions, repair NTFS/FAT boot sectors, recover ext2 superblocks
# upstream: https://www.cgsecurity.org/wiki/TestDisk

_testdisk-bin() {
    _arguments \
        '/log[create log]' \
        '/debug[debug mode]' \
        '/cmd+[command sequence]:cmd:' \
        '/list[list disks then exit]' \
        '/help[show help]' \
        '*:image or device:_files'
}

_testdisk-bin "$@"
