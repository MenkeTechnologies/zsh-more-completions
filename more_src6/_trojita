#compdef trojita
# Documentation: https://github.com/KDE/trojita/blob/master/src/Gui/main.cpp
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-a --addressbook)'{-a,--addressbook}'[show addressbook window]' \
  '(-c --compose)'{-c,--compose}'[compose new e-mail (default when url is provided)]' \
  '(-l --log-to-disk)'{-l,--log-to-disk}'[activate debug traffic logging to disk by default]' \
  '(-m --mainwindow)'{-m,--mainwindow}'[show main window (default when no option is provided)]' \
  '(-p --profile)'{-p+,--profile=}'[set a specific profile to use]:profile:' \
  '*:mailto url:' && ret=0

return ret
