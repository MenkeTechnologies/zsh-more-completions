#compdef typst-fmt
# _typst-fmt — Typst markup formatter CLI alias (Typst community, Rust); clap-rs
# upstream: https://github.com/typst-community/typstyle

_typst-fmt() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--check[check formatting without writing]' \
        '-c[check formatting without writing]' \
        '--diff[print diff to stdout]' \
        '-d[print diff to stdout]' \
        '--in-place[edit files in place]' \
        '-i[edit files in place]' \
        '--stdout[write result to stdout]' \
        '-o[write result to stdout]' \
        '--config=+[config file]:file:_files -g "typstyle.toml *.toml"' \
        '--column=+[max column width]:n:' \
        '-w+[max column width]:n:' \
        '--tab-spaces=+[tab spaces]:n:' \
        '--reorder-import-items[reorder import items]' \
        '--wrap-text[wrap text]' \
        '--no-wrap-text[no wrap text]' \
        '--style=+[style]:s:(default compact extended)' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--no-color[no color]' \
        '*:file:_files -g "*.typ"'
}

_typst-fmt "$@"
