#compdef x2sys_cross
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/x2sys/x2sys_cross.html
# Source: GenericMappingTools/gmt supplements/x2sys — compute crossover locations + errors between tracks.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-T+[x2sys TAG identifying data attributes]:tag:_default' \
    '-A+[restrict to track pairs in file]:file:_files' \
    '-C+[save per-pair runtimes]:opts:_default' \
    '-D+[geographic coord handling (S/N pole select)]:opts:(S N)' \
    '-E+[min track-orientation difference (deg)]:limit:_default' \
    '-I+[interpolation mode]:mode:(a c l n)' \
    '-Q+[crossover scope]:scope:(e i)' \
    '-R+[region west/east/south/north]:region:_default' \
    '-S+[track-speed window (lower/upper/highest)]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-W+[max points per side for spline (default 3)]:n:_default' \
    '-Z[report individual track values (not error+mean)]' \
    '-bo+[binary output format]:format:_default' \
    '-do+[NaN output → nodata replacement]:value:_default' \
    '*:track file:_files' \
    && ret=0

return ret
