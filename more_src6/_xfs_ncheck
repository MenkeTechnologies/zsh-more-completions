#compdef xfs_ncheck
# _xfs_ncheck — xfsprogs xfs_ncheck (generate names for inode numbers on an unmounted XFS filesystem; -f generates output suited for xfs_fsr, -i lists only specified inodes, -l logdev for external log, -s prints inode size summary, -V show version, positional device required)
# upstream: https://git.kernel.org/pub/scm/fs/xfs/xfsprogs-dev.git
# Flags from xfsprogs db/check.c on tip.

_xfs_ncheck() {
    _arguments \
        '-V[show version]' \
        '-f[format for xfs_fsr]' \
        '*-i+[inode number]:inode:' \
        '-l+[external log device]:device:_files -g "/dev/*"' \
        '-s[print size]' \
        '1:device:_files -g "/dev/*"'
}

_xfs_ncheck "$@"
