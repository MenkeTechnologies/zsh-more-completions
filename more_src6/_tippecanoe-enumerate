#compdef tippecanoe-enumerate
# Documentation: https://github.com/mapbox/tippecanoe
# Source: mapbox/tippecanoe enumerate.cpp — enumerate tile coordinates from .mbtiles (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '*:mbtiles file:_files -g "*.mbtiles"' \
    && ret=0

return ret
