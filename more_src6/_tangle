#compdef tangle
# Documentation: tangle --help (TeX Live 2026 WEB)
# Source: Knuth WEB system — tangle WEBFILE.web into a Pascal program.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[display help]' \
    '(- *)-version[output version information]' \
    '-length=[first NUMBER characters of an identifier must be unique (default 32)]:number:' \
    '(-strict)-loose[honor case/underline options when comparing identifiers (default)]' \
    '(-loose)-strict[remove underlines and uppercase identifiers before comparison]' \
    '(-mixedcase -uppercase)-lowercase[make all identifiers lowercase]' \
    '(-lowercase -uppercase)-mixedcase[retain identifier case unchanged (default)]' \
    '(-lowercase -mixedcase)-uppercase[make all identifiers uppercase]' \
    '-underline[do not remove underline characters from identifiers]' \
    '1:web source:_files -g "*.web"' \
    '2:change file:_files -g "*.ch"' \
    '3:pascal output:_files -g "*.p"' \
    && ret=0

return ret
