#compdef tckresample
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/tckresample.html
# Source: MRtrix3/mrtrix3 cmd/tckresample.cpp + src/dwi/tractography/resampling/resampling.cpp (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(-downsample -step_size -num_points -endpoints -line -arc)-upsample+[upsample density by factor]:factor:_default' \
    '(-upsample -step_size -num_points -endpoints -line -arc)-downsample+[downsample density by factor]:factor:_default' \
    '(-upsample -downsample -num_points -endpoints -line -arc)-step_size+[resample to step size in mm]:size:_default' \
    '(-upsample -downsample -step_size -endpoints -line -arc)-num_points+[resample to fixed number of points]:n:_default' \
    '(-upsample -downsample -step_size -num_points -line -arc)-endpoints[output only the two endpoints]' \
    '(-upsample -downsample -step_size -num_points -endpoints -arc)-line+[sample along straight line between two points]:n:_default:start:_default:end:_default' \
    '(-upsample -downsample -step_size -num_points -endpoints -line)-arc+[sample along arc through three points]:n:_default:start:_default:mid:_default:end:_default' \
    '1:in_tracks:_files -g "*.{tck,trk}"' \
    '2:out_tracks:_files' \
    && ret=0

return ret
