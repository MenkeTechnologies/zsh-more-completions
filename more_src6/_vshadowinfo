#compdef vshadowinfo
# Documentation: https://github.com/libyal/libvshadow
# Source: libyal/libvshadow manuals/vshadowinfo.1 — display info about Windows Volume Shadow Copy (VSS) stores.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[show allocation information]' \
    '-h[show help]' \
    '-o[volume offset in bytes]:offset:' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '*:image file or volume:_files' \
    && ret=0

return ret
