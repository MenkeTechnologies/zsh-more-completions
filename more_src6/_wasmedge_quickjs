# ============================================================================

_wasmedge_quickjs() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show usage help and exit]' \
    ':file:_files -g "*.js"' \
    '*:argument:'
}

_wasmedge_quickjs "$@"
