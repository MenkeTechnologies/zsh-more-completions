#compdef tsup-cli
# _tsup-cli — egoist tsup TypeScript library bundler CLI alias (egoist, TypeScript); cac
# upstream: https://github.com/egoist/tsup

_tsup-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-c+[config file]:file:_files -g "tsup.config.*"' \
        '--config=+[config file]:file:_files -g "tsup.config.*"' \
        '--watch[watch mode]' \
        '-w[watch mode]' \
        '--clean[clean dist before build]' \
        '--clean.dist=+[clean dist]:b:(true false)' \
        '--dts[generate dts]' \
        '--dts.only=+[only emit dts]:b:(true false)' \
        '--dts.resolve=+[dts resolve]:b:(true false)' \
        '--dts.entry=+[dts entry]:str:' \
        '--experimentalDts[experimental dts]' \
        '--minify[minify]' \
        '--minify=terser[minify with terser]' \
        '--minify=swc[minify with swc]' \
        '--minify=esbuild[minify with esbuild]' \
        '--minify-whitespace[minify whitespace]' \
        '--minify-identifiers[minify identifiers]' \
        '--minify-syntax[minify syntax]' \
        '--keep-names[keep names]' \
        '--platform=+[platform]:p:(browser node neutral)' \
        '--external=+[external module]:list:' \
        '--noExternal=+[bundle even if marked external]:list:' \
        '--target=+[target]:list:' \
        '--format=+[format]:f:(cjs esm iife)' \
        '--global-name=+[global name]:str:' \
        '--legacy-output[legacy output]' \
        '--define=+[define key=value]:list:' \
        '--inject=+[inject path]:list:_files' \
        '--shims[generate shims]' \
        '--sourcemap=+[sourcemap]:m:(true false inline)' \
        '--out-dir=+[output dir]:dir:_files -/' \
        '--out-dir[output dir]' \
        '--entry=+[entry file]:list:_files' \
        '--ignore-watch=+[ignore watch]:list:' \
        '--onSuccess=+[command to run on success]:str:' \
        '--silent[silent]' \
        '--treeshake[tree shake]' \
        '--no-treeshake[no tree shake]' \
        '--no-splitting[no splitting]' \
        '--splitting[splitting]' \
        '--public-dir=+[public dir]:dir:_files -/' \
        '--bundle[bundle]' \
        '--no-bundle[no bundle]' \
        '--metafile=+[metafile output]:file:_files' \
        '--no-config[no config]' \
        '--banner=+[banner type=text]:str:' \
        '--footer=+[footer type=text]:str:' \
        '--name=+[name]:str:' \
        '*:entry:_files'
}

_tsup-cli "$@"
