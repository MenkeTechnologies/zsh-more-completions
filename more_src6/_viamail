#compdef viamail
# Documentation: man viamail(1)
# Source: nmh uip/viamail.c (master) — send a file as multimedia mail (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-to+[recipient]:address:_email_addresses' \
    '-from+[sender]:address:_email_addresses' \
    '-subject+[subject]:subject:_default' \
    '-parameters+[arguments]:args:_default' \
    '-description+[description text]:text:_default' \
    '-comment+[comment text]:text:_default' \
    '-delay+[delay seconds]:seconds:_default' \
    '(-verbose -noverbose)-verbose[verbose]' \
    '(-verbose -noverbose)-noverbose[no verbose]' \
    '-debug[debug output]' \
    '-version[show version]' \
    '-help[show help]' \
    && ret=0

return ret
