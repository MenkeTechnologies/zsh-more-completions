#compdef temporal-server
# _temporal-server — Temporal workflow server (temporalio/temporal)
# upstream: https://github.com/temporalio/temporal
# Subcommands from cmd/server/main.go (urfave/cli).

_temporal-server() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-r --root)'{-r+,--root=}'[root directory (deprecated)]:dir:_files -/' \
        '(-c --config)'{-c+,--config=}'[config dir relative to root (deprecated)]:dir:_files -/' \
        '(-e --env)'{-e+,--env=}'[runtime environment (deprecated)]:env:(development production)' \
        '(--az --zone)'{--az+,--zone=}'[availability zone (deprecated)]:az:' \
        '--config-file=[path to config file]:file:_files' \
        '--allow-no-auth[allow no authorizer]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                start:'start Temporal server'
                validate-dynamic-config:'validate a dynamic config file against known keys/types'
                render-config:'render server config template'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                start)
                    _arguments \
                        '*'{-svc+,--service=}'[service to start (repeatable)]:service:(frontend matching history worker internal-frontend)' ;;
                validate-dynamic-config)
                    _arguments '*:dynamic config file:_files -g "*.(yml|yaml)"' ;;
            esac
            ;;
    esac
}

_temporal-server "$@"
