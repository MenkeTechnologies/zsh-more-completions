#compdef xmlsec xmlsec1
# Documentation: https://manpages.debian.org/bookworm/xmlsec1/xmlsec1.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream xmlsec1(1) manpage. Commands are specified with -- prefix:
# `xmlsec --sign`, `xmlsec --verify`, etc.

# xmlsec1: XML Security command line tool (signatures + encryption)
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--help-all[show help for all commands]' \
  '(- *)--help-keys[show keys command help]' \
  '(- *)--help-sign[show sign command help]' \
  '(- *)--help-verify[show verify command help]' \
  '(- *)--help-encrypt[show encrypt command help]' \
  '(- *)--help-decrypt[show decrypt command help]' \
  '(- *)--version[show version]' \
  '--keys[keys management]' \
  '--sign[sign data using the template file]' \
  '--verify[verify a signed file]' \
  '--sign-tmpl[create and sign a dynamic template]' \
  '--encrypt[encrypt data using the template file]' \
  '--decrypt[decrypt an encrypted file]' \
  '--output=[output file]:file:_files' \
  '--crypto=[crypto engine]:name:(openssl mscrypto nss gnutls gcrypt)' \
  '--crypto-config=[crypto config path]:dir:_files -/' \
  '--node-id=[XML node ID]:id:' \
  '--node-name=[XML node name]:name:' \
  '--node-xpath=[XPath expression to select node]:xpath:' \
  '--privkey-pem=[private key (PEM)]:file:_files' \
  '--privkey-der=[private key (DER)]:file:_files' \
  '--pkcs8-pem=[PKCS8 private key (PEM)]:file:_files' \
  '--pkcs8-der=[PKCS8 private key (DER)]:file:_files' \
  '--pubkey-pem=[public key (PEM)]:file:_files' \
  '--pubkey-der=[public key (DER)]:file:_files' \
  '--aeskey=[AES key file]:file:_files' \
  '--deskey=[DES key file]:file:_files' \
  '--hmackey=[HMAC key file]:file:_files' \
  '--pkcs12=[PKCS12 file]:file:_files' \
  '--pubkey-cert-pem=[public key cert (PEM)]:file:_files' \
  '--pubkey-cert-der=[public key cert (DER)]:file:_files' \
  '--pwd=[password]:password:' \
  '--trusted-pem=[trusted certs (PEM)]:file:_files' \
  '--untrusted-pem=[untrusted certs (PEM)]:file:_files' \
  '--depth=[max cert chain depth]:n:' \
  '--insecure[do not verify certificates]' \
  '--X509-skip-strict-checks[skip strict X.509 checks]' \
  '--binary-data=[binary input data]:file:_files' \
  '--xml-data=[XML input data]:file:_files' \
  '--session-key=[session key class-size]:spec:' \
  '--dtd-file=[DTD file]:file:_files' \
  '--enabled-key-data=[enabled key data]:list:' \
  '--enabled-retrieval-uris=[enabled retrieval URI schemes]:list:' \
  '--enabled-reference-uris=[enabled reference URI schemes]:list:' \
  '--enabled-cipher-reference-uris=[enabled cipher reference URI schemes]:list:' \
  '--enable-visa3d-hack[enable Visa3D ID hack]' \
  '--ignore-manifests[ignore manifests]' \
  '--store-references[store references]' \
  '--store-signatures[store signatures]' \
  '--id-attr=[ID attribute name]:attr:' \
  '--gen-key=[generate key spec]:spec:' \
  '--keys-file=[keys file]:file:_files' \
  '--privkey-openssl-engine=[OpenSSL engine for private key]:engine:' \
  '--repeat=[number of repeat iterations]:n:' \
  '--print-debug[print debug info]' \
  '--print-xml-debug[print XML debug]' \
  '--xxe[enable XXE (insecure)]' \
  '*:file:_files' && ret=0

return ret
