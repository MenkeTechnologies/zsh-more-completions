#compdef umbrel
# _umbrel — Umbrel personal server OS CLI alias (getumbrel team, Bash/TypeScript); custom argparse
# upstream: https://github.com/getumbrel/umbrel

_umbrel() {
    local -a sub=(
        'start:start umbrel services'
        'stop:stop umbrel services'
        'restart:restart umbrel services'
        'status:show service status'
        'logs:show service logs'
        'update:update umbrel'
        'reset:reset umbrel state'
        'app:install:install app'
        'app:uninstall:uninstall app'
        'app:start:start app'
        'app:stop:stop app'
        'app:restart:restart app'
        'app:update:update app'
        'app:logs:show app logs'
        'app:compose:run compose command for app'
        'app:list:list installed apps'
        'app:get-state:get app state'
        'app:get-config:get app config'
        'app:set-config:set app config'
        'app:port:get port'
        'app:nginx:reload nginx'
        'app:script:run app script'
        'app:store:list:list stores'
        'app:store:add:add store'
        'app:store:remove:remove store'
        'app:store:update:update store'
        'user:set:set user info'
        'user:get:get user info'
        'user:reset-password:reset password'
        'user:set-2fa:set 2fa'
        'user:disable-2fa:disable 2fa'
        'tor:enable:enable tor'
        'tor:disable:disable tor'
        'tor:status:tor status'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'umbrel subcommand' sub ;;
        args)
            case $words[1] in
                app:install|app:uninstall|app:start|app:stop|app:restart|app:update|app:logs|app:get-state|app:get-config|app:port|app:script) _arguments '1:app id:' ;;
                app:compose) _arguments '1:app id:' '*:compose args:' ;;
                app:store:add|app:store:remove|app:store:update) _arguments '1:store url:_urls' ;;
            esac
            ;;
    esac
}

_umbrel "$@"
