#compdef zpool-detach
# _zpool-detach — OpenZFS zpool detach (detach a leg from a mirrored vdev; only valid when the remaining mirror leg(s) still satisfy redundancy; positional pool followed by the device to remove)
# upstream: https://github.com/openzfs/zfs
# Argument shape from openzfs cmd/zpool/zpool_main.c (zpool_do_detach) on tip.

_zpool-detach() {
    _arguments \
        '1:pool:' \
        '2:device:'
}

_zpool-detach "$@"
