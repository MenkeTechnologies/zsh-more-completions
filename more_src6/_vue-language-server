#compdef vue-language-server
# Documentation: https://github.com/vuejs/language-tools
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: vuejs/language-tools README does not document CLI flags for the
# vue-language-server binary; like other LSP servers it is normally
# invoked by an editor over stdio. Only --stdio (universal LSP convention)
# kept; --help removed (not documented).

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '--stdio[run on stdio transport]' && ret=0
return ret
