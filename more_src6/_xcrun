#compdef xcrun
# Documentation: https://developer.apple.com/library/archive/documentation/Darwin/Reference/ManPages/man1/xcrun.1.html
# Source: Apple Xcode developer tools — locate and run a developer tool from the active SDK / toolchain.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '--version[show version]' \
    '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
    '(--sdk)--sdk[SDK name or path]:sdk:(macosx iphoneos iphonesimulator appletvos appletvsimulator watchos watchsimulator driverkit)' \
    '(--toolchain)--toolchain[toolchain identifier or path]:toolchain:' \
    '(-f --find)'{-f,--find}'[print absolute path of the tool and exit]' \
    '(-r --run)'{-r,--run}'[find and execute the tool (default behavior)]' \
    '(-n --no-cache)'{-n,--no-cache}'[do not use the lookup cache]' \
    '(-k --kill-cache)'{-k,--kill-cache}'[invalidate the lookup cache]' \
    '(-l --log)'{-l,--log}'[show what was invoked on stderr]' \
    '(--show-sdk-path)--show-sdk-path[show selected SDK installation path]' \
    '(--show-sdk-version)--show-sdk-version[show selected SDK version]' \
    '(--show-sdk-build-version)--show-sdk-build-version[show selected SDK build version]' \
    '(--show-sdk-platform-path)--show-sdk-platform-path[show selected SDK platform path]' \
    '(--show-sdk-platform-version)--show-sdk-platform-version[show selected SDK platform version]' \
    '*:tool and arguments:_command_names -e' \
    && ret=0

return ret
