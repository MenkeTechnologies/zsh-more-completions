#compdef xxd-cli
# _xxd-cli — Juergen Weigert xxd make hex dump or do reverse CLI alias (vim team, C); custom argparse
# upstream: https://github.com/vim/vim

_xxd-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-a[toggle autoskip]' \
        '-b[binary digits]' \
        '-C[capitalize variable names in C output]' \
        '-c+[cols]:n:' \
        '-E[show characters in EBCDIC]' \
        '-e[little endian dump]' \
        '-g+[bytes per group]:n:' \
        '-i[C include file output]' \
        '-l+[length]:n:' \
        '-n+[name]:str:' \
        '-o+[offset]:n:' \
        '-p[postscript output]' \
        '-q[quiet]' \
        '-r[reverse operation]' \
        '-s+[seek]:str:' \
        '-u[uppercase hex]' \
        '*:input output:_files'
}

_xxd-cli "$@"
