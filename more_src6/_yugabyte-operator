#compdef yugabyte-operator
# _yugabyte-operator — Yugabyte Kubernetes operator (reconciles YBCluster + YBUniverse CRs into yb-master + yb-tserver StatefulSets)
# upstream: https://github.com/yugabyte/yugabyte-operator
# Source: cmd/manager/main.go on tip; runtime configuration via env vars (WATCH_NAMESPACE, OPERATOR_NAME, POD_NAME) + operator-sdk zap flags (--zap-*).

_yugabyte-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--zap-devel[zap development-mode encoder]' \
        '--zap-encoder=[zap log encoder]:enc:(json console)' \
        '--zap-log-level=[zap log level]:level:(debug info warn error dpanic panic fatal)' \
        '--zap-stacktrace-level=[zap log level that triggers a stacktrace]:level:(info error panic)' \
        '--zap-time-encoding=[zap time encoding]:enc:(epoch millis nano iso8601 rfc3339 rfc3339nano)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_yugabyte-operator "$@"
