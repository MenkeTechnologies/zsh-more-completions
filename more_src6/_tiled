#compdef tiled
# _tiled — Tiled map editor with CLI export support
# upstream: https://github.com/mapeditor/tiled

_arguments -s -S \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '--export-map=[export a map file]:source dest:' \
    '--export-tileset=[export a tileset file]:source dest:' \
    '--export-formats[print list of supported export formats]' \
    '--minimize[start minimized]' \
    '--no-opengl[disable hardware-accelerated rendering]' \
    '--disable-opengl[disable OpenGL]' \
    '--detach[detach from console]' \
    '--new-instance[do not join a running instance]' \
    '*:files:_files -g "*.(tmx|tsx|json|tmj|tsj|tiled-project|tiled-session|world)"' \
    && return 0
