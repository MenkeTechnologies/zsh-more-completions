#compdef xdg-su
# Documentation: https://www.freedesktop.org/wiki/Software/xdg-utils/
# Source: freedesktop xdg-utils scripts/xdg-su.in — wrapper around kdesu/gksu (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show usage]' \
    '--manual[show manual page]' \
    '--version[show version]' \
    '-u+[target user]:user:_users' \
    '-c+[command string]:command:_command_names' \
    && ret=0

return ret
