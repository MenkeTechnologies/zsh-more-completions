#compdef xbanish
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-a[hide cursor on any key, not just modifier keys]' \
  '-b[hide on all buttons]' \
  '-d[X display]:display' \
  '-i[idle timeout in seconds]:timeout (seconds)' \
  '-s[hide cursor immediately at startup]' \
  '-t[typing timeout in milliseconds]:timeout (ms)' && ret=0
return ret
