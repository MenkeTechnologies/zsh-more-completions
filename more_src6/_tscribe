'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::url -- URL to transcribe (default mode, no subcommand needed):_default' \
":: :_tscribe_commands" \
"*::: :->tscribe" \
&& ret=0
    case $state in
    (tscribe)
        words=($line[2] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tscribe-command-$line[2]:"
        case $line[2] in
            (cache)
