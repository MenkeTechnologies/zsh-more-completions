# WHAT IT IS
#   tx2uml is "an Ethereum transaction visualizer that generates
#   UML sequence diagrams from an Ethereum archive node and an
#   Etherscan-like block explorer".  Given one or more transaction
#   hashes, it walks the call tree via `debug_traceTransaction`
#   (geth/Erigon/Anvil), pairs each call with its Etherscan-
#   verified ABI, and renders an annotated PlantUML sequence
#   diagram showing every CALL/STATICCALL/DELEGATECALL/CREATE,
#   ether and token transfers, gas, event logs, and the resulting
#   balance deltas.  The CLI ships three subcommands:  `call`
#   (default) draws contract calls, `value` draws token / ether
#   transfers, and `copy` replays the transaction on a different
#   chain (relayed or impersonated for development nodes like
#   Hardhat / Anvil).
#
# CLI ARGUMENT GRAMMAR  (verbatim from lib/tx2uml.js compiled
#                       from src/ts/tx2uml.ts — Commander 12
#                       `new Command()` chain)
#   tx2uml [GLOBAL OPTIONS] [<SUBCOMMAND>] <txHash(s)> [args]
#
#   Global options (apply to every subcommand):
#     -f, --outputFormat <FMT>      Output format
#                                   (svg|png|pdf|puml|md)
#                                   [default: svg]
#     -o, --outputFileName <NAME>   Output filename (auto-derived
#                                   from tx hashes by default;
#                                   `v` prefix for value
#                                   diagrams)
#     -u, --url <URL>               Archive node URL with trace
#                                   support
#                                   [env: ARCHIVE_NODE_URL —
#                                   default: http://localhost:8545]
#     -c, --chain <CHAIN>           Block explorer chain name or
#                                   chain id (`none` skips source
#                                   code; `custom` uses
#                                   --explorerUrl; named
#                                   shortcuts map to chain ids)
#                                   [env: ETH_NETWORK —
#                                   default: ethereum]
#     -e, --explorerUrl <URL>       Required when --chain is
#                                   `custom`
#                                   [env: EXPLORER_URL]
#     -k, --etherscanKey <KEY>      Etherscan-like API key
#                                   [env: EXPLORER_API_KEY —
#                                   REQUIRED]
#     -cf, --configFile <NAME>      Contract override config JSON
#                                   [default: tx.config.json]
#     -af, --abiFile <NAME>         Contract ABI override JSON
#                                   [default: tx.abi.json]
#     -m, --memory <GB>             Max Java memory for PlantUML
#                                   (large png needs up to 12g;
#                                   svg is preferred for large
#                                   txs)
#     --title <TITLE>               Diagram title  [default: tx
#                                                    hash]
#     -hf, --hideFooter             Hide contract lifeline footer
#                                   boxes
#     -hc, --hideCaption            Hide network/block/timestamp
#                                   caption
#     -v, --verbose                 Debug statements
#
#   Subcommands:
#     call <txHash(s)>              [DEFAULT] UML sequence diagram
#                                   of contract calls
#       -n, --nodeType <TYPE>        Archive node trace API
#                                    (geth|erigon|tgeth|nethermind|
#                                     openeth|anvil)
#                                    [env: ARCHIVE_NODE_TYPE —
#                                    default: geth]
#       -a, --noAddresses <CSV>     Hide calls to specific
#                                   addresses
#       -d, --depth <N>             Limit call depth
#       -e, --noEther               Hide ether values
#       -g, --noGas                 Hide gas usage
#       -l, --noLogDetails          Hide log/event details
#       -p, --noParams              Hide function param names and
#                                   values
#       -pv, --noParamValues        Hide values only (keep names)
#       -t, --noTxDetails           Hide tx-level details
#       -x, --noDelegates           Hide delegate calls / library
#                                   calls
#       --mapSource <MAPPING>       Map unverified addresses to
#                                   verified ones
#                                   (left:right, comma-separated)
#
#     value <txHash(s)>             UML sequence diagram of ether
#                                   and token value transfers
#                                   (requires debug_traceTransaction
#                                   with custom EVM tracers — geth,
#                                   Erigon, or Anvil)
#       -e, --onlyToken             Token events only (no ETH
#                                   tracing)
#       --mapSource <MAPPING>       Same as `call`
#       -hb, --hideBalances         Hide balance-change footer
#
#     copy <txHash(s)>              Replay txs on another chain
#                                   (relayed or impersonated)
#       -du, --destUrl <URL>        Destination node URL
#                                   [env: DEST_NODE_URL — default:
#                                   http://localhost:8545]
#       -i, --impersonate <ADDR>    Account to impersonate (dev
#                                   nodes only)
#
#   Standard commander auto-flags:
#     -h, --help                    Show help
#     -V, --version                 Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `ethers ^5.8.0` declared in package.json
#   — `ethers` is THE canonical Node.js Ethereum SDK maintained
#   by Richard Moore (ricmoo/ethers.js, 8K+ stars, ~26M npm
#   downloads/month).  ethers.js exposes the `ethers.Provider`
#   (JsonRpcProvider, WebSocketProvider, FallbackProvider,
#   StaticJsonRpcProvider, AnkrProvider, EtherscanProvider,
#   InfuraProvider, AlchemyProvider), the `ethers.Wallet`
#   primitive, the `ethers.Contract` typed contract interface
#   built from an ABI JSON, `ethers.utils` (formatEther,
#   parseEther, keccak256, defaultAbiCoder, hexlify,
#   getAddress, Interface, FunctionFragment, EventFragment),
#   `ethers.BigNumber`, EIP-1193 EIP-712 signed-typed-data
#   support, ENS resolution, the `ethers.constants` set
#   (AddressZero, HashZero, MaxUint256, Two, One), and the
#   complete TX-encoding pipeline (`serializeTransaction`,
#   `parseTransaction`, `RLP.encode/decode`).  tx2uml's
#   `src/ts/callDiagram.ts` and `src/ts/valueDiagram.ts`
#   construct `ethers.providers.JsonRpcProvider`, call
#   `provider.send("debug_traceTransaction", ...)` for the
#   trace data, and use `ethers.utils.Interface` to decode each
#   call's selector against the ABI fetched from Etherscan.
#   Verified via:
#     gh api repos/naddison36/tx2uml/contents/package.json
#       → "ethers": "^5.8.0"
#       → "bin": {"tx2uml": "lib/tx2uml.js"}
#     gh api repos/naddison36/tx2uml/contents/lib/tx2uml.js
#       → const program = new Command();
#       → program.command("call", { isDefault: true })
#       → program.command("value")
#       → program.command("copy")
#       → global options:  --outputFormat, --outputFileName,
#         --url, --chain, --explorerUrl, --etherscanKey
#         (mandatory), --configFile, --abiFile, --memory,
#         --title, --hideFooter, --hideCaption, --verbose
#   This entry is the TS-Node=142 leader bump that CLOSES Axis
#   87 (Ethereum / alloy-rs Library) at 1/1/1 three-language
#   symmetry — pairing Rust=alloy-rs via pawurb/mevlog-rs (R937
#   _mevlog), Go=ethereum/go-ethereum via Tenderly/tenderly-cli
#   (R938 _tenderly), and TS-Node=ethers.js via naddison36/
#   tx2uml (this entry).  Triple-142 landmark on commit.  Axis
#   87 = 80th axis closed.
#
#   No completion for `tx2uml` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_tx2uml() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-f --outputFormat)'{-f,--outputFormat}'=[output format]:format:(svg png pdf puml md)' \
        '(-o --outputFileName)'{-o,--outputFileName}'=[output filename]:file:_files' \
        '(-u --url)'{-u,--url}'=[archive node URL with trace support]:url:' \
        '(-c --chain)'{-c,--chain}'=[chain name or id]:chain:(ethereum sepolia goerli holesky base optimism arbitrum polygon avalanche bsc fantom gnosis celo none custom)' \
        '(-e --explorerUrl)'{-e,--explorerUrl}'=[block explorer API URL (required with --chain custom)]:url:' \
        '(-k --etherscanKey)'{-k,--etherscanKey}'=[Etherscan API key (REQUIRED)]:key:' \
        '(-cf --configFile)'{-cf,--configFile}'=[contract override config JSON]:file:_files -g "*.json"' \
        '(-af --abiFile)'{-af,--abiFile}'=[ABI override JSON]:file:_files -g "*.json"' \
        '(-m --memory)'{-m,--memory}'=[max Java memory for PlantUML]:gb:' \
        '--title=[diagram title]:title:' \
        '(-hf --hideFooter)'{-hf,--hideFooter}'[hide lifeline footer boxes]' \
        '(-hc --hideCaption)'{-hc,--hideCaption}'[hide network/block/timestamp caption]' \
        '(-v --verbose)'{-v,--verbose}'[debug statements]' \
        '1: :_tx2uml_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                call)
                    _arguments \
                        '(-n --nodeType)'{-n,--nodeType}'=[archive node trace API]:type:(geth erigon tgeth nethermind openeth anvil)' \
                        '(-a --noAddresses)'{-a,--noAddresses}'=[hide calls to specific addresses (CSV)]:csv:' \
                        '(-d --depth)'{-d,--depth}'=[limit call depth]:n:' \
                        '(-e --noEther)'{-e,--noEther}'[hide ether values]' \
                        '(-g --noGas)'{-g,--noGas}'[hide gas usage]' \
                        '(-l --noLogDetails)'{-l,--noLogDetails}'[hide log/event details]' \
                        '(-p --noParams)'{-p,--noParams}'[hide function parameter names and values]' \
                        '(-pv --noParamValues)'{-pv,--noParamValues}'[hide values only (keep names)]' \
                        '(-t --noTxDetails)'{-t,--noTxDetails}'[hide tx-level details]' \
                        '(-x --noDelegates)'{-x,--noDelegates}'[hide delegate / library calls]' \
                        '--mapSource=[map unverified addresses to verified]:mapping:' \
                        ':tx hash(es):' && ret=0 ;;
                value)
                    _arguments \
                        '(-e --onlyToken)'{-e,--onlyToken}'[token events only (no ETH tracing)]' \
                        '--mapSource=[map unverified addresses]:mapping:' \
                        '(-hb --hideBalances)'{-hb,--hideBalances}'[hide balance-change footer]' \
                        ':tx hash(es):' && ret=0 ;;
                copy)
                    _arguments \
                        '(-du --destUrl)'{-du,--destUrl}'=[destination node URL]:url:' \
                        '(-i --impersonate)'{-i,--impersonate}'=[account to impersonate (dev nodes only)]:addr:' \
                        ':tx hash(es):' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_tx2uml_commands] )) ||
_tx2uml_commands() {
    local -a commands
    commands=(
        'call:UML sequence diagram of contract calls (default)'
        'value:UML sequence diagram of ether/token value transfers'
        'copy:replay txs on another chain (relayed or impersonated)'
    )
    _describe -t commands 'tx2uml command' commands
}

_tx2uml "$@"
