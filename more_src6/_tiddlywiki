#compdef tiddlywiki
# Documentation: https://tiddlywiki.com/static/Commands.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  '--build:compile and generate static output'
  '--clearpassword:remove password protection'
  '--commands:display available commands'
  '--deletetiddlers:remove specified tiddlers'
  '--editions:manage wiki editions'
  '--fetch:retrieve content from external sources'
  '--help:display help information'
  '--import:bring in tiddlers from files'
  '--init:create a new wiki'
  '--listen:start a web server'
  '--load:read tiddlers into memory'
  '--makelibrary:create a reusable plugin library'
  '--output:specify output destination'
  '--password:set access protection'
  '--render:convert tiddlers to output format'
  '--save:write tiddlers to storage'
  '--savewikifolder:export entire wiki structure'
  '--setfield:modify tiddler field values'
  '--unpackplugin:extract plugin contents'
  '--verbose:enable detailed logging'
  '--version:show software version'
)

_arguments -C \
  '1:wiki folder:_files -/' \
  '*::cmd-and-args:->args' && ret=0

case $state in
  (args) _describe -t cmds 'tiddlywiki command' commands && ret=0 ;;
esac

return ret
