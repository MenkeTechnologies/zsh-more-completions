#compdef themeify
# Documentation: https://github.com/J3rry320/themeify
# Reference accessed: 2026-05-23
# Verified: upstream README apply command flags.

# Zsh completion for themeify - apply themes to React/Next.js projects

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'themeify command' 'apply[apply theme to project]' && ret=0
    ;;
  args)
    case $line[1] in
      (apply)
        _arguments \
          '--path[project path]:directory:_directories' \
          '--framework[UI framework]:fw:(MUI Tailwind ShadCN Bootstrap)' \
          '--theme[theme name]:theme:' \
          '--palette[palette name]:palette:' \
          '--font[font name]:font:' && ret=0
        ;;
    esac
    ;;
esac

return ret
