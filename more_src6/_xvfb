#compdef Xvfb xvfb
# Documentation: man Xvfb (X.Org)
# Source: virtual framebuffer X server (no real display).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-screen+[screen N WxHxD]:screen num:' \
    '-pixdepths+[supported pixel depths]:list:' \
    '-fbdir+[memory framebuffer directory]:dir:_files -/' \
    '-shmem[use shared-memory framebuffer]' \
    '-linebias+[line drawing bias]:n:' \
    '-blackpixel+[black pixel value]:pixel:' \
    '-whitepixel+[white pixel value]:pixel:' \
    '-render+[Render extension support level]:level:(default mono gray color)' \
    && ret=0

return ret
