#compdef woke
# Documentation: https://docs.getwoke.tech/usage/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# woke: detect non-inclusive language in source code.
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
  '--debug[enable debug logging]' \
  '--disable-default-rules[disable the default ruleset]' \
  '--exit-1-on-failure[return exit code 1 when findings are detected]' \
  '--no-ignore[do not respect .gitignore/.wokeignore]' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(text simple github-actions json sonarqube checkstyle)' \
  '--stdin[read input from standard input]' \
  '*:file or directory:_files' && ret=0

return ret
