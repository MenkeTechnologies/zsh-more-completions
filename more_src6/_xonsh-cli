_xonsh-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[command]:str:' \
        '*-c+[command]:str:' \
        '-i[interactive]' \
        '--interactive[interactive]' \
        '-l[login shell]' \
        '--login[login shell]' \
        '--shell-type=+[t]:t:(prompt_toolkit readline dumb random best none)' \
        '-D+[name=value]:str:' \
        '*-D+[name=value]:str:' \
        '--no-rc[no rc]' \
        '--no-env[no env]' \
        '--rc=+[file]:file:_files -g "xonshrc *.xsh"' \
        '*--rc=+[file]:file:_files -g "xonshrc *.xsh"' \
        '--no-script-cache[no script cache]' \
        '--cache-everything[cache everything]' \
        '--timings[show timings]' \
        '--no-colors[no colors]' \
        '--print-config[print config]' \
        '--config-path=+[file]:file:_files' \
        '*:script:_files -g "*.xsh *.py"'
}

_xonsh-cli "$@"
