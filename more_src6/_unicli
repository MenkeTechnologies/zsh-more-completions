#compdef unicli
# Documentation: source-direct extraction from upstream
# apognu/unicli lib/unicli.ex + lib/cli.ex
# (**Elixir language**; uses **`Optimus`** —
# funbox/optimus, the de-facto modern Elixir CLI
# library.  Corpus's **first documented Elixir CLI
# library** — pivots from R305 _hibp_search (C++
# CLI11) into the **Elixir language tooling
# cluster**):
#   lib/unicli.ex line ~90
#     (`parser = Optimus.new!(CLI.options())
#                |> Optimus.parse!(args)` — Optimus's
#     PRIMARY ENTRY POINT pair.  `Optimus.new!`
#     COMPILES a keyword-list spec into an Optimus
#     parser struct; `Optimus.parse!` runs it against
#     argv.  Both `!` variants raise on error (Elixir
#     convention: `name!` raises, `name` returns
#     {:ok, _} | {:error, _}).  Elixir pipe `|>`
#     chain — sister to R303 Gleam Glint's `|>`
#     builder but flatter (single-shot rather than
#     a long fluent chain))
#   lib/unicli.ex lines ~100-120
#     (subcommand DISPATCH via Elixir pattern
#     match: `case parser do { [:devices |
#     subcommands], %Optimus.ParseResult{} = options }
#     -> UniCLI.Devices.run(settings, subcommands,
#     options) ...`.  Optimus returns a tuple
#     `{[atom_path], %Optimus.ParseResult{}}` —
#     `atom_path` is a LIST of atoms representing
#     the SUBCOMMAND PATH the user took (e.g.
#     `unicli devices ports list` → `[:devices,
#     :ports, :list]`).  Distinct from R302 Clojure
#     babashka.cli (subcommand path as VECTOR of
#     STRINGS), R303 Gleam Glint (LIST of STRINGS).
#     Optimus uses ELIXIR ATOMS — interned-symbol
#     identifiers compiled into the VM's atom
#     table; cheaper than strings for case-match
#     dispatch.  Corpus's **first documented
#     atom-list-subcommand-path CLI pattern**)
#   lib/cli.ex line 1
#     (`defmodule CLI do` — Elixir MODULE.  Elixir
#     modules are FIRST-CLASS-IN-CODE — they have
#     names, public funs, doc strings)
#   lib/cli.ex lines 2-9
#     (`@site` MODULE ATTRIBUTE — Elixir SHARED-
#     OPTION REUSE pattern.  `@site` is a keyword
#     list bound at COMPILE TIME via `@attr value`
#     syntax.  Referenced via `options: @site` at
#     many subcommand spec sites — Elixir EXPANDS
#     the attribute LEXICALLY at compile time, so
#     this is a true SPEC-LEVEL DRY mechanism.
#     Distinct from R302 Clojure babashka.cli's
#     `(add-global-aliases COMMANDS)` (runtime map
#     over the data spec), R303 Gleam Glint's
#     `glint.add(at:, do:)` (no spec-level reuse —
#     each subcommand defines its own flags).
#     Corpus's **first documented compile-time-
#     attribute-spec-reuse CLI pattern**)
#   lib/cli.ex line 18
#     (`subcommands: [ sites: [...], devices: [...]
#     ...]` — the SUBCOMMAND TREE is an Elixir
#     KEYWORD LIST (the syntactic form `[atom_key:
#     value, ...]` desugars to `[{:atom_key,
#     value}, ...]`).  Keys are ATOMS, values are
#     keyword lists themselves.  Arbitrary nesting
#     supported.  Distinct from R301 Nim cligen
#     (proc-signature spec — no subcommand support
#     without dispatchMulti), R302 Clojure
#     babashka.cli (flat vector with path-matching),
#     R303 Gleam Glint (flat list with path-
#     matching), R304 Ada GNAT.Command_Line (no
#     subcommands; one-level only).  Optimus
#     supports TRUE TREE NESTING — `subcommands:
#     [...]` at any depth)
#   lib/cli.ex line 14
#     (`allow_double_dash: true` — Optimus
#     supports the POSIX `--` SENTINEL convention:
#     argv tokens after `--` are treated as
#     POSITIONALS regardless of leading dashes.
#     Distinct from R301 Nim cligen (auto-detects
#     positional via seq[T] at end of proc params),
#     R272 C POSIX getopt (handled by callee — `--`
#     halts option parsing), R302 Clojure babashka.
#     cli (handled by `:args->opts` mapping
#     positionals).  Optimus's approach: EXPLICIT
#     OPT-IN via the spec flag; default false
#     means stricter parsing)
#   lib/cli.ex line 13
#     (`allow_unknown_flags: false` — Optimus
#     REJECTS unknown flags by default; this is the
#     explicit declaration.  Distinct from R269
#     Crystal stdlib OptionParser (rejects unknown
#     flags by default with no opt-out), R302
#     Clojure babashka.cli (silently accepts and
#     stores unknown as map entries — opposite
#     default).  Corpus's **first documented
#     opt-in-strict-mode-vs-permissive CLI pattern**)
#   lib/cli.ex line 8
#     (`parser: :string` — Optimus TYPE-PARSER
#     ATOMS.  Built-in: `:string`, `:integer`,
#     `:float`.  Plus user-defined: a FUNCTION
#     `fn input -> {:ok, value} | {:error, message}
#     end` — see locate's state arg at lines 88-92
#     `parser: fn "on" -> {:ok, true}; "off" ->
#     {:ok, false}; _ -> {:error, "only 'on' and
#     'off' are accepted"} end`.  Elixir's pattern-
#     match function clauses encode an enum-like
#     validator inline.  Distinct from R305 C++
#     CLI11 (`->check(CLI::IsMember(set))`), R304
#     Ada GNAT.Command_Line (caller validates
#     post-Getopt), R303 Gleam Glint (typed
#     `int_flag` / `string_flag` only).  Corpus's
#     **first documented pattern-match-as-validator
#     CLI parser pattern**)
#   lib/cli.ex line 4
#     (`short: "-s"` + `long: "--site"` — Optimus
#     short/long flag declaration.  Spec is a
#     keyword list with EXPLICIT `short:`/`long:`
#     entries.  Distinct from R304 Ada GNAT.Command_
#     Line `"-X:"`/`"--long="` postfix-marker
#     literals (combined into one string), R301
#     Nim cligen (auto-derived from first letter),
#     R302 Clojure babashka.cli (no explicit short
#     — uses `:aliases {:T :tool}`))
# Reference accessed: 2026-05-31 via gh api.
#
# unicli subcommand tree (decoded source-direct
# from lib/cli.ex):
#   sites                      [no args, no opts]
#   devices                    (group)
#     list                     [-s SITE]
#     adopt <DEVICE_MAC>       [-s SITE]
#     restart <DEVICE_ID>      [-s SITE]
#     provision <DEVICE_ID>    [-s SITE]
#     locate <DEVICE_ID> <STATE: on|off>
#                              [-s SITE]
#     ports                    (group)
#       list <DEVICE_ID>       [-s SITE]
#       disable <DEVICE_ID> <PORT_ID>  [-s SITE]
#       enable <DEVICE_ID> <PORT_ID>   [-s SITE]
#   networks                   (group)
#     list                     [-s SITE]
#     wlan                     (group)
#       list                   [-s SITE]
#       enable <NETWORK_ID>    [-s SITE]
#       disable <NETWORK_ID>   [-s SITE]
#   clients                    (group)
#     list                     [-s SITE]
#     block <CLIENT_MAC>       [-s SITE]
#     unblock <CLIENT_MAC>     [-s SITE]
#     kick <CLIENT_MAC>        [-s SITE]
#     guests                   (group)
#       authorize <CLIENT_MAC> [-s SITE]
#       unauthorize <CLIENT_MAC> [-s SITE]
#   vouchers                   (group)
#     list                     [-s SITE]
#     create [-n N] [-e DUR] [-t USES] [-c COMMENT]
#            [-q MB] [-d KBPS_DOWN] [-u KBPS_UP]
#            [-s SITE]
#     revoke <VOUCHER_ID>      [-s SITE]
#   radius                     (group)
#     users                    (group)
#       list                   [no opts]
#       delete <USER_ID>       [no opts]
#       create <USERNAME> <PASSWORD>
#              [-v VLAN] [-t TUNNEL] [-m MEDIUM]
#              [-s SITE]
#   events                     [-s SITE]
#   alerts                     [-s SITE]
#
# unicli is a UniFi controller CLI — queries and
# controls Ubiquiti UniFi devices/networks/clients/
# vouchers/alerts from the command line, talks to
# the UniFi controller's HTTP API.  Authored by
# apognu (15 GH stars).  Sister tools: ubnt-discover
# (UniFi device discovery, not in corpus), unifi-
# protect-viewer (UniFi camera viewer).
#
# Critical extraction note: unicli uses **Elixir
# `Optimus` library** at unicli.ex:~90 — corpus's
# **first documented Elixir CLI library**.
# funbox/optimus is the de-facto modern Elixir CLI
# library — supports nested subcommand trees,
# typed args, custom parser closures, and global +
# per-command options.  Distinct from Elixir's
# stdlib `OptionParser` (low-level token loop,
# similar to R287 Nim parseopt — used by `mix`
# tasks but no subcommand support), `cli` (less
# popular), and Erlang's `getopt:parse` (R292
# emqtt — same BEAM VM but Erlang flavor).  Optimus
# adds the SUBCOMMAND TREE that stdlib OptionParser
# lacks.  Extends cross-language CLI taxonomy to
# FORTY-FIVE library variants: Rust (6), Go (4),
# Python (3), Crystal 1 OptionParser (R269),
# Haskell (R270), OCaml (R271), C (R272), Java (R276),
# Kotlin (R277), Scala (R278), Dart (R279),
# Ruby (R280), Perl (R281), PHP (R282), Swift (R283),
# F# (R284), Lua (R285), C# (R286), Nim 1 parseopt
# (R287), Zig (R288), D (R289), Racket (R290),
# Common Lisp 1 (R291), Erlang (R292), Tcl (R293),
# Pharo Smalltalk (R294), Common Lisp 2 clingon (R295),
# Julia (R296), SWI-Prolog optparse (R297), Pony
# stdlib cli (R298), Crystal 2 Admiral (R299), V
# stdlib `flag` (R300), Nim 2 cligen (R301),
# Clojure babashka.cli (R302), Gleam Glint (R303),
# Ada GNAT.Command_Line (R304), C++ CLI11 (R305),
# **Elixir Optimus** (R306 — NEW).  **MAJOR PATTERN
# MILESTONE**: 45 cross-language CLI library
# variants documented.  Elixir joins Erlang (R292)
# on the BEAM VM — corpus now documents CLI
# libraries on BOTH BEAM languages.
#
# Critical extraction note: unicli uses **Optimus
# `[atom_path]` subcommand dispatch** at unicli.ex
# ~100-120 — Optimus returns a tuple `{[atom,
# atom, ...], %Optimus.ParseResult{}}` where the
# atom-list is the SUBCOMMAND PATH the user took.
# Elixir CASE-MATCHES on the atom list with the
# CONS-CELL DESTRUCTURING `[:devices | subcommands]`
# — head is the first atom, tail is the rest.
# Distinct from R302 Clojure babashka.cli (path
# as VECTOR of STRINGS, prefix-matched against
# command list), R303 Gleam Glint (path as LIST of
# STRINGS, longest-prefix-matched).  Optimus uses
# ELIXIR ATOMS — interned-symbol identifiers
# compiled into the BEAM VM atom table; cheaper
# than strings for case-match dispatch (atoms are
# integer-compared, strings are byte-compared).
# Corpus's **first documented atom-list-subcommand-
# path CLI pattern**.
#
# Critical extraction note: unicli uses **Elixir
# module-attribute spec-reuse** at cli.ex:2-9 —
# `@site [site: [short: "-s", long: "--site",
# help: "which site to talk to", default: "default",
# parser: :string]]` defines a SHARED OPTION
# SPECIFICATION at COMPILE TIME via the `@`
# attribute syntax.  Referenced as `options: @site`
# at 24 subcommand spec sites in cli.ex.  Elixir
# expands the attribute LEXICALLY at compile time,
# so `@site` is INLINED at each reference site —
# this is a true SPEC-LEVEL DRY mechanism with
# ZERO RUNTIME COST.  Distinct from R302 Clojure
# babashka.cli's `(add-global-aliases COMMANDS)`
# (RUNTIME map over the data spec), R303 Gleam
# Glint's `glint.add(at:, do:)` (no spec-level
# reuse — each subcommand defines its own flags),
# R304 Ada GNAT.Command_Line (no equivalent).
# Corpus's **first documented compile-time-
# attribute-spec-reuse CLI pattern**.
#
# Critical extraction note: unicli uses **Optimus
# pattern-match function as inline validator** at
# cli.ex:88-92 (locate's state arg) — `parser: fn
# "on" -> {:ok, true}; "off" -> {:ok, false}; _ ->
# {:error, "only 'on' and 'off' are accepted"} end`.
# Elixir's MULTI-CLAUSE ANONYMOUS FUNCTIONS pattern-
# match on the input value and return either
# `{:ok, parsed_value}` or `{:error, message}`.
# Distinct from R305 C++ CLI11 `->check(CLI::
# IsMember({"on","off"}))` (validator object), R304
# Ada GNAT.Command_Line (caller validates post-
# Getopt), R303 Gleam Glint (typed `int_flag` /
# `string_flag` only).  Optimus's approach: PATTERN-
# MATCH-AS-VALIDATOR — sister to R295 CL clingon's
# `:option-type :choice :choices '("on" "off")` but
# arbitrarily more powerful (the parser can also
# TRANSFORM the value, here converting "on"/"off"
# to `true`/`false`).  Corpus's **first documented
# pattern-match-as-validator CLI parser pattern**.
#
# Critical extraction note: unicli uses **Optimus
# `parser: :atom` typed-parser specification** at
# cli.ex multiple sites — `parser: :string`,
# `parser: :integer`, `parser: :float`.  Each
# parser atom triggers the matching built-in
# coercion function.  Distinct from R301 Nim cligen
# (auto-derives from proc param TYPE — `int`/`bool`/
# `seq[T]`), R304 Ada GNAT.Command_Line (no parser
# config — the variable's TYPE determines parsing
# via aliased's static type), R305 C++ CLI11
# (template-deduces from reference target type).
# Optimus uses EXPLICIT atom specs because Elixir
# is DYNAMICALLY TYPED — there's no compile-time
# target-type to deduce from.  Corpus's **first
# documented atom-key-typed-parser CLI pattern**.
#
# Critical extraction note: unicli uses **Optimus
# `Optimus.new!` / `Optimus.parse!` raising-pair
# convention** at unicli.ex:~90 — Elixir's
# CONVENTION is to provide PAIRS of functions:
# `name!` raises an exception on error, `name`
# returns `{:ok, _}` | `{:error, _}` tagged tuple.
# `Optimus.new!(spec) |> Optimus.parse!(args)` is
# the IMPERATIVE error-via-exception variant.
# Distinct from R304 Ada GNAT.Command_Line (Getopt
# raises Exit_From_Command_Line on help), R305 C++
# CLI11_PARSE macro (try/catch wrapper around
# parse), R303 Gleam Glint (glint.execute returns
# Result discriminated union).  Optimus integrates
# with Elixir's BANG-CONVENTION — if you want
# error tuples back, you'd write `with {:ok, parser}
# <- Optimus.new(spec), do: Optimus.parse(parser,
# args)` instead.  Corpus's **first documented
# raising-pair-convention CLI pattern**.
#
# Hunt-skip notes: skipped `_iex` / `_livebook` /
# `_elixir` / `_mix` / `_hex` (Elixir stdlib tools
# all in corpus — and they use stdlib OptionParser
# not Optimus), `_unison` (DUP with stock zsh),
# `_lake` / `_elan` / `_lean4` (Lean ecosystem in
# corpus), `_alr` (Alire Ada in corpus).  Probed
# `sysread/fnord` (AI code archaeologist, 41 stars
# — but uses ESCRIPT + Optimus with auto-generated
# spec from Burrito; harder to extract source-
# direct), `proxyconf/proxyconf` (Envoy proxy
# control plane, 15 stars — uses Optimus but spec
# is spread across many files), `pcharbon70/aiex`
# (Elixir AI agent, 5 stars — newer/less stable),
# `croesnick/taskbeam` (0 stars — too new),
# `matthewsinclair/arca_cli` (0 stars — CLI
# framework, not a CLI tool), `savonarola/optimus`
# (THE LIBRARY ITSELF, 21 stars — not a CLI),
# `QuinnWilton/beam_spy` (1 star — too small).
# Chose unicli: 15 stars, FULL THREE-LEVEL NESTED
# subcommand tree (35 commands total — devices →
# ports → enable, networks → wlan → list, clients
# → guests → authorize, radius → users → create),
# `@site` compile-time module-attribute spec-reuse
# DEMONSTRATED at 24 sites in cli.ex, custom
# pattern-match parser closure for `state` arg
# (`"on"`→true/`"off"`→false), 7-flag `vouchers
# create` subcommand exercising integer parser +
# custom Timex.Duration parser closure.  Single-
# file cli.ex (442 lines) makes source-direct
# extraction clean.  Stable v0.0.1 release.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# 35 commands in 3-level tree decoded source-direct
# from lib/cli.ex's `subcommands:` keyword list.
local -a unicli_top=(
  'sites:list all sites configured on the controller'
  'devices:control UniFi devices'
  'networks:control UniFi networks'
  'clients:control connected clients'
  'vouchers:manage HotSpot vouchers'
  'radius:manage RADIUS users for 802.1X'
  'events:list events'
  'alerts:list alerts'
)
local -a unicli_devices=(
  'list:list all adopted UniFi devices'
  'adopt:adopt a new device'
  'restart:restart a device'
  'provision:force provisionning of a device'
  'locate:enable or disable blinking of device LEDs'
  'ports:control device ports'
)
local -a unicli_devices_ports=(
  'list:list all ports on a device'
  'disable:disable a port'
  'enable:enable a port'
)
local -a unicli_networks=(
  'wlan:control UniFi wireless networks'
  'list:list all UniFi virtual networks'
)
local -a unicli_networks_wlan=(
  'list:list all configured wireless networks'
  'enable:enable a specific wireless network'
  'disable:disable a specific wireless network'
)
local -a unicli_clients=(
  'list:list all connected users'
  'block:block a client from the network'
  'unblock:unblock a client from the network'
  'kick:kick a guest from their network'
  'guests:manage guest clients'
)
local -a unicli_clients_guests=(
  'authorize:authorize a guest'
  'unauthorize:unauthorize a guest'
)
local -a unicli_vouchers=(
  'list:list all active vouchers'
  'create:create a voucher'
  'revoke:revoke a voucher'
)
local -a unicli_radius=(
  'users:manage RADIUS users for 802.1X'
)
local -a unicli_radius_users=(
  'list:list all RADIUS users'
  'delete:delete a RADIUS user'
  'create:create a new RADIUS user'
)

# Global --site option appears at almost every leaf
# command (24 subcommand sites in cli.ex via `@site`)
local -a site_opt=(
  '(-s --site)'{-s+,--site=}'[which site to talk to (default: default)]:site name:'
)

_arguments -C \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-v,--version}'[display version]' \
  '1: :->topcmd' \
  '*:: :->args' && ret=0

case $state in
  topcmd)
    _describe -t commands 'unicli subcommand' unicli_top && ret=0
    ;;
  args)
    case $words[1] in
      sites)
        _arguments $site_opt && ret=0
        ;;
      events|alerts)
        _arguments $site_opt && ret=0
        ;;
      devices)
        if (( CURRENT == 2 )); then
          _describe -t commands 'devices subcommand' unicli_devices && ret=0
        else
          shift words; (( CURRENT-- ))
          case $words[1] in
            list) _arguments $site_opt && ret=0 ;;
            adopt) _arguments $site_opt '1:DEVICE_MAC:' && ret=0 ;;
            restart|provision) _arguments $site_opt '1:DEVICE_ID:' && ret=0 ;;
            locate) _arguments $site_opt '1:DEVICE_ID:' '2:STATE:(on off)' && ret=0 ;;
            ports)
              if (( CURRENT == 2 )); then
                _describe -t commands 'ports subcommand' unicli_devices_ports && ret=0
              else
                shift words; (( CURRENT-- ))
                case $words[1] in
                  list) _arguments $site_opt '1:DEVICE_ID:' && ret=0 ;;
                  disable|enable) _arguments $site_opt '1:DEVICE_ID:' '2:PORT_ID:' && ret=0 ;;
                esac
              fi
              ;;
          esac
        fi
        ;;
      networks)
        if (( CURRENT == 2 )); then
          _describe -t commands 'networks subcommand' unicli_networks && ret=0
        else
          shift words; (( CURRENT-- ))
          case $words[1] in
            list) _arguments $site_opt && ret=0 ;;
            wlan)
              if (( CURRENT == 2 )); then
                _describe -t commands 'wlan subcommand' unicli_networks_wlan && ret=0
              else
                shift words; (( CURRENT-- ))
                case $words[1] in
                  list) _arguments $site_opt && ret=0 ;;
                  enable|disable) _arguments $site_opt '1:NETWORK_ID:' && ret=0 ;;
                esac
              fi
              ;;
          esac
        fi
        ;;
      clients)
        if (( CURRENT == 2 )); then
          _describe -t commands 'clients subcommand' unicli_clients && ret=0
        else
          shift words; (( CURRENT-- ))
          case $words[1] in
            list) _arguments $site_opt && ret=0 ;;
            block|unblock|kick) _arguments $site_opt '1:CLIENT_MAC:' && ret=0 ;;
            guests)
              if (( CURRENT == 2 )); then
                _describe -t commands 'guests subcommand' unicli_clients_guests && ret=0
              else
                shift words; (( CURRENT-- ))
                case $words[1] in
                  authorize|unauthorize) _arguments $site_opt '1:CLIENT_MAC:' && ret=0 ;;
                esac
              fi
              ;;
          esac
        fi
        ;;
      vouchers)
        if (( CURRENT == 2 )); then
          _describe -t commands 'vouchers subcommand' unicli_vouchers && ret=0
        else
          shift words; (( CURRENT-- ))
          case $words[1] in
            list) _arguments $site_opt && ret=0 ;;
            create)
              # 7 flags from cli.ex:288-326 (vouchers create options)
              _arguments $site_opt \
                '-n+[how many vouchers to create (default: 1)]:count:' \
                '-e+[validity duration as ISO8601 (e.g. PT24H; default: 1440 min)]:duration:' \
                '-t+[number of times this voucher can be used (0=unlimited; default: 1)]:uses:' \
                '-c+[comment (default: "Created from UniCLI")]:comment:' \
                '-q+[usage quota in MB (default: 0)]:quota MB:' \
                '-d+[download bandwidth limit in Kbps (default: 0)]:Kbps:' \
                '-u+[upload bandwidth limit in Kbps (default: 0)]:Kbps:' && ret=0
              ;;
            revoke) _arguments $site_opt '1:VOUCHER_ID:' && ret=0 ;;
          esac
        fi
        ;;
      radius)
        if (( CURRENT == 2 )); then
          _describe -t commands 'radius subcommand' unicli_radius && ret=0
        else
          shift words; (( CURRENT-- ))
          case $words[1] in
            users)
              if (( CURRENT == 2 )); then
                _describe -t commands 'users subcommand' unicli_radius_users && ret=0
              else
                shift words; (( CURRENT-- ))
                case $words[1] in
                  list) _arguments '(-h --help)'{-h,--help}'[display help]' && ret=0 ;;
                  delete) _arguments '1:USER_ID:' && ret=0 ;;
                  create)
                    _arguments $site_opt \
                      '-v+[VLAN ID]:vlan:' \
                      '-t+[tunnel type ID]:tunnel_type:' \
                      '-m+[tunnel medium type ID]:medium_type:' \
                      '1:USERNAME:' \
                      '2:PASSWORD:' && ret=0
                    ;;
                esac
              fi
              ;;
          esac
        fi
        ;;
    esac
    ;;
esac

return ret
