#compdef wsmoused
# Documentation: man wsmoused(8)
# Source: netbsd/src usr.sbin/wsmoused — console mouse copy/paste daemon (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d+[wsmouse device (default /dev/wsmouse)]:device:_files' \
    '-f+[configuration file (default /etc/wsmoused.conf)]:config file:_files' \
    '-m+[modes to activate (whitespace-separated)]:modes:_default' \
    '-n[do not fork to background]' \
    && ret=0

return ret
