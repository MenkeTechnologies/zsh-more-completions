#compdef zcash-cli
# Documentation: https://github.com/zcash/zcash (src/bitcoin-cli.cpp SetupCliArgs - zcash forks bitcoin-cli)
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-?[show help]' \
  '(- *)-help[show help]' \
  '(- *)-version[print version and exit]' \
  '-conf=-[configuration file]:file:_files' \
  '-datadir=-[data directory (cannot use ~)]:dir:_directories' \
  '-stdin[read extra arguments from stdin, one per line]' \
  '-rpcconnect=-[node IP address to connect to]:ip:_hosts' \
  '-rpcport=-[JSON-RPC port (default 8232, testnet 18232)]:port:' \
  '-rpcwait[wait for RPC server startup]' \
  '-rpcuser=-[JSON-RPC username]:user:' \
  '-rpcpassword=-[JSON-RPC password]:password:' \
  '-rpcclienttimeout=-[HTTP request timeout in seconds (0 = no timeout)]:seconds:' \
  '-testnet[connect to testnet]' \
  '-regtest[connect to regtest]' \
  '*:: :->args' && ret=0

return ret
