#compdef updmap updmap-sys updmap-user
# Documentation: updmap --help (TeX Live 2026)
# Source: TeX updmap — manage pdftex.map / psfonts.map etc.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a verbs
verbs=(
    '--all:recreate all map files'
    '--listmaps:list all maps'
    '--listavailablemaps:list maps available in updmap.cfg'
    '--syncwithtrees:remove maps for unavailable .pfb / TTF files'
    '--setoption:set updmap option'
    '--showoption:show updmap option'
    '--enable:enable a map (KanjiMap/Map/MixedMap LINE)'
    '--disable:disable a map'
    '--showoptions:show all options'
    '--edit:edit updmap.cfg'
    '--listfonts:list fonts'
    '--listpermitted:list permitted fonts'
    '--quickdoc:quick HOWTO'
    '--help:show help'
    '--version:show version'
)

_arguments -C \
    '(-sys -user --sys --user)-sys[update system-wide config]' \
    '(-sys -user --sys --user)-user[update per-user config]' \
    '(-sys -user --sys --user)--sys[update system-wide config]' \
    '(-sys -user --sys --user)--user[update per-user config]' \
    '*--cnffile=[updmap configuration file]:file:_files' \
    '--dvipdfmxoutputdir=[dvipdfm(x) output dir]:dir:_files -/' \
    '--dvipsoutputdir=[dvips output dir]:dir:_files -/' \
    '--pdftexoutputdir=[pdftex output dir]:dir:_files -/' \
    '--outputdir=[output directory]:dir:_files -/' \
    '--copy[copy files (vs symlink)]' \
    '(-n --dry-run)'{-n,--dry-run}'[do not run actions]' \
    '--force[force update even if no .cfg change]' \
    '--nohash[do not update ls-R]' \
    '--nomkmap[do not generate font map files]' \
    '--quiet[no progress messages]' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd) _describe -t updmap-verbs 'updmap command' verbs && ret=0 ;;
    args) _files && ret=0 ;;
esac

return ret
