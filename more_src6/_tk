#compdef tk
# _tk — Grafana Labs Tanka tk CLI for managing Kubernetes resources declaratively with Jsonnet templating using the Tanka environment abstraction supporting multi-env apply diff export show eval lint fmt jpath (grafana team, Go); cobra
# upstream: https://github.com/grafana/tanka

_tk() {
    local -a sub=(
        'apply:apply Tanka environment'
        'diff:diff vs cluster'
        'show:render manifests'
        'prune:prune orphaned resources'
        'export:export environment manifests'
        'env:env operations'
        'init:initialize new project'
        'fmt:format Jsonnet'
        'lint:lint Jsonnet'
        'tool:dev tooling'
        'eval:evaluate Jsonnet expression'
        'status:show environment status'
        'jsonnetfmt:format Jsonnet'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--name=+[env name]:str:' \
        '--inject-labels[inject labels]' \
        '--ext-code=+[name=expr]:str:' \
        '--ext-str=+[name=val]:str:' \
        '--tla-code=+[name=expr]:str:' \
        '--tla-str=+[name=val]:str:' \
        '--cache-dir=+[dir]:dir:_files -/' \
        '--jpath=+[csv]:str:' \
        '-J+[csv]:str:' \
        '--max-stack=+[N]:n:' \
        '--target=+[kind/name pattern]:str:' \
        '-t+[kind/name pattern]:str:' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'tk subcommand' sub ;;
        args)
            case $words[1] in
                apply|diff|show|prune|export|status) _arguments \
                    '--dry-run=+[mode]:m:(none server client)' \
                    '--auto-approve=+[mode]:m:(never always)' \
                    '*:env path:_files -/' ;;
                env) _arguments \
                    '1:action:(add set list rm)' \
                    '*:env name:' ;;
                init) _arguments \
                    '--k8s=+[version]:str:' \
                    '--inline[inline]' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_tk "$@"
