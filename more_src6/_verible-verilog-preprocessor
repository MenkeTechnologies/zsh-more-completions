#compdef verible-verilog-preprocessor
# Documentation: https://chipsalliance.github.io/verible/
# Source: chipsalliance/verible verible/verilog/tools/preprocessor/verilog-preprocessor.cc — SV/Verilog preprocessor / comment stripper / ifdef variant generator.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '--limit_variants=[maximum number of variants printed (generate-variants only)]:n:' \
    '--flagfile=[load flags from comma-separated files]:files:_files' \
    '--fromenv=[set flags from env (comma-separated)]:flags:' \
    '--tryfromenv=[try to set flags from env if present]:flags:' \
    '--undefok=[flag names ok to specify on CLI]:flags:' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'preprocess:preprocess one or more SV/Verilog source files'
            'strip-comments:remove // and /**/ comments from input'
            'generate-variants:emit every possible variant of `ifdef blocks'
        )
        _describe -t subcmds 'subcommand' subcmds && ret=0
        ;;
    args)
        _files && ret=0
        ;;
esac

return ret
