#compdef ttftotype42
# Documentation: ttftotype42 --help (lcdf-typetools)
# Source: lcdf-typetools ttftotype42 — convert TrueType (or OpenType TT-flavor) to Type 42.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-o --output)'{-o,--output=}'[output file]:file:_files' \
    '(-q --quiet)'{-q,--quiet}'[no error messages]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '1:TrueType / OpenType font:_files -g "*.{ttf,otf,ttc}"' \
    '2:output Type 42 font:_files' \
    && ret=0

return ret
