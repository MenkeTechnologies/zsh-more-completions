#compdef xray-knife
# _xray-knife — Swiss Army Knife for xray-core & sing-box (lilendian0x00/xray-knife)
# upstream: https://github.com/lilendian0x00/xray-knife
# Subcommands from cmd/root.go (cobra).

_xray-knife() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'parse:parse a single xray/sing-box config link'
                'subs:fetch & inspect subscription URLs'
                'http:HTTP/socks5 latency/availability test'
                'net:network/TCP probe tools'
                'cfscanner:Cloudflare IP scanner'
                'proxy:run a local proxy against a config link'
                'webui:start the web UI for management'
                'exec:execute test scenarios from a script'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_xray-knife "$@"
