#compdef uptime-kuma
# Documentation: https://github.com/louislam/uptime-kuma
# Reference accessed: 2026-05-21
# Verified: upstream server.js + database.js argv parsing.
# Most configuration is via environment variables
# (UPTIME_KUMA_HOST, UPTIME_KUMA_PORT, UPTIME_KUMA_SSL_KEY, etc.).
# Only the flags below are parsed from the command line.

_arguments -s -S \
  '--data-dir=[data directory (overridden by $DATA_DIR)]:directory:_files -/' \
  '--disable-frame-sameorigin[disable X-Frame-Options SAMEORIGIN]' \
  '--cloudflared-token=[Cloudflare Tunnel token]:token:' \
  '--test[start in test mode]'
