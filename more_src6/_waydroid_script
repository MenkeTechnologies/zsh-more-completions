#compdef waydroid_script
# _waydroid_script — Waydroid container install / hack helper (casualsnek/waydroid_script)
# upstream: https://github.com/casualsnek/waydroid_script
# Subcommands + flags from main.py (argparse).

_waydroid_script() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-a --android-version)'{-a+,--android-version=}'[Android version]:version:(11 13)' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_waydroid_script_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                install)
                    _arguments \
                        '(-c --ca-cert)'{-c+,--ca-cert=}'[CA certificate (mitm only)]:file:_files -g "*.pem"' \
                        '*:app:(gapps microg libndk libhoudini magisk smartdock fdroidpriv widevine mitm)'
                    ;;
                remove|uninstall)
                    _arguments '*:app:(gapps microg libndk libhoudini magisk smartdock fdroidpriv widevine mitm nodataperm hidestatusbar)'
                    ;;
                hack)
                    _arguments '*:option:(nodataperm hidestatusbar)'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_waydroid_script_commands] )) ||
_waydroid_script_commands() {
    local -a commands
    commands=(
        'certified:get device ID to obtain Play Store certification'
        'install:install an app (gapps / microg / magisk / etc.)'
        'remove:remove an installed app'
        'uninstall:alias for remove'
        'hack:apply a system hack (nodataperm / hidestatusbar)'
    )
    _describe -t commands 'waydroid_script command' commands
}

_waydroid_script "$@"
