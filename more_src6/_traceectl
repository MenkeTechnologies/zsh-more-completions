#compdef traceectl
# Documentation: https://github.com/aquasecurity/tracee (cmd/traceectl/cmd/{root,event,stream,metrics,version}.go cobra)
# Reference accessed: 2026-05-29
# traceectl — Aqua Security tracee control CLI. Manage events, stream live, query metrics on a running tracee server.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'event:manage tracee events (enable/disable/describe)'
  'stream:stream events from tracee (real-time gRPC consumer)'
  'metrics:display tracee metrics (performance + resource usage)'
  'version:print traceectl version'
  'help:show help for a subcommand'
)

local -a _event_sub
_event_sub=(
  'enable:enable a specific event by name'
  'disable:disable a specific event by name'
  'describe:list available events (or describe a single event)'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcmd' \
  '*:: :->args' && ret=0

case $state in
  subcmd)
    _describe -t commands 'traceectl subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      event)
        _arguments -C \
          '(- *)'{-h,--help}'[show help]' \
          '1: :->evsub' \
          '*:: :->evargs' && ret=0
        case $state in
          evsub)
            _describe -t commands 'event subcommand' _event_sub && ret=0
            ;;
          evargs)
            case $line[1] in
              describe)
                _arguments \
                  '--server=[tracee server unix socket]:socket:_files' \
                  '--format=[output format (default table)]:fmt:(table json)' \
                  '--output=[output destination (default stdout)]:dest:' \
                  '1:event name (optional — empty = list all):' && ret=0
                ;;
              enable|disable)
                _arguments \
                  '--server=[tracee server unix socket]:socket:_files' \
                  '--output=[output destination (default stdout)]:dest:' \
                  '1:event name (required):' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      stream)
        _arguments \
          '--server=[tracee server unix socket]:socket:_files' \
          '--format=[stream format (default table)]:fmt:(table json)' \
          '--output=[stream destination (default stdout)]:dest:' \
          '*:policy name (optional, filters which policies to stream):' && ret=0
        ;;
      metrics)
        _arguments \
          '--server=[tracee server unix socket]:socket:_files' && ret=0
        ;;
      version)
        _arguments '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
