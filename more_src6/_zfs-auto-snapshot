#compdef zfs-auto-snapshot
# Zsh completion for zfs-auto-snapshot - Automatic ZFS snapshot management
# https://github.com/zfsonlinux/zfs-auto-snapshot

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-d --debug)'{-d,--debug}'[print debugging messages]' \
  '(-e --event)'{-e,--event}'[set event name]:event name:' \
  '(-k --keep)'{-k,--keep}'[number of snapshots to keep]:number:' \
  '(-l --label)'{-l,--label}'[set snapshot label]:label:(frequent hourly daily weekly monthly)' \
  '(-n --dry-run)'{-n,--dry-run}'[print actions without executing]' \
  '(-p --prefix)'{-p,--prefix}'[set snapshot prefix]:prefix:' \
  '(-q --quiet)'{-q,--quiet}'[suppress warnings]' \
  '(-r --recursive)'{-r,--recursive}'[snapshot recursively]' \
  '(-s --syslog)'{-s,--syslog}'[log to syslog]' \
  '(-g --skip-scrub)'{-g,--skip-scrub}'[skip pools being scrubbed]' \
  '(-v --verbose)'{-v,--verbose}'[print verbose info]' \
  '--send-full=[send full backup to destination]:destination:' \
  '--send-incr=[send incremental backup to destination]:destination:' \
  '--sep=[snapshot name separator]:separator:' \
  '--destroy-only[only destroy old snapshots]' \
  '*:ZFS dataset:_files -/'
