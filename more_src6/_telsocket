#compdef telsocket
# ============================================================================
# telsocket - Telnet for WebSockets: line-mode
#              interactive WebSocket client (Go, MIT)
#
# Author : Khaled Hussein (lafikl)
# Upstream: https://github.com/lafikl/telsocket
#
# `telsocket` is the WebSocket analog of the classic
# `telnet` command - it dials a WebSocket endpoint,
# upgrades the connection, then drops into a line-mode
# REPL: each line typed on stdin becomes one outbound
# WebSocket text frame, and each incoming text frame
# is printed to stdout (cyan-colored for inbound vs
# default for outbound). Intended for poking at
# WebSocket servers during development without writing
# a one-off JS client snippet in the browser console.
#
# Usage:
#   telsocket -url <ws://...>
#             [-headers name=value,name=value,...]
#
# Flags (flag.* stdlib parsing):
#   -url <url>             - WebSocket endpoint URL (ws://
#                             or wss://; required)
#   -headers <list>        - comma-separated key=value
#                             HTTP headers to send on the
#                             upgrade request (e.g.
#                             `Authorization=Bearer
#                             abc,X-Foo=bar`)
#
# Operational model:
#   - stdin lines -> outbound text frames (one per line,
#     newline-trimmed)
#   - inbound text frames -> stdout (cyan)
#   - Ctrl-C / Ctrl-D / EOF -> close connection
#
# The gorilla/websocket lane is built on `github.com/
# gorilla/websocket` (declared at upstream go.mod HEAD
# as a direct dep, imported from main.go as `import
# "github.com/gorilla/websocket"`), the canonical Go
# WebSocket library by the Gorilla web toolkit org -
# github.com/gorilla/websocket, 23000+ stars.
#
# gorilla/websocket has the most notable governance
# history of any library in the cross-language Axis 248
# cluster:
#   - Originally part of the Gorilla web toolkit (1.0
#     in 2013), the most widely-used Go web library
#     family of the early-to-mid-2010s alongside the
#     standard library's net/http
#   - Reached canonical status in the Go ecosystem
#     before any spec-author-adjacent alternative
#     emerged
#   - December 2022: the broader Gorilla toolkit org
#     archived all its repos including
#     gorilla/websocket - the maintainers cited
#     burnout + the absence of fresh contributors
#   - During 2023: the proposed successor,
#     `nhooyr.io/websocket` (later renamed `coder/
#     websocket` after the project moved to Coder's
#     org), tried to displace gorilla/websocket but
#     existing-user inertia kept it as the de-facto
#     standard
#   - July 2023: gorilla/websocket was *unarchived* and
#     resumed maintenance under a new contributor team
#     after the community-led successor failed to take
#     over
#   - 2024+: gorilla/websocket continues as the
#     canonical Go WebSocket library; coder/websocket
#     remains an actively-maintained alternative for
#     codebases that prefer its API
#
# This archive-then-unarchive story is unique to the Go
# Axis 248 slot. The Rust + Node slots both have stable
# single-author / single-org maintenance stories without
# the dramatic governance interruption.
#
# telsocket uses `websocket.DefaultDialer.Dial(url,
# headers)` to perform the WebSocket handshake against
# the target endpoint, then `c.ReadMessage()` /
# `c.WriteMessage(websocket.TextMessage, ...)` for the
# line-mode I/O loop. The conn is held open until
# either side closes the WebSocket (or stdin hits EOF).
#
# ----------------------------------------------------------------------------
# AXIS 248 :: WebSocket / RFC 6455 (bidirectional
#              full-duplex framing over HTTP/1.1 Upgrade)
# Round 1443 :: Go slot 2 of 4 :: continues Axis 248
#
# Cross-language canonical library family for this axis:
#   Rust    : snapview/tokio-tungstenite  [R1442 _phantasm]
#             (+ snapview/tungstenite-rs)
#   Go      : gorilla/websocket           [R1443 THIS FILE]
#   TS/Node : websockets/ws               [R1444 closing]
#
# gorilla/websocket is structurally the most interesting
# library in this axis cluster because of its archive ->
# unarchive governance arc (covered in detail above).
# The Gorilla web toolkit's broader story is similar -
# the toolkit was sunset together (`gorilla/mux`, the
# Gorilla HTTP router, was the highest-profile casualty;
# `gorilla/securecookie`, `gorilla/csrf`, etc. all went
# with it), but only `gorilla/websocket` was reactivated
# afterward because none of the alternatives managed to
# accumulate equivalent ecosystem buy-in during the
# archived window.
#
# Cross-language interop happens at the wire format
# level - RFC 6455 framing is byte-identical across
# all three lanes. A tokio-tungstenite client can
# connect to a gorilla/websocket server, exchange
# messages with a websockets/ws server, etc. The
# autobahn-test-suite conformance corpus validates this
# cross-library interop across all 500+ test vectors.
# ============================================================================

_telsocket() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '-url[WebSocket endpoint URL (ws:// or wss://)]:url:' \
        '-headers[comma-separated key=value HTTP headers]:list:' \
        '(- *)-h[print help]'
}

_telsocket "$@"
