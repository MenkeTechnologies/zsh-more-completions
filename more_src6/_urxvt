#compdef urxvt rxvt rxvt-unicode urxvtc urxvtd mrxvt
# Documentation: man urxvt(1)
# Source: exg/rxvt-unicode src/xdefaults.C (master) — rxvt-unicode terminal emulator (C++, optList table).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-d --display)-d+[X display]:display:_x_display' \
    '-display+[X display]:display:_x_display' \
    '-tn+[TERM environment value]:terminal:_default' \
    '-g+[geometry]:WxH+X+Y:_default' \
    '-geometry+[geometry]:WxH+X+Y:_default' \
    '-cd+[start shell in this directory]:dir:_files -/' \
    '-chdir+[start shell in this directory]:dir:_files -/' \
    '-C[intercept console messages]' \
    '(-iconic -ic)-iconic[start iconic]' \
    '(-iconic -ic)-ic[start iconic (short)]' \
    '-dockapp[start as dockapp]' \
    '(-rv +rv)-rv[reverse video]' \
    '(-rv +rv)+rv[disable reverse video]' \
    '(-ls +ls)-ls[login shell]' \
    '(-ls +ls)+ls[disable login shell]' \
    '-mc+[multi-click time (ms)]:ms:_default' \
    '(-j +j)-j[jump scrolling]' \
    '(-j +j)+j[disable jump scroll]' \
    '(-sb +sb)-sb[show scrollbar]' \
    '(-sb +sb)+sb[hide scrollbar]' \
    '(-sr +sr)-sr[scrollbar right]' \
    '(-sr +sr)+sr[scrollbar left]' \
    '(-st +st)-st[floating scrollbar (no trough)]' \
    '(-st +st)+st[scrollbar with trough]' \
    '-sbt+[scrollbar thickness px]:px:_default' \
    '-mode+[scrollbar style]:style:(plain next xterm rxvt)' \
    '-fade+[fade % when losing focus]:percent:_default' \
    '-fadecolor+[target color for off-focus fading]:color:_default' \
    '(-ut +ut)-ut[utmp inhibit]' \
    '(-ut +ut)+ut[utmp record]' \
    '(-vb +vb)-vb[visual bell]' \
    '(-vb +vb)+vb[audible bell]' \
    '-fg+[foreground color]:color:_default' \
    '-bg+[background color]:color:_default' \
    '-fn+[normal font]:font:_default' \
    '-fb+[bold font]:font:_default' \
    '-fi+[italic font]:font:_default' \
    '-fbi+[bold italic font]:font:_default' \
    '-bw+[border width]:px:_default' \
    '-bd+[border color]:color:_default' \
    '-bl[borderless]' \
    '-cr+[cursor color]:color:_default' \
    '-title+[window title]:title:_default' \
    '-T+[window title]:title:_default' \
    '-name+[application name]:name:_default' \
    '-n+[icon name]:name:_default' \
    '-pe+[perl extensions]:exts:_default' \
    '-pixmap+[background pixmap]:file:_files -g "*.{png,jpg,xpm}"' \
    '-tr[true transparency]' \
    '-embed+[X window to embed in]:winid:_default' \
    '-pty-fd+[pty file descriptor]:fd:_default' \
    '-e+[command to execute]:command:_command_names -e' \
    '*::command args:_default' \
    && ret=0

return ret
