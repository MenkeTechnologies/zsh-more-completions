#compdef tap
# Documentation: https://node-tap.org/cli/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for node-tap (Node.js TAP test runner)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:run tests (default)'
  'report:generate coverage reports'
  'replay:rerun previous test output through reporters'
  'repl:interactive shell for test suite interaction'
  'plugin:manage plugins (add, rm, list)'
  'config:manage configuration (get, list, dump, set, edit)'
  'list:list test files matching configuration'
  'build:rebuild test class with plugin configuration'
  'node-options:output loader and Node arguments for standalone execution'
  'debug:generate debugging information'
  'version:show tap version'
  'versions:show tap and all component/plugin versions'
  'help:show help'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --versions)'{-V,--versions}'[show all component versions]' \
  '*--plugin=[configure Test class with plugin]:module:' \
  '(-R --reporter)'{-R,--reporter}'=[output reporter]:reporter:(base terse min dot silent json markdown junit tap)' \
  '(-f --reporter-file)'{-f,--reporter-file}'=[write report to file]:file:_files' \
  '*'{-r,--reporter-arg}'=[reporter argument]:arg:' \
  '(-j --jobs)'{-j,--jobs}'=[parallel test files]:jobs:' \
  '(-t --timeout)'{-t,--timeout}'=[test timeout (seconds, default 30)]:seconds:' \
  '(-b --bail)'{-b,--bail}'[stop on first failure]' \
  '(-B --no-bail)'{-B,--no-bail}'[continue after failures]' \
  '--fail-todo[treat TODO tests as failures]' \
  '--fail-skip[treat skipped assertions as failures]' \
  '--fail-only[fail tests marked with only:true]' \
  '(-n --changed)'{-n,--changed}'[run only tests for changed files]' \
  '*--include=[glob pattern for test discovery]:pattern:' \
  '*--exclude=[glob pattern to exclude]:pattern:' \
  '(-s --save)'{-s,--save}'=[save failed tests list]:file:_files' \
  '*--files=[test file specification]:file:_files' \
  '--comments[print TAP comments to stderr]' \
  '--passes[include passing tests in summaries]' \
  '(-c --color)'{-c,--color}'[force color output]' \
  '(-C --no-color)'{-C,--no-color}'[disable color output]' \
  '--diag[show diagnostics for all results]' \
  '--no-diag[hide diagnostics from passing/failing tests]' \
  '--coverage-report=[coverage report type (repeatable)]:type:' \
  '--show-full-coverage[display 100% coverage lines]' \
  '--coverage-map=[coverage map module]:file:_files' \
  '*--coverage-exclude=[glob pattern for excluded coverage]:pattern:' \
  '--allow-empty-coverage[suppress error when no coverage]' \
  '--allow-incomplete-coverage[suppress error for incomplete coverage]' \
  '--disable-coverage[skip code coverage tracking]' \
  '--statements=[required statement coverage %]:n:' \
  '--branches=[required branch coverage %]:n:' \
  '--lines=[required line coverage %]:n:' \
  '--functions=[required function coverage %]:n:' \
  '--browser[auto-open HTML coverage reports]' \
  '--no-browser[do not open HTML coverage reports]' \
  '*--serial=[directory tests to run sequentially]:dir:_directories' \
  '--before=[module to run before tests]:file:_files' \
  '--after=[module to run after tests]:file:_files' \
  '--shuffle[randomize test file order]' \
  '(-o --output-file)'{-o,--output-file}'=[write raw TAP output]:file:_files' \
  '(-d --output-dir)'{-d,--output-dir}'=[write per-test TAP files]:dir:_directories' \
  '*--test-arg=[argument to test process]:arg:' \
  '*--test-env=[set test process env var]:key=value:' \
  '*--node-arg=[argument to Node binary]:arg:' \
  '--debug[verbose debug output]' \
  '--omit-version[suppress TAP version line]' \
  '--omit-whitespace[remove empty lines]' \
  '--no-omit-whitespace[preserve empty lines]' \
  '(-O --only)'{-O,--only}'[run only tests marked only:true]' \
  '*'{-g,--grep}'=[filter tests by pattern]:pattern:' \
  '(-i --invert)'{-i,--invert}'[invert grep match]' \
  '(-I --no-invert)'{-I,--no-invert}'[normal pattern matching]' \
  '--filter-quietly[omit skip messages for filtered tests]' \
  '--no-filter-quietly[always show skip messages]' \
  '(-F --save-fixture)'{-F,--save-fixture}'[retain fixture directories]' \
  '(-S --snapshot)'{-S,--snapshot}'[generate snapshot files]' \
  '--snapshot-clean-cwd[replace CWD with token in snapshots]' \
  '--no-snapshot-clean-cwd[preserve CWD in snapshot data]' \
  '--typecheck[TypeScript type checking on tests]' \
  '--tsconfig=[path to tsconfig.json]:file:_files' \
  '--type-strip-only[use Node native type stripping]' \
  '*:test file:_files -g "*.{js,mjs,cjs,ts,mts,cts,jsx,tsx}"' && ret=0

case $state in
  (command)
    _describe -t commands 'tap command' commands && ret=0
    ;;
esac

return ret
