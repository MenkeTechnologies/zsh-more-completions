#compdef xdelta3
# Documentation: man xdelta3(1)
# Source: jmacd/xdelta xdelta3/xdelta3-main.h (master) — VCDIFF binary diff/patch tool (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a cmds=(
    'config:print xdelta3 configuration'
    'decode:decompress the input'
    'encode:compress the input'
    'test:run builtin tests'
    'printdelta:print info about VCDIFF delta'
    'printhdr:print info about first VCDIFF window'
    'printhdrs:print info about all VCDIFF windows'
    'recode:re-encode with new settings'
    'merge:merge VCDIFF inputs'
)

_arguments -s -C \
    '-0[fastest compression]' \
    '-1[compression level 1]' \
    '-2[compression level 2]' \
    '-3[compression level 3]' \
    '-4[compression level 4]' \
    '-5[compression level 5]' \
    '-6[compression level 6]' \
    '-7[compression level 7]' \
    '-8[compression level 8]' \
    '-9[best compression]' \
    '-c[use stdout]' \
    '(-d -e)-d[decompress]' \
    '(-d -e)-e[compress]' \
    '-f[force (overwrite, ignore trailing garbage)]' \
    '-F[force the external compression subprocess]' \
    '-h[show help]' \
    '-q[quiet]' \
    '*-v[verbose (max 2)]' \
    '-V[show version]' \
    '-B+[source window size in bytes]:bytes:_default' \
    '-W+[input window size in bytes]:bytes:_default' \
    '-P+[duplicates window size]:size:_default' \
    '-I+[instruction buffer size (0=unlimited)]:size:_default' \
    '-s+[source file to copy from]:file:_files' \
    '-S+[secondary compression]:type:(lzma djw fgk none)' \
    '-N[disable small-string matching]' \
    '-D[disable external decompression]' \
    '-R[disable external recompression]' \
    '-n[disable checksum]' \
    '-C+[soft config]:config:_default' \
    '-A+[application header]:apphead:_default' \
    '-J[disable output (check only)]' \
    '*-m+[merge VCDIFF input]:file:_files -g "*.vcdiff"' \
    '1::command:->cmd' \
    '*::file:_files' \
    && ret=0

case $state in
    cmd) _describe -t commands 'xdelta3 command' cmds && ret=0 ;;
esac

return ret
