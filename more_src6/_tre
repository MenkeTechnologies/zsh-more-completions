#compdef tre
# Documentation: https://github.com/dduan/tre
# Reference accessed: 2026-05-21
# Verified: upstream docs (README flag table).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-V,--version}'[display version]' \
  '(-a --all)'{-a,--all}'[print all files and directories, including hidden]' \
  '(-c --color)'{-c,--color}'=[when to use color]:when:(automatic always never)' \
  '(-d --directories)'{-d,--directories}'[only list directories]' \
  '(-e --editor)'{-e,--editor}'=[activate file-opening aliases with optional command]:editor:_command_names -e' \
  '*'{-E,--exclude}'=[exclude paths matching regex (repeatable)]:pattern' \
  '(-j --json)'{-j,--json}'[output JSON instead of tree diagram]' \
  '(-l --limit)'{-l,--limit}'=[limit depth of tree]:depth' \
  '(-p --portable)'{-p,--portable}'[generate absolute paths for aliases]' \
  '(-s --simple)'{-s,--simple}'[disregard .gitignore]' \
  '*:directory:_directories' && ret=0

return ret
