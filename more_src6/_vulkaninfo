#compdef vulkaninfo
# Documentation: https://docs.vulkan.org/spec/latest/appendices/vulkaninfo.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed from prior file: bogus man.archlinux.org URL; fabricated
# --devsim, --portability, --gpu flags (not in upstream).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[print help]' \
  '--summary[display summary of instance and GPUs]' \
  '--text[produce text output (default)]' \
  '--html[produce HTML output (vulkaninfo.html)]' \
  '(-j --json)'{-j,--json}'[produce JSON output (Vulkan Profiles schema)]' \
  '(-j --json)'{-j=-,--json=-}'[produce JSON output for specific GPU]:gpu number:' \
  '(-o --output)'{-o+,--output=}'[print output to file]:file:_files' \
  '--show-all[show all properties]' \
  '--show-tool-props[display active VkPhysicalDeviceToolPropertiesEXT]' \
  '--show-formats[display format properties (text only)]' \
  '--show-promoted-structs[include promoted structs in pNext chains]' \
  '--show-video-props[display video profile/capabilities/formats (text only)]' && ret=0

return ret
