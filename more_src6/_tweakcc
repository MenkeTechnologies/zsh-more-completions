#compdef tweakcc
# Documentation: https://github.com/Piebald-AI/tweakcc
# Reference accessed: 2026-05-21
# Verified: Piebald-AI/tweakcc README.

# Zsh completion for tweakcc - Claude Code customization tool

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--apply[apply saved customizations]' \
  '--restore[revert to original Claude Code]' \
  '--config-url=[fetch config from remote URL]:url:' \
  '--verbose[show detailed diffs]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a cmds=(
      'unpack:extract embedded JS from native Claude Code binary'
      'repack:embed JS back into native Claude Code binary'
      'adhoc-patch:apply one-off patches'
    )
    _describe -t commands 'tweakcc command' cmds && ret=0
    ;;
  args)
    case "${words[1]}" in
      unpack|repack)
        _arguments \
          ':js path:_files -g "*.js"' \
          '::binary path:_files' && ret=0
        ;;
      adhoc-patch)
        _arguments \
          '--string[fixed string replacement]:old: :new:' \
          '--regex[regex-based replacement]:pattern: :replacement:' \
          '--script[run JS patch (@file or @https URL)]:code-or-ref:' \
          '--index=[replace specific occurrence]:n:' && ret=0
        ;;
    esac
    ;;
esac

return ret
