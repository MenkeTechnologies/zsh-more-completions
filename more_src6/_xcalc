#compdef xcalc
# Documentation: xcalc usage (X.Org)
# Source: X11 scientific calculator.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-rpn[Reverse-Polish-Notation (HP-style) mode]' \
    '-stipple[use stippled background]' \
    && ret=0

return ret
