#compdef transmission-edit
# Documentation: https://manpages.debian.org/testing/transmission-cli/transmission-edit.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '*'{-a,--add}'[add a tracker announce URL]:URL' \
  '*'{-d,--delete}'[delete a tracker announce URL]:URL' \
  '*'{-r,--replace}'[replace tracker (OLD NEW)]:OLD:: :NEW:' \
  '(-V --version)'{-V,--version}'[show version number]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:torrent file:_files -g "*.torrent"' && ret=0

return ret
