#compdef unitd
# Documentation: https://unit.nginx.org/howto/source/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Completion for unitd - NGINX Unit application server

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version and build configuration]' \
  '--control=[control API socket address (IPv4/IPv6/UNIX)]:socket:_files' \
  '--control-user=[owner of UNIX control socket]:user:_users' \
  '--control-group=[group of UNIX control socket]:group:_groups' \
  '--control-mode=[permission of UNIX control socket]:mode:' \
  '--group=[group name for non-privileged processes]:group:_groups' \
  '--log=[log file path]:log file:_files' \
  '--modulesdir=[language modules directory]:directory:_directories' \
  '--pid=[PID file path]:pid file:_files' \
  '--statedir=[state storage directory]:directory:_directories' \
  '--tmpdir=[temp file storage directory]:directory:_directories' \
  '--user=[user account for non-privileged processes]:user:_users' \
  '--no-daemon[run in non-daemon mode]' && ret=0

return ret
