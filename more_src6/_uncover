#compdef uncover
# Documentation: https://github.com/projectdiscovery/uncover
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# Zsh completion for ProjectDiscovery Uncover - search engine wrapper

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-version[show version]' \
  '*-q+[search query]:query:' \
  '*-query+[search query]:query:' \
  '*-e+[search engine]:engine:(shodan censys fofa quake hunter zoomeye netlas criminalip publicwww hunterhow google driftnet daydaymap)' \
  '*-engine+[search engine]:engine:(shodan censys fofa quake hunter zoomeye netlas criminalip publicwww hunterhow google driftnet daydaymap)' \
  '-asq[use pre-built awesome search queries]' \
  '-awesome-search-queries[use pre-built awesome search queries]' \
  '-shodan+[Shodan query]:query:' \
  '-censys+[Censys query]:query:' \
  '-fofa+[FOFA query]:query:' \
  '-quake+[Quake query]:query:' \
  '-hunter+[Hunter query]:query:' \
  '-zoomeye+[ZoomEye query]:query:' \
  '-netlas+[Netlas query]:query:' \
  '-criminalip+[CriminalIP query]:query:' \
  '-publicwww+[publicwww query]:query:' \
  '-hunterhow+[hunterhow query]:query:' \
  '-google+[Google query]:query:' \
  '-onyphe+[Onyphe query]:query:' \
  '-driftnet+[driftnet query]:query:' \
  '-daydaymap+[daydaymap query]:query:' \
  '-pc+[provider config file]:file:_files' \
  '-provider+[provider config file]:file:_files' \
  '-config+[flag config file]:file:_files' \
  '-timeout+[request timeout (s)]:seconds:' \
  '-rl+[HTTP requests/second]:rate:' \
  '-rate-limit+[HTTP requests/second]:rate:' \
  '-rlm+[HTTP requests/minute]:rate:' \
  '-rate-limit-minute+[HTTP requests/minute]:rate:' \
  '-retry+[retries]:n:' \
  '-proxy+[HTTP proxy]:url:' \
  '-o+[output file]:file:_files' \
  '-output+[output file]:file:_files' \
  '-f+[fields to display (ip, port, host)]:fields:' \
  '-field+[fields to display]:fields:' \
  '-j[JSONL output]' \
  '-json[JSONL output]' \
  '-r[raw API response output]' \
  '-raw[raw API response output]' \
  '-l+[result limit]:n:' \
  '-limit+[result limit]:n:' \
  '-nc[disable colored output]' \
  '-no-color[disable colored output]' \
  '-silent[show only results]' \
  '-v[verbose output]' \
  && ret=0

return ret
