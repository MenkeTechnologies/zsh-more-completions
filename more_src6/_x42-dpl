#compdef x42-dpl
# _x42-dpl — Robin Gareus x42-dpl digital peak limiter standalone JACK app and LV2 plugin for true-peak ceiling limiting with adjustable release and inter-sample peak protection (x42 team, C++); GOption
# upstream: https://github.com/x42/dpl.lv2

_x42-dpl() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-J+[jack client name]:str:' \
        '--jack-name=+[jack client name]:str:' \
        '-S+[jack server name]:str:' \
        '--jack-server=+[jack server name]:str:' \
        '-A[autoconnect]' \
        '--autoconnect[autoconnect]' \
        '-N[no autoconnect]' \
        '--no-autoconnect[no autoconnect]' \
        '-i+[input port]:str:' \
        '--input=+[input port]:str:' \
        '-o+[output port]:str:' \
        '--output=+[output port]:str:' \
        '-t+[threshold dBFS]:f:' \
        '--threshold=+[threshold dBFS]:f:' \
        '-r+[release ms]:f:' \
        '--release=+[release ms]:f:' \
        '-c+[ceiling dBFS]:f:' \
        '--ceiling=+[ceiling dBFS]:f:' \
        '-w+[window width]:n:' \
        '--width=+[window width]:n:' \
        '-d+[window height]:n:' \
        '--height=+[window height]:n:' \
        '--no-gui[no GUI]' \
        '--osc-port=+[port]:n:' \
        '--true-peak[true-peak]' \
        '--no-true-peak[no true-peak]' \
        '--auto-release[auto release]' \
        '--no-auto-release[no auto release]'
}

_x42-dpl "$@"
