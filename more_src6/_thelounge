#compdef thelounge
# Documentation: https://github.com/thelounge/thelounge/tree/master/server/command-line
# Reference accessed: 2026-05-21
# Verified: upstream command-line source at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start server'
  'install:install theme or plugin package'
  'uninstall:uninstall theme or plugin package'
  'upgrade:upgrade all installed packages'
  'outdated:check for package updates'
  'storage:configure storage options'
  'add:add user'
  'remove:remove user'
  'reset:reset user password'
  'edit:edit user config'
  'list:list users'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*'{-c,--config}'=[override config entries]:key=value:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'thelounge command' commands && ret=0 ;;
esac

return ret
