#compdef zpool-online
# _zpool-online — OpenZFS zpool online (mark a vdev online after it was previously offlined or replaced; -e expand to new device size, -t mark online only until next reboot; positional pool followed by one or more device names)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zpool/zpool_main.c (zpool_do_online) on tip.

_zpool-online() {
    _arguments \
        '-e[expand to new size]' \
        '-t[temporary online]' \
        '1:pool:' \
        '*:device:'
}

_zpool-online "$@"
