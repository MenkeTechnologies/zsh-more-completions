#compdef wiki-tui
# Documentation: https://github.com/Builditluc/wiki-tui/blob/main/src/cli.rs
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-l --language)'{-l,--language}'=[override configured Wikipedia language]:language' \
  '--level=[override configured logging level]:level:(trace debug info warn error)' \
  '--cache-dir[print path to cache directory]' \
  '--config-path[print path to config file]' \
  '--theme-config-path[print path to theme config file]' \
  '*:search query:' && ret=0

return ret
