#compdef vertx
# Documentation: https://datacadamia.com/lang/java/vertx/run
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'run:run a verticle'
  'start:start a Vert.x application in the background'
  'stop:stop a running Vert.x application'
  'list:list running Vert.x applications'
  'bare:start a bare Vert.x instance'
  'version:show version'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'vertx subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '-cp+[provide an extra classpath]:classpath:' \
          '-classpath+[provide an extra classpath]:classpath:' \
          '--conf=[main verticle configuration: JSON file or string]:file:_files' \
          '--instances=[number of verticle instances to deploy]:n:' \
          '--worker[deploy as worker verticle]' \
          '--ha[deploy as high availability]' \
          '--hagroup=[HA group to join (default __DEFAULT__)]:group:' \
          '--quorum=[minimum cluster nodes for HA to be active]:n:' \
          '--options=[Vert.x options: JSON file or string]:file:_files' \
          '--cluster[form a cluster with other Vert.x instances]' \
          '--cluster-host=[host to bind for cluster communication]:host:_hosts' \
          '--cluster-port=[port for cluster communication]:port:' \
          '--cluster-public-host=[public hostname for cluster]:host:_hosts' \
          '--cluster-public-port=[public port for cluster]:port:' \
          '--redeploy=[redeployment includes pattern]:pattern:' \
          '--on-redeploy=[shell command triggered on redeploy]:cmd:' \
          '--redeploy-grace-period=[grace period between 2 redeployments (ms)]:ms:' \
          '--redeploy-scan-period=[file system scanning period (ms)]:ms:' \
          '--redeploy-termination-period=[time to wait for previous version stop (ms)]:ms:' \
          ':main-verticle:' && ret=0
        ;;
      (stop)
        _arguments ':id:' && ret=0
        ;;
    esac
    ;;
esac

return ret
