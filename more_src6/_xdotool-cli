#compdef xdotool-cli
# _xdotool-cli — Jordan Sissel xdotool command-line X11 automation CLI alias (jordansissel team, C); custom argparse
# upstream: https://github.com/jordansissel/xdotool

_xdotool-cli() {
    local -a sub=(
        'help:show help'
        'version:show version'
        'sleep:sleep for seconds'
        'click:click mouse button'
        'mousedown:press mouse button'
        'mouseup:release mouse button'
        'mousemove:move mouse cursor'
        'mousemove_relative:move mouse relative'
        'getmouselocation:show mouse position'
        'key:send key sequence'
        'keydown:press key'
        'keyup:release key'
        'type:type a string'
        'search:search for windows'
        'getactivewindow:get active window'
        'getwindowfocus:get focused window'
        'getwindowname:get window name'
        'getwindowpid:get window PID'
        'getwindowgeometry:get window geometry'
        'getwindowclassname:get window class name'
        'getdisplaygeometry:get screen geometry'
        'set_window:set window properties'
        'activate:activate window'
        'focus:focus window (no raise)'
        'windowsize:resize window'
        'windowmove:move window'
        'windowraise:raise window'
        'windowminimize:minimize window'
        'windowmap:map window'
        'windowunmap:unmap window'
        'windowclose:close window'
        'windowkill:kill window'
        'windowactivate:activate window'
        'windowreparent:reparent window'
        'set_num_desktops:set desktop count'
        'get_num_desktops:get desktop count'
        'set_desktop:switch desktop'
        'get_desktop:get current desktop'
        'set_desktop_for_window:move window to desktop'
        'get_desktop_for_window:get window desktop'
        'set_desktop_viewport:set viewport'
        'get_desktop_viewport:get viewport'
        'exec:exec a command'
        'spawn:spawn a command'
        'behave:behave on event'
        'behave_screen_edge:behave on screen edge'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--clearmodifiers[clear modifiers]' \
        '--delay=+[ms between events]:n:' \
        '--repeat=+[repeat count]:n:' \
        '--repeat-delay=+[ms]:n:' \
        '--sync[wait for sync]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'xdotool subcommand' sub ;;
        args)
            case $words[1] in
                click|mousedown|mouseup) _arguments \
                    '1:button:(1 2 3 4 5)' \
                    '--clearmodifiers[clear modifiers]' \
                    '--repeat=+[count]:n:' \
                    '--delay=+[ms]:n:' \
                    '--window=+[window]:str:' ;;
                mousemove|mousemove_relative) _arguments \
                    '1:x:' \
                    '2:y:' \
                    '--screen=+[screen]:n:' \
                    '--window=+[window]:str:' \
                    '--polar[polar coords]' ;;
                key|keydown|keyup|type) _arguments \
                    '*:key/string:' \
                    '--window=+[window]:str:' \
                    '--clearmodifiers[clear modifiers]' \
                    '--delay=+[ms]:n:' \
                    '--file=+[file]:file:_files' ;;
                search) _arguments \
                    '*:pattern:' \
                    '--class[class match]' \
                    '--classname[classname match]' \
                    '--name[name match]' \
                    '--maxdepth=+[depth]:n:' \
                    '--onlyvisible[only visible]' \
                    '--screen=+[screen]:n:' \
                    '--desktop=+[desktop]:n:' \
                    '--limit=+[limit]:n:' \
                    '--all[match all]' \
                    '--any[match any]' \
                    '--sync[wait for results]' ;;
                windowsize|windowmove) _arguments \
                    '1:window:' \
                    '2:x or width:' \
                    '3:y or height:' \
                    '--relative[relative]' \
                    '--sync[sync]' ;;
                set_desktop|get_desktop) _arguments '1:desktop:' ;;
                exec|spawn) _arguments '*:command:' ;;
            esac
            ;;
    esac
}

_xdotool-cli "$@"
