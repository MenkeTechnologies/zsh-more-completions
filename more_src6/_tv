#compdef tv tidy-viewer
# Documentation: https://github.com/alexhallam/tv
# Reference accessed: 2026-05-21
# Verified: tidy-viewer-cli/src/main.rs structopt definitions in alexhallam/tv.

# Zsh completion for tidy-viewer (tv - pretty CSV/TSV viewer)

_arguments -s -S \
  '(-c --color)'{-c,--color}'[color palette]:palette:(0 1 2 3 4 5)' \
  '(-s --delimiter)'{-s,--delimiter}'[field delimiter]:delimiter:' \
  '(-t --title)'{-t,--title}'[table title]:title:' \
  '(-F --footer)'{-F,--footer}'[table footer]:footer:' \
  '(-n --number-of-rows-to-output)'{-n,--number-of-rows-to-output}'[number of rows to display]:rows:' \
  '(-l --lower-column-width)'{-l,--lower-column-width}'[minimum column width]:width:' \
  '(-u --upper-column-width)'{-u,--upper-column-width}'[maximum column width]:width:' \
  '(-g --sigfig)'{-g,--sigfig}'[significant digits]:digits:' \
  '--max-decimal-width=[scientific notation threshold]:n:' \
  '--preserve-scientific[preserve scientific notation in input]' \
  '(-e --extend-width-and-length)'{-e,--extend-width-and-length}'[extend beyond terminal width]' \
  '(-f --force-all-rows)'{-f,--force-all-rows}'[print all rows]' \
  '(-j --jump-invalid-rows)'{-j,--jump-invalid-rows}'[skip invalid rows]' \
  '(-p --pedantic)'{-p,--pedantic}'[crash on malformed csv]' \
  '(-d --debug-mode)'{-d,--debug-mode}'[enable debug mode]' \
  '(-a --color-always)'{-a,--color-always}'[force color output]' \
  '(-D --no-dimensions)'{-D,--no-dimensions}'[turn off dimensions display]' \
  '(-R --no-row-numbering)'{-R,--no-row-numbering}'[disable row numbering]' \
  '(-C --config-details)'{-C,--config-details}'[show current config details]' \
  '--streaming-threshold=[streaming auto-enable threshold MB]:mb:' \
  '--no-streaming[disable streaming mode]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:csv file:_files -g "*.csv *.tsv"' && return 0
