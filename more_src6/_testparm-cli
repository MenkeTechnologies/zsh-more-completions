#compdef testparm-cli
# _testparm-cli — Samba testparm check smb.conf syntax CLI alias (samba team, C); custom argparse
# upstream: https://github.com/samba-team/samba

_testparm-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-s[supress prompt]' \
        '--suppress-prompt[supress prompt]' \
        '-v[show verbose output]' \
        '--verbose[show verbose output]' \
        '-l[show options as in smb.conf]' \
        '--show-all-parameters[show options as in smb.conf]' \
        '-x[exit on first error]' \
        '--skip-logic-checks[exit on first error]' \
        '--parameter-name=+[name]:str:' \
        '--section-name=+[name]:str:' \
        '--client-name=+[name]:str:' \
        '--client-ip=+[ip]:str:' \
        '-t+[encoding]:str:' \
        '--encoding=+[encoding]:str:' \
        '-d+[debug level]:n:' \
        '--debuglevel=+[debug level]:n:' \
        '--debug-stdout[debug to stdout]' \
        '-l+[log basename]:str:' \
        '--log-basename=+[log basename]:str:' \
        '*:smb.conf:_files -g "smb.conf"'
}

_testparm-cli "$@"
