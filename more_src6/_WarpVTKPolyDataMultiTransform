#compdef WarpVTKPolyDataMultiTransform
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/WarpVTKPolyDataMultiTransform.cxx — apply multiple ANTs transforms to a VTK polydata (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-R+[reference image (output space)]:file:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '*-i[invert the next affine transform]' \
    '1:input.vtk:_files -g "*.vtk"' \
    '2:output.vtk:_files -g "*.vtk"' \
    '*:warp/affine files (right-to-left order):_files' \
    && ret=0

return ret
