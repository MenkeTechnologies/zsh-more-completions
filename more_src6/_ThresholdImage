#compdef ThresholdImage
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/ThresholdImage.cxx — apply intensity threshold to an image (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:ImageDimension:(2 3 4)' \
    '2:ImageIn.ext:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3:outImage.ext:_files' \
    '4:threshlo:_default' \
    '5:threshhi:_default' \
    '6::insideValue (default 1):_default' \
    '7::outsideValue (default 0):_default' \
    && ret=0

return ret
