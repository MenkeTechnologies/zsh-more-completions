#compdef zpool-trim
# _zpool-trim — OpenZFS zpool trim (initiate or control a TRIM operation against the SSDs in a pool; -d cancel, -s suspend, -r resume, -w wait until complete, -p partial (only contiguous regions), --rate sets bytes-per-second cap; positional pool optionally followed by specific devices)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zpool/zpool_main.c (zpool_do_trim) on tip.

_zpool-trim() {
    _arguments \
        '-d[cancel in-progress trim]' \
        '-s[suspend in-progress trim]' \
        '-r+[rate bytes/sec]:bytes:' \
        '--rate+[rate bytes/sec]:bytes:' \
        '-p[partial (contiguous regions only)]' \
        '-w[wait until complete]' \
        '*:pool [device ...]:'
}

_zpool-trim "$@"
