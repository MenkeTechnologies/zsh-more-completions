#compdef zplug
# Documentation: https://github.com/zplug/zplug
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (README command table).

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[display help]' \
  '--version[display zplug version]' \
  '--log[show error reports]' \
  '--rollback[rollback a failed package]' \
  '--self-manage[self management of zplug]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'check:return true if all packages are installed'
      'clean:remove repositories no longer managed'
      'clear:remove the cache file'
      'install:install packages in parallel'
      'list:list installed packages'
      'load:source installed plugins, add commands to PATH'
      'status:check if remote repositories are up to date'
      'update:update installed packages in parallel'
      'info:show source URL and tag values for a package'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (check)
        _arguments '--verbose[verbose output]' && ret=0
        ;;
      (info)
        _arguments '1:package:' && ret=0
        ;;
      (clean)
        _arguments \
          '--force[force clean without confirmation]' \
          '--select[interactively select packages to clean]' && ret=0
        ;;
      (load)
        _arguments '--verbose[verbose output]' && ret=0
        ;;
      (list)
        _arguments \
          '--select[interactively select packages]' \
          '--loaded[list only loaded packages]' \
          '--installed[list only installed packages]' && ret=0
        ;;
      (status)
        _arguments '--select[interactively select packages]' && ret=0
        ;;
      (update)
        _arguments \
          '--select[interactively select packages]' \
          '--force[update even if up-to-date]' && ret=0
        ;;
    esac
    ;;
esac

return ret
