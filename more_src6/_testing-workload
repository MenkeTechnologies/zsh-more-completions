#compdef testing-workload
# _testing-workload — TiDB Operator e2e testing workload driver
# upstream: https://github.com/pingcap/tidb-operator
# Flags from cmd/testing-workload/main.go on tip.

_testing-workload() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--action=[action to run]:action:(ping workload import pd-region)' \
        '--host=[TiDB host]:host:' \
        '--port=[TiDB port]:port:' \
        '--user=[DB user]:user:' \
        '--password=[DB password]:pw:' \
        '--duration=[workload duration (minutes)]:n:' \
        '--max-connections=[max DB connections]:n:' \
        '--sleep-interval=[sleep interval (ms)]:ms:' \
        '--long-txn-sleep=[long txn sleep (s)]:s:' \
        '--max-life-time=[max DB conn lifetime (s)]:s:' \
        '--tiflash-replicas=[TiFlash replicas]:n:' \
        '--max-execution-time=[TiDB max_execution_time]:n:' \
        '--workload-type=[workload type]:type:(TXN SelectCount)' \
        '--batch-size=[batch size for import]:n:' \
        '--total-rows=[total rows for import]:n:'
}

_testing-workload "$@"
