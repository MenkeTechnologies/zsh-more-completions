#compdef velad
# _velad — minimal single-node KubeVela control plane installer (kubevela/velad)
# upstream: https://github.com/kubevela/velad
# Subcommands from pkg/cmd/command.go (cobra).

_velad() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                install:'install VelaD control plane'
                join:'join a worker node'
                status:'show status of the control plane'
                kubeconfig:'print kubeconfig for the control plane'
                token:'print cluster token'
                uninstall:'uninstall the control plane'
                version:'show velad version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                install)
                    _arguments \
                        '--cluster-only[start cluster without installing vela-core]' \
                        '--database-endpoint=[external database endpoint]:dsn:' \
                        '--bind-ip=[additional hostname or IP to bind]:ip:' \
                        '--node-ip=[public IP of the node]:ip:' \
                        '--token=[cluster identification token]:token:' \
                        '--name=[cluster/node name]:name:' \
                        '--dry-run[dry-run the install process]' \
                        '*--set=[set key=value (comma-separated)]:kv:' \
                        '(-n --namespace)'{-n+,--namespace=}'[KubeVela Core namespace]:ns:' \
                        '(-d --detail)'{-d,--detail}'[show detailed installation log]' \
                        '(-r --reuse)'{-r,--reuse}'[reuse previous values]' ;;
                join)
                    _arguments \
                        '--token=[cluster identification token]:token:' \
                        '(-n --worker-name)'{-n+,--worker-name=}'[worker node name]:name:' \
                        '--master-ip=[public IP of the master node]:ip:' \
                        '--dry-run[dry-run the join process]' ;;
                kubeconfig)
                    _arguments \
                        '(-n --name)'{-n+,--name=}'[cluster name (mac/win only)]:name:' \
                        '--internal[print kubeconfig for Docker network]' \
                        '--external[print kubeconfig usable on remote machines]' \
                        '--host[print kubeconfig path on this machine]' ;;
                token)
                    _arguments \
                        '(-n --name)'{-n+,--name=}'[cluster name]:name:' ;;
                uninstall)
                    _arguments \
                        '(-n --name)'{-n+,--name=}'[control plane name]:name:' ;;
            esac
            ;;
    esac
}

_velad "$@"
