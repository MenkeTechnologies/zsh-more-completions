#compdef tensor2metric
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/tensor2metric.html
# Source: MRtrix3/mrtrix3 cmd/tensor2metric.cpp — derive DTI scalars/eigenvalues from tensor image (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-adc+[apparent diffusion coefficient output]:image:_files' \
    '-fa+[fractional anisotropy output]:image:_files' \
    '-ad+[axial diffusivity (largest eigenvalue) output]:image:_files' \
    '-rd+[radial diffusivity output]:image:_files' \
    '-cl+[linearity output]:image:_files' \
    '-cp+[planarity output]:image:_files' \
    '-cs+[sphericity output]:image:_files' \
    '-value+[selected eigenvalues output]:image:_files' \
    '-vector+[selected eigenvectors output]:image:_files' \
    '-num+[eigenvalue/vector indices (comma-separated, 1=largest)]:sequence:_default' \
    '-modulate+[modulate vectors by]:choice:(none fa eigval)' \
    '-mask+[restrict to mask voxels]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '1:tensor image:_files -g "*.{nii,nii.gz,mif}"' \
    && ret=0

return ret
