#compdef zksync-cli
# Documentation: https://github.com/matter-labs/zksync-cli (src/index.ts)
# Reference accessed: 2026-05-29
# ZKsync Era CLI for development, contracts, transactions, wallet, bridge.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'dev:development environment commands (start/stop chains, manage modules)'
  'contract:smart contract operations (read, write, encode-data)'
  'transaction:transaction management (info)'
  'create:scaffold a new project'
  'wallet:wallet operations (balance, transfer, withdraw)'
  'bridge:bridge funds between L1 and L2 (deposit, withdraw, withdraw-finalize)'
  'config:CLI configuration management (chains)'
  'help:show help for a subcommand'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'zksync-cli subcommand' _subcmds && ret=0
    ;;
  args)
    local -a _dev _contract _transaction _wallet _bridge _config
    _dev=(
      'config:configure the local environment'
      'start:start a local zksync node'
      'stop:stop a local zksync node'
      'restart:restart a local zksync node'
      'logs:tail logs from a running module'
      'clean:wipe state from a module'
      'install:install a custom module'
      'modules:list available modules'
      'update:update modules'
    )
    _contract=(
      'read:read state from a deployed contract'
      'write:write to a deployed contract'
      'encode-data:encode call data for a contract method'
    )
    _transaction=(
      'info:show transaction info'
    )
    _wallet=(
      'balance:show wallet balance'
      'transfer:transfer tokens to another address'
      'withdraw:withdraw tokens from L2'
    )
    _bridge=(
      'deposit:deposit funds from L1 to L2'
      'withdraw:initiate L2 -> L1 withdrawal'
      'withdraw-finalize:finalize an L2 -> L1 withdrawal'
    )
    _config=(
      'chains:manage saved chain configurations'
    )
    case $line[1] in
      dev) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'dev' _dev && ret=0 ;;
      contract) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'contract' _contract && ret=0 ;;
      transaction) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'transaction' _transaction && ret=0 ;;
      wallet) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'wallet' _wallet && ret=0 ;;
      bridge) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'bridge' _bridge && ret=0 ;;
      config) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'config' _config && ret=0 ;;
    esac
    ;;
esac

return ret
