#compdef vgchange
# _vgchange — change volume group attributes (LVM2); activate/deactivate, tag, change resource limits
# upstream: https://gitlab.com/lvmteam/lvm2

_vgchange() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-a --activate)'{-a,--activate}'+[activate]:mode:(y n ay)' \
        '(-K --ignoreactivationskip)'{-K,--ignoreactivationskip}'[ignore activation skip]' \
        '(-c --clustered)'{-c,--clustered}'+[clustered]:bool:(y n)' \
        '(-l --logicalvolume)'{-l,--logicalvolume}'+[max lvs]:n:' \
        '(-p --maxphysicalvolumes)'{-p,--maxphysicalvolumes}'+[max pvs]:n:' \
        '(-s --physicalextentsize)'{-s,--physicalextentsize}'+[extent size]:size:' \
        '(-u --uuid)'{-u,--uuid}'[generate new uuid]' \
        '(-x --resizeable)'{-x,--resizeable}'+[resizable]:bool:(y n)' \
        '--addtag+[add tag]:tag:' \
        '--deltag+[delete tag]:tag:' \
        '--alloc+[allocation policy]:policy:(contiguous cling normal anywhere inherit)' \
        '--systemid+[system id]:str:' \
        '--monitor+[dmeventd monitor]:bool:(y n)' \
        '--poll+[poll]:bool:(y n)' \
        '--refresh[refresh metadata]' \
        '--lockstart[start lockspace]' \
        '--lockstop[stop lockspace]' \
        '--locktype+[lock type]:type:(none clvm dlm sanlock)' \
        '*:vg:'
}

_vgchange "$@"
