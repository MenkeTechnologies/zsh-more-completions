#compdef yek
# Documentation: https://github.com/bodo-run/yek
# Reference accessed: 2026-05-22

# Zsh completion for yek - serialize repo content for LLM context

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-m --max-tokens)'{-m,--max-tokens}'[maximum token count]:tokens' \
  '(-o --output)'{-o,--output}'[output file path]:file:_files' \
  '--tokens-per-file[token limit per file]:tokens' \
  '--ignore-patterns[glob patterns to ignore]:patterns' \
  '(-c --config)'{-c,--config}'[config file path]:file:_files' \
  '--stream[stream output to stdout]' \
  '--max-files[max number of files to process]:count' \
  '1:directory:_directories' && ret=0

return ret
