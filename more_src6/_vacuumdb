#compdef vacuumdb
# Documentation: https://www.postgresql.org/docs/current/app-vacuumdb.html
# Source: postgres/postgres src/bin/scripts/vacuumdb.c — garbage-collect and analyze a PostgreSQL database (C, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-V,--version}'[show version]' \
    '(- *)'{-\?,--help}'[show help]' \
    {-h+,--host=}'[server host]:host:_hosts' \
    {-p+,--port=}'[server port]:port:_default' \
    {-U+,--username=}'[connect as user]:user:_users' \
    {-w,--no-password}'[never prompt for password]' \
    {-W,--password}'[force password prompt]' \
    {-e,--echo}'[show commands sent]' \
    {-q,--quiet}'[suppress messages]' \
    {-d+,--dbname=}'[database to vacuum]:db:_default' \
    {-z,--analyze}'[update planner statistics]' \
    {-Z,--analyze-only}'[only analyze, do not vacuum]' \
    {-F,--freeze}'[freeze row transaction info]' \
    {-a,--all}'[vacuum all databases]' \
    '*'{-t+,--table=}'[vacuum only named table]:table:_default' \
    {-f,--full}'[full vacuum]' \
    {-v,--verbose}'[verbose output]' \
    {-j+,--jobs=}'[parallel jobs]:n:_default' \
    {-P+,--parallel=}'[index workers per VACUUM]:n:_default' \
    '*'{-n+,--schema=}'[only this schema]:schema:_default' \
    '*'{-N+,--exclude-schema=}'[exclude schema]:schema:_default' \
    '--maintenance-db=-[alternate maintenance db]:db:_default' \
    '--analyze-in-stages[multi-stage analyze]' \
    '--disable-page-skipping[do not skip pages via VM]' \
    '--skip-locked[skip locked relations]' \
    '--min-xid-age=-[min relfrozenxid age]:n:_default' \
    '--min-mxid-age=-[min relminmxid age]:n:_default' \
    '--no-index-cleanup[do not clean up indexes]' \
    '--force-index-cleanup[force index cleanup]' \
    '--no-truncate[do not truncate]' \
    '--no-process-toast[do not process TOAST]' \
    '--no-process-main[do not process main relation]' \
    '--buffer-usage-limit=-[buffer access strategy size]:size:_default' \
    '--missing-stats-only[analyze only relations lacking stats]' \
    '--dry-run[parse options without executing]' \
    '1::dbname:_default' \
    && ret=0

return ret
