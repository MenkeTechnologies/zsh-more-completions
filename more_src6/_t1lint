#compdef t1lint
# Documentation: t1lint --help (lcdf-typetools)
# Source: lcdf-typetools t1lint — check a PostScript Type 1 font for correctness.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(-q --quiet)'{-q,--quiet}'[do not report errors to stderr]' \
    '(- *)--version[show version]' \
    '*:Type 1 font (PFA / PFB):_files -g "*.{pfa,pfb}"' \
    && ret=0

return ret
