#compdef xprop
# Documentation: https://man.archlinux.org/man/xprop.1.en
# Reference accessed: 2026-05-30
# xprop — display + modify X11 window/font properties. Part of x11-utils.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-help[show command summary]' \
  '(- *)-version[print program version]' \
  '(- *)-grammar[show detailed grammar for all options]' \
  '-id+[select window by ID (decimal or hex)]:id:' \
  '-name+[select window by name]:name:' \
  '-root[target the X root window]' \
  '-font+[display properties of a font instead of a window]:font:' \
  '-frame[look at window manager frame when selecting by hand]' \
  '-len+[read+display at most N bytes of any property]:N:' \
  '-notype[omit property type information from output]' \
  '-fs+[load additional property formats from file]:file:_files' \
  '*-f+[custom format for a property]:atom format [dformat]:' \
  '*-set[set a property value on the window]:property-name value:' \
  '*-remove+[remove a property from the window]:property-name:' \
  '-spy[monitor window properties continuously for change events]' \
  '-display+[X server to connect to]:display:' \
  '*:property atom:' \
  && ret=0

return ret
