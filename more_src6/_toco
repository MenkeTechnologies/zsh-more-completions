#compdef toco
# Documentation: https://github.com/tensorflow/tensorflow/blob/master/tensorflow/lite/python/tflite_convert.py
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# toco: legacy TensorFlow → TFLite converter (driven by tflite_convert.py argparse)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--output_file=[output TFLite file]:file:_files' \
  '--graph_def_file=[input GraphDef .pb]:file:_files' \
  '--saved_model_dir=[input SavedModel directory]:dir:_files -/' \
  '--keras_model_file=[input Keras .h5 model]:file:_files' \
  '--output_format=[output format]:format:(TFLITE GRAPHVIZ_DOT)' \
  '--inference_type=[inference type]:type:(FLOAT QUANTIZED_UINT8 INT8 INT16)' \
  '--inference_input_type=[inference input type]:type:(FLOAT QUANTIZED_UINT8 INT8 INT16)' \
  '--input_arrays=[input arrays]:arrays:' \
  '--input_shapes=[input shapes]:shapes:' \
  '--output_arrays=[output arrays]:arrays:' \
  '--saved_model_tag_set=[SavedModel tag set]:tags:' \
  '--saved_model_signature_key=[SavedModel signature key]:key:' \
  '--mean_values=[mean values]:vals:' \
  '--std_dev_values=[std values]:vals:' \
  '--default_ranges_min=[default range min]:min:' \
  '--default_ranges_max=[default range max]:max:' \
  '--post_training_quantize[post-training quantize]' \
  '--quantize_to_float16[quantize to float16]' \
  '--drop_control_dependency[drop control dependency]' \
  '--reorder_across_fake_quant[reorder across fake quant]' \
  '--change_concat_input_ranges=[change concat input ranges]:bool:(true false)' \
  '--allow_custom_ops[allow custom ops]' \
  '--custom_opdefs=[custom op definitions]:ops:' \
  '--target_ops=[target ops set]:ops:' \
  '--experimental_select_user_tf_ops=[select user TF ops]:ops:' \
  '--dump_graphviz_dir=[graphviz dump dir]:dir:_files -/' \
  '--dump_graphviz_video[dump graphviz video]' \
  '--conversion_summary_dir=[conversion summary dir]:dir:_files -/' \
  '--experimental_new_converter=[use new converter]:bool:(true false)' \
  '--experimental_new_quantizer=[use new quantizer]:bool:(true false)' \
  '--enable_v1_converter[enable v1 converter]' \
  '*::toco args:_files' && ret=0
return ret
