#compdef write-good
# Documentation: https://github.com/btford/write-good
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (bin/write-good.js).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--parse[parse-happy output with Unix exit codes]' \
  '--text=[check a string of text]:text' \
  '--checks=[load a custom checks module]:module:' \
  '--passive[enable only passive voice check]' \
  '--no-passive[disable passive voice check]' \
  '--illusion[enable only lexical illusion check]' \
  '--no-illusion[disable lexical illusion check]' \
  '--so[enable only "so" at sentence start check]' \
  '--no-so[disable "so" at sentence start check]' \
  '--thereIs[enable only "there is/there are" check]' \
  '--no-thereIs[disable "there is/there are" check]' \
  '--weasel[enable only weasel words check]' \
  '--no-weasel[disable weasel words check]' \
  '--adverb[enable only adverb check]' \
  '--no-adverb[disable adverb check]' \
  '--tooWordy[enable only too wordy check]' \
  '--no-tooWordy[disable too wordy check]' \
  '--cliches[enable only cliches check]' \
  '--no-cliches[disable cliches check]' \
  '--yes-eprime[enable E-Prime check (opt-in)]' \
  '*:file:_files' && ret=0

return ret
