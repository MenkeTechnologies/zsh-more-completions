#compdef veryl
# Documentation: https://github.com/dalance/veryl/blob/master/crates/veryl/src/main.rs
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--verbose[enable debug-level logging]' \
  '--trace[enable trace-level logging]' \
  '--quiet[suppress info-level messages]' \
  '--completion=[generate shell completions]:shell:(bash zsh fish elvish powershell)' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'new:create a new project'
      'init:initialize a project'
      'fmt:format code'
      'check:check project validity'
      'build:compile the project'
      'clean:remove build artifacts'
      'update:update dependencies'
      'publish:publish to registry'
      'migrate:migrate project files'
      'doc:generate documentation'
      'metadata:display project metadata'
      'dump:output internal structures'
      'test:run tests'
      'synth:synthesize hardware'
      'translate:convert to other languages'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (new|init)
        _arguments '1:project name:' && ret=0
        ;;
      (fmt|check|build)
        _arguments '*:files:_files -g "*.veryl"' && ret=0
        ;;
      (*)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
