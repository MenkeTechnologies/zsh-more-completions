#compdef webcat
# ============================================================================
# _webcat — zsh completion for webcat, p2p pipe over WebRTC
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/mafintosh/webcat
#   Author     : Mathias Buus (@mafintosh)
#   License    : MIT
#   Stars      : 453
#   Language   : JavaScript (Node.js)
#   npm        : webcat v3.0.0
#   Binary     : webcat  (package.json bin → ./bin.js)
#
# WHAT IT IS
#   webcat is a "mad science p2p pipe across the web using WebRTC that uses
#   your GitHub private/public key for authentication and a signalhub for
#   discovery."  It establishes a peer-to-peer pipe between two GitHub users
#   over WebRTC, exchanges signaling metadata via a public signalhub server,
#   and authenticates both peers by verifying that each holds the SSH private
#   key corresponding to the SSH public keys published on their GitHub
#   profile (via mafintosh's `ghsign` library).  Stdio is then piped end-to-
#   end through the WebRTC data channel — `pump(process.stdin, webcat(user),
#   process.stdout)`.
#
# CLI ARGUMENT GRAMMAR  (verbatim from bin.js minimist parser)
#   webcat [options] <receivers-github-username>
#
#   Options (single-dash short aliases mapped in minimist.alias):
#     -c, --configure         interactive setup; writes ~/.config/webcat.json
#                             with your GitHub username, then exits
#     -u, --username <user>   override stored GitHub username for this call
#     -s, --signalhub <url>   signalhub server URL for WebRTC signaling
#                             (default: built-in list)
#     -v, --version           print package.json version and exit
#
#   Configuration:
#     ~/.config/webcat.json    JSON file storing { "username": "<github-user>" }
#                              written on first run or on --configure
#
# AXIS / CORPUS POSITION
#   Direct dependency on TWO WebRTC libraries declared in package.json:
#     "simple-peer": "^5.1.0"    — Feross Aboukhadijeh's WebRTC wrapper
#     "wrtc": "0.0.55"           — node-webrtc native binding to libwebrtc
#   Both are real Node.js WebRTC poles.  Verified via:
#     gh api repos/mafintosh/webcat/contents/package.json
#       → "dependencies" block
#   This entry is the TS-Node=111 leader bump that CLOSES Axis 56
#   (WebRTC Media Library) at 1/1/1 three-language symmetry:
#     Rust   = webrtc-rs   (R813, `whipinto`, live777 workspace)
#     Go     = pion/webrtc (R814, `weron`, pojntfx overlay network)
#     TS-Node = simple-peer + wrtc (R815, `webcat`, mafintosh p2p pipe)
#   Reaches the triple-111 landmark Rust=Go=TS-Node=111.
#
#   No completion for `webcat` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_webcat() {
    _arguments -s \
        '(-c --configure)'{-c,--configure}'[interactive setup; writes ~/.config/webcat.json and exits]' \
        '(-u --username)'{-u+,--username=}'[override stored GitHub username for this call]:github username:' \
        '(-s --signalhub)'{-s+,--signalhub=}'[signalhub server URL for WebRTC signaling]:signalhub URL:_urls' \
        '(- *)'{-v,--version}'[print package.json version and exit]' \
        '*:receivers github username:'
}

_webcat "$@"
