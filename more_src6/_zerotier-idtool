#compdef zerotier-idtool
# Documentation: https://github.com/zerotier/ZeroTierOne/blob/main/one.cpp (idtoolPrintHelp)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local -a subcommands

subcommands=(
  'generate:generate identity (and optional vanity prefix)'
  'validate:validate an identity'
  'getpublic:print public component of identity'
  'sign:sign a file'
  'verify:verify a signed file'
  'initmoon:initialize a moon definition'
  'genmoon:generate signed moon from JSON'
)

_arguments -s \
  "1:idtool subcommand:->sub" \
  '*::arg:_files'

[[ $state == sub ]] && _describe -t subcommands 'idtool subcommand' subcommands
