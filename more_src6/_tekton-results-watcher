#compdef tekton-results-watcher
# _tekton-results-watcher — Tekton Results TaskRun/PipelineRun watcher (tektoncd/results)
# upstream: https://github.com/tektoncd/results
# Flags from cmd/watcher/main.go on tip.

_tekton-results-watcher() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-api_addr=[Results API server host\:port]:host\:port:' \
        '-auth_mode=[authentication mode]:mode:(google)' \
        '-disable_crd_update=[skip CRD annotation update on reconcile]:bool:(true false)' \
        '-token=[authentication token]:token:' \
        '-completed_run_grace_period=[grace period before deleting completed Runs]:dur:' \
        '-threadiness=[goroutines per controller]:n:' \
        '-qps=[Kubernetes client QPS]:f:' \
        '-burst=[Kubernetes client burst]:n:' \
        '-logs_api=[enable sending logs (if server supports)]:bool:(true false)' \
        '-logs_timestamps=[include timestamps when collecting logs]:bool:(true false)' \
        '-label_selector=[deletion label selector]:sel:' \
        '-requeue_interval=[requeue wait after non-matching events]:dur:' \
        '-namespace=[restrict watcher to a namespace]:ns:' \
        '-summary_labels=[comma-sep label keys included in result summary]:list:' \
        '-summary_annotations=[comma-sep annotation keys included in result summary]:list:' \
        '-check_owner=[honor owner references when deleting]:bool:(true false)' \
        '-update_log_timeout=[UpdateLog operation timeout]:dur:' \
        '-dynamic_reconcile_timeout=[dynamic reconciler timeout]:dur:' \
        '-store_event=[store run-related Events]:bool:(true false)' \
        '-disable_storing_incomplete_runs=[store only completed Runs]:bool:(true false)' \
        '-v[klog verbosity level]:n:'
}

_tekton-results-watcher "$@"
