#compdef ttf2tfm
# Documentation: ttf2tfm --help (TeX Live)
# Source: TeX ttf2tfm — convert a TrueType font table to TeX font metrics (TFM).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-c+[smallcaps height factor (default 0.8)]:n:' \
    '-e+[widen by factor (default 1.0)]:n:' \
    '-E+[TTF encoding ID (default 1)]:n:' \
    '-f+[font index in a TTC (default 0)]:n:' \
    '-l[create 1st/2nd byte ligatures in subfonts]' \
    '-L+[ligature subfonts from file]:ligfile:_files -g "*.sfd"' \
    '(-n -N)-n[use PS names of TrueType font]' \
    '(-n -N)-N[use only PS names; no cmap]' \
    '-o+[make OVP for conversion to OVF/OFM]:file:_files' \
    '-O[octal codes in VPL output]' \
    '-p+[TTF->TeX mapping encoding file]:encfile:_files -g "*.enc"' \
    '-P+[TTF platform ID (default 3)]:n:' \
    '-q[no informational output]' \
    '*-r[replace glyph name OLDNAME with NEWNAME]:old:new:' \
    '-R+[glyph replacement names file]:rplfile:_files -g "*.rpl"' \
    '-s+[slant amount]:real:' \
    '-t+[VPL output encoding]:encfile:_files -g "*.enc"' \
    '-T+[shortcut for -p + -t]:encfile:_files -g "*.enc"' \
    '-u[output only chars from encodings]' \
    '-v+[make VPL file for VF conversion]:file:_files' \
    '-V+[like -v but synthesize smallcaps]:scfile:_files' \
    '-w[generate subfont enc vectors with glyph indices]' \
    '-x[rotate subfont glyphs by 90 degrees]' \
    '-y+[move rotated glyphs down by factor (default 0.25)]:n:' \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '1:TrueType font (.ttf or .ttc):_files -g "*.{ttf,ttc}"' \
    '2:output TFM:_files' \
    && ret=0

return ret
