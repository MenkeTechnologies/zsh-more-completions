#compdef tmt
# Documentation: https://tmt.readthedocs.io/en/stable/overview.html
# Reference accessed: 2026-05-21
# Verified: upstream tmt docs (global options + subcommand list).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--root=[path to metadata tree]:path:_directories' \
  '--verbose[print additional information]' \
  '--debug[turn on debugging output]' \
  '--quiet[disable output]' \
  '--log-topic=[enable topic logging]:topic:' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'run:run tests'
      'tests:tests management'
      'test:tests management (alias)'
      'plans:plans management'
      'plan:plans management (alias)'
      'stories:stories management'
      'story:stories management (alias)'
      'init:initialize a new tree'
      'lint:validate metadata'
      'try:try a test'
      'clean:clean workdir'
      'status:show plan status'
      'about:about tmt'
    )
    _describe -t commands 'tmt command' commands && ret=0
    ;;
esac

return ret
