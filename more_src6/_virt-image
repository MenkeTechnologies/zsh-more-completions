#compdef virt-image
# Documentation: https://manpages.org/virt-image
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above. virt-image is deprecated;
# upstream recommends virt-install instead.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-n --name)'{-n+,--name=}'[guest instance name]:name:' \
  '(-u --uuid)'{-u+,--uuid=}'[guest UUID]:uuid:' \
  '(-r --ram)'{-r+,--ram=}'[memory in MB]:mb:' \
  '--vcpus=[number of virtual CPUs]:n:' \
  '--cpu=[CPU model]:cpu:' \
  '--cpuset=[set of host CPUs]:set:' \
  '--os-type=[OS type]:type:(linux windows generic)' \
  '--os-variant=[OS variant]:variant:' \
  '(-w --network)'{-w+,--network=}'[network connectivity]:net:' \
  '--graphics=[graphical display]:gfx:(vnc spice none)' \
  '--noapic[disable APIC]' \
  '--noacpi[disable ACPI]' \
  '(-p --print)'{-p,--print}'[print XML without creating VM]' \
  '--replace[remove existing guest before install]' \
  '--noreboot[do not autostart]' \
  '(-d --debug)'{-d,--debug}'[debug logging]' \
  '*:image XML:_files -g "*.xml"' && ret=0
return ret
