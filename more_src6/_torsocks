#compdef torsocks
# _torsocks — Tor torsocks (LD_PRELOAD wrapper that routes a child process's network IO through a Tor SOCKS proxy; -i show, -q quiet, -d debug, -p use TCP-only mode, --version, --config TORSOCKS_CONF override, on/off subcommand to toggle the active shell; positional argument is the command to run)
# upstream: https://gitlab.torproject.org/tpo/core/torsocks
# Flags from torproject.org/torsocks src/bin/torsocks.in on tip.

_torsocks() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-i[show config + exit]' \
        '-q[quiet]' \
        '-d[debug]' \
        '-p[tcp-only]' \
        '--config+[config file]:file:_files' \
        '1::action:(on off show)' \
        '*::command:_command_names -e'
}

_torsocks "$@"
