#compdef wasm-interp
# _wasm-interp — WABT WebAssembly interpreter (WABT project, C++); decode and run a wasm binary file
# upstream: https://github.com/WebAssembly/wabt

_wasm-interp() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--enable-exceptions[enable exceptions proposal]' \
        '--disable-mutable-globals[disable mutable globals]' \
        '--disable-saturating-float-to-int[disable saturating float to int]' \
        '--disable-sign-extension[disable sign extension]' \
        '--disable-simd[disable simd]' \
        '--enable-threads[enable threads]' \
        '--enable-function-references[enable function references]' \
        '--enable-multi-memory[enable multi memory]' \
        '--enable-tail-call[enable tail call]' \
        '--enable-bulk-memory[enable bulk memory]' \
        '--enable-reference-types[enable reference types]' \
        '--enable-annotations[enable annotations]' \
        '--enable-code-metadata[enable code metadata]' \
        '--enable-gc[enable GC]' \
        '--enable-memory64[enable memory64]' \
        '--enable-all[enable all features]' \
        '--run-all-exports[run all exports]' \
        '--host-print[host print]' \
        '--trace[trace execution]' \
        '--value-stack-size=+[value stack size]:n:' \
        '--call-stack-size=+[call stack size]:n:' \
        '*:file:_files -g "*.wasm"'
}

_wasm-interp "$@"
