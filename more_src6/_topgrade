#compdef topgrade
# Documentation: https://github.com/topgrade-rs/topgrade/blob/main/src/config.rs
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for topgrade - a command to upgrade all the things

_arguments -s -S \
  '(-n --dry-run)'{-n,--dry-run}'[print steps without executing]' \
  '*--only=[only perform specific steps]:step' \
  '*--disable=[disable specific steps]:step' \
  '(-y --yes)'{-y,--yes}'[do not ask for confirmations]' \
  '--no-retry[do not retry failed steps (deprecated/hidden)]' \
  '--no-ask-retry[do not ask to retry failed steps]' \
  '--auto-retry=[automatically retry N times]:count' \
  '--skip-notify[skip notification at end of run (hidden)]' \
  '--notify-end=[notify at end of run]:choice:(true false auto)' \
  '(-c --cleanup)'{-c,--cleanup}'[cleanup temporary or old files]' \
  '--config=[path to configuration file]:file:_files' \
  '--config-reference[print the default configuration]' \
  '--edit-config[open the config in $EDITOR]' \
  '(-k --keep)'{-k,--keep}'[keep terminal window open at end of run]' \
  '(-t --tmux)'{-t,--tmux}'[run updates with tmux]' \
  '--no-tmux[do not run with tmux]' \
  '(-r --run-type)'{-r,--run-type=}'[run type]:type:(dry wet)' \
  '*--custom-commands=[run custom commands by name]:name' \
  '*--env=[set environment variables]:NAME=VALUE' \
  '--disable-predefined-git-repos[disable predefined git repos]' \
  '--remote-host-limit=[limit remote hosts by regex]:regex' \
  '--show-skipped[show skipped steps]' \
  '--allow-root[allow running as root]' \
  '--sudoloop[keep sudo credentials alive]' \
  '--sudoloop-interval=[sudoloop interval]:seconds' \
  '--log-filter=[log filter directive]:filter' \
  '--no-self-update[skip self-update]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-h --help)'{-h,--help}'[print help]'
