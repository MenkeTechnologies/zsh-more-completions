#compdef throttled lenovo_fix
# Documentation: https://github.com/erpalma/throttled
# Reference accessed: 2026-05-21
# Verified: upstream throttled.py argparse at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--monitor)--debug[add debug info and additional checks]' \
  '(--debug)--monitor=[realtime monitoring of throttling causes (default 1s)]:interval:' \
  '--config=[override default config file path]:file:_files' \
  '--force[bypass compatibility checks (EXPERTS only)]' \
  '--log=[log to file instead of stdout]:file:_files' && ret=0

return ret
