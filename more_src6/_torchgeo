#compdef torchgeo torchgeo-cli
# _torchgeo — Microsoft torchgeo geospatial deep learning library with datasets samplers transforms models pretrained weights (microsoft team, Python); jsonargparse
# upstream: https://github.com/microsoft/torchgeo

_torchgeo() {
    local -a sub=(
        'fit:train a model'
        'validate:run validation'
        'test:run test set evaluation'
        'predict:run inference'
        'tune:hyperparameter tuning'
        'datasets:dataset subcommands'
        'models:model subcommands'
        'transforms:transform subcommands'
        'samplers:sampler subcommands'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--print-config[print effective config]' \
        '--data.root=+[dataset root]:dir:_files -/' \
        '--data.batch-size=+[N]:n:' \
        '--data.num-workers=+[N]:n:' \
        '--data.patch-size=+[N]:n:' \
        '--data.length=+[N]:n:' \
        '--trainer.accelerator=+[accelerator]:a:(gpu cpu tpu mps auto)' \
        '--trainer.devices=+[N or list]:str:' \
        '--trainer.max-epochs=+[N]:n:' \
        '--trainer.precision=+[precision]:p:(16 32 64 bf16 16-mixed bf16-mixed)' \
        '--trainer.strategy=+[strategy]:str:' \
        '--trainer.default-root-dir=+[work dir]:dir:_files -/' \
        '--seed-everything=+[seed]:n:' \
        '--model.class-path=+[model class]:str:' \
        '--data.class-path=+[data module class]:str:' \
        '--optimizer.class-path=+[optimizer class]:str:' \
        '--lr-scheduler.class-path=+[lr scheduler class]:str:' \
        '--ckpt-path=+[checkpoint]:file:_files -g "*.ckpt"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'torchgeo subcommand' sub ;;
        args)
            case $words[1] in
                fit|validate|test|predict) _arguments \
                    '--data=+[data module]:d:(BigEarthNetDataModule ChesapeakeCVPRDataModule COWCCountingDataModule COWCDetectionDataModule CycloneDataModule ETCI2021DataModule EuroSATDataModule FAIR1MDataModule FireRiskDataModule InriaAerialImageLabelingDataModule LandCoverAIDataModule LEVIRCDPlusDataModule LoveDADataModule NAIPChesapeakeDataModule OSCDDataModule PotsdamDataModule RESISC45DataModule SeasonalContrastS2DataModule SEN12MSDataModule So2SatDataModule SpaceNet1DataModule TropicalCycloneDataModule UCMercedDataModule USAVarsDataModule Vaihingen2DDataModule)' \
                    '--model=+[model]:m:(ClassificationTask SemanticSegmentationTask RegressionTask BYOLTask MoCoTask SimCLRTask ChangeDetectionTask ObjectDetectionTask InstanceSegmentationTask PointDetectionTask)' ;;
                datasets) _arguments '1:datasets cmd:(list show download stats)' ;;
                models) _arguments '1:models cmd:(list show)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_torchgeo "$@"
