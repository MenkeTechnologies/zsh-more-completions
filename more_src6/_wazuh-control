#compdef wazuh-control
# Documentation: https://documentation.wazuh.com/current/user-manual/reference/tools/wazuh-control.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-j[JSON output (server installations)]' \
  '-v[print version value]' \
  '-r[print revision value]' \
  '-t[print installation type value]' \
  '1:action:->action' \
  '*::sub:->sub' && ret=0

case $state in
  (action)
    local -a actions=(
      'start:Start the Wazuh processes'
      'stop:Stop the Wazuh processes'
      'restart:Restart the Wazuh processes'
      'reload:Restart all processes except wazuh-execd'
      'status:Show which processes are running'
      'info:Print installation type, version, revision'
      'enable:Enable debug mode (use: enable debug)'
      'disable:Disable debug mode (use: disable debug)'
    )
    _describe -t actions 'wazuh-control action' actions && ret=0
    ;;
  (sub)
    case $line[1] in
      (enable|disable)
        _values 'mode' 'debug' && ret=0
        ;;
    esac
    ;;
esac

return ret
