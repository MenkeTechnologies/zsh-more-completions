#compdef xctrace
# _xctrace — Apple xctrace Xcode-instruments command-line interface CLI (Apple, Objective-C); custom argparse
# upstream: https://developer.apple.com/xcode/

_xctrace() {
    local -a sub=(
        'record:record a trace'
        'export:export trace to XML or other format'
        'attach:attach to running process for live record'
        'help:show help'
        'version:show version'
        'list:list devices/templates'
        'symbolicate:symbolicate trace data'
        'replace:replace bundle in trace'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'xctrace subcommand' sub ;;
        args)
            case $words[1] in
                record) _arguments \
                    '--template=+[template]:str:' \
                    '-t+[template]:str:' \
                    '--output=+[output trace]:file:_files -g "*.trace"' \
                    '-o+[output trace]:file:_files -g "*.trace"' \
                    '--time-limit=+[time limit]:str:' \
                    '-l+[time limit]:str:' \
                    '--device=+[device id]:str:' \
                    '-d+[device id]:str:' \
                    '--target-stdout=+[stdout]:file:_files' \
                    '--target-stderr=+[stderr]:file:_files' \
                    '--env=+[env]:str:' \
                    '--launch=+[app path]:file:_files' \
                    '--attach=+[pid]:pid:_pids' \
                    '--all-processes[all processes]' \
                    '--package=+[package]:file:_files' \
                    '--use-tagged-process[use tagged process]' \
                    '--instrument=+[instrument]:str:' \
                    '--data=+[data spec]:str:' \
                    '--allowed-name=+[allowed proc name]:str:' \
                    '--required-name=+[required proc name]:str:' \
                    '--append-run[append run]' \
                    '--no-append-run[no append run]' \
                    '--starting-condition=+[starting condition]:str:' \
                    '*:arg:' ;;
                export) _arguments \
                    '--input=+[input trace]:file:_files -g "*.trace"' \
                    '-i+[input trace]:file:_files -g "*.trace"' \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '--xpath=+[xpath]:str:' \
                    '--har[HAR format]' \
                    '--toc[table of contents]' \
                    '--type=+[type]:t:(json yaml csv pdf xml)' ;;
                list) _arguments \
                    '1:cmd:(devices templates instruments)' ;;
                symbolicate) _arguments \
                    '--input=+[input trace]:file:_files' \
                    '-i+[input trace]:file:_files' \
                    '--dsym=+[dsym]:dir:_files -/' \
                    '--symbol-path=+[symbol path]:list:_files -/' ;;
                attach) _arguments \
                    '--pid=+[pid]:pid:_pids' \
                    '--name=+[process name]:str:' ;;
            esac
            ;;
    esac
}

_xctrace "$@"
