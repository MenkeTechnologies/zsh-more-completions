#compdef transition-check
# Documentation: https://manpages.debian.org/transition-check
# Source: debian/devscripts scripts/transition-check.pl — check packages against ongoing Debian transitions (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '*'{-f+,--filename=}'[transition file to check]:file:_files' \
    '*:source package:_default' \
    && ret=0

return ret
