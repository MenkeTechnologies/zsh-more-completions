#compdef viddy
# Documentation: https://github.com/sachaos/viddy
# Reference accessed: 2026-05-21
# Verified: sachaos/viddy@master src/cli.rs (clap derive struct Cli).
# Removed from prior file: -v/--version (clap auto, not in struct under
# that long name — version is auto, but no -v alias declared), -r alias
# (does not exist), --no-bell (does not exist), --pty (does not exist),
# --history-limit (does not exist).

_arguments -s -S \
  '(-n --interval)'{-n,--interval}'[seconds to wait between updates (>= 100ms)]:duration:' \
  '(-d --differences)'{-d,--differences}'[highlight changes between updates]' \
  '(-D --deletion-differences)'{-D,--deletion-differences}'[highlight deletion changes between updates]' \
  '(-p --precise)'{-p,--precise}'[attempt run command in precise intervals]' \
  '(-t --no-title)'{-t,--no-title}'[turn off header]' \
  '(-w --unfold)'{-w,--unfold}'[turn off line wrapping]' \
  '--shell[shell (default: sh / cmd on Windows)]:shell:_command_names' \
  '(-s --skip-empty-diffs)'{-s,--skip-empty-diffs}'[skip snapshots with no changes in history]' \
  '*--shell-options[additional shell options]:options:' \
  '(-b --bell)'{-b,--bell}'[ring terminal bell on changes between updates]' \
  '(-x --exec)'{-x,--exec}'[pass command to exec instead of "sh -c"]' \
  '--debug[debug mode]' \
  '--save[path to backup file (else temporary)]:file:_files' \
  '--disable_auto_save[disable automatic save]' \
  '--disable_mouse[stop handling mouse events]' \
  '--load[path to backup file (alias --lookback)]:file:_files' \
  '--lookback[path to backup file]:file:_files' \
  '--help[show help]' \
  '--version[show version]' \
  '*::command:_command_names -e'
