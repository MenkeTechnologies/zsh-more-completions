#compdef tsc-alias
# _tsc-alias — TypeScript path alias resolver for compiled output
# upstream: https://github.com/justkey007/tsc-alias

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-p --project)'{-p+,--project=}'[path to tsconfig.json]:file:_files' \
  '--dir=[output directory to process]:directory:_directories' \
  '--outDir=[output directory override]:directory:_directories' \
  '--resolve-full-paths[resolve full file paths including extensions]' \
  '--resolve-full-extension=[extension for full path resolution]:ext:(.js .mjs .cjs)' \
  '(-w --watch)'{-w,--watch}'[watch for file changes]' \
  '--silent[suppress console output]' \
  '--verbose[verbose output]' \
  '--replacer=[path to custom replacer module]:file:_files' \
  '--output[print output instead of writing to files]' && ret=0

return ret
