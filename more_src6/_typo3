#compdef typo3 typo3console typo3-console
# _typo3 — TYPO3 GmbH typo3 console CLI for managing TYPO3 v9+ CMS installations running scheduler tasks installing extensions warming caches database migrations on the TYPO3 Symfony Console framework (typo3 team, PHP); Symfony Console
# upstream: https://github.com/TYPO3/typo3

_typo3() {
    local -a sub=(
        'list:list commands'
        'help:show help'
        'install:install operations'
        'database:database operations'
        'cache:cache operations'
        'extension:extension operations'
        'scheduler:scheduler operations'
        'site:site operations'
        'language:language operations'
        'configuration:configuration operations'
        'redirects:redirect operations'
        'backend:backend operations'
        'core:core operations'
        'mailer:mailer operations'
        'workspace:workspace operations'
        'syslog:syslog operations'
        'completion:generate shell completion'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n[no interaction]' \
        '--no-interaction[no interaction]' \
        '--ansi[force ansi]' \
        '--no-ansi[disable ansi]' \
        '-e+[application environment]:e:(Default Production Development Testing)' \
        '--env=+[application environment]:e:(Default Production Development Testing)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'typo3 subcommand' sub ;;
        args)
            case $words[1] in
                cache) _arguments \
                    '1:action:(flush warmup flushgroup flushtags)' \
                    '--group=+[g]:g:(all pages system di assets)' ;;
                extension) _arguments \
                    '1:action:(activate deactivate install uninstall setup setupall list dumpautoload removeinactive)' \
                    '*:extension key:' ;;
                scheduler) _arguments \
                    '1:action:(run list)' \
                    '--task-uid=+[N]:n:' ;;
                site) _arguments \
                    '1:action:(list show)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_typo3 "$@"
