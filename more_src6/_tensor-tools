#compdef tensor-tools
# Documentation: https://github.com/huggingface/candle/blob/main/tensor-tools/src/main.rs
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for tensor-tools (Candle ML utility)

local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'ls:list tensor information from files'
  'print:display tensor contents'
  'quantize:quantize a model'
  'dequantize:convert GGUF to safetensors'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[Show help message]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd) _describe -t commands "tensor-tools command" commands && ret=0 ;;
  (args)
    case $words[1] in
      (ls)
        _arguments \
          '--format=[file format]:format:' \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '*:input file:_files' && ret=0
        ;;
      (print)
        _arguments \
          '--format=[file format]:format:' \
          '--full[show complete tensor content]' \
          '--line_width=[output line width]:width:' \
          '1:input file:_files' \
          '*:tensor name:' && ret=0
        ;;
      (quantize)
        _arguments \
          '--quantization=[quantization type]:type:(q4_0 q4_1 q5_0 q5_1 q8_0 q8_1 q2k q3k q4k q5k q6k q8k f16 f32)' \
          '--out_file=[output GGUF file]:file:_files' \
          '--mode=[which tensors to quantize]:mode:(llama)' \
          '*:input safetensors:_files' && ret=0
        ;;
      (dequantize)
        _arguments \
          '--out_file=[output safetensors file]:file:_files' \
          '1:input GGUF file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
