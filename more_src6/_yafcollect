#compdef yafcollect ipfixDump yafzcbalance
# Documentation: upstream src/yafcollect.c, scripts/ipfixDump.pod,
# scripts/yafzcbalance.pod at github.com/britram/cert-netsa-yaf and
# github.com/yaf-project/yaf
# Reference accessed: 2026-05-30 via gh api inspection of
# Makefile.am bin_PROGRAMS declarations + POD OPTIONS sections.
# CERT NetSA YAF R89 — 3-stem multi-binary harvest completing the
# R88 YAF inventory note. Existing _yaf multi-stem covers
# `#compdef yaf yafscii getFlowKeyHash yafMeta2Pcap super_mediator`,
# so this round adds the remaining 3 YAF-side binaries.

case $service in

  yafcollect)
    # IPFIX collector — receives flows from yaf(1) and rotates output.
    # AF_OPTION-based parser (airframe library).
    local -a _transports
    _transports=( tcp udp sctp )
    _arguments -s -S \
      '(-i --in)'{-i,--in}'=[input host (collector source)]:host:_hosts' \
      '(-I --rotate-delay)'{-I,--rotate-delay}'=[output rotate delay (seconds)]:sec:' \
      '--transport=[transport protocol]:proto:($_transports)' \
      '--port=[listen port]:port:' \
      '--tls[enable TLS]' \
      '--tls-ca=[CA file]:file:_files' \
      '--tls-cert=[certificate file]:file:_files' \
      '--tls-key=[private key file]:file:_files' \
      '--tls-pass=[private key passphrase]:passphrase:' \
      '--print-all[print all incoming records]' \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]'
    ;;

  ipfixDump)
    # IPFIX file dumper — pretty-print IPFIX templates and records.
    _arguments -s -S \
      '--in=[input filename (- for stdin)]:file:_files' \
      '--out=[output filename (- for stdout)]:file:_files' \
      '--yaf[include yaf(1) CERT private enterprise information elements]' \
      '--template[only write the templates present]' \
      '--data[only write the data records present]' \
      '--stats[only write overall file statistics]' \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)--version[show version]'
    ;;

  yafzcbalance)
    # PF_RING ZC load balancer for YAF — distributes packets from
    # zero-copy interfaces to multiple yaf(1) consumer processes.
    _arguments -s -S \
      '--in=[interface device(s) (comma-separated, e.g. zc\:eth0)]:device(s):' \
      '--cluster=[unique PF_RING cluster ID]:id:' \
      '--num=[number of yaf processes to distribute to (default 1)]:N:' \
      '--core=[bind yafzcbalance to this CPU core]:core:' \
      '--time=[bind timestamp thread to this CPU core]:core:' \
      '--pidfile=[full path to write PID file]:file:_files' \
      '--daemon[run as a daemon]' \
      '--log=[log file (default stdout)]:file:_files' \
      '--user=[drop to this user after opening capture device]:user:_users' \
      '--stats=[write process statistics every N seconds]:sec:' \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)--version[show version]'
    ;;

esac
