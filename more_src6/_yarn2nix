#compdef yarn2nix

# Zsh completion for yarn2nix - convert yarn.lock to Nix expressions

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-l --lockfile)'{-l,--lockfile}'[path to yarn.lock]:path:_files' \
  '--no-patch[do not include patches]' \
  '--no-nix-prefetch[do not use nix-prefetch-url]'
