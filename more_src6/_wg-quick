#compdef wg-quick
# Documentation: https://manpages.debian.org/bookworm/wireguard-tools/wg-quick.8.en.html
# Reference accessed: 2026-05-30
# wg-quick — Jason Donenfeld's setup wrapper around wg(8). Reads a config
# file (default `/etc/wireguard/<INTERFACE>.conf`) for Address/DNS/MTU/Table/
# Pre+PostUp/Down/SaveConfig directives, then drives wg + ip(8) accordingly.

local curcontext="$curcontext" state line ret=1

local -a _verbs
_verbs=(
  'up:add and set up an interface (Address/MTU/routes/PreUp/PostUp)'
  'down:tear down and remove an interface (PreDown/PostDown)'
  'save:save current interface state into its config file'
  'strip:dump config with wg-quick-only directives stripped (pipe-friendly for `wg setconf`)'
)

# Helper: list interface names from /etc/wireguard/*.conf (strip leading dir
# and trailing .conf so the user-visible candidate is bare interface name).
_wg_quick_interfaces() {
  local -a ifaces
  local cfg
  for cfg in /etc/wireguard/*.conf(N); do
    ifaces+=( "${cfg:t:r}" )
  done
  _describe -t interfaces 'wireguard interface' ifaces
}

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->verb' \
  '2: :->target' \
  && ret=0

case $state in
  verb)
    _describe -t commands 'wg-quick subcommand' _verbs && ret=0
    ;;
  target)
    _alternative \
      'configs:config file:_files -g "*.conf"' \
      'interfaces:interface:_wg_quick_interfaces' \
      && ret=0
    ;;
esac

return ret
