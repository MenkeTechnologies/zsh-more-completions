#compdef xkbprint
# Documentation: xkbprint -help (X.Org)
# Source: print an XKB keyboard description to PostScript / EPS.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-help,-\?}'[show help]' \
    '(-color -mono)-color[use colors from geometry]' \
    '(-color -mono)-mono[ignore geometry colors (default)]' \
    '-dflts[compute defaults for missing components]' \
    '-diffs[only show explicit key definitions]' \
    '-eps[generate an EPS file]' \
    '(-fit -full)-fit[fit keyboard image on page (default)]' \
    '(-fit -full)-full[print keyboard image full sized]' \
    '-grid+[grid resolution in mm]:n:' \
    '-if+[internal font name to dump]:name:' \
    '(-kc -nokc)-kc[print keycodes]' \
    '(-kc -nokc)-nokc[do not print keycodes]' \
    '-label+[label to draw on keys]:what:(none name code symbols)' \
    '-lc+[locale for fonts and symbols]:locale:' \
    '(-level1 -level2)-level1[level 1 PostScript (default)]' \
    '(-level1 -level2)-level2[level 2 PostScript]' \
    '-lg+[keyboard group number for labels]:num:' \
    '-ll+[shift level for labels]:num:' \
    '-n+[number of copies]:num:' \
    '-nkg+[groups to print per key]:num:' \
    '-npk+[keyboards per page]:num:' \
    '-ntg+[total groups to print]:num:' \
    '-o+[output file]:file:_files' \
    '-R-[root directory]::dir:_files -/' \
    '1:input file:_files' \
    '2:output file:_files' \
    && ret=0

return ret
