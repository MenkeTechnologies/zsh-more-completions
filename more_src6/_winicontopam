#compdef winicontopam
# Documentation: man winicontopam (Netpbm)
# Source: convert a Windows .ico file to PAM (with optional AND-mask).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-image -allimages)-image=[image index to extract]:index:' \
    '(-image -allimages)-allimages[extract every image as multi-image PAM]' \
    '-andmasks[also extract AND masks]' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:icon file:_files -g "*.ico"' \
    && ret=0

return ret
