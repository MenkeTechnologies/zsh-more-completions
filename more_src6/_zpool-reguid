#compdef zpool-reguid
# _zpool-reguid — OpenZFS zpool reguid (regenerate the unique pool GUID stored in the labels; useful after cloning a pool so two copies don't collide on import; positional argument is the pool name)
# upstream: https://github.com/openzfs/zfs
# Argument shape from openzfs cmd/zpool/zpool_main.c (zpool_do_reguid) on tip.

_zpool-reguid() {
    _arguments \
        '-g+[specific GUID hex]:guid:' \
        '1:pool:'
}

_zpool-reguid "$@"
