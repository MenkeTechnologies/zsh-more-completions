#compdef ttrpc-aa-client
# _ttrpc-aa-client — Confidential Containers attestation-agent ttRPC test client (GetTee/GetEvidence/GetToken/ExtendRuntimeMeasurement)
# upstream: https://github.com/confidential-containers/guest-components
# Subcommands + flags from attestation-agent/attestation-agent/src/bin/ttrpc-aa-client.rs Cli on tip (clap).

_ttrpc-aa-client() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '(-a --attestation_sock)'{-a,--attestation_sock}'=[attestation ttRPC Unix socket addr]:uri:' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                'get-tee':'get the TEE type'
                'get-evidence':'get attestation evidence'
                'get-token':'get an attestation token'
                'extend-runtime-measurement':'extend a runtime measurement (PCR)'
            )
            _describe -t commands 'ttrpc-aa-client subcommand' subs
            ;;
        args)
            case $line[1] in
                'get-evidence')
                    _arguments \
                        '(-r --runtime_data)'{-r,--runtime_data}'=[base64 runtime data]:b64:'
                    ;;
                'get-token')
                    _arguments \
                        '(-t --token_type)'{-t,--token_type}'=[token type]:type:'
                    ;;
                'extend-runtime-measurement')
                    _arguments \
                        '(-d --domain)'{-d,--domain}'=[domain name]:name:' \
                        '(-o --operation)'{-o,--operation}'=[operation name]:name:' \
                        '(-c --content)'{-c,--content}'=[content name]:name:' \
                        '(-p --pcr)'{-p,--pcr}'=[PCR index]:n:'
                    ;;
            esac
            ;;
    esac
}

_ttrpc-aa-client "$@"
