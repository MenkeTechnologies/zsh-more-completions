#compdef tyk-pump tyk-identity-broker
# Documentation: source-direct extraction from upstream
# TykTechnologies/tyk-pump
#   main.go:                   9 kingpin.Flag(...) declarations.
# TykTechnologies/tyk-identity-broker
#   main.go:                   3 flag.StringVar declarations
#                              (--conf/-c + -p).
# Reference accessed: 2026-05-30 via gh api.
# TykTechnologies R171 — 2-stem multi-binary harvest of the
# Tyk API gateway companion family.  tyk-pump is the analytics-
# pump that drains gateway analytics into MongoDB/Elastic/
# Splunk/etc.; tyk-identity-broker (TIB) is the OIDC/SAML/LDAP
# federation broker.  Sister tools to the already-covered `tyk`
# gateway binary in the corpus.  Sister to the heavily-covered
# L7 proxy stack (caddy/envoy/haproxy/traefik/kong/kongctl etc.)
# and observability/analytics family (mongodump/mongorestore/
# elasticsearch/splunk etc.) already in the corpus.

case $service in

  tyk-pump)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[print help and exit]' \
      '--version[print version and exit]' \
      '(-c --conf)'{-c+,--conf=}'[path to the config file (default pump.conf)]:file:_files' \
      '--demo=[orgID string to generate demo data]:org-id:' \
      '--demo-api=[apiID string to generate demo data]:api-id:' \
      '--demo-api-version=[apiID string to generate demo data]:api-id:' \
      '--demo-track-path=[enable track path in analytics records]:bool:(true false)' \
      '--demo-days=[number of days for analytics records (default 30)]:n:' \
      '--demo-records-per-hour=[records per hour for analytics records (default 0)]:n:' \
      '--demo-future-data=[demo data should be in the future]:bool:(true false)' \
      '--debug[enable debug mode]'
    ;;

  tyk-identity-broker)
    # Go `flag` package: -conf and -c are duplicates per
    # `flag.StringVar(&confFile, "conf", ...)` +
    # `flag.StringVar(&confFile, "c", ...)`.
    _arguments -s -S \
      '(-conf -c --conf --c)'{-conf+,--conf=,-c+,--c=}'[path to the config file (default tib.conf)]:file:_files' \
      '(-p --p)'{-p+,--p=}'[path to the profiles file (default ./profiles.json)]:file:_files -g "*.json"' \
      '(-h --h -help --help)'{-h,--h,-help,--help}'[print help and exit]'
    ;;

esac
