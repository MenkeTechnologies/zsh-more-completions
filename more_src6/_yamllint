#compdef yamllint
# _yamllint — Adrien Vergé's YAML linter (Python; configurable rules for indentation, line length, keys order, truthy values, etc.)
# upstream: https://github.com/adrienverge/yamllint
# Flags from yamllint/cli.py run() on tip (argparse); honors YAMLLINT_CONFIG_FILE / XDG_CONFIG_HOME / project .yamllint config.

_yamllint() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version and exit]' \
        '(-c --config-file -d --config-data)'{-c+,--config-file=}'[path to custom config]:file:_files' \
        '(-c --config-file -d --config-data)'{-d+,--config-data=}'[inline YAML config string]:yaml:' \
        '--list-files[list files that would be linted and exit]' \
        '(-f --format)'{-f+,--format=}'[output format]:fmt:(parsable standard colored github auto)' \
        '(-s --strict)'{-s,--strict}'[treat warnings as errors for exit code]' \
        '--no-warnings[suppress warning-level problems]' \
        '-[read YAML from stdin]' \
        '*:file:_files'
}

_yamllint "$@"
