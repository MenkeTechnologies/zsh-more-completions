#compdef trimgalore
# Documentation: https://github.com/FelixKrueger/TrimGalore/blob/master/Docs/Trim_Galore_User_Guide.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Trim Galore (alternate invocation name) - same options as trim-galore
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-q --quality)'{-q,--quality=}'[quality threshold]:q:' \
  '--phred33[Phred 33]' \
  '--phred64[Phred 64]' \
  '--fastqc[run FastQC after]' \
  '-a[R1 adapter]:seq:' \
  '-a2[R2 adapter]:seq:' \
  '--illumina[Illumina TruSeq adapter]' \
  '--nextera[Nextera adapter]' \
  '--small_rna[Illumina small RNA adapter]' \
  '--stringency=[adapter overlap]:n:' \
  '-e[error rate]:val:' \
  '--length=[min read length]:n:' \
  '--max_n=[max N count]:n:' \
  '--trim-n[trim N from ends]' \
  '-o[output dir]:dir:_files -/' \
  '--gzip[gzip output]' \
  '--paired[paired-end mode]' \
  '--retain_unpaired[keep singletons]' \
  '--clip_R1=[clip R1 5-prime bp]:n:' \
  '--clip_R2=[clip R2 5-prime bp]:n:' \
  '--three_prime_clip_R1=[clip R1 3-prime bp]:n:' \
  '--three_prime_clip_R2=[clip R2 3-prime bp]:n:' \
  '-j[parallel cores]:n:' \
  '--cores=[cores]:n:' \
  '*:FASTQ file:_files -g "*.(fastq|fq|fastq.gz|fq.gz)"' && ret=0
return ret
