#compdef xtts xtts-cli
# _xtts — Coqui XTTS Coqui zero-shot voice-cloning TTS CLI alias (Coqui.ai, Python); custom argparse
# upstream: https://github.com/coqui-ai/TTS

_xtts() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--model_name=+[model name]:str:' \
        '--model_path=+[model path]:dir:_files -/' \
        '--config_path=+[config path]:file:_files' \
        '--checkpoint_dir=+[checkpoint dir]:dir:_files -/' \
        '--vocab_path=+[vocab path]:file:_files' \
        '--text=+[text to synthesize]:str:' \
        '-t+[text to synthesize]:str:' \
        '--language=+[language code]:lang:(en es fr de it pt pl tr ru nl cs ar zh-cn hu ko ja hi)' \
        '-l+[language code]:lang:(en es fr de it pt pl tr ru nl cs ar zh-cn hu ko ja hi)' \
        '--speaker_wav=+[speaker reference wav]:list:_files -g "*.wav"' \
        '-r+[speaker reference wav]:list:_files -g "*.wav"' \
        '--speaker_idx=+[speaker idx]:str:' \
        '--gpt_cond_len=+[gpt cond length]:n:' \
        '--gpt_cond_chunk_len=+[gpt cond chunk length]:n:' \
        '--max_ref_length=+[max ref length seconds]:n:' \
        '--sound_norm_refs[normalize reference]' \
        '--temperature=+[temperature]:f:' \
        '--length_penalty=+[length penalty]:f:' \
        '--repetition_penalty=+[repetition penalty]:f:' \
        '--top_k=+[top k]:n:' \
        '--top_p=+[top p]:f:' \
        '--enable_text_splitting[enable text splitting]' \
        '--num_beams=+[num beams]:n:' \
        '--speed=+[speech speed]:f:' \
        '--out_path=+[output wav]:file:_files -g "*.wav"' \
        '-o+[output wav]:file:_files -g "*.wav"' \
        '--use_deepspeed[use deepspeed]' \
        '--use_cuda[use CUDA]' \
        '--device=+[device]:d:(cpu cuda mps)' \
        '*:arg:'
}

_xtts "$@"
