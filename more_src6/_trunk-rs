#compdef trunk
# _trunk-rs — Trunk WASM web bundler for Rust (trunk-rs/trunk)
# upstream: https://github.com/trunk-rs/trunk

_trunk-rs() {
    local curcontext="$curcontext" state line ret=1

    local -a commands=(
        'build:build the Rust WASM app and all assets'
        'watch:build and watch for changes'
        'serve:build, watch, and serve on a local server'
        'clean:clean output artifacts'
        'config:show Trunk configuration'
        'tools:manage tools used by Trunk'
        'completions:generate shell completions'
    )

    local -a global_flags=(
        '--config=[path to Trunk.toml]:file:_files -g "*.toml"'
        '(-v --verbose)'{-v,--verbose}'[enable verbose output]'
        '(-q --quiet)'{-q,--quiet}'[suppress output]'
        '--help[show help]'
        '--version[show version]'
    )

    _arguments -C \
        $global_flags \
        '1: :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        cmd)
            _describe -t commands 'trunk command' commands && ret=0 ;;
        args)
            local -a build_flags=(
                '--release[build in release mode]'
                '--dist=[output directory]:dir:_directories'
                '--public-url=[public URL base path]:url:'
                '--filehash[enable file hashing]'
                '--no-default-features[disable default features]'
                '--features=[enable specific features]:features:'
                '--target=[target index.html file]:file:_files -g "*.html"'
                '--offline[run without network access]'
                '--frozen[require Cargo.lock is up to date]'
                '--locked[require Cargo.lock is unchanged]'
            )
            case $line[1] in
                build)
                    _arguments $build_flags && ret=0 ;;
                watch)
                    _arguments $build_flags && ret=0 ;;
                serve)
                    _arguments \
                        $build_flags \
                        '--address=[bind address]:address:' \
                        '--port=[listen port]:port:' \
                        '--open[open browser after start]' \
                        '--proxy-backend=[proxy backend URL]:url:' \
                        '--proxy-rewrite=[rewrite URL path]:path:' \
                        '--proxy-ws[enable WebSocket proxy]' && ret=0 ;;
                clean)
                    _arguments '--dist=[output directory]:dir:_directories' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

_trunk-rs "$@"
