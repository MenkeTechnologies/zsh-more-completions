#compdef tekton-triggers-controller
# _tekton-triggers-controller — Tekton Triggers EventListener/Interceptor controller (tektoncd/triggers)
# upstream: https://github.com/tektoncd/triggers
# Flags from cmd/controller/main.go + knative.dev/pkg/injection/sharedmain on tip.

_tekton-triggers-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--el-image=[EventListener Service Pod image]:image:' \
        '--el-port=[EventListener Pod port]:port:' \
        '--el-readtimeout=[EventListener read timeout (s)]:n:' \
        '--el-writetimeout=[EventListener write timeout (s)]:n:' \
        '--el-idletimeout=[EventListener idle timeout (s)]:n:' \
        '--el-timeouthandler=[EventListener handler timeout (s)]:n:' \
        '--el-events=[emit EventListener Kubernetes Events]:val:(enable disable)' \
        '--period-seconds=[liveness/readiness probe interval (s)]:n:' \
        '--failure-threshold=[probe failure threshold]:n:' \
        '--disable-controllers=[comma-sep disabled controllers]:list:' \
        '--disable-ha[disable high-availability/leader election]' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr[log to stderr]'
}

_tekton-triggers-controller "$@"
