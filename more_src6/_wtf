#compdef wtfutil wtf
# Documentation: https://github.com/wtfutil/wtf/blob/master/flags/flags.go
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Flags struct in flags/flags.go (go-flags tags):
#   -c/--config (path to config file)
#   -m/--module (display info about specific module)
#   -p/--profile (profile memory usage)
#   -v/--version (show version info)
#   -h/--help (auto-added by go-flags)
# Positional subcommand: save-secret <service>.
# Removed --opt-in: not in upstream Flags struct.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version info]' \
  '(-c --config)'{-c+,--config=}'[path to config file]:config file:_files' \
  '(-m --module)'{-m+,--module=}'[display info about a specific module]:module:' \
  '(-p --profile)'{-p,--profile}'[profile application memory usage]' \
  '1:command:->commands' \
  '*::arg:_files' && ret=0

case $state in
  commands)
    _values 'wtfutil command' 'save-secret[save a secret into the secret store]' && ret=0
    ;;
esac

return ret
