#compdef vttestserver
# _vttestserver — Vitess local test server
# upstream: https://github.com/vitessio/vitess
# Flags from go/cmd/vttestserver/cli/main.go on tip.

_vttestserver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--port=[base port to listen on]:port:' \
        '--proto-topo=[proto-encoded topology]:proto:' \
        '--schema-dir=[schema directory]:dir:_files -/' \
        '--default-schema-dir=[default schema directory]:dir:_files -/' \
        '--data-dir=[data directory]:dir:_files -/' \
        '--mysql-only=[run MySQL only (no VTGate)]:bool:(true false)' \
        '--persistent-mode=[persistent mode (keep data between runs)]:bool:(true false)' \
        '--initialize-with-random-data=[seed tables with random data]:bool:(true false)' \
        '--rng-seed=[random seed]:n:' \
        '--min-table-shard-size=[min rows per shard]:n:' \
        '--max-table-shard-size=[max rows per shard]:n:' \
        '--mysql-bind-host=[MySQL bind host]:host:' \
        '--vtcombo-bind-host=[vtcombo bind host]:host:' \
        '--extra-my-cnf=[extra my.cnf file]:file:_files' \
        '--cells=[csv of cell names]:csv:' \
        '--keyspaces=[csv of keyspace names]:csv:' \
        '--replica-count=[replicas per shard]:n:' \
        '--rdonly-count=[rdonly tablets per shard]:n:' \
        '--charset=[MySQL charset]:charset:' \
        '--planner-version=[default planner]:planner:(Gen4 Gen4Greedy Gen4Left2Right)' \
        '--snapshot-file=[snapshot to restore]:file:_files' \
        '--enable-system-settings=[allow per-session system settings]:bool:(true false)' \
        '--transaction-mode=[transaction mode]:mode:(MULTI SINGLE TWOPC)' \
        '--queryserver-config-transaction-timeout=[query-server transaction timeout]:dur:' \
        '--tablet-hostname=[tablet hostname]:host:' \
        '--vschema-ddl-authorized-users=[csv of users allowed vschema DDL]:csv:' \
        '--foreign-key-mode=[foreign key handling]:mode:(allow disallow)' \
        '--enable-online-ddl=[allow Online DDL]:bool:(true false)' \
        '--enable-direct-ddl=[allow direct DDL]:bool:(true false)' \
        '--external-topo-implementation=[topology implementation for vtcombo]:impl:' \
        '-v[verbosity level]:n:'
}

_vttestserver "$@"
