#compdef xbps-uhelper
# _xbps-uhelper — XBPS shell-script helper (void-linux/xbps)
# upstream: https://github.com/void-linux/xbps
# Flags + modes from bin/xbps-uhelper/main.c.

_xbps-uhelper() {
    local -a args modes
    modes=(
        'arch:print configured XBPS architecture'
        'binpkgarch:print architecture from binpkg name(s)'
        'binpkgver:print pkgver from binpkg name(s)'
        'cmpver:compare two version strings'
        'getname:print pkgname from pkgvers or dependencies'
        'getpkgdepname:print pkgname from a dependency'
        'getpkgdepversion:print version constraint from a dependency'
        'getpkgname:print pkgname from pkgver'
        'getpkgrevision:print revision from pkgver'
        'getpkgversion:print version from pkgver'
        'getversion:print version from pattern or pkgver'
        'pkgmatch:match pkgver against a dependency pattern'
        'real-version:print version of installed real packages'
        'version:print version of installed packages'
        'getsystemdir:print the system xbps.d directory'
    )
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-V,--version}'[show XBPS version]'
        '(-C --config)'{-C+,--config=}'[path to confdir (xbps.d)]:dir:_files -/'
        '(-d --debug)'{-d,--debug}'[debug mode to stderr]'
        '(-r --rootdir)'{-r+,--rootdir=}'[full path to rootdir]:dir:_files -/'
        '(-v --verbose)'{-v,--verbose}'[verbose messages]'
        "1:mode:(($modes))"
        '*:arg:'
    )
    _arguments -s -S $args
}

_xbps-uhelper "$@"
