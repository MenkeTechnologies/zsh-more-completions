#compdef tcprules
# _tcprules — DJB ucspi-tcp tcprules (compile a textual access-control rule list (from stdin) into a cdb consumed by tcpserver -x / rblsmtpd)
# upstream: https://github.com/schmonz/ucspi-tcp
# Source: tcprules.c on tip; positional only (final cdb path + temporary path).

_tcprules() {
    _arguments \
        '1:rules.cdb:_files' \
        '2:rules.tmp:_files'
}

_tcprules "$@"
