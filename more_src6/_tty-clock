#compdef tty-clock
# Documentation: https://github.com/xorg62/tty-clock
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for tty-clock - terminal clock display

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-i[show tty-clock info]' \
  '-s[show seconds]' \
  '-S[screensaver mode]' \
  '-x[show box border]' \
  '-c[center clock]' \
  '-C+[set color (0-7)]:color:(0 1 2 3 4 5 6 7)' \
  '-b[bold font]' \
  '-B[blinking colon]' \
  '-t[12-hour format]' \
  '-u[UTC time]' \
  '-T+[render clock on specified tty device]:tty:_files -g "/dev/tty*"' \
  '-r[rebound animation]' \
  '-f+[custom date format string]:format' \
  '-d+[redraw delay seconds]:delay' \
  '-a+[nanosecond delay between redraws]:nsdelay' \
  '-n[do not quit on keypress]' \
  '-D[hide date display]'
