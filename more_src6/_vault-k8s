#compdef vault-k8s
# Documentation: https://github.com/hashicorp/vault-k8s (subcommand/injector/command.go)
# Reference accessed: 2026-05-21
# Verified: upstream Go source flag definitions.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-listen=[address to listen on]:address:' \
  '-log-level=[log verbosity level]:level:(trace debug info warn error)' \
  '-log-format=[log output format]:format:(standard json)' \
  '-ca-cert=[TLS CA certificate file]:file:_files' \
  '-cert=[TLS certificate file]:file:_files' \
  '-key=[TLS private key file]:file:_files' \
  '-auto-name=[MutatingWebhookConfiguration name for auto-TLS]:name:' \
  '-auto-hosts=[Subject Alternative Names for auto-generated certificates]:hosts:' \
  '-exit-on-retry-failure[exit agent on retry failure]' \
  '-static-secret-render-interval=[interval for rendering static secrets]:duration:' \
  '-max-connections-per-host=[connection pool limit per host]:n:' \
  '-lease-renewal-threshold=[threshold for lease renewal]:float:' \
  '-vault-service=[Vault service name]:name:' \
  '-vault-ca-cert=[CA certificate for Vault TLS validation]:file:_files' \
  '-proxy-address=[HTTP proxy for Vault communication]:url:' \
  '-vault-image=[Vault container image name]:image:' \
  '-vault-auth-type=[Vault authentication method type]:type:' \
  '-vault-auth-path=[mount path for auth method]:path:' \
  '-vault-namespace=[Vault enterprise namespace]:namespace:' \
  '-revoke-on-shutdown[revoke tokens during pod termination]' \
  '-run-as-user=[user ID for agent container]:uid:' \
  '-run-as-group=[group ID for agent container]:gid:' \
  '-run-as-same-user[match first container user]' \
  '-set-security-context[apply SecurityContext settings]' \
  '-telemetry-path=[metrics exposure endpoint path]:path:' \
  '-use-leader-elector[enable leader election logic]' \
  '-default-template=[default template format]:format:(map json)' \
  '-resource-request-cpu=[CPU request for injected containers]:cpu:' \
  '-resource-request-mem=[memory request for injected containers]:mem:' \
  '-resource-request-ephemeral=[ephemeral storage request]:storage:' \
  '-resource-limit-cpu=[CPU limit for injected containers]:cpu:' \
  '-resource-limit-mem=[memory limit for injected containers]:mem:' \
  '-resource-limit-ephemeral=[ephemeral storage limit]:storage:' \
  '-tls-min-version=[minimum TLS protocol version]:version:(tls10 tls11 tls12 tls13)' \
  '-tls-cipher-suites=[supported cipher suites (comma-separated)]:suites:' \
  '-auth-min-backoff=[minimum backoff for authentication retries]:duration:' \
  '-auth-max-backoff=[maximum backoff for authentication retries]:duration:' \
  '-disable-idle-connections=[idle connection handling]:value:' \
  '-disable-keep-alives=[keep-alive connection control]:value:' && ret=0

return ret
