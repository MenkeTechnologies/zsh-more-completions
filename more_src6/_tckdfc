#compdef tckdfc
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/tckdfc.html
# Source: MRtrix3/mrtrix3 cmd/tckdfc.cpp — track-weighted dynamic functional connectivity (TW-dFC) (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(-dynamic)-static[output static 3D TW-dFC image]' \
    '(-static)-dynamic+[output dynamic 4D TW-dFC]:shape:(rectangle triangle cosine hann hamming lanczos):width:_default' \
    '-template+[template image]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-vox+[voxel size]:size:_default' \
    '-stat_vox+[voxel-wise statistic]:type:(sum min mean max)' \
    '-backtrack[backtrack endpoints to where streamline last intersected the mask]' \
    '-upsample+[upsample streamlines by this factor]:factor:_default' \
    '1:tracks:_files -g "*.{tck,trk}"' \
    '2:fmri (pre-processed time series):_files -g "*.{nii,nii.gz,mif}"' \
    '3:output (TW-dFC image):_files' \
    && ret=0

return ret
