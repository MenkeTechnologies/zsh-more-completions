#compdef yabasic
# Documentation: man yabasic(1)
# Source: marcIhm/yabasic unix/lang/main.c (master) — Yet Another BASIC interpreter (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-version[show version]' \
    '(-help -?)'{-help,-\\?}'[show help]' \
    '-check[syntax-check only and exit]' \
    '-infolevel+[message level]:level:(debug note warning error fatal)' \
    '(-fg -foreground)'{-fg+,-foreground+}'[foreground color]:color:_default' \
    '(-bg -background)'{-bg+,-background+}'[background color]:color:_default' \
    '-geometry+[graphics window geometry WxH+X+Y]:geom:_default' \
    '-bind+[bind a program to this executable]:script:_files -g "*.yab"' \
    '-execute+[execute the given string and exit]:code:_default' \
    '-librarypath+[library search path]:path:_files -/' \
    '-display+[X display]:display:_x_display' \
    '-font+[graphics window font]:font:_default' \
    '1::script:_files -g "*.yab"' \
    '*::script args:_default' \
    && ret=0

return ret
