#compdef upsmon
# Documentation: https://networkupstools.org/docs/man/upsmon.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show NUT version]' \
  '-c+[signal running upsmon]:cmd:(fsd stop reload)' \
  '-P+[PID to signal (overrides PID file)]:pid:' \
  '-D[raise debugging level]' \
  '-K[test for shutdown flag and exit]' \
  '-F[force foreground execution]' \
  '-B[force background execution]' \
  '-u+[user for unprivileged monitoring process]:user:_users' \
  '-p[run privileged always (not recommended)]' \
  '-W+[network connection timeout in seconds]:seconds:' && ret=0

return ret
