#compdef terraform-graph-beautifier
# Documentation: https://github.com/pcasteran/terraform-graph-beautifier
# Reference accessed: 2026-05-21
# Verified: upstream README.
# Real flags: --input, --output, --output-type (cyto-html/cyto-json/graphviz),
# --embed-modules, --exclude (repeatable regex), --keep-tf-junk,
# --graph-name, --cyto-html-template.
# Removed from prior file: -version (not documented), -exclude (real long
# is --exclude with two dashes).

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--input=[input dot file (default stdin)]:file:_files -g "*.dot"' \
  '--output=[output file (default stdout)]:file:_files' \
  '--output-type=[output format]:type:(cyto-html cyto-json graphviz)' \
  '--embed-modules=[embed modules into parent graph]:bool:(true false)' \
  '*--exclude=[regex of node types to exclude (repeatable)]:regex' \
  '--keep-tf-junk[keep terraform-generated nodes]' \
  '--graph-name=[graph name for HTML output]:name' \
  '--cyto-html-template=[custom HTML template]:file:_files' && ret=0

return ret
