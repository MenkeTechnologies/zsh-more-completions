#compdef trezor-agent keepkey-agent ledger-agent jade-agent onlykey-agent bitbox02-agent
# _trezor-agent — hardware-wallet SSH agent (romanz/trezor-agent)
# upstream: https://github.com/romanz/trezor-agent
# Flags from libagent/ssh/__init__.py (argparse).

_trezor-agent() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '*'{-v,--verbose}'[increase verbosity]' \
        '(-e --ecdsa-curve-name)'{-e+,--ecdsa-curve-name=}'[ECDSA curve name]:curve:(nist256p1 nist384p1 nist521p1 secp256k1 ed25519)' \
        '--timeout=[seconds to accept SSH client connections]:s:' \
        '--debug[log SSH protocol messages]' \
        '--log-file=[path to agent log file]:file:_files' \
        '--sock-path=[path to UNIX socket of the agent]:file:_files' \
        '--pin-entry-binary=[path to PIN entry UI helper]:file:_command_names -e' \
        '--passphrase-entry-binary=[path to passphrase entry UI helper]:file:_command_names -e' \
        '--cache-expiry-seconds=[expire passphrase from cache after this duration]:s:' \
        '(-d --daemonize -f --foreground -s --shell -c --connect --mosh)'{-d,--daemonize}'[daemonize agent and print socket path]' \
        '(-d --daemonize -f --foreground -s --shell -c --connect --mosh)'{-f,--foreground}'[run agent in foreground with specified socket path]' \
        '(-d --daemonize -f --foreground -s --shell -c --connect --mosh)'{-s,--shell}'[run $SHELL as subprocess under SSH agent]' \
        '(-d --daemonize -f --foreground -s --shell -c --connect --mosh)'{-c,--connect}'[connect to specified host via SSH]' \
        '(-d --daemonize -f --foreground -s --shell -c --connect --mosh)--mosh[connect to specified host via Mosh]' \
        '1:identity (proto://[user@]host[:port][/path]):' \
        '*::argument:_normal'
}

_trezor-agent "$@"
