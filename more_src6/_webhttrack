#compdef webhttrack
# Documentation: https://www.httrack.com/html/fcguide.html
# Reference accessed: 2026-05-21
# Verified: upstream HTTrack command-line guide (webhttrack wraps httrack).

local -a arguments

arguments=(
    '-q[Quiet mode]'
    '-i[Continue interrupted mirror]'
    '-w[Mirror website (default)]'
    '-W[Mirror with semi-automatic mode]'
    '-g[Get files without parsing links]'
    '-O[Output path for mirror/logs/cache]:path:_directories'
    '-P[Proxy server]:proxy address:'
    '-F[User-Agent field]:user agent string:'
    '-r[Mirror depth]:depth:'
    '-m[Max file length]:bytes:'
    '-M[Max overall size]:bytes:'
    '-E[Max mirror time]:seconds:'
    '-A[Max transfer rate]:rate:'
    '-n[Get non-HTML files near HTML]'
    '-t[Test all URLs]'
    '-c[Simultaneous connections]:connections:'
    '-T[Connection timeout]:timeout:'
    '-R[Number of retries]:retries:'
    '-H[Host abandonment conditions]'
    '-a[Stay on same address]'
    '-d[Stay on same domain]'
    '-l[Stay on same TLD]'
    '-e[Go everywhere]'
    '-p[Priority mode]:priority:'
    '-N[Directory structure type]:type:'
    '-s[Follow robots.txt]'
    '-S[Stay in same directory]'
    '-D[Only go down into subdirs]'
    '-U[Only go up directories]'
    '-B[Go up and down]'
    '-o[Generate error pages]'
    '-X[Purge old files]'
    '-Y[Mirror all links from first-level pages]'
    '-V[Execute command after each file]:command:'
    '-Q[Quiet log mode]'
    '-v[Verbose screen output]'
    '-Z[Debug logging]'
    '--mirror[Make site mirror]'
    '--get[Get specified files]'
    '--mirrorlinks[Mirror all first-level links]'
    '--testlinks[Test link validity]'
    '--spider[Spider and report errors]'
    '--skeleton[Mirror HTML only]'
    '--update[Update existing mirror]'
    '--continue[Continue interrupted mirror]'
    '--catchurl[Capture complex URLs]'
    '--clean[Erase cache/logs]'
    '--http10[Force HTTP/1.0]'
    '--help[Show help]'
    '*:URLs:'
)

_arguments -s -S $arguments
