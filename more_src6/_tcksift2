#compdef tcksift2
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/tcksift2.html
# Source: MRtrix3/mrtrix3 cmd/tcksift2.cpp — SIFT2: optimised streamline cross-section weights (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-out_coeffs+[per-streamline coefficient output]:path:_files' \
    '-proc_mask+[image processing mask]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-act+[ACT 5TT image for anatomical constraints]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-fd_scale_gm[scale GM fibre density (with -act)]' \
    '-no_dilate_lut[do not dilate FOD lobe lookup table]' \
    '-make_null_lobes[add null FOD lobes for unmatched stream contributions]' \
    '-remove_untracked[remove FOD lobes not reached by any streamline]' \
    '-fd_thresh+[fibre density threshold]:value:_default' \
    '-csv+[per-iteration CSV stats output]:path:_files' \
    '-mu+[output final mu coefficient to text file]:path:_files' \
    '-output_debug[output debug images]' \
    '-reg_tikhonov+[Tikhonov regularisation term]:value:_default' \
    '-reg_tv+[Total Variation regularisation term]:value:_default' \
    '-min_td_frac+[minimum fraction of FOD term valid streamlines]:value:_default' \
    '-min_iters+[minimum number of iterations]:n:_default' \
    '-max_iters+[maximum number of iterations]:n:_default' \
    '-min_factor+[minimum allowable per-streamline weight]:value:_default' \
    '-max_factor+[maximum allowable per-streamline weight]:value:_default' \
    '-min_coeff+[minimum allowable coefficient]:value:_default' \
    '-max_coeff+[maximum allowable coefficient]:value:_default' \
    '-linear[scale per-streamline weights linearly with FD]' \
    '1:in_tracks:_files -g "*.{tck,trk}"' \
    '2:in_fod (SH FOD image):_files -g "*.{nii,nii.gz,mif}"' \
    '3:out_weights:_files' \
    && ret=0

return ret
