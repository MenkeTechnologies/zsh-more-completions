#compdef wast2json
# Documentation: https://github.com/WebAssembly/wabt
# Source: WebAssembly/wabt src/tools/wast2json.cc — convert WebAssembly text spec test (.wast) to JSON + .wasm fixtures.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*'{-v,--verbose}'[verbose (use multiple times)]' \
    '(-o --output)'{-o+,--output=}'[output JSON file]:file:_files' \
    '(-r --relocatable)'{-r,--relocatable}'[create a relocatable wasm binary (for lld linking)]' \
    '--no-canonicalize-leb128s[write all LEB128 sizes as 5 bytes]' \
    '--debug-names[write debug names to the generated binary]' \
    '--no-check[do not check for invalid modules]' \
    '--enable-exceptions[enable exception-handling proposal]' \
    '--enable-mutable-globals[enable mutable-globals proposal]' \
    '--enable-saturating-float-to-int[enable saturating float-to-int proposal]' \
    '--enable-sign-extension[enable sign-extension proposal]' \
    '--enable-simd[enable SIMD proposal]' \
    '--enable-threads[enable threads proposal]' \
    '--enable-multi-value[enable multi-value proposal]' \
    '--enable-bulk-memory[enable bulk-memory proposal]' \
    '--enable-reference-types[enable reference-types proposal]' \
    '--enable-tail-call[enable tail-call proposal]' \
    '--enable-annotations[enable annotations proposal]' \
    '--enable-code-metadata[enable code-metadata proposal]' \
    '--enable-gc[enable garbage-collection proposal]' \
    '--enable-memory64[enable memory64 proposal]' \
    '--enable-multi-memory[enable multi-memory proposal]' \
    '--enable-extended-const[enable extended-const proposal]' \
    '--enable-relaxed-simd[enable relaxed-SIMD proposal]' \
    '--enable-function-references[enable function-references proposal]' \
    '--enable-all[enable all proposals]' \
    '*:input .wast file:_files -g "*.wast"' \
    && ret=0

return ret
