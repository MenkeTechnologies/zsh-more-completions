_tree-grepper() {
    local -a langs
    langs=(c cpp cuda elixir elm go haskell java js markdown nix php powershell py ruby rust sass ts)

    _arguments -s -S \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '*'{-q+,--query=}'[tree-sitter query (LANGUAGE QUERY pair, repeatable)]:language:->lang' \
        '--no-gitignore[do not use git ignore/exclude files to filter candidates]' \
        '(-f --format)'{-f+,--format=}'[output format]:format:(lines json json-lines pretty-json)' \
        '--sort[sort matches stably (O(n log n) overhead)]' \
        '--languages[list supported languages]' \
        '*--show-tree=[show concrete syntax tree for a single file]:language:->lang' \
        '*:path:_files'

    case $state in
        lang)
            _describe -t languages 'tree-sitter language' langs
            ;;
    esac
}

_tree-grepper "$@"
