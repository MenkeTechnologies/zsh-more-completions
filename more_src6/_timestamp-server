#compdef timestamp-server
# _timestamp-server — Sigstore Timestamp Authority (RFC 3161 TSA) server
# upstream: https://github.com/sigstore/timestamp-authority
# Flags from cmd/timestamp-server/app/root.go on tip.

_timestamp-server() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[config file (default \$HOME/.timestamp-server.yaml)]:file:_files' \
        '--log-type=[logger type]:type:(dev prod)' \
        '--enable-pprof[enable pprof endpoint on :6060]' \
        '--http-ping-only[serve only /ping in the HTTP server]' \
        '--enforce-intermediate-eku=[require intermediate certs to have TSA EKU]:bool:(true false)' \
        '--use-http-201=[respond with HTTP 201 instead of 200]:bool:(true false)' \
        '--timestamp-signer=[TSA signer backend]:backend:(kms tink memory file)' \
        '--timestamp-signer-hash=[signer hash algorithm]:alg:(sha256 sha384 sha512)' \
        '--include-chain-in-response=[include issuing chain in response when certReq is set]:bool:(true false)' \
        '--kms-key-resource=[KMS key URI (gcpkms,azurekms,hashivault,awskms)]:uri:' \
        '--tink-key-resource=[KMS key URI for Tink keyset]:uri:' \
        '--tink-keyset-path=[KMS-encrypted Tink keyset path]:file:_files' \
        '--tink-hcvault-token=[Hashicorp Vault token for Tink]:token:' \
        '--certificate-chain-path=[PEM cert chain certifying the signer key]:file:_files' \
        '--file-signer-key-path=[PEM-encoded private key file (file signer)]:file:_files' \
        '--file-signer-passwd=[private key passphrase]:pw:' \
        '--ntp-monitoring=[NTP monitoring config file]:file:_files' \
        '--disable-ntp-monitoring=[disable NTP monitoring]:bool:(true false)' \
        '--http-request-id-header-name=[HTTP request correlation ID header name]:name:' \
        '--max-request-body-size=[max allowed request body size (bytes)]:bytes:' \
        '--cleanup-timeout=[grace period before killing idle connections]:dur:' \
        '--default-policy-oid=[default policy OID]:oid:' \
        '*--accepted-policy-oids=[accepted policy OID (csv)]:csv:' \
        '--allow-custom-extensions=[allow custom request extensions in signed timestamp]:bool:(true false)'
}

_timestamp-server "$@"
