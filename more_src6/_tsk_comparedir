#compdef tsk_comparedir
# Documentation: https://www.sleuthkit.org/sleuthkit/man/tsk_comparedir.html
# Source: sleuthkit/sleuthkit man/tsk_comparedir.1 — compare a local directory against the contents of an image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '-n[starting inum for a directory in the image]:inum:' \
    '-f[specify file system type]:fstype:(ext2 ext3 ext4 fat fat12 fat16 fat32 ntfs ufs ufs1 ufs2 iso9660 hfs ext yaffs2 list)' \
    '-i[format of image file]:imgtype:(raw aff afd afm afflib ewf split)' \
    '-b[device sector size in bytes]:sector size:(512 1024 2048 4096)' \
    '-o[sector offset for a partition in image or device]:sector offset:' \
    '*:image then local dir:_files' \
    && ret=0

return ret
