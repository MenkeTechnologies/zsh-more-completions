#compdef x86info
# _x86info — x86 CPU information utility (kernelslacker/x86info)
# upstream: https://github.com/kernelslacker/x86info
# Flags from commandline.c (custom strcmp dispatch).

_x86info() {
    _arguments \
        '(- *)--help[show help]' \
        '(-a --all)'{-a,--all}'[print all info (some require root)]' \
        '--all-cpus[show info for all CPUs]' \
        '--addr[show address sizes]' \
        '--apic[show APIC info (root)]' \
        '--bios[show BIOS info (root)]' \
        '--bugs[show known CPU bugs]' \
        '(-c --cache)'{-c,--cache}'[show cache info]' \
        '--connector[show CPU socket connector]' \
        '--debug[debug output]' \
        '(-f --flags)'{-f,--flags}'[show CPU feature flags]' \
        '(-m --msr)'{-m,--msr}'[show MSR contents (root)]' \
        '--microcode[show microcode revision (root)]' \
        '-mhz[show MHz reading]' \
        '--mhz[show MHz reading]' \
        '-mp[show MP table (root)]' \
        '--mptable[show MP table (root)]' \
        '--mtrr[show MTRR registers (root)]' \
        '--pm[show power-management info]' \
        '(-r --raw-cpuid)'{-r,--raw-cpuid}'[show raw CPUID values]' \
        '-mce[show machine-check exception info (root)]' \
        '--show-machine-check[show MCE info (root)]' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
}

_x86info "$@"
