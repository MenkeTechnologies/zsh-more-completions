#compdef t3 t3-cli create-t3
# _t3 — create-t3-app's t3 CLI (Theo's T3 Stack contributors, TypeScript); commander
# upstream: https://github.com/t3-oss/create-t3-app

_t3() {
    local -a sub=(
        'new:scaffold T3 project'
        'add:add a package'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--noGit[no git init]' \
        '--noInstall[no install]' \
        '--default[use defaults]' \
        '-y[use defaults]' \
        '--CI[continuous integration mode]' \
        '--tailwind[include tailwind]' \
        '--trpc[include trpc]' \
        '--prisma[include prisma]' \
        '--drizzle[include drizzle]' \
        '--nextAuth[include nextauth]' \
        '--appRouter[use App Router]' \
        '--biome[use biome instead of prettier+eslint]' \
        '--dbProvider=+[db provider]:p:(postgres mysql sqlite planetscale)' \
        '--importAlias=+[import alias]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 't3 subcommand' sub
            _files ;;
        args)
            case $words[1] in
                add) _arguments '*:package:' ;;
            esac
            ;;
    esac
}

_t3 "$@"
