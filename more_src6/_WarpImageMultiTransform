#compdef WarpImageMultiTransform
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/WarpImageMultiTransform.cxx — apply multiple transforms to a moving image (C++, mixed flags + positionals).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-R+[reference image (output space)]:file:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '--tightest-bounding-box[use tightest bounding box]' \
    '--reslice-by-header[reslice using header info only]' \
    '--use-NN[nearest-neighbour interpolation]' \
    '--use-BSpline[B-spline interpolation]' \
    '--ANTS-prefix=[prefix for ANTS-format transforms]:prefix:_default' \
    '--ANTS-prefix-invert=[prefix for ANTS-format inverse transforms]:prefix:_default' \
    '--Id[insert identity transform here]' \
    '(-mh --moving-image-header)'{-mh,--moving-image-header}'[apply moving image header]' \
    '(-rh --reference-image-header)'{-rh,--reference-image-header}'[apply reference image header]' \
    '*-i[invert the next affine transform]' \
    '1:ImageDimension:(2 3 4)' \
    '2:moving_image:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3:output_image:_files' \
    '*:warp/affine files (right-to-left order):_files' \
    && ret=0

return ret
