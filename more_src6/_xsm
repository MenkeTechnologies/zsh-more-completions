#compdef xsm
# Documentation: man xsm (X.Org)
# Source: X session manager.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-display+[X display]:display:' \
    '-session+[session name to restore]:session name:' \
    '-verbose[verbose output]' \
    && ret=0

return ret
