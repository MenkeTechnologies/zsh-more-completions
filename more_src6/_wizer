#compdef wizer
# Documentation: https://github.com/bytecodealliance/wizer
# Reference accessed: 2026-05-21
# Verified: clap arg definitions in src/bin/wizer.rs (Options struct) and
# wasmtime crates/wizer/src/lib.rs (Wizer struct flattened into Options).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-o+[output Wasm path (default stdout)]:file:_files -g "*.wasm"' \
  '--allow-wasi[allow WASI imports during initialization]' \
  '--relaxed-simd-deterministic=[use deterministic relaxed SIMD]:bool:(true false)' \
  '*--preload=[additional preloaded module name=file.{wasm,wat}]:name=file:' \
  '--inherit-stdio=[inherit stdio during init]:bool:(true false)' \
  '--inherit-env=[inherit env vars during init]:bool:(true false)' \
  '*--dir=[WASI directory to preopen]:directory:_files -/' \
  '*--mapdir=[map guest dir to host dir (GUEST::HOST)]:guest::host:' \
  '--wasm-multi-memory=[enable multi-memory proposal]:bool:(true false)' \
  '--wasm-multi-value=[enable multi-value proposal]:bool:(true false)' \
  '--wasm-bulk-memory=[enable bulk memory operations]:bool:(true false)' \
  '--wasm-simd=[enable SIMD128 proposal]:bool:(true false)' \
  '--wasm-relaxed-simd=[enable relaxed SIMD proposal]:bool:(true false)' \
  '--wasm-reference-types=[enable reference-types proposal]:bool:(true false)' \
  '(-f --init-func)'{-f+,--init-func=}'[initialization function name]:function:' \
  '*'{-r+,--rename-func=}'[rename exported function OLD=NEW]:mapping:' \
  '--keep-init-func=[keep init function after wizening]:bool:(true false)' \
  '1:input wasm file:_files -g "*.wasm"' && ret=0

return ret
