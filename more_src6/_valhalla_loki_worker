#compdef valhalla_loki_worker
# Documentation: https://github.com/valhalla/valhalla
# Source: valhalla/valhalla src/valhalla_loki_worker.cc — Loki HTTP worker process (location lookups).
# Reference accessed: 2026-06-10
#
# Loki/Thor/Odin workers use simple positional config-file invocation, not cxxopts.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:Valhalla config file:_files -g "*.json(-.)"' \
    && ret=0

return ret
