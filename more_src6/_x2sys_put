#compdef x2sys_put
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/x2sys/x2sys_put.html
# Source: GenericMappingTools/gmt supplements/x2sys — update database from a track bin file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-T+[x2sys TAG identifying data attributes]:tag:_default' \
    '-D[delete all tracks found in bin file]' \
    '-F[replace existing database info for these tracks]' \
    '*-V[verbose (stackable)]' \
    '(- *)-\?[show help]' \
    '*:track bin file (info.tbf):_files' \
    && ret=0

return ret
