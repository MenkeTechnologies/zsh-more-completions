#compdef vmware-network-setup
# _vmware-network-setup — VMware open-vm-tools vmware-network-setup (helper hooked into NetworkManager / udev that pushes guest IP and routing facts back to the host VMX through the open-vm-tools backdoor; subcommands: start, stop, status, restart, reload; --verbose verbose, --version, --help)
# upstream: https://github.com/vmware/open-vm-tools
# Behaviour from vmware/open-vm-tools open-vm-tools/scripts/network on tip.

_vmware-network-setup() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '1::command:(start stop status restart reload)'
}

_vmware-network-setup "$@"
