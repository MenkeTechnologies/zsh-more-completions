#compdef yubico-c yubikey-c ykclient ykclient-cli
# _yubico-c — Yubico yubico-c ykclient CLI for validating YubiKey OTP token codes against the YubiCloud or a local validation server with client identifier and shared HMAC secret (Yubico team, C); getopt
# upstream: https://github.com/Yubico/yubico-c-client

_yubico-c() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[client id]:n:' \
        '--client-id=+[client id]:n:' \
        '-k+[shared key b64]:str:' \
        '--key=+[shared key b64]:str:' \
        '-K+[key from file]:file:_files' \
        '--key-file=+[key file]:file:_files' \
        '-u+[validation url]:str:' \
        '--url=+[validation url]:str:' \
        '--ca-file=+[file]:file:_files -g "*.pem *.crt"' \
        '--ca-path=+[dir]:dir:_files -/' \
        '-n+[nonce]:str:' \
        '--nonce=+[nonce]:str:' \
        '-s+[sl]:n:(0 1 2 25 50 75 100)' \
        '--sl=+[sl]:n:(0 1 2 25 50 75 100)' \
        '-t+[timeout sec]:n:' \
        '--timeout=+[timeout sec]:n:' \
        '--proxy=+[url]:str:' \
        '--user-agent=+[ua]:str:' \
        '*:OTP token:'
}

_yubico-c "$@"
