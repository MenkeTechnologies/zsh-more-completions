#compdef vizex
# Documentation: https://github.com/bexxmodd/vizex

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--save=[save chart to file]:file:_files -g "*.png"' \
  '--path=[show usage for specific path]:path:_files -/' \
  '--every[show all filesystems including virtual]' \
  '--details[show additional filesystem details]' \
  '--exclude=[exclude filesystems matching pattern]:pattern:' \
  '--header=[set header color]:color:(red green yellow blue magenta cyan white)' \
  '--style=[set chart style]:style:(default alt)' \
  '--text=[set text color]:color:(red green yellow blue magenta cyan white)' \
  && return 0
