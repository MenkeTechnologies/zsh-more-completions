#compdef wayvnc
# Documentation: https://man.archlinux.org/man/wayvnc.1.en
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-C --config)'{-C,--config}'=[select config file]:config file:_files' \
  '(-d --disable-input)'{-d,--disable-input}'[disable all remote input]' \
  '(-D --detached)'{-D,--detached}'[start detached from a compositor]' \
  '(-f --max-fps)'{-f,--max-fps}'=[rate limit (default 30)]:fps' \
  '(-g --gpu)'{-g,--gpu}'[enable GPU-requiring features]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-k --keyboard)'{-k,--keyboard}'=[keyboard layout[-variant\]]:layout' \
  '(-L --log-level)'{-L,--log-level}'=[set log level]:level:(error warning info debug trace quiet)' \
  '(-o --output)'{-o,--output}'=[output to capture]:output' \
  '(-p --show-performance)'{-p,--show-performance}'[show performance counters]' \
  '(-r --render-cursor)'{-r,--render-cursor}'[enable overlay cursor rendering]' \
  '(-R --disable-resizing)'{-R,--disable-resizing}'[disable automatic desktop resizing]' \
  '(-s --seat)'{-s,--seat}'=[select seat by name]:seat' \
  '(-t --transient-seat)'{-t,--transient-seat}'[create a transient seat per client session]' \
  '(-S --socket)'{-S,--socket}'=[wayvnc control socket path]:socket:_files' \
  '(-u --unix-socket)'{-u,--unix-socket}'[create UNIX domain socket instead of TCP]' \
  '(-v --verbose)'{-v,--verbose}'[verbose (equivalent to --log-level=info)]' \
  '(-V --version)'{-V,--version}'[show version information]' \
  '(-w --websocket)'{-w,--websocket}'[create a websocket]' \
  '(-x --external-listener-fd)'{-x,--external-listener-fd}'=[listen on already-bound socket FD]:fd:' \
  '1:address' \
  '2:port' && ret=0

return ret
