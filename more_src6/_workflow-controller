#compdef workflow-controller
# _workflow-controller — Argo Workflows controller daemon (argoproj/argo-workflows)
# upstream: https://github.com/argoproj/argo-workflows
# Flags from cmd/workflow-controller/main.go (cobra + AddKubectlFlagsToCmd).

_workflow-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--configmap=[K8s configmap with controller configuration]:name:' \
        '--executor-image=[executor image override]:image:' \
        '--executor-image-pull-policy=[executor imagePullPolicy override]:policy:(Always IfNotPresent Never)' \
        '--loglevel=[log level]:level:(debug info warn error)' \
        '--gloglevel=[glog level]:n:' \
        '--log-format=[log format]:format:(text json)' \
        '--workflow-workers=[number of workflow workers]:n:' \
        '--workflow-ttl-workers=[number of workflow TTL workers]:n:' \
        '--pod-cleanup-workers=[number of pod cleanup workers]:n:' \
        '--cron-workflow-workers=[number of cron workflow workers]:n:' \
        '--workflow-archive-workers=[number of workflow archive workers]:n:' \
        '--burst=[max burst for throttle]:n:' \
        '--qps=[queries per second]:n:' \
        '--namespaced[run controller in namespaced mode]' \
        '--managed-namespace=[namespace controller watches]:namespace:' \
        '--executor-plugins[enable executor plugins]' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--context=[kubeconfig context]:context:' \
        '--namespace=[kubernetes namespace]:namespace:' \
        '--server=[kubernetes API server]:url:_urls' \
        '--token=[bearer token for authentication]:token:' \
        '--user=[kubeconfig user]:user:' \
        '--cluster=[kubeconfig cluster]:cluster:' \
        '1:subcommand:(version)'
}

_workflow-controller "$@"
