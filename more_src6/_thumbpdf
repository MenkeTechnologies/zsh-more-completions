#compdef thumbpdf
# Documentation: thumbpdf --help (3.17, Heiko Oberdiek)
# Source: generate page thumbnails for inclusion via the thumbpdf.sty package.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[print usage]' \
    '(- *)--version[print version number]' \
    '--quiet[suppress messages]' \
    '--noquiet[do not suppress messages]' \
    '--verbose[verbose printing]' \
    '--noverbose[disable verbose printing]' \
    '--debug[debug information]' \
    '--nodebug[disable debug]' \
    '--makepng[make thb*.png thumbnails]' \
    '--nomakepng[do not make thb*.png thumbnails]' \
    '--makepdf[make thumbpdf.pdf with thumbnails as images]' \
    '--nomakepdf[do not make thumbpdf.pdf]' \
    '--makedata[make data file(s) for thumbpdf.sty]' \
    '--nomakedata[do not make data file(s)]' \
    '--clean[clear temp files]' \
    '--noclean[keep temp files]' \
    '--useps[makepng uses .ps instead of .pdf file]' \
    '--nouseps[makepng uses .pdf file]' \
    '--level2[<jobname>.tpm with PS level 2 features]' \
    '--nolevel2[disable PS level 2 features]' \
    '--greek[text in Greek style (experimental)]' \
    '--nogreek[disable Greek style]' \
    '--gscmd=[Ghostscript invocation command]:gs:_command_names -e' \
    '--antialias=[anti-aliasing (0 disable .. 4 max)]:level:(0 1 2 3 4)' \
    '--device=[Ghostscript device for thumbnails]:device:(png16m pngmono pnggray png16 png256)' \
    '--png=[Ghostscript png variant]:device:(png16m pngmono pnggray png16 png256)' \
    '--resolution=[thumbnail resolution for makepng]:res:' \
    '--compress=[compress level (0..10)]:n:' \
    '--modes=[output modes]:modes:(pdftex pdfmark dvips ps2pdf vtexpdfmark all)' \
    '--password=[password for an encrypted pdf]:password:' \
    '1:jobname or pdf/ps:_files -g "*.(pdf|ps)"' \
    && ret=0

return ret
