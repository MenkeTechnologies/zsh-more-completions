#compdef ziti-tunnel ziti-tunneler
# _ziti-tunnel — NetFoundry ziti-tunnel zero-trust networking CLI launching OpenZiti edge tunneler in host transparent-proxy or DNS-only mode binding to identity files services and DNS resolver (openziti team, Go); cobra
# upstream: https://github.com/openziti/ziti-tunnel-sdk-c

_ziti-tunnel() {
    local -a sub=(
        'run:run tunneler'
        'run-host:run in host mode'
        'run-tproxy:run in transparent proxy mode'
        'run-dns:run as DNS resolver'
        'enroll:enroll identity'
        'add-identity:add identity'
        'list-identities:list identities'
        'remove-identity:remove identity'
        'service:list services'
        'tunnel:run tunnel'
        'host:run host mode'
        'dump:dump tunneler state'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--cli-agent[enable cli agent]' \
        '--cli-agent-addr=+[addr]:str:' \
        '--config-dir=+[dir]:dir:_files -/' \
        '-i+[identity file]:file:_files -g "*.json"' \
        '--identity-dir=+[dir]:dir:_files -/' \
        '--resolver=+[addr]:str:' \
        '--dns-ip-range=+[cidr]:str:' \
        '--service-poll-interval=+[d]:str:' \
        '--no-color[no color]' \
        '--log-formatter=+[fmt]:f:(text json)' \
        '--log-level=+[level]:l:(panic fatal error warn info debug trace)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ziti-tunnel subcommand' sub ;;
        args)
            case $words[1] in
                enroll) _arguments \
                    '--jwt=+[file]:file:_files -g "*.jwt"' \
                    '--out=+[file]:file:_files -g "*.json"' \
                    '--key=+[file]:file:_files -g "*.pem"' \
                    '--cert=+[file]:file:_files -g "*.pem"' \
                    '--rm-jwt[remove jwt]' ;;
                add-identity) _arguments \
                    '--enrollment-jwt=+[file]:file:_files -g "*.jwt"' \
                    '--identity-file=+[file]:file:_files -g "*.json"' ;;
            esac
            ;;
    esac
}

_ziti-tunnel "$@"
