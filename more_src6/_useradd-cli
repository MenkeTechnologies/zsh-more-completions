#compdef useradd-cli
# _useradd-cli — shadow useradd create a new user CLI alias (shadow-maint team, C); custom argparse
# upstream: https://github.com/shadow-maint/shadow

_useradd-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-b+[base dir]:dir:_files -/' \
        '--base-dir=+[base dir]:dir:_files -/' \
        '--btrfs-subvolume-home[btrfs subvolume home]' \
        '-c+[comment]:str:' \
        '--comment=+[comment]:str:' \
        '-d+[home dir]:dir:_files -/' \
        '--home-dir=+[home dir]:dir:_files -/' \
        '-D[show defaults]' \
        '--defaults[show defaults]' \
        '-e+[expire date]:str:' \
        '--expiredate=+[expire date]:str:' \
        '-f+[inactive days]:n:' \
        '--inactive=+[inactive days]:n:' \
        '-F+[fluid args]:str:' \
        '--add-subids-for-system[add subids for system]' \
        '-g+[group]:_groups' \
        '--gid=+[group]:_groups' \
        '-G+[supplementary groups]:str:' \
        '--groups=+[supplementary groups]:str:' \
        '-k+[skel dir]:dir:_files -/' \
        '--skel=+[skel dir]:dir:_files -/' \
        '-K+[key=value]:str:' \
        '--key=+[key=value]:str:' \
        '-l[no add to lastlog and faillog]' \
        '--no-log-init[no add to lastlog and faillog]' \
        '-m[create home]' \
        '--create-home[create home]' \
        '-M[no create home]' \
        '--no-create-home[no create home]' \
        '-N[no create group]' \
        '--no-user-group[no create group]' \
        '-o[allow duplicate uid]' \
        '--non-unique[allow duplicate uid]' \
        '-p+[encrypted password]:str:' \
        '--password=+[encrypted password]:str:' \
        '-P+[prefix path]:dir:_files -/' \
        '--prefix=+[prefix path]:dir:_files -/' \
        '-r[create system user]' \
        '--system[create system user]' \
        '-R+[chroot dir]:dir:_files -/' \
        '--root=+[chroot dir]:dir:_files -/' \
        '-s+[shell]:str:' \
        '--shell=+[shell]:str:' \
        '-u+[uid]:n:' \
        '--uid=+[uid]:n:' \
        '-U[create group with same name]' \
        '--user-group[create group with same name]' \
        '-Z+[selinux user]:str:' \
        '--selinux-user=+[selinux user]:str:' \
        '*:login:_users'
}

_useradd-cli "$@"
