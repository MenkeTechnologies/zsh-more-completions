#compdef xditview
# Documentation: man xditview (X.Org)
# Source: ditroff/troff DVI viewer for X11.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-page+[start at page]:page number:' \
    '-resolution+[screen resolution dpi]:dpi:' \
    '-noPolyText[do not use PolyText extension]' \
    '-backingStore+[backing-store type]:type:(WhenMapped Always NotUseful)' \
    '-bg+[background color]:color:' \
    '-bd+[border color]:color:' \
    '-bw+[border width]:n:' \
    '-fg+[foreground color]:color:' \
    '-fn+[font]:font:' \
    '-rv[reverse video]' \
    '-geometry+[window geometry]:geom:' \
    '-display+[X display]:display:' \
    '*-xrm+[resource specification]:resource:' \
    '1:dvi/ditroff file:_files' \
    && ret=0

return ret
