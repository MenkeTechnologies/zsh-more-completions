#compdef visit
# Documentation: https://visit-sphinx-github-user-manual.readthedocs.io/en/v3.2.0/gui_manual/StartupOptions/index.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# VisIt: parallel visualisation and analysis tool (LLNL)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-fullhelp[show full help]' \
  '-version[show current version]' \
  '-v[run a specific VisIt version]:version:' \
  '-beta[run beta version]' \
  '-gui[GUI mode (default)]' \
  '-cli[command-line interface mode]' \
  '-nowin[off-screen rendering (OSMesa)]' \
  '-o[open data file at startup]:file:_files' \
  '-s[execute VisIt script (CLI/movie mode)]:file:_files -g "*.py"' \
  '-sessionfile[open session file at startup]:file:_files -g "*.session"' \
  '-config[viewer config file]:file:_files' \
  '-noconfig[skip configuration file]' \
  '-launchengine[launch engine at startup]:host:' \
  '-nosplash[hide splash screen]' \
  '-small[smaller window size]' \
  '-fullscreen[fullscreen viewer]' \
  '-stereo[enable active stereo]' \
  '-style[visual style]:style:' \
  '-geometry[screen geometry WxH+X+Y]:geom:' \
  '-viewer_geometry[viewer window geometry]:geom:' \
  '-window_anchor[window position on screen]:x,y:' \
  '-movie[run CLI in movie making mode]' \
  '-par[run parallel version]' \
  '-np[number of processors]:n:' \
  '-nn[number of nodes]:n:' \
  '-l[parallel launch method]:method:' \
  '-machinefile[machine file]:file:_files' \
  '-debug[debug level 1-5]:n:(1 2 3 4 5)' \
  '-quiet[do not print Running message]' \
  '-dir[run VisIt in specified installation directory]:dir:_files -/' \
  '*:file:_files' && ret=0
return ret
