#compdef telebit
# _telebit — Telebit TCP+TLS tunnel CLI (Node.js); ngrok-alternative routing telebit.cloud SNI/HTTP/TCP to local services
# upstream: https://git.coolaj86.com/coolaj86/telebit.js

_telebit() {
    local -a sub=(
        'init:initialize config'
        'enable:enable service on boot'
        'disable:disable service on boot'
        'start:start the local daemon'
        'restart:restart the daemon'
        'stop:stop the daemon'
        'status:show daemon status'
        'http:tunnel HTTP for a port'
        'tcp:tunnel TCP for a port'
        'ssh:tunnel SSH'
        'list:list active tunnels'
        'remove:remove an active tunnel'
        'save:save settings'
        'config:show config'
        'logout:remove credentials'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--config+[config file]:file:_files' \
        '--debug[debug log]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'telebit subcommand' sub ;;
        args)
            case $words[1] in
                http|tcp) _arguments '1:port:' '2:domain:' ;;
                remove) _arguments '1:tunnel:' ;;
            esac
            ;;
    esac
}

_telebit "$@"
