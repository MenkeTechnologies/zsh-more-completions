#compdef vtep-ctl
# _vtep-ctl — Open vSwitch vtep-ctl control utility for OVSDB VTEP schema configuration (openvswitch team, C); custom argparse
# upstream: https://github.com/openvswitch/ovs

_vtep-ctl() {
    local -a sub=(
        'init:init VTEP DB'
        'show:show VTEP DB summary'
        'add-ps:add a physical switch'
        'del-ps:delete a physical switch'
        'list-ps:list physical switches'
        'ps-exists:check whether ps exists'
        'list-ports:list ports on physical switch'
        'add-port:add port on physical switch'
        'del-port:delete port on physical switch'
        'add-ls:add a logical switch'
        'del-ls:delete a logical switch'
        'list-ls:list logical switches'
        'ls-exists:check whether ls exists'
        'bind-ls:bind logical switch to port and VLAN'
        'unbind-ls:unbind logical switch'
        'list-bindings:list bindings on a port'
        'set-replication-mode:set replication mode'
        'get-replication-mode:get replication mode'
        'add-mcast-local:add local mcast macs'
        'del-mcast-local:delete local mcast macs'
        'add-mcast-remote:add remote mcast macs'
        'del-mcast-remote:delete remote mcast macs'
        'clear-local-macs:clear local macs'
        'clear-remote-macs:clear remote macs'
        'add-ucast-local:add local unicast macs'
        'del-ucast-local:delete local unicast macs'
        'add-ucast-remote:add remote unicast macs'
        'del-ucast-remote:delete remote unicast macs'
        'list-local-macs:list local macs'
        'list-remote-macs:list remote macs'
        'list-mcast-local:list local mcast macs'
        'list-mcast-remote:list remote mcast macs'
        'add-mp:add a manager'
        'del-mp:delete a manager'
        'list-mp:list managers'
        'set:set a column'
        'get:get a column'
        'list:list rows of a table'
        'find:find rows of a table'
        'create:create row'
        'destroy:destroy row'
        'add:append to set'
        'remove:remove from set'
        'clear:clear set'
        'wait-until:wait until condition'
        'comment:add comment'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v+[verbose modules]:str:' \
        '--verbose=+[verbose modules]:str:' \
        '--db=+[VTEP DB]:str:' \
        '-t+[timeout secs]:n:' \
        '--timeout=+[timeout secs]:n:' \
        '--no-syslog[no syslog]' \
        '--oneline[one line]' \
        '--dry-run[dry run]' \
        '--data=+[data format]:f:(string bare json)' \
        '--pretty[pretty json]' \
        '--bootstrap-ca-cert=+[ca cert]:file:_files' \
        '--ca-cert=+[ca cert]:file:_files' \
        '--certificate=+[cert]:file:_files' \
        '--private-key=+[key]:file:_files' \
        '--ssl-protocols=+[protocols]:str:' \
        '--ssl-ciphers=+[ciphers]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vtep-ctl subcommand' sub ;;
    esac
}

_vtep-ctl "$@"
