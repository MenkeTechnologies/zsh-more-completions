#compdef yazi
# Documentation: https://github.com/sxyazi/yazi/blob/main/yazi-boot/src/args.rs
# Reference accessed: 2026-05-21
# Verified: upstream clap Args struct in yazi-boot at the URL above.

# Zsh completion for yazi (terminal file manager)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '--cwd-file=[write the cwd on exit to this file]:file:_files' \
  '--chooser-file=[write the selected files on open fired]:file:_files' \
  '--clear-cache[clear the cache directory]' \
  '--client-id=[use the specified globally-unique client ID]:id:' \
  '--local-events=[report the specified local events to stdout]:events:' \
  '--remote-events=[report the specified remote events to stdout]:events:' \
  '--debug[print debug information]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(- *)'{-h,--help}'[print help]' \
  '*:entry:_files' && ret=0

return ret
