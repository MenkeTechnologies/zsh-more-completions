#compdef usvg
# Documentation: https://github.com/linebender/resvg/blob/main/crates/usvg/src/main.rs
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--dpi=[set DPI (10-4000)]:dpi' \
  '--languages=[set comma-separated languages]:languages' \
  '--shape-rendering=[set shape rendering mode]:mode:(optimizeSpeed crispEdges geometricPrecision)' \
  '--text-rendering=[set text rendering mode]:mode:(optimizeSpeed optimizeLegibility geometricPrecision)' \
  '--image-rendering=[set image rendering mode]:mode:(optimizeQuality optimizeSpeed smooth high-quality crisp-edges pixelated)' \
  '--resources-dir=[directory with fonts and images]:directory:_directories' \
  '--font-family=[set the default font family]:family' \
  '--font-size=[set the default font size (1-192)]:size' \
  '--serif-family=[set the serif font family]:family' \
  '--sans-serif-family=[set the sans-serif font family]:family' \
  '--monospace-family=[set the monospace font family]:family' \
  '--cursive-family=[set the cursive font family]:family' \
  '--fantasy-family=[set the fantasy font family]:family' \
  '--skip-system-fonts[skip loading system fonts]' \
  '--list-fonts[display loaded font faces]' \
  '*--use-font-file=[load a specific font file]:file:_files' \
  '*--use-fonts-dir=[load fonts from a directory]:directory:_directories' \
  '--stylesheet=[inject stylesheet for CSS resolution]:file:_files' \
  '--preserve-text[keep text elements instead of converting to paths]' \
  '--indent=[set XML node indent]:indent:(none 0 1 2 3 4 tabs)' \
  '--attrs-indent=[set XML attribute indent]:indent:(none 0 1 2 3 4 tabs)' \
  '--coordinates-precision=[coordinate precision (2-8)]:precision' \
  '--transforms-precision=[transform precision (2-8)]:precision' \
  '--default-width=[default viewport width]:width' \
  '--default-height=[default viewport height]:height' \
  '--id-prefix=[add a prefix to all IDs]:prefix' \
  '-c[write output to stdout]' \
  '--quiet[suppress warnings]' \
  '1:input SVG:_files -g "*.svg"' \
  '2:output SVG:_files -g "*.svg"' && ret=0

return ret
