#compdef terraform-cli
# _terraform-cli — HashiCorp Terraform IaC CLI (HashiCorp, Go); plan/apply infrastructure changes from HCL
# upstream: https://github.com/hashicorp/terraform

_terraform-cli() {
    local -a sub=(
        'apply:apply changes'
        'console:interactive console'
        'destroy:destroy infrastructure'
        'env:env (deprecated, see workspace)'
        'fmt:reformat code'
        'force-unlock:force-unlock state'
        'get:download modules'
        'graph:graph dependencies'
        'import:import state'
        'init:initialize working directory'
        'login:login to Terraform Cloud'
        'logout:logout from Terraform Cloud'
        'metadata:show metadata'
        'output:read outputs'
        'plan:plan changes'
        'providers:provider info'
        'push:push state'
        'refresh:refresh state'
        'show:show plan/state'
        'state:state subcommands'
        'taint:taint resource'
        'untaint:untaint resource'
        'validate:validate config'
        'version:show version'
        'workspace:workspace subcommands'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '-version[show version]' \
        '-chdir+[chdir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'terraform subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments \
                    '-backend+[init backend]:bool:(true false)' \
                    '-backend-config+[backend config]:str:' \
                    '-force-copy[suppress prompts]' \
                    '-from-module+[module source]:src:' \
                    '-get+[get modules]:bool:(true false)' \
                    '-input+[input]:bool:(true false)' \
                    '-lock+[lock state]:bool:(true false)' \
                    '-lock-timeout+[lock timeout]:duration:' \
                    '-no-color[no color]' \
                    '-plugin-dir+[plugin dir]:dir:_files -/' \
                    '-reconfigure[reconfigure backend]' \
                    '-migrate-state[migrate state]' \
                    '-upgrade[upgrade providers]' \
                    '-var+[input variable]:KEY=VAL:' \
                    '-var-file+[var file]:file:_files' ;;
                plan) _arguments \
                    '-compact-warnings[compact warnings]' \
                    '-destroy[destroy plan]' \
                    '-detailed-exitcode[detailed exit code]' \
                    '-input+[input]:bool:(true false)' \
                    '-lock+[lock state]:bool:(true false)' \
                    '-lock-timeout+[lock timeout]:duration:' \
                    '-no-color[no color]' \
                    '-out+[output plan file]:file:_files' \
                    '-parallelism+[parallelism]:n:' \
                    '-refresh+[refresh]:bool:(true false)' \
                    '-refresh-only[refresh only]' \
                    '-replace+[replace resource]:resource:' \
                    '-state+[state file]:file:_files' \
                    '-target+[target resource]:resource:' \
                    '-var+[input variable]:KEY=VAL:' \
                    '-var-file+[var file]:file:_files' \
                    '-generate-config-out+[generate config out]:file:_files' ;;
                apply|destroy) _arguments \
                    '-auto-approve[skip approval]' \
                    '-backup+[backup file]:file:_files' \
                    '-compact-warnings[compact warnings]' \
                    '-input+[input]:bool:(true false)' \
                    '-lock+[lock state]:bool:(true false)' \
                    '-lock-timeout+[lock timeout]:duration:' \
                    '-no-color[no color]' \
                    '-parallelism+[parallelism]:n:' \
                    '-refresh+[refresh]:bool:(true false)' \
                    '-replace+[replace resource]:resource:' \
                    '-state+[state file]:file:_files' \
                    '-state-out+[state out file]:file:_files' \
                    '-target+[target resource]:resource:' \
                    '-var+[input variable]:KEY=VAL:' \
                    '-var-file+[var file]:file:_files' \
                    '*:plan file:_files' ;;
                workspace) _arguments '1:workspace cmd:(list select new delete show)' '*:workspace:' ;;
                state) _arguments '1:state cmd:(list mv pull push replace-provider rm show)' '*:args:' ;;
                fmt) _arguments \
                    '-list+[list files]:bool:(true false)' \
                    '-write+[write]:bool:(true false)' \
                    '-diff[show diff]' \
                    '-check[exit non-zero if changes]' \
                    '-recursive[recursive]' \
                    '*:file:_files' ;;
                output) _arguments \
                    '-state+[state file]:file:_files' \
                    '-no-color[no color]' \
                    '-json[json]' \
                    '-raw[raw]' \
                    '*:name:' ;;
                show) _arguments '-json[json]' '-no-color[no color]' '*:file:_files' ;;
                import|taint|untaint) _arguments \
                    '-allow-missing[allow missing]' \
                    '-state+[state file]:file:_files' \
                    '*:resource id:' ;;
                validate) _arguments '-no-color[no color]' '-json[json]' ;;
                refresh) _arguments \
                    '-state+[state file]:file:_files' \
                    '-target+[target]:resource:' \
                    '-var+[var]:KEY=VAL:' \
                    '-var-file+[var file]:file:_files' ;;
                console) _arguments \
                    '-state+[state file]:file:_files' \
                    '-var+[var]:KEY=VAL:' \
                    '-var-file+[var file]:file:_files' ;;
            esac
            ;;
    esac
}

_terraform-cli "$@"
