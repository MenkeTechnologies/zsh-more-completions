#compdef wasmtime
# Documentation: https://github.com/bytecodealliance/wasmtime (src/bin/wasmtime.rs)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_wasmtime_commands() {
  local -a commands=(
    'run:Run a WebAssembly module'
    'serve:Run a WebAssembly component (wasi:http/proxy) via HTTP'
    'compile:Compile a WebAssembly module ahead-of-time'
    'explore:Generate an HTML visualization comparing wasm and native code'
    'settings:Show Cranelift settings for the target architecture'
    'wast:Run a WebAssembly spec test script'
    'config:Manage Wasmtime configuration (cache, etc.)'
    'completion:Generate shell completion scripts'
    'objdump:Dump compiled .cwasm contents'
    'hot-blocks:Profile hot blocks (Linux only)'
    'wizer:Pre-initialize a WebAssembly module (wizer)'
  )
  _describe -t commands 'wasmtime command' commands
}

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:_wasmtime_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      run)
        _arguments -s -S \
          '--invoke=[name of function to invoke]:function' \
          '*--env=[pass environment variable (KEY=VALUE)]:var' \
          '*--dir=[grant access to host directory (HOST[::GUEST])]:dir:_directories' \
          '--allow-precompiled[allow loading precompiled modules]' \
          '*-S+[WASI option (-S NAME[=VALUE])]:s' \
          '*-W+[Wasm option (-W NAME[=VALUE])]:w' \
          '*-O+[optimization option (-O NAME[=VALUE])]:o' \
          '*-D+[debug option (-D NAME[=VALUE])]:d' \
          '*-C+[codegen option (-C NAME[=VALUE])]:c' \
          '--profile=[profiler]:profile:(perfmap jitdump vtune)' \
          '--allow-unknown-exports[allow modules with unknown exports]' \
          '--module-name=[module name override]:name' \
          '*--preload=[preload module (NAME=FILE)]:mod' \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:wasm module:_files -g "*.(wasm|wat|cwasm)"' && ret=0
        ;;
      serve)
        _arguments -s -S \
          '--addr=[listening address]:address' \
          '*--env=[pass environment variable]:var' \
          '*--dir=[grant access to directory]:dir:_directories' \
          '*-S+[WASI option]:s' \
          '*-W+[Wasm option]:w' \
          '*-O+[optimization option]:o' \
          '*-D+[debug option]:d' \
          '*-C+[codegen option]:c' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:wasm component:_files -g "*.(wasm|wat|cwasm)"' && ret=0
        ;;
      compile)
        _arguments -s -S \
          '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
          '--target=[target triple]:target' \
          '*-O+[optimization option]:o' \
          '*-C+[codegen option]:c' \
          '*-W+[Wasm option]:w' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:wasm module:_files -g "*.(wasm|wat)"' && ret=0
        ;;
      explore)
        _arguments -s -S \
          '(-o --output)'{-o+,--output=}'[output HTML file]:file:_files' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:wasm module:_files -g "*.(wasm|wat)"' && ret=0
        ;;
      wast)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:wast file:_files -g "*.wast"' && ret=0
        ;;
      config)
        _arguments -s -S \
          '1:subcommand:(new)' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      objdump)
        _arguments -s -S \
          '--all[dump all sections]' \
          '--dwarf-dump[dump DWARF debug info]' \
          '*:file:_files -g "*.cwasm"' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish powershell elvish)' && ret=0
        ;;
      settings)
        _arguments -s -S \
          '--target=[target triple]:target' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
