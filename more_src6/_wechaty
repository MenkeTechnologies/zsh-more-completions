#
#  Maintained by Huan LI (Wechaty.js project lead, zixia@zixia.net,
#  Microsoft AI MVP).  22,805 GH stars.  wechaty is a CONVERSATIONAL
#  RPA SDK for chatbot makers — a Node.js framework for building
#  bots that interact with messaging platforms (WeChat, WhatsApp,
#  Telegram, Lark/Feishu, DingTalk, Wecom, Discord, Gitter, etc.)
#  through a UNIFIED PUPPET ABSTRACTION.  The PUPPET pattern: each
#  messaging platform has a "puppet" implementation (wechaty-
#  puppet-wechat, wechaty-puppet-whatsapp, wechaty-puppet-padlocal,
#  etc.) that wraps the platform's API into a common interface.
#  Bot code writes once → puppet adapters do platform-specific
#  marshalling.  Used for WeChat bots in China where WeChat doesn't
#  expose an official bot API.  ALSO POLYGLOT: Python (wechaty-py),
#  Rust (wechaty-rs), Go (wechaty-go) bindings exist; all speak
#  Wechaty Puppet Service (WPS) gRPC over the wire.  Bin names
#  shipped by the npm package: wechaty, wechaty-doctor, wechaty-
#  io-client, wechaty-puppet-install, wechaty-version.  Sister
#  tools: botpress (Botpress conversational AI — in corpus via
#  _botpress), botkit (Botkit framework), microsoft/botbuilder-js
#  (Microsoft Bot Framework SDK), errbot (Python ChatOps — in
#  corpus via _errbot), hubot (GitHub-era chatbot — in corpus via
#  _hubot).
#
#  CLI library taxonomy update: 13th TypeScript/Node CLI library —
#  Gal "Schniz" Schlezinger's **cmd-ts** (Schniz/cmd-ts).
#  TypeScript-Node ecosystem now has 13 documented CLI libraries —
#  TYING WITH RUST AND GO at the top of the cross-language
#  taxonomy in a THREE-WAY TIE at 13 each.  🎉 TypeScript-Node
#  CATCHES UP — restoring three-way parity (Rust=13, Go=13,
#  TypeScript-Node=13).
#
#  cmd-ts (Schniz/cmd-ts) is Gal "Schniz" Schlezinger's TYPE-DRIVEN
#  TypeScript CLI arg parser — designed around the philosophy of
#  PARSER COMBINATORS / ALGEBRAIC DATA TYPES borrowed from Haskell's
#  optparse-applicative and Scala's decline.  357 GH stars.  Type
#  flows from PARSERS TO HANDLERS: declare a `type: string` arg →
#  handler's `args` param infers `string`; declare `type: array(
#  string)` → handler infers `string[]`; declare `type: oneOf(['a',
#  'b'])` → handler infers `'a' | 'b'` (literal union).  Used by
#  wechaty/wechaty (Conversational RPA SDK 22,805 stars), l2beat/
#  l2beat (Ethereum L2 analytics 656 stars), lunasec-io/lunasec
#  (open-source vuln scanner 1,469 stars), linz/basemaps (NZ
#  authoritative basemap service 120 stars), blacha/cogeotiff
#  (Cloud-Optimized GeoTIFF reader 111 stars), garzj/google-photos-
#  migrate (Google Photos migration 1k+ stars FUTURE), MaayanLab/
#  Playbook-Workflow-Builder, Bisonai/orakl (Bisonai Orakl oracle
#  network), Pingid/lectures.london, PackmindHub/packmind, Layr-
#  Labs/zeus, huan/sidecar (sidecar pattern lib), and other
#  TypeScript CLIs that prefer parser-combinator-style algebraic
#  composition over schema-object frameworks like commander/oclif.
#
#  cmd-ts API:
#    import {
#      command,             // single-command builder
#      subcommands,         // subcommand-group builder
#      run,                 // executor (process.argv → handler)
#      binary,              // strip first 2 argv elements
#      option,              // --flag-with-value
#      flag,                // --boolean-flag
#      positional,          // positional arg
#      string,              // STRING type parser
#      number,              // NUMBER type parser (parses int/float)
#      boolean,             // BOOLEAN type parser
#      array,               // array(T) — REPEATABLE flag combinator
#      optional,            // optional(T) — wraps to Optional<T>
#      oneOf,               // oneOf(['a', 'b']) — literal union
#      multioption,         // multioption(T) — repeat-allowed option
#      Type,                // TYPE INTERFACE for custom parsers
#    } from 'cmd-ts'
#
#    // SINGLE COMMAND
#    const myCmd = command({
#      name: 'mytool',
#      description: 'My tool',
#      version: '1.0.0',
#      args: {
#        // OPTION: --port 8080 / -p 8080
#        port: option({
#          long: 'port',
#          short: 'p',
#          type: optional(number),         // type-inferred Optional<number>
#          description: 'Port number',
#        }),
#        // FLAG: --verbose (boolean)
#        verbose: flag({
#          long: 'verbose',
#          short: 'v',
#          description: 'Verbose output',
#        }),
#        // POSITIONAL: required string arg
#        target: positional({
#          type: string,
#          displayName: 'TARGET',
#          description: 'Target URL',
#        }),
#        // ARRAY: --tag foo --tag bar (repeatable)
#        tags: multioption({
#          long: 'tag',
#          type: array(string),
#          description: 'Tag (repeatable)',
#        }),
#        // ONEOF: --mode=fast | --mode=slow (literal union)
#        mode: option({
#          long: 'mode',
#          type: oneOf(['fast', 'slow', 'auto']),
#          description: 'Run mode',
#        }),
#      },
#      handler: async (args) => {
#        // args is type-inferred:
#        //   { port?: number, verbose: boolean, target: string,
#        //     tags: string[], mode: 'fast' | 'slow' | 'auto' }
#      },
#    });
#
#    // SUBCOMMAND TREE
#    const app = subcommands({
#      name: 'wechaty',
#      description: 'Wechaty CLI',
#      version: VERSION,
#      cmds: {
#        gateway,                          // each cmd is a command(...)
#        token,                            // token itself is subcommands(...)
#        friday,
#        // ...
#      },
#    });
#
#    run(binary(app), process.argv).catch(console.error);
#
#  cmd-ts distinctive features:
#    - PARSER COMBINATOR architecture borrowed from Haskell's
#      optparse-applicative — types are FIRST-CLASS COMPOSABLE
#      values: `array(T)`, `optional(T)`, `oneOf([...])`, `extendType
#      (base, fn)` build new parsers from existing ones
#    - TYPE-FLOWS-FROM-PARSERS-TO-HANDLERS — TypeScript infers the
#      handler's `args` parameter type ENTIRELY from the args
#      schema; `type: optional(number)` → `args.port: number |
#      undefined` AUTOMATICALLY (no manual type annotation)
#    - `Type` INTERFACE — custom parsers implement `{ from(input:
#      string): T; defaultValue?: () => T; description?: string }`;
#      caller-defined types compose with built-in combinators
#    - `option({long, short, type, description, defaultValue, env})`
#      — value-bearing flag with required `type` parser
#    - `flag({long, short, description})` — boolean flag (no value)
#    - `positional({type, displayName, description})` — POSITIONAL
#      arg (type-parsed)
#    - `multioption({long, type, description})` — REPEATABLE option
#      (`--tag foo --tag bar` → `args.tags: T[]`); requires
#      `array(T)` type
#    - `subcommands({name, description, version, cmds})` — NESTED
#      subcommand tree; each entry can be `command()` or another
#      `subcommands()` (RECURSIVE COMPOSITION)
#    - `binary(cmd)` — wrapper that strips the first 2 elements of
#      process.argv (node binary + script path) before parsing
#    - `run(parser, argv)` — executes the matched handler with
#      parsed args; returns its Promise
#    - AUTO --help / --version generation from `name`/`description`/
#      `version` plus per-arg descriptions
#    - `extendType(base, fn)` — derive new type from existing
#      (useful for `int = extendType(string, parseInt)` patterns)
#    - `env: 'VAR_NAME'` on option — read from env if not provided
#    - INSPIRED BY Haskell's optparse-applicative, Scala's decline
#      (typelevel.org/decline), Idris's parse-args — all algebraic
#      DATA TYPE driven CLI builders.  Schniz blog post: "Type-safe
#      CLI Apps in TypeScript with cmd-ts" (gal.hagever.com).
#  Distinct from R236 commander (TJ Holowaychuk's chained-builder
#  with subcommand-tree — Vue CLI/jest/ngx), R237 oclif (Heroku/
#  Salesforce enterprise framework with plugin discovery), yargs
#  (Bash-style yargs-parser — npm/jest), R398 meow (Sindre Sorhus
#  zero-config using minimist), R399 substack/minimist (the
#  ORIGINAL minimal parser), R400 cac (Anthony Fu — uses mri
#  internally), R403 clipanion (Yarn's class-based CLI with
#  `@Command()` decorators — Yarn 2+), R406 vercel/arg (spec-object
#  schema with BUILT-IN type COERCION FUNCTIONS as types — different
#  philosophy from cmd-ts's algebraic Type interface), R409 mri
#  (lukeed minimal parser — what cac/sade use internally), R412
#  citty (UnJS's TypeScript-first DECLARATIVE-SCHEMA — string type
#  names like 'string'/'boolean', NOT cmd-ts's parser-combinator
#  Type values).  TypeScript-Node documented libraries so far:
#  commander, oclif, yargs, meow, minimist, cac, clipanion, arg,
#  mri, sade, citty, cmd-ts (this round)... that's 12 explicit +
#  cmd-ts makes 13 (counting sade which appeared with mri's R409
#  documentation).  cmd-ts's distinguishing feature vs ALL other
#  TS-Node libs: cmd-ts is the ONLY ONE that uses PARSER COMBINATOR
#  ALGEBRA where types are FIRST-CLASS COMPOSABLE VALUES (array(T)/
#  optional(T)/oneOf([...])/extendType(base, fn)) borrowed from
#  Haskell's optparse-applicative — every other TS-Node lib uses
#  either chained-builders (commander/yargs) or schema-objects
#  with string type names (citty/clipanion/arg/cac).  cmd-ts's
#  approach: TYPE-DRIVEN PARSER COMBINATOR with `command({name,
#  description, args, handler})` builder + `subcommands({name,
#  cmds})` recursive subcommand tree + `option/flag/positional/
#  multioption` arg constructors + COMPOSABLE TYPE COMBINATORS
#  (`string`/`number`/`boolean` primitives + `array(T)`/`optional(T)`/
#  `oneOf([...])`/`extendType(base, fn)` higher-kinded combinators)
#  + AUTOMATIC TypeScript type inference from args schema to
#  handler's args param + `run(binary(cmd), process.argv)` executor
#  + AUTO --help/--version + `Type` interface for custom parsers +
#  `env: 'VAR'` env-var fallback — corpus's **first documented
#  parser-combinator-algebra TypeScript-Node CLI library**.  Brings
#  cross-language CLI library taxonomy variant count to 154;
#  TypeScript-Node ecosystem now has 13 documented CLI libraries —
#  TYING WITH RUST AND GO at the top of the cross-language
#  taxonomy in a THREE-WAY TIE at 13.
#
#  Surface (verbatim from `bin/cli.ts` + `src/cli/*.ts` cmd-ts
#  subcommands + wechaty/token bin metadata):
#
#  Usage:
#    wechaty <subcommand> [options]
#
#  Subcommands:
#    friday                         Contact Friday BOT and talk to
#                                   him (NOT YET IMPLEMENTED — stub)
#    gateway                        Publish your DIY token as a
#                                   Wechaty Puppet Service (WPS).
#                                   Generates token via
#                                   `wechaty token generate` if not
#                                   provided
#    provider                       Manage Wechaty Puppet Provider
#                                   (WPP) (NOT YET IMPLEMENTED —
#                                   stub)
#    service                        Manage Wechaty Puppet Service
#                                   (WPS) (NOT YET IMPLEMENTED —
#                                   stub)
#    token                          Generate & discover TOKEN for
#                                   Wechaty (NESTED subcommands
#                                   from wechaty-token package):
#                                   * generate — generate a new
#                                     Wechaty token
#                                   * discover — discover token
#                                     puppet service from network
#
#  Subcommand-specific options:
#
#    wechaty gateway:
#      -t, --token <TOKEN>          Specify a TOKEN for your DIY WPS
#                                   (auto-generated if not provided)
#      -p, --port <PORT>            Specify a port for WPS (free
#                                   port selected automatically if
#                                   not provided; MUST be publicly
#                                   accessible via internet)
#      -P, --puppet <NAME>          Specify a Wechaty Puppet Provider
#                                   (env: WECHATY_PUPPET; defaults
#                                   to OFFICIAL_PUPPET_DEFAULT)
#      -T, --puppet-token <TOKEN>   WPP token (env:
#                                   WECHATY_PUPPET_TOKEN; uses
#                                   WECHATY_PUPPET_XXX_TOKEN
#                                   pattern per provider)
#
#  Meta:
#        --help                     Show help (auto-generated by
#                                   cmd-ts)
#        --version                  Show version (from
#                                   src/config.ts VERSION export)
#
#  Companion binaries shipped by the wechaty npm package
#  (out of scope for this completion — each has its own _completion
#  file or no flags):
#    wechaty-doctor                 Diagnose wechaty installation
#    wechaty-io-client              IO Client launcher
#    wechaty-puppet-install         Install a Wechaty Puppet
#                                   Provider package
#    wechaty-version                Print wechaty version
#
#  Examples:
#    wechaty                                                 # Show help (auto cmd-ts)
#    wechaty gateway                                         # Run gateway, auto-generate token + port + puppet
#    wechaty gateway -t MYTOKEN -p 8788                      # Gateway with explicit token + port
#    wechaty gateway --puppet wechaty-puppet-padlocal        # Gateway with PadLocal puppet
#    wechaty gateway -t MYTOKEN -p 8788 -P wechaty-puppet-padlocal -T PADLOCAL_TOKEN
#    wechaty token generate                                  # Generate a new Wechaty token
#    wechaty token discover                                  # Discover puppet service in network
#    wechaty friday                                          # (stub) contact Friday bot
#    WECHATY_PUPPET=wechaty-puppet-wechat wechaty gateway    # Env var for puppet
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also cmd-ts users):
#    - l2beat (l2beat/l2beat 656 stars — Ethereum L2 analytics;
#      FUTURE candidate)
#    - lunasec (lunasec-io/lunasec 1,469 stars — vuln scanner;
#      FUTURE candidate)
#    - basemaps (linz/basemaps 120 stars — NZ basemap service;
#      FUTURE candidate)
#    - cogeotiff (blacha/cogeotiff 111 stars — Cloud-Optimized
#      GeoTIFF reader; FUTURE candidate)
#    - crosshare (crosshare-org/crosshare 161 stars — crossword
#      site; FUTURE candidate)
# ============================================================================

_wechaty() {
  local context state state_descr line
  typeset -A opt_args
  local curcontext="$curcontext"

  _arguments -C \
    '--help[show help (cmd-ts auto-generated)]' \
    '--version[show version]' \
    '1: :->subcommand' \
    '*:: :->args' && return

  case "$state" in
    subcommand)
      local -a subcmds
      subcmds=(
        'friday:contact Friday BOT (stub — not yet implemented)'
        'gateway:publish your DIY token as a Wechaty Puppet Service'
        'provider:manage Wechaty Puppet Provider (stub)'
        'service:manage Wechaty Puppet Service (stub)'
        'token:generate & discover TOKEN for Wechaty'
      )
      _describe -t subcommands 'wechaty subcommand' subcmds
      ;;
    args)
      case "${words[1]}" in
        gateway)
          _arguments -s -S \
            '(-t --token)'{-t,--token}'[specify a TOKEN for your DIY WPS]:token:' \
            '(-p --port)'{-p,--port}'[specify a port for WPS]:port:' \
            '(-P --puppet)'{-P,--puppet}'[specify a Wechaty Puppet Provider]:puppet:' \
            '(-T --puppet-token)'{-T,--puppet-token}'[WPP token]:token:'
          ;;
        token)
          local -a tokencmds
          tokencmds=(
            'generate:generate a new Wechaty token'
            'discover:discover puppet service from network'
          )
          _describe -t subcommands 'token subcommand' tokencmds
          ;;
        friday|provider|service)
          ;;
      esac
      ;;
  esac
}

_wechaty "$@"
