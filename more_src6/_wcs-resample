#compdef wcs-resample
# Documentation: https://astrometry.net
# Source: dstndstn/astrometry.net man/wcs-resample.1 — project one FITS image onto another (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-E+[input image FITS extension (default 0)]:n:_default' \
    '-w+[input WCS file (default: read WCS from input)]:file:_files -g "*.{wcs,fits,fit}"' \
    '-e+[input WCS FITS extension (default 0)]:n:_default' \
    '-x+[output WCS FITS extension (default 0)]:n:_default' \
    '-L+[Lanczos order (default: nearest-neighbor)]:n:_default' \
    '-z[zero out inf/NaN input values]' \
    '1:input FITS:_files -g "*.{fits,fit,fts}"' \
    '2:output WCS:_files -g "*.{wcs,fits,fit}"' \
    '3:output FITS:_files' \
    && ret=0

return ret
