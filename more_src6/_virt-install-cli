#compdef virt-install-cli
# _virt-install-cli — Red Hat virt-install libvirt VM provisioning CLI alias (virt-manager team, Python); argparse
# upstream: https://github.com/virt-manager/virt-manager

_virt-install-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--connect=+[libvirt URI]:str:' \
        '-c+[libvirt URI]:str:' \
        '--name=+[VM name]:str:' \
        '-n+[VM name]:str:' \
        '--memory=+[RAM MB]:n:' \
        '-r+[RAM MB]:n:' \
        '--memorybacking=+[backing opts]:str:' \
        '--memballoon=+[opts]:str:' \
        '--memdev=+[memory device]:str:' \
        '--vcpus=+[vcpus]:n:' \
        '--numatune=+[opts]:str:' \
        '--cputune=+[opts]:str:' \
        '--cpu=+[cpu model]:str:' \
        '--metadata=+[VM metadata]:str:' \
        '--features=+[features]:str:' \
        '--clock=+[clock opts]:str:' \
        '--pm=+[power management]:str:' \
        '--launchSecurity=+[opts]:str:' \
        '--keywrap=+[opts]:str:' \
        '--events=+[events]:str:' \
        '--resource=+[opts]:str:' \
        '--sysinfo=+[opts]:str:' \
        '--qemu-commandline=+[command line]:str:' \
        '--iothreads=+[opts]:str:' \
        '--osinfo=+[os variant]:str:' \
        '--os-variant=+[os variant]:str:' \
        '--cdrom=+[ISO path]:file:_files -g "*.iso"' \
        '--location=+[install location]:str:' \
        '-l+[install location]:str:' \
        '--pxe[boot from PXE]' \
        '--import[skip install]' \
        '--livecd[live CD]' \
        '--install=+[install opts]:str:' \
        '--unattended=+[unattended install]:str:' \
        '--cloud-init=+[cloud-init opts]:str:' \
        '--boot=+[boot opts]:str:' \
        '--idmap=+[opts]:str:' \
        '--disk=+[disk opts]:str:' \
        '-w+[net opts]:str:' \
        '--network=+[net opts]:str:' \
        '--graphics=+[graphics opts]:str:' \
        '--controller=+[controller]:str:' \
        '--input=+[input device]:str:' \
        '--serial=+[serial]:str:' \
        '--parallel=+[parallel]:str:' \
        '--channel=+[channel]:str:' \
        '--console=+[console]:str:' \
        '--hostdev=+[hostdev]:str:' \
        '--video=+[video]:str:' \
        '--smartcard=+[smartcard]:str:' \
        '--redirdev=+[redirdev]:str:' \
        '--memballoon=+[memballoon]:str:' \
        '--tpm=+[tpm]:str:' \
        '--rng=+[rng]:str:' \
        '--panic=+[panic device]:str:' \
        '--shmem=+[shmem]:str:' \
        '--vsock=+[vsock]:str:' \
        '--iommu=+[iommu]:str:' \
        '--watchdog=+[watchdog]:str:' \
        '--xml=+[xml additions]:str:' \
        '--virt-type=+[hypervisor]:t:(kvm xen qemu vz)' \
        '--accelerate[use acceleration]' \
        '--paravirt[paravirt]' \
        '-p[paravirt]' \
        '--hvm[full virt]' \
        '-v[full virt]' \
        '--container[container guest]' \
        '--arch=+[architecture]:str:' \
        '--machine=+[machine type]:str:' \
        '--filesystem=+[filesystem]:str:' \
        '--noautoconsole[no auto console]' \
        '--noreboot[no reboot]' \
        '--wait=+[wait time]:n:' \
        '--print-xml=+[step]:str:' \
        '--dry-run[dry run]' \
        '--check[check args]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--autostart[autostart VM]' \
        '--transient[transient guest]' \
        '--destroy-on-exit[destroy on exit]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--reinstall=+[reinstall name]:str:' \
        '*:arg:'
}

_virt-install-cli "$@"
