#compdef tableau-cli tabcmd tableau
# _tableau-cli — Tableau Salesforce tableau-cli tabcmd CLI command-line frontend wrapping the Tableau Server Tableau Cloud Salesforce platform managing publish workbook datasource view extract refresh schedule project site user group permission login logout export refresh-extracts run-schedule create-project create-site delete-site (Salesforce team, Java); custom argparse
# upstream: https://www.tableau.com/

_tableau-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'publish:publish a workbook or data source'
        'get:download a workbook or data source'
        'list:list resources'
        'delete:delete a resource'
        'refresh-extracts:refresh extracts'
        'export:export a view'
        'create-project:create a project'
        'create-site:create a site'
        'delete-site:delete a site'
        'create-group:create a group'
        'create-user:create a user'
        'add-users:add users to a group'
        'remove-users:remove users from a group'
        'set:set permissions'
        'reset:reset state'
        'runschedule:run a schedule'
        'editdomain:edit a domain'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-s+[server]:str:' \
        '--server=+[url]:str:' \
        '-u+[user]:str:' \
        '--user=+[user]:str:' \
        '-p+[password]:str:' \
        '--password=+[password]:str:' \
        '-t+[site]:str:' \
        '--site=+[name]:str:' \
        '--proxy=+[url]:str:' \
        '--token-name=+[name]:str:' \
        '--personal-access-token=+[token]:str:' \
        '--no-prompt[no prompt]' \
        '--cookie[use session cookie]' \
        '--no-certcheck[no cert check]' \
        '--no-proxy[no proxy]' \
        '--proxy-credentials=+[user:pass]:str:' \
        '--save[save session]' \
        '-x+[timeout sec]:n:' \
        '--timeout=+[sec]:n:' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'tableau-cli subcommand' sub ;;
        args)
            case $words[1] in
                publish|get|delete|refresh-extracts|export) _arguments '*:resource:_files -g "*.twb *.twbx *.tdsx *.tds *.tde *.hyper"' ;;
                runschedule|create-project|create-site|delete-site|create-group|create-user|add-users|remove-users) _arguments '*:name:' ;;
            esac
            ;;
    esac
}

_tableau-cli "$@"
