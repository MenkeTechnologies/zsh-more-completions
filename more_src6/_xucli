#compdef xucli
# ============================================================================
# _xucli — zsh completion for ExchangeUnion's xucli, the user-facing
#           CLI for the Exchange Union Daemon (xud) — TS-Node=139 CLOSES
#           Axis 84 gRPC Framework Library at 1/1/1 (triple-139 landmark)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/ExchangeUnion/xud
#   Maintainer : Exchange Union
#   License    : AGPL-3.0
#   Stars      : 113
#   Language   : TypeScript (Node.js)
#   Package    : xud  (single npm package shipping two binaries:
#                       xud daemon + xucli client)
#   Binary     : xucli  (package.json bin: {"xucli": "./bin/xucli"})
#   Last push  : 2023-02-25
#
# WHAT IT IS
#   xud is the Exchange Union Daemon — a decentralized cross-chain
#   atomic-swap exchange node built on Lightning Network HTLCs that
#   speaks gRPC for both local control and peer-to-peer trading.
#   `xucli` is its companion command-line client:  it connects to a
#   running xud over a TLS-protected gRPC channel and exposes every
#   daemon RPC as a yargs subcommand — wallet management
#   (`create`, `unlock`, `restore`, `changepass`, `getmnemonic`),
#   currency / pair / channel management (`addcurrency`, `addpair`,
#   `removecurrency`, `removepair`, `openchannel`, `closechannel`,
#   `walletdeposit`, `walletwithdraw`), trading (`buy`, `sell`,
#   `orderbook`, `listorders`, `removeorder`, `removeallorders`,
#   `streamorders`, `tradehistory`, `tradinglimits`), peer
#   management (`connect`, `discovernodes`, `ban`, `unban`,
#   `listpeers`, `executeswap`), and introspection (`getinfo`,
#   `getbalance`, `getnodeinfo`, `listcurrencies`, `listpairs`,
#   `loglevel`, `shutdown`).
#
# CLI ARGUMENT GRAMMAR  (verbatim from bin/xucli `require('yargs')
#                       .options({...})` block plus
#                       `lib/cli/commands/<name>.ts` `export const
#                       command = '...'` strings — yargs 17 builder
#                       API)
#   xucli [GLOBAL OPTIONS] <SUBCOMMAND> [ARGS...]
#
#   Global options:
#     -p, --rpcport <PORT>          RPC service port
#     -h, --rpchost <HOST>          RPC service hostname
#     -c, --tlscertpath <PATH>      Path to the xud TLS certificate
#     -j, --json                    Display output in JSON format
#                                    [default: false]
#     -x, --xudir <DIR>             Data directory for xud
#
#   Subcommands (35 total):
#     addcurrency <currency> <swap_client> [decimal_places]
#                                                  [token_address]
#     addpair                      Add a trading pair
#     ban                          Ban a peer node
#     buy <quantity> <pair_id> <price> [order_id]
#                                  Place a limit/market buy order
#     changepass                   Change the wallet password
#     closechannel                 Close a payment channel
#     connect                      Connect to a peer node
#     create                       Initialize and create a new
#                                  wallet
#     deposit                      Deposit funds into a channel
#     discovernodes                Discover peer nodes
#     executeswap                  Execute a cross-chain atomic
#                                  swap
#     getbalance [currency]        Query channel + wallet balance
#     getinfo                      Display node info (alias counts,
#                                  peers, channels, pairs, version)
#     getmnemonic                  Print the wallet seed mnemonic
#     getnodeinfo                  Print connected-peer info
#     listcurrencies               List supported currencies
#     listorders                   List local orders
#     listpairs                    List trading pairs
#     listpeers                    List connected peers
#     loglevel <level>             Set the log level
#     openchannel <currency> <amount> [node_identifier]
#                                  [push_amount] [fee]
#                                  Open a payment channel
#     orderbook                    Print order book snapshots
#     removeallorders              Remove all local orders
#     removecurrency               Remove a currency
#     removeorder                  Remove a local order
#     removepair                   Remove a trading pair
#     restore                      Restore a wallet from mnemonic
#     sell <quantity> <pair_id> <price> [order_id]
#                                  Place a limit/market sell order
#     shutdown                     Stop the xud daemon
#     streamorders                 Stream order updates
#     tradehistory                 Print recent trades
#     tradinglimits                Print trading limits
#     unban                        Lift a peer ban
#     unlock                       Unlock a previously created wallet
#     walletdeposit                Deposit funds into the on-chain
#                                  wallet
#     walletwithdraw               Withdraw on-chain funds from the
#                                  wallet
#
#   Standard yargs auto-flags:
#     --help                        Show help
#     --version                     Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `@grpc/grpc-js ^1.2.2` declared in
#   package.json — the canonical Node.js gRPC implementation
#   maintained by the gRPC organization at Google
#   (grpc/grpc-node, packages/grpc-js).  `@grpc/grpc-js` is THE
#   pure-JavaScript Node gRPC client/server library (no native
#   bindings, no node-pre-gyp toolchain);  it exposes the
#   `grpc.Client` constructor, `grpc.Server`, `grpc.credentials`
#   builders (`createSsl` / `createInsecure` /
#   `combineChannelCredentials`), `grpc.Metadata`,
#   `grpc.ChannelOptions`, unary + server-streaming +
#   client-streaming + bidi-streaming method definitions,
#   interceptor pipelines, retry / keepalive / channel-state
#   policy, and the modern `loadPackageDefinition` flow paired
#   with `@grpc/proto-loader`.  xucli's `lib/grpc/XudClient.ts`
#   instantiates a per-service `grpc.Client` from the loaded
#   `.proto` files and dispatches each yargs subcommand as a
#   typed RPC against the running xud daemon over TLS.
#   Verified via:
#     gh api repos/ExchangeUnion/xud/contents/package.json
#       → "@grpc/grpc-js": "^1.2.2"
#       → "bin": {"xud": "./bin/xud", "xucli": "./bin/xucli"}
#     gh api repos/ExchangeUnion/xud/contents/bin/xucli
#       → require('yargs').options({...}).commandDir(
#             '../dist/cli/commands/', { recurse: true })
#         .demandCommand(1, '').strict()
#     gh api repos/ExchangeUnion/xud/contents/lib/cli/commands
#       → 35 .ts files, one per RPC
#   This entry is the TS-Node=139 leader bump that CLOSES Axis 84
#   (gRPC Framework Library) at 1/1/1 three-language symmetry —
#   pairing Rust=tonic via xline-kv/Xline (R925 _xlinectl),
#   Go=google.golang.org/grpc via bavix/gripmock (R926 _gripmock),
#   and TS-Node=@grpc/grpc-js via ExchangeUnion/xud (this entry).
#   Triple-139 landmark on commit.
#
#   No completion for `xucli` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_xucli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '(-p --rpcport)'{-p,--rpcport}'=[RPC service port]:port:' \
        '(-h --rpchost)'{-h,--rpchost}'=[RPC service hostname]:host:' \
        '(-c --tlscertpath)'{-c,--tlscertpath}'=[path to the xud TLS certificate]:cert:_files' \
        '(-j --json)'{-j,--json}'[display output in JSON format]' \
        '(-x --xudir)'{-x,--xudir}'=[data directory for xud]:dir:_files -/' \
        '1: :_xucli_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                addcurrency)
                    _arguments \
                        ':currency:' \
                        ':swap_client:' \
                        '::decimal_places:' \
                        '::token_address:' && ret=0 ;;
                buy|sell)
                    _arguments \
                        ':quantity:' \
                        ':pair_id:' \
                        ':price:' \
                        '::order_id:' && ret=0 ;;
                openchannel)
                    _arguments \
                        ':currency:' \
                        ':amount:' \
                        '::node_identifier:' \
                        '::push_amount:' \
                        '::fee:' && ret=0 ;;
                getbalance)
                    _arguments \
                        '::currency:' && ret=0 ;;
                loglevel)
                    _arguments \
                        ':level:(error warn info verbose debug trace)' && ret=0 ;;
                *)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_xucli_commands] )) ||
_xucli_commands() {
    local -a commands
    commands=(
        'addcurrency:add a currency'
        'addpair:add a trading pair'
        'ban:ban a peer node'
        'buy:place a buy order'
        'changepass:change wallet password'
        'closechannel:close a payment channel'
        'connect:connect to a peer node'
        'create:create a new wallet'
        'deposit:deposit funds into a channel'
        'discovernodes:discover peer nodes'
        'executeswap:execute a cross-chain atomic swap'
        'getbalance:query channel + wallet balance'
        'getinfo:display node info'
        'getmnemonic:print wallet seed mnemonic'
        'getnodeinfo:print connected-peer info'
        'listcurrencies:list supported currencies'
        'listorders:list local orders'
        'listpairs:list trading pairs'
        'listpeers:list connected peers'
        'loglevel:set log level'
        'openchannel:open a payment channel'
        'orderbook:print order book snapshots'
        'removeallorders:remove all local orders'
        'removecurrency:remove a currency'
        'removeorder:remove a local order'
        'removepair:remove a trading pair'
        'restore:restore wallet from mnemonic'
        'sell:place a sell order'
        'shutdown:stop the xud daemon'
        'streamorders:stream order updates'
        'tradehistory:print recent trades'
        'tradinglimits:print trading limits'
        'unban:lift a peer ban'
        'unlock:unlock a created wallet'
        'walletdeposit:deposit funds into on-chain wallet'
        'walletwithdraw:withdraw on-chain funds'
    )
    _describe -t commands 'xucli command' commands
}

_xucli "$@"
