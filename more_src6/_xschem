#compdef xschem
# Documentation: https://github.com/StefanSchippers/xschem/blob/master/src/options.c
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (option parser source).

# Xschem: schematic capture with Spice/VHDL/Verilog/tEDAx/symbol netlister.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(- *)'{-v,--version}'[show version and exit]' \
  {-b,--detach}'[detach (batch / no GUI)]' \
  {-x,--no_x}'[disable X display]' \
  {-q,--quit}'[quit after performing requested actions]' \
  {-n,--netlist}'[create netlist]' \
  {-f,--flat_netlist}'[create flat netlist]' \
  {-s,--spice}'[set netlist type to SPICE]' \
  '--spectre[set netlist type to Spectre]' \
  {-V,--vhdl}'[set netlist type to VHDL]' \
  {-w,--verilog}'[set netlist type to Verilog]' \
  {-t,--tedax}'[set netlist type to tEDAx]' \
  {-y,--symbol}'[set netlist type to symbol]' \
  {-p,--postscript}'[print PostScript]' \
  '--pdf[print PDF]' \
  '--png[print PNG]' \
  '--svg[print SVG]' \
  {-c,--color_ps}'[color PostScript output]' \
  {-z,--rainbow}'[rainbow colors]' \
  {-S,--simulate}'[run simulation]' \
  {-W,--waves}'[show waves]' \
  {-r,--no_readline}'[disable readline]' \
  '--pipe[same as --no_readline]' \
  {-i,--no_rcload}'[do not load rc file]' \
  {-d,--debug}'+[debug level]:level:' \
  {-l,--log}'+[log file]:file:_files' \
  {-o,--netlist_path}'+[netlist output directory]:dir:_directories' \
  {-N,--netlist_filename}'+[netlist file name]:file:_files' \
  '--plotfile=[plot file path]:file:_files' \
  '--rcfile=[xschemrc file]:file:_files' \
  '--lastclosed[reopen last closed file]' \
  '--lastopened[reopen last opened files]' \
  '--preinit=[Tcl command before init]:cmd:' \
  '--tcl=[pass Tcl command to interpreter]:cmd:' \
  '--script=[Tcl script file]:file:_files' \
  '--command=[Tcl command after init]:cmd:' \
  '--diff=[diff with file]:file:_files' \
  '--tcp_port=[TCP port]:port:' \
  '*:schematic file:_files -g "*.sch"' && ret=0
return ret
