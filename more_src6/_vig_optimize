#compdef vig_optimize
# Documentation: https://www.systutorials.com/docs/linux/man/1-vig_optimize/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# vig_optimize is part of the Hugin panoramic stitcher suite (the
# "vignetting/exposure optimizer" - not the ViennaRNA tool of similar
# name). Removed from prior file: '-o' as a flag option (it takes
# argument), '-r' (random points; this is correct per upstream).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[display help summary]' \
  '-o+[write results to output project]:file:_files -g "*.pto"' \
  '-v[verbose, print progress messages]' \
  '-p+[number of points to extract]:n:' \
  '-r[extract random points (faster, less accurate)]' \
  '-s+[work on downscaled images, every step halves dimensions]:level:' \
  '-i+[read corresponding points from file]:file:_files' \
  '-w+[dump corresponding points to file]:file:_files' \
  '*:pto_file:_files -g "*.pto"' && ret=0

return ret
