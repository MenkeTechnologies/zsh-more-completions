#compdef tcode
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/tcode.html
# Reference accessed: 2026-05-21
# Verified: EMBOSS tcode — identify coding regions with Fickett TESTCODE statistic.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[turn off prompts]' '-stdout[write stdout]' \
  '-filter[stdin/stdout]' '-options[prompt qualifiers]' '-debug[debug log]' \
  '-verbose[verbose]' '-warning[warnings]' '-error[errors]' '-fatal[fatal]' \
  '-die[dying]' '-version[version]' '-outfile=[output report]:file:_files' \
  '-sequence=[DNA sequence(s)]:file:_files' \
  '-window=[window size (default 200)]:n:' \
  '-step=[window sliding increment (default 3)]:n:' \
  '-datafile=[Fickett statistic data file (Etcode.dat)]:file:_files' \
  '-plot[plot result as graph]' \
  '-graph=[graph format]:fmt:(ps hpgl hp7470 hp7580 meta cps x11 tek tekt none data xterm png gif pdf svg)' \
  '*:DNA sequence:_files' && ret=0

return ret
