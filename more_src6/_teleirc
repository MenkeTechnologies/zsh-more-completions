_teleirc() {
    _arguments -s \
        '-conf[path to config file (default .env)]:file:_files' \
        '-debug[enable debugging output]' \
        '-version[print TeleIRC version and exit]' \
        '-h[show help]' \
        '--help[show help]'
}

_teleirc "$@"
