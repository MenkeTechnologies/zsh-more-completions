#compdef verible-verilog-diff
# Documentation: https://chipsalliance.github.io/verible/
# Source: chipsalliance/verible verible/verilog/tools/diff/verilog-diff.cc — SV-aware diff for verifying formatter / obfuscator output.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--mode=[difference function]:mode:((format\:ignore\ whitespaces\,\ compare\ token\ texts\ \(verify\ formatter\) obfuscate\:preserve\ whitespaces\,\ compare\ token-text\ lengths\ \(verify\ obfuscator\)))' \
    '--flagfile=[load flags from comma-separated files]:files:_files' \
    '--fromenv=[set flags from env (comma-separated)]:flags:' \
    '--tryfromenv=[try to set flags from env if present]:flags:' \
    '--undefok=[flag names ok to specify on CLI]:flags:' \
    '*:SV source files (left then right):_files' \
    && ret=0

return ret
