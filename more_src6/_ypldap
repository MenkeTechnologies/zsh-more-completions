#compdef ypldap
# _ypldap — OpenBSD ypldap (daemon providing YP/NIS maps backed by LDAP per RFC 2307 schemas; mutually exclusive with ypserv(8) for traditional file-backed maps)
# upstream: https://github.com/openbsd/src (usr.sbin/ypldap)
# Flags from usr.sbin/ypldap/ypldap.8 on tip.

_ypldap() {
    _arguments \
        '-d[debug (foreground + stderr)]' \
        '-n[validate config + exit]' \
        '-v[verbose]' \
        '*-D+[define macro=value]:macro=value:' \
        '-f+[config file (default /etc/ypldap.conf)]:file:_files'
}

_ypldap "$@"
