#compdef vpm
# _vpm — V Language vpm CLI package manager for the V language equivalent to npm cargo handling install update list outdated remove search show get vpkg vpm-vlang-org-registry per-project v.mod package definition file Git GitHub-source-direct mirror gitlab-source-direct package authoring (V team, V); custom argparse
# upstream: https://vpm.vlang.io/

_vpm() {
    local -a sub=(
        'install:install a module'
        'update:update a module'
        'upgrade:upgrade a module'
        'outdated:list outdated'
        'list:list installed modules'
        'remove:remove a module'
        'search:search the registry'
        'show:show module info'
        'get:get a module'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--git[clone via git]' \
        '--hg[clone via hg]' \
        '-d[dry run]' \
        '--dry-run[dry run]' \
        '-force[force overwrite]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vpm subcommand' sub ;;
        args)
            case $words[1] in
                install|update|upgrade|remove|search|show|get) _arguments '*:module:' ;;
            esac
            ;;
    esac
}

_vpm "$@"
