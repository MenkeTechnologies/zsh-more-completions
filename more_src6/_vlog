#compdef vlog
# _vlog — Mentor Graphics Siemens ModelSim Questa vlog CLI for the Verilog SystemVerilog compiler producing simulation libraries supporting IEEE 1800-2017 mixed-language UVM include defines incremental compile (Mentor team, C++); custom argparse
# upstream: https://eda.sw.siemens.com/en-US/ic/questa/

_vlog() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-quiet[quiet]' \
        '-modelsimini=+[file]:file:_files -g "*.ini modelsim.ini"' \
        '-sv[SystemVerilog]' \
        '-sv09[SystemVerilog 2009]' \
        '-sv12[SystemVerilog 2012]' \
        '-sv17[SystemVerilog 2017]' \
        '-novopt[no optimization]' \
        '-O0[optimization level 0]' \
        '-O1[optimization level 1]' \
        '-O5[optimization level 5]' \
        '-work+[library name]:str:' \
        '+incdir+=+[include dir]:dir:_files -/' \
        '-y+[search dir]:dir:_files -/' \
        '+libext+=+[ext]:str:' \
        '+define+=+[macro]:str:' \
        '+protect+[file]:file:_files' \
        '-debugVA[debug VA]' \
        '-source[print source]' \
        '-l+[log file]:file:_files' \
        '-logfile=+[log file]:file:_files' \
        '-pedanticerrors[pedantic errors]' \
        '-suppress=+[csv]:str:' \
        '-warning=+[csv]:str:' \
        '-error=+[csv]:str:' \
        '-incr[incremental]' \
        '-incremental[incremental]' \
        '-just[just compile]' \
        '-mfcu[multi-file compile unit]' \
        '-time[print time]' \
        '-sv_pkg+[package]:str:' \
        '-f+[command file]:file:_files' \
        '*:Verilog file:_files -g "*.v *.sv *.vh *.svh"'
}

_vlog "$@"
