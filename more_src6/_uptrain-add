#compdef uptrain-add
# Documentation: https://github.com/uptrain-ai/uptrain
# Reference accessed: 2026-05-23
# Verified: uptrain-add --help (uptrain PyPI optional feature installer).

# Zsh completion for uptrain-add - install Uptrain optional feature extras

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--feature[feature extra to install]:feature:(local-generation st_classic llama-index embeddings openai-evals selfhosted dashboard full)' && ret=0

return ret
