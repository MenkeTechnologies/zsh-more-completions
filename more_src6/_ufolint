#compdef ufolint
# _ufolint — Christopher Simpkins ufolint CLI for fast pre-flight linting of UFO source font directories validating glyph names XML well-formedness fontinfo.plist required fields and reserved subdirectories (source-foundry team, Python); argparse
# upstream: https://github.com/source-foundry/ufolint

_ufolint() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n[non-stdout output]' \
        '--no-color[no color]' \
        '*:UFO source dir:_files -g "*.ufo *.ufoz"'
}

_ufolint "$@"
