#compdef tt
# _tt — Task Timer TUI by caarlos0 (caarlos0/tasktimer)
# upstream: https://github.com/caarlos0/tasktimer
# Subcommands + flags from internal/cmd/*.go (cobra).

_tt() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-p --project)'{-p+,--project=}'[project name]:name:' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_tt_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                completion)
                    _arguments '1:shell:(bash zsh fish)'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_tt_commands] )) ||
_tt_commands() {
    local -a commands
    commands=(
        'report:print a markdown report of the project to stdout'
        'list:list all projects'
        'paths:print the paths used for logs / data / etc.'
        'edit:export → $EDITOR → import (one-step round-trip)'
        'to-json:export the project database as JSON'
        'from-json:import a JSON dump (WIPES the project first)'
        'man:generate manpages for tt'
        'completion:print shell autocompletion scripts'
    )
    _describe -t commands 'tt command' commands
}

_tt "$@"
