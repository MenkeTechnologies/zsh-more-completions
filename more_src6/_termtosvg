#compdef termtosvg
# Documentation: https://github.com/nbedos/termtosvg/blob/develop/man/termtosvg.md
# Reference accessed: 2026-05-21
# Verified: upstream manpage. Subcommands: record, render.
# Flags: -c/--command, -D/--loop-delay, -g/--screen-geometry,
# -m/--min-frame-duration, -M/--max-frame-duration, -t/--template,
# -s/--still-frames, -h/--help.
# Removed from prior file: --version, --verbose,
# -D/--screen-geometry-detection (manpage uses -D for loop-delay),
# (previous file had --loop-delay without short -D).

_termtosvg_commands() {
  local -a commands=(
    'record:record a terminal session in asciicast v2 format'
    'render:convert an asciicast recording to an animated SVG'
  )
  _describe -t commands 'command' commands
}

_termtosvg() {
  local curcontext="$curcontext" state line ret=1

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help message]' \
    '(-g --screen-geometry)'{-g+,--screen-geometry=}'[terminal screen geometry (COLSxROWS)]:geometry' \
    '(-m --min-frame-duration)'{-m+,--min-frame-duration=}'[minimum frame duration in ms]:milliseconds' \
    '(-M --max-frame-duration)'{-M+,--max-frame-duration=}'[maximum frame duration in ms]:milliseconds' \
    '(-s --still-frames)'{-s,--still-frames}'[render still frames into a directory]' \
    '(-t --template)'{-t+,--template=}'[SVG template]:template' \
    '(-c --command)'{-c+,--command=}'[program to record]:command' \
    '(-D --loop-delay)'{-D+,--loop-delay=}'[delay between animation loops (ms)]:milliseconds' \
    '1: :->cmd_or_file' \
    '*::arg:_files' && ret=0

  case $state in
    cmd_or_file)
      _alternative \
        'commands:command:_termtosvg_commands' \
        'files:output file:_files' && ret=0
      ;;
  esac

  return ret
}

_termtosvg "$@"
