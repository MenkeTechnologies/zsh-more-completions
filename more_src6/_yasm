#compdef yasm
# Documentation: yasm -h
# Source: Tortall YASM — modular assembler (NASM-compatible front end).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--version[show version]' \
    '(- *)--license[show license]' \
    '(- *)'{-h,--help}'[show help]' \
    '(-a --arch)'{-a,--arch=}'[architecture (a help for list)]:arch:' \
    '(-p --parser)'{-p,--parser=}'[parser (p help for list)]:parser:' \
    '(-r --preproc)'{-r,--preproc=}'[preprocessor (r help for list)]:preproc:' \
    '(-f --oformat)'{-f,--oformat=}'[object format (f help for list)]:format:' \
    '(-g --dformat)'{-g,--dformat=}'[debug format (g help for list)]:format:' \
    '(-L --lformat)'{-L,--lformat=}'[list format (L help for list)]:format:' \
    '(-l --list)'{-l,--list=}'[list-file output]:file:_files' \
    '(-o --objfile)'{-o,--objfile=}'[object-file output]:file:_files' \
    '--mapfile=[map-file output]:file:_files' \
    '(-m --machine)'{-m,--machine=}'[machine (m help for list)]:machine:' \
    '--force-strict[treat sized operands as strict]' \
    '-w[inhibit warning messages]' \
    '*-W+-[enable/disable warning]:warning:' \
    '-M[generate Makefile dependencies on stdout]' \
    '-E+[redirect error messages to file]:file:_files' \
    '-s[redirect error messages to stdout]' \
    '(-e --preproc-only)'{-e,--preproc-only}'[preprocess only]' \
    '*-i+[include path]:dir:_files -/' \
    '*-I+[include path]:dir:_files -/' \
    '*-P+[pre-include file]:file:_files' \
    '*-d+[pre-define macro]:macro[=value]:' \
    '*-D+[pre-define macro]:macro[=value]:' \
    '*-u+[undefine macro]:macro:' \
    '*-U+[undefine macro]:macro:' \
    '-X+[error/warning message style]:style:(gnu vc)' \
    '--prefix=[prepend to external symbol names]:prefix:' \
    '--suffix=[append to external symbol names]:suffix:' \
    '--postfix=[append to external symbol names]:suffix:' \
    '*:source file:_files -g "*.{asm,s,S}"' \
    && ret=0

return ret
