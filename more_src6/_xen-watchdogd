#compdef xen-watchdogd xenwatchdogd
# Documentation: https://github.com/xen-project/xen/blob/master/tools/misc/xenwatchdogd.c
# Reference accessed: 2026-05-21
# Verified: upstream xenwatchdogd.c getopt_long quoted from source. Note: the
# upstream binary is named `xenwatchdogd` (no hyphen); `xen-watchdogd` is an
# alias used by some distros. Real flags: -h/--help, -F/--foreground,
# -x/--safe-exit, plus required <timeout> [<sleep>] positionals.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(-F --foreground)'{-F,--foreground}'[run in foreground (do not daemonize)]' \
  '(-x --safe-exit)'{-x,--safe-exit}'[disable watchdog on orderly exit]' \
  '1:timeout (seconds, >=2):' \
  '2:sleep (seconds, >=1, < timeout):' && ret=0
return ret
