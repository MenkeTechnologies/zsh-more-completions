#compdef wormhole-william
# Documentation: https://github.com/psanford/wormhole-william
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--relay-url=[rendezvous relay URL]:url' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'send:send a file, directory, or text'
      'recv:receive a file, directory, or text'
      'receive:receive a file, directory, or text'
      'completion:generate shell completion'
    )
    _describe -t commands 'wormhole-william command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      send)
        _arguments -s -S \
          '--code=[user-generated code phrase]:code' \
          '(-c --code-length)'{-c,--code-length}'=[length of code in bytes/words]:length' \
          '(-v --verify)'{-v,--verify}'[display verification string and wait for approval]' \
          '--hide-progress[suppress progress-bar display]' \
          '--text=[text message to send instead of a file (- for stdin)]:text' \
          '--qr[display code as QR code (experimental)]' \
          '--relay-url=[rendezvous relay URL]:url' \
          '*:file to send:_files' && ret=0
        ;;
      receive|recv)
        _arguments -s -S \
          '(-v --verify)'{-v,--verify}'[display verification string and wait for approval]' \
          '--hide-progress[suppress progress-bar display]' \
          '--relay-url=[rendezvous relay URL]:url' \
          '*:code:' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
