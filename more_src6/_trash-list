#compdef trash-list
# Documentation: https://github.com/andreafrancia/trash-cli
# Reference accessed: 2026-05-21
# Verified: upstream docs (trashcli/list/parser.py).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--volumes[list volumes]' \
  '--trash-dirs[list trash directories]' \
  '*--trash-dir=[specify trash directory]:directory:_directories' \
  '--all-users[list trashcans of all users]' && ret=0

return ret
