#compdef tun2socks
# Documentation: https://github.com/xjasonlyu/tun2socks (main.go)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version and exit]' \
  '(-c --config)'{-c,--config}'=[YAML configuration file]:file:_files' \
  '(-d --device)'{-d,--device}'=[device, [driver://]name]:device' \
  '(-p --proxy)'{-p,--proxy}'=[proxy [protocol://]host[:port]]:proxy URL' \
  '--interface=[network interface]:interface' \
  '--loglevel=[log level]:level:(debug info warn error silent)' \
  '--restapi=[HTTP statistic server listen address]:address' \
  '--tcp-sndbuf=[TCP send buffer size for netstack]:size' \
  '--tcp-rcvbuf=[TCP receive buffer size for netstack]:size' \
  '--tcp-auto-tuning[enable TCP receive buffer auto-tuning]' \
  '--udp-timeout=[timeout for each UDP session]:duration' \
  '--mtu=[device maximum transmission unit]:mtu' \
  '--fwmark=[firewall MARK (Linux/BSD)]:mark' \
  '--multicast-groups=[multicast groups, comma separated]:groups' \
  '--tun-pre-up=[command to execute before TUN device setup]:cmd' \
  '--tun-post-up=[command to execute after TUN device setup]:cmd' && ret=0

return ret
