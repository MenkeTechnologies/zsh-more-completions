#compdef zaqar-status
# Documentation: https://docs.openstack.org/zaqar/latest/cli/zaqar-status.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed from prior file: bogus man.archlinux.org search URL and
# unverified oslo.config flag list (kept only the documented
# upgrade subcommand).

local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'upgrade:release-specific upgrade readiness checks'
)
_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'zaqar-status command' commands && ret=0 ;;
  args)
    case $line[1] in
      upgrade)
        _arguments '*::sub:(check)' && ret=0 ;;
    esac ;;
esac
return ret
