#compdef zenta
# Documentation: https://github.com/e6a5/zenta
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_zenta() {
    local line state
    local -a commands
    commands=(
        'now:Standard breathing session with wisdom quote'
        'anchor:Interactive breathing anchor for user-led pacing'
        'reflect:Gentle evening review'
    )

    _arguments -C \
        '--help[Show help]' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'zenta command' commands
            ;;
        args)
            case $line[1] in
                now)
                    _arguments \
                        '--quick[single breathing cycle instead of default 3]' \
                        '--extended[five breathing cycles]' \
                        '--silent[breathing animation without wisdom quote]' \
                        '--simple[line animation instead of circles]'
                    ;;
            esac
            ;;
    esac
}

_zenta "$@"
