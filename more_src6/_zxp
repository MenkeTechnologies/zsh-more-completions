#compdef zxp
# _zxp — zot node-exporter Prometheus bridge (project-zot/zot)
# upstream: https://github.com/project-zot/zot
# Subcommands from pkg/exporter/cli/cli.go (cobra).

_zxp() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'config:start exporter using the given config file'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                config) _arguments '1:config file:_files -g "*.(json|yml|yaml)"' ;;
            esac
            ;;
    esac
}

_zxp "$@"
