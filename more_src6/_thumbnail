#compdef thumbnail
# Documentation: http://www.libtiff.org/tools.html
# Source: libtiff tools/thumbnail.c — generate thumbnail TIFF from input TIFF (C, getopt).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h+[thumbnail image height (default 274)]:height:_default' \
    '-w+[thumbnail image width (default 216)]:width:_default' \
    '-c+[contrast curve]:curve:(linear exp50 exp60 exp70 exp80 exp90 exp)' \
    '1:input.tif:_files -g "*.{tif,tiff,TIF,TIFF}"' \
    '2:output.tif:_files' \
    && ret=0

return ret
