#compdef whodb-cli
# Documentation: https://github.com/clidey/whodb
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: upstream README documents only `whodb-cli` (interactive TUI) and
#       `whodb-cli mcp serve`; full flag list not published.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a cmds
    cmds=(
      'mcp:Model Context Protocol server commands'
    )
    _describe 'command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      mcp)
        _arguments '1:subcommand:(serve)' && ret=0
        ;;
    esac
    ;;
esac

return ret
