#compdef vis
# Documentation: man vis(1) (BSD)
# Source: BSD vis(1) — display non-printable characters in a visual format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-b[turn off backslash prepending + doubling (cat -v-like)]' \
    '-c[C-style backslash sequences (VIS_CSTYLE)]' \
    '-e+[also encode chars in EXTRA]:extra:' \
    '-F+[fold output lines to FOLDWIDTH cols]:foldwidth:' \
    '-f[same as -F]' \
    '-h[RFC 1808 URI encoding (VIS_HTTPSTYLE)]' \
    '-l[mark newlines with \\$ then newline]' \
    '-M[encode all shell meta chars (implies -S -w -g)]' \
    '-m[MIME Quoted-Printable encoding (VIS_MIMESTYLE)]' \
    '-N[encode using "C" locale (VIS_NOLOCALE)]' \
    '-n[turn off encoding (only backslash-double + hidden-NL via -f/-F)]' \
    '-o[octal display \\ddd (VIS_OCTAL)]' \
    '-S[encode shell meta-chars non-whitespace/non-glob (VIS_SHELL)]' \
    '-s[encode only terminal-unsafe chars (VIS_SAFE)]' \
    '-t[also encode tabs (VIS_TAB)]' \
    '-w[also encode whitespace (VIS_WHITE)]' \
    '*:file:_files' \
    && ret=0

return ret
