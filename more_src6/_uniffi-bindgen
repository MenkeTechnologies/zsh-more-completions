#
# WHAT IS camino AND WHY IS IT THE 67TH RUST CLI LIBRARY?
#
# camino (https://github.com/camino-rs/camino, 556+ stars) is **the
# Rust library for UTF-8-encoded paths** — a narrowly-focused crate
# that solves the recurring Rust-CLI problem of "I know all my paths
# are UTF-8 but std::path::Path forces me to handle the OsStr non-
# UTF-8 case at every conversion".  Where Rust's stdlib treats paths
# as OS-specific byte sequences (PathBuf wraps OsString which on
# Linux is arbitrary bytes and on Windows is UTF-16), camino's
# Utf8PathBuf + Utf8Path types guarantee UTF-8 encoding at the type
# level — converting INTO camino from OS paths requires explicit
# validation, converting OUT of camino to std is infallible.
#
# camino's distinguishing characteristics:
#
#   1. Utf8PathBuf + Utf8Path TYPES — camino's central feature is
#      drop-in UTF-8-guaranteed replacements for std::path types:
#
#          use camino::{Utf8Path, Utf8PathBuf};
#          use std::path::{Path, PathBuf};
#
#          // Convert FROM std (validates UTF-8):
#          let std_path = PathBuf::from("/etc/passwd");
#          let utf8_path: Utf8PathBuf = Utf8PathBuf::from_path_buf(
#              std_path
#          ).expect("path must be valid UTF-8");
#
#          // Convert FROM camino TO std (infallible):
#          let std_path: PathBuf = utf8_path.into();
#          let std_path_ref: &Path = utf8_path.as_std_path();
#
#          // Use camino directly — every std::path method
#          // mirrored, with UTF-8 return types where applicable:
#          let parent: Option<&Utf8Path> = utf8_path.parent();
#          let extension: Option<&str> = utf8_path.extension();
#          let file_name: Option<&str> = utf8_path.file_name();
#          let str_view: &str = utf8_path.as_str();  // INFALLIBLE
#
#      Compare:
#         * std::path::Path: OsStr (NOT guaranteed UTF-8); methods
#                              return Option<&OsStr> requiring
#                              .to_str()? at every use
#         * Rust path-related crates: most don't provide UTF-8
#                                       guarantees
#         * Go filepath stdlib: paths are strings (Go's strings
#                                are byte slices, not validated
#                                UTF-8 either)
#         * Node path stdlib: JavaScript strings are UTF-16
#                              (effectively unicode); paths are
#                              strings
#         * camino: UTF-8 GUARANTEED at the type level for Rust
#      FIRST documented Rust Axis 14 library with type-level
#      UTF-8 path encoding guarantee.
#
#   2. METHOD-BY-METHOD STD::PATH PARALLEL — camino is intentionally
#      designed as a DROP-IN REPLACEMENT for std::path.  Every
#      std::path method is mirrored on camino's types:
#
#          // All std::path::Path methods work on Utf8Path:
#          utf8_path.exists()
#          utf8_path.is_file()
#          utf8_path.is_dir()
#          utf8_path.is_absolute()
#          utf8_path.is_relative()
#          utf8_path.has_root()
#          utf8_path.parent()         // returns Option<&Utf8Path>
#          utf8_path.file_name()      // returns Option<&str> (UTF-8!)
#          utf8_path.file_stem()      // returns Option<&str>
#          utf8_path.extension()      // returns Option<&str>
#          utf8_path.join(other)       // returns Utf8PathBuf
#          utf8_path.with_extension(ext)
#          utf8_path.read_dir()       // returns std::fs::ReadDir
#          utf8_path.canonicalize()   // returns Result<Utf8PathBuf>
#          utf8_path.metadata()
#          utf8_path.symlink_metadata()
#          utf8_path.read_link()      // returns Result<Utf8PathBuf>
#          utf8_path.ancestors()      // returns iterator
#          utf8_path.components()     // returns iterator
#          // ... every std::path method
#
#      Compare:
#         * std::path: same API surface, but returns OsStr/PathBuf
#                       requiring UTF-8 conversion at use sites
#         * camino: SAME API SURFACE with UTF-8 return types
#      FIRST documented Rust Axis 14 library with method-by-method
#      std::path API parallel.
#
#   3. SERDE INTEGRATION via "serde" feature — camino's Utf8PathBuf
#      serializes/deserializes as plain strings, unlike std::path
#      PathBuf which has awkward OsString-wrapped representations
#      in serde-driven serialization:
#
#          #[derive(serde::Serialize, serde::Deserialize)]
#          struct Config {
#              data_dir: Utf8PathBuf,        // ← becomes "/path/to/data"
#              cache_dir: Utf8PathBuf,
#              log_file: Utf8PathBuf,
#          }
#
#          // JSON:
#          // {"data_dir": "/var/lib/myapp", ...}
#
#          // Compare to PathBuf which round-trips as either
#          // "/var/lib/myapp" (if UTF-8) or some platform-specific
#          // byte representation
#
#      Compare:
#         * std::path::PathBuf: serde uses OsString representation;
#                                bytes on Linux can produce
#                                non-string JSON
#         * Go filepath: native string type; trivial JSON serde
#         * Node path: native string type; trivial JSON serde
#         * camino: GUARANTEED STRING serde representation
#      FIRST documented Rust Axis 14 library with guaranteed
#      string serde round-tripping.
#
#   4. CARGO-FOUNDATIONAL — camino is used INTERNALLY by Cargo (the
#      Rust package manager) for ALL path handling in Cargo.toml
#      manifest parsing, Cargo.lock lockfile generation, and the
#      crates.io index.  This means EVERY Rust developer is
#      transitively using camino via cargo, even if they don't
#      directly depend on it.
#
#      Other foundational uses:
#         * cargo-msrv (R-prev?) for MSRV detection
#         * cargo-deny for dependency auditing
#         * cargo-audit for security advisories
#         * uniffi-bindgen (THIS — Mozilla cross-platform bindings)
#         * ankitects/anki (28k stars — Anki flashcard software)
#         * casey/just (34k stars — task runner)
#         * vercel/turborepo (build system)
#         * facet-rs/facet (reflection)
#         * microsoft/windows-drivers-rs (Windows drivers)
#         * coreos/rpm-ostree (atomic upgrades)
#         * 1500+ Rust applications
#      FIRST documented Rust Axis 14 library with cargo-
#      foundational provenance.
#
#   5. DAVID-TOLNAY ECOSYSTEM PROVENANCE — camino is co-maintained
#      by David Tolnay (dtolnay on GitHub), who also maintains:
#         * serde — THE canonical Rust serialization framework
#         * anyhow (R598) — error type for applications
#         * thiserror (R602) — derive macros for library errors
#         * syn — Rust syntax tree
#         * quote — TokenStream quoting
#         * proc-macro2 — proc-macro infrastructure
#         * paste, async-trait, semver, prettyplease
#         * dtoa, itoa, ryu — number→string
#         * 50+ more
#      David's "Tolnay-ecosystem" is the INFRASTRUCTURE LAYER of
#      Rust development — packages used transitively by tens of
#      thousands of Rust applications.  camino joins this layer
#      as the UTF-8 path component.
#      Anyhow (R598) + thiserror (R602) + camino are three Tolnay
#      libraries now documented in this taxonomy (across Axes 6 +
#      6 + 14).  Tolnay becomes the FIRST library-author with
#      THREE documented libraries across THREE distinct axes
#      (matching Sindre Sorhus from R635 in cross-axis breadth).
#      FIRST documented Rust Axis 14 library with this specific
#      David-Tolnay infrastructure-Rust provenance.
#
# camino's relationship to other Rust libraries (no other Axis 14
# library documented yet — camino opens this axis):
#
#   * Unlike std::path::Path — std::path is OsStr-wrapped, NOT
#                                guaranteed UTF-8; camino is
#                                UTF-8 guaranteed at type level
#   * Closest cross-language analogs:
#         * Go path/filepath (stdlib) — string-typed paths (Go
#                                          strings are bytes,
#                                          loosely-validated UTF-8)
#         * Node path module (stdlib) — JavaScript-string paths
#                                         (UTF-16 native)
#         * Python pathlib (stdlib) — str-typed (UTF-8 by Python
#                                       3 convention)
#     camino is the FIRST documented Rust Axis 14 library
#     providing type-level UTF-8 path guarantees + method-by-
#     method std::path API parallel + cargo-foundational role +
#     David-Tolnay infrastructure-Rust ecosystem provenance.
#
# -----------------------------------------------------------------------------
#
# THE uniffi-bindgen CLI — clap-derive + camino + 3 subcommands + 4 target langs
#
# uniffi-bindgen's CLI is in uniffi/src/cli/uniffi_bindgen.rs.  Uses
# clap 4.x derive with Subcommand enum:
#
#     use camino::Utf8PathBuf;
#     use clap::{Args, Parser, Subcommand, ValueEnum};
#
#     #[derive(Copy, Clone, ValueEnum)]
#     enum TargetLanguageArg {
#         Kotlin, Swift, Python, Ruby,
#     }
#
#     #[derive(Parser)]
#     #[clap(name = "uniffi-bindgen")]
#     #[clap(version = clap::crate_version!())]
#     #[clap(propagate_version = true)]
#     struct Cli {
#         #[clap(subcommand)]
#         command: Commands,
#     }
#
#     #[derive(Subcommand)]
#     enum Commands {
#         Generate { ... },        // foreign-language bindings
#         Scaffolding { ... },     // Rust-side FFI scaffolding
#         Pipeline(PipelineArgs),  // inspect render pipeline
#     }
#
# Every path argument in the CLI uses camino::Utf8PathBuf:
#     out_dir: Option<Utf8PathBuf>
#     config: Option<Utf8PathBuf>
#     source: Utf8PathBuf
#     udl_file: Utf8PathBuf
#
# Subcommands:
#   generate     — Generate foreign-language bindings
#                   --language/-l LANG    (kotlin/swift/python/ruby; repeatable)
#                   --out-dir/-o DIR
#                   --no-format/-n
#                   --config/-c FILE      (uniffi.toml global config)
#                   --library             (cdylib source mode)
#                   --crate NAME          (crate name override)
#                   --metadata-no-deps    (exclude Cargo deps)
#                   SOURCE                (UDL file OR cdylib path)
#   scaffolding  — Generate Rust scaffolding
#                   --out-dir/-o DIR
#                   --no-format/-n
#                   UDL_FILE
#   pipeline     — Inspect bindings render pipeline (debugging)
#                   --library             (cdylib source mode)
#                   --crate NAME
#                   --metadata-no-deps
#                   --pass/-p PASS        (filter to specific pass)
#                   --no-diff             (suppress middle-pass diffs)
#                   --type/-t TYPE        (filter by type name)
#                   --name/-n FILTER      (filter by field name)
#                   LANGUAGE
#                   SOURCE
#
# Five-axis distinctness from no other Rust Axis 14 library (camino
# opens this axis):
#
#   1. TYPE-LEVEL UTF-8 GUARANTEE — Utf8PathBuf/Utf8Path enforce
#      UTF-8 at the type system; std::path uses OsStr which may
#      not be UTF-8.
#
#   2. METHOD-BY-METHOD STD::PATH API PARALLEL — every std::path
#      method mirrored with UTF-8 return types.
#
#   3. SERDE INTEGRATION — guaranteed-string serde representation;
#      std::path::PathBuf has awkward OsString-wrapped serde
#      behavior.
#
#   4. CARGO-FOUNDATIONAL — used internally by Cargo for ALL
#      manifest path handling.
#
#   5. DAVID-TOLNAY ECOSYSTEM — joins serde + anyhow + thiserror +
#      syn + quote in the infrastructure-Rust layer.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/mozilla/uniffi-rs/blob/main/uniffi/src/cli/uniffi_bindgen.rs
# clap derive Cli + Commands + PipelineArgs structs.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _uniffi_cmds _uniffi_languages
_uniffi_cmds=(
    'generate:generate foreign-language bindings (kotlin/swift/python/ruby)'
    'scaffolding:generate Rust-side FFI scaffolding'
    'pipeline:inspect the bindings render pipeline (debugging)'
    'help:show help for a subcommand'
)
_uniffi_languages=(
    'kotlin:Kotlin bindings (Android + JVM)'
    'swift:Swift bindings (iOS + macOS)'
    'python:Python bindings'
    'ruby:Ruby bindings'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'uniffi-bindgen subcommand' _uniffi_cmds && ret=0
        ;;
    args)
        case $words[1] in
            generate)
                _arguments \
                    '*'{-l+,--language=}'[foreign language(s) for bindings]:language:(kotlin swift python ruby)' \
                    '(-o --out-dir)'{-o+,--out-dir=}'[directory for generated files (default: UDL folder)]:dir:_directories' \
                    '(-n --no-format)'{-n,--no-format}'[skip formatting of generated bindings]' \
                    '(-c --config)'{-c+,--config=}'[global uniffi.toml config path]:config file:_files -g "*.toml"' \
                    '--library[source is a cdylib rather than UDL file (default; deprecated flag)]' \
                    '--crate=[crate name (use without parsing Cargo.toml)]:crate:_default' \
                    '--metadata-no-deps[exclude dependencies in cargo metadata]' \
                    '1:UDL file or cdylib:_files -g "*.{udl,so,dylib,dll}"' \
                    && ret=0
                ;;
            scaffolding)
                _arguments \
                    '(-o --out-dir)'{-o+,--out-dir=}'[directory for generated files]:dir:_directories' \
                    '(-n --no-format)'{-n,--no-format}'[skip formatting of generated scaffolding]' \
                    '1:UDL file:_files -g "*.udl"' \
                    && ret=0
                ;;
            pipeline)
                _arguments \
                    '--library[source is a cdylib rather than UDL file]' \
                    '--crate=[crate name override]:crate:_default' \
                    '--metadata-no-deps[exclude dependencies in cargo metadata]' \
                    '(-p --pass)'{-p+,--pass=}'[only show passes matching PASS (or "last")]:pass:_default' \
                    '--no-diff[do not show diffs for middle passes]' \
                    '(-t --type)'{-t+,--type=}'[filter to types with this name]:type:_default' \
                    '(-n --name)'{-n+,--name=}'[filter to items with fields matching FILTER]:name:_default' \
                    '1:target language:(kotlin swift python ruby)' \
                    '2:UDL file or cdylib:_files -g "*.{udl,so,dylib,dll}"' \
                    && ret=0
                ;;
            help)
                _describe -t commands 'subcommand' _uniffi_cmds && ret=0
                ;;
        esac
        ;;
esac

return ret
