#compdef trezorctl
# Documentation: https://github.com/trezor/trezor-firmware/blob/main/python/src/trezorlib/cli/trezorctl.py
# Reference accessed: 2026-05-27
# Verified: upstream trezorctl.py main `cli` Click group (trezor/trezor-firmware)
# Coverage: all top-level subcommand groups and global flags; per-subcommand
# internals delegated to _normal fallback.

local curcontext="$curcontext" state line ret=1

local -a _trezorctl_subcommands
_trezorctl_subcommands=(
  'btc:Bitcoin and Bitcoin-like coin commands'
  'cardano:Cardano (ADA) commands'
  'crypto:Generic cryptographic primitives'
  'device:Device management commands'
  'eos:EOS commands'
  'ethereum:Ethereum commands'
  'evolu:Evolu commands'
  'fido:FIDO2 / U2F commands'
  'firmware:Firmware update commands'
  'monero:Monero commands'
  'nem:NEM commands'
  'nostr:Nostr commands'
  'ripple:Ripple (XRP) commands'
  'settings:Device settings (alias of set)'
  'solana:Solana commands'
  'stellar:Stellar commands'
  'telemetry:Telemetry commands'
  'tezos:Tezos commands'
  'tron:Tron commands'
  'debug:Debug commands'
  'benchmark:Benchmark commands'
  'ble:Bluetooth Low Energy commands'
)

_arguments -C \
  '(-p --path)'{-p+,--path=}'[select device by specific transport path]:path:' \
  '(-B --ble --no-ble)'{-B,--ble,--no-ble}'[enable or disable Bluetooth Low Energy transport]' \
  '*'{-v,--verbose}'[show communication messages (repeat for more)]' \
  '(-j --json)'{-j,--json}'[print result as JSON object]' \
  '(-P --passphrase-on-host)'{-P,--passphrase-on-host}'[enter passphrase on host]' \
  '(-S --script)'{-S,--script}'[use UI suitable for script usage]' \
  '(-s --session-id)'{-s+,--session-id=}'[resume the given session id]:session-id:' \
  '(-r --record)'{-r+,--record=}'[record screen changes into directory]:directory:_files -/' \
  '--version[show version information and exit]' \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'trezorctl subcommand' _trezorctl_subcommands && ret=0
    ;;
  args)
    _normal && ret=0
    ;;
esac

return ret
