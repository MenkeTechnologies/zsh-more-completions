#compdef unconvert
# Documentation: https://github.com/mdempsky/unconvert
# Reference accessed: 2026-05-21
# Verified: upstream unconvert.go flag.Bool/flag.String declarations.

_arguments -s -S \
  '-all[type-check all GOOS and GOARCH combinations]' \
  '-apply[apply edits to source files]' \
  '-safe[be more conservative (experimental)]' \
  '-v[verbose output]' \
  '-tests[include test source files]' \
  '-fastmath[remove conversions that force intermediate rounding]' \
  '-cpuprofile=[write CPU profile to file]:file:_files' \
  '-tags=[space-separated build tags]:tags:' \
  '-configs=[custom configs (experimental)]:configs:' \
  '*:packages or paths:_files -/'
