#compdef wcs-pv2sip
# Documentation: https://astrometry.net
# Source: dstndstn/astrometry.net man/wcs-pv2sip.1 — convert FITS PV WCS distortion to SIP (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-o+[SIP polynomial order]:n:_default' \
    '-e+[FITS extension to read]:n:_default' \
    '-S[strip TPV/TAN keywords from output]' \
    '-s[do not strip distortion keywords]' \
    '-t[output TAN-SIP instead of SIP]' \
    '-v[verbose]' \
    '-W+[image width (pixels)]:n:_default' \
    '-H+[image height (pixels)]:n:_default' \
    '-x+[grid point x-lo]:n:_default' \
    '-y+[grid point y-lo]:n:_default' \
    '-X+[grid point x-hi]:n:_default' \
    '-Y+[grid point y-hi]:n:_default' \
    '-a+[grid spacing/size]:n:_default' \
    '1:input WCS file:_files -g "*.{wcs,fits,fit}"' \
    '2::output WCS file:_files' \
    && ret=0

return ret
