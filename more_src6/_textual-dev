#compdef textual-dev

_textual-dev() {
    local curcontext="$curcontext" state line ret=1

    _arguments -C \
        '(- *)--help[show help message and exit]' \
        '(- *)--version[show version and exit]' \
        '1:subcommand:->subcmd' \
        '*::args:->args' && ret=0

    case $state in
        subcmd)
            local -a subcmds=(
                'run:run a Textual application'
                'console:start the developer console'
                'colors:display available colors'
                'easing:display easing functions'
                'keys:display key bindings'
                'borders:display available border styles'
                'css:show CSS reference'
            )
            _describe -t commands 'textual-dev subcommand' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                run)
                    _arguments \
                        '--dev[enable development mode]' \
                        '--press=[simulate key presses]:keys:' \
                        '--screenshot=[take screenshot after delay]:delay:' \
                        '--command=[run a command instead of importing a module]:command:' \
                        '*:app module:_files' && ret=0
                    ;;
                console)
                    _arguments \
                        '--port=[port for the console server]:port:' \
                        '(-v --verbose)'{-v,--verbose}'[enable verbose output]' && ret=0
                    ;;
                colors|easing|keys|borders|css)
                    _arguments \
                        '--help[show help for this subcommand]' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_textual-dev "$@"
