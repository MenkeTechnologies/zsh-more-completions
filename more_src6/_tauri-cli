#compdef cargo-tauri tauri
# _tauri-cli — Tauri CLI for building desktop apps (tauri-apps/tauri)
# upstream: https://github.com/tauri-apps/tauri

_tauri-cli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_tauri_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                init)
                    _arguments \
                        '--app-name=[app name]:name:' \
                        '--window-title=[window title]:title:' \
                        '--dist-dir=[web assets directory]:dir:_directories' \
                        '--dev-path=[dev server URL or path]:path:' \
                        '(-f --force)'{-f,--force}'[force overwrite]' \
                        '(-l --log)'{-l,--log}'[enable logging]' \
                        '--ci[skip prompts]' && ret=0 ;;
                dev)
                    _arguments \
                        '(-r --release)'{-r,--release}'[build in release mode]' \
                        '(-f --features)'{-f,--features}'=[Cargo features]:features:' \
                        '--target=[target triple]:target:' \
                        '--no-watch[disable file watcher]' \
                        '--port=[dev server port]:port:' && ret=0 ;;
                build)
                    _arguments \
                        '(-d --debug)'{-d,--debug}'[build in debug mode]' \
                        '(-f --features)'{-f,--features}'=[Cargo features]:features:' \
                        '--target=[target triple]:target:' \
                        '(-b --bundles)'{-b,--bundles}'=[bundle types]:type:(deb appimage msi nsis dmg app updater)' \
                        '--ci[skip prompts]' && ret=0 ;;
                icon)
                    _arguments \
                        '(-o --output)'{-o,--output}'=[output directory]:dir:_directories' \
                        '1:input icon:_files -g "*.png *.svg"' && ret=0 ;;
                signer)
                    _arguments \
                        '1: :(generate sign)' && ret=0 ;;
                completions)
                    _arguments \
                        '(-s --shell)'{-s,--shell}'=[shell]:shell:(bash elvish fish powershell zsh)' \
                        '(-o --output)'{-o,--output}'=[output directory]:dir:_directories' && ret=0 ;;
                info|migrate|version|help) ;;
                plugin|inspect|add|remove|permission|capability)
                    _arguments '*:args:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_tauri_commands] )) ||
_tauri_commands() {
    local -a commands
    commands=(
        'init:initialize a Tauri project'
        'dev:run the app in development mode'
        'build:build the Tauri application'
        'info:show environment info'
        'icon:generate app icons'
        'signer:manage signing keys'
        'completions:generate shell completions'
        'plugin:manage Tauri plugins'
        'migrate:migrate to latest Tauri version'
        'inspect:inspect Tauri project'
        'add:add a Tauri plugin'
        'remove:remove a Tauri plugin'
        'permission:manage permissions'
        'capability:manage capabilities'
    )
    _describe -t commands 'tauri command' commands
}

_tauri-cli "$@"
