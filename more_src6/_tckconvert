#compdef tckconvert
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/tckconvert.html
# Source: MRtrix3/mrtrix3 cmd/tckconvert.cpp — convert between tractography formats (tck/vtk/ply/rib) (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-scanner2voxel+[reference image: scanner→voxel transform]:reference:_files -g "*.{nii,nii.gz,mif}"' \
    '-scanner2image+[reference image: scanner→image-space transform]:reference:_files -g "*.{nii,nii.gz,mif}"' \
    '-voxel2scanner+[reference image: voxel→scanner transform]:reference:_files -g "*.{nii,nii.gz,mif}"' \
    '-image2scanner+[reference image: image-space→scanner transform]:reference:_files -g "*.{nii,nii.gz,mif}"' \
    '-sides+[number of sides for PLY/RIB streamlines]:n:_default' \
    '-increment+[generate point every N points (PLY/RIB)]:n:_default' \
    '-dec[add DEC as a primvar (RIB)]' \
    '-radius+[streamline radius (PLY/RIB)]:value:_default' \
    '(-binary)-ascii[write ASCII VTK file (default)]' \
    '(-ascii)-binary[write binary VTK file]' \
    '1:input track file:_files -g "*.{tck,trk,vtk,ply,rib}"' \
    '2:output track file:_files -g "*.{tck,trk,vtk,ply,rib}"' \
    && ret=0

return ret
