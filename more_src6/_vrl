#compdef vrl
# Documentation: https://github.com/vectordotdev/vrl (src/cli/cmd.rs clap derive)
# Reference accessed: 2026-05-29
# Vector Remap Language — script/REPL for VRL programs (Datadog Vector's transform DSL).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-i --input)'{-i,--input=}'[file containing event objects (JSON, one per line)]:file:_files -g "*.(json|jsonl|ndjson)"' \
  '(-p --program PROGRAM)'{-p,--program=}'[VRL program file (conflicts with PROGRAM positional)]:file:_files -g "*.vrl"' \
  '(-q --quiet)'{-q,--quiet}'[suppress banner and startup help]' \
  '(-o --object)'{-o,--object}'[print modified event object instead of final expression result]' \
  '(-z --timezone)'{-z,--timezone=}'[timezone used to parse dates]:tz:(UTC America/New_York America/Los_Angeles Europe/London Europe/Paris Europe/Berlin Asia/Tokyo Asia/Shanghai Asia/Kolkata Australia/Sydney)' \
  '(-r --runtime)'{-r,--runtime=}'[VRL runtime]:runtime:(ast vm)' \
  '--print-warnings[enable warning output]' \
  '*:VRL program or args:' && ret=0

return ret
