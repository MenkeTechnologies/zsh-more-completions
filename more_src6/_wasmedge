#compdef wasmedge
# Documentation: https://github.com/WasmEdge/WasmEdge (include/driver/tool.h, include/driver/options.h)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--reactor[run exported functions instead of _start]' \
  '--run-mode=[execution mode]:mode:(interpreter jit aot)' \
  '*--dir=[bind directory into WASI virtual filesystem (guest:host)]:mapping' \
  '*--env=[assign WASI environment variable (KEY=VALUE)]:var' \
  '*--module=[link an additional module]:file:_files' \
  '--time-limit=[execution time limit in milliseconds]:ms' \
  '--gas-limit=[gas consumption limit]:n' \
  '--memory-page-limit=[memory page limit per instance]:pages' \
  '--enable-instruction-count[enable instruction count statistics]' \
  '--enable-gas-measuring[enable gas measurement statistics]' \
  '--enable-time-measuring[enable time measurement statistics]' \
  '--enable-all-statistics[enable all statistics]' \
  '--enable-coredump[enable wasm coredump on trap]' \
  '--coredump-for-wasmgdb[emit coredump compatible with wasmgdb]' \
  '--allow-af-unix[allow AF_UNIX sockets in WASI]' \
  '--log-level=[log level]:level:(trace debug info warning error critical off)' \
  '*--forbidden-plugin=[name of plugin to forbid loading]:name' \
  '--enable-jit[(deprecated) enable JIT; use --run-mode=jit]' \
  '--force-interpreter[(deprecated) force interpreter; use --run-mode=interpreter]' \
  '--wasm-1[set as WASM 1.0 standard]' \
  '--wasm-2[set as WASM 2.0 standard]' \
  '--wasm-3[set as WASM 3.0 standard (default)]' \
  '--disable-import-export-mut-globals[disable mutable globals proposal]' \
  '--disable-non-trap-float-to-int[disable non-trapping float-to-int conversions proposal]' \
  '--disable-sign-extension-operators[disable sign extension operators proposal]' \
  '--disable-multi-value[disable multi-value proposal]' \
  '--disable-bulk-memory[disable bulk memory operations proposal]' \
  '--disable-reference-types[disable reference types proposal]' \
  '--disable-simd[disable SIMD proposal]' \
  '--disable-tail-call[disable tail-call proposal]' \
  '--disable-extended-const[disable extended-const proposal]' \
  '--disable-function-reference[disable function references proposal]' \
  '--disable-gc[disable GC proposal]' \
  '--disable-multi-memory[disable multiple memories proposal]' \
  '--disable-relaxed-simd[disable relaxed SIMD proposal]' \
  '--disable-memory64[disable memory64 proposal]' \
  '--disable-exception-handling[disable exception handling proposal]' \
  '--enable-exception-handling[(deprecated) enable exception handling]' \
  '--enable-tail-call[(deprecated) enable tail-call]' \
  '--enable-extended-const[(deprecated) enable extended-const]' \
  '--enable-function-reference[(deprecated) enable function references]' \
  '--enable-gc[(deprecated) enable GC]' \
  '--enable-multi-memory[(deprecated) enable multiple memories]' \
  '--enable-relaxed-simd[(deprecated) enable relaxed SIMD]' \
  '--enable-threads[enable threads proposal]' \
  '--enable-component[enable component model proposal]' \
  '--enable-all[enable all features]' \
  '*: :_files -g "*.(wasm|so)"' && ret=0

return ret
