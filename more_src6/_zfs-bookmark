#compdef zfs-bookmark
# _zfs-bookmark — OpenZFS zfs bookmark (create a lightweight bookmark from a snapshot or another bookmark; positional arguments are SOURCE (snapshot|bookmark) and NEWBOOKMARK; bookmarks let incremental sends survive after the source snapshot is destroyed)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zfs/zfs_main.c (zfs_do_bookmark) on tip.

_zfs-bookmark() {
    _arguments \
        '1:source snapshot or bookmark:' \
        '2:new bookmark:'
}

_zfs-bookmark "$@"
