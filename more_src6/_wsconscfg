#compdef wsconscfg
# Documentation: man wsconscfg(8)
# Source: netbsd/src usr.sbin/wsconscfg — wscons virtual terminal configuration (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d[delete the specified terminal]' \
    '-e+[terminal emulation type]:emul:_default' \
    '-F[force deletion of in-use terminals]' \
    '-f+[wscons control device (default /dev/ttyEcfg)]:ctldev:_files' \
    '-g[print current virtual terminal index]' \
    '(-m)-k[keyboard-related operations]' \
    '(-k)-m[multiplexor-related operations]' \
    '-s[switch to specified virtual terminal]' \
    '-t+[screen type (format/color depth)]:type:_default' \
    '1::index (0-7) or wskbd device:_default' \
    && ret=0

return ret
