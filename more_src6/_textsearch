#compdef textsearch
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/textsearch.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# EMBOSS textsearch: search sequence documentation by keyword
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[turn off prompts]' '-stdout[write stdout]' \
  '-filter[stdin/stdout]' '-options[prompt qualifiers]' '-debug[debug log]' \
  '-verbose[verbose]' '-warning[warnings]' '-error[errors]' '-fatal[fatal]' \
  '-die[dying]' '-version[version]' '-outfile=[output]:file:_files' \
  '-sequence=[sequence(s) to search]:file:_files' \
  '-pattern=[search pattern (regex)]:pattern:' \
  '-casesensitive[case sensitive match]' \
  '-html[output HTML formatted]' \
  '-only[shorten command by showing only chosen fields]' \
  '-heading[display column headings]' \
  '-usa[display USA column]' \
  '-accession[display accession column]' \
  '-name[display name column]' \
  '-description[display description column]' \
  '*:sequence:_files' && ret=0

return ret
