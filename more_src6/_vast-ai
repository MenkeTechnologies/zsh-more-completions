#compdef vast-ai vast vast-cli
# _vast-ai — Vast.ai vast-ai CLI command-line frontend wrapping the Vast.ai GPU rental marketplace REST API managing search offers instances rent destroy stop start labels copy reboot self-test ssh attach-ssh execute reports stats account bid configure machines hosts hostnames templates ipv6 cloud-providers-images (Vast.ai team, Python); argparse
# upstream: https://vast.ai/

_vast-ai() {
    local -a sub=(
        'create:create an instance'
        'destroy:destroy an instance'
        'stop:stop an instance'
        'start:start an instance'
        'reboot:reboot an instance'
        'label:label an instance'
        'attach-ssh:attach SSH key'
        'execute:execute a command'
        'logs:fetch logs'
        'copy:copy files'
        'search:search offers'
        'show:show offers/instances'
        'list:list offers'
        'machine:machine operations'
        'bid:set bid'
        'invoice:invoice operations'
        'audit-log:audit log'
        'self-test:run self-test'
        'reports:reports'
        'config:configuration'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--instance-id=+[id]:str:' \
        '--offer-id=+[id]:str:' \
        '--image=+[name]:str:' \
        '--gpu-name=+[name]:str:' \
        '--num-gpus=+[N]:n:' \
        '--cpu-cores=+[N]:n:' \
        '--ram=+[GB]:n:' \
        '--disk=+[GB]:n:' \
        '--ssh[ssh access]' \
        '--jupyter[Jupyter access]' \
        '--direct[direct ssh]' \
        '--cuda-version=+[v]:str:' \
        '--query=+[filter]:str:' \
        '-q+[query]:str:' \
        '--type=+[t]:t:(on-demand interruptible reserved)' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vast-ai subcommand' sub ;;
        args)
            case $words[1] in
                create|destroy|stop|start|reboot|label|attach-ssh|execute|logs|copy|show) _arguments '*:instance id:' ;;
                search|list) _arguments '*:query:' ;;
            esac
            ;;
    esac
}

_vast-ai "$@"
