#compdef xclogparser
# Documentation: https://github.com/MobileNativeFoundation/XCLogParser
# Reference accessed: 2026-05-21
# Verified: Sources/XCLogParserApp/commands/DumpCommand.swift, ParseCommand.swift,
# ManifestCommand.swift (swift-argument-parser declarations).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      'dump:dump an xcactivitylog file as JSON'
      'parse:parse an xcactivitylog into the chosen reporter format'
      'manifest:dump LogStoreManifest.plist as JSON'
    )
    _describe -t commands 'xclogparser command' commands && ret=0
    ;;
  args)
    case $line[1] in
      dump)
        _arguments -s -S \
          '--file=[path to xcactivitylog file]:log:_files' \
          '--derived_data=[DerivedData directory]:path:_files -/' \
          '--project=[Xcode project name prefix]:name:' \
          '--workspace=[xcworkspace path]:workspace:_files -g "*.xcworkspace"' \
          '--xcodeproj=[xcodeproj path]:project:_files -g "*.xcodeproj"' \
          '--redacted[redact usernames in paths]' \
          '--without_build_specific_information[strip build-specific identifiers]' \
          '--strictProjectName[strict project name matching]' && ret=0
        ;;
      parse)
        _arguments -s -S \
          '--file=[path to xcactivitylog file]:log:_files' \
          '--derived_data=[DerivedData directory]:path:_files -/' \
          '--project=[Xcode project name prefix]:name:' \
          '--workspace=[xcworkspace path]:workspace:_files -g "*.xcworkspace"' \
          '--xcodeproj=[xcodeproj path]:project:_files -g "*.xcodeproj"' \
          '--reporter=[output reporter]:reporter:(json flatJson summaryJson chromeTracer html btr)' \
          '--machine_name=[machine name in report]:name:' \
          '--redacted[redact usernames in paths]' \
          '--without_build_specific_information[strip build-specific identifiers]' \
          '--strictProjectName[strict project name matching]' \
          '--output=[output file path]:file:_files' \
          '--rootOutput=[root output directory]:path:_files -/' \
          '--omit_warnings[omit warnings from the report]' \
          '--omit_notes[omit notes from the report]' \
          '--trunc_large_issues[truncate >100 issues per task]' && ret=0
        ;;
      manifest)
        _arguments -s -S \
          '--long_manifest=[existing LogStoreManifest.plist path]:file:_files' \
          '--derived_data=[DerivedData directory]:path:_files -/' \
          '--project=[Xcode project name prefix]:name:' \
          '--workspace=[xcworkspace path]:workspace:_files -g "*.xcworkspace"' \
          '--xcodeproj=[xcodeproj path]:project:_files -g "*.xcodeproj"' \
          '--strictProjectName[strict project name matching]' \
          '--output=[output file path]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
