#compdef xdpr
# Documentation: man xdpr (X.Org)
# Source: dump and print an X window (xwd + xpr pipeline).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[show help]' \
    '-display+[X display host\:display[.screen]]:display:' \
    '-P+[printer]:printer:' \
    '-device+[device type for xpr]:devtype:(ljet pp ps lj la75 ln03 ljet+ ljet3)' \
    '1:input xwd file:_files -g "*.xwd"' \
    && ret=0

return ret
