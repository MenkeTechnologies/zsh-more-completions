#compdef unxz xzcat lzcat unlzma
# Documentation: unxz --help (XZ Utils 5.x)
# Source: decompress .xz / .lzma files (front-end to xz -d).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[short help]' \
    '(- *)'{-H,--long-help}'[long help with advanced options]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-z --compress -d --decompress -t --test -l --list)'{-z,--compress}'[force compression]' \
    '(-z --compress -d --decompress -t --test -l --list)'{-d,--decompress}'[force decompression]' \
    '(-z --compress -d --decompress -t --test -l --list)'{-t,--test}'[test integrity]' \
    '(-z --compress -d --decompress -t --test -l --list)'{-l,--list}'[list .xz file info]' \
    '(-k --keep)'{-k,--keep}'[keep input files]' \
    '(-f --force)'{-f,--force}'[overwrite output / link]' \
    '(-c --stdout)'{-c,--stdout}'[write to stdout]' \
    '-0[preset 0]' '-1[preset 1]' '-2[preset 2]' '-3[preset 3]' '-4[preset 4]' \
    '-5[preset 5]' '-6[preset 6 (default)]' '-7[preset 7]' '-8[preset 8]' '-9[preset 9]' \
    '(-e --extreme)'{-e,--extreme}'[extreme compression]' \
    '(-T --threads)'{-T+,--threads=}'[thread count (0 = auto)]:num:' \
    '*'{-q,--quiet}'[quiet (repeatable)]' \
    '*'{-v,--verbose}'[verbose (repeatable)]' \
    '*:xz file:_files -g "*.(xz|lzma|lz)"' \
    && ret=0

return ret
