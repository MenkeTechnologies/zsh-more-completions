#compdef tred
# Documentation: man tred(1) (graphviz)
# Source: GraphViz tred — compute transitive reduction of directed graphs.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-v[verbose output]' \
    '(- *)-?[show usage and exit]' \
    '*:DOT file:_files -g "*.{dot,gv}"' \
    && ret=0

return ret
