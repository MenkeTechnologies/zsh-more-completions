#compdef xonsh
# _xonsh-bin — xonsh Python-powered shell (Anthony Scopatz et al); BASH-compatible shell with embedded Python expressions
# upstream: https://github.com/xonsh/xonsh

_xonsh-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-c)-c+[evaluate string]:code:' \
        '(-i)-i[interactive]' \
        '(-l)-l[login shell]' \
        '--no-rc[do not load .xonshrc]' \
        '--rc+[rc file]:file:_files' \
        '--no-script-cache[disable script cache]' \
        '--cache-everything[cache everything]' \
        '-D+[define env var]:KEY=VAL:' \
        '--shell-type+[shell type]:type:(readline prompt_toolkit dumb best)' \
        '--config-path+[config path]:dir:_files -/' \
        '--no-env[skip env import]' \
        '*:script:_files -g "*.(xsh|xonsh)"'
}

_xonsh-bin "$@"
