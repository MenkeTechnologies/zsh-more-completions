#compdef uv-lock
# _uv-lock — uv lockfile manager (astral-sh/uv)
# upstream: https://github.com/astral-sh/uv

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--frozen[assert lockfile is up-to-date]' \
  '--locked[assert lockfile is up-to-date]' \
  '--python=[Python version]:version:' \
  '--upgrade[upgrade all dependencies]' \
  '--upgrade-package=[upgrade specific package]:package:' \
  '--index-url=[package index URL]:url:' \
  '--extra-index-url=[extra index URL]:url:' \
  '--quiet[quiet output]' \
  '--verbose[verbose output]'
