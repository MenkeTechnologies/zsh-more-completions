#compdef winicontoppm
# Documentation: man winicontoppm (Netpbm)
# Source: convert a Windows .ico file to one or more PPM images.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-writeands[write AND-mask PGM files for transparency]' \
    '(-allicons -bestqual)-allicons[write every contained icon]' \
    '(-allicons -bestqual)-bestqual[write only the best-quality icon]' \
    '-multippm[multi-image PPM output stream]' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:icon file:_files -g "*.ico"' \
    '2:ppm output:_files -g "*.ppm"' \
    && ret=0

return ret
