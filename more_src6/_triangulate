#compdef triangulate
# Documentation: https://docs.generic-mapping-tools.org/latest/triangulate.html
# Source: GenericMappingTools/gmt classic-mode triangulate — Delaunay / Voronoi triangulation of (x,y) data.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-R+[region west/east/south/north]:region:_default' \
    '-J+[projection]:proj:_default' \
    '-A[compute Cartesian triangle areas]' \
    '-C+[slope grid for bathymetric uncertainty]:file:_files' \
    '-D+[derivative (x or y) of surface]:axis:(x y)' \
    '-E+[empty-node value]:value:_default' \
    '-G+[output grid file]:file:_files' \
    '-I+[grid spacing or node count]:spacing:_default' \
    '-L+[precomputed Delaunay info]:file:_files' \
    '-M[output as multiple line segments]' \
    '-N[output Delaunay vertex triplets]' \
    '-Q[output Voronoi cell edges (not Delaunay)]' \
    '-S[output triangles as polygon segments]' \
    '-T[output edges/polygons even with gridding]' \
    '*-V[verbose (stackable)]' \
    '-Z[include z-coordinates in I/O]' \
    '-bi+[binary input format]:format:_default' \
    '-bo+[binary output format]:format:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-h+[header records]:n:_default' \
    '-r[pixel registration (default gridline)]' \
    '-:[swap first two columns]' \
    '*:input table:_files' \
    && ret=0

return ret
