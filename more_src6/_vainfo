#compdef vainfo
# Documentation: intel/libva-utils vainfo/vainfo.c + common/va_display.c
# Reference accessed: 2026-05-30
# vainfo — show information from VA-API (Video Acceleration API) driver.
# Wrapper around libva that enumerates supported entrypoints, profiles, and
# rendering attributes per installed driver.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(-a --all)'{-a,--all}'[show all supported VA attributes]' \
  '--display=[display backend (or "help" to list)]:display:(x11 wayland drm win32 help)' \
  '--device=[device name (only for drm and win32 displays)]:device:_files -g "/dev/dri/*"' \
  && ret=0

return ret
