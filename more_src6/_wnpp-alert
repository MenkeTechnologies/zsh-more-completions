#compdef wnpp-alert
# Documentation: https://manpages.debian.org/wnpp-alert
# Source: debian/devscripts scripts/wnpp-alert.sh — list installed packages that need new maintainers (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '(-d --diff)'{-d,--diff}'[show diff since last invocation]' \
    '*:package:_default' \
    && ret=0

return ret
