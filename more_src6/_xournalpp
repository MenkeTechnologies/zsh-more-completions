#compdef xournalpp xournal++
# Documentation: https://manpages.debian.org/bookworm/xournalpp/xournalpp.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help options]' \
  '--help-all[show all help options]' \
  '--help-gapplication[show GApplication options]' \
  '--help-gtk[show GTK+ options]' \
  '--help-export[display advanced export options]' \
  '(- *)--version[show version]' \
  '(-n --page)'{-n+,--page=}'[jump to page]:page:' \
  '--display=[X display to use]:display:' \
  '(-p --create-pdf)'{-p+,--create-pdf=}'[export to PDF file]:file:_files' \
  '(-i --create-img)'{-i+,--create-img=}'[export to image file (png/svg)]:file:_files' \
  '*:xopp file:_files -g "*.{xopp,xoj,pdf}"' && ret=0

return ret
