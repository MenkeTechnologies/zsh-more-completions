#compdef wvWare wv
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-x[config/transform file]:config file:_files' \
  '-c[output charset]:charset' \
  '-p[document password]:password' \
  '-d[target directory]:directory:_directories' \
  '-b[no graphics]' \
  '-v[show version]' \
  '-h[show help]' \
  '1:input document:_files -g "*.doc(-.)"' \
  '2::output file:_files' && ret=0
return ret
