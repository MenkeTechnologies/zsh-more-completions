#compdef xenhypfs
# Documentation: https://xenbits.xenproject.org/docs/unstable/man/xenhypfs.1.html
# Reference accessed: 2026-05-21
# Verified: upstream man page lists ls, cat (with optional -b), write, tree.

local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'ls:list available entries below path'
  'cat:show contents of an entry'
  'write:set contents of an entry'
  'tree:show entire filesystem as a tree'
)
_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'xenhypfs command' commands && ret=0 ;;
  args)
    case $line[1] in
      cat)
        _arguments \
          '-b[do not convert non-printable bytes to \\xNN]' \
          '*:path:_files' && ret=0
        ;;
      *) _files && ret=0 ;;
    esac
    ;;
esac
return ret
