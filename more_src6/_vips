#compdef vips
# Documentation: https://www.libvips.org/API/current/using-the-cli.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above and tools/vips.c +
# libvips/iofuncs/init.c in libvips/libvips master.

# Zsh completion for vips (libvips image processing tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-l --list)'{-l-,--list=}'[list classes|packages|all|package-name|operation-name]:what:' \
  '(-p --plugin)'{-p+,--plugin=}'[load plugin]:plugin:_files' \
  '(-c --completion)'{-c-,--completion=}'[output shell completion]:shell:(bash zsh fish)' \
  '(-t --targets)'{-t,--targets}'[list operation targets]' \
  '--vips-concurrency=[evaluate with N concurrent threads]:N:' \
  '--vips-progress[show progress feedback]' \
  '--vips-leak[leak-check on exit]' \
  '--vips-profile[profile and dump timing on exit]' \
  '--vips-disc-threshold=[images larger than N are decompressed to disc]:N:' \
  '--vips-novector[disable vectorised versions of operations]' \
  '--vips-cache-max=[cache at most N operations]:N:' \
  '--vips-cache-max-memory=[cache at most N bytes in memory]:N:' \
  '--vips-cache-max-files=[allow at most N open files]:N:' \
  '--vips-cache-trace[trace operation cache]' \
  '--vips-cache-dump[dump operation cache on exit]' \
  '--vips-version[print libvips version and exit]' \
  '--vips-unlimited[disable DoS checks in loaders]' \
  '--vips-max-coord=[maximum coordinate]:N:' \
  '1:command:' \
  '*::arguments:_files' && ret=0

return ret
