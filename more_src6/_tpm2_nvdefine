#compdef tpm2_nvdefine
# _tpm2_nvdefine — tpm2-software tpm2_nvdefine define a TPM2 NV index for storing user data (tpm2-software team, C); custom argparse
# upstream: https://github.com/tpm2-software/tpm2-tools

_tpm2_nvdefine() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-C+[hierarchy]:h:(o p owner platform)' \
        '--hierarchy=+[hierarchy]:h:(o p owner platform)' \
        '-P+[hierarchy auth]:str:' \
        '--hierarchy-auth=+[hierarchy auth]:str:' \
        '-p+[index auth]:str:' \
        '--index-auth=+[index auth]:str:' \
        '-s+[size bytes]:n:' \
        '--size=+[size bytes]:n:' \
        '-a+[attributes]:str:' \
        '--attributes=+[attributes]:str:' \
        '-L+[policy file]:file:_files' \
        '--policy=+[policy file]:file:_files' \
        '-g+[hash algorithm]:h:(sha1 sha256 sha384 sha512)' \
        '--hash-algorithm=+[hash algorithm]:h:(sha1 sha256 sha384 sha512)' \
        '-Q[do not output anything]' \
        '--cphash=+[cp hash file]:file:_files' \
        '*:NV index:'
}

_tpm2_nvdefine "$@"
