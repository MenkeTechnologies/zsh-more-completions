#compdef tiff2rgba
# Documentation: tiff2rgba (libtiff)
# Source: convert a TIFF image to RGBA color space.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-c+[compression scheme]:scheme:(jpeg zip lzw packbits none)' \
    '-r+[rows per strip]:n:' \
    '-t+[rows per strip (same as -r)]:n:' \
    '-b[progress by block rather than full image]' \
    '-n[do not emit alpha component]' \
    '-B+[background value for alpha compositing]:value:' \
    '-8[write BigTIFF instead of ClassicTIFF]' \
    ':input:_files -g "*.(tif|tiff|TIF|TIFF)"' \
    ':output:_files -g "*.(tif|tiff)"' \
    && ret=0

return ret
