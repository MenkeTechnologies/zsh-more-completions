#compdef velociraptor velociraptor-cli velociraptor.exe
# Documentation: https://docs.velociraptor.app/ (source: github.com/Velocidex/velociraptor bin/)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'frontend:start the server frontend'
  'gui:run the GUI'
  'config:configuration related commands'
  'artifact:list/show/collect/fetch artifacts'
  'query:run a VQL query'
  'tools:tool related commands'
  'rpm:RPM packaging commands'
  'debian:Debian packaging commands'
  'fuse:mount as FUSE filesystem'
  'unzip:unzip a velociraptor zip'
  'collector:build an offline collector'
  'deaddisk:dead disk analysis'
  'fs:filesystem accessor commands (cp/ls/cat/rm)'
  'client:run a velociraptor client'
  'pool_client:run a pool client'
  'hunts:hunt related commands'
  'acl:access control (show/grant)'
  'user:user management'
  'verify:verify artifact bundles'
  'reformat:reformat a VQL artifact'
  'csv:CSV utilities'
  'vql:VQL utilities'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*--config=[config file]:file:_files' \
  '*--api_config=[api config]:file:_files' \
  '*--definitions=[artifact definitions dir]:dir:_files -/' \
  '--logging.output_directory=[log dir]:dir:_files -/' \
  '--logging.separate_logs_per_component=[separate logs]:b:(true false)' \
  '*--debug[enable debug mode]' \
  '--debug_port=[debug port]:port:' \
  '*--profile=[profile dir]:dir:_files -/' \
  '*--cpu_profile=[cpu profile]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'velociraptor command' commands && ret=0 ;;
  (args) _files ;;
esac

return ret
