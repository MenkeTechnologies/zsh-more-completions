#compdef wyrd
# wyrd - Text-based front-end for the Remind calendar program

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--add=[run reminding interactively for the given date]:date:' \
  '-a[start in agenda mode]' \
  '-c+[specify configuration file]:file:_files' \
  '-d+[specify remind data directory]:directory:_files -/' \
  '-f+[specify remind data file]:file:_files' \
  '-m[start with month view]' \
  '-w[start with week view]' \
  '1:remind file:_files -g "*.rem"' \
  && ret=0

return ret
