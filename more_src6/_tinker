#compdef tinker
# Documentation: https://github.com/TinkerTools/tinker
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (sources in /source verify each program).

# Tinker: package for molecular modeling — invokes sub-programs by name.
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'alchemy:free energy perturbation calculations'
  'analyze:analyze a structure or trajectory'
  'anneal:simulated annealing'
  'archive:archive trajectory files'
  'bar:Bennett acceptance ratio free energy'
  'correlate:trajectory correlation analysis'
  'crystal:crystal structure manipulation'
  'diffuse:diffusion coefficient calculation'
  'distgeom:distance geometry'
  'document:produce documentation from sources'
  'dynamic:run molecular dynamics simulation'
  'freefix:free energy fix'
  'gda:gaussian density annealing'
  'intedit:edit internal coordinates'
  'intxyz:convert internal to Cartesian coordinates'
  'minimize:energy minimization'
  'mol2xyz:convert MOL2 to xyz'
  'molxyz:convert MOL to xyz'
  'monte:Monte Carlo simulation'
  'newton:Newton-Raphson minimization'
  'nucleic:build nucleic acid structure'
  'optimize:optimize molecular geometry'
  'optirot:rotational optimization'
  'optrigid:rigid body optimization'
  'path:reaction path calculation'
  'pdbxyz:convert PDB to xyz'
  'polarize:polarization analysis'
  'poledit:edit multipole parameters'
  'potential:fit electrostatic potential'
  'prmedit:edit parameter file'
  'protein:build protein from sequence'
  'pss:potential surface scanning'
  'pssrigid:rigid body PSS'
  'pssrot:rotational PSS'
  'radial:radial distribution function'
  'sniffer:scan for new structures'
  'spacefill:spacefilling volume/surface area'
  'spectrum:vibrational spectrum'
  'testgrad:test analytical gradient'
  'testpair:test pair list'
  'testpol:test polarization'
  'testrot:test rotational moves'
  'testvir:test virial'
  'timer:timing benchmarks'
  'timerot:rotational timing'
  'torsfit:torsional fitting'
  'valence:valence parameter fitting'
  'vibrate:vibrational analysis'
  'vibrot:rotational vibrations'
  'xtalfit:crystal lattice fitting'
  'xtalmin:crystal lattice minimization'
  'xyzedit:edit Cartesian coordinates'
  'xyzint:convert Cartesian to internal coordinates'
  'xyzmol2:convert xyz to MOL2'
  'xyzpdb:convert xyz to PDB'
)

_arguments -C \
  '1: :->cmd' \
  '*::tinker args and key file:->args' && ret=0

case $state in
  cmd) _describe -t commands 'tinker command' commands && ret=0 ;;
esac
return ret
