#compdef tdspool
# Documentation: https://github.com/FreeTDS/freetds (src/pool/main.c)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# tdspool: FreeTDS connection pool server

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-l+[log file]:file:_files' \
  '-c+[config file]:file:_files' \
  '-d[daemon mode]' \
  '1:pool name:' && ret=0

return ret
