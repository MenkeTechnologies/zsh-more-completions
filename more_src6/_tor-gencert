#compdef tor-gencert
# Documentation: tor-gencert --help (Tor)
# Source: generate authority identity / signing keys and certificates for Tor.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '*-v[verbose (stackable)]' \
    '(-r --reuse)'{-r,--reuse}'[reuse existing signing key]' \
    '--create-identity-key[create new identity key]' \
    '-i+[identity key file]:file:_files' \
    '-s+[signing key file]:file:_files' \
    '-c+[certificate file]:file:_files' \
    '-m+[lifetime in months]:months:' \
    '-a+[address:port]:address:_hosts' \
    '--passphrase-fd=[file descriptor for passphrase]:fd:' \
    && ret=0

return ret
