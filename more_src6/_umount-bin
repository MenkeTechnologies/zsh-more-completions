#compdef umount
# _umount-bin — util-linux unmount filesystems; detach a mounted filesystem
# upstream: https://github.com/util-linux/util-linux

_umount-bin() {
    _arguments \
        '(-a --all)'{-a,--all}'[unmount all]' \
        '(-A --all-targets)'{-A,--all-targets}'[unmount all bind targets]' \
        '(-c --no-canonicalize)'{-c,--no-canonicalize}'[do not canonicalize paths]' \
        '(-d --detach-loop)'{-d,--detach-loop}'[detach loop device too]' \
        '(-f --force)'{-f,--force}'[force unmount]' \
        '(-i --internal-only)'{-i,--internal-only}'[no /sbin/umount.<type>]' \
        '(-l --lazy)'{-l,--lazy}'[lazy unmount]' \
        '(-N --namespace)'{-N,--namespace}'+[namespace]:ns:' \
        '(-n --no-mtab)'{-n,--no-mtab}'[do not write /etc/mtab]' \
        '(-O --test-opts)'{-O,--test-opts}'+[restrict by options]:opts:' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '(-R --recursive)'{-R,--recursive}'[recursive]' \
        '(-r --read-only)'{-r,--read-only}'[remount read-only on failure]' \
        '(-t --types)'{-t,--types}'+[fs types]:types:' \
        '(-T --fstab)'{-T,--fstab}'+[alternate fstab]:file:_files' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '*:device or dir:_files'
}

_umount-bin "$@"
