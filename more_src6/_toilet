#compdef toilet
# Documentation: man toilet(1)
# Source: cacalabs/toilet src/main.c (master) — colored figlet-style banner generator (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-f --font)'{-f+,--font=}'[font name]:font:_default' \
    '(-d --directory)'{-d+,--directory=}'[font directory]:dir:_files -/' \
    '(-w --width)'{-w+,--width=}'[output width]:cols:_default' \
    '(-t --termwidth)'{-t,--termwidth}'[use terminal width]' \
    '*'{-F+,--filter=}'[filter name (list for available)]:filter:(gay metal rainbow border crop flip flop list)' \
    '(--gay --metal --rainbow)--gay[gay filter (rainbow + sparkle)]' \
    '(--gay --metal --rainbow)--metal[metal filter]' \
    '(--gay --metal --rainbow)--rainbow[rainbow filter]' \
    '(-E --export)'{-E+,--export=}'[output format]:format:(ansi utf8 utf8cp437 html irc ps svg tga)' \
    '--irc[shortcut for --export irc]' \
    '--html[shortcut for --export html]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-I --infocode)'{-I+,--infocode=}'[infocode]:N:_default' \
    '(-v --version)'{-v,--version}'[show version]' \
    '-s[smush mode]' \
    '-S[force smush]' \
    '-k[kern (touch)]' \
    '-W[full width]' \
    '-o[overlap smush]' \
    '*:message:_default' \
    && ret=0

return ret
