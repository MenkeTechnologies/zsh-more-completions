#compdef tarsnap-recrypt
# _tarsnap-recrypt — re-encrypt all Tarsnap archives under a new key (Tarsnap/tarsnap)
# upstream: https://github.com/Tarsnap/tarsnap
# Flags from recrypt/recrypt.c (getopt).

_tarsnap-recrypt() {
    _arguments \
        '(- *)--version[print version]' \
        '--oldkey=[existing key file]:file:_files' \
        '--oldcachedir=[existing cache directory]:dir:_files -/' \
        '--newkey=[new key file]:file:_files' \
        '--newcachedir=[new cache directory]:dir:_files -/'
}

_tarsnap-recrypt "$@"
