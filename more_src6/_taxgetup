#compdef taxgetup
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/taxgetup.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# EMBOSS taxgetup: get parents of taxon(s)
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[turn off prompts]' '-stdout[write stdout]' \
  '-filter[stdin/stdout]' '-options[prompt qualifiers]' '-debug[debug log]' \
  '-verbose[verbose]' '-warning[warnings]' '-error[errors]' '-fatal[fatal]' \
  '-die[dying]' '-version[version]' \
  '-taxons=[input taxonomy entries]:USA:' \
  '-iformat1=[input taxonomy format]:fmt:' \
  '-iquery1=[input query fields/ID list]:query:' \
  '-ioffset1=[input start offset]:offset:' \
  '-idbname1=[user-provided database name]:dbname:' \
  '-outfile=[output file]:file:_files' \
  '-odirectory2=[output directory]:dir:_files -/' \
  '-oformat2=[output taxonomy format]:fmt:(ncbi ebi tax excel)' \
  '-hidden[show taxons hidden in GenBank]' \
  '*:taxonomy query:' && ret=0

return ret
