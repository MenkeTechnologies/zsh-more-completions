#compdef yamlscript ys
# _yamlscript — Ingy döt Net YAMLScript YAML as a programming language CLI alias (yaml/yamlscript team, Clojure); custom argparse
# upstream: https://github.com/yaml/yamlscript

_yamlscript() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--run[run yamlscript]' \
        '-r[run yamlscript]' \
        '--load[load and print]' \
        '-l[load and print]' \
        '--eval=+[expression]:str:' \
        '-e+[expression]:str:' \
        '--compile[compile to clj]' \
        '-c[compile to clj]' \
        '--pretty[pretty print]' \
        '-p[pretty print]' \
        '--json[output JSON]' \
        '-J[output JSON]' \
        '--yaml[output YAML]' \
        '-Y[output YAML]' \
        '--edn[output EDN]' \
        '-E[output EDN]' \
        '--repl[start repl]' \
        '-R[start repl]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--debug-stage=+[stage]:s:(parse compose resolve construct emit)' \
        '-D+[stage]:s:(parse compose resolve construct emit)' \
        '--mode=+[mode]:m:(c d s)' \
        '-m+[mode]:m:(c d s)' \
        '--clj[compile to clj]' \
        '-C[compile to clj]' \
        '--stream[stream output]' \
        '-s[stream output]' \
        '--xtra[extra YAML output]' \
        '-X[extra YAML output]' \
        '--print[print result]' \
        '-P[print result]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '*:files:_files -g "*.{ys,yml,yaml}"'
}

_yamlscript "$@"
