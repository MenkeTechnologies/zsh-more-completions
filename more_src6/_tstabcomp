#compdef tstabcomp
# _tstabcomp — TSDuck tstabcomp MPEG-2 TS table compiler converting between XML and binary PSI/SI table representations PAT PMT NIT SDT EIT TOT TDT BAT (tsduck team, C++); custom argparse
# upstream: https://github.com/tsduck/tsduck

_tstabcomp() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--version[show version]' \
        '-d+[debug level]:n:' \
        '--debug=+[debug level]:n:' \
        '-c[compile]' \
        '--compile[compile]' \
        '-D[decompile]' \
        '--decompile[decompile]' \
        '-o+[output file]:file:_files -g "*.xml *.bin *.psi *.si"' \
        '--output=+[output file]:file:_files -g "*.xml *.bin *.psi *.si"' \
        '-x[xml output]' \
        '--xml[xml output]' \
        '-j[json output]' \
        '--json[json output]' \
        '--xml-model=+[file]:file:_files -g "*.xml *.xsd"' \
        '--from-json[from JSON]' \
        '--default-charset=+[c]:str:' \
        '--time-reference=+[r]:r:(system tdt utc local)' \
        '--ignore-version[ignore version]' \
        '--ignore-crc[ignore CRC]' \
        '--no-rrt[no RRT]' \
        '--no-pcr[no PCR]' \
        '--pad-cell[pad cell]' \
        '*:table file:_files -g "*.xml *.bin *.psi *.si"'
}

_tstabcomp "$@"
