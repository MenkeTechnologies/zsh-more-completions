#compdef yk-fido fido2-token
# _yk-fido — Yubico libfido2 fido2-token FIDO2 device management CLI alias (Yubico, C); custom argparse
# upstream: https://github.com/Yubico/libfido2

_yk-fido() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-C[change PIN]' \
        '-D[delete resident credential by id]' \
        '-G[get parameters]' \
        '-I[get device info]' \
        '-L[list all FIDO devices]' \
        '-S[set PIN]' \
        '-R[reset FIDO authenticator]' \
        '-V[list device parameters]' \
        '-c[CTAP version]' \
        '-d[debug]' \
        '-i+[input file (raw assertion)]:file:_files' \
        '-k+[CTAP HID frame size]:n:' \
        '-l+[list devices to file]:file:_files' \
        '-n+[name]:str:' \
        '-r[read resident credentials]' \
        '-u+[user id]:str:' \
        '-w[write resident credentials]' \
        '*:device:'
}

_yk-fido "$@"
