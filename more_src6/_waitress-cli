#compdef waitress-cli waitress-serve
# _waitress-cli — Waitress pure-Python WSGI server CLI alias (Pylons community, Python); argparse
# upstream: https://github.com/Pylons/waitress

_waitress-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--host=+[bind host]:host:_hosts' \
        '--port=+[bind port]:port:' \
        '--listen=+[listen on host:port or [ipv6\]:port]:str:' \
        '--ipv4=+[ipv4]:b:(true false)' \
        '--ipv6=+[ipv6]:b:(true false)' \
        '--unix-socket=+[unix socket path]:file:_files' \
        '--unix-socket-perms=+[unix socket perms]:str:' \
        '--url-prefix=+[url prefix]:str:' \
        '--url-scheme=+[url scheme]:scheme:(http https)' \
        '--threads=+[threads]:n:' \
        '--backlog=+[backlog]:n:' \
        '--max-request-header-size=+[max request header size]:n:' \
        '--max-request-body-size=+[max request body size]:n:' \
        '--connection-limit=+[connection limit]:n:' \
        '--cleanup-interval=+[cleanup interval sec]:n:' \
        '--asyncore-loop-timeout=+[asyncore loop timeout]:n:' \
        '--asyncore-use-poll[asyncore use poll]' \
        '--ident=+[server header ident]:str:' \
        '--server-name=+[server name]:str:' \
        '--clear-untrusted-proxy-headers=+[clear untrusted proxy headers]:b:(true false)' \
        '--trust-proxy=+[trust proxy]:b:(true false)' \
        '--trusted-proxy-count=+[trusted proxy count]:n:' \
        '--trusted-proxy-headers=+[trusted proxy headers]:list:' \
        '--log-untrusted-proxy-headers=+[log untrusted proxy headers]:b:(true false)' \
        '--expose-tracebacks=+[expose tracebacks]:b:(true false)' \
        '--channel-timeout=+[channel timeout]:n:' \
        '--channel-request-lookahead=+[channel request lookahead]:n:' \
        '--outbuf-overflow=+[outbuf overflow]:n:' \
        '--outbuf-high-watermark=+[outbuf high watermark]:n:' \
        '--inbuf-overflow=+[inbuf overflow]:n:' \
        '--recv-bytes=+[recv bytes]:n:' \
        '--send-bytes=+[send bytes]:n:' \
        '--call=+[call factory function]:b:(true false)' \
        '*:dotted-app:'
}

_waitress-cli "$@"
