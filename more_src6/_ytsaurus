#compdef ytsaurus yt ytctl
# _ytsaurus — Yandex YTsaurus open-source big-data MapReduce dynamic tables storage and compute platform yt and ytctl CLIs (ytsaurus team, C++/Python); custom argparse
# upstream: https://github.com/ytsaurus/ytsaurus

_ytsaurus() {
    local -a sub=(
        'read:read a table or file'
        'write:write a table or file'
        'create:create a node'
        'remove:remove a node'
        'list:list nodes'
        'find:find nodes'
        'get:get node attributes'
        'set:set node attributes'
        'exists:check node existence'
        'copy:copy a node'
        'move:move a node'
        'link:create a symbolic link'
        'mount-table:mount a dynamic table'
        'unmount-table:unmount a dynamic table'
        'freeze-table:freeze a dynamic table'
        'unfreeze-table:unfreeze a dynamic table'
        'reshard-table:reshard a dynamic table'
        'select-rows:select rows from dynamic table'
        'insert-rows:insert rows into dynamic table'
        'delete-rows:delete rows from dynamic table'
        'lookup-rows:lookup rows in dynamic table'
        'lock:lock a node'
        'map:run a map operation'
        'reduce:run a reduce operation'
        'join-reduce:run a join-reduce operation'
        'map-reduce:run a map-reduce operation'
        'sort:run a sort operation'
        'merge:run a merge operation'
        'erase:run an erase operation'
        'remote-copy:remote copy'
        'vanilla:run a vanilla operation'
        'start-tx:start a transaction'
        'commit-tx:commit a transaction'
        'abort-tx:abort a transaction'
        'ping-tx:ping a transaction'
        'abort-op:abort an operation'
        'suspend-op:suspend an operation'
        'resume-op:resume an operation'
        'complete-op:complete an operation'
        'update-op-parameters:update op parameters'
        'get-operation:get operation info'
        'list-operations:list operations'
        'list-jobs:list jobs'
        'get-job:get job info'
        'run-job-shell:run shell in job'
        'abort-job:abort a job'
        'admin:admin subcommands'
        'completion:generate completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--proxy=+[proxy address]:str:' \
        '--config=+[config file]:file:_files -g "*.yson *.json"' \
        '--format=+[format]:f:(json yson dsv schemaful_dsv yamr)' \
        '--tx=+[transaction id]:str:' \
        '--ping-ancestor-txs[ping ancestor txs]' \
        '--trace[trace mode]' \
        '--silent[silent]' \
        '--no-color[disable color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'yt subcommand' sub ;;
        args)
            case $words[1] in
                read|write) _arguments \
                    '--format=+[format]:f:(json yson dsv schemaful_dsv yamr)' \
                    '--control-attributes[control attributes]' \
                    '--table-reader=+[reader config]:str:' \
                    '*:path:' ;;
                map|reduce|join-reduce|map-reduce|sort|merge|erase|remote-copy|vanilla) _arguments \
                    '--spec=+[spec yson/json]:str:' \
                    '--sync[wait for completion]' \
                    '--track[follow]' ;;
                admin) _arguments '1:admin cmd:(disable-job-scheduler enable-job-scheduler add-node remove-node disable-tablet-cells enable-tablet-cells)' ;;
            esac
            ;;
    esac
}

_ytsaurus "$@"
