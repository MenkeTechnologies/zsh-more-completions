#compdef webalizer
# Documentation: https://manpages.debian.org/bookworm/webalizer/webalizer.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream Debian manpage flag list.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-v[verbose mode]' \
  '-d[debug mode]' \
  '-i[ignore history file]' \
  '-b[ignore incremental data file]' \
  '-p[preserve incremental state]' \
  '-q[quiet (suppress info messages)]' \
  '-Q[really quiet (suppress all messages)]' \
  '-T[show timing info]' \
  '-c+[config file]:file:_files' \
  '-n+[hostname for report]:host:' \
  '-o+[output directory]:dir:_files -/' \
  '-t+[report title]:title:' \
  '-F+[log type]:fmt:(clf ftp squid w3c)' \
  '-f[fold out-of-sequence log records]' \
  '-Y[suppress country graph]' \
  '-G[suppress hourly graph]' \
  '-x+[HTML file extension]:ext:' \
  '-H[suppress hourly statistics]' \
  '-K+[yearly summary table months (12-120)]:n:' \
  '-k+[yearly summary graph months (12-72)]:n:' \
  '-L[suppress color-coded graph legends]' \
  '-l+[background reference lines on graphs]:n:' \
  '-P+[page file extensions]:name:' \
  '-O+[exclude URLs from page counts]:name:' \
  '-m+[visit timeout in seconds]:n:' \
  '-I+[additional index alias]:name:' \
  '-M+[user agent mangle level]:n:(0 1 2 3 4 5)' \
  '-g+[group by domain level]:n:' \
  '-D+[DNS cache file]:file:_files' \
  '-N+[DNS child process count]:n:' \
  '-j[enable native GeoDB]' \
  '-J+[alternate GeoDB database]:file:_files' \
  '-w[enable GeoIP]' \
  '-W+[alternate GeoIP database]:file:_files' \
  '-z+[country flag graphics dir]:dir:_files -/' \
  '-a+[hide agent pattern]:pattern:' \
  '-r+[hide referrer pattern]:pattern:' \
  '-s+[hide site pattern]:pattern:' \
  '-X[hide individual sites]' \
  '-u+[hide URL pattern]:pattern:' \
  '-A+[max user agents]:n:' \
  '-R+[max referrers]:n:' \
  '-S+[max sites]:n:' \
  '-U+[max URLs]:n:' \
  '-C+[max countries]:n:' \
  '-e+[max entry pages]:n:' \
  '-E+[max exit pages]:n:' \
  '*:logfile:_files' && ret=0

return ret
