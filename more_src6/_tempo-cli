#compdef tempo-cli
# Documentation: https://grafana.com/docs/tempo/latest/operations/tempo_cli/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# tempo-cli: Grafana Tempo CLI for trace ingestion/diagnostics
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'query:query API commands (trace-id, search, search-tags, search-tag-values, metrics)'
  'list:list blocks/index/cache info'
  'view:view block index'
  'gen:generate bloom or index for a block'
  'search:search blocks for key/value'
  'parquet:convert parquet schemas'
  'migrate:migrate tenants or overrides-config'
  'analyse:analyse blocks'
  'rewrite-blocks:rewrite blocks (drop-trace)'
  'help:show help'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --config-file)'{-c,--config-file=}'[config file]:file:_files' \
  '--backend=[storage backend]:backend:(s3 gcs azure local)' \
  '--bucket=[bucket name]:bucket:' \
  '--s3-endpoint=[S3 API endpoint]:endpoint:' \
  '--s3-user=[S3 user]:user:' \
  '--s3-pass=[S3 password]:pass:' \
  '--insecure-skip-verify[skip TLS verification]' \
  '--org-id=[organization id]:tenant:' \
  '--use-grpc[use gRPC streaming]' \
  '--secure[use HTTPS/gRPC with TLS]' \
  '--v1[use v1 API endpoint]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'tempo-cli command' commands && ret=0 ;;
esac
return ret
