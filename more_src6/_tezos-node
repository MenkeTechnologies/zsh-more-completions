#compdef tezos-node octez-node
# _tezos-node — Nomadic Labs octez-node Tezos network full node implementing RPC peer-to-peer baker and snapshot import/export with selectable history modes (tezos team, OCaml); custom argparse
# upstream: https://gitlab.com/tezos/tezos

_tezos-node() {
    local -a sub=(
        'config:config operations'
        'identity:identity operations'
        'run:run the node'
        'snapshot:snapshot operations'
        'storage:storage operations'
        'reconstruct:reconstruct storage'
        'replay:replay blocks'
        'upgrade:upgrade'
        'man:show manual'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'tezos-node subcommand' sub ;;
        args)
            case $words[1] in
                config) _arguments \
                    '1:config action:(init reset update show validate)' \
                    '--data-dir=+[dir]:dir:_files -/' \
                    '--config-file=+[file]:file:_files -g "*.json"' \
                    '--network=+[net]:n:(mainnet ghostnet sandbox proxy)' \
                    '--rpc-addr=+[addr]:str:' \
                    '--net-addr=+[addr]:str:' \
                    '--history-mode=+[mode]:m:(archive full rolling)' \
                    '--expected-pow=+[N]:n:' ;;
                identity) _arguments \
                    '1:identity action:(generate check show import)' \
                    '--data-dir=+[dir]:dir:_files -/' \
                    '--expected-pow=+[N]:n:' ;;
                run) _arguments \
                    '--data-dir=+[dir]:dir:_files -/' \
                    '--config-file=+[file]:file:_files -g "*.json"' \
                    '--network=+[net]:n:(mainnet ghostnet sandbox proxy)' \
                    '--rpc-addr=+[addr]:str:' \
                    '--rpc-tls=+[cert,key]:str:' \
                    '--net-addr=+[addr]:str:' \
                    '--peer=+[peer]:str:' \
                    '--no-bootstrap-peers[no bootstrap peers]' \
                    '--connections=+[N]:n:' \
                    '--history-mode=+[mode]:m:(archive full rolling)' \
                    '--singleprocess[single process]' \
                    '--allow-all-rpc=+[origins]:str:' \
                    '--cors-origin=+[origins]:str:' \
                    '--cors-header=+[headers]:str:' \
                    '--metrics-addr=+[addr]:str:' \
                    '--operation-metadata-size-limit=+[N]:n:' ;;
                snapshot) _arguments \
                    '1:snapshot action:(export import info)' \
                    '--data-dir=+[dir]:dir:_files -/' \
                    '--block=+[hash]:str:' \
                    '--export-format=+[fmt]:f:(raw tar)' \
                    '*:snapshot file:_files -g "*.snapshot *.full *.rolling *.archive"' ;;
            esac
            ;;
    esac
}

_tezos-node "$@"
