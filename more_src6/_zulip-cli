#compdef zulip-cli
# _zulip-cli — official Zulip Python API CLI (zulip/python-zulip-api)
# upstream: https://github.com/zulip/python-zulip-api
# Subcommands from zulip/zulip/cli.py (click).

_zulip-cli() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'send-message:send a message'
                'upload-file:upload a file'
                'update-message:edit a message'
                'delete-message:delete a message'
                'add-reaction:add an emoji reaction'
                'remove-reaction:remove an emoji reaction'
                'get-message-history:show edit history of a message'
                'mark-all-as-read:mark all messages as read'
                'get-subscriptions:list subscribed streams'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                send-message)
                    _arguments \
                        '(-s --stream)'{-s+,--stream=}'[target stream]:stream:' \
                        '(-S --subject)'{-S+,--subject=}'[message subject]:subject:' \
                        '(-m --message)'{-m+,--message=}'[message content]:text:' \
                        '*:recipient:'
                    ;;
                update-message|delete-message|get-message-history)
                    _arguments '1:message id:'
                    ;;
                add-reaction|remove-reaction)
                    _arguments '1:message id:' '2:emoji name:'
                    ;;
            esac
            ;;
    esac
}

_zulip-cli "$@"
