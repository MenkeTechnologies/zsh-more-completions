#compdef zkctld
# _zkctld — Vitess ZooKeeper daemon-mode service
# upstream: https://github.com/vitessio/vitess
# Flags from go/cmd/zkctld/cli/zkctld.go on tip.

_zkctld() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--zk.cfg=[ZooKeeper config file]:file:_files' \
        '-v[verbosity level]:n:'
}

_zkctld "$@"
