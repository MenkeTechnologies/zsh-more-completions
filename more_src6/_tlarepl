#compdef tlarepl
# Documentation: https://raw.githubusercontent.com/pmer/tla-bin/master/bin/tlarepl
# Reference accessed: 2026-05-27
# Verified: upstream tlc2.REPL.main() in tlaplus/tlaplus
#   tlatools/org.lamport.tlatools/src/tlc2/REPL.java
#
# tlc2.REPL takes no flag options. With zero arguments it enters interactive
# mode; with exactly one argument that argument is evaluated as a TLA+
# expression and the program exits.

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:TLA+ expression to evaluate (optional):' && ret=0

return ret
