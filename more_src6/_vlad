#compdef vlad vlad-cli sd-next webui-sdnext
# _vlad — vladmandic SD.Next next-gen Stable Diffusion UI CLI alias (Vladimir Mandic / vladmandic, Python); custom argparse
# upstream: https://github.com/vladmandic/automatic

_vlad() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--listen[listen on 0.0.0.0]' \
        '--port=+[port]:port:' \
        '--server-name=+[server name]:host:_hosts' \
        '--share[share via gradio]' \
        '--insecure[allow insecure connections]' \
        '--use-cpu=+[use CPU for]:list:(all interrogate gfpgan codeformer esrgan vae)' \
        '--use-ipex[use Intel IPEX]' \
        '--use-rocm[use AMD ROCm]' \
        '--use-zluda[use ZLUDA]' \
        '--use-directml[use DirectML]' \
        '--use-openvino[use OpenVINO]' \
        '--device-id=+[device id]:n:' \
        '--cuda-stream[CUDA stream]' \
        '--xformers[use xformers]' \
        '--force-enable-xformers[force enable xformers]' \
        '--allow-code[allow code]' \
        '--theme=+[theme]:t:(dark light system)' \
        '--ui-config=+[UI config]:file:_files' \
        '--ui-settings-file=+[UI settings file]:file:_files' \
        '--config=+[config]:file:_files' \
        '--data-dir=+[data dir]:dir:_files -/' \
        '--styles-file=+[styles file]:file:_files' \
        '--gradio-debug[gradio debug]' \
        '--gradio-auth=+[gradio auth]:str:' \
        '--gradio-auth-path=+[gradio auth path]:file:_files' \
        '--reinstall[reinstall]' \
        '--reset[reset]' \
        '--skip-extensions[skip extensions]' \
        '--skip-git[skip git]' \
        '--skip-requirements[skip requirements]' \
        '--skip-torch[skip torch]' \
        '--skip-update[skip update]' \
        '--skip-ui[skip UI]' \
        '--no-download[no download]' \
        '--no-metadata[no metadata]' \
        '--no-hashing[no hashing]' \
        '--no-half[no half]' \
        '--no-half-vae[no half VAE]' \
        '--ckpt=+[checkpoint]:file:_files' \
        '--vae=+[VAE]:file:_files' \
        '--vae-dir=+[VAE dir]:dir:_files -/' \
        '--ckpt-dir=+[checkpoint dir]:dir:_files -/' \
        '--lora-dir=+[LoRA dir]:dir:_files -/' \
        '--embeddings-dir=+[embeddings dir]:dir:_files -/' \
        '--hypernetwork-dir=+[hypernetwork dir]:dir:_files -/' \
        '--lyco-dir=+[LyCORIS dir]:dir:_files -/' \
        '--codeformer-models-path=+[codeformer models path]:dir:_files -/' \
        '--gfpgan-models-path=+[gfpgan models path]:dir:_files -/' \
        '--esrgan-models-path=+[esrgan models path]:dir:_files -/' \
        '--bsrgan-models-path=+[bsrgan models path]:dir:_files -/' \
        '--realesrgan-models-path=+[realesrgan models path]:dir:_files -/' \
        '--scunet-models-path=+[scunet models path]:dir:_files -/' \
        '--swinir-models-path=+[swinir models path]:dir:_files -/' \
        '--clip-models-path=+[clip models path]:dir:_files -/' \
        '--allowed-paths=+[allowed paths]:list:_files -/' \
        '--enable-insecure-extension-access[enable insecure extension access]' \
        '--api[enable API]' \
        '--api-auth=+[API auth]:str:' \
        '--api-log[API log]' \
        '--api-only[API only]' \
        '--nowebui[no web UI]' \
        '--allow-noproxy[allow no proxy]' \
        '--update-all-extensions[update all extensions]' \
        '--upgrade[upgrade]' \
        '--quick[quick startup]' \
        '--debug[debug]' \
        '--log=+[log file]:file:_files' \
        '*:arg:'
}

_vlad "$@"
