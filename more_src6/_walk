#compdef walk
# Documentation: https://github.com/antonmedv/walk
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '--icons[display file icons]' \
  '--dir-only[show directories only]' \
  '--hide-hidden[hide hidden files]' \
  '--preview[launch with preview mode enabled]' \
  '--with-border[add border in preview mode]' \
  '--fuzzy[start with fuzzy search activated]' \
  '*:directory:_directories' && ret=0
return ret
