#compdef tgatoppm
# Documentation: man tgatoppm (Netpbm)
# Source: convert a Truevision Targa (TGA) file to PPM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--alphaout=[alpha output file (- for stdout)]:file:_files' \
    '--headerdump[dump TGA header info]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:tga file:_files -g "*.(tga|targa)"' \
    && ret=0

return ret
