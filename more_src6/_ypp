#compdef ypp
# ============================================================================
#  _ypp — ypp: Yet a PreProcessor (Lua-based text/markdown preprocessor)
#
#  Source-direct extraction from
#    https://github.com/CDSoft/luax/blob/master/ypp/ypp.lua
#    https://github.com/mpeterv/argparse (the argparse library)
#
#  Authored by Christophe Delord (CDSoft).  Part of luax project (206 GH
#  stars on luax — Lua interpreter and REPL based on Lua 5.4, augmented
#  with useful packages + "compiler" producing standalone executables).
#  Current home: https://codeberg.org/cdsoft/luax.  ypp is one of luax's
#  binaries — a programmable text preprocessor with @-prefixed Lua
#  expressions, image generation (SVG/PDF/PNG), Lua script include
#  semantics, and Make-style dependency tracking (--MD/--MF/--MT).
#
#  CLI library taxonomy update: 2nd Lua CLI library — mpeterv/argparse.
#  Lua ecosystem now has 2 documented CLI libraries (R285 + R349
#  mpeterv/argparse) joining the multi-library leaders.  mpeterv/argparse
#  is the de-facto Lua CLI library (289 GH stars) used by luacheck,
#  busted, ldoc, and many other Lua tools.  Distinct from R285 (whatever
#  the first Lua entry was — likely a different style).
#
#  mpeterv/argparse API uses METHOD-CHAIN BUILDER pattern with COLON
#  syntax (Lua's `:` invokes a method on the receiver, returning the
#  receiver for chaining):
#
#    local parser = require "argparse"()
#        : name "X"                   -- set program name
#        : description "Y"            -- set description text
#        : epilog "Z"                 -- set help footer text
#
#    parser : flag "-X"               -- register boolean flag
#        : description "Y"            -- flag help text
#        : target "field-name"        -- destination field in parsed table
#        : action(fn)                 -- callback when flag matched
#
#    parser : option "-X"             -- register value-taking flag
#        : argname "PLACEHOLDER"      -- value placeholder in help
#        : count "*"                  -- repeatable (0+ occurrences)
#        : choices { "a", "b", "c" }  -- restricted values
#
#    parser : argument "name"         -- register positional argument
#        : args "*"                   -- variadic (0+ values)
#
#    local args = parser:parse()      -- parse process argv into table
#
#  Brings cross-language CLI library taxonomy variant count to 88; Lua
#  ecosystem now has 2 documented CLI libraries.
#
#  Surface (verbatim from ypp/ypp.lua `parse_args`):
#
#  Flags:
#    -v                          Show ypp version and exit
#    -a                          Force ANSI colorization
#    -l SCRIPT (repeatable)      Execute a Lua script before processing
#    -e STATEMENT (repeatable)   Execute a Lua statement
#    -D NAME=VALUE (repeatable)  Define a Lua variable
#    -p PATH (repeatable)        Add path to package.path
#    -o FILE                     Redirect output to file
#    -t FORMAT                   Default image format (svg/pdf/png)
#    --MT TARGET (repeatable)    Add target to dependency target list
#                                (implies --MD)
#    --MF NAME                   Set dependency file name (implies --MD)
#    --MD                        Generate a dependency file
#    --img PATH                  Set path for generated images
#    --meta PATH                 Set path for generated meta image files
#    -s                          Add blank line separator between input
#                                files
#
#  Positional:
#    <input>...                  Input files (stdin if none given)
#
#  Dup-skipped neighbors during hunt (already in corpus or smaller):
#    - luacheck (mpeterv/luacheck — IN CORPUS, used argparse)
#    - busted (Olivine-Labs/busted — IN CORPUS, used argparse)
#    - ldoc (lunarmodules/ldoc — IN CORPUS, used argparse)
#    - luax (CDSoft/luax 206 stars top-level binary — build.lua argparse
#      is minimal 1-flag surface; ypp is luax's RICHEST argparse consumer)
# ============================================================================

_ypp() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '-v[show ypp version and exit]' \
    '-a[force ANSI colorization]' \
    '*-l[execute Lua script]:script:_files -g "*.lua"' \
    '*-e[execute Lua statement]:statement' \
    '*-D[define Lua variable (NAME=VALUE)]:definition' \
    '*-p[add path to package.path]:path:_directories' \
    '-o[redirect output to file]:file:_files' \
    '-t[default image format]:format:(svg pdf png)' \
    '*--MT[add target to dependency target list]:target' \
    '--MF[set dependency file name]:dep file:_files' \
    '--MD[generate dependency file]' \
    '--img[path for generated images]:path:_directories' \
    '--meta[path for generated meta image files]:path:_directories' \
    '-s[add blank line separator between input files]' \
    '*:input file:_files'
}

_ypp "$@"
