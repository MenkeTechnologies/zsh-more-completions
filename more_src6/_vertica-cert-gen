#compdef vertica-cert-gen cert-gen
# _vertica-cert-gen — Vertica Kubernetes operator helper that mints a self-signed x509 cert + emits the matching Secret YAML to stdout
# upstream: https://github.com/vertica/vertica-kubernetes
# Flags from cmd/cert-gen/main.go on tip; positional args: <secret-name> <namespace> <common-name>.

_vertica-cert-gen() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--extra-dns-names=[csv of additional DNS SANs]:csv:' \
        '--ips=[csv of additional IP SANs]:csv:' \
        '1:secret name:' \
        '2:secret namespace:' \
        '3:common name:'
}

_vertica-cert-gen "$@"
