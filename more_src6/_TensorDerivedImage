#compdef TensorDerivedImage
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/TensorDerivedImage.cxx — compute scalar (FA/MD/RGB/etc.) image from a DT tensor volume (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:tensorvolume:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '2:outputvolume:_files' \
    '3:outputtype:(fa md rgb ad rd geodesicAnisotropy modeOfAnisotropy planar linear spherical)' \
    && ret=0

return ret
