#compdef wails
# Documentation: https://github.com/wailsapp/wails (v2 cmd/wails/flags/)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_wails_commands() {
  local -a commands=(
    'build:build the project'
    'dev:run in development mode'
    'doctor:diagnose development environment'
    'generate:generation tools'
    'init:initialise a new Wails project'
    'show:show various info'
    'update:update Wails'
    'version:print the version'
  )
  _describe -t commands 'wails command' commands
}

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :_wails_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      init)
        _arguments -s -S \
          '-n+[project name]:name' \
          '-t+[template name/path/url]:template' \
          '-d+[project directory]:dir:_directories' \
          '-l[list available templates]' \
          '-g[initialise git repository]' \
          '-ide+[generate IDE project files]:ide:(vscode goland)' \
          '-q[suppress output]' \
          '-ci[CI mode]' \
          '-nocolour[disable colour in output]' && ret=0
        ;;
      build)
        _arguments -s -S \
          '-clean[clean bin directory before building]' \
          '-compiler=[Go compiler to use]:compiler:_files' \
          '-debug[build in debug mode]' \
          '-devtools[enable devtools in production]' \
          '-dryrun[print build command without executing]' \
          '-f[force rebuild of application]' \
          '-garbleargs=[arguments to pass to garble]:args' \
          '-ldflags=[additional ldflags]:ldflags' \
          '-m[skip mod tidy before compile]' \
          '-nopackage[skip platform-specific packaging]' \
          '-nocolour[disable colour in output]' \
          '-nosyncgomod[do not sync go.mod]' \
          '-nsis[generate NSIS installer for Windows]' \
          '-installscope=[NSIS install scope]:scope:(machine user)' \
          '-o+[output filename]:filename' \
          '-obfuscated[obfuscate bound Wails methods]' \
          '-platform=[target platform]:platform:(darwin linux windows darwin/amd64 darwin/arm64 linux/amd64 linux/arm64 windows/amd64 windows/arm64)' \
          '-race[build with Go race detector]' \
          '-s[skip frontend build]' \
          '-skipbindings[skip bindings generation]' \
          '-tags=[build tags]:tags' \
          '-trimpath[remove file system paths from binary]' \
          '-u[update go.mod to match CLI version]' \
          '-upx[compress binary with UPX]' \
          '-upxflags=[flags for UPX]:flags' \
          '-v=[verbosity level]:level:(0 1 2)' \
          '-webview2=[WebView2 installer strategy]:strategy:(download embed browser error)' \
          '-windowsconsole[keep console for Windows builds]' && ret=0
        ;;
      dev)
        _arguments -s -S \
          '-appargs=[arguments to pass to the app]:args' \
          '-assetdir=[directory for served assets]:dir:_directories' \
          '-browser[open browser on startup]' \
          '-compiler=[Go compiler to use]:compiler:_files' \
          '-debounce=[debounce time for recompilation (ms)]:ms' \
          '-devserver=[address for dev server]:address' \
          '-e=[extensions to trigger rebuilds]:extensions' \
          '-f[force rebuild of application]' \
          '-frontenddevserverurl=[URL for external frontend dev server]:url' \
          '-ldflags=[additional ldflags]:ldflags' \
          '-loglevel=[log level]:level:(Trace Debug Info Warning Error)' \
          '-m[skip mod tidy before compile]' \
          '-nocolor[disable colour in output]' \
          '-nogorebuild[disable rebuilding on backend file changes]' \
          '-noreload[disable automatic reload on asset change]' \
          '-race[build with Go race detector]' \
          '-reloaddirs=[additional directories to trigger reloads]:dirs' \
          '-s[skip frontend build]' \
          '-save[save flags as defaults]' \
          '-skipbindings[skip bindings generation]' \
          '-tags=[build tags]:tags' \
          '-v=[verbosity level]:level:(0 1 2)' \
          '-viteservertimeout=[Vite server detection timeout (s)]:seconds' \
          '-wailsjsdir=[directory for generated Wails JS modules]:dir:_directories' && ret=0
        ;;
      generate)
        local -a gen_cmds=(
          'module:generate wailsjs modules'
          'template:generate a template from a project'
        )
        _describe -t gen-commands 'generate command' gen_cmds
        ;;
    esac
    ;;
esac

return ret
