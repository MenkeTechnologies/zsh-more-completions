#compdef tuftool
# Documentation: https://github.com/awslabs/tough
# Source: https://github.com/awslabs/tough/blob/develop/tuftool/src/main.rs
# Reference accessed: 2026-06-01
# Rust CLI for creating, signing, and downloading TUF repositories.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _tuf_cmds
_tuf_cmds=(
    'clone:clone a TUF repository (metadata and some/all targets)'
    'create:create a TUF repository'
    'delegation:delegation commands (add-key/add-role/create-role/remove/remove-key)'
    'download:download a TUF repository`s targets'
    'root:manipulate a root.json metadata file'
    'transfer-metadata:transfer metadata from a previous root to a new root'
    'update:update repository metadata, optionally adding targets'
    'help:show help'
)

local -a _tuf_delegation
_tuf_delegation=(
    'add-key:add a key to a delegated role'
    'add-role:add a delegated role'
    'create-role:create a delegated role'
    'remove:remove a role'
    'remove-key:remove a key from a delegated role'
)

_arguments -C \
    '(-l --log-level)'{-l+,--log-level=}'[logging verbosity]:level:(trace debug info warn error)' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'tuftool command' _tuf_cmds && ret=0
        ;;
    args)
        case $line[1] in
            delegation)
                _arguments -s -S \
                    '--signing-role=[the signing role (required)]:role:_default' \
                    '1:subcommand:->deleg' \
                    '*::positional:_default' && ret=0
                case $state in
                    deleg) _describe -t deleg 'delegation subcommand' _tuf_delegation && ret=0 ;;
                esac
                ;;
        esac
        ;;
esac

return ret
