#compdef xwininfo
# Documentation: man xwininfo(1)
# Source: xwininfo — window-information utility for X.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[print usage summary]' \
    '-id[target window id]:window-id:' \
    '-root[target X root window]' \
    '-name[target window by name]:name:' \
    '-int[display window ids as integers (default hex)]' \
    '-children[print root/parent/children ids+names of target]' \
    '-tree[recursive variant of -children]' \
    '-stats[location/appearance attributes (default)]' \
    '-bits[raw-bits+storage attributes]' \
    '-events[event masks (wanted and no-propagate)]' \
    '-size[sizing hints (normal+zoom)]' \
    '-wm[window-manager hints]' \
    '-shape[shape extents]' \
    '-frame[consider WM frames when manually selecting]' \
    '-all[shorthand for every information section]' \
    '-english[also display sizes in inches/feet/yards/miles]' \
    '-metric[also display sizes in millimeters]' \
    '(-d -display)'{-d,-display}'[X server host\:dpy]:host\:dpy:' \
    '(- *)-version[print version and exit]' \
    && ret=0

return ret
