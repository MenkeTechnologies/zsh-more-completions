#compdef xctool
# _xctool — Facebook xctool xcodebuild wrapper for iOS/macOS (Meta/Facebook, Objective-C); custom argparse
# upstream: https://github.com/facebookarchive/xctool

_xctool() {
    _arguments \
        '-help[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-h[show help]' \
        '-workspace+[workspace]:file:_files -g "*.xcworkspace"' \
        '-project+[project]:file:_files -g "*.xcodeproj"' \
        '-scheme+[scheme]:str:' \
        '-target+[target]:str:' \
        '-configuration+[configuration]:str:' \
        '-arch+[arch]:arch:' \
        '-destination+[destination spec]:str:' \
        '-sdk+[sdk]:sdk:' \
        '-derivedDataPath+[derived data path]:dir:_files -/' \
        '-resultBundlePath+[result bundle path]:dir:_files -/' \
        '-toolchain+[toolchain]:str:' \
        '-jobs+[parallel jobs]:n:' \
        '-reporter+[reporter:dst]:str:' \
        '-find-target+[target name]:str:' \
        '-find-target-path-filter+[path filter]:str:' \
        '-actool=+[actool arg]:str:' \
        '-ibtool=+[ibtool arg]:str:' \
        '-actoolPath=+[actool path]:file:_files' \
        '-ibtoolPath=+[ibtool path]:file:_files' \
        '-only=+[only test class:method]:str:' \
        '-omit=+[omit test class:method]:str:' \
        '-only-list[only list]' \
        '-test-sdk+[test sdk]:sdk:' \
        '-launch-timeout+[launch timeout]:n:' \
        '-list-targets[list targets]' \
        '-list-schemes[list schemes]' \
        '-showBuildSettings[show build settings]' \
        '-parallelize[parallelize tests]' \
        '-parallelize-tests[parallelize tests]' \
        '-fresh-simulator[fresh simulator]' \
        '-fresh-install[fresh install]' \
        '-reset-simulator[reset simulator]' \
        '-newSimulatorInstance[new simulator instance]' \
        '-noResetSimulator[no reset simulator]' \
        '-killSimulator[kill simulator]' \
        '-simulator-app-path+[simulator app path]:file:_files' \
        '-clean[clean]' \
        '-build[build]' \
        '-test[test]' \
        '-archive[archive]' \
        '-run-tests[run tests]' \
        '-build-tests[build tests]' \
        '-analyze[analyze]' \
        '-install[install]' \
        '-uninstall[uninstall]' \
        '-failFast[fail fast]' \
        '-resetBuildSettings[reset build settings]' \
        '*:action-or-arg:'
}

_xctool "$@"
