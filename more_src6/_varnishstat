#compdef varnishstat
# Documentation: https://manpages.debian.org/testing/varnish/varnishstat.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-1[print statistics once to stdout and exit]' \
  '-f+[legacy field filtering glob]:glob' \
  '-I+[field inclusion glob]:glob' \
  '-X+[field exclusion glob]:glob' \
  '-j[print statistics to stdout as JSON]' \
  '-l[list available fields to use with -f]' \
  '-n+[varnish working directory of instance]:workdir:' \
  '-r[toggle raw or adjusted gauges]' \
  '-t+[initial VSM connection timeout]:seconds' \
  '-x[print statistics to stdout as XML]' && ret=0

return ret
