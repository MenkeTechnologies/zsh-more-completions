#compdef tckgen
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/tckgen.html
# Source: MRtrix3/mrtrix3 cmd/tckgen.cpp + src/dwi/tractography/seeding+tracking (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-algorithm+[tractography algorithm]:name:(fact ifod1 ifod2 nulldist1 nulldist2 sd_stream seedtest tensor_det tensor_prob)' \
    '-select+[target number of streamlines]:n:_default' \
    '-step+[step size in mm]:size:_default' \
    '-angle+[max angle between successive steps (deg)]:value:_default' \
    '-minlength+[minimum streamline length (mm)]:value:_default' \
    '-maxlength+[maximum streamline length (mm)]:value:_default' \
    '-cutoff+[FOD/FA cutoff for terminating tracks]:value:_default' \
    '-trials+[max attempts to propagate streamline from seed]:n:_default' \
    '-noprecomputed[do not precompute SH transformation]' \
    '-rk4[use 4th-order Runge-Kutta integration]' \
    '-stop[stop on all-include traversal]' \
    '-downsample+[downsample streamlines by factor]:factor:_default' \
    '*-seed_image+[mask image to seed within]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '*-seed_sphere+[spherical seed XYZ,radius]:coords:_default' \
    '*-seed_random_per_voxel+[N seeds per voxel of mask]:image:_files -g "*.{nii,nii.gz,mif}":n:_default' \
    '*-seed_grid_per_voxel+[grid seeds per voxel of mask]:image:_files -g "*.{nii,nii.gz,mif}":n:_default' \
    '*-seed_rejection+[seed by image rejection sampling]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-seed_gmwmi+[seed at GM/WM interface (ACT only)]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-seed_dynamic+[dynamic seeding via SIFT model]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-seeds+[total number of seeds]:n:_default' \
    '-max_attempts_per_seed+[max attempts per seed]:n:_default' \
    '-seed_cutoff+[FA/FOD threshold for seeding]:value:_default' \
    '-seed_unidirectional[track only one direction from seed]' \
    '-seed_direction+[seeding direction vector]:dir:_default' \
    '-output_seeds+[output successful seed locations]:file:_files' \
    '*-include+[ROI streamlines must enter]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '*-include_ordered+[ordered ROIs streamlines must traverse]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '*-exclude+[ROI streamlines must avoid]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '*-mask+[mask restricting streamline propagation]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-act+[ACT 5TT image]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-backtrack[backtrack into white matter on ACT termination]' \
    '-crop_at_gmwmi[crop streamline endpoints to GM-WM interface]' \
    '-power+[power of FOD raised before sampling]:value:_default' \
    '-samples+[FOD samples per step (iFOD2)]:n:_default' \
    '-grad+[MRtrix gradient table]:file:_files' \
    '-fslgrad+[FSL bvecs bvals pair]:files:_files' \
    '1:source (FOD or DWI image):_files -g "*.{nii,nii.gz,mif}"' \
    '2:tracks (output):_files -g "*.tck"' \
    && ret=0

return ret
