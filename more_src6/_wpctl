#compdef wpctl
# Documentation: https://manpages.opensuse.org/Tumbleweed/wireplumber/wpctl.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_wpctl_set_volume() {
  _arguments \
    '--pid[filter by PID]:pid:_pids' \
    ':ID:' \
    ':volume:'
}

_wpctl_set_mute() {
  _arguments \
    ':ID:' \
    ':mute state:(1 0 toggle)'
}

_wpctl_clear_default() {
  _arguments \
    ':id:'
}

_wpctl() {
  local -a commands
  commands=(
    'status:display current state of objects in PipeWire'
    'get-volume:retrieve volume information about a node'
    'inspect:display detailed information about an object'
    'set-default:set device node as default for its category'
    'set-volume:set volume of a node'
    'set-mute:set mute state of a node'
    'set-profile:set profile of a device'
    'set-route:set route of a device'
    'clear-default:remove default node configuration'
    'settings:show change or remove WirePlumber settings'
    'set-log-level:set WirePlumber log level'
  )

  _arguments \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '1:command:->command' \
    '*::arguments:->arguments'

  case "$state" in
    command)
      _describe -t commands 'wpctl command' commands
      ;;
    arguments)
      case "$words[1]" in
        set-volume) _wpctl_set_volume ;;
        set-mute) _wpctl_set_mute ;;
        clear-default) _wpctl_clear_default ;;
        inspect|set-default|get-volume) _arguments ':ID:' ;;
        set-profile) _arguments ':ID:' ':profile index:' ;;
        set-route) _arguments ':ID:' ':route index:' ;;
        set-log-level) _arguments ':level:' ;;
      esac
      ;;
  esac
}

_wpctl "$@"
