#compdef tidb
# Documentation: https://docs.pingcap.com/tidb/stable/command-line-flags-for-tidb-configuration
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-V[show version]' \
  '--advertise-address=[IP for cluster access]:addr:' \
  '--host=[server listen address (default 0.0.0.0)]:host:_hosts' \
  '-P=[MySQL client port (default 4000)]:port:' \
  '--socket=[unix socket file path]:file:_files' \
  '--store=[storage engine]:engine:(unistore tikv)' \
  '--path=[data directory or PD address]:path:' \
  '--temp-dir=[temporary directory]:dir:_files -/' \
  '--config=[configuration file path]:file:_files -g "*.toml"' \
  '--config-check[validate config and exit]' \
  '--config-strict[enforce config validity]' \
  '-L=[log level]:level:(debug info warn error fatal)' \
  '--log-file=[log file path]:file:_files' \
  '--log-general=[general log filename]:file:_files' \
  '--log-slow-query=[slow query log directory]:dir:_files -/' \
  '--redact[desensitize logs]' \
  '--status=[status report port (default 10080)]:port:' \
  '--status-host=[status monitoring host]:host:_hosts' \
  '--report-status[enable metrics/pprof]' \
  '--metrics-addr=[Prometheus Pushgateway address]:addr:' \
  '--metrics-interval=[Prometheus push interval in seconds]:duration:' \
  '--initialize-insecure[bootstrap in insecure mode]' \
  '--initialize-secure[use socket authentication for root]' \
  '--initialize-sql-file=[SQL script run on first start]:file:_files' \
  '--lease=[schema lease duration (default 45s)]:duration:' \
  '--run-ddl=[enable DDL execution]:flag:(true false)' \
  '--token-limit=[concurrent session limit (default 1000)]:n:' \
  '--plugin-dir=[plugin storage directory]:dir:_files -/' \
  '--plugin-load=[comma-separated plugin names]:plugins:' \
  '--cors=[CORS header value for HTTP]:origin:' \
  '--tidb-service-scope=[service scope setting]:scope:' \
  '--affinity-cpus=[CPU affinity list]:cpus:' \
  '--repair-mode[enable repair mode]' \
  '--repair-list=[tables to repair]:tables:' \
  '--proxy-protocol-networks=[allowed proxy IPs/CIDR]:networks:' \
  '--proxy-protocol-fallbackable[enable PROXY protocol fallback]' \
  '--proxy-protocol-header-timeout=[header read timeout seconds (default 5)]:duration:' && ret=0

return ret
