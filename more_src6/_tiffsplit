#compdef tiffsplit
# Documentation: tiffsplit usage on libtiff 4.7.1
# Source: libtiff tiffsplit — split a multi-image TIFF into single-image TIFF files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-M+[memory allocation limit (MiB; 0 = no limit)]:size:' \
    '1:input multi-image TIFF:_files -g "*.{tif,tiff,TIF,TIFF}"' \
    '2:output prefix:_files' \
    && ret=0

return ret
