#compdef ttok

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-m --model)'{-m,--model}'[model to use for tokenization]:model:(gpt-4 gpt-4o gpt-3.5-turbo claude)' \
  '(-e --encoding)'{-e,--encoding}'[encoding to use]:encoding:(cl100k_base p50k_base r50k_base o200k_base)' \
  '(-t --truncate)'{-t,--truncate}'[truncate input to N tokens]:token count:' \
  '--help[show help message]' \
  '*:input text:' && ret=0

return ret
