#compdef termshark
# Documentation: https://github.com/gcla/termshark/blob/master/docs/UserGuide.md
# Reference accessed: 2026-05-21
# Verified: upstream UserGuide.md — flags -i, -r, -w, -f, -Y, -d, -D,
# -t (timestamp format), -C/--profile, --tty, --pass-thru, --log-tty,
# -h/--help, -v/--version.
# Removed: -T (output format — that's tshark, not termshark),
# -c (packet count — not documented), --debug, --tshark-args
# (no evidence in upstream docs).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-i+[interface to capture from]:interface:_net_interfaces' \
  '-r+[read packet data from file or fifo]:capture file:_files' \
  '-w+[write raw packet data to file]:output file:_files' \
  '-f+[capture filter expression]:filter' \
  '-Y+[display filter expression]:display filter' \
  '-d+[custom dissection (decode-as)]:decode specification' \
  '-D[list available interfaces]' \
  '-t+[packet timestamp format]:format' \
  '(-C --profile)'{-C+,--profile=}'[use named configuration profile]:profile' \
  '--tty=[display UI on specified terminal]:tty:_files' \
  '--pass-thru=[run tshark instead (auto/true/false)]:mode:(auto true false)' \
  '--log-tty[log to terminal]' \
  '*:capture filter' && ret=0

return ret
