#compdef yaf yafscii getFlowKeyHash yafMeta2Pcap super_mediator
# Documentation: https://tools.netsa.cert.org/yaf2/{yaf,yafscii,getFlowKeyHash,yafMeta2Pcap}.html
#                https://tools.netsa.cert.org/super_mediator/super_mediator.html
# Reference accessed: 2026-05-30
# YAF / super_mediator — CERT NetSA's flow-meter family. Complements the SiLK
# completions added across rounds 135-140. yaf produces IPFIX from pcap;
# yafscii prints IPFIX as text; getFlowKeyHash computes flow IDs; yafMeta2Pcap
# extracts per-flow pcap from yaf metadata; super_mediator is the IPFIX
# collector/aggregator that ingests yaf output.
# Deferred this round: filterv6 + yafzcballast (upstream 404).

local curcontext="$curcontext" state line ret=1

# Shared logging cluster.
local -a _log
_log=(
  '--log=[log destination (stderr/syslog facility/path)]:dest:'
  '--loglevel=[minimum log level]:level:(quiet error critical warning message info debug)'
  '--verbose[equivalent to --loglevel debug]'
  '(- *)--version[show version + build info]'
)

case $service in

  yaf)
    _arguments -s -S \
      $_log \
      '--config=[Lua configuration file]:file:_files -g "*.lua"' \
      '--in=[input source (file/interface/stdin)]:source:' \
      '--live=[live capture backend]:backend:(pcap pfring dag napatech netronome zc)' \
      '--caplist[input is newline-delimited pcap list]' \
      '--noerror[continue on pcap read errors]' \
      '--filter=[BPF expression]:bpf:' \
      '--filter-file=[BPF expression file]:file:_files' \
      '--decompress=[dir for gzip decompression]:dir:_files -/' \
      '--export-interface[export ingress/egress interface fields]' \
      '--out=[output destination]:dest:' \
      '--ipfix=[IPFIX export protocol]:proto:(tcp udp sctp spread)' \
      '--ipfix-port=[IPFIX collector port (default 4739)]:port:' \
      '--rotate=[rotate output files every N sec]:seconds:' \
      '--lock[use lockfiles for concurrent access]' \
      '--no-output[suppress IPFIX export]' \
      '--stats=[process stats interval (default 300s)]:seconds:' \
      '--no-stats[disable stats export]' \
      '--no-tombstone[disable tombstone record export]' \
      '--tombstone-configured-id=[custom tombstone identifier]:id:' \
      '--no-frag[ignore fragmented packets]' \
      '--max-frags=[fragment table size limit]:N:' \
      '(--ip4-only --ip6-only)--ip4-only[process IPv4 only]' \
      '(--ip4-only --ip6-only)--ip6-only[process IPv6 only]' \
      '--gre-decode[decode GRE-encapsulated]' \
      '--vxlan-decode[decode VxLAN (default port 4789)]' \
      '--vxlan-decode-ports=[VxLAN port list]:ports:' \
      '--geneve-decode[decode Geneve (default port 6081)]' \
      '--geneve-decode-ports=[Geneve port list]:ports:' \
      '--force-read-all[process out-of-sequence packets]' \
      '--no-vlan-in-key[exclude VLAN from flow key hash]' \
      '--idle-timeout=[idle timeout (default 300s)]:seconds:' \
      '--active-timeout=[active timeout (default 1800s)]:seconds:' \
      '--udp-temp-timeout=[UDP template timeout (default 600s)]:seconds:' \
      '--max-flows=[limit concurrent open flows]:N:' \
      '--max-payload=[max payload octets per direction]:N:' \
      '--protocol-payload=[protocols for payload capture]:list:' \
      '--udp-payload[capture payload from all UDP packets]' \
      '--silk[export in SiLK-compatible mode]' \
      '--udp-uniflow=[single-packet flow export UDP port]:port:' \
      '--export-payload[export captured payload]' \
      '--payload-applabel-select=[export payload for applabels]:list:' \
      '--max-export=[max payload bytes to export]:N:' \
      '--uniflow[uniflow via Record Adjacency]' \
      '--mac[export MAC layer information]' \
      '--force-ip6-export[force IPv4 as IPv6-mapped]' \
      '--observation-domain=[observationDomainId]:id:' \
      '--flow-stats[export additional flow stats]' \
      '--delta[export counts as deltas]' \
      '--ingress=[ingress interface field]:int:' \
      '--egress=[egress interface field]:int:' \
      '--metadata-export[export template/element metadata]' \
      '--time-elements=[timestamp precision values (1=ms,2=μs,3=ns)]:values:' \
      '--applabel[enable application labeling]' \
      '--applabel-rules=[custom applabel rules file]:file:_files' \
      '--applabel-check-early=[early labeling threshold]:N:' \
      '--applabel-max-payload=[per-app payload limits]:spec:' \
      '--ndpi[enable nDPI deep packet inspection]' \
      '--ndpi-protocol-file=[nDPI protocol definitions]:file:_files' \
      '--entropy[export Shannon entropy values]' \
      '--tls[use TLS for IPFIX connection]' \
      '--tls-ca=[CA certificate PEM]:file:_files' \
      '--tls-cert=[client certificate PEM]:file:_files' \
      '--tls-key=[private key PEM]:file:_files' \
      '*--group=[Spread group names]:names:' \
      '--groupby=[group-by type]:type:(port vlan applabel protocol version)' \
      '--become-user=[drop privileges to user]:user:_users' \
      '--become-group=[drop privileges to group]:group:_groups' \
      '--pcap=[PCAP export path]:path:_files' \
      '--pcap-per-flow[separate PCAP per flow]' \
      '--max-pcap=[max PCAP file size MB (default 25)]:MB:' \
      '--pcap-timer=[PCAP rotation seconds]:seconds:' \
      '--pcap-meta-file=[PCAP metadata file]:file:_files' \
      '--index-pcap[include packet offset/length in metadata]' \
      '--hash=[extract PCAP for flow hash]:hash:' \
      '--stime=[match flow by start time ms]:ms:' \
      '*--plugin-name=[plugin library path]:lib:_files' \
      '--plugin-opts=[plugin arguments]:opts:' \
      '*--plugin-conf=[plugin configuration files]:file:_files' \
      '--p0fprint[export p0f OS fingerprinting data]' \
      '--p0f-fingerprints=[custom p0f fingerprint file]:file:_files' \
      '--fpexport[export handshake headers for external FP]' \
      && ret=0
    ;;

  yafscii)
    _arguments -s -S \
      $_log \
      '--in=[input source (file/dir/glob/-)]:source:' \
      '--out=[output destination (file/dir/-)]:dest:' \
      '--tabular[automation-friendly table format]' \
      '--mac[include source/dest MAC (with --tabular)]' \
      '--print-header[add column headers (with --tabular)]' \
      '(--daemon --foreground)--daemon[run as background daemon]' \
      '(--daemon --foreground)--foreground[stay foreground (debug daemon mode)]' \
      '--lock[lockfiles for concurrent access]' \
      '--poll=[polling interval (default 60s)]:seconds:' \
      '--nextdir=[move processed files here (or delete)]:dir:' \
      '--faildir=[move failed files here (or delete)]:dir:' \
      && ret=0
    ;;

  getFlowKeyHash)
    _arguments -s -S \
      '(- *)--version[show version]' \
      '--in=[input source]:source:_files' \
      '--out=[output destination]:dest:_files' \
      '--sip4=[source IPv4 (dotted)]:ip:' \
      '--dip4=[destination IPv4 (dotted)]:ip:' \
      '--sip6=[source IPv6]:ip:' \
      '--dip6=[destination IPv6]:ip:' \
      '--sport=[source port (0-65535)]:port:' \
      '--dport=[destination port (0-65535)]:port:' \
      '--protocol=[IP protocol (6=TCP, 17=UDP)]:proto:' \
      '--vlan=[VLAN identifier]:id:' \
      '--ipfix[export hash in IPFIX]' \
      '--date=[flow start date YYYY-MM-DD (UTC)]:date:' \
      '--time=[flow start time HH:MM:SS[.sss]]:time:' \
      '--reverse[reverse flow key hash (swap IPs+ports)]' \
      '--snmp[ignore SNMP interface field]' \
      && ret=0
    ;;

  yafMeta2Pcap)
    _arguments -s -S \
      '(- *)--version[show version]' \
      '--verbose[debug output to stdout]' \
      '--pcap-meta-file=[yaf metadata file (glob OK)]:pattern:' \
      '--pcap=[original PCAP file (glob OK)]:pattern:_files -g "*.pcap"' \
      '--caplist=[newline-delimited PCAP filename list]:file:_files' \
      '--metalist=[newline-delimited metadata filename list]:file:_files' \
      '--out=[extracted PCAP output path]:path:_files' \
      '--hash=[flow key hash]:hash:' \
      '--time=[flow start ms since epoch]:ms:' \
      '--etime=[flow end ms since epoch]:ms:' \
      '-w+[search window after start-time (ms)]:ms:' \
      '--window=[search window after start-time (ms)]:ms:' \
      '--packets=[total packet count for bi-flow]:N:' \
      '--yaf-program=[path to yaf executable]:file:_files -g "yaf"' \
      && ret=0
    ;;

  super_mediator)
    _arguments -s -S \
      '(- *)--help[show help]' \
      '(- *)--version[show version + supported features]' \
      '--log=[log destination]:dest:' \
      '--log-dir=[rotating log directory]:dir:_files -/' \
      '--verbose[DEBUG-level logging]' \
      '--quiet[disable all logging]' \
      '--config=[super_mediator.conf file]:file:_files' \
      '--test-config[parse config and exit]' \
      '--ipfix-input=[IPFIX collector transport]:proto:(tcp udp)' \
      '--ipfix-port=[listen port (default 18000)]:port:' \
      '--polling-interval=[file directory poll interval (sec)]:N:' \
      '--move-dir=[move processed files here]:dir:_files -/' \
      '--no-locked-files[ignore lock files (unimplemented)]' \
      '--out=[output target (filename/host/-)]:dest:' \
      '--output-mode=[export mode]:mode:(tcp udp text json)' \
      '--export-port=[export TCP/UDP port (default 18001)]:port:' \
      '--rotate=[output rotation seconds]:N:' \
      '--fields=[TEXT mode IPFIX element list]:list:' \
      '--print-headers[write headers for delimited text]' \
      '--no-stats[do not forward yaf stats records]' \
      '--preserve-obdomain[do not overwrite observation domain IDs]' \
      '--rewrite-ssl-certs[restructure SSL cert records]' \
      '--disable-metadata-export[omit element + template metadata]' \
      '--ipsetfile=[IPset file (errors if no IPset support)]:file:_files -g "*.set"' \
      '--sleep=[sleep between fBufAppend calls (μs)]:microseconds:' \
      '--udp-temp-timeout=[UDP template timeout (unimplemented)]:N:' \
      '--daemonize[run as daemon]' \
      '--pidfile=[PID file location]:file:_files' \
      '--become-user=[drop privileges to user]:user:_users' \
      '--become-group=[drop privileges to group]:group:_groups' \
      && ret=0
    ;;

esac

return ret
