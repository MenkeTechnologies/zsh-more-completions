#compdef waymore
# _waymore — Xnl-h4ck3r waymore find more URLs from Wayback Common Crawl URLScan AlienVault VirusTotal IntelX (xnl-h4ck3r team, Python); argparse
# upstream: https://github.com/xnl-h4ck3r/waymore

_waymore() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-i+[input domain or file]:str:' \
        '--input=+[input domain or file]:str:' \
        '-mode=+[mode]:m:(R U B)' \
        '-mc=+[match codes]:str:' \
        '--match-codes=+[match codes]:str:' \
        '-fc=+[filter codes]:str:' \
        '--filter-codes=+[filter codes]:str:' \
        '-mct=+[match content types]:str:' \
        '--match-content-types=+[match content types]:str:' \
        '-fct=+[filter content types]:str:' \
        '--filter-content-types=+[filter content types]:str:' \
        '-from=+[from date]:str:' \
        '-from-date=+[from date]:str:' \
        '-to=+[to date]:str:' \
        '-to-date=+[to date]:str:' \
        '-l+[limit responses]:n:' \
        '--limit=+[limit responses]:n:' \
        '-lr+[limit results]:n:' \
        '--limit-requests=+[limit results]:n:' \
        '-ci+[capture interval]:n:' \
        '--capture-interval=+[capture interval]:n:' \
        '-ko[keep older]' \
        '--keep-older[keep older]' \
        '-ow[overwrite responses]' \
        '--overwrite[overwrite responses]' \
        '-c+[config file]:file:_files -g "*.yml *.yaml"' \
        '--config=+[config file]:file:_files -g "*.yml *.yaml"' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-oR+[output responses dir]:dir:_files -/' \
        '--output-responses=+[output responses dir]:dir:_files -/' \
        '-oU+[output URLs file]:file:_files' \
        '--output-urls=+[output URLs file]:file:_files' \
        '-oI+[output IPs file]:file:_files' \
        '-oP+[output paths file]:file:_files' \
        '-p+[processes]:n:' \
        '--processes=+[processes]:n:' \
        '-t+[timeout secs]:n:' \
        '--timeout=+[timeout secs]:n:' \
        '-r+[regex filter]:str:' \
        '--regex=+[regex filter]:str:' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-no-banner[no banner]' \
        '--no-banner[no banner]' \
        '-no-update-check[no update check]' \
        '-nl[no limit]' \
        '--no-limit[no limit]' \
        '-ra[random user agent]' \
        '--random-agent[random user agent]'
}

_waymore "$@"
