#compdef ttf2afm ttf2pk
# Documentation: ttf2afm / ttf2pk usage (TeX Live; pdftex tools)
# Source: pdftex ttf2afm / ttf2pk — TTF -> AFM / TTF -> TeX PK bitmap.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-i -u -c -v)-i[print glyph names as index123 form]' \
    '(-i -u -c -v)-u[print glyph names as uniABCD form]' \
    '(-i -u -c -v)-c[print encoding tables to file]' \
    '(- *)-v[show version]' \
    '-e+[encoding vector file]:enc:_files -g "*.enc"' \
    '-o+[output file]:file:_files' \
    '-m+[unicode mapping (default 1)]:n:' \
    '-q[no informational output (ttf2pk)]' \
    '-n[use .pk extension only (ttf2pk)]' \
    '-t[test for font existence (ttf2pk; exit 0 on success)]' \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '1:TrueType font:_files -g "*.ttf"' \
    '2:dpi (ttf2pk) / output filename:' \
    && ret=0

return ret
