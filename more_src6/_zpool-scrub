#compdef zpool-scrub
# _zpool-scrub — OpenZFS zpool scrub (verify and repair all data using parity/mirroring redundancy; -s stop, -p pause, -w wait until complete, -e error scrub (focus on suspected bad blocks); positional argument is the pool to scrub)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zpool/zpool_main.c (zpool_do_scrub) on tip.

_zpool-scrub() {
    _arguments \
        '-s[stop in-progress scrub]' \
        '-p[pause in-progress scrub]' \
        '-w[wait until complete]' \
        '-e[error scrub]' \
        '*:pool:'
}

_zpool-scrub "$@"
