#compdef wireguard-vanity-keygen
# Documentation: https://github.com/axllent/wireguard-vanity-keygen
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-s --summary)'{-s,--summary}'[print results when all are found]' \
  '(-c --case-sensitive)'{-c,--case-sensitive}'[case-sensitive matching]' \
  '(-t --threads)'{-t,--threads}'=[number of threads to use]:n:' \
  '(-l --limit)'{-l,--limit}'=[max results before exiting]:n:' \
  '(-T --timeout)'{-T,--timeout}'=[quit after specified duration]:duration:' \
  '(-j --json)'{-j,--json}'[write results to JSON file]:file:_files' \
  '(-u --update)'{-u,--update}'[update to latest release]' \
  '(- *)'{-v,--version}'[display application version]' \
  '(- *)'{-h,--help}'[show help]' \
  '*:search prefix: '
