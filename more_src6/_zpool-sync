#compdef zpool-sync
# _zpool-sync — OpenZFS zpool sync (force a synchronous txg flush of the named pools (or all when no positional given), as if a manual SYNC was issued; useful before snapshots/checkpoints/backups)
# upstream: https://github.com/openzfs/zfs
# Argument shape from openzfs cmd/zpool/zpool_main.c (zpool_do_sync) on tip.

_zpool-sync() {
    _arguments \
        '-f[force]' \
        '*:pool:'
}

_zpool-sync "$@"
