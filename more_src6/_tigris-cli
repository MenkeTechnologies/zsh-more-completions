#compdef tigris-cli
# Documentation: https://github.com/tigrisdata/tigris-cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# tigris: command-line client for Tigris global database
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'login:login to Tigris cloud'
  'logout:logout'
  'config:configure tigris-cli'
  'completion:emit shell completion'
  'create:create project/branch/index/etc'
  'delete:delete an object'
  'describe:describe object'
  'drop:drop branch/project/collection/database/index'
  'list:list projects/branches/etc'
  'read:read documents'
  'search:search documents'
  'transact:transactional commands'
  'update:update fields'
  'insert:insert documents'
  'replace:replace documents'
  'restore:restore a snapshot'
  'sub:subscribe to topic'
  'publish:publish to topic'
  'quota:manage quotas'
  'scaffold:generate sample project'
  'server:run dev server'
  'shell:open interactive shell'
  'tail:tail logs'
  'create-key:create app key'
  'list-keys:list app keys'
  'delete-key:delete app key'
  'version:show version'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-c[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '-u[Tigris URI]:url:' \
  '--uri=[Tigris URI]:url:' \
  '-t[auth token]:token:' \
  '--token=[auth token]:token:' \
  '-i[client id]:id:' \
  '--client-id=[client id]:id:' \
  '-s[client secret]:secret:' \
  '--client-secret=[client secret]:secret:' \
  '-p[project name]:name:' \
  '--project=[project name]:name:' \
  '-b[branch name]:name:' \
  '--branch=[branch name]:name:' \
  '--quiet[quiet]' \
  '--insecure[insecure (skip TLS)]' \
  '-S[shell mode]' \
  '--verbose[verbose]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'tigris command' commands && ret=0 ;;
esac
return ret
