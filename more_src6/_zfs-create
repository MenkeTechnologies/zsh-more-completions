#compdef zfs-create
# _zfs-create — OpenZFS zfs create dataset/volume CLI alias (openzfs team, C); custom argparse
# upstream: https://github.com/openzfs/zfs

_zfs-create() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-p[create parent datasets]' \
        '-u[do not mount]' \
        '-o+[property=value]:str:' \
        '-V+[volsize]:str:' \
        '-b+[block size]:str:' \
        '-s[sparse volume]' \
        '-n[no act]' \
        '-v[verbose]' \
        '*:dataset:'
}

_zfs-create "$@"
