#compdef valhalla_build_landmarks
# Documentation: https://github.com/valhalla/valhalla
# Source: valhalla/valhalla src/mjolnir/valhalla_build_landmarks.cc — build landmark POI DB from PBF.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '(-c --config)'{-c+,--config=}'[JSON config file]:file:_files -g "*.json(-.)"' \
    '(-i --inline-config)'{-i+,--inline-config=}'[inline JSON config]:json:_default' \
    '*:OSM PBF file:_files -g "*.osm.pbf(-.)"' \
    && ret=0

return ret
