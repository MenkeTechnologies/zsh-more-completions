#compdef zpaq
# Documentation: http://mattmahoney.net/dc/zpaq.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed from prior file: `purge` subcommand (zpaq is a journaling
# archiver and does not support deleting old versions; only `add` /
# `extract` / `list` / `compare` / `test` exist in upstream zpaq 7.15)
# and `-summary` (Mahoney's reference does not document this flag).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add:add or update files in archive'
  'extract:extract files from archive'
  'list:list archive contents'
  'compare:compare archive with filesystem'
  'test:verify archive integrity'
)

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'zpaq command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (add)
        _arguments -s -S \
          '-key=[encryption key/password]:key' \
          '-method=[compression level]:level:(0 1 2 3 4 5)' \
          '-force[force without confirmation]' \
          '-noattributes[do not store file attributes]' \
          '-not=[exclude files matching pattern]:pattern' \
          '-only=[include only files matching pattern]:pattern' \
          '-until=[include only files up to version/date]:version' \
          '-threads=[number of threads]:n' \
          '-to=[output destination prefix]:prefix' \
          '-fragment=[set fragment size]:size' \
          '-index=[use/create index file]:file:_files' \
          '-test[verify archive after update]' \
          '1:archive:_files -g "*.zpaq"' \
          '*:files:_files' && ret=0
        ;;
      (extract)
        _arguments -s -S \
          '-key=[decryption key]:key' \
          '-force[force overwrite existing files]' \
          '-noattributes[do not restore file attributes]' \
          '-not=[exclude files matching pattern]:pattern' \
          '-only=[include only files matching pattern]:pattern' \
          '-until=[extract up to version/date]:version' \
          '-threads=[number of threads]:n' \
          '-to=[extract to specified directory]:directory:_files -/' \
          '1:archive:_files -g "*.zpaq"' \
          '*:files' && ret=0
        ;;
      (list)
        _arguments -s -S \
          '-key=[decryption key]:key' \
          '-not=[exclude files matching pattern]:pattern' \
          '-only=[include only files matching pattern]:pattern' \
          '-until=[list up to version/date]:version' \
          '-all[show all file versions]' \
          '1:archive:_files -g "*.zpaq"' && ret=0
        ;;
      (compare)
        _arguments -s -S \
          '-key=[decryption key]:key' \
          '-not=[exclude files matching pattern]:pattern' \
          '-only=[include only files matching pattern]:pattern' \
          '-to=[compare against specified directory]:directory:_files -/' \
          '1:archive:_files -g "*.zpaq"' && ret=0
        ;;
      (test)
        _arguments -s -S \
          '-key=[decryption key]:key' \
          '-threads=[number of threads]:n' \
          '1:archive:_files -g "*.zpaq"' && ret=0
        ;;
    esac
    ;;
esac

return ret
