#compdef zpool-list
# _zpool-list — OpenZFS zpool list (table view of pools and their basic properties; -H scriptable (tab-delimited, no header), -p parsable byte counts, -P print full path, -o picks columns, -T timestamp, -v breaks down by vdev; positional pool optionally filters)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zpool/zpool_main.c (zpool_do_list) on tip.

_zpool-list() {
    _arguments \
        '-H[scriptable output]' \
        '-p[parsable bytes]' \
        '-P[full paths]' \
        '-L[resolve symlinks]' \
        '-g[show GUIDs]' \
        '-j[JSON output]' \
        '-v[verbose (per-vdev)]' \
        '-o+[columns]:cols:(name size allocated free checkpoint expandsize fragmentation capacity dedupratio health altroot autoexpand autoreplace bootfs cachefile delegation failmode listsnapshots readonly version)' \
        '-T+[timestamp format]:format:(u d)' \
        '*:pool:'
}

_zpool-list "$@"
