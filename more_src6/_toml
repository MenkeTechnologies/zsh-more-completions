#compdef toml
# Documentation: https://github.com/gnprice/toml-cli
# Source: gnprice/toml-cli — Rust CLI to query and edit TOML files preserving formatting/comments.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _toml_cmds
_toml_cmds=(
    'get:print some data from the file'
    'set:edit the file to set some data'
    'help:show help'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'toml command' _toml_cmds && ret=0
        ;;
    args)
        case $line[1] in
            get)
                _arguments -s -S \
                    '(-r --raw)'{-r,--raw}'[output raw string]' \
                    '--output-toml[output TOML fragment]' \
                    '1:file:_files -g "*.toml"' \
                    '2:dotted query:_default' \
                    && ret=0
                ;;
            set)
                _arguments -s -S \
                    '1:file:_files -g "*.toml"' \
                    '2:dotted query:_default' \
                    '3:value:_default' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
