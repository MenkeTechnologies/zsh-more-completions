#compdef vessel
# _vessel — original Motoko package manager for Internet Computer (caffeinelabs/vessel)
# upstream: https://github.com/caffeinelabs/vessel
# Subcommands from src/bin/vessel.rs (structopt).

_vessel() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--package-set=[path to the package-set file (default package-set.dhall)]:file:_files -g "*.dhall"' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_vessel_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                install)
                    _arguments \
                        '-f[force reinstall even if already installed]' && ret=0 ;;
                upgrade-set)
                    _arguments \
                        '1:tag (defaults to latest):' && ret=0 ;;
                verify)
                    _arguments \
                        '--version=[Motoko compiler version to use]:version:' \
                        '--moc=[path to the moc binary]:file:_files' \
                        '--moc-args=[extra arguments forwarded to moc]:args:' \
                        '--compile[fully compile the package and validate the wasm]' \
                        '1:package name (optional):' && ret=0 ;;
                init|sources|bin) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_vessel_commands] )) ||
_vessel_commands() {
    local -a commands
    commands=(
        'init:set up the minimal project configuration'
        'install:install all dependencies and print a summary'
        'upgrade-set:print import + hash for the latest vessel-package-set release'
        'sources:install deps and emit --package flags for moc'
        'bin:install compiler binaries and print the path to them'
        'verify:verify that every package in the package set builds'
    )
    _describe -t commands 'vessel command' commands
}

_vessel "$@"
