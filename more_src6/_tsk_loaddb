#compdef tsk_loaddb
# Documentation: https://www.sleuthkit.org/sleuthkit/man/tsk_loaddb.html
# Source: sleuthkit/sleuthkit man/tsk_loaddb.1 — populate an Autopsy SQLite database from an image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[add image to existing database instead of creating a new one]' \
    '-d[path for the database (default: same directory as the image)]:database:_files' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '-k[do not create block data table]' \
    '-h[calculate MD5 hash value for each file and store in table]' \
    '-i[format of image file]:imgtype:(raw aff afd afm afflib ewf split)' \
    '-b[device sector size in bytes]:sector size:(512 1024 2048 4096)' \
    '*:image file:_files' \
    && ret=0

return ret
