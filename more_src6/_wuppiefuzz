#compdef wuppiefuzz
# Documentation: https://github.com/TNO-S3/WuppieFuzz
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: README documents usage "wuppiefuzz [OPTIONS] [OPENAPI_SPEC.YAML]"
# and a 'fuzz' subcommand with --coverage-format, --jacoco-class-dir,
# --config, --report, --coverage-host, --timeout but defers full flag
# reference to --help output without listing it. Only -h/--help and
# -V/--version are clap-conventional defaults; deeper flag set cannot be
# fully verified from README alone.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:subcommand:(fuzz)' \
  '*::arg:_files -g "*.{yaml,yml,json}"' && ret=0
return ret
