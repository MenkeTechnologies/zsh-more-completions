#compdef warpinvert
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/warpinvert.html
# Source: MRtrix3/mrtrix3 cmd/warpinvert.cpp — invert a non-linear warp field (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-template+[output warp grid template image]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-displacement[treat input/output as displacement field]' \
    '1:in (input warp):_files -g "*.{nii,nii.gz,mif}"' \
    '2:out (output warp):_files' \
    && ret=0

return ret
