#compdef tuptime
# Documentation: https://github.com/rfmoz/tuptime
# Reference accessed: 2026-05-21
# Verified: rfmoz/tuptime src/tuptime get_arguments().

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  {-A,--at}'[set reference epoch]:epoch:' \
  {-b,--bootid}'[show boot ID]' \
  {-c,--csv}'[output in CSV format]' \
  {-d,--date}'[date/time format]:format:' \
  {-e,--dec}'[decimal places]:n:' \
  {-E,--exclude}'[exclude bootids]:list:' \
  '--decp[decimal precision]:digits:' \
  {-f,--filedb}'[database file]:file:_files' \
  {-g,--graceful}'[graceful state]' \
  {-i,--invert}'[invert table/list]' \
  {-k,--kernel}'[show kernel version]' \
  {-l,--list}'[list each startup]' \
  {-n,--noup}'[do not update database]' \
  {-o,--order}'[order by key]:key:(e r s u d)' \
  {-p,--power}'[show power events]' \
  '--pctl[show percentiles]' \
  {-q,--quiet}'[quiet]' \
  {-r,--reverse}'[reverse sort order]' \
  {-s,--seconds}'[show seconds]' \
  {-S,--since}'[since date]:date:' \
  {-t,--table}'[table format]' \
  '--tat[at epoch via positional]:epoch:' \
  '--tsince[since via positional epoch]:epoch:' \
  '--tuntil[until via positional epoch]:epoch:' \
  {-U,--until}'[until date]:date:' \
  {-v,--verbose}'[verbose output]' \
  {-V,--version}'[show version]' \
  {-x,--silent}'[silent (suppress output)]' && ret=0
return ret
