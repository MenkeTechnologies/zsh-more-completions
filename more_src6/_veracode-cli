#compdef veracode-cli veracode
# _veracode-cli — Veracode application security CLI (Veracode, Go); spf13/cobra
# upstream: https://github.com/veracode/veracode-cli

_veracode-cli() {
    local -a sub=(
        'configure:configure credentials'
        'static:run static analysis'
        'sca:run software composition analysis'
        'sbom:produce/scan SBOM'
        'pipeline-scan:run pipeline scan'
        'policy:manage policies'
        'workspace:manage workspaces'
        'projects:manage projects'
        'agents:manage agents'
        'workflows:manage workflows'
        'application:manage applications'
        'package:package binary for scan'
        'helper:misc helpers'
        'upload-and-scan:upload + scan binary'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--vid=+[veracode api id]:str:' \
        '--vkey=+[veracode api key]:str:' \
        '--profile=+[profile]:str:' \
        '--config-file=+[config file]:file:_files' \
        '--region=+[region]:r:(commercial federal europe)' \
        '--debug[debug]' \
        '--output=+[output format]:fmt:(json table yaml)' \
        '-o+[output format]:fmt:(json table yaml)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'veracode subcommand' sub ;;
        args)
            case $words[1] in
                static) _arguments \
                    '1:cmd:(scan results)' \
                    '--source=+[source path]:dir:_files -/' \
                    '--name=+[scan name]:str:' \
                    '--policy=+[policy]:str:' \
                    '--wait[wait]' \
                    '*:arg:' ;;
                sca) _arguments \
                    '1:cmd:(scan agent-based-scan upload-scan)' \
                    '--source=+[source path]:dir:_files -/' \
                    '--workspace=+[workspace]:str:' \
                    '--application=+[application]:str:' \
                    '*:arg:' ;;
                sbom) _arguments \
                    '1:cmd:(generate scan)' \
                    '--source=+[source path]:dir:_files -/' \
                    '--format=+[format]:fmt:(cyclonedx spdx)' \
                    '--output=+[output file]:file:_files' \
                    '*:arg:' ;;
                pipeline-scan) _arguments \
                    '--file=+[binary file]:file:_files' \
                    '-f+[binary file]:file:_files' \
                    '--baseline-file=+[baseline file]:file:_files' \
                    '-b+[baseline file]:file:_files' \
                    '--fail-on-cwe=+[fail on cwe]:list:' \
                    '--fail-on-severity=+[fail on severity]:list:(Very-High High Medium Low Very-Low Informational)' \
                    '--include-modules=+[include modules]:list:' \
                    '--exclude-modules=+[exclude modules]:list:' \
                    '--issue-details[issue details]' \
                    '--json-output-file=+[json output]:file:_files' \
                    '--summary-output-file=+[summary output]:file:_files' \
                    '--gitlab-issue-output-file=+[gitlab output]:file:_files' \
                    '--filtered-json-output-file=+[filtered json]:file:_files' \
                    '--ide[ide format]' \
                    '--policy-file=+[policy file]:file:_files' \
                    '--project-name=+[project name]:str:' \
                    '--project-url=+[project url]:url:_urls' \
                    '--app-id=+[app id]:str:' \
                    '*:arg:' ;;
                package) _arguments \
                    '--source=+[source]:dir:_files -/' \
                    '--output=+[output]:dir:_files -/' \
                    '--type=+[type]:t:(directory git docker maven gradle node)' ;;
                upload-and-scan) _arguments \
                    '--filepath=+[binary]:file:_files' \
                    '--scanname=+[scan name]:str:' \
                    '--appid=+[app id]:str:' \
                    '--sandboxid=+[sandbox id]:str:' \
                    '--scantimeout=+[scan timeout]:n:' ;;
                configure) _arguments \
                    '--vid=+[veracode api id]:str:' \
                    '--vkey=+[veracode api key]:str:' \
                    '--profile=+[profile]:str:' \
                    '--region=+[region]:r:(commercial federal europe)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_veracode-cli "$@"
