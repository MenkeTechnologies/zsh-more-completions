#compdef waydroid-cli
# Documentation: https://docs.waydro.id/usage/waydroid-command-line-options
# Reference accessed: 2026-05-21
# Verified: upstream tools/helpers/arguments.py at github.com/waydroid/waydroid.
# NOTE: canonical binary is `waydroid`, not `waydroid-cli`; this alias is
# kept for users who symlink/wrap it.

local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'status:quick check for the waydroid'
  'log:follow the waydroid logfile'
  'init:initialize container'
  'upgrade:upgrade container OS'
  'session:session management'
  'container:container controller'
  'app:application management'
  'prop:android property controller'
  'show-full-ui:show Waydroid UI'
  'first-launch:first launch wizard'
  'shell:shell into the Android container'
  'logcat:tail logcat output'
  'adb:manage adb connection'
  'bugreport:create a bugreport archive interactively'
)
_arguments -C \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-l --log)'{-l,--log}'+[path to log file]:file:_files' \
  '--details-to-stdout[print details to stdout]' \
  '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
  '(-q --quiet)'{-q,--quiet}'[suppress log output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'waydroid command' commands && ret=0 ;;
esac
return ret
