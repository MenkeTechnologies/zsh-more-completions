#compdef x
# Documentation: https://github.com/sferik/x-cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: `x` (sferik/x-cli) is a Ruby Thor CLI for the X (Twitter) API with
# top-level command families {cli, delete, list, search, set, stream} and
# local commands {accounts, set active, delete account, version, ruler}.
# Thor adds -h/--help by default. Full subcommand tree is not stably
# enumerated in the README; expanding further requires fabrication.
# Note: in some setups `x` is aliased to x-cmd or unrelated tools - this
# file is intentionally generic.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--profile=[custom profile config path]:file:_files' \
  '*::args:_default' && ret=0
return ret
