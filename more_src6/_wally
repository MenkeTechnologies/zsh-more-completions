#
# WHAT IS figment AND WHY IS IT THE 66TH RUST CLI LIBRARY?
#
# figment (https://github.com/SergioBenitez/Figment, 898+ stars) is
# **Sergio Benitez's "hierarchical configuration library so con-free,
# it's unreal"** — a Rust configuration library extracted from the
# Rocket web framework's internal config loader.  Where config-rs
# (R629) uses a builder pattern with explicit file/env sources,
# figment uses a `Provider` TRAIT abstraction that any source can
# implement, making custom configuration sources composable on equal
# footing with built-in providers.
#
# figment's distinguishing characteristics:
#
#   1. PROVIDER TRAIT ABSTRACTION — figment's central design is the
#      `Provider` trait.  Any type implementing Provider can be
#      merged into a Figment:
#
#          use figment::{Figment, providers::{Env, Toml, Json,
#                          Serialized, Format}};
#
#          // Compose multiple providers:
#          let config = Figment::new()
#              .merge(Serialized::defaults(MyConfig::default()))
#              .merge(Toml::file("App.toml"))
#              .merge(Toml::file("App.local.toml").nested())
#              .merge(Env::prefixed("APP_").global())
#              .select(env::var("APP_PROFILE").unwrap_or("debug".into()));
#
#          // Extract into a typed struct:
#          let app_config: MyConfig = config.extract()?;
#
#          // OR extract a specific subkey:
#          let db_url: String = config.extract_inner("database.url")?;
#
#      Compare:
#         * config-rs (R629, Rust): builder with add_source(File::...)
#         * viper (R630, Go): global singleton + viper.AddConfigPath
#         * cosmiconfig (R631, Node): search-places + upward walk
#         * Rust confy: single-file simple persistence
#         * figment: PROVIDER TRAIT — any source implements one trait
#      FIRST documented Rust Axis 13 library with Provider trait
#      abstraction as primary API.
#
#   2. BUILT-IN PROVIDERS for 7+ formats — figment ships providers
#      via feature flags:
#         * Toml::file(path) / Toml::string(s) / Toml::default()
#         * Json::file(path) / Json::string(s) / Json::default()
#         * Yaml::file(path) / Yaml::string(s) / Yaml::default()
#         * Env::prefixed("APP_") / Env::raw()
#         * Serialized::defaults(struct) / Serialized::globals(struct)
#         * Format trait — implement custom formats
#         * Composability — multiple Toml files can be merged
#           additively (.merge() vs .join() vs .adjoin() semantics)
#
#      Compare:
#         * config-rs (R629): 7 file formats via Format::from_ext
#         * viper (R630): 7+ formats with HCL/Properties
#         * cosmiconfig (R631): file-discovery only
#         * figment: 7+ providers via Format trait + Serialized
#                     for programmatic defaults
#      FIRST documented Rust Axis 13 library with Serialized
#      provider for programmatic struct-based defaults.
#
#   3. PROFILE-AWARE CONFIGURATION — figment supports named profiles
#      (default / debug / release / custom):
#
#          # Rocket.toml example:
#          [global]
#          address = "0.0.0.0"
#          port = 8080
#
#          [debug]
#          log_level = "debug"
#          template_dir = "templates"
#
#          [release]
#          log_level = "warn"
#          template_dir = "/var/app/templates"
#
#          // In code:
#          let config = Figment::new()
#              .merge(Toml::file("Rocket.toml").nested())
#              .select(env::var("APP_PROFILE").unwrap_or("debug".into()));
#
#          // figment merges [global] then [debug] (or [release])
#          // values based on the selected profile.
#
#      Compare:
#         * config-rs (R629): no profile support (manual)
#         * viper (R630): no profile (manual via SetEnvPrefix)
#         * cosmiconfig (R631): no profile
#         * figment: PROFILE-AWARE built-in (default/debug/release)
#      FIRST documented Rust Axis 13 library with built-in profile-
#      aware configuration matching Rocket.toml's [global]/[debug]/
#      [release] section pattern.
#
#   4. ROUTING ERROR MESSAGES — when extraction fails, figment
#      reports the EXACT source provider, the OFFENDING key path,
#      and the EXPECTED vs ACTUAL types:
#
#          // If "database.url" expects String but Toml has integer:
#          Error: invalid type: found integer, expected string
#            in `database.url`
#            sourced from TOML file `App.toml`
#
#      The error tracking through merged providers means complex
#      multi-source configurations are debuggable.  Compare:
#         * config-rs (R629): generic deserialize errors
#         * viper (R630): generic type-coercion errors
#         * cosmiconfig (R631): file-format errors only
#         * figment: SOURCE-AWARE typed errors with key paths
#      FIRST documented Rust Axis 13 library with source-aware
#      error reporting through merged providers.
#
#   5. SERGIO BENITEZ / ROCKET-FRAMEWORK PROVENANCE — figment is by
#      Sergio Benitez (SergioBenitez on GitHub, also author of
#      Rocket web framework with 24,000+ stars).  Sergio extracted
#      figment from Rocket's internal configuration loader as a
#      standalone library because the design was generally useful
#      beyond Rocket.  Downstream users:
#         * Rocket (24k stars web framework — uses figment internally)
#         * slatedb/slatedb (cloud-native storage, 3k stars)
#         * cnosdb/cnosdb (time series DB, 1.7k stars)
#         * LukeMathWalker/pavex (backend framework, 2k stars)
#         * UpliftGames/wally (THIS — Roblox package manager)
#         * metaplex-foundation/digital-asset-rpc-infrastructure
#           (Solana metaplex tooling)
#         * Dstack-TEE/dstack (confidential AI, 496 stars)
#         * cubist-labs/cubist (multichain SDK)
#         * ackwell/boilmaster (FFXIV data service)
#         * 900+ Rust applications using figment Provider
#      Sergio is at Massachusetts Institute of Technology (MIT) +
#      maintains Rocket since 2016.  FIRST documented Rust Axis 13
#      library with this specific Sergio-Benitez / Rocket-framework
#      / MIT-academic provenance.
#
# figment's relationship to config-rs (R629):
#
#   * Unlike config-rs (R629) — config-rs is builder pattern with
#                                 explicit file/env sources;
#                                 figment is Provider trait
#                                 abstraction with merge() semantics
#   * Closest analogs:
#         * Go knadh/koanf — modern alternative with similar
#                               Provider-like approach
#         * Go viper (R630) — different (global singleton)
#         * Node cosmiconfig (R631) — different (search discovery)
#         * Python dynaconf — similar layered approach with
#                              providers
#     figment is the SECOND documented Rust Axis 13 library
#     providing layered configuration via Provider trait
#     abstraction + profile-aware extraction + source-aware error
#     reporting + Rocket-framework-ecosystem provenance.
#
# -----------------------------------------------------------------------------
#
# THE wally CLI — structopt + figment + 9 subcommands
#
# wally's CLI is in src/main.rs + src/commands/mod.rs.  Uses
# structopt (clap derive's predecessor):
#
#     use structopt::StructOpt;
#
#     #[derive(Debug, StructOpt)]
#     #[structopt(about = env!("CARGO_PKG_DESCRIPTION"))]
#     pub struct Args {
#         #[structopt(flatten)]
#         pub global: GlobalOptions,
#         #[structopt(subcommand)]
#         pub subcommand: Subcommand,
#     }
#
#     #[derive(Debug, StructOpt)]
#     pub struct GlobalOptions {
#         #[structopt(global = true, parse(from_occurrences),
#                       long = "verbose", short)]
#         pub verbosity: u8,
#         ...
#     }
#
#     #[derive(Debug, StructOpt)]
#     pub enum Subcommand {
#         Init(InitSubcommand),
#         Install(InstallSubcommand),
#         Update(UpdateSubcommand),
#         Publish(PublishSubcommand),
#         Login(LoginSubcommand),
#         Logout(LogoutSubcommand),
#         Search(SearchSubcommand),
#         Package(PackageSubcommand),
#         ManifestToJson(ManifestToJsonSubcommand),
#     }
#
# Subcommands (9 total):
#   init               Initialize a new wally project
#   install            Install dependencies from wally.toml
#   update             Update locked dependencies to latest
#   publish            Publish package to registry
#   login              Authenticate with registry
#   logout             Clear registry authentication
#   search <query>     Search packages by name
#   package            Low-level package commands
#                       (download/extract sub-subcommands)
#   manifest-to-json   Convert wally.toml to JSON
#
# Global flag:
#   -v, --verbose      Increase verbosity (repeatable: 0/1/2/3+)
#
# figment is used in wally-registry-backend/src for loading the
# registry server configuration from TOML + environment vars,
# with profile-aware extraction for production/development modes.
#
# Five-axis distinctness from config-rs (R629):
#
#   1. PROVIDER TRAIT ABSTRACTION — Provider trait makes
#      configuration sources first-class composable types;
#      config-rs uses builder method calls.
#
#   2. PROFILE-AWARE EXTRACTION — built-in support for [global]/
#      [debug]/[release] profile sections via Figment::select;
#      config-rs requires manual environment-specific files.
#
#   3. SOURCE-AWARE ERROR REPORTING — extraction failures report
#      the exact Provider source + offending key path; config-rs
#      reports flat deserialize errors.
#
#   4. SERIALIZED PROVIDER — programmatic struct-based defaults
#      via Serialized::defaults(struct); config-rs requires
#      converting to file/string first.
#
#   5. SERGIO-BENITEZ / ROCKET-FRAMEWORK PROVENANCE — extracted
#      from Rocket web framework, used by every Rocket app
#      transitively.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/UpliftGames/wally/blob/master/src/commands/mod.rs
# structopt derive declarations.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _wally_cmds
_wally_cmds=(
    'init:initialize a new wally project (creates wally.toml)'
    'install:install dependencies from wally.toml'
    'update:update locked dependencies to latest matching versions'
    'publish:publish package to registry'
    'login:authenticate with registry (stores auth token)'
    'logout:clear registry authentication'
    'search:search packages by name'
    'package:low-level package commands (download/extract)'
    'manifest-to-json:convert wally.toml to JSON for tooling'
    'help:show help for a subcommand'
)

_arguments -C \
    '*'{-v,--verbose}'[increase verbosity (repeatable: 0/1/2/3+)]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'wally subcommand' _wally_cmds && ret=0
        ;;
    args)
        case $words[1] in
            init)
                _arguments \
                    '1:project directory:_directories' \
                    && ret=0
                ;;
            install|update)
                _arguments \
                    '*:package name:_default' \
                    && ret=0
                ;;
            publish)
                _arguments \
                    '--project-path=[path to wally project]:dir:_directories' \
                    && ret=0
                ;;
            search)
                _arguments \
                    '1:search query:_default' \
                    && ret=0
                ;;
            login)
                _arguments \
                    '--token=[auth token]:token:_default' \
                    && ret=0
                ;;
            package)
                _values 'package subcommand' \
                    'download[download a package without installing]' \
                    'extract[extract a downloaded package archive]' \
                    && ret=0
                ;;
            manifest-to-json)
                _arguments \
                    '--project-path=[path to wally project]:dir:_directories' \
                    && ret=0
                ;;
            help)
                _describe -t commands 'subcommand' _wally_cmds && ret=0
                ;;
        esac
        ;;
esac

return ret
