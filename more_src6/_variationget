#compdef variationget
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/variationget.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# EMBOSS variationget: read and write variation data entries
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[report command line options and exit]' \
  '-auto[turn off prompts]' \
  '-stdout[write first file to standard output]' \
  '-filter[read from stdin, write to stdout]' \
  '-options[prompt for standard and additional values]' \
  '-debug[write debug output to program.dbg]' \
  '-verbose[report command line options]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-die[report dying program messages]' \
  '-version[report version and exit]' \
  '-variation=[input variation entries (filename/format/USA)]:input:' \
  '-iformat1=[input variation format]:fmt:' \
  '-iquery1=[input query fields or ID list]:query:' \
  '-ioffset1=[input start position offset]:offset:' \
  '-idbname1=[user-provided database name]:dbname:' \
  '-outfile=[output file]:file:_files' \
  '-odirectory2=[output directory]:dir:_files -/' \
  '-oformat2=[variation output format]:fmt:' \
  '*:USA:' && ret=0

return ret
