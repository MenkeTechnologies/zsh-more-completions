#compdef wyoming-piper
# Documentation: https://github.com/rhasspy/wyoming-piper/blob/master/wyoming_piper/__main__.py
# Reference accessed: 2026-05-27
# Verified: upstream argparse definitions in wyoming_piper/__main__.py (rhasspy/wyoming-piper).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--voice=[default Piper voice (e.g. en_US-lessac-medium)]:voice:' \
  '--uri=[server URI: stdio://, unix://, or tcp://]:uri:' \
  '--zeroconf=[enable zeroconf discovery with optional name]:name:' \
  '--piper=[path to piper binary or wrapper]:file:_files' \
  '--data-dir=[data directory containing downloaded voices]:dir:_files -/' \
  '--download-dir=[directory to download voices into]:dir:_files -/' \
  '--speaker=[speaker name or id for default voice]:speaker:' \
  '--noise-scale=[generator noise]:float:' \
  '--length-scale=[phoneme length scale]:float:' \
  '--noise-w-scale=[phoneme width noise]:float:' \
  '--noise-w=[phoneme width noise (alias of --noise-w-scale)]:float:' \
  '--auto-punctuation=[punctuation characters to auto-append]:chars:' \
  '--samples-per-chunk=[audio samples per chunk]:n:' \
  '--no-streaming[disable audio streaming on sentence boundaries]' \
  '--update-voices[download latest voices.json on startup]' \
  '--use-cuda[use CUDA if available (requires onnxruntime-gpu)]' \
  '--debug[log DEBUG messages]' \
  '--log-format=[python logging format string]:format:' \
  '--version[print version and exit]' && ret=0

return ret
