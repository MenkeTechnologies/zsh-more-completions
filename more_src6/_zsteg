#compdef zsteg
# Documentation: https://github.com/zed-0xff/zsteg
# Reference accessed: 2026-05-21
# Verified: upstream README options list at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-a --all)'{-a,--all}'[try all known methods]' \
  '(-E --extract)'{-E,--extract}'=[extract specified payload (e.g. 1b,rgb,lsb)]:name:' \
  '(-o --order)'{-o,--order}'=[pixel iteration order]:order:' \
  '(-c --channels)'{-c,--channels}'=[channels to scan]:channels:' \
  '(-b --bits)'{-b,--bits}'=[number of bits (value, list, or range)]:bits:' \
  '--lsb[least significant BIT comes first]' \
  '--msb[most significant BIT comes first]' \
  '(-P --prime)'{-P,--prime}'[analyze only prime bytes/pixels]' \
  '--shift=[prepend N zero bits]:n:' \
  '--step=[step value]:n:' \
  '--invert[XOR bits with 0xff]' \
  '--pixel-align[align hidden data to pixels]' \
  '(-l --limit)'{-l,--limit}'=[limit bytes to check (0=unlimited)]:n:' \
  '--file[enable file type detection]' \
  '--no-file[disable file type detection]' \
  '--no-strings[disable ASCII string search]' \
  '(-s --strings)'{-s,--strings}'=[string detection mode]:mode:(first all longest none)' \
  '(-n --min-str-len)'{-n,--min-str-len}'=[minimum string length]:n:' \
  '*'{-v,--verbose}'[verbose (repeatable)]' \
  '*'{-q,--quiet}'[suppress warnings (repeatable)]' \
  '(-C --color --no-color)'{-C,--color}'[force color output]' \
  '(-C --color)--no-color[disable color output]' \
  '*:PNG/BMP file:_files -g "*.(png|bmp|PNG|BMP)"' && ret=0

return ret
