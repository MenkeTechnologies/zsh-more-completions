#compdef virt-tar-in
# _virt-tar-in — libguestfs virt-tar-in (extract a tar archive into a libvirt VM image at the given in-guest directory; -a disk, -d domain, -c libvirt URI, -m mount spec, --format disk format; positional source tar followed by in-guest destination directory)
# upstream: https://github.com/libguestfs/libguestfs (cat)
# Flags from libguestfs cat/cat.ml (tar variants) on tip.

_virt-tar-in() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '*-a+[disk image]:file:_files' \
        '*-d+[domain]:domain:' \
        '-c+[libvirt URI]:uri:' \
        '*-m+[mount spec]:mountspec:' \
        '--format=*[disk format]:fmt:(raw qcow2 vmdk vdi)' \
        '1:source tar:_files -g "*.(tar|tar.gz|tar.xz|tar.bz2|tar.zst|tgz)"' \
        '2:in-guest directory:'
}

_virt-tar-in "$@"
