#compdef weave-scope
# Documentation: https://github.com/weaveworks/scope
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Weave Scope: live topology/monitoring for containers
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'launch:launch Scope (probe + app)'
  'help:show help'
  'stop:stop a running Scope'
  'restart:restart Scope'
  'status:show status'
  'version:show version'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--service-token=[Weave Cloud service token]:token:' \
  '--probe-token=[probe-only token]:token:' \
  '--app-only[run only the app]' \
  '--probe-only[run only the probe]' \
  '--no-app[do not run app]' \
  '--no-probe[do not run probe]' \
  '--probe.docker=[enable docker reports]:bool:(true false)' \
  '--probe.kubernetes=[enable kubernetes reports]:bool:(true false)' \
  '--probe.processes=[enable process reports]:bool:(true false)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'weave-scope command' commands && ret=0 ;;
esac
return ret
