#compdef unionfs-fuse
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man8/unionfs-fuse.8.html
# Reference accessed: 2026-05-21
# Verified: upstream man page text.

# -o options use FUSE comma-separated form: -o cow,hide_meta_files,max_files=N
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-d[debug mode]' \
  '-f[foreground mode]' \
  '*-o+[mount options (cow, hide_meta_files, relaxed_permissions, statfs_omit_ro, chroot=PATH, debug_file=FILE, max_files=N, noinitgroups)]:options' \
  '1:branches (dir=RW\:dir=RO):_directories' \
  '2:mountpoint:_directories' && return 0
