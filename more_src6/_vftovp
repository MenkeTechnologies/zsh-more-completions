#compdef vftovp vptovf
# Documentation: vftovp --help / vptovf --help (TeX Live 2026)
# Source: TeX VF (virtual font) <-> VPL (virtual property list) translators.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-charcode-format=[character code output format]:type:(octal ascii)' \
    '(- *)-help[show help]' \
    '-verbose[display progress reports]' \
    '(- *)-version[show version]' \
    '1:VF or VPL file:_files -g "*.{vf,vpl}"' \
    '2:companion TFM file:_files -g "*.tfm"' \
    '3:output VPL or VF file:_files' \
    && ret=0

return ret
