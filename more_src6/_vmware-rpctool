#compdef vmware-rpctool
# _vmware-rpctool — VMware open-vm-tools vmware-rpctool (send a single RPC command to the host's VMX through the VMware backdoor; -h help, -V version; positional argument is the literal RPC string such as "info-get guestinfo.ip", "info-set guestinfo.foo bar", "log message" or "vmx.set_message")
# upstream: https://github.com/vmware/open-vm-tools
# Argument shape from vmware/open-vm-tools open-vm-tools/rpctool/rpctool.c on tip.

_vmware-rpctool() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '*:rpc command:'
}

_vmware-rpctool "$@"
