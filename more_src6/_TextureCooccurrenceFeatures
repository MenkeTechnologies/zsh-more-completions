local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:imageDimension:(2 3 4)' \
    '2:inputImage:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3::numberOfBins:_default' \
    '4::maskImage:_files -g "*.{nii,nii.gz}"' \
    '5::label (inside-mask pixel value, default 1):_default' \
    && ret=0

return ret
