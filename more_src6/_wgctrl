#compdef wgctrl
# _wgctrl — wgctrl CLI command-line frontend to the wgctrl-go Go-based WireGuard control library performing portable user-space ioctl-based device queries peer management add-remove configure listen-port endpoint private-key public-key without needing kernel headers root-ipsec stack-binding direct-API call (golang Wireguard team, Go); cobra
# upstream: https://github.com/WireGuard/wgctrl-go

_wgctrl() {
    local -a sub=(
        'show:show devices and peers'
        'set:set device parameters'
        'add-peer:add peer to device'
        'remove-peer:remove peer from device'
        'devices:list devices'
        'genkey:generate private key'
        'pubkey:derive public key'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--device=+[iface]:_net_interfaces' \
        '-d+[device]:_net_interfaces' \
        '--private-key=+[file]:file:_files' \
        '--public-key=+[key]:str:' \
        '--preshared-key=+[file]:file:_files' \
        '--listen-port=+[port]:n:' \
        '--fwmark=+[mark]:str:' \
        '--endpoint=+[host:port]:str:' \
        '--allowed-ips=+[cidrs]:str:' \
        '--persistent-keepalive=+[sec]:n:' \
        '--replace-peers[replace peer list]' \
        '-o+[output]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wgctrl subcommand' sub ;;
        args)
            case $words[1] in
                show|set|add-peer|remove-peer) _arguments '*:device:_net_interfaces' ;;
            esac
            ;;
    esac
}

_wgctrl "$@"
