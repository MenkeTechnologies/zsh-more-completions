#compdef vega-lite vl2svg vl2png vl2pdf vl2vg
# _vega-lite — UW Interactive Data Lab vega-lite CLI tools vl2svg vl2png vl2pdf vl2vg compiling Vega-Lite specs to Vega specs and rasterized chart outputs (vega team, JavaScript); commander.js
# upstream: https://github.com/vega/vega-lite

_vega-lite() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-b+[base URL]:str:' \
        '--base=+[base URL]:str:' \
        '-c+[config json]:file:_files -g "*.json"' \
        '--config=+[config json]:file:_files -g "*.json"' \
        '-f+[loader format]:f:(svg png pdf vega)' \
        '--format=+[loader format]:f:(svg png pdf vega)' \
        '-l+[loglevel]:l:(none error warn info debug)' \
        '--loglevel=+[loglevel]:l:(none error warn info debug)' \
        '-s+[svg scale]:f:' \
        '--scale=+[svg scale]:f:' \
        '-t+[theme]:t:(excel ggplot2 quartz vox dark fivethirtyeight latimes urbaninstitute googlecharts powerbi)' \
        '--theme=+[theme]:t:(excel ggplot2 quartz vox dark fivethirtyeight latimes urbaninstitute googlecharts powerbi)' \
        '-r+[renderer]:r:(svg canvas hybrid)' \
        '--renderer=+[renderer]:r:(svg canvas hybrid)' \
        '-d+[dpi]:n:' \
        '--dpi=+[dpi]:n:' \
        '-bg+[background]:c:(white transparent)' \
        '--background=+[background]:c:(white transparent)' \
        '-w+[width]:n:' \
        '--width=+[width]:n:' \
        '-H+[height]:n:' \
        '--height=+[height]:n:' \
        '--header[print header]' \
        '--seed=+[N]:n:' \
        '*:vega-lite json:_files -g "*.vl.json *.json"'
}

_vega-lite "$@"
