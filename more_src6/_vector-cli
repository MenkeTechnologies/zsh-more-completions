#compdef vector-cli vector
# Documentation: https://vector.dev/docs/reference/cli/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Vector: high-perf observability data pipeline
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'validate:verify configuration integrity'
  'generate:create configuration from component pipeline'
  'graph:visualize topology in DOT format'
  'list:enumerate available components'
  'top:display real-time topology metrics'
  'tap:monitor events in components'
  'test:execute configuration unit tests'
  'vrl:execute Vector Remap Language programs'
  'help:display command documentation'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*'{-c,--config=}'[config file]:file:_files -g "*.(toml|yaml|yml|json)"' \
  '--config-toml=[TOML config file]:file:_files -g "*.toml"' \
  '--config-yaml=[YAML config file]:file:_files -g "*.(yaml|yml)"' \
  '--config-json=[JSON config file]:file:_files -g "*.json"' \
  '--config-dir=[read configs from directory]:dir:_files -/' \
  '--allow-empty-config[allow configuration without components]' \
  '(-w --watch-config)'{-w,--watch-config}'[reload on configuration file changes]' \
  '--watch-config-method=[config watching strategy]:method:(recommend poll)' \
  '--watch-config-poll-interval-seconds=[poll interval seconds]:n:' \
  '*'{-v,--verbose}'[enable detailed logging]' \
  '*'{-q,--quiet}'[reduce logging detail]' \
  '--no-graceful-shutdown-limit[never timeout during graceful shutdown]' \
  '--graceful-shutdown-limit-secs=[shutdown timeout duration]:s:' \
  '--color=[ANSI terminal formatting]:val:(auto always never)' \
  '--log-format=[logging format]:fmt:(json text)' \
  '--openssl-no-probe[disable OpenSSL root certificate probing]' \
  '(-r --require-healthy)'{-r,--require-healthy}'[exit if sinks fail health checks]' \
  '(-t --threads)'{-t,--threads=}'[processing thread count]:n:' \
  '(-i --internal-log-rate-limit)'{-i,--internal-log-rate-limit=}'[identical log emission limit]:n:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'vector command' commands && ret=0 ;;
esac
return ret
