#compdef xdo
# Documentation: https://github.com/baskerville/xdo

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'activate:activate window (set _NET_ACTIVE_WINDOW)'
  'close:request window close'
  'hide:unmap window'
  'show:map window'
  'raise:raise window'
  'lower:lower window'
  'below:put window below target'
  'above:put window above target'
  'move:move window'
  'resize:resize window'
  'id:print window ID'
  'pid:print PID owning window'
  'key_press:simulate key press'
  'key_release:simulate key release'
  'button_press:simulate button press'
  'button_release:simulate button release'
  'pointer_motion:move pointer'
)

_arguments -s -S \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'xdo command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (activate|close|hide|show|raise|lower)
        _arguments -s -S \
          '-r[target the closest ascendant with a client redirect]' \
          '-n+[target windows with given name]:name:' \
          '-N+[target windows with given class name]:class:' \
          '-d+[target windows on given desktop]:desktop:' \
          '-p+[target windows with given PID]:pid:_pids' \
          '*:window id:' && ret=0
        ;;
      (below|above)
        _arguments -s -S \
          '-r[target the closest ascendant with a client redirect]' \
          '-n+[target windows with given name]:name:' \
          '-N+[target windows with given class name]:class:' \
          '-d+[target windows on given desktop]:desktop:' \
          '-p+[target windows with given PID]:pid:_pids' \
          '*:window id:' && ret=0
        ;;
      (move)
        _arguments -s -S \
          '-r[target the closest ascendant with a client redirect]' \
          '-n+[target windows with given name]:name:' \
          '-N+[target windows with given class name]:class:' \
          '-d+[target windows on given desktop]:desktop:' \
          '-p+[target windows with given PID]:pid:_pids' \
          '-x+[x coordinate]:x:' \
          '-y+[y coordinate]:y:' \
          '*:window id:' && ret=0
        ;;
      (resize)
        _arguments -s -S \
          '-r[target the closest ascendant with a client redirect]' \
          '-n+[target windows with given name]:name:' \
          '-N+[target windows with given class name]:class:' \
          '-d+[target windows on given desktop]:desktop:' \
          '-p+[target windows with given PID]:pid:_pids' \
          '-w+[width]:width:' \
          '-h+[height]:height:' \
          '*:window id:' && ret=0
        ;;
      (id)
        _arguments -s -S \
          '-r[target the closest ascendant with a client redirect]' \
          '-n+[target windows with given name]:name:' \
          '-N+[target windows with given class name]:class:' \
          '-d+[target windows on given desktop]:desktop:' \
          '-p+[target windows with given PID]:pid:_pids' \
          '*:window id:' && ret=0
        ;;
      (pid)
        _arguments -s -S \
          '-r[target the closest ascendant with a client redirect]' \
          '-n+[target windows with given name]:name:' \
          '-N+[target windows with given class name]:class:' \
          '-d+[target windows on given desktop]:desktop:' \
          '*:window id:' && ret=0
        ;;
      (key_press|key_release)
        _arguments -s -S \
          '-n+[target windows with given name]:name:' \
          '-N+[target windows with given class name]:class:' \
          '-d+[target windows on given desktop]:desktop:' \
          '-p+[target windows with given PID]:pid:_pids' \
          '-k+[key code]:keycode:' \
          '*:window id:' && ret=0
        ;;
      (button_press|button_release)
        _arguments -s -S \
          '-n+[target windows with given name]:name:' \
          '-N+[target windows with given class name]:class:' \
          '-d+[target windows on given desktop]:desktop:' \
          '-p+[target windows with given PID]:pid:_pids' \
          '-k+[button code]:button:' \
          '*:window id:' && ret=0
        ;;
      (pointer_motion)
        _arguments -s -S \
          '-n+[target windows with given name]:name:' \
          '-N+[target windows with given class name]:class:' \
          '-d+[target windows on given desktop]:desktop:' \
          '-p+[target windows with given PID]:pid:_pids' \
          '-x+[x coordinate]:x:' \
          '-y+[y coordinate]:y:' \
          '*:window id:' && ret=0
        ;;
    esac
    ;;
esac

return ret
