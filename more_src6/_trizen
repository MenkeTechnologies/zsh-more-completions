#compdef trizen
# Documentation: https://raw.githubusercontent.com/trizen/trizen/master/trizen.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed prior fabricated --makepkg-conf, --pacman-conf, --repo flags
# (not documented in trizen(1)).

# Zsh completion for trizen - lightweight AUR helper

_arguments -s -S \
  '(-S --sync)'{-S,--sync}'[install packages from repos or AUR]' \
  '(-Q --query)'{-Q,--query}'[query the package database]' \
  '(-R --remove)'{-R,--remove}'[remove packages]' \
  '(-U --upgrade)'{-U,--upgrade}'[install built packages]' \
  '(-D --database)'{-D,--database}'[operate on package database]' \
  '(-F --files)'{-F,--files}'[query files database]' \
  '(-G --get)'{-G,--get}'[clone an AUR package]' \
  '(-s --search)'{-s,--search}'[search package names]' \
  '(-u --sysupgrade)'{-u,--sysupgrade}'[upgrade installed packages]' \
  '(-y --refresh)'{-y,--refresh}'[refresh package databases]' \
  '(-c --clean)'{-c,--clean}'[clean cache directories]' \
  '(-i --info)'{-i,--info}'[view package information]' \
  '(-q --quiet)'{-q,--quiet}'[minimal output]' \
  '(-a --aur)'{-a,--aur}'[AUR operations only]' \
  '(-r --regular)'{-r,--regular}'[pacman/regular operations only]' \
  '--noconfirm[do not ask for confirmation]' \
  '--needed[do not reinstall up-to-date packages]' \
  '--noedit[do not edit PKGBUILDs]' \
  '--devel[check VCS (-git, -hg, -svn...) packages for updates]' \
  '--show-ood[display out-of-date flagged packages]' \
  '--clone-dir=[clone/build directory]:directory:_files -/' \
  '--ignore=[packages to skip during updates]:packages:' \
  '--debug[verbose/debug mode]' \
  '--nocolors[disable ANSI colors]' \
  '*:package'
