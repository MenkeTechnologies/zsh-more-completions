#compdef vlagent
# _vlagent — VictoriaLogs ingestion agent (receives logs from clients and forwards/buffers them to VictoriaLogs storage)
# upstream: https://github.com/VictoriaMetrics/VictoriaLogs
# Flags from app/vlagent/main.go on tip + shared lib (httpserver, logger, envflag); all flags also bindable via VL_<flag> env.

_vlagent() {
    _arguments \
        '(- *)'{-h,-help,--help}'[show help]' \
        '-tmpDataPath=[base directory for buffered ingestion data]:dir:_files -/' \
        '-remoteWrite.url=[remote VictoriaLogs URL to forward to (repeatable via comma)]:url:_urls' \
        '*-remoteWrite.headers=[headers to send to -remoteWrite.url (Header:Value)]:hdr:' \
        '-httpListenAddr=[HTTP listen address]:addr:' \
        '-tls[enable TLS for HTTP listener]' \
        '-tlsCertFile=[TLS cert file]:file:_files' \
        '-tlsKeyFile=[TLS key file]:file:_files' \
        '-loggerLevel=[log level]:level:(INFO WARN ERROR FATAL)' \
        '-loggerFormat=[log format]:fmt:(default json)' \
        '-loggerOutput=[log output destination]:dest:(stderr stdout)' \
        '-memory.allowedPercent=[percentage of RAM available for caches]:n:' \
        '-memory.allowedBytes=[max bytes available for caches]:size:' \
        '-version[show version and exit]'
}

_vlagent "$@"
