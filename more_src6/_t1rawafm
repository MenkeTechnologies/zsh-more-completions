#compdef t1rawafm
# Documentation: t1rawafm --help (lcdf-typetools)
# Source: lcdf-typetools t1rawafm — generate a raw AFM (kernless + ligatureless).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-o --output)'{-o,--output=}'[output file]:file:_files' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1:Type 1 font (PFA / PFB):_files -g "*.{pfa,pfb}"' \
    '2:output AFM file:_files' \
    && ret=0

return ret
