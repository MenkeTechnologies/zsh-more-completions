#compdef termsvg
# Documentation: https://github.com/MrMarble/termsvg
# Reference accessed: 2026-05-21
# Verified: upstream README — subcommands are rec, play, export
# (not record/auth as previous file claimed).
# rec:    -c/--command
# play:   -i/--idle-time-limit, -s/--speed
# export: -o/--output, -m/--minify

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a cmds=(
      'rec:record a terminal session to an asciicast file'
      'play:replay a recorded asciicast'
      'export:convert a recorded asciicast to an SVG file'
    )
    _describe -t commands 'termsvg command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      rec)
        _arguments -s -S \
          '(-c --command)'{-c+,--command=}'[command to record (default $SHELL)]:command:_command_names' \
          '*:asciicast file:_files' && ret=0
        ;;
      play)
        _arguments -s -S \
          '(-i --idle-time-limit)'{-i+,--idle-time-limit=}'[limit inactivity duration (seconds)]:seconds' \
          '(-s --speed)'{-s+,--speed=}'[playback speed factor]:factor' \
          '*:asciicast file:_files' && ret=0
        ;;
      export)
        _arguments -s -S \
          '(-o --output)'{-o+,--output=}'[output SVG filename]:file:_files' \
          '(-m --minify)'{-m,--minify}'[minify SVG output]' \
          '*:asciicast file:_files' && ret=0
        ;;
      *) _files && ret=0 ;;
    esac
    ;;
esac

return ret
