#compdef virt-rescue-cli
# _virt-rescue-cli — libguestfs virt-rescue rescue shell for VM image CLI alias (libguestfs team, C); custom argparse
# upstream: https://github.com/libguestfs/libguestfs

_virt-rescue-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--add=+[disk]:file:_files' \
        '-a+[disk]:file:_files' \
        '--append=+[kernel cmdline]:str:' \
        '--connect=+[libvirt URI]:str:' \
        '-c+[libvirt URI]:str:' \
        '--domain=+[VM domain]:str:' \
        '-d+[VM domain]:str:' \
        '--format=+[image format]:f:(raw qcow2 vmdk)' \
        '--memsize=+[mb]:n:' \
        '-m+[mb]:n:' \
        '--network[guest network]' \
        '--no-network[no network]' \
        '--read-only[read only]' \
        '--ro[read only]' \
        '--rw[read write]' \
        '--scratch=+[temp disks]:n:' \
        '--selinux[enable selinux]' \
        '--smp=+[smp]:n:' \
        '--suggest[suggest mount commands]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '*:disk image:_files -g "*.{qcow2,img,raw,vmdk}"'
}

_virt-rescue-cli "$@"
