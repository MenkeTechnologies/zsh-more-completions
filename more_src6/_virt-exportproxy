#compdef virt-exportproxy
# _virt-exportproxy — KubeVirt VirtualMachineExport TLS proxy that fronts virt-exportserver pods
# upstream: https://github.com/kubevirt/kubevirt
# Flags from cmd/virt-exportproxy/virt-exportproxy.go on tip.

_virt-exportproxy() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--tls-cert-file=[TLS certificate file]:file:_files' \
        '--tls-key-file=[TLS private key file]:file:_files' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--alsologtostderr[log to stderr and files]' \
        '--stderrthreshold=[stderr threshold level]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:' \
        '--log-file=[log file destination]:file:_files'
}

_virt-exportproxy "$@"
