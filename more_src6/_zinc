#compdef zinc zinc-cli
# _zinc — Lightbend Zinc Scala incremental compiler CLI alias (Lightbend / sbt team, Scala); custom argparse
# upstream: https://github.com/sbt/zinc

_zinc() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-S+[scala flags]:str:' \
        '-C+[java flags]:str:' \
        '-J+[jvm flags]:str:' \
        '-debug[debug log level]' \
        '-verbose[verbose log level]' \
        '-warn[warn log level]' \
        '-error[error log level]' \
        '-cp+[classpath]:list:_files' \
        '-classpath+[classpath]:list:_files' \
        '-d+[output dir]:dir:_files -/' \
        '-output+[output dir]:dir:_files -/' \
        '-sources+[source files list]:list:_files' \
        '-as-jar[output as jar]' \
        '-scala-home+[scala home]:dir:_files -/' \
        '-scala-version+[scala version]:str:' \
        '-scala-jars+[scala jars]:list:_files' \
        '-scala-compiler+[scala compiler jar]:file:_files' \
        '-scala-extra+[scala extra jars]:list:_files' \
        '-scala-library+[scala library jar]:file:_files' \
        '-scala-reflect+[scala reflect jar]:file:_files' \
        '-incremental[incremental]' \
        '-no-incremental[no incremental]' \
        '-pickle-cache+[pickle cache dir]:dir:_files -/' \
        '-rebase-source+[rebase source]:str:' \
        '-target+[target]:str:' \
        '-encoding+[encoding]:str:' \
        '-deprecation[deprecation]' \
        '-feature[feature]' \
        '-unchecked[unchecked]' \
        '-optimise[optimise]' \
        '-cache-map+[cache map]:str:' \
        '-cache-dir+[cache dir]:dir:_files -/' \
        '-analysis+[analysis store]:file:_files' \
        '-analysis-cache+[analysis cache]:file:_files' \
        '-zinc-version[show zinc version]' \
        '*:source-file:_files -g "*.scala *.java"'
}

_zinc "$@"
