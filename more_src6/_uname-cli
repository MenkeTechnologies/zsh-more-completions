#compdef uname-cli
# _uname-cli — GNU coreutils uname print system information CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_uname-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[print all]' \
        '--all[print all]' \
        '-s[kernel name]' \
        '--kernel-name[kernel name]' \
        '-n[network node hostname]' \
        '--nodename[network node hostname]' \
        '-r[kernel release]' \
        '--kernel-release[kernel release]' \
        '-v[kernel version]' \
        '--kernel-version[kernel version]' \
        '-m[machine hardware name]' \
        '--machine[machine hardware name]' \
        '-p[processor type]' \
        '--processor[processor type]' \
        '-i[hardware platform]' \
        '--hardware-platform[hardware platform]' \
        '-o[operating system]' \
        '--operating-system[operating system]' \
        '*:arg:'
}

_uname-cli "$@"
