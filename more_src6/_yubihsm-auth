#compdef yubihsm-auth
# _yubihsm-auth — Yubico yubihsm-auth CLI managing YubiKey-stored YubiHSM authentication credentials over CCID smartcard interface listing creating deleting touch-required credentials calculating session keys without exporting long-term keys (Yubico team, C); custom argparse
# upstream: https://developers.yubico.com/yubihsm-shell/

_yubihsm-auth() {
    local -a sub=(
        'list:list stored credentials'
        'put:create new credential'
        'delete:delete a credential'
        'reset:reset YubiHSM-Auth application'
        'calculate:derive session keys'
        'version:print version'
        'getmgmtkey:get management key'
        'putmgmtkey:set management key'
        'getversion:get YubiHSM-Auth version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-r+[reader name]:str:' \
        '--reader=+[reader]:str:' \
        '-l+[label]:str:' \
        '--label=+[label]:str:' \
        '-p+[mgmt key hex]:str:' \
        '--mgmkey=+[mgmt key]:str:' \
        '-t[touch required]' \
        '--touch[touch required]' \
        '-k+[derivation password]:str:' \
        '--derivation-password=+[password]:str:' \
        '-C+[context hex]:str:' \
        '--context=+[context]:str:' \
        '-c+[card creds]:str:' \
        '--credpwd=+[creds password]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'yubihsm-auth subcommand' sub ;;
    esac
}

_yubihsm-auth "$@"
