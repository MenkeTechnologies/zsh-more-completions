#compdef wmake
# Documentation: https://github.com/OpenFOAM/OpenFOAM-6/blob/master/wmake/wmake
# Reference accessed: 2026-05-21
# Verified: usage() in upstream wmake source lists only the options below.

# OpenFOAM wmake: OpenFOAM build/wrap tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-s --silent)'{-s,-silent}'[quiet mode, do not echo commands]' \
  '(-a --all)'{-a,-all}'[wmake all sub-directories, running Allwmake if present]' \
  '(-q --queue)'{-q,-queue}'[wmakeCollect all sub-directories, running Allwmake if present]' \
  '(-k --non-stop)'{-k,-non-stop}'[compile without stopping on errors]' \
  '-j[compile using all local cores/hyperthreads]' \
  '-j-[compile using N cores/hyperthreads]:N' \
  '-no-scheduler[compile without wmakeScheduler]' \
  '-update[update lnInclude dirs, dep files, remove deprecated files]' \
  '(- *)'{-h,-help}'[print usage]' \
  '1:target type:(all queue exe lib libo libso dep objects)' \
  '*::directory:_files -/' && ret=0
return ret
