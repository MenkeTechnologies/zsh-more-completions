#compdef vgrep
# Documentation: https://github.com/vrothberg/vgrep
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_vgrep() {
    _arguments \
        '(-h --help)'{-h,--help}'[print help]' \
        '(-v --version)'{-v,--version}'[print version]' \
        '(-s --show)'{-s,--show}'=[open indexed file locations in editor]:command' \
        '(-i --interactive)'{-i,--interactive}'[enter interactive shell mode]' \
        '(-n --no-header)'{-n,--no-header}'[do not print header]' \
        '(-N --no-less)'{-N,--no-less}'[do not use less as pager]' \
        '--no-git[do not use git grep]' \
        '--no-ripgrep[do not use ripgrep]' \
        '(-j --json)'{-j,--json}'[output as JSON]' \
        '*:pattern-or-file:_files'
}

_vgrep "$@"
