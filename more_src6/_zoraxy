_zoraxy() {
    _arguments -s -S \
        '-port[management interface listening port (default :8000)]:port:' \
        '-db[database backend]:backend:(leveldb boltdb auto)' \
        '-noauth[disable authentication for management interface (DANGEROUS)]' \
        '-version[show version + exit]' \
        '-sshlb[allow loopback web-SSH connection (DANGER)]' \
        '-mdns[enable mDNS scanner + transponder (default true)]' \
        '-mdnsname[mDNS name (default zoraxy_{node-uuid}.local)]:name:' \
        '-docker[run in Docker compatibility mode]' \
        '-fastgeoip[high-speed GeoIP lookup (requires 1GB RAM)]' \
        '-cfgupgrade[auto-config upgrade on breaking change (default true)]' \
        '-autorenew[ACME renew check interval in seconds (default 86400)]:sec:' \
        '-earlyrenew[early-renew days before expiry (default 30)]:days:' \
        '-acmetestmode[ACME staging/test mode]' \
        '-acmekeymode[ACME private-key file mode (default 0600)]:octal:' \
        '-acmepublicmode[ACME cert file mode (default 0644)]:octal:' \
        '-enablelog[enable system-wide logging (default true)]' \
        '-default_inbound_port[default web-server port (default 443)]:port:' \
        '-default_inbound_enabled[enable web server by default]' \
        '-readheadertimeout[proxy read-header timeout in seconds (default 30)]:sec:' \
        '-writetimeout[proxy write timeout in seconds (default 0)]:sec:' \
        '-idletimeout[proxy idle keep-alive timeout in seconds (default 300)]:sec:' \
        '-dbpath[database path (default ./sys.db)]:path:_files' \
        '-conf[configuration folder (default ./conf)]:dir:_files -/' \
        '-tmp[temporary folder (default ./tmp)]:dir:_files -/' \
        '-uuid[sys.uuid file path (default ./sys.uuid)]:path:_files' \
        '-log[log folder (default ./log)]:dir:_files -/' \
        '-webroot[static web-server root (default ./www)]:dir:_files -/' \
        '-plugin[plugin folder (default ./plugins)]:dir:_files -/' \
        '-update_geoip[download latest GeoIP + exit]' \
        '-dev[development build (external web folder + verbose)]' \
        '-reset_ac[reset admin account to default + exit]' \
        '-h[show help]' \
        '-help[show help]'
}

_zoraxy "$@"
