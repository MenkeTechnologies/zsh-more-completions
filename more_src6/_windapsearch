#compdef windapsearch
# Documentation: https://github.com/ropnop/go-windapsearch
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version info]' \
  '(-d --domain)'{-d,--domain}'=[domain FQDN]:domain:' \
  '--dc=[domain controller to query]:dc:' \
  '(-u --username)'{-u,--username}'=[full username with domain to bind with]:user:' \
  '--bindDN=[full DN to use to bind]:dn:' \
  '(-p --password)'{-p,--password}'=[password to use]:pw:' \
  '--hash=[NTLM hash to use instead of password]:hash:' \
  '--ntlm[use NTLM auth]' \
  '--port=[port to connect to]:port:' \
  '--secure[use LDAPS]' \
  '--proxy=[SOCKS5 proxy to use]:proxy:' \
  '--full[output all attributes from LDAP]' \
  '--ignore-display-filters[ignore display filters set by module]' \
  '(-o --output)'{-o,--output}'=[save results to file]:file:_files' \
  '(-j --json)'{-j,--json}'[convert LDAP output to JSON]' \
  '--page-size=[LDAP page size to use]:size:' \
  '(-v --verbose)'{-v,--verbose}'[show info logs]' \
  '--debug[show debug logs]' \
  '(-m --module)'{-m,--module}'=[module to use]:module:(users groups computers domain-admins privileged-users user-spns unconstrained-users unconstrained-computers gpos members search lookup custom)' \
  '--attrs=[comma separated custom attributes to display]:attrs:' \
  '--filter=[extra LDAP syntax filter to use]:filter:' \
  '(-s --search)'{-s,--search}'=[search term to filter on]:term:' && ret=0

return ret
