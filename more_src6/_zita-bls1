#compdef zita-bls1
# _zita-bls1 — binaural to stereo loudspeaker converter (Fons Adriaensen)
# upstream: https://kokkinizita.linuxaudio.org/linuxaudio/index.html
# Flags from zita-bls1(1) man page.

_zita-bls1() {
    _arguments \
        '(- *)-h[show help]' \
        '-s[JACK server name]:server:' \
        '-g[window geometry / position]:geometry:'
}

_zita-bls1 "$@"
