#compdef wev
# Documentation: https://manpages.debian.org/testing/wev/wev.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# wev: Wayland event viewer (tool for debugging events on a Wayland window)
local curcontext="$curcontext" ret=1
_arguments -s -S \
  '-g[print globals]' \
  '*-f+[show only events for given interface[:event]]:interface[:event]:' \
  '*-F+[show all events except for given interface[:event]]:interface[:event]:' \
  '-M+[write wl_keyboard keymap to path]:path:_files' && ret=0
return ret
