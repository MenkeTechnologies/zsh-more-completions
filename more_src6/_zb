#compdef zb
# _zb — zot registry performance benchmark / stress tool (project-zot/zot)
# upstream: https://github.com/project-zot/zot
# Flags from cmd/zb/main.go (cobra).

_zb() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version and exit]' \
        '(-A --auth-creds)'{-A+,--auth-creds=}'[basic auth credentials user:pass]:creds:' \
        '(-i --src-ips)'{-i+,--src-ips=}'[comma-separated source IPs]:ips:' \
        '(-s --src-cidr)'{-s+,--src-cidr=}'[CIDR to pick source IPs from]:cidr:' \
        '(-d --working-dir)'{-d+,--working-dir=}'[working directory]:dir:_files -/' \
        '(-r --repo)'{-r+,--repo=}'[target repository]:repo:' \
        '(-c --concurrency)'{-c+,--concurrency=}'[concurrent requests]:n:' \
        '(-n --requests)'{-n+,--requests=}'[total requests]:n:' \
        '(-o --output-format)'{-o+,--output-format=}'[output format]:fmt:(stdout ci-cd)' \
        '--skip-cleanup[do not clean up after the run]' \
        '(-t --test-regex)'{-t+,--test-regex=}'[regex selecting test scenarios]:regex:' \
        '(-l --list-tests)'{-l,--list-tests}'[list available tests and exit]' \
        '(-u --upstream-server-url)'{-u+,--upstream-server-url=}'[upstream registry URL for sync tests]:url:' \
        '1:registry URL:'
}

_zb "$@"
