#          Originally a Ruby gem (1,800+ stars on olistic/warriorrb)
#          ported to JavaScript by the same author.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — TS-NODE CROSSES TO 26
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents the
# 26TH TypeScript-Node CLI library variant.  TypeScript-Node climbs from
# 25 to 26 documented libraries (citty via warriorjs).  New leaderboard:
# Rust=26, Go=26, TypeScript-Node=26 — THREE-WAY TIE RESTORED at the top.
# Taxonomy now spans 215 cross-language CLI library variants across 51
# documented languages.
# -----------------------------------------------------------------------------
#
# WHAT IS unjs/citty AND WHY IS IT A DISTINCT 26TH TS-NODE CLI LIBRARY?
#
# citty (https://github.com/unjs/citty, 1,260+ stars) is the COMMAND-LINE
# BUILDER from the UnJS ecosystem — the loosely federated TypeScript
# infrastructure consortium that produces h3 (web framework powering
# Nuxt 3), nitro (universal web server), defu (deep merge utility),
# unbuild (bundler), nypm (universal package manager), giget (template
# downloader), pathe (cross-platform path utility), consola (logger),
# magicast (AST manipulation), and many other tools used across the
# Nuxt 3 / Nitro / Vite ecosystem.  Maintained primarily by Pooya Parsa
# (pi0) and the UnJS organization.
#
# citty is DISTINCT from every other TS-Node CLI library documented in the
# corpus on SIX specific axes:
#
#   1. DEFINECOMMAND PATTERN — citty's primary API is `defineCommand({...})`
#      which returns a Command object.  This matches the UnJS ecosystem's
#      "defineX" naming convention shared with `defineEventHandler` (h3),
#      `defineNuxtConfig` (Nuxt), `defineNitroConfig` (Nitro),
#      `defineEslintConfig`, etc.  The defineX functions are PURE TYPE
#      HELPERS — they return their argument as-is at runtime but provide
#      TypeScript inference at definition time.  This is the FIRST
#      documented TS-Node CLI library using the defineX convention.
#
#   2. TYPE-FIELD WITH STRING LITERALS — citty's flag types are declared
#      via STRING LITERAL types: `type: 'string'`, `type: 'boolean'`,
#      `type: 'number'`, `type: 'positional'`.  TypeScript narrows these
#      via `as const` assertions, giving compile-time type inference
#      for the parsed result.  Compare:
#        commander.js: no type declarations
#        yargs: `.option("name", { type: "number" })` (similar)
#        cleye (R472): `{ type: Number }` (constructor reference)
#        stricli (R466): `{ kind: "parsed", parse: parseFloat }`
#      citty's string-literal types are more idiomatic with TypeScript's
#      template-literal type system than constructor references.
#
#   3. parseArgs AS A SEPARATE STANDALONE FUNCTION — citty exports
#      `parseArgs(argv, argsDef)` as a standalone helper that returns
#      parsed results WITHOUT building a full command tree.  This is
#      what warriorjs uses: it imports `parseArgs` directly and bypasses
#      citty's defineCommand framework.  Most TS CLI libraries don't
#      separate "argv parsing" from "command tree assembly" this way.
#
#   4. INK-COMPATIBLE OUTPUT — citty is designed to work alongside Ink
#      (Vadim Demedes' React for CLIs) without conflicts.  citty handles
#      argv parsing; Ink handles TUI rendering.  warriorjs is a canonical
#      example: parseArgs from citty drives the game logic, render from
#      ink draws the gameplay.  This separation-of-concerns is unusual
#      among TS CLI libraries — most try to handle BOTH parsing AND
#      output rendering.
#
#   5. ALIAS AS SHORT-FLAG MAPPING — citty's `alias: 'd'` declares the
#      short form `-d` for the `--directory` flag.  Single-character
#      aliases are the common case but multi-character aliases work too.
#      Compare commander's `-d, --directory` syntax (single string),
#      yargs's `.alias('d', 'directory')` (separate call), cleye's
#      `{ alias: { d: 'directory' } }` (separate map).  citty's per-flag
#      alias field is the most localized.
#
#   6. EXPLICIT description FIELD — every flag has a `description` field
#      that drives `--help` output.  Without explicit `description`,
#      citty still parses but produces less useful help.  This is the
#      TYPESCRIPT-IDIOMATIC pattern of "document-as-you-declare" rather
#      than relying on doc strings or external help text files.
#
# THE citty API SURFACE (verbatim from warriorjs usage)
#
#   import { parseArgs } from "citty";
#
#   const argsDef = {
#       directory: {
#           type: "string" as const,
#           alias: "d",
#           default: ".",
#           description: "Run under given directory",
#       },
#       level: {
#           type: "string" as const,
#           alias: "l",
#           description: "Practice level (epic mode only)",
#       },
#       silent: {
#           type: "boolean" as const,
#           alias: "s",
#           default: false,
#           description: "Suppress play log",
#       },
#   };
#
#   const parsed = parseArgs(args, argsDef);
#   // parsed.directory : string  (defaulted to ".")
#   // parsed.level     : string | undefined
#   // parsed.silent    : boolean (defaulted to false)
#
# Or with full defineCommand:
#
#   import { defineCommand, runMain } from "citty";
#
#   const main = defineCommand({
#       meta: { name: "warriorjs", version: "0.14.0",
#               description: "An exciting game of programming and AI" },
#       args: {
#           directory: { type: "string", alias: "d", default: ".",
#                        description: "Run under given directory" },
#           level: { type: "string", alias: "l", description: "..." },
#           silent: { type: "boolean", alias: "s", default: false,
#                     description: "Suppress play log" },
#       },
#       run({ args }) {
#           // args is typed via TypeScript inference from argsDef
#           const game = new Game(args.directory, +args.level, args.silent);
#           // ...
#       },
#   });
#
#   runMain(main);
#
# Flag type values (the `type` field):
#   "string"     — string flag (or positional)
#   "boolean"    — boolean flag
#   "number"     — numeric flag (parsed via Number())
#   "positional" — positional argument (consumed by position not flag)
#   "enum"       — restricted set of string values (via `options`)
#
# Common fields per flag:
#   type:        Type discriminator (see above)
#   alias:       Single-char (or string) alias
#   default:     Default value when flag omitted
#   description: Help text
#   required:    Boolean, makes flag mandatory
#   options:     Array of allowed values (for enum)
#   valueHint:   Display name in --help (e.g., "FILE", "DIR")
#
# CONTRAST WITH OTHER TS-NODE CLI LIBRARIES DOCUMENTED IN THE CORPUS
#
#   * commander.js               — fluent builder method chain
#   * yargs                      — chainable builder
#   * minimist                   — pure argv parser
#   * vercel/arg                 — small typed parser
#   * meow                       — opinionated yargs wrapper
#   * mri                        — minimist successor
#   * caporal                    — declarative + plugin
#   * nopt                       — npm's classic parser
#   * cmd-ts                     — type-safe TS CLI builder
#   * clipanion                  — class+decorator (Yarn 2)
#   * cac                        — chainable typed
#   * sade                       — lukeed minimal
#   * type-flag                  — typed flag parser (cleye built on it)
#   * dthree/vorpal (R442)       — REPL-style interactive
#   * gluegun                    — full framework
#   * @stricli/core (R466)       — Bloomberg, zero-dep declarative
#   * cleye (R472)               — TypeScript-first by privatenumber
#   * citty (THIS)               — UnJS defineCommand convention
#
# citty's UnJS-ecosystem positioning is what differentiates it from
# cleye, stricli, and other modern TS CLI libraries: citty is designed
# to FIT INTO a larger UnJS application built with h3, Nitro, Nuxt,
# unbuild, consola, etc.  Its API conventions match the rest of the
# UnJS family rather than standing alone.  When you're already using
# UnJS tools (which most Nuxt 3 / Nitro apps do), citty is the natural
# CLI choice because its idioms match what you're already writing.
#
# REAL-WORLD citty USERS:
#
#   * olistic/warriorjs — coding AI game (THIS, 9517*)
#   * wg-easy/wg-easy — WireGuard Web UI (25886* — uses citty in src/)
#   * storybookjs/storybook — Storybook scripts (90148* — scripts/ uses citty)
#   * Most of UnJS's own ecosystem: nypm, unbuild, giget, nuxi (Nuxt CLI),
#     etc. — though these are already in the completion corpus
#   * Hundreds of independent Nuxt 3 / Nitro app CLIs
#
# -----------------------------------------------------------------------------
# WARRIORJS CLI SURFACE (verbatim from apps/cli/src/parseArgs.ts)
# -----------------------------------------------------------------------------
#
# USAGE:
#   warriorjs [OPTIONS]
#
# Run from a directory containing a warrior profile.  warriorjs will detect
# the profile and launch the appropriate tower level.
#
# Options:
#   -d, --directory <DIR>     Run under given directory (default: ".")
#                             Looks for profile.json, towers/, playerCode.js
#                             in this dir.
#   -l, --level <N>           Practice level (epic mode only — replay
#                             a specific level after completing the tower)
#   -s, --silent              Suppress play log (only show final result)
#
# In normal mode, warriorjs:
#   1. Prompts for profile creation if none exists
#   2. Shows the current tower level's map + warrior + monsters
#   3. Loads your playerCode.js and runs your Player.playTurn() each turn
#   4. Renders gameplay via Ink (React for CLIs)
#   5. Reports score, abilities unlocked, and advances to next level
#
# In epic mode (after beating the tower normally), --level N replays
# a specific level for score optimization.  --silent suppresses the
# per-turn animation for faster iteration.
#
# =============================================================================

_warriorjs() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -s \
        '(-d --directory)'{-d,--directory}'[run under given directory]:dir:_directories' \
        '(-l --level)'{-l,--level}'[practice level (epic mode only)]:level:' \
        '(-s --silent)'{-s,--silent}'[suppress play log]' \
        '--help[show help and exit]' \
        '--version[show version and exit]' \
        && ret=0

    return ret
}

_warriorjs "$@"
