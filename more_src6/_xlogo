#compdef xlogo
# Documentation: xlogo -help (X.Org)
# Source: display the X logo.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-fg+[foreground color]:color:' \
    '-bg+[background color]:color:' \
    '-rv[reverse video (swap fg/bg)]' \
    '-bw+[border width pixels]:pixels:' \
    '-bd+[border color]:color:' \
    '-v[verbose]' \
    '-q[quiet]' \
    '-d+[display]:host\:vs:' \
    '-g+[geometry WIDTHxHEIGHT+X+Y]:geometry:' \
    '-render[use RENDER extension]' \
    '-sharp[sharp edges]' \
    '-shape[use shape extension to make non-rectangular window]' \
    && ret=0

return ret
