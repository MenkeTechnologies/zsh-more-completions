#compdef vcfanno
# Documentation: https://github.com/brentp/vcfanno/blob/master/vcfanno.go
# Reference accessed: 2026-05-27
# Verified: upstream flag.* calls in vcfanno.go (brentp/vcfanno)

# vcfanno: annotate a VCF with information from other VCF/BED/BAM files

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '-p[number of processes to use]:procs:' \
  '-lua[path to file containing custom Lua functions]:file:_files -g "*.lua"' \
  '-base-path[base path to prepend to annotation files in the config]:path:_files -/' \
  '-ends[annotate the start and end as well as the interval itself]' \
  '-permissive-overlap[allow annotation with overlapping variants without strict ref/alt match]' \
  '1:config (TOML):_files -g "*.(toml|conf)"' \
  '2:query VCF:_files -g "*.(vcf|vcf.gz|bcf)"' && ret=0

return ret
