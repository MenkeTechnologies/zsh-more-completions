#compdef unflatten
# Documentation: man unflatten(1) (graphviz)
# Source: GraphViz unflatten — improve dot layout aspect ratio.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-l+[stagger leaf-edge minimum length (1..LEN)]:len:' \
    '-c+[chain disconnected nodes up to LEN long]:len:' \
    '-f[fanout staggering for in/out-degree-1 nodes (requires -l)]' \
    '-o+[output file]:file:_files' \
    '*:DOT file:_files -g "*.{dot,gv}"' \
    && ret=0

return ret
