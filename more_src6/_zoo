#compdef zoo
# Documentation: https://manpages.org/zoo
# Reference accessed: 2026-05-30
# zoo — Rahul Dhesi's classic .zoo archiver (Lempel-Ziv based; mid-80s era,
# still used for legacy PD shareware archives). CLI is dual-mode: a 17-letter
# "expert" single-character command verb, or a hyphenated 10-verb "novice"
# form (-add/-extract/etc) that mirrors the same operations.

local curcontext="$curcontext" state line ret=1

local -a _expert
_expert=(
  'a:add files (overwrites if newer)'
  'u:update (newer-only)'
  'c:comment archive entries'
  'f:filter (compress/decompress, with M/u/h modifiers)'
  'D:delete files inside archive'
  'e:extract (basename only)'
  'g:generate (sub-archive, w/ A/q/+/-/=)'
  'h:show short help'
  'H:show verbose help'
  'l:list (short)'
  'L:long list'
  'P:pack (squeeze archive)'
  'T:fix archive timestamp'
  'U:undelete files inside archive'
  'v:verbose list'
  'V:full verbose list'
  'x:extract preserving paths'
)

local -a _novice
_novice=(
  '-add:novice add'
  '-freshen:novice freshen'
  '-delete:novice delete'
  '-update:novice update'
  '-extract:novice extract'
  '-move:novice move (add + delete originals)'
  '-print:novice print to stdout'
  '-list:novice list'
  '-test:novice test integrity'
  '-comment:novice comment'
)

_arguments -s -S \
  '(- *)-h[show short help]' \
  '1: :->verb' \
  '2:archive file:_files -g "*.(zoo|ZOO)"' \
  '*:file inside archive:_files' \
  && ret=0

case $state in
  verb)
    _alternative \
      'experts:expert single-letter command:_describe -t commands "expert command" _expert' \
      'novice:hyphenated novice command:_describe -t commands "novice command" _novice' \
      && ret=0
    ;;
esac

return ret
