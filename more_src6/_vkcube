#compdef vkcube vkcubepp
# Documentation: https://github.com/KhronosGroup/Vulkan-Tools/blob/main/cube/cube.cpp
# Reference accessed: 2026-05-21
# Verified: upstream source cube/cube.cpp argv parser.

local curcontext="$curcontext" ret=1

_arguments -C \
  '--help[show help]' \
  '--use_staging[use staging buffer]' \
  '--present_mode=[present mode index]:mode:(0 1 2 3)' \
  '--break[break on first frame]' \
  '--validate[enable validation layers]' \
  '--c[number of frames to render]:n:' \
  '--width=[window width]:px:' \
  '--height=[window height]:px:' \
  '--suppress_popups[suppress popup dialogs]' \
  '--gpu_number=[GPU index]:gpu:' \
  '--force_errors[force errors as warnings to validation layers]' \
  '--protected_output[run with protected output]' \
  '--wsi=[WSI platform]:wsi:(xcb xlib wayland display)' \
  '--xlib[(deprecated) force xlib WSI]' && ret=0

return ret
