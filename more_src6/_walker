#compdef walker
# Documentation: https://github.com/abenz1267/walker
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--gapplication-service[run as background service]' \
  '--modules=[restrict to modules]:modules:' \
  '--password[password input mode]' \
  '--placeholder=[placeholder text]:text:' \
  '--theme=[theme name]:theme:' \
  '--style=[style sheet path]:file:_files' \
  '--config=[config file path]:file:_files' \
  '--label=[display label]:label:' \
  '--bench[benchmark mode]' \
  '(-d --dmenu)'{-d,--dmenu}'[dmenu mode]' \
  '--forceprint[force print to stdout]' \
  '--keepsort[keep input order]' && ret=0

return ret
