#compdef targetcli-fb
# Documentation: https://github.com/open-iscsi/targetcli-fb/blob/master/targetcli.8
# Reference accessed: 2026-05-21
# Verified: upstream src/targetcli/targetcli_shell.py - usage "{argv0} [--version|--help|CMD|--disable-daemon]".

# targetcli-fb: Linux SCSI target (LIO) interactive admin shell (fork)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

_arguments -C \
  '(- *)'{-h,--help,help}'[show help]' \
  '(- *)'{-v,--version,version}'[show version]' \
  '--disable-daemon[disable global auto-use daemon flag]' \
  '*::cmd:_default' && ret=0
return ret
