#compdef tmutil
# Documentation: https://www.unix.com/man-page/osx/8/tmutil/
# Source: Apple macOS — Time Machine CLI (backup / snapshot / restore / exclusion).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'help:print extended usage for a verb (or list verbs)'
            'enable:turn on automatic backups (root)'
            'disable:turn off automatic backups (root)'
            'enablelocal:turn on local snapshots (root)'
            'disablelocal:turn off local snapshots + trigger cleanup'
            'snapshot:create a new local snapshot'
            'startbackup:begin a backup if not running'
            'stopbackup:cancel a backup in progress'
            'delete:delete snapshots / machine dirs / backup stores'
            'restore:restore item from inside a snapshot'
            'compare:perform a backup diff'
            'setdestination:configure local HFS+/AFP as backup destination'
            'destinationinfo:print configured destinations'
            'removedestination:remove a destination'
            'addexclusion:exclude file/dir/volume from backup'
            'removeexclusion:remove a configured exclusion'
            'isexcluded:check if path is excluded'
            'inheritbackup:claim machine dir / sparsebundle'
            'associatedisk:bind snapshot-volume dir to local disk'
            'latestbackup:print path of most recent snapshot'
            'listbackups:print paths of all completed snapshots'
            'machinedirectory:print this machine'\''s directory'
            'calculatedrift:per-snapshot change-rate report'
            'uniquesize:unique size of a path'
        )
        _describe -t subcmds 'tmutil command' subcmds && ret=0
        ;;
    args)
        case $words[1] in
            startbackup)
                _arguments \
                    '(-a --auto)'{-a,--auto}'[run as system-scheduled]' \
                    '(-b --block)'{-b,--block}'[wait until backup finishes]' \
                    '(-r --rotation)'{-r,--rotation}'[allow auto destination rotation]' \
                    '(-d --destination)'{-d+,--destination=}'[destination ID]:dest:' \
                    && ret=0
                ;;
            compare)
                _arguments \
                    '-a[compare all supported metadata]' \
                    '-@[compare extended attributes]' \
                    '-e[compare ACLs]' \
                    '-s[compare sizes]' \
                    '-m[compare modes]' \
                    '-u[compare UIDs]' \
                    '-g[compare GIDs]' \
                    '-t[compare mtimes]' \
                    '-n[no metadata comparison]' \
                    '-d[compare data forks]' \
                    '-D[max depth]:n:' \
                    '-E[ignore exclusions]' \
                    '-I[ignore path component]:name:' \
                    '-U[ignore volume identity differences]' \
                    '-X[XML plist output]' \
                    '*:path:_files' \
                    && ret=0
                ;;
            setdestination)
                _arguments \
                    '-a[add destination to existing list]' \
                    '-p[enter password at prompt]' \
                    '*:destination url/share/path:' \
                    && ret=0
                ;;
            addexclusion|removeexclusion)
                _arguments \
                    '-p[set fixed-path exclusion]' \
                    '*:path:_files' \
                    && ret=0
                ;;
            destinationinfo|isexcluded)
                _arguments \
                    '-X[XML plist output]' \
                    '*:path:_files' \
                    && ret=0
                ;;
            restore)
                _arguments \
                    '-v[verbose]' \
                    '*:src then dst:_files' \
                    && ret=0
                ;;
            associatedisk)
                _arguments \
                    '-a[associate all matching snapshot volumes]' \
                    '*:mountpoint:_files' \
                    && ret=0
                ;;
            *)
                _files
                ;;
        esac
        ;;
esac

return ret
