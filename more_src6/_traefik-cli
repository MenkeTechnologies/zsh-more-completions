#compdef traefik-cli traefikctl
# _traefik-cli — Traefik Labs cloud-native reverse proxy CLI alias (Traefik Labs, Go); spf13/cobra
# upstream: https://github.com/traefik/traefik

_traefik-cli() {
    local -a sub=(
        'completion:generate shell completion'
        'healthcheck:run healthcheck'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--configFile=+[config file]:file:_files -g "*.toml *.yaml *.yml"' \
        '-c+[config file]:file:_files -g "*.toml *.yaml *.yml"' \
        '--entryPoints=+[entry point]:str:' \
        '--providers.docker[enable docker provider]' \
        '--providers.docker.endpoint=+[docker endpoint]:str:' \
        '--providers.docker.exposedByDefault=+[expose by default]:b:(true false)' \
        '--providers.file.directory=+[file provider dir]:dir:_files -/' \
        '--providers.file.filename=+[file provider config]:file:_files' \
        '--providers.kubernetesCRD[enable kubernetes CRD]' \
        '--providers.kubernetesIngress[enable kubernetes ingress]' \
        '--providers.consul[enable consul]' \
        '--providers.etcd[enable etcd]' \
        '--providers.zookeeper[enable zookeeper]' \
        '--providers.redis[enable redis]' \
        '--api[enable api]' \
        '--api.dashboard[enable dashboard]' \
        '--api.insecure[insecure api]' \
        '--api.debug[debug api]' \
        '--metrics.prometheus[enable prometheus]' \
        '--metrics.influxdb[enable influxdb]' \
        '--metrics.datadog[enable datadog]' \
        '--metrics.statsd[enable statsd]' \
        '--tracing.jaeger[enable jaeger tracing]' \
        '--tracing.zipkin[enable zipkin tracing]' \
        '--tracing.datadog[enable datadog tracing]' \
        '--tracing.openTelemetry[enable opentelemetry tracing]' \
        '--accessLog[enable access log]' \
        '--accessLog.filePath=+[access log file]:file:_files' \
        '--log[enable log]' \
        '--log.level=+[log level]:level:(DEBUG INFO WARN ERROR FATAL PANIC)' \
        '--log.format=+[log format]:fmt:(common json)' \
        '--log.filePath=+[log file]:file:_files' \
        '--certificatesResolvers=+[cert resolver]:str:' \
        '--ping[enable ping]' \
        '--ping.entryPoint=+[ping entry point]:str:' \
        '--hostResolver[enable host resolver]' \
        '--global.checkNewVersion[check new version]' \
        '--global.sendAnonymousUsage[send anonymous usage]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'traefik subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                healthcheck) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_traefik-cli "$@"
