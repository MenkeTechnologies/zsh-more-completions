#compdef xfsrestore
# _xfsrestore — xfsprogs xfsrestore (restore an XFS dump produced by xfsdump(8); -f input media (- for stdin), -i interactive subtree selection, -r resume previous restore, -s subtree-only, -t toc only, -A skip xattrs, -D no inventory update, -F no prompts, -L session label match)
# upstream: https://git.kernel.org/pub/scm/fs/xfs/xfsdump-dev.git
# Flags from xfsdump restore/main.c on tip.

_xfsrestore() {
    _arguments \
        '-h[show help]' \
        '-c[show contents and exit]' \
        '-f+[input media]:media:_files' \
        '-i[interactive subtree picker]' \
        '-r[resume previous restore]' \
        '-s+[subtree to restore]:subtree:' \
        '-t[toc only]' \
        '-A[skip xattrs]' \
        '-D[no inventory db update]' \
        '-F[no prompts]' \
        '-L+[session label match]:label:' \
        '-S+[session id]:id:' \
        '-q[quiet]' \
        '-v+[verbosity]:level:(error info warning notice debug)' \
        '-J[skip xattrs]' \
        '-K[keep going on error]' \
        '-O+[options file]:file:_files' \
        '-x[expert/restore everything]' \
        '*:destination:_files -/'
}

_xfsrestore "$@"
