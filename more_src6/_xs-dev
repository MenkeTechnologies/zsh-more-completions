_xs-dev() {
  local context state state_descr line
  typeset -A opt_args
  local curcontext="$curcontext"

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show xs-dev version]' \
    '1: :->subcommand' \
    '*:: :->args' && return

  case "$state" in
    subcommand)
      local -a subcmds
      subcmds=(
        'build:build a Moddable JS app for a target device'
        'clean:clean Moddable build artifacts for a target'
        'debug:launch xsbug debugger attached to running device'
        'doctor:diagnose Moddable SDK installation issues'
        'dr:diagnose Moddable SDK installation (alias for doctor)'
        'info:diagnose Moddable SDK installation (alias for doctor)'
        'include:add a Moddable manifest include to current project'
        'init:initialize a new Moddable JS project'
        'remove:remove a Moddable component or tool installation'
        'run:build + flash + run a Moddable app on a target device'
        'scan:scan for connected target devices (USB enumeration)'
        'setup:download and build Moddable tooling for platform targets'
        'teardown:remove a previously-installed Moddable target toolchain'
        'update:update Moddable SDK to latest release or specified branch'
      )
      _describe -t subcommands 'xs-dev subcommand' subcmds
      ;;
    args)
      case "${words[1]}" in
        setup|update)
          _arguments -s -S \
            '--device=[target device]:device:(esp8266 esp32 pico wasm nrf52 zephyr mac linux win)' \
            '--list-devices[print list of available target devices]' \
            '--tool=[specific Moddable tool to run]:tool:(ejectfix)' \
            '--branch=[Moddable SDK git branch]:branch:' \
            '--release=[Moddable SDK release version]:release:' \
            '--source-repo=[custom Moddable source repo URL]:url:' \
            '--interactive[enable interactive prompts]'
          ;;
        build|run|clean|debug|teardown)
          _arguments -s -S \
            '--device=[target device]:device:(esp8266 esp32 pico wasm nrf52 zephyr mac linux win)'
          ;;
        init|include|remove|scan|doctor|dr|info)
          _arguments -s -S \
            '(-h --help)'{-h,--help}'[show subcommand help]'
          ;;
      esac
      ;;
  esac
}

_xs-dev "$@"
