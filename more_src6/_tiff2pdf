#compdef tiff2pdf
# Documentation: tiff2pdf usage on libtiff 4.7.1
# Source: libtiff tiff2pdf — convert a TIFF image to a PDF document.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-o+[output file name]:file:_files' \
    '(-j -z -d -n)-j[compress with JPEG]' \
    '(-j -z -d -n)-z[compress with Zip/Deflate]' \
    '-q+[compression quality]:n:' \
    '(-j -z -d -n)-n[no compressed data passthrough]' \
    '(-j -z -d -n)-d[do not compress (decompress)]' \
    '-i[invert colors]' \
    '-u+[distance unit (i = inch, m = centimeter)]:unit:(i m)' \
    '-x+[X resolution default (dpi)]:dpi:' \
    '-y+[Y resolution default (dpi)]:dpi:' \
    '-w+[page width in units]:width:' \
    '-l+[page length in units]:length:' \
    '-r+[resolution mode]:mode:(d o)' \
    '-p+[paper size]:size:(letter legal A4 A3 A5 B5 executive ledger tabloid)' \
    '-F[make TIFF fill the PDF page]' \
    '-f[set PDF "Fit Window" user preference]' \
    '-e+[date override YYYYMMDDHHMMSS]:date:' \
    '-c+[document creator (overrides image software)]:string:' \
    '-a+[document author (overrides image artist)]:string:' \
    '-t+[document title (overrides image name)]:string:' \
    '-s+[document subject (overrides image description)]:string:' \
    '-k+[document keywords]:string:' \
    '-b[set PDF "Interpolate" user preference]' \
    '-m+[memory allocation limit (MiB; 0 = no limit)]:size:' \
    '(- *)-h[usage]' \
    '*:input TIFF:_files -g "*.{tif,tiff,TIF,TIFF}"' \
    && ret=0

return ret
