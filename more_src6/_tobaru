# -----------------------------------------------------------------------------
#
# WHY notify IS THE 71ST RUST CLI LIBRARY
#
# notify is the de-facto Rust filesystem-event library, providing
# a unified cross-platform API over four distinct kernel event
# sources.  Distinct from std::fs (no watching), from polling
# loops (high CPU, low precision), and from manual platform-
# specific APIs (impossible to use portably).
#
# Five distinguishing characteristics:
#
#   1. CROSS-PLATFORM ABSTRACTION via RecommendedWatcher —
#      single trait abstracts over:
#         Linux:   inotify (kernel 2.6.13+, ~2005)
#         macOS:   FSEvents (10.7+, ~2011) + kqueue
#         Windows: ReadDirectoryChangesW (NT API)
#         BSDs:    kqueue (FreeBSD/OpenBSD/NetBSD)
#      Each backend produces native kernel events without
#      polling.  notify is the FIRST documented Rust Axis 17
#      library providing this abstraction.
#
#   2. EVENT KIND TAXONOMY — granular classification:
#      EventKind::Create / Modify / Remove / Access / Other,
#      each with subkinds (DataChange, MetadataKind, RenameMode,
#      etc.).  Distinct from raw inotify masks which require
#      manual bit-flag interpretation.
#
#   3. CHANNEL / CLOSURE API — Watcher accepts a closure or
#      channel that receives Events asynchronously.  Distinct
#      from blocking-poll APIs that require manual select()
#      loops.
#
#   4. RECURSIVE WATCHING — single watch() call captures all
#      descendant paths of a directory.  Distinct from raw
#      inotify which requires manually iterating subdirectories
#      and adding watches for each.
#
#   5. NOTIFY-RS / FRANÇOIS MOCKERS ECOSYSTEM PROVENANCE —
#      distinct from Sean McArthur (Hyperium / reqwest),
#      Mathew Roy (go-resty), Tolnay (serde), Sindre Sorhus
#      (Node CLI utils).  notify-rs is a community-owned
#      maintenance group providing the foundational Rust
#      filesystem-event layer.
#
# -----------------------------------------------------------------------------
#
# THE tobaru CLI — manual flag parsing + notify hot reload
#
# tobaru's CLI is in src/main.rs.  Uses manual std::env::args()
# parsing (no clap / no structopt) for minimal binary size.
# notify is used for config file hot-reload:
#
#     use notify::{Event, EventKind, RecommendedWatcher,
#                  RecursiveMode, Watcher};
#     ...
#     let mut watcher = notify::recommended_watcher(
#         move |res: notify::Result<Event>| match res {
#             Ok(event) => {
#                 if matches!(event.kind, EventKind::Modify(..)) {
#                     tx.send(ConfigChanged {}).unwrap();
#                 }
#             }
#             Err(e) => println!("watch error: {:?}", e),
#         }
#     ).unwrap();
#     for config_path in config_paths {
#         watcher.watch(Path::new(&config_path),
#                       RecursiveMode::NonRecursive)?;
#     }
#
# When a Modify event fires for any watched config, tobaru
# rebuilds the server config and gracefully cycles servers
# without dropping connections.
#
# Flags (manually parsed):
#   -t, --threads NUM         worker thread count
#                              (default: available_parallelism())
#       --clear-iptables-all  clear all tobaru-created iptables
#                              rules and exit immediately
#       --clear-iptables-matching
#                              clear iptables rules only for
#                              addresses in specified configs +
#                              exit immediately
#       --dry-run             validate configs without starting
#                              servers
#   -h, --help                show help
#
# Positional arguments:
#   <CONFIG PATH or URL>...    .yaml/.json config files OR
#                              URL-form configs like
#                              tcp://127.0.0.1:1000?target=
#                              127.0.0.1:2000
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/cfal/tobaru/blob/master/src/main.rs
# help_str() function + main() argument-parse loop.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-t --threads)'{-t+,--threads=}'[number of worker threads (default: available parallelism)]:threads:_default' \
    '--clear-iptables-all[clear all tobaru-created iptables rules and exit]' \
    '--clear-iptables-matching[clear iptables rules for addresses in specified configs and exit]' \
    '--dry-run[validate configs without starting servers]' \
    '(- *)'{-h,--help}'[show help]' \
    '*:config path or URL:_files -g "*.(yaml|yml|json)"' \
    && ret=0

return ret
