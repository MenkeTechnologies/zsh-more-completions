#compdef wasi_nn_rpcserver
# _wasi_nn_rpcserver — WasmEdge WASI-NN gRPC server (forwards wasi_nn API calls from a guest to a backend via Unix domain socket)
# upstream: https://github.com/WasmEdge/WasmEdge
# Flags from lib/driver/wasiNNRPCServerTool.cpp on tip (custom PO::Option parser; --nn-preload comes from the wasi_nn plugin).

_wasi_nn_rpcserver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[print version and exit]' \
        '--nn-rpc-uri=[NN RPC URI to serve (unix://...)]:uri:' \
        '*--nn-preload=[wasi_nn model preload spec (name:encoding:target:path)]:spec:'
}

_wasi_nn_rpcserver "$@"
