#compdef xfs_check
# Documentation: https://manpages.org/xfs_check/8
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Fixed: -s description (only serious errors, not filesystem status).
# Added: -i ino, -b bno (documented upstream).

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-f[image is regular file]' \
  '-l+[xfs external log device]:dev:_files -W /dev' \
  '-s[report only serious errors]' \
  '-v[verbose output]' \
  '-i+[verbose behavior for specified inode]:ino:' \
  '-b+[verbose behavior for specific filesystem block]:bno:' \
  '*:device or image:_files' && ret=0

return ret
