#compdef tldr tealdeer
# Documentation: https://tealdeer-rs.github.io/tealdeer/usage.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for tealdeer (tldr client)

_arguments -s -S \
  '(-l --list)'{-l,--list}'[list all commands in the cache]' \
  '--edit-page[edit custom page with EDITOR]' \
  '--edit-patch[edit custom patch with EDITOR]' \
  '(-f --render)'{-f+,--render=}'[render a local file]:file:_files -g "*.md"' \
  '(-p --platform)'{-p+,--platform=}'[override OS]:platform:(linux macos sunos windows android freebsd netbsd openbsd common)' \
  '(-L --language)'{-L+,--language=}'[override language]:language:' \
  '(-u --update)'{-u,--update}'[update the local cache]' \
  '--no-auto-update[disable auto-update for current run]' \
  '(-c --clear-cache)'{-c,--clear-cache}'[clear the local cache]' \
  '--config-path=[override config file location]:file:_files' \
  '--pager[use a pager for output]' \
  '(-r --raw)'{-r,--raw}'[display raw markdown]' \
  '(-q --quiet)'{-q,--quiet}'[suppress informational messages]' \
  '--show-paths[display file and directory paths used]' \
  '--seed-config[create a basic config]' \
  '--color=[control color output]:when:(always auto never)' \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-h --help)'{-h,--help}'[print help]' \
  '*:command:' && return 0
