#compdef tzap
# _tzap — Linux-DVB tzap DVB-T terrestrial tuner channel-by-name zapper from linuxtv dvb-apps with channels.conf service selection (linuxtv team, C); getopt
# upstream: https://www.linuxtv.org/wiki/index.php/LinuxTV_dvb-apps

_tzap() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '-a+[adapter]:n:(0 1 2 3)' \
        '-f+[frontend]:n:(0 1 2 3)' \
        '-d+[demux]:n:(0 1 2 3)' \
        '-c+[channels.conf file]:file:_files -g "*.conf channels.conf"' \
        '-x[exit after tuning]' \
        '-r[record to dvr]' \
        '-p[print pids]' \
        '-S[wait for SI]' \
        '-H[human-readable]' \
        '-l[list channels]' \
        '-n+[channel num]:n:' \
        '-N[no timeout]' \
        '-t+[tuning timeout]:n:' \
        '-z[zap on receive]' \
        '-s[show stats]' \
        '-D[strong signal]' \
        '*:channel name:'
}

_tzap "$@"
