# weston-launch: deprecated Weston session launcher
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-u --user)'{-u,--user=}'[user to switch to]:user:_users' \
  '(-t --tty)'{-t,--tty=}'[tty to use]:tty:' \
  '*:Weston args (after --):_files' && ret=0
return ret
