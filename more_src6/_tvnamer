#compdef tvnamer
# Documentation: https://github.com/dbr/tvnamer
# Reference accessed: 2026-05-21
# Verified: upstream tvnamer/cliarg_parser.py add_option() calls.

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[show debugging info]' \
  '(-q --not-verbose)'{-q,--not-verbose}'[disable verbose output]' \
  '--dry-run[only print what would happen, do not rename]' \
  '(-a --always)'{-a,--always}'[always rename, but prompt for series]' \
  '--not-always[override --always]' \
  '(-f --selectfirst)'{-f,--selectfirst}'[select first series search result]' \
  '--not-selectfirst[override --selectfirst]' \
  '(-b --batch)'{-b,--batch}'[rename without human intervention]' \
  '--not-batch[override --batch]' \
  '(-c --config)'{-c,--config}'[load config from file]:file:_files' \
  '(-s --save)'{-s,--save}'[save configuration to file and exit]:file:_files' \
  '(-p --preview-config)'{-p,--preview-config}'[show current config values and exit]' \
  '(-n --name)'{-n,--name}'[override parsed series name]:name:' \
  '--series-id=[explicitly set TVDB show id]:id:' \
  '--order=[TvDB episode order]:order:(aired dvd)' \
  '(-l --lang)'{-l,--lang}'[language for episode names]:lang:' \
  '(-r --recursive)'{-r,--recursive}'[descend more than one directory level]' \
  '--not-recursive[only descend one directory level]' \
  '(-m --move)'{-m,--move}'[move files to destination]' \
  '--not-move[do not move files]' \
  '--force-move[force move, overwrite if needed]' \
  '--force-rename[force rename source file]' \
  '(-d --movedestination)'{-d,--movedestination}'[destination directory pattern]:dir:_files -/' \
  '*:file or directory:_files'
