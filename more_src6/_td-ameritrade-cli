#compdef td-ameritrade-cli td-ameritrade tda tda-cli
# _td-ameritrade-cli — TD Ameritrade td-ameritrade-cli CLI command-line frontend wrapping the TD Ameritrade thinkorswim REST API now migrated to Charles Schwab Trader-API managing accounts orders trades positions transactions watchlists options market quote price-history movers fundamentals instruments user-preferences streamer (TD Ameritrade team, Go); cobra
# upstream: https://developer.tdameritrade.com/

_td-ameritrade-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'account:account operations'
        'order:order operations'
        'trade:trade operations'
        'position:position operations'
        'transaction:transaction operations'
        'watchlist:watchlist operations'
        'option:options chain'
        'price-history:price history'
        'quote:quote operations'
        'market:market operations'
        'movers:movers operations'
        'fundamental:fundamentals'
        'instrument:instrument operations'
        'preference:user preferences'
        'streamer:streaming subscription'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--client-id=+[id]:str:' \
        '--access-token=+[token]:str:' \
        '--refresh-token=+[token]:str:' \
        '--redirect-uri=+[url]:str:' \
        '--account-id=+[id]:str:' \
        '--api-url=+[url]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'td-ameritrade-cli subcommand' sub ;;
        args)
            case $words[1] in
                order) _arguments \
                    '1:op:(list get place cancel modify status)' \
                    '--symbol=+[ticker]:str:' \
                    '--instruction=+[i]:i:(BUY SELL BUY_TO_COVER SELL_SHORT BUY_TO_OPEN BUY_TO_CLOSE SELL_TO_OPEN SELL_TO_CLOSE)' \
                    '--order-type=+[t]:t:(MARKET LIMIT STOP STOP_LIMIT TRAILING_STOP)' \
                    '--quantity=+[N]:n:' \
                    '--price=+[N]:str:' \
                    '--duration=+[d]:d:(DAY GOOD_TILL_CANCEL FILL_OR_KILL)' \
                    '*:order id:' ;;
                account|trade|position|transaction|watchlist|streamer|preference|instrument|fundamental|movers) _arguments '1:op:(list get create update delete)' '*:id:' ;;
                quote|price-history|market|option) _arguments '*:symbol:' ;;
            esac
            ;;
    esac
}

_td-ameritrade-cli "$@"
