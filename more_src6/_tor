#compdef tor
# _tor — Tor onion-router (anonymous overlay-network daemon; -f torrc file, --defaults-torrc defaults, --hash-password produce hashed control password and exit, --verify-config parse-only, --service install|remove|reload Windows service, --dump-config short|non-builtin|full, --keygen, --list-fingerprint, --version, --quiet/--hush; common runtime options can also be supplied as command line: --SocksPort, --ControlPort, --DataDirectory, --Log, --Nickname)
# upstream: https://gitlab.torproject.org/tpo/core/tor
# Flags from torproject.org/tor src/app/main on tip.

_tor() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-f+[torrc file]:file:_files' \
        '--defaults-torrc+[defaults torrc]:file:_files' \
        '--ignore-missing-torrc[ignore missing torrc]' \
        '--hash-password+[password]:password:' \
        '--verify-config[parse-only]' \
        '--service+[Windows service op]:op:(install remove reload start stop)' \
        '--dump-config+[mode]:mode:(short non-builtin full)' \
        '--keygen[generate identity key]' \
        '--newpass[new pass for identity key]' \
        '--list-fingerprint[show fingerprint]' \
        '--list-torrc-options[list options]' \
        '--quiet[quiet]' \
        '--hush[hush]' \
        '--RunAsDaemon=*[run as daemon]:bool:(0 1)' \
        '--DataDirectory+[data dir]:dir:_files -/' \
        '--PidFile+[pidfile]:file:_files' \
        '--Log+[log spec]:spec:' \
        '--ControlPort+[port]:port:' \
        '--SocksPort+[port]:port:' \
        '--Nickname+[nickname]:nick:' \
        '--ORPort+[port]:port:' \
        '--DirPort+[port]:port:' \
        '*--HashedControlPassword+[hash]:hash:'
}

_tor "$@"
