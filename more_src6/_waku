#compdef waku
# Documentation: https://www.npmjs.com/package/waku
# Reference accessed: 2026-05-23
# Verified: npx waku --help.

# Zsh completion for waku - Waku React framework CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'dev:start the development server'
  'build:build for production'
  'start:start the production server'
  'router:router subcommands'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '-h[hostname to bind]:host:_hosts' \
  '--host=[hostname to bind]:host:_hosts' \
  '-p[port number]:port:' \
  '--port=[port number]:port:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    _describe -t commands 'waku command' commands && ret=0
    ;;
  (args)
    _arguments '*::args:' && ret=0
    ;;
esac

return ret
