#compdef xsltproc
# Documentation: https://manpages.debian.org/xsltproc.1
# Source: libxslt — XSLT 1.0 processor CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-V,--version}'[show libxml and libxslt versions]' \
    '(-v --verbose)'{-v,--verbose}'[report each step taken]' \
    '(-o --output)'{-o+,--output=}'[output file or directory]:path:_files' \
    '--timing[report parse + transform + save timing]' \
    '--repeat[run the transformation 20 times (timing)]' \
    '--debug[output XML tree of transformed document]' \
    '--novalid[skip loading document DTD]' \
    '--noout[do not output the result]' \
    '--maxdepth=[max template-stack depth before infinite-loop detection]:depth:' \
    '--maxvars=[max number of variables (default 15000)]:n:' \
    '--maxparserdepth=[max XML parser nesting (default 256)]:depth:' \
    '--huge[set XML_PARSE_HUGE to relax hardcoded limits]' \
    '--seed-rand=[seed pseudo-random number generator]:seed:' \
    '--html[input document is HTML]' \
    '--encoding=[input document encoding]:encoding:(UTF-8 UTF-16 ISO-8859-1 ISO-8859-15 ASCII)' \
    '*--param[pass PARAMNAME PARAMVALUE node-identifier]:name then value:' \
    '*--stringparam[pass PARAMNAME PARAMVALUE string]:name then value:' \
    '--nonet[do not use Internet to fetch DTDs/entities]' \
    '--path=[filesystem path list for DTD/entity/document lookup]:paths:' \
    '--load-trace[log loaded documents to stderr]' \
    '--catalogs[use SGML catalogs from SGML_CATALOG_FILES]' \
    '--xinclude[process input via XInclude]' \
    '--xincludestyle[process stylesheet via XInclude]' \
    '(--profile --norman)--profile[profile time spent in each stylesheet section]' \
    '(--profile --norman)--norman[profile time spent in each stylesheet section (alias)]' \
    '--dumpextensions[dump registered extensions to stdout]' \
    '--nowrite[refuse to write any file or resource]' \
    '--nomkdir[refuse to create directories]' \
    '--writesubtree=[allow file writes only inside PATH subtree]:path:_directories' \
    '--nodtdattr[do not apply default DTD attributes]' \
    '*:stylesheet then XML files:_files' \
    && ret=0

return ret
