#compdef zfs-load-key
# _zfs-load-key — OpenZFS zfs load-key (load wrapping keys for native ZFS encryption; -L prompts for key location URI, -n dry-run validates passphrase, -r recursive on encryption roots, -a apply to all loaded pools; positional argument is the encryption-root dataset)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zfs/zfs_main.c (zfs_do_load_key) on tip.

_zfs-load-key() {
    _arguments \
        '-L+[key location URI]:uri:(prompt file:// pkcs11: http:// https://)' \
        '-n[dry-run]' \
        '-r[recursive]' \
        '-a[all encryption roots]' \
        '*:dataset:'
}

_zfs-load-key "$@"
