#compdef zq
# Documentation: https://zed.brimdata.io/docs/commands/zq/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed from prior file: --split-size, --color when-style argument,
# -raw, GNU-style --format/--help/--version, and `lake` output format
# (zq uses Go-flag single-dash style; no such GNU double-dash forms
# and no `lake` output format documented).

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-i+[input format]:format:(auto arrows csv json line parquet tsv vng zeek zjson zng zson)' \
  '-f+[output format]:format:(arrows csv json parquet table text tsv vng zeek zjson zng zson)' \
  '-z[shortcut for -f zson]' \
  '-Z[shortcut for -f zson -pretty 4]' \
  '-j[shortcut for -f json]' \
  '-J[shortcut for -f json -pretty 4]' \
  '-o+[output file path]:file:_files' \
  '-split[split output across multiple files by schema]' \
  '-pretty+[pretty-print indent spaces]:spaces' \
  '-color+[colorize output]:bool:(true false)' \
  '-C[compile and display query in canonical form]' \
  '-I+[include source file]:file:_files' \
  '-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '*:file:_files' && ret=0

return ret
