#compdef zpool
# Documentation: https://openzfs.github.io/openzfs-docs/man/master/8/zpool.8.html
# Reference accessed: 2026-05-29
# OpenZFS storage pool CLI.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'create:create a new storage pool from virtual devices'
  'destroy:destroy a pool and free its devices'
  'add:add virtual devices to a pool'
  'remove:remove virtual devices from a pool'
  'attach:attach a device to a mirror or convert non-redundant to mirror'
  'detach:detach a device from a mirror'
  'replace:replace an existing device with a new one'
  'split:create a new pool by splitting mirrors'
  'list:list pools with health status and space usage'
  'get:get pool properties'
  'set:set pool properties'
  'status:display detailed health information'
  'iostat:show logical I/O statistics'
  'history:display command history'
  'events:list recent ZFS kernel-module events'
  'scrub:begin/resume scrub operations'
  'trim:initiate on-demand TRIM operations'
  'upgrade:manage on-disk format versions'
  'import:make pools available for use'
  'export:export pools from the system'
  'initialize:start initialization of unallocated regions'
  'labelclear:remove ZFS label information from devices'
  'online:bring devices online'
  'offline:take devices offline'
  'clear:clear errors on pool/device'
  'reopen:reopen all vdevs in the pool'
  'wait:wait for activity to complete'
  'checkpoint:checkpoint pool state'
  'resilver:start a resilver on the pool'
  'reguid:re-generate pool GUID'
  'sync:force pool to flush all in-memory data'
  'version:show ZFS version'
  'help:show help for a subcommand'
)

_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'zpool subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      create)
        _arguments \
          '-f[force creation]' \
          '-n[dry run]' \
          '-d[disable features (use with -o feature@xxx=enabled)]' \
          '*-o[pool property=value]:property:' \
          '*-O[filesystem property=value]:property:' \
          '-R[alt root]:dir:_directories' \
          '-m[mountpoint]:dir:_directories' \
          '-t[temp pool name]:name:' \
          ':pool name:' \
          '*:vdev:' && ret=0
        ;;
      destroy)
        _arguments \
          '-f[force destroy of mounted/exported]' \
          ':pool:' && ret=0
        ;;
      status)
        _arguments \
          '-c[command to run on each device]:cmd:' \
          '-D[display deduplication histogram]' \
          '-e[only show errored/unhealthy]' \
          '-g[show GUIDs]' \
          '-i[show vdev initialization status]' \
          '-L[follow symlinks]' \
          '-p[parsable output]' \
          '-P[full paths]' \
          '-s[slow IOs]' \
          '-t[show vdev TRIM status]' \
          '-T[display timestamp]:format:(u d)' \
          '-v[verbose]' \
          '-x[only show unhealthy pools]' \
          '*:pool:' && ret=0
        ;;
      list)
        _arguments \
          '-g[show GUIDs]' \
          '-H[scripted output]' \
          '-L[follow symlinks]' \
          '-o[output properties]:properties:' \
          '-p[parsable output]' \
          '-P[full paths]' \
          '-T[display timestamp]:format:(u d)' \
          '-v[verbose]' \
          '*:pool:' && ret=0
        ;;
      import)
        _arguments \
          '-a[import all pools found]' \
          '-c[cachefile]:file:_files' \
          '-d[search directory or device]:dir:_directories' \
          '-D[import destroyed pools]' \
          '-f[force]' \
          '-F[recovery mode]' \
          '-l[load keys]' \
          '-m[allow missing log device]' \
          '-n[dry run with recovery]' \
          '-N[do not mount]' \
          '-o[pool property=value]:property:' \
          '-R[alt root]:dir:_directories' \
          '-s[search using scan, not cachefile]' \
          '-t[import as temporary name]' \
          '-T[txg for recovery]:txg:' \
          '-X[extreme recovery]' \
          '*:pool name or id:' && ret=0
        ;;
      export)
        _arguments \
          '-a[export all pools]' \
          '-f[force unmount]' \
          '*:pool:' && ret=0
        ;;
      iostat)
        _arguments \
          '-c[command to run on each device]:cmd:' \
          '-e[only show errored]' \
          '-g[show GUIDs]' \
          '-H[scripted output]' \
          '-l[latency statistics]' \
          '-L[follow symlinks]' \
          '-n[hide-headers]' \
          '-p[parsable output]' \
          '-P[full paths]' \
          '-q[queue statistics]' \
          '-r[request-size histograms]' \
          '-T[display timestamp]:format:(u d)' \
          '-v[verbose vdev tree]' \
          '-w[latency histograms]' \
          '-y[skip stat snapshot]' \
          '*:: :_files' && ret=0
        ;;
      scrub)
        _arguments \
          '-s[stop scrub]' \
          '-p[pause scrub]' \
          '-w[wait for scrub to complete]' \
          '-e[only scrub errors recorded]' \
          '*:pool:' && ret=0
        ;;
      trim)
        _arguments \
          '-c[cancel trim]' \
          '-d[secure discard]' \
          '-r[rate limit]:rate:' \
          '-s[suspend trim]' \
          '-w[wait for completion]' \
          ':pool:' \
          '*:vdev:' && ret=0
        ;;
      add|attach|detach|replace|remove)
        _arguments \
          '-f[force]' \
          '-n[dry run]' \
          ':pool:' \
          '*:vdev:' && ret=0
        ;;
      get)
        _arguments \
          '-H[scripted output]' \
          '-p[parsable]' \
          '-o[output fields]:fields:' \
          ':property:' \
          '*:pool:' && ret=0
        ;;
      set)
        _arguments \
          ':property=value:' \
          ':pool:' && ret=0
        ;;
      upgrade)
        _arguments \
          '-a[upgrade all pools]' \
          '-v[show supported features]' \
          '-V[upgrade to specific version]:ver:' \
          '*:pool:' && ret=0
        ;;
    esac
    ;;
esac

return ret
