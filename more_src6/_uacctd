#compdef uacctd
# Documentation: https://raw.githubusercontent.com/pmacct/pmacct/master/src/uacctd.c
# Reference accessed: 2026-05-30
# uacctd — pmacct user-space accounting daemon. Receives Netlink ULOG/NFLOG packets + accounts via plugins.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)-h[show help]' \
  '(- *)-V[show version and compile-time options]' \
  '-f+[config file]:file:_files' \
  '-a[list aggregation primitives]' \
  '-c+[aggregation method]:primitive:' \
  '-D[run as daemon]' \
  '-d[enable debug mode]' \
  '-n+[networks/ASNs definitions file]:file:_files' \
  '-t+[ports definitions file]:file:_files' \
  '*-P+[activate plugin]:plugin:(memory print mysql pgsql sqlite3 amqp kafka nfprobe sfprobe)' \
  '-S+[syslog facility]:facility:(auth mail daemon kern user local0 local1 local2 local3 local4 local5 local6 local7)' \
  '-F+[PID file]:file:_files' \
  '-R[renormalize sampled data]' \
  '-g+[Netlink NFLOG group]:group:' \
  '-L+[snapshot length]:bytes:' \
  '-u[keep IP protocols in numeric format]' \
  '-T+[dry run]:target:(config setup)' \
  '-p+[client-server socket path]:socket:_files' \
  '-b+[memory plugin buckets]:N:' \
  '-m+[memory pool count]:N:' \
  '-s+[memory pool size]:bytes:' \
  '-r+[refresh time (seconds)]:sec:' \
  '-O+[output format]:fmt:(formatted csv json avro)' \
  '-o+[output file]:file:_files' \
  '-M[print event markers]' \
  '-A[append to output file]' \
  '-E+[CSV separator character]:char:' \
  && ret=0

return ret
