#compdef wal-reader
# _wal-reader — Grafana Mimir Prometheus-format WAL inspector (grafana/mimir)
# upstream: https://github.com/grafana/mimir
# Flags from tools/wal-reader/main.go on tip.

_wal-reader() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-print-series=[print series entries]:bool:(true false)' \
        '-print-samples[print samples, exemplars, metadata, tombstones]' \
        ':wal-dir:_files -/'
}

_wal-reader "$@"
