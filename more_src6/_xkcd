#compdef xkcd
# Documentation: https://github.com/anirudhajith/xkcd-cli
# Reference accessed: 2026-05-21
# Verified: multiple competing upstream tools share this name; the most common
# `xkcd` shell CLI takes only a positional COMIC_INDEX (or none for latest).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '*:comic id or empty for latest: ' && ret=0

return ret
