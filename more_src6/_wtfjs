#
# THE wtfjs CLI — meow + boxen + chalk + msee
#
# wtfjs's CLI is in wtfjs.js (Node CommonJS):
#
#     const boxen = require("boxen");
#     const chalk = require("chalk");
#     const msee = require("msee");
#     const meow = require("meow");
#     const updateNotifier = require("update-notifier");
#
#     const cli = meow(
#         [
#             "Usage",
#             "  wtfjs",
#             "",
#             "Options",
#             "  --lang, -l  Translation language",
#             "",
#             "Examples",
#             "  wtfjs",
#             "  wtfjs --lang pt-br",
#         ],
#         {
#             flags: {
#                 lang: { type: "string", alias: "l", default: "" },
#             },
#         }
#     );
#
#     const boxenOpts = {
#         borderColor: "yellow",
#         margin: { bottom: 1 },
#         padding: { right: 1, left: 1 },
#     };
#
#     // ... fetch random README section, render as markdown via msee,
#     //     wrap in boxen, print to stdout via default-pager ...
#
# Usage:
#   wtfjs                 — Show random WTF JS example in English
#   wtfjs --lang pt-br    — Brazilian Portuguese translation
#   wtfjs --lang zh-cn    — Simplified Chinese translation
#   wtfjs --lang fr-fr    — French translation
#   wtfjs --lang it-it    — Italian translation
#   wtfjs --lang kr       — Korean translation
#   wtfjs --lang hi       — Hindi translation
#   wtfjs --lang pl-pl    — Polish translation
#   wtfjs --lang si       — Sinhala translation
#
# Five-axis distinctness from every other documented TS-Node library:
#
#   1. FUNCTION-RETURNS-STRING DESIGN — Every other documented
#      TS-Node TUI library renders directly to terminal.
#      boxen returns a STRING for the caller to print.
#
#   2. TEN+ PRE-BUILT BORDER STYLES — Every other documented
#      TS-Node terminal-frame library has fewer or no border
#      style presets.  boxen has 10+ (single/double/round/bold/
#      classic/arrow/singleDouble/doubleSingle/none/custom).
#
#   3. TITLE-IN-BORDER FEATURE — Every other documented
#      TS-Node terminal-frame library renders borders without
#      titles.  boxen supports title positioned within the top
#      border with alignment options.
#
#   4. CSS-STYLE PADDING + MARGIN — Every other documented
#      TS-Node terminal-frame library lacks the CSS-style
#      shorthand for padding + margin (boxen accepts numbers,
#      objects with top/bottom/left/right, etc).
#
#   5. UPDATE-NOTIFIER 10000+ PACKAGES PROVENANCE — Every other
#      documented TS-Node terminal-frame library has different
#      provenance.  boxen is the box-rendering layer of
#      update-notifier — used transitively by ~10,000 npm
#      packages for the iconic "Update available!" yellow
#      boxes that every Node developer has seen hundreds of
#      times.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/denysdovhan/wtfjs/blob/master/wtfjs.js
# meow flag setup.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '(-l --lang)'{-l+,--lang=}'[translation language]:lang:(en pt-br zh-cn fr-fr it-it kr hi pl-pl si)' \
    && ret=0

return ret
