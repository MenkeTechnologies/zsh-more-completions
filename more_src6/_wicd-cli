#compdef wicd-cli
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man8/wicd-cli.8.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# wicd-cli: WICD network manager CLI (legacy)
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show summary of options]' \
  '(-y --wireless)'{-y,--wireless}'[use the wireless interface]' \
  '(-z --wired)'{-z,--wired}'[use the wired interface]' \
  '(-S --scan)'{-S,--scan}'[scan available wireless networks]' \
  '(-w --save)'{-w,--save}'[save the network connection profile]' \
  '(-l --list-networks)'{-l,--list-networks}'[list networks WICD has in its cache]' \
  '(-c --connect)'{-c,--connect}'[connect to the selected network]' \
  '(-x --disconnect)'{-x,--disconnect}'[disconnect from the current network]' \
  '(-n --network)'{-n,--network}'=[target network by ID]:id' \
  '(-d --network-details)'{-d,--network-details}'[show details of selected network]' \
  '(-p --network-property)'{-p,--network-property}'=[display a specific network property]:property' \
  '(-s --set-to)'{-s,--set-to}'=[assign a value to the selected property]:value' \
  '(-m --name)'{-m,--name}'=[profile name for loading/saving]:name' \
  '(-e --list-encryption-types)'{-e,--list-encryption-types}'[view supported encryption templates]' \
  '(-o --load-profile)'{-o,--load-profile}'[load a wired connection profile]' && ret=0

return ret
