#compdef weeder
# Documentation: https://github.com/ocharles/weeder
# Reference accessed: 2026-05-21
# Verified: upstream src/Weeder/Main.hs optparse-applicative definitions.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--config=[Weeder configuration file]:config file:_files' \
  '--hie-extension=[extension for HIE files]:ext:' \
  '*--hie-directory=[directory to search for .hie files]:directory:_directories' \
  '--require-hs-files[skip .hie files without matching .hs modules]' \
  '--write-default-config[generate a default config if missing]' \
  '--no-default-fields[disable default field values for missing config entries]' \
  '-j+[number of cores to use]:n:' \
  '-N[use all available cores]' && ret=0

return ret
