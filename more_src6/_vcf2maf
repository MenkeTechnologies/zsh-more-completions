#compdef vcf2maf
# Documentation: https://github.com/mskcc/vcf2maf
# Source: mskcc/vcf2maf vcf2maf.pl — VCF→MAF converter with VEP annotation (Perl, Getopt::Long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(- *)--help[show help]' \
    '(- *)--man[show full manual]' \
    '--verbose[verbose output]' \
    '--input-vcf=[input VCF file]:file:_files -g "*.{vcf,vcf.gz}"' \
    '--output-maf=[output MAF file]:file:_files' \
    '--tmp-dir=[temporary directory]:dir:_files -/' \
    '--tumor-id=[tumor sample name]:id:_default' \
    '--normal-id=[normal sample name]:id:_default' \
    '--vcf-tumor-id=[tumor column name in VCF]:id:_default' \
    '--vcf-normal-id=[normal column name in VCF]:id:_default' \
    '--custom-enst=[file of custom ENST IDs to retain]:file:_files' \
    '--vep-path=[VEP installation directory]:dir:_files -/' \
    '--vep-data=[VEP cache data directory]:dir:_files -/' \
    '--vep-forks=[number of parallel VEP forks (default 4)]:n:_default' \
    '--vep-custom=[VEP custom annotation files]:list:_default' \
    '--vep-config=[VEP config file]:file:_files' \
    '--vep-plugins=[VEP plugins]:list:_default' \
    '--vep-overwrite[overwrite existing VEP annotated VCF]' \
    '--vep-stats[generate VEP stats]' \
    '--buffer-size=[VEP variant buffer (default 5000)]:n:_default' \
    '--any-allele[report annotation for any matching allele]' \
    '--inhibit-vep[skip VEP and assume input is already annotated]' \
    '--online[use VEP online lookup]' \
    '--ref-fasta=[reference FASTA used by VEP]:file:_files -g "*.{fa,fasta,fa.gz,fasta.gz}"' \
    '--species=[Ensembl species name]:species:_default' \
    '--ncbi-build=[NCBI build (GRCh37/GRCh38)]:build:(GRCh37 GRCh38)' \
    '--cache-version=[VEP cache version]:n:_default' \
    '--maf-center=[MAF center column value]:center:_default' \
    '--retain-info=[INFO fields to retain in MAF]:fields:_default' \
    '--retain-fmt=[FORMAT fields to retain in MAF]:fields:_default' \
    '--retain-ann=[VEP ANN fields to retain]:fields:_default' \
    '--min-hom-vaf=[minimum homozygous VAF (default 0.7)]:n:_default' \
    '--remap-chain=[liftover chain file]:file:_files' \
    '--max-subpop-af=[max sub-population AF (default 0.0004)]:n:_default' \
    '--samtools-exec=[samtools executable]:path:_files' \
    '--tabix-exec=[tabix executable]:path:_files' \
    '--liftover-exec=[liftover executable]:path:_files' \
    && ret=0

return ret
