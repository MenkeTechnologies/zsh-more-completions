#compdef vmtouch
# Documentation: https://github.com/hoytech/vmtouch/blob/master/vmtouch.pod
# Reference accessed: 2026-05-21
# Verified: upstream POD manpage at the URL above.

# Zsh completion for vmtouch - portable file system cache diagnostics and control

_arguments -s -S \
  '-t[touch (bring pages into cache by reading one byte per page)]' \
  '-e[evict mapped pages from filesystem cache]' \
  '-l[lock pages into physical memory with mlock]' \
  '-L[lock pages into memory with mlockall]' \
  '-d[daemon mode (requires -l or -L)]' \
  '-m+[max file size to process]:max size:' \
  '-p+[map portion of file specified by range]:range:' \
  '-f[follow symbolic links]' \
  '-F[do not recurse into separate filesystems]' \
  '*-i+[ignore files/dirs matching pattern]:pattern:' \
  '*-I+[only process files matching pattern]:pattern:' \
  '-b+[read list of files from file]:list file:_files' \
  '-0[NUL-byte delimiters in batch mode]' \
  '-P+[PID file (requires -l or -L)]:pidfile:_files' \
  '-v[verbose: print every file processed]' \
  '-q[quiet: suppress end-of-crawl summary]' \
  '-h[double-count files with multiple hard links]' \
  '*:file:_files'
