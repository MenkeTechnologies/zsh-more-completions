#compdef terratag
# Documentation: https://github.com/env0/terratag
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above. Terratag uses Go-style
# single-dash flags (e.g. -dir=...) with one exception (--keep-existing-tags).

_arguments -s \
  '-tags=[JSON or comma-separated tags to apply]:tags:' \
  '-dir=[directory containing Terraform files]:dir:_files -/' \
  '-skipTerratagFiles=[process existing *.terratag.tf files]:bool:(true false)' \
  '-rename=[create *.terratag.tf or keep original filenames]:bool:(true false)' \
  '-filter=[apply tags only to matching resource types]:regex:' \
  '-skip=[exclude resource types from tagging]:regex:' \
  '-verbose[enable detailed logging output]' \
  '-type=[tool type]:type:(terraform terragrunt terragrunt-run-all)' \
  '-default-to-terraform[use Terraform when OpenTofu is installed]' \
  '--keep-existing-tags[preserve existing tags during merge]' \
  '*:files or dirs:_files -/'
