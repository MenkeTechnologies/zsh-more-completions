#compdef writable-cgroups
# _writable-cgroups — containerd NRI sample plugin: keeps the container's cgroup writable (nsdelegate-aware) so workloads can self-manage cgroups
# upstream: https://github.com/containerd/nri
# Flags from plugins/writable-cgroups/writable-cgroups.go on tip.

_writable-cgroups() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--idx=[plugin index to register to NRI]:n:' \
        '--socket-path=[path of the NRI socket file]:socket:_files' \
        '--host-mount-file=[host mountinfo file to inspect for nsdelegate]:file:_files' \
        '--verbose[enable verbose logging]'
}

_writable-cgroups "$@"
