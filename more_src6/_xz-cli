#compdef xz-cli unxz-cli xzcat-cli lzma-cli unlzma-cli lzcat-cli
# _xz-cli — Lasse Collin XZ Utils LZMA compression CLI alias (tukaani-project team, C); custom argparse
# upstream: https://github.com/tukaani-project/xz

_xz-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-H[long help]' \
        '--long-help[long help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-z[compress]' \
        '--compress[compress]' \
        '-d[decompress]' \
        '--decompress[decompress]' \
        '--uncompress[decompress]' \
        '-t[test integrity]' \
        '--test[test integrity]' \
        '-l[list info]' \
        '--list[list info]' \
        '-c[output to stdout]' \
        '--stdout[output to stdout]' \
        '--to-stdout[output to stdout]' \
        '-f[force overwrite]' \
        '--force[force overwrite]' \
        '-k[keep input files]' \
        '--keep[keep input files]' \
        '-q[suppress warnings]' \
        '--quiet[suppress warnings]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--no-warn[no warning on non-fatal]' \
        '--robot[robot mode]' \
        '-T+[threads]:n:' \
        '--threads=+[threads]:n:' \
        '-Q[no warning on non-fatal]' \
        '-0[level 0]' \
        '-1[level 1]' \
        '-2[level 2]' \
        '-3[level 3]' \
        '-4[level 4]' \
        '-5[level 5]' \
        '-6[level 6]' \
        '-7[level 7]' \
        '-8[level 8]' \
        '-9[level 9]' \
        '--fast[level 0]' \
        '--best[level 9]' \
        '-e[extreme compression]' \
        '--extreme[extreme compression]' \
        '-M+[memory limit]:str:' \
        '--memlimit=+[memory limit]:str:' \
        '--memlimit-compress=+[memory limit]:str:' \
        '--memlimit-decompress=+[memory limit]:str:' \
        '-F+[format]:f:(auto xz lzma raw)' \
        '--format=+[format]:f:(auto xz lzma raw)' \
        '-C+[check]:c:(none crc32 crc64 sha256)' \
        '--check=+[check]:c:(none crc32 crc64 sha256)' \
        '--ignore-check[ignore check]' \
        '-Z[same as -1]' \
        '-S+[suffix]:str:' \
        '--suffix=+[suffix]:str:' \
        '--files=+[file list]:file:_files' \
        '--files0=+[file list null]:file:_files' \
        '--block-size=+[size]:str:' \
        '--block-list=+[sizes]:str:' \
        '--flush-timeout=+[ms]:n:' \
        '--no-adjust[no adjust]' \
        '--single-stream[single stream]' \
        '--no-sparse[no sparse]' \
        '--lzma1=+[options]:str:' \
        '--lzma2=+[options]:str:' \
        '--delta=+[dist]:str:' \
        '--x86=+[start_offset]:str:' \
        '--powerpc=+[start_offset]:str:' \
        '--ia64=+[start_offset]:str:' \
        '--arm=+[start_offset]:str:' \
        '--armthumb=+[start_offset]:str:' \
        '--arm64=+[start_offset]:str:' \
        '--sparc=+[start_offset]:str:' \
        '*:files:_files -g "*.{xz,lzma,tar.xz,txz}"'
}

_xz-cli "$@"
