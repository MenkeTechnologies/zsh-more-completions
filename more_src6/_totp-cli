#compdef totp-cli
# Documentation: https://github.com/yitsushi/totp-cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'add-token:add a new token'
      'add:add a new token (alias)'
      'change-password:change storage password'
      'delete:delete a token or namespace'
      'dump:dump all tokens'
      'generate:generate a TOTP code'
      'g:generate (alias)'
      'import:import tokens from YAML file'
      'instant:generate code without storage'
      'list:list namespaces or accounts'
      'rename:rename an account or namespace'
      'set-length:set token length'
      'set-prefix:set token namespace prefix'
      'help:show help'
    )
    _describe -t commands 'totp-cli command' commands && ret=0
    ;;
  args)
    case $line[1] in
      add-token|add|delete|generate|g|rename|set-length|set-prefix)
        _arguments -s -S \
          '1:namespace:' \
          '2:account:' && ret=0
        ;;
      list)
        _arguments -s -S \
          '1:namespace:' && ret=0
        ;;
      import)
        _arguments -s -S \
          '1:file:_files -g "*.yaml *.yml"' && ret=0
        ;;
      instant)
        _arguments -s -S \
          '1:token:' && ret=0
        ;;
    esac
    ;;
esac

return ret
