#compdef zfs-driver
# _zfs-driver — OpenEBS ZFS-LocalPV CSI driver (provisions PVs backed by ZFS pools / datasets / zvols; runs as controller or node plugin)
# upstream: https://github.com/openebs/zfs-localpv
# Flags from cmd/main.go on tip (cobra).

_zfs-driver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--nodename=[Nodename identifying the node running this driver]:name:' \
        '--version=[display driver version]:ver:' \
        '--endpoint=[CSI endpoint]:uri:' \
        '--name=[name of this driver]:name:' \
        '--plugin=[type of this driver]:type:(controller agent csi-plugin)' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_zfs-driver "$@"
