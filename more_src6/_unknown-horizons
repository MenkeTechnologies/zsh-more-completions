#compdef unknown-horizons
# Documentation: https://github.com/unknown-horizons/unknown-horizons/blob/master/horizons/util/cmdlineoptions.py
# Reference accessed: 2026-05-21
# Verified: upstream cmdlineoptions.py add_option() calls.
# Removed from prior file: --load-quicksave (real is --load-last-quicksave),
# --start-specific-map (real is --start-specific-random-map), --no-fife-cache
# (not in source - real is --no-preload), --enable-unstable-features (invented),
# --profile (invented), --unstable-singleplayer (invented), --atlas-generation
# (invented; only --no-atlas-generation is real), --no-sound (real is --no-audio).

# Unknown Horizons: 2D real-time strategy
local curcontext="$curcontext" ret=1
_arguments -C \
  '-d[enable debug]' \
  '--debug[enable debug]' \
  '--debug-log-only[debug only to log file]' \
  '--debug-module=[enable debug for module]:module:' \
  '--fife-path=[fife engine path]:dir:_files -/' \
  '--restore-settings[restore default settings]' \
  '--mp-master=[multiplayer master server URL]:url:' \
  '--mp-bind=[local multiplayer bind address]:host:' \
  '--ai-players=[number of AI players]:n:' \
  '--human-ai-hybrid[human-AI hybrid mode]' \
  '--force-player-id=[force player id]:id:' \
  '--ai-highlights[show AI highlights]' \
  '--ai-combat-highlights[show AI combat highlights]' \
  '--start-dev-map[start with developer map]' \
  '--start-random-map[start with random map]' \
  '--start-specific-random-map=[load specific random map]:seed:' \
  '--start-map=[load map by name]:map:' \
  '--start-scenario=[load scenario]:scenario:' \
  '--load-game=[load named save]:save:' \
  '--load-last-quicksave[load latest quicksave]' \
  '--edit-map=[open map editor on named map]:map:' \
  '--edit-game-map=[open map editor on a game'\''s map]:save:' \
  '--generate-minimap=[generate minimap]:map:' \
  '--create-mp-game[host a multiplayer game]' \
  '--join-mp-game[join a multiplayer game]' \
  '--game-speed=[set game speed]:speed:' \
  '--gui-test=[run a GUI test]:name:' \
  '--gui-log=[log GUI events]:file:_files' \
  '--logfile=[log to file]:file:_files' \
  '--max-ticks=[max ticks before exit]:n:' \
  '--no-audio[disable audio]' \
  '--no-preload[disable preload]' \
  '--no-freeze-protection[disable freeze protection]' \
  '--no-atlas-generation[disable atlas generation]' \
  '--sp-seed=[singleplayer RNG seed]:seed:' \
  '--string-previewer[run the string previewer]' \
  '*::extra args:_files' && ret=0
return ret
