#compdef water
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/water.html
# Reference accessed: 2026-05-21
# Verified: upstream EMBOSS docs at the URL above.

# EMBOSS water: Smith-Waterman local pairwise alignment
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' \
  '-auto[turn off prompts]' \
  '-stdout[write output to stdout]' \
  '-filter[read from stdin, write to stdout]' \
  '-options[prompt for all values]' \
  '-debug[generate debug output]' \
  '-verbose[report command-line options]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-die[report dying messages]' \
  '-version[show version]' \
  '-outfile=[output alignment file]:file:_files' \
  '-asequence=[first sequence]:file:_files' \
  '-bsequence=[second sequence(s)]:file:_files' \
  '-datafile=[scoring matrix file]:file:_files' \
  '-gapopen=[gap opening penalty (0.0-100.0)]:score:' \
  '-gapextend=[gap extension penalty (0.0-10.0)]:score:' \
  '-brief[brief identity/similarity output]' \
  '-nobrief[disable brief output]' \
  '-aformat=[alignment output format]:fmt:(pair markx0 markx1 markx2 markx3 markx10 match sam bam score srspair)' \
  '*:sequence:_files' && ret=0

return ret
