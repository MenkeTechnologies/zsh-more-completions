#compdef vertica-operator
# _vertica-operator — Vertica Kubernetes operator (reconciles VerticaDB + VerticaAutoscaler + VerticaReplicator + VerticaScrutinize + VerticaRestorePointsQuery + EventTrigger CRs)
# upstream: https://github.com/vertica/vertica-kubernetes
# Source: cmd/operator/main.go on tip; no CLI flags — runtime config via env vars resolved by pkg/opcfg (VERTICA_K8S_NAMESPACE, CONTROLLERS_SCOPE, CONTROLLERS_ENABLED, WEBHOOKS_ENABLED, CACHE_ENABLED, WEBHOOK_CERT_SECRET, USE_CERT_MANAGER, IS_OLM_DEPLOYMENT, METRICS_TLS_SECRET, METRICS_ADDR, LOGGING_FILEPATH, LEADER_ELECTION_ID, VDB_MAX_BACKOFF_DURATION, SANDBOX_MAX_BACKOFF_DURATION, BROADCASTER_BURST_SIZE).

_vertica-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]'
}

_vertica-operator "$@"
