#compdef unimatrix
# Documentation: https://github.com/will8211/unimatrix
# Reference accessed: 2026-05-21
# Verified: upstream unimatrix.py argparse declarations.

# Zsh completion for unimatrix - Matrix terminal effect with Unicode

_arguments -s -S \
  '(- *)'{-h,--help}'[display extended usage information and exit]' \
  '(-a --asynchronous)'{-a,--asynchronous}'[use asynchronous scrolling]' \
  '(-b --all-bold)'{-b,--all-bold}'[use all bold characters]' \
  '(-c --color)'{-c+,--color=}'[text color]:color:(green red blue white yellow cyan magenta black)' \
  '(-f --flashers)'{-f,--flashers}'[some characters continuously change in place]' \
  '(-g --bg-color)'{-g+,--bg-color=}'[background color]:color:(green red blue white yellow cyan magenta black)' \
  '(-i --ignore-keyboard)'{-i,--ignore-keyboard}'[ignore all keyboard input]' \
  '(-l --character-list)'{-l+,--character-list=}'[character set]:chars:' \
  '(-n --no-bold)'{-n,--no-bold}'[do not use bold characters]' \
  '(-o --status-off)'{-o,--status-off}'[disable on-screen status]' \
  '(-s --speed)'{-s+,--speed=}'[speed (0-100, default 85)]:speed:' \
  '(-t --time)'{-t+,--time=}'[exit after N seconds]:seconds:' \
  '(-u --custom-characters)'{-u+,--custom-characters=}'[custom characters to display]:chars:' \
  '(-w --single-wave)'{-w,--single-wave}'[run a single wave then exit]'
