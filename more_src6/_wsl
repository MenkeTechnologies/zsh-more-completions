#compdef wsl wsl.exe
# _wsl — Microsoft WSL launcher (Windows Subsystem for Linux; subcommands: --install, --update, --list/-l (with --all/--running/--quiet/--verbose), --set-default/-s, --terminate/-t, --shutdown, --import/--export, --unregister, --set-version, --status, --uninstall, --user, --cd; positional argument is a distro name then optional command)
# upstream: https://github.com/microsoft/WSL
# Flags from WSL wsl.exe on tip.

_wsl() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--install[install default distro]' \
        '--update[update WSL kernel]' \
        '--shutdown[shutdown all distros + VM]' \
        '--status[show WSL status]' \
        '-l[list distros]' \
        '--list[list distros]' \
        '--all[(--list) include not-running]' \
        '--running[(--list) only running]' \
        '--quiet[(--list) quiet]' \
        '--verbose[(--list) verbose]' \
        '--online[(--list) online available distros]' \
        '-s+[set default distro]:distro:' \
        '--set-default+[set default distro]:distro:' \
        '-t+[terminate distro]:distro:' \
        '--terminate+[terminate distro]:distro:' \
        '--unregister+[unregister distro]:distro:' \
        '--import+[name installdir tarball]:name installdir tarball:' \
        '--export+[distro file]:distro file:' \
        '--set-version+[distro version]:distro version:' \
        '--set-default-version+[version]:version:(1 2)' \
        '-d+[run in distro]:distro:' \
        '--distribution+[run in distro]:distro:' \
        '-u+[run as user]:user:_users' \
        '--user+[run as user]:user:_users' \
        '--cd+[start cwd]:dir:_files -/' \
        '--exec[exec without shell]' \
        '-e[exec without shell]' \
        '--uninstall[uninstall WSL]' \
        '*::command:_command_names -e'
}

_wsl "$@"
