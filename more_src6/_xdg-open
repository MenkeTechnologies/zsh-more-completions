#compdef xdg-open
# _xdg-open — XDG xdg-open (open a file or URL in the user's preferred app; honors $BROWSER for http(s); auto-detects KDE/GNOME/Xfce/MATE/LXDE/Cinnamon/MATE through generic_open helpers)
# upstream: https://gitlab.freedesktop.org/xdg/xdg-utils
# Argument shape from xdg-utils scripts/xdg-open.in on tip.

_xdg-open() {
    _arguments \
        '--help[show help]' \
        '--manual[show full manual]' \
        '--version[show version]' \
        '1:file or URL:_files'
}

_xdg-open "$@"
