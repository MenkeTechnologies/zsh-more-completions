#compdef waybackpy
# Documentation: https://github.com/akamhy/waybackpy/wiki/CLI-docs
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# akamhy/waybackpy — Click CLI (`waybackpy/cli.py`)

local ret=1
_arguments -s -S \
  '(-u)'{-u+,--url=}'[target URL]:url:_urls' \
  '-ua+,--user-agent=,--user_agent=[HTTP User-Agent]:agent:' \
  '(-v)'{-v,--version}'[print waybackpy version]' \
  '-l,--show-license,--show_license,--license[print MIT license text]' \
  '(-n)'{-n,--newest,-au,--archive-url,--archive_url}'[newest snapshot URL]' \
  '(-o)'{-o,--oldest}'[oldest snapshot URL]' \
  '(-N)'{-N,--near}'[snapshot near datetime components]' \
  '-Y+,--year=[near year]:year:' \
  '-M+,--month=[near month]:month:' \
  '-D+,--day=[near day]:day:' \
  '-H+,--hour=[near hour]:hour:' \
  '-MIN+,--minute=[near minute]:minute:' \
  '(-s)'{-s,--save}'[Save Page Now + print archive URL]' \
  '(-h)'{-h,--headers}'[with --save: dump Save API headers]' \
  '-ku,--known-urls,--known_urls[list known URLs for site]' \
  '-sub,--subdomain[with known URLs: include subdomains]' \
  '--file[with known URLs: write url-per-line file in CWD]' \
  '--cdx[use CDX Server API output mode]' \
  '--start-timestamp=,--start_timestamp=,--from+[CDX start ts yyyymmddhhmmss]:ts:' \
  '--end-timestamp=,--end_timestamp=,--to+[CDX end ts]:ts:' \
  '-C+,--closest=[CDX closest timestamp]:ts:' \
  '*--cdx-filter=*,--cdx_filter=*,--filter=*[CDX filter (repeatable)]:filter:' \
  '-mt+,--match-type=,--match_type=[CDX match type]:match:' \
  '--sort=[CDX sort: default/closest/reverse]:sort:(default closest reverse)' \
  '-up,--use-pagination,--use_pagination[CDX pagination API]' \
  '-gz+,--gzip=[CDX gzip boolean string]:gzip:' \
  '*-c+,--collapse=*[CDX collapse spec (repeatable)]:collapse:' \
  '--limit=[CDX records per request]:limit:' \
  '*-cp+,--cdx-print=*,--cdx_print=*[CDX output fields (repeatable)]:field:' && ret=0
return ret
