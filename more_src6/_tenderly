# WHAT IT IS
#   Tenderly CLI is "a suite of development tools for smart
#   contracts" — Tenderly's local-side companion for the
#   tenderly.co SaaS that lets developers monitor, debug, and
#   observe EVM smart contracts on any network.  The driver
#   bundles project lifecycle (`init`, `login`, `logout`,
#   `whoami`), contract management (`push`, `verify`, `export`),
#   nested Web3 Actions workflow (`actions init/publish/schema/
#   validate`), Tenderly DevNets (`devnet spawn-rpc`), Tenderly
#   Extensions (`extensions init/deploy/config`), and explicit
#   project-config plumbing (`--project-config`, `--global-
#   config`, `--project-dir`).  Auto-detects Truffle, Hardhat,
#   Buidler, OpenZeppelin, and Brownie projects.
#
# CLI ARGUMENT GRAMMAR  (verbatim from commands/root.go
#                       RootCmd.PersistentFlags and the per-
#                       command `commands/<name>.go` files —
#                       spf13/cobra v1.4.0)
#   tenderly [GLOBAL OPTIONS] <SUBCOMMAND> [args...]
#
#   Global options (persistent on every subcommand):
#     --debug                        Turn on debug-level logging
#     --reset-provider               Clear set deployment provider
#                                    (otherwise uses provider from
#                                    tenderly.yaml)
#     --output <MODE>                Output mode (text|json)
#                                    [default: text]
#     --global-config <NAME>         Global config file name (no
#                                    extension)  [default: config]
#     --project-config <NAME>        Project config file name (no
#                                    extension)  [default: tenderly]
#     --project-dir <DIR>            Project directory
#                                    [default: .]
#
#   Subcommands:
#     init                           Initialize Tenderly config
#                                    for the current project
#       --project <NAME>               Project for the generated
#                                      config
#       --create-project               Create the project if it
#                                      doesn't exist
#       --re-init                      Force re-initialize an
#                                      already-initialized project
#       --force                        Skip the Truffle layout
#                                      check
#
#     login                          Log in to your Tenderly account
#       --email <EMAIL>                Email login
#       --password <PASS>              Password login
#       --access-key <KEY>             Dashboard-generated access
#                                      key
#       --authentication-method <M>    `email` or `access-key`
#       --force                        Don't check existing login
#
#     logout                         Log out of Tenderly
#
#     whoami                         Show the currently logged-in
#                                    user
#
#     push                           Push project contracts to
#                                    Tenderly
#       --tag <TAG>                    Optional deployment tag
#       --networks <CSV>               Comma-separated network list
#       --project-slug <SLUG>          Tenderly project slug
#
#     verify                         Verify smart contracts on
#                                    Tenderly
#       --networks <CSV>               Comma-separated network list
#
#     export                         Export local txs/state
#       export init                    Initialize an export config
#
#     actions <SUBCOMMAND>           Web3 Actions workflow
#       init                           Initialize a new Action
#       publish                        Publish Actions
#       schema                         Print/manage Action schema
#       validate                       Validate Action source +
#                                      config
#
#     contract <SUBCOMMAND>          Smart-contract management
#       push / remove / verify         (mirror top-level actions)
#
#     devnet <SUBCOMMAND>            Tenderly DevNet management
#       spawn-rpc                      Spawn a DevNet RPC endpoint
#
#     extensions <SUBCOMMAND>        Tenderly Extensions
#       init / config / deploy
#
#     version                        Show CLI version
#
#   Standard cobra auto-flags:
#     -h, --help                     Show help
#
# AXIS / CORPUS POSITION
#   Direct dependency on `github.com/ethereum/go-ethereum
#   v1.10.26` declared in go.mod — `github.com/ethereum/go-
#   ethereum` is THE canonical Go Ethereum SDK maintained by the
#   Ethereum Foundation's geth team (ethereum/go-ethereum, 48K+
#   stars).  go-ethereum is the production Ethereum client
#   implementation in Go;  beyond running a full node, it
#   exposes the `accounts`, `common`, `consensus`, `core`,
#   `core/types`, `core/vm`, `crypto`, `eth`, `ethclient`,
#   `event`, `p2p`, `rlp`, `rpc`, and `trie` packages used by
#   every Go Ethereum tool.  Tenderly CLI's
#   `providers/contracts/contracts.go` uses
#   `common.HexToAddress`, `crypto.Keccak256`,
#   `core/types.Transaction`, and `accounts/abi.Method` to parse
#   compiled artifacts and project metadata for the Tenderly
#   API.  Verified via:
#     gh api repos/Tenderly/tenderly-cli/contents/go.mod
#       → github.com/ethereum/go-ethereum v1.10.26
#       → github.com/spf13/cobra v1.4.0
#       → module github.com/tenderly/tenderly-cli
#     gh api repos/Tenderly/tenderly-cli/contents/commands/
#         root.go
#       → RootCmd.Use = "tenderly"
#       → PersistentFlags: --debug, --reset-provider, --output,
#         --global-config, --project-config, --project-dir
#     gh api repos/Tenderly/tenderly-cli/contents/main.go
#       → _ "github.com/tenderly/tenderly-cli/commands/actions"
#       → _ "github.com/tenderly/tenderly-cli/commands/contract"
#       → _ "github.com/tenderly/tenderly-cli/commands/devnet"
#       → _ "github.com/tenderly/tenderly-cli/commands/
#           extensions"
#   This entry is the Go=142 leader bump that continues Axis 87
#   (Ethereum / alloy-rs Library) opened at R937 with Rust=alloy
#   via pawurb/mevlog-rs.
#
#   No completion for `tenderly` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_tenderly() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--debug[turn on debug-level logging]' \
        '--reset-provider[clear set deployment provider]' \
        '--output=[output mode]:mode:(text json)' \
        '--global-config=[global config file name (no extension)]:name:' \
        '--project-config=[project config file name (no extension)]:name:' \
        '--project-dir=[project directory]:dir:_files -/' \
        '1: :_tenderly_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                init)
                    _arguments \
                        '--project=[project for the generated config]:project:' \
                        '--create-project[create the project if it does not exist]' \
                        '--re-init[force re-initialize]' \
                        '--force[skip Truffle layout check]' && ret=0 ;;
                login)
                    _arguments \
                        '--email=[email login]:email:' \
                        '--password=[password login]:password:' \
                        '--access-key=[dashboard-generated access key]:key:' \
                        '--authentication-method=[authentication method]:method:(email access-key)' \
                        '--force[do not check existing login]' && ret=0 ;;
                push)
                    _arguments \
                        '--tag=[optional deployment tag]:tag:' \
                        '--networks=[comma-separated network list]:csv:' \
                        '--project-slug=[Tenderly project slug]:slug:' && ret=0 ;;
                verify)
                    _arguments \
                        '--networks=[comma-separated network list]:csv:' && ret=0 ;;
                export)
                    _arguments \
                        '1::export subcommand:(init)' \
                        '*::arg:' && ret=0 ;;
                actions)
                    _arguments \
                        '1:actions subcommand:(init publish schema validate)' \
                        '*::arg:' && ret=0 ;;
                contract)
                    _arguments \
                        '1:contract subcommand:(push remove verify)' \
                        '*::arg:' && ret=0 ;;
                devnet)
                    _arguments \
                        '1:devnet subcommand:(spawn-rpc)' \
                        '*::arg:' && ret=0 ;;
                extensions)
                    _arguments \
                        '1:extensions subcommand:(init config deploy)' \
                        '*::arg:' && ret=0 ;;
                whoami|logout|version)
                    _arguments && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_tenderly_commands] )) ||
_tenderly_commands() {
    local -a commands
    commands=(
        'init:initialize Tenderly config for the current project'
        'login:log in to your Tenderly account'
        'logout:log out of Tenderly'
        'whoami:show the currently logged-in user'
        'push:push project contracts to Tenderly'
        'verify:verify smart contracts on Tenderly'
        'export:export local txs/state'
        'actions:Web3 Actions workflow (init/publish/schema/validate)'
        'contract:smart-contract management (push/remove/verify)'
        'devnet:Tenderly DevNet management (spawn-rpc)'
        'extensions:Tenderly Extensions (init/config/deploy)'
        'version:show CLI version'
    )
    _describe -t commands 'tenderly command' commands
}

_tenderly "$@"
