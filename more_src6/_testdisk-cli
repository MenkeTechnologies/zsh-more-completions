#compdef testdisk-cli
# _testdisk-cli — Christophe Grenier TestDisk partition/file recovery tool CLI alias (cgsecurity team, C); custom argparse
# upstream: https://github.com/cgsecurity/testdisk

_testdisk-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '/log[enable log]' \
        '/nolog[disable log]' \
        '/debug[debug mode]' \
        '/all[search all disks]' \
        '/dump[dump partition data]' \
        '/cmd[batch mode]' \
        '/list[list disks]' \
        '*:device:_files -g "/dev/sd*"'
}

_testdisk-cli "$@"
