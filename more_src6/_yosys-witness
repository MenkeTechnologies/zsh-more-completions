#compdef yosys-witness
# Documentation: https://github.com/YosysHQ/yosys/blob/main/backends/smt2/witness.py
# Reference accessed: 2026-05-21
# Verified: upstream source (argparse subcommand definitions).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'display:display a Yosys witness trace human-readable'
  'stats:display statistics of a Yosys witness trace'
  'yw2yw:transform a witness trace (concatenate inputs)'
  'aiw2yw:convert AIGER witness to Yosys witness'
  'yw2aiw:convert Yosys witness to AIGER witness'
  'wit2yw:convert BTOR witness to Yosys witness'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  command)
    _describe -t commands 'yosys-witness command' commands && ret=0
    ;;
  args)
    case $words[1] in
      display|aiw2yw)
        _arguments \
          '--skip-x[leave x bits unassigned]' \
          '*:witness file:_files -g "*.(yw|aiw)"' && ret=0
        ;;
      yw2yw)
        _arguments \
          '*'{-p+,--append=}'[steps to append]:n:' \
          '--skip-x[leave input x bits unassigned]' \
          '*:witness file:_files -g "*.yw"' && ret=0
        ;;
      aiw2yw)
        _arguments \
          '--skip-x[leave input x bits unassigned]' \
          '--present-only[only bits present in at least one step]' \
          '*:witness file:_files' && ret=0
        ;;
      *)
        _files
        ;;
    esac
    ;;
esac
return ret
