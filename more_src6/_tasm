#compdef tasm
# Documentation: https://archive.org/details/bitsavers_borlandturemblerVersion4.0UsersGuideNov93_13508562
# Reference accessed: 2026-05-21
# Verified: Turbo Assembler 4.0 User's Guide.
# TASM: Borland Turbo Assembler (DOS x86); switches use / on DOS, listed here with -.

local curcontext="$curcontext" ret=1
_arguments -C \
  '-a[alphabetical segment order]' \
  '-b[buffer size (compat)]' \
  '-c[create cross-reference listing]' \
  '-d[define symbol]:symbol[=value]:' \
  '-e[emulate floating point]' \
  '(-h -\?)'{-h,-\?}'[show help]' \
  '*-i[include path]:dir:_files -/' \
  '-j[inject assembler directive]:directive:' \
  '-kh[max symbols]:n:' \
  '-l[create listing]' \
  '-la[expanded listing]' \
  '-m[passes]:n:' \
  '-ml[case-sensitive symbols]' \
  '-mu[upper-case symbols (default)]' \
  '-mx[case-sensitive externals/publics]' \
  '-n[suppress symbol table in listing]' \
  '-o[overlay-compatible fixups (TLINK)]' \
  '-oi[overlay fixups (IBM linker)]' \
  '-op[overlay fixups (Phar Lap)]' \
  '-os[standard TLINK objects (default)]' \
  '-p[check for impure protected mode]' \
  '-q[suppress dependency records]' \
  '-r[real 80x87 instructions]' \
  '-s[sequential segment order (default)]' \
  '-t[suppress success messages]' \
  '-u[target version]:ver:' \
  '-v[extra statistics (compat)]' \
  '-w[warning level]:spec:' \
  '-x[include false conditionals]' \
  '-z[show source line on error]' \
  '-zd[line-number debug info]' \
  '-zi[full debug info]' \
  '-zn[no debug info]' \
  '*:source file:_files -g "*.asm"' && ret=0
return ret
