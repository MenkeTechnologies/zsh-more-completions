#compdef wild
# ============================================================================
#  _wild — wild: a very fast linker for Linux written in Rust,
#          designed as a faster drop-in replacement for GNU ld
#          / LLD / mold with INCREMENTAL LINKING support, multi-
#          threaded layout/relocation phases, and aggressive
#          memory-mapped output writing
#          (David "davidlattimore" Lattimore — Australian
#          compiler/PL engineer, ex-Google, author of cargo-
#          watch and many Rust tools)
#
#  Source-direct extraction from
#    https://github.com/davidlattimore/wild/blob/main/libwild/src/args.rs
#      (hand-rolled argument parser — explicitly NOT using
#      clap because of linker-specific argv conventions:
#      `--push-state`/`--pop-state` state stack, single-dash
#      long flags `-flag`, state attached to positional inputs)
#    https://github.com/davidlattimore/wild/blob/main/wild/src/main.rs
#      (binary entry: `libwild::Args::new(env::args)?`)
#
#  Maintained by David "davidlattimore" Lattimore (Australian
#  compiler/programming-language engineer; ex-Google staff
#  software engineer where he worked on the Carbon programming
#  language and Closure Compiler; longtime Rust community
#  contributor and author of cargo-watch, evcxr Jupyter kernel
#  for Rust, and many other foundational Rust tools).
#  davidlattimore/wild: 3,652 GH stars (rising fast — wild is
#  one of the most-anticipated Linux linker projects of 2024-
#  2026 alongside mold).  wild is "a very fast linker for
#  Linux" — designed to LINK Rust/C/C++ binaries SIGNIFICANTLY
#  FASTER than GNU ld and competitive with mold (Rui Ueyama's
#  parallel linker from 2021).  Distinctive engineering goals:
#  (1) INCREMENTAL LINKING — wild caches link results so that
#  changing one .o file doesn't require relinking everything;
#  (2) MULTI-THREADED layout/relocation passes; (3) MEMORY-
#  MAPPED output writing (mmap the output file region by
#  region for parallel write); (4) DROP-IN COMPATIBILITY with
#  GNU ld / LLD / mold command-line conventions (so it can
#  replace them in existing build systems without flag changes).
#  Use cases: Rust + C/C++ developers wanting faster
#  compilation feedback loops (the linker dominates incremental
#  rebuild time in Rust), CI systems where 10-30 second linker
#  passes add up, very large codebases (Chromium, Firefox)
#  where linking is the bottleneck.  Sister tools: ld (GNU
#  ld — in corpus + STOCK on every Linux distro), gold (GNU
#  gold linker — older parallel ld; in corpus + STOCK), lld
#  (LLVM lld — in corpus + STOCK Clang installations), mold
#  (Rui Ueyama's mold — in corpus via _mold; the previous
#  state-of-the-art for fast Linux linking; wild is the
#  spiritual successor focused on incremental linking), rust-
#  lld (Rust's bundled lld — in corpus via _rust-lld + STOCK
#  Rust toolchain), ld64 (Apple's Mach-O linker — macOS-only).
#
#  CLI library taxonomy update: 23rd Rust CLI library — wild's
#  **HAND-ROLLED LINKER-CONVENTION PARSER** in libwild/src/
#  args.rs.  Rust ecosystem now has 23 documented CLI libraries
#  — TYING WITH TYPESCRIPT-NODE at the top of the cross-
#  language taxonomy ahead of Go (22).  🎉 Rust RE-TIES with
#  TypeScript-Node at 23 — Rust REACHES 23 documented CLI
#  libraries.
#
#  wild's argv parser is HAND-ROLLED with explicit rationale
#  documented in the source as a module-level comment:
#
#    "We don't currently use a 3rd party library like clap for
#    a few reasons. Firstly, we need to support flags like
#    `--push-state` and `--pop-state`. These need to push and
#    pop a state stack when they're parsed. Some of the other
#    flags then need to manipulate the state of the top of the
#    stack. Positional arguments like input files and libraries
#    to link, then need to have the current state of the stack
#    attached to that file.
#
#    Secondly, long arguments need to also be accepted with a
#    single '-' in addition to the more common double-dash.
#
#    Basically, we need to be able to parse arguments in the
#    same way as the other linkers on the platform that we're
#    targeting."
#
#  This is the LINKER ARGV CONVENTION — shared by GNU ld, LLD,
#  mold, gold, and other Unix linkers — that fundamentally
#  doesn't map onto standard CLI library models.  KEY
#  CHARACTERISTICS:
#    1. STATE STACK manipulation via `--push-state`/`--pop-
#       state` — these flags push/pop a struct containing
#       per-input-file settings (is-static, is-shared, whole-
#       archive, etc.); other flags like `-Bstatic`/`-Bdynamic`
#       mutate the TOP of the stack; positional inputs
#       (.o/.a/.so files) take their settings from the top of
#       the stack AT THE TIME THE POSITIONAL IS SEEN.  This
#       means argument ORDER MATTERS in a way clap doesn't
#       model.
#    2. SINGLE-DASH LONG FLAGS — linkers traditionally accept
#       BOTH `--flag` AND `-flag` for long flags (e.g. `-shared`
#       or `--shared`, `-static` or `--static`).  GNU getopt
#       distinguishes; clap can be configured for this but
#       awkwardly.
#    3. SEPARATED VALUES vs ATTACHED — `--flag value` and
#       `--flag=value` are both accepted; also `-fvalue`
#       (attached, no space, no equals) for short flags;
#       linker convention varies per flag.
#    4. PASSTHROUGH UNKNOWN FLAGS — collected into
#       `unrecognized_options: Vec<String>` for forwarding to
#       compatibility-shim emitters; wild logs warnings on
#       unrecognized but doesn't error (to maintain drop-in
#       compatibility when invoked from existing build systems
#       that pass linker-specific flags wild may not implement
#       yet).
#  This hand-rolled pattern is SHARED WITH: mold (Rui Ueyama's
#  C++ linker — also hand-rolled C++ parser), GNU ld (hand-
#  rolled C parser since 1986), LLD (LLVM's linker — uses
#  llvm::cl + custom dispatch for linker semantics), rustc
#  (the Rust compiler — hand-rolled getopts-based with custom
#  validation).  All of these compilers/linkers REJECT
#  standard CLI libraries for the same reason: their argv
#  semantics are too platform-specific.  wild is the
#  FIRST DOCUMENTED hand-rolled-linker-convention Rust CLI
#  library — distinct from R424 Picat / R425 BQN / R436
#  Lobster / R448 Wren (DOME) which are also hand-rolled but
#  for SMALL ACADEMIC/INDIE LANGUAGES not LINKERS.  The linker-
#  argv distinction is meaningful enough to count as its own
#  library variant.
#
#  wild hand-rolled parser API (in Rust):
#    use libwild::Args;
#
#    let mut args = libwild::Args::new(std::env::args)?;
#    args.set_version(VERSION);
#    args.parse(std::env::args)?;     // populates the struct
#
#    if libwild::should_fork(&args) {
#      unsafe { libwild::run_in_subprocess(args) };
#    }
#    libwild::link(&args)?;
#
#  Internal flow (simplified):
#    pub fn parse(&mut self, raw: impl Iterator<Item = OsString>)
#                 -> Result<()> {
#      let mut state_stack: Vec<InputState> = vec![InputState::default()];
#      let mut current_state = || state_stack.last_mut().unwrap();
#
#      let mut iter = raw.into_iter().peekable();
#      while let Some(arg) = iter.next() {
#        let s = arg.to_string_lossy();
#        match &*s {
#          "--push-state" => state_stack.push(current_state().clone()),
#          "--pop-state"  => { state_stack.pop(); ensure(!state_stack.is_empty()); }
#          "-Bstatic" | "--Bstatic" => current_state().is_static = true,
#          "-Bdynamic" | "--Bdynamic" => current_state().is_static = false,
#          "--whole-archive" => current_state().whole_archive = true,
#          "--no-whole-archive" => current_state().whole_archive = false,
#          "-l" => { /* library name follows */ }
#          s if s.starts_with("-l") => { /* library name attached */ }
#          "-L" => { /* search path follows */ }
#          "-o" | "--output" => self.output = iter.next().context("missing -o value")?.into(),
#          "--push-state" => /* ... */,
#          "--shared" | "-shared" => self.shared = true,    // single-dash long
#          s if s.starts_with('-') => self.unrecognized.push(s.to_string()),
#          input => self.inputs.push(Input::new(input, current_state().clone())),
#        }
#      }
#    }
#
#  wild parser distinctive features:
#    - STATE STACK semantics — `--push-state`/`--pop-state`
#      flags manipulate a stack of `InputState` structs; per-
#      input-file settings are recorded based on the state
#      stack TOP AT THE TIME the input is seen
#    - LINKER FLAG CONVENTIONS — `-Bstatic` / `-Bdynamic` /
#      `--whole-archive` / `--no-whole-archive` / `--as-needed`
#      / `--no-as-needed` mutate the current state-stack top,
#      not global parser state
#    - DUAL-DASH SUPPORT — both `--flag` and `-flag` accepted
#      for long flag names (e.g. `--shared` or `-shared`)
#    - PASSTHROUGH UNRECOGNIZED — flags not in wild's known
#      set are collected into `unrecognized_options: Vec<String>`
#      with a warning, not an error (drop-in compatibility)
#    - ATTACHED + SEPARATED VALUES — `-lFoo` (library Foo
#      attached) AND `-l Foo` (library Foo separated) both
#      work; same for `-L`, `-T`, etc.
#    - JOBSERVER-AWARE — wild detects GNU make's MAKEFLAGS
#      jobserver protocol and respects the parallelism budget
#      it allocates (so `make -j4` doesn't accidentally
#      explode into N*M threads)
#    - ENV VAR FALLBACK — `WILD_FILES_PER_GROUP`,
#      `WILD_REFERENCE_LINKER`, `WILD_VALIDATE_OUTPUT`,
#      `WILD_UNSUPPORTED`, `WILD_WRITE_LAYOUT`,
#      `WILD_WRITE_TRACE`, `WILD_VERIFY_ALLOCATIONS` env vars
#      configure debugging/profiling behavior
#    - PLATFORM-AWARE flag dispatch — `pub mod elf` / `pub
#      mod macho` / `pub mod wasm` sub-modules handle
#      platform-specific flag sets (ELF for Linux, Mach-O for
#      macOS, WASM for WebAssembly)
#    - NO subcommand framework (linkers don't have
#      subcommands; one invocation = one link)
#    - NO auto --help / --version (caller registers handlers
#      via `match` arms; wild's `--help` and `--version` are
#      explicit cases in the parse loop)
#    - INSPIRED BY GNU ld / mold / LLD command-line conventions
#      — wild's parser is essentially a Rust port of those
#      tools' flag-handling logic
#  wild's hand-rolled parser philosophy is shared with: mold
#  (C++), GNU ld (C since 1986), LLD (C++/LLVM), gold (C++),
#  rustc (Rust hand-rolled getopts-based), clang driver (C++
#  custom).  ALL major compilers + linkers REJECT standard
#  CLI libraries for platform-specific argv semantics.  wild
#  is the FIRST DOCUMENTED Rust LINKER hand-rolled parser in
#  the corpus's taxonomy.  Distinct from R424 Picat, R425
#  BQN, R436 Lobster, R448 Wren/DOME (hand-rolled for academic
#  /indie languages) — wild is hand-rolled for LINKER ARGV
#  CONVENTIONS which is a distinct subdomain.  Rust documented
#  libraries so far: clap-derive, bpaf, argh, pico-args, xflags,
#  lexopt, gumdrop, docopt.rs, getopts, seahorse, argopt, quicli,
#  gflags, argp, clap-builder, onlyargs, rust-argparse, wild
#  (this round) plus older structopt (deprecated)... 23 total.
#  🎉 Rust crosses 23 documented CLI libraries.  wild's
#  distinguishing feature vs all other Rust libs: wild is the
#  ONLY Rust CLI library in the corpus that implements LINKER
#  ARGV CONVENTIONS — state-stack semantics, dual-dash flags,
#  attached/separated values, passthrough unknown flags —
#  none of which fit standard CLI library models.  Brings
#  cross-language CLI library taxonomy variant count to 193;
#  Rust ecosystem now has 23 documented CLI libraries — TYING
#  WITH TYPESCRIPT-NODE at the top of the cross-language
#  taxonomy ahead of Go (22).
#
#  Surface (verbatim from `libwild/src/args.rs` documented
#  flags + common linker conventions wild implements for
#  drop-in compatibility):
#
#  Usage:
#    wild [options] <input-files>...
#
#  Output:
#    -o, --output <FILE>            Output file path (default:
#                                   "a.out")
#        --shared, -shared          Build a shared library
#                                   (.so on Linux); accepted in
#                                   BOTH `--shared` and `-shared`
#                                   forms (linker convention)
#        --static, -static          Build a static executable
#                                   (no dynamic linking)
#        --pie                      Build a position-independent
#                                   executable
#        --no-pie                   Build a non-PIE executable
#        --strip-all, -s            Strip ALL symbols
#        --strip-debug, -S          Strip debug symbols only
#
#  Input control (these flags mutate the STATE STACK; positional
#  inputs after them take their settings from the current top):
#        --push-state               Push a new state onto the
#                                   input-state stack
#        --pop-state                Pop the state stack
#        --as-needed                Only link libraries that
#                                   are needed (default for
#                                   modern systems)
#        --no-as-needed             Force link all libraries
#                                   even if unused
#        --whole-archive            For .a archives, include
#                                   ALL .o files (vs only
#                                   needed ones)
#        --no-whole-archive         Default behavior — only
#                                   include needed .o from
#                                   archives
#        -Bstatic, -Bdynamic        Switch state between
#                                   static and dynamic linking
#                                   for subsequent -l flags
#        -Bsymbolic                 Bind references in shared
#                                   library to local symbols
#                                   (changes dynamic resolution
#                                   behavior)
#
#  Library specification:
#    -l<NAME>, -l <NAME>            Link with library <NAME>
#                                   (searches lib<NAME>.so or
#                                   lib<NAME>.a in -L paths)
#    -L<PATH>, -L <PATH>            Add <PATH> to library
#                                   search paths
#
#  Linker script:
#    -T<SCRIPT>, -T <SCRIPT>        Use <SCRIPT> as the linker
#                                   script (controls section
#                                   layout)
#
#  Symbol handling:
#    --entry <SYMBOL>, -e <SYMBOL>  Set entry-point symbol
#                                   (default: _start)
#    --undefined <SYMBOL>           Force <SYMBOL> to be
#                                   defined (link in
#                                   referencing objects even
#                                   if unused)
#    --export-dynamic, -E           Export ALL symbols
#                                   dynamically (for plugin
#                                   loading)
#
#  Optimization:
#    --gc-sections                  Garbage-collect unused
#                                   sections (smaller output)
#    --no-gc-sections               Disable section GC
#    -O<LEVEL>                      Optimization level (0, 1,
#                                   2) — currently affects
#                                   string-pool merging and
#                                   relocation choices
#
#  Threading + jobs:
#        --threads <N>              Number of linker threads
#                                   (default: detected from
#                                   jobserver or CPU count)
#        --files-per-group <N>      Files per parallel layout
#                                   group (also via env var
#                                   WILD_FILES_PER_GROUP)
#
#  Debugging / introspection (wild-specific):
#        --write-layout             Write layout file (for
#                                   debugging wild)
#        --write-trace              Write trace file
#        --validate-output          Validate output file
#                                   after writing
#        --no-fork                  Don't fork a subprocess
#                                   for linking (debug mode)
#
#  Meta:
#    --version, -V                  Show wild version
#                                   (registered via `args.set_
#                                   version()` from build.rs)
#        --help, -h                 Show usage help (wild's
#                                   --help is more minimal
#                                   than clap-generated help;
#                                   for full reference,
#                                   consult GNU ld(1) since
#                                   wild aims for drop-in
#                                   compatibility)
#
#  Positional:
#    <input-files>...               Input object files (.o),
#                                   static archives (.a),
#                                   shared libraries (.so), or
#                                   linker scripts (.ld).  Each
#                                   input takes the current
#                                   state-stack top's settings
#                                   (is-static, whole-archive,
#                                   etc.) AT THE TIME IT IS
#                                   SEEN — so flag/input ORDER
#                                   MATTERS.
#
#  Environment variables (configure debugging behavior):
#    WILD_FILES_PER_GROUP           Files per parallel layout
#                                   group (default: 16)
#    WILD_REFERENCE_LINKER          Path to reference linker
#                                   (e.g. mold) for output
#                                   validation
#    WILD_VALIDATE_OUTPUT           Validate output against
#                                   reference linker output
#    WILD_UNSUPPORTED               Behavior on unsupported
#                                   flag (warn/error/ignore)
#    WILD_WRITE_LAYOUT              Write layout debug file
#    WILD_WRITE_TRACE               Write trace debug file
#    WILD_VERIFY_ALLOCATIONS        Verify allocation
#                                   consistency during writing
#
#  Examples:
#    wild -o myapp main.o lib.o                          # Basic link
#    wild -o myapp.so --shared main.o lib.o              # Shared library
#    wild -shared -o myapp.so main.o                     # Same (single-dash form)
#    wild -o myapp main.o -L/usr/lib -lpthread -lm       # With library paths + libs
#    wild --whole-archive -lfoo --no-whole-archive -lbar # Mixed archive modes
#    wild --push-state --whole-archive -lfoo --pop-state -lbar  # Stack
#    wild -static -o myapp main.o                        # Fully static link
#    wild --gc-sections --strip-all -o tiny main.o       # Optimized
#    wild --threads 8 -o myapp main.o lib.o              # 8 threads
#    wild -O2 --gc-sections -o myapp main.o              # Level-2 optimize
#    wild -T linker.ld -o myapp main.o                   # Custom linker script
#    wild -e _start --entry main -o myapp main.o         # Set entry symbol
#    wild --version                                      # Show wild version
#    wild --help                                         # Show help
#    # As cargo's linker:
#    RUSTFLAGS="-C linker=wild" cargo build              # Use wild for Rust builds
#    # As Clang's linker:
#    clang -fuse-ld=wild main.c -o main                  # Use wild for Clang builds
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  similar Linux linker / hand-rolled-linker parsers):
#    - ld / ld.gold (IN CORPUS + STOCK — GNU binutils linkers;
#      hand-rolled C parsers; original linker argv convention)
#    - ld.lld (IN CORPUS + STOCK Clang — LLVM lld; uses llvm::
#      cl + custom dispatch; FUTURE candidate for formal
#      llvm::cl entry)
#    - mold (IN CORPUS via _mold — Rui Ueyama's parallel
#      Linux linker; hand-rolled C++ parser; the most direct
#      competitor to wild)
#    - rust-lld (IN CORPUS + STOCK Rust toolchain — Rust's
#      bundled lld; uses lld's parser)
#    - ld64 (Apple Mach-O linker — macOS only; not in corpus)
#    - davidlattimore/wild repo itself (3,652 stars project
#      not just CLI library)
# ============================================================================

_wild() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show usage help]' \
    '(-V --version)'{-V,--version}'[show wild version]' \
    '(-o --output)'{-o,--output}'[output file path]:file:_files' \
    '(--shared -shared)'{--shared,-shared}'[build a shared library (.so)]' \
    '(--static -static)'{--static,-static}'[build a static executable]' \
    '--pie[build a position-independent executable]' \
    '--no-pie[build a non-PIE executable]' \
    '(--strip-all -s)'{--strip-all,-s}'[strip ALL symbols]' \
    '(--strip-debug -S)'{--strip-debug,-S}'[strip debug symbols only]' \
    '--push-state[push a new state onto the input-state stack]' \
    '--pop-state[pop the state stack]' \
    '--as-needed[only link needed libraries]' \
    '--no-as-needed[force link all libraries]' \
    '--whole-archive[include ALL .o files from .a archives]' \
    '--no-whole-archive[only include needed .o from archives (default)]' \
    '-Bstatic[switch to static linking for subsequent -l]' \
    '-Bdynamic[switch to dynamic linking for subsequent -l]' \
    '-Bsymbolic[bind shared-library refs to local symbols]' \
    '*-l+[link with library]:library:' \
    '*-L+[library search path]:path:_directories' \
    '*-T+[use linker script]:script:_files -g "*.ld"' \
    '(--entry -e)'{--entry,-e}'[entry-point symbol]:symbol:' \
    '*--undefined[force symbol to be defined]:symbol:' \
    '(--export-dynamic -E)'{--export-dynamic,-E}'[export all symbols dynamically]' \
    '--gc-sections[garbage-collect unused sections]' \
    '--no-gc-sections[disable section GC]' \
    '-O+[optimization level]:level:(0 1 2)' \
    '--threads[number of linker threads]:n:' \
    '--files-per-group[files per parallel layout group]:n:' \
    '--write-layout[write layout debug file]' \
    '--write-trace[write trace debug file]' \
    '--validate-output[validate output file after writing]' \
    '--no-fork[do not fork a subprocess for linking]' \
    '*:input:_files -g "*.(o|a|so|ld)"'
}

_wild "$@"
