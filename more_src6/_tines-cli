#compdef tines-cli tines
# _tines-cli — Tines tines-cli CLI command-line frontend wrapping the Tines no-code automation Story SOAR Security Orchestration Automation and Response platform CLI providing login logout whoami story action team folder tenant credential webhook trigger resource event record team-credential team-action shared-team-resource recipe AI-natural-language-action sharing setlist team-member case audit-log usage-statistics (Tines team Eoin Hinchy Thomas Kinsella, Go); cobra
# upstream: https://www.tines.com/

_tines-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'story:story operations'
        'action:action operations'
        'team:team operations'
        'folder:folder operations'
        'tenant:tenant operations'
        'credential:credential operations'
        'webhook:webhook operations'
        'trigger:trigger operations'
        'resource:resource operations'
        'event:event operations'
        'record:record operations'
        'team-member:team member operations'
        'case:case operations'
        'audit-log:audit log operations'
        'usage:usage statistics'
        'send-event:send event'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-token=+[token]:str:' \
        '--api-url=+[url]:str:' \
        '--tenant-url=+[url]:str:' \
        '--team-id=+[id]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'tines subcommand' sub ;;
        args)
            case $words[1] in
                story|action|team|folder|tenant|credential|webhook|trigger|resource|event|record|team-member|case) _arguments '1:op:(list get create update delete enable disable export import duplicate)' '*:id:' ;;
                send-event) _arguments '*:webhook id:' ;;
            esac
            ;;
    esac
}

_tines-cli "$@"
