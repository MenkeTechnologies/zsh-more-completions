#compdef vvp
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/vvp.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (Icarus Verilog vvp runtime).
# Removed from prior file: bogus man.archlinux.org URL; fabricated
# -h/--help long form (vvp has no -h/--help); fabricated +vcd2fst,
# +vcd-off, +fst+speed, +fst+parallel, +fst+nodate, +fst+notimescale
# extended args (real ones are +vcd, +fst, +fst-speed, +fst-space,
# +lxt, +lxt2, +lx2, +none); fabricated -V long form.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-V[show runtime version and exit]' \
  '-i[make stdout unbuffered]' \
  '-l+[direct MCI stdlog to logfile (- for stderr)]:log file:_files' \
  '-M+[add VPI module search directory]:directory:_directories' \
  '-m+[load named VPI module]:module name:' \
  '-n[treat \$stop or Ctrl-C as \$finish]' \
  '-N[like -n but exit 1 on \$stop]' \
  '-s[stop simulation before scheduling]' \
  '-v[verbose runtime progress messages]' \
  '1:simulation file:_files -g "*.(vvp|out)"' \
  '*:extended args:' && ret=0

return ret
