#compdef vopono
# Documentation: https://github.com/jamesmcm/vopono
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'exec:run application through VPN tunnel'
  'list:list active connections'
  'list-providers:list available VPN providers'
  'servers:list servers for a provider'
  'sync:sync VPN provider configuration files'
  'daemon:run privileged root daemon'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'vopono command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (exec)
        _arguments \
          '--provider=[VPN provider]:provider:' \
          '--server=[server location]:server:' \
          '--protocol=[VPN protocol]:protocol:(wireguard openvpn)' \
          '--port-forwarding[enable port forwarding]' \
          '--custom=[custom config file]:file:_files' \
          '*:application and arguments:_default' && ret=0 ;;
      (servers)
        _arguments \
          '--provider=[VPN provider]:provider:' \
          '*:_files' && ret=0 ;;
    esac ;;
esac

return ret
