#compdef tuxmath
# Documentation: https://manpages.debian.org/bookworm/tuxmath/tuxmath.6.en.html
# Reference accessed: 2026-05-21
# Verified: Debian bookworm tuxmath(6) manpage.

# tuxmath: math drill game for kids
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--homedir=[home directory]:dir:_files -/' \
  '--optionfile=[options file]:file:_files' \
  '--playthroughlist[play through standard lesson list]' \
  '(--answersmiddle)--answersfirst[show answers first]' \
  '(--answersfirst)--answersmiddle[show answers middle]' \
  '--nosound[disable sound]' \
  '--nobackground[disable background image]' \
  '(--windowed)--fullscreen[fullscreen mode]' \
  '(--fullscreen)--windowed[windowed mode]' \
  '--keypad[show on-screen keypad]' \
  '--demo[run in demo mode]' \
  '--speed=[game speed]:speed:' \
  '--allownegatives[allow negative number answers]' \
  '--debug-all[enable all debug categories]' \
  '*:lesson file:_files' && ret=0
return ret
