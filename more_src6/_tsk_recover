#compdef tsk_recover
# Documentation: https://www.sleuthkit.org/sleuthkit/man/tsk_recover.html
# Source: sleuthkit/sleuthkit man/tsk_recover.1 — export files from an image to a local directory.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '(-a -e)-a[recover allocated files only]' \
    '(-a -e)-e[recover all files (allocated and unallocated)]' \
    '-f[specify file system type]:fstype:(ext2 ext3 ext4 fat fat12 fat16 fat32 ntfs ufs ufs1 ufs2 iso9660 hfs ext yaffs2 list)' \
    '-i[format of image file]:imgtype:(raw aff afd afm afflib ewf split)' \
    '-b[device sector size in bytes]:sector size:(512 1024 2048 4096)' \
    '-o[sector offset for volume to recover]:sector offset:' \
    '-d[directory inum to recover from]:dir inum:' \
    '*:image then output dir:_files' \
    && ret=0

return ret
