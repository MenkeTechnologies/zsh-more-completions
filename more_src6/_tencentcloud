#compdef tccli
# _tencentcloud — Tencent Cloud TCCLI (Tencent Cloud, Python); call Tencent Cloud APIs from CLI
# upstream: https://github.com/TencentCloud/tencentcloud-cli

_tencentcloud() {
    local -a sub=(
        'configure:configure profile'
        'auto-complete:auto completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--profile+[profile]:profile:' \
        '--secretId+[secret id]:str:' \
        '--secretKey+[secret key]:str:' \
        '--region+[region]:region:' \
        '--endpoint+[endpoint]:url:_urls' \
        '--output+[output format]:fmt:(json table text)' \
        '--cli-unfold-argument[unfold argument]' \
        '--debug[debug]' \
        '--retry+[retries]:n:' \
        '--retry-time+[retry interval ms]:n:' \
        '--timeout+[timeout sec]:n:' \
        '--token+[token]:str:' \
        '--language+[language]:lang:(en-US zh-CN)' \
        '--generate-cli-skeleton+[generate skeleton]:type:(input output)' \
        '--cli-input-json+[input json]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'tccli subcommand' sub ;;
    esac
}

_tencentcloud "$@"
