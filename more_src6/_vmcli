#compdef vmcli
# _vmcli — VictoriaMetrics vmcli CLI command-line client to the VictoriaMetrics time-series database REST API performing read query export import series-label-discovery operations health checks via prometheus-compatible PromQL MetricsQL multi-tenant /api/v1/query /api/v1/series /api/v1/labels /api/v1/import / (VictoriaMetrics team, Go); cobra
# upstream: https://docs.victoriametrics.com/

_vmcli() {
    local -a sub=(
        'query:run PromQL/MetricsQL query'
        'series:list series'
        'labels:list labels'
        'label-values:list values for a label'
        'export:export raw series'
        'import:import series from a file'
        'targets:show scrape targets'
        'rules:show alerting/recording rules'
        'tenants:list multi-tenant identifiers'
        'snapshot:snapshot operations'
        'reload:reload runtime config'
        'health:check server health'
        'metrics:fetch server self-metrics'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-u+[url]:str:' \
        '--url=+[url]:str:' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '--bearer-token=+[token]:str:' \
        '--tenant=+[tenant id]:str:' \
        '--tls-skip-verify[skip TLS verify]' \
        '-f+[format]:f:(json yaml csv table prometheus)' \
        '--format=+[format]:f:(json yaml csv table prometheus)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '--start=+[time]:str:' \
        '--end=+[time]:str:' \
        '--step=+[duration]:str:' \
        '--timeout=+[duration]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vmcli subcommand' sub ;;
        args)
            case $words[1] in
                query|series|label-values) _arguments '*:query:' ;;
                import) _arguments '*:file:_files' ;;
            esac
            ;;
    esac
}

_vmcli "$@"
