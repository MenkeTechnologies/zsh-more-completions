# -----------------------------------------------------------------------------
#
# THE udacimak CLI
#
# udacimak is a multi-subcommand CLI built on commander
# v2.x.  Invocation:
#   udacimak <command> <args> [options]
#
# Subcommands:
#   download [courseid...]            fetch course/Nanodegree
#                                     JSON to disk
#   listnd                            list user enrolled +
#                                     graduated Nanodegrees
#   render <path>                     render JSON → HTML
#                                     lessons (one course)
#   renderdir <path>                  render all JSON
#                                     files in a dir tree
#   settoken <token>                  save Udacity JWT
#                                     locally (manual paste)
#   login                             interactive Udacity
#                                     OAuth login
#
# Common arguments:
#   <courseid>                        Udacity course ID
#                                     (e.g. nd019, ud611,
#                                     st101)
#   <path>                            path to a downloaded
#                                     JSON file or
#                                     directory tree
#   <token>                           Udacity JWT (extract
#                                     from browser DevTools
#                                     cookie named "_jwt")
#
# Common invocations:
#   # Initial setup: save auth token (one of these)
#   udacimak login                              # interactive
#   udacimak settoken eyJhbGciOiJIUzI1NiIsInR... # manual paste
#
#   # List my Nanodegrees
#   udacimak listnd
#
#   # Download a single Nanodegree
#   udacimak download nd019
#
#   # Download multiple Nanodegrees
#   udacimak download nd019 st101 ud611
#
#   # Download to a specific target directory
#   udacimak download -t ~/Udacity nd019 st101
#   udacimak download --targetdir ~/Udacity nd019
#
#   # Render one downloaded course to HTML
#   udacimak render ~/Udacity/React
#
#   # Render with YouTube delay + subtitles
#   udacimak render -d 5 -s ~/Udacity/React
#   udacimak render --delay-youtube 5 --subtitles ~/Udacity/React
#
#   # Render verbosely (youtube-dl debug output)
#   udacimak render -v ~/Udacity/React
#
#   # Render and preserve user-submitted quiz answers
#   udacimak render --userquizanswer ~/Udacity/React
#
#   # Render to a different target dir
#   udacimak render -t ~/Output ~/Udacity/React
#
#   # Bulk-render every downloaded JSON in a dir
#   udacimak renderdir -t ~/Output -d 5 -s ~/Udacity
#
# OPTIONS (sourced directly from
# https://github.com/udacimak/udacimak/blob/master/src/index.js):
#
# Global:
#   -v, --version                     print version
#
# download [courseid...]:
#   -t, --targetdir <dir>             target directory for JSON
#
# listnd:                             (no flags)
#
# render <path>:
#   -t, --targetdir <dir>             output directory
#   -d, --delay-youtube <secs>        delay between YouTube fetches
#   -s, --subtitles                   download YouTube subtitles
#   -v, --verbose                     youtube-dl verbose debug
#   --userquizanswer                  preserve user's quiz answers
#
# renderdir <path>:
#   -t, --targetdir <dir>             output directory
#   -d, --delay-youtube <secs>        delay between YouTube fetches
#   -s, --subtitles                   download YouTube subtitles
#   -v, --verbose                     youtube-dl verbose debug
#   --userquizanswer                  preserve user's quiz answers
#
# settoken <token>:                   (positional JWT)
# login:                              (no flags)
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _udm_subcommands
_udm_subcommands=(
    'download:fetch course/Nanodegree JSON content from Udacity'
    'listnd:list user enrolled + graduated Nanodegrees'
    'render:render downloaded JSON course content into HTML lessons'
    'renderdir:bulk-render a whole directory of downloaded JSON courses'
    'settoken:save Udacity JWT auth token locally (manual paste)'
    'login:interactive Udacity OAuth login'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '1:subcommand:->subcmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    subcmd)
        _describe -t subcmds 'udacimak subcommand' _udm_subcommands && ret=0
        ;;
    args)
        case $words[1] in
            download)
                _arguments \
                    '(-t --targetdir)'{-t,--targetdir}'=[target directory to save downloaded course JSON data]:dir:_directories' \
                    '*:course id (e.g. nd019, st101, ud611): ' \
                    && ret=0
                ;;
            listnd|login)
                ret=0
                ;;
            render|renderdir)
                _arguments \
                    '(-t --targetdir)'{-t,--targetdir}'=[target directory for rendered HTML]:dir:_directories' \
                    '(-d --delay-youtube)'{-d,--delay-youtube}'=[delay in seconds between YouTube downloads]:seconds: ' \
                    '(-s --subtitles)'{-s,--subtitles}'[download YouTube video subtitles]' \
                    '(-v --verbose)'{-v,--verbose}'[force youtube-dl to log debug information]' \
                    '--userquizanswer[preserve user-submitted Programming Question code answers]' \
                    '1:path to JSON file or directory:_files' \
                    && ret=0
                ;;
            settoken)
                _arguments \
                    '1:Udacity JWT token (extract from browser cookie "_jwt"): ' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
