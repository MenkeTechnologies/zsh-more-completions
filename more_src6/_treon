#compdef treon
# Documentation: treon --help
# Source: ReviewNB/treon treon/treon.py (master) — run Jupyter notebooks as tests (Python docopt).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '--version[show version]' \
    '--threads=[number of parallel threads (default 10)]:N:_default' \
    '*'{-e+,--exclude=}'[exclude path prefix]:path:_files' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '*:notebook file or directory:_files -g "*.ipynb"' \
    && ret=0

return ret
