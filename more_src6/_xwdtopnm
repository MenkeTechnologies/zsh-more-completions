#compdef xwdtopnm
# Documentation: man xwdtopnm (Netpbm)
# Source: convert an X11 window-dump (.xwd) file to PNM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-verbose[verbose output]' \
    '-headerdump[dump XWD header info]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:xwd file:_files -g "*.xwd"' \
    && ret=0

return ret
