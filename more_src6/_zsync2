#compdef zsync2 zsyncmake2
# Documentation: source-direct extraction from upstream
# AppImageCommunity/zsync2
#   src/main.cpp:        11 Taywee/args (args.hxx) ValueFlag /
#                        Flag / Positional declarations.
#   src/make_main.cpp:   5 Taywee/args declarations + 1
#                        Positional.
#   Binary-to-source mapping from src/CMakeLists.txt:
#     add_executable(zsync2 main.cpp)
#     add_executable(zsyncmake2 make_main.cpp)
# Reference accessed: 2026-05-30 via gh api.
# AppImageCommunity zsync2 R173 — modern C++11 rewrite of the
# zsync rsync-over-HTTP partial-update tool, providing both a
# library and standalone CLIs.  zsync2 fetches an incremental
# diff against a remote .zsync(2) file; zsyncmake2 generates the
# .zsync metadata that drives those incremental updates.  Sister
# tool to the heavily-covered file-sync family (rsync/unison/
# rclone/duplicacy/restic/borg/attic/bup/obnam) and the original
# zsync (Colin Phipps, separate C codebase already covered) in
# the corpus.

case $service in

  zsync2)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[display help and exit]' \
      '*'{-i+,--seed-file=}'[use data from this file during update (repeatable)]:file:_files' \
      '(-I --insecure)'{-I,--insecure}'[switch to HTTP insecure mode (skip TLS verification)]' \
      '(-j --check-for-changes)'{-j,--check-for-changes}'[only check changes (exit 1 if changed, 0 if not)]' \
      '(-k --copy-zsync-file-to)'{-k+,--copy-zsync-file-to=}'[save copy of .zsync file to path]:file:_files' \
      '(-r --resolve-redirection)'{-r,--resolve-redirection}'[resolve redirection for given URL and exit]' \
      '(-o --output)'{-o+,--output=}'[output file path (default from .zsync file)]:file:_files' \
      '(-u --url)'{-u+,--url=}'[URL to get the target file]:url:' \
      '--force-update[skip update check and force update]' \
      '(-s -q --silent-mode)'{-s,-q,--silent-mode}'[quiet mode]' \
      '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
      '(-V --version)'{-V,--version}'[print version and exit]' \
      '1:.zsync(2) file or URL:_files -g "*.zsync*"'
    ;;

  zsyncmake2)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[display help and exit]' \
      '(-u --url)'{-u+,--url=}'[URL the .zsync file should point to (may be relative)]:url:' \
      '(-b --blocksize)'{-b+,--blocksize=}'[blocksize for rsync algorithm (power of 2; default 2048 or 4096 by file size)]:bytes:' \
      '*'{-c+,--custom-header=}'[custom key=value header field (repeatable)]:key=value:' \
      '(-V --version)'{-V,--version}'[print version and exit]' \
      '1:file to generate .zsync metadata for:_files'
    ;;

esac
