#compdef xc
# Documentation: https://github.com/joerdav/xc
# Reference accessed: 2026-05-21
# Verified: cmd/xc/main.go flag.* declarations (version, help, heading, file, type, short, display, complete, uncomplete, no-tty).

_xc() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-V -version --version)'{-V,-version,--version}'[show xc version]' \
    '(-h -help --help)'{-h,-help,--help}'[show xc usage]' \
    '(-H -heading --heading)'{-H,-heading,--heading}'+[specify the heading for xc tasks]:heading:' \
    '(-f -file --file)'{-f,-file,--file}'+[Markdown/Org file with tasks]:file:_files -g "*.(md|org)"' \
    '(-type --type)'{-type,--type}'+[file type]:type:(md org)' \
    '(-s -short --short)'{-s,-short,--short}'[list task names in short format]' \
    '(-d -display --display)'{-d,-display,--display}'[print task source instead of running it]' \
    '(-complete --complete)'{-complete,--complete}'[install shell completion]' \
    '(-uncomplete --uncomplete)'{-uncomplete,--uncomplete}'[uninstall shell completion]' \
    '(-no-tty --no-tty)'{-no-tty,--no-tty}'[disable interactive picker]' \
    '1:task:->tasks' \
    '*::arg:->args'

  case $state in
    tasks)
      local -a tasks
      tasks=(${(f)"$(xc -s 2>/dev/null)"})
      _describe 'task' tasks
      ;;
  esac
}

_xc "$@"
