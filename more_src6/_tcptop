#compdef tcptop tcptop-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/tcptop.py argparse)
# Reference accessed: 2026-05-29
# tcptop — top-like display of TCP send/recv throughput per session (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-C --noclear)'{-C,--noclear}'[do not clear the screen]' \
  '(-S --nosummary)'{-S,--nosummary}'[skip system summary line]' \
  '(-p --pid)'{-p,--pid=}'[trace this PID only]:pid:_pids' \
  '--cgroupmap=[trace cgroups in this BPF map only]:map:' \
  '--mntnsmap=[trace mount namespaces in this BPF map only]:map:' \
  '(-4 --ipv4 -6 --ipv6)'{-4,--ipv4}'[trace IPv4 family only]' \
  '(-4 --ipv4 -6 --ipv6)'{-6,--ipv6}'[trace IPv6 family only]' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:interval (seconds, default 1):' \
  '2:count (number of outputs, default unlimited):' \
  && ret=0

return ret
