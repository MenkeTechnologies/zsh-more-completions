#compdef varnishncsa
# Documentation: https://varnish-cache.org/docs/trunk/reference/varnishncsa.html
# Reference accessed: 2026-05-29

_arguments -s \
  '-a[append to output file instead of overwriting]' \
  '-b[only log backend requests]' \
  '-c[only log client requests]' \
  '-C[use caseless regular expressions]' \
  '-d[process old log entries on startup]' \
  '-D[daemonize]' \
  '-F[set output format string]:format string' \
  '-f[specify VSM file]:VSM file:_files' \
  '-g[set grouping mode]:grouping:(session request vxid raw)' \
  '(- *)'-h'[print help]' \
  '-n[specify varnish instance name]:instance name' \
  '-N[specify stale VSM file]:stale VSM file:_files' \
  '-P[write PID to file]:PID file:_files' \
  '-q[VSL query expression]:query' \
  '-r[read log from binary file]:binary log file:_files' \
  '-t[VSM connection timeout]:timeout (seconds)' \
  '-V[display version]' \
  '-w[write output to file]:output file:_files' \
  && return 0
