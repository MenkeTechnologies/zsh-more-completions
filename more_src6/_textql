#compdef textql
# Documentation: https://github.com/dinedal/textql
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for textql (SQL on text files)

local ret=1

_arguments -s -S \
  '(- *)-version[print version and exit]' \
  '-header[treat first row of input as header]' \
  '-dlm+[input delimiter]:delimiter:' \
  '-sql+[SQL statement(s) to execute]:query:' \
  '-output-header[display column names in output]' \
  '-output-dlm+[output delimiter]:delimiter:' \
  '-output-file+[write output to file]:file:_files' \
  '-pretty[output results in a pretty table]' \
  '-quiet[suppress non-error output]' \
  '-console[launch an interactive SQLite console]' \
  '-save-to+[save in-memory database to file]:file:_files' \
  '*:file:_files' && ret=0

return ret
