#compdef wd
# Documentation: https://github.com/mfaerevaag/wd (zsh warp directory)
#                https://codeberg.org/maxlath/wikibase-cli (npm `wd`)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URLs above.
# STUB: `wd` name is ambiguous — zsh warp-directory plugin ships its
# own completion separately; wikibase-cli `wd` subcommand list is
# documented across multiple files. Defer to upstream completion or
# `wd help`.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--config=[custom config file]:file:_files' \
  '--quiet[suppress all output]' \
  '*::arguments:_default' && ret=0
return ret
