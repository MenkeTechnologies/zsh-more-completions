#compdef usnjls
# Documentation: https://www.sleuthkit.org/sleuthkit/man/usnjls.html
# Source: sleuthkit/sleuthkit man/usnjls.1 — list the contents of an NTFS USN change journal ($UsnJrnl:$J).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f[specify file system type]:fstype:(ntfs list)' \
    '-i[identify type of image file]:imgtype:(raw aff afd afm afflib ewf split)' \
    '-o[sector offset where file system starts in image]:offset:' \
    '-b[underlying device sector size in bytes]:sector size:(512 1024 2048 4096)' \
    '(-l -m)-l[long format: describe field values and unpack data into human readable strings]' \
    '(-l -m)-m[print output in mactime format]' \
    '-V[display version]' \
    '-v[verbose output]' \
    '*:image file:_files' \
    && ret=0

return ret
