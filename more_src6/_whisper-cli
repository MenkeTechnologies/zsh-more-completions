#compdef whisper-cli
# Documentation: https://github.com/ggml-org/whisper.cpp/blob/master/examples/cli/cli.cpp
# Reference accessed: 2026-05-27
# Verified: upstream whisper_params_parse() in examples/cli/cli.cpp (ggml-org/whisper.cpp).
# Note: the legacy binary name `main` is deprecated upstream and now prints a
# warning redirecting to `whisper-cli`; this completion targets the current
# canonical name only to avoid hijacking the generic `main` command.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-t --threads)'{-t+,--threads=}'[number of threads]:n:' \
  '(-p --processors)'{-p+,--processors=}'[number of processors]:n:' \
  '(-ot --offset-t)'{-ot+,--offset-t=}'[time offset in milliseconds]:ms:' \
  '(-on --offset-n)'{-on+,--offset-n=}'[segment index offset]:n:' \
  '(-d --duration)'{-d+,--duration=}'[duration of audio to process (ms)]:ms:' \
  '(-mc --max-context)'{-mc+,--max-context=}'[maximum text context tokens]:n:' \
  '(-ml --max-len)'{-ml+,--max-len=}'[maximum segment length in characters]:n:' \
  '(-bo --best-of)'{-bo+,--best-of=}'[number of best candidates to keep]:n:' \
  '(-bs --beam-size)'{-bs+,--beam-size=}'[beam size for beam search]:n:' \
  '(-ac --audio-ctx)'{-ac+,--audio-ctx=}'[audio context size]:n:' \
  '(-wt --word-thold)'{-wt+,--word-thold=}'[word timestamp probability threshold]:float:' \
  '(-et --entropy-thold)'{-et+,--entropy-thold=}'[entropy threshold for decoder fail]:float:' \
  '(-lpt --logprob-thold)'{-lpt+,--logprob-thold=}'[log probability threshold]:float:' \
  '(-nth --no-speech-thold)'{-nth+,--no-speech-thold=}'[no speech threshold]:float:' \
  '(-tp --temperature)'{-tp+,--temperature=}'[sampling temperature (0-1)]:float:' \
  '(-tpi --temperature-inc)'{-tpi+,--temperature-inc=}'[temperature increment]:float:' \
  '(-debug --debug-mode)'{-debug,--debug-mode}'[enable debug mode]' \
  '(-tr --translate)'{-tr,--translate}'[translate output to English]' \
  '(-di --diarize)'{-di,--diarize}'[stereo audio diarization]' \
  '(-tdrz --tinydiarize)'{-tdrz,--tinydiarize}'[enable tinydiarize]' \
  '(-sow --split-on-word)'{-sow,--split-on-word}'[split on word rather than token]' \
  '(-nf --no-fallback)'{-nf,--no-fallback}'[disable temperature fallback decoding]' \
  '(-otxt --output-txt)'{-otxt,--output-txt}'[output result as text file]' \
  '(-ovtt --output-vtt)'{-ovtt,--output-vtt}'[output result as VTT file]' \
  '(-osrt --output-srt)'{-osrt,--output-srt}'[output result as SRT file]' \
  '(-owts --output-words)'{-owts,--output-words}'[output karaoke (wts) script]' \
  '(-ocsv --output-csv)'{-ocsv,--output-csv}'[output result as CSV file]' \
  '(-oj --output-json)'{-oj,--output-json}'[output result as JSON file]' \
  '(-ojf --output-json-full)'{-ojf,--output-json-full}'[output result as full JSON]' \
  '(-olrc --output-lrc)'{-olrc,--output-lrc}'[output result as LRC file]' \
  '(-np --no-prints)'{-np,--no-prints}'[suppress output except results]' \
  '(-ps --print-special)'{-ps,--print-special}'[print special tokens]' \
  '(-pc --print-colors)'{-pc,--print-colors}'[print with colors]' \
  '--print-confidence[print word confidence levels]' \
  '(-pp --print-progress)'{-pp,--print-progress}'[print progress information]' \
  '(-nt --no-timestamps)'{-nt,--no-timestamps}'[omit timestamps in output]' \
  '(-dl --detect-language)'{-dl,--detect-language}'[exit after detecting language]' \
  '--carry-initial-prompt[always prepend initial prompt across windows]' \
  '(-ls --log-score)'{-ls,--log-score}'[log best decoder scores]' \
  '(-ng --no-gpu)'{-ng,--no-gpu}'[disable GPU]' \
  '(-fa --flash-attn)'{-fa,--flash-attn}'[enable flash attention]' \
  '(-nfa --no-flash-attn)'{-nfa,--no-flash-attn}'[disable flash attention]' \
  '(-sns --suppress-nst)'{-sns,--suppress-nst}'[suppress non-speech tokens]' \
  '--vad[enable Voice Activity Detection]' \
  '(-l --language)'{-l+,--language=}'[spoken language code]:lang:(auto en zh de es ru ko fr ja pt tr pl ca nl ar sv it id hi fi vi he uk el ms cs ro da hu ta no th ur hr bg lt la mi ml cy sk te fa lv bn sr az sl kn et mk br eu is hy ne mn bs kk sq sw gl mr pa si km sn yo so af oc ka be tg sd gu am yi lo uz fo ht ps tk nn mt sa lb my bo tl mg as tt haw ln ha ba jw su)' \
  '--prompt=[initial prompt text]:prompt:' \
  '(-m --model)'{-m+,--model=}'[model file path]:file:_files' \
  '(-f --file)'{-f+,--file=}'[input audio file path]:file:_files -g "*.(wav|mp3|flac|ogg|m4a|webm|opus)(-.)"' \
  '(-of --output-file)'{-of+,--output-file=}'[output file path without extension]:file:_files' \
  '(-fp --font-path)'{-fp+,--font-path=}'[path to monospace font for karaoke]:file:_files' \
  '(-oved --ov-e-device)'{-oved+,--ov-e-device=}'[OpenVINO device for encoding]:device:' \
  '(-dtw --dtw)'{-dtw+,--dtw=}'[DTW model preset]:preset:' \
  '--suppress-regex=[regex of tokens to suppress]:regex:' \
  '--grammar=[GBNF grammar file or inline string]:grammar:' \
  '--grammar-rule=[top-level grammar rule name]:rule:' \
  '--grammar-penalty=[grammar penalty scaling]:float:' \
  '(-vm --vad-model)'{-vm+,--vad-model=}'[VAD model path]:file:_files' \
  '(-vt --vad-threshold)'{-vt+,--vad-threshold=}'[VAD speech probability threshold (0-1)]:float:' \
  '(-vspd --vad-min-speech-duration-ms)'{-vspd+,--vad-min-speech-duration-ms=}'[VAD minimum speech duration in ms]:ms:' \
  '(-vsd --vad-min-silence-duration-ms)'{-vsd+,--vad-min-silence-duration-ms=}'[VAD minimum silence duration in ms]:ms:' \
  '(-vmsd --vad-max-speech-duration-s)'{-vmsd+,--vad-max-speech-duration-s=}'[VAD maximum speech duration in seconds]:s:' \
  '(-vp --vad-speech-pad-ms)'{-vp+,--vad-speech-pad-ms=}'[VAD speech padding in ms]:ms:' \
  '(-vo --vad-samples-overlap)'{-vo+,--vad-samples-overlap=}'[VAD sample overlap in seconds]:s:' \
  '(-dev --device)'{-dev+,--device=}'[GPU device id]:id:' \
  '*:audio file:_files -g "*.(wav|mp3|flac|ogg|m4a|webm|opus)(-.)"' && ret=0

return ret
