#compdef wiringpi gpio
# _wiringpi — Gordon Henderson WiringPi gpio CLI for direct access to BCM2835 BCM2711 Raspberry Pi GPIO pins reading writing modes pwm i2c spi pinmode mode-out unexport schmitt-trigger drive-strength (WiringPi team, C); getopt
# upstream: https://github.com/WiringPi/WiringPi

_wiringpi() {
    local -a sub=(
        'mode:set pin mode'
        'read:read pin value'
        'write:write pin value'
        'awrite:analog write'
        'aread:analog read'
        'pwm:set PWM value'
        'clock:set clock'
        'pwmc:set PWM clock'
        'pwmr:set PWM range'
        'pwm-bal:set PWM balanced mode'
        'pwm-ms:set PWM mark-space mode'
        'load:load module'
        'unload:unload module'
        'unexport:unexport pin'
        'unexportall:unexport all'
        'export:export pin'
        'exports:list exports'
        'wfi:wait for interrupt'
        'edge:set interrupt edge'
        'readall:read all pins'
        'allreadall:read all pins all chips'
        'pins:show pin layout'
        'i2cdetect:i2c detect'
        'i2cd:i2c detect alias'
        'wb:write byte raw'
        'rbx:read byte raw'
        'usbp:set USB port power'
        'gbr:get board revision'
        'gbw:get board wattage'
        'qmode:query pin mode'
        'drive:set drive strength'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-g[use BCM_GPIO pin numbering]' \
        '-1[use physical pin numbering]' \
        '-p[use Pi 1 pinout]' \
        '-x+[extension setup]:str:' \
        '-d[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wiringpi subcommand' sub ;;
        args)
            case $words[1] in
                mode) _arguments '*:pin mode:(in out pwm clock up down tri off)' ;;
                read|write|aread|awrite|edge|wfi|pwm|export|unexport|qmode|drive) _arguments '*:pin value:' ;;
                edge) _arguments \
                    '1:pin:' \
                    '2:edge:(rising falling both)' ;;
            esac
            ;;
    esac
}

_wiringpi "$@"
