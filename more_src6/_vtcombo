#compdef vtcombo
# _vtcombo — Vitess all-in-one process (vtgate + vttablet + mysqld + topo)
# upstream: https://github.com/vitessio/vitess
# Flags from go/cmd/vtcombo/cli/main.go on tip.

_vtcombo() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--schema-dir=[schema base directory (per-keyspace subdirs)]:dir:_files -/' \
        '--start-mysql=[also start mysqld]:bool:(true false)' \
        '--mysql-port=[mysqld port]:port:' \
        '--external-topo-server=[use external topology server]:bool:(true false)' \
        '--planner-version=[default planner]:planner:(Gen4 Gen4Greedy Gen4Left2Right)' \
        '--vschema-persistence-dir=[persist per-keyspace vschema to this dir]:dir:_files -/' \
        '--proto-topo=[proto-encoded topology]:proto:' \
        '--port=[vtcombo listen port]:port:' \
        '--mysql-bind-host=[mysqld bind host]:host:' \
        '--charset=[MySQL charset]:charset:' \
        '--enable-system-settings=[allow per-session system settings]:bool:(true false)' \
        '--transaction-mode=[transaction mode]:mode:(MULTI SINGLE TWOPC)' \
        '--queryserver-config-transaction-timeout=[transaction timeout]:dur:' \
        '--foreign-key-mode=[foreign-key handling]:mode:(allow disallow)' \
        '--enable-online-ddl=[allow Online DDL]:bool:(true false)' \
        '--enable-direct-ddl=[allow direct DDL]:bool:(true false)' \
        '--external-topo-implementation=[external topology implementation]:impl:' \
        '-v[verbosity level]:n:'
}

_vtcombo "$@"
