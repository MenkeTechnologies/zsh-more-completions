#compdef vttlstest
# _vttlstest — Vitess TLS testing helper (issue test CAs/certs/CRLs)
# upstream: https://github.com/vitessio/vitess
# Subcommands + flags from go/cmd/vttlstest/cli/vttlstest.go on tip.

_vttlstest() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--root=[root directory for artifacts]:dir:_files -/' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'CreateCA:create a root CA'
                'CreateIntermediateCA:create an intermediate CA'
                'CreateCRL:create a CRL'
                'CreateSignedCert:create a server cert signed by a CA'
                'RevokeCert:revoke a previously issued cert'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                CreateIntermediateCA|CreateSignedCert)
                    _arguments \
                        '--parent=[parent cert name (use "ca" for top-level CA)]:name:' \
                        '--serial=[serial number for the new cert]:serial:' \
                        '--common-name=[Common Name (CN) for the cert]:cn:' \
                        '*:cert name:'
                    ;;
                RevokeCert)
                    _arguments \
                        '--parent=[parent cert name]:name:' \
                        '*:cert name:'
                    ;;
                CreateCRL)
                    _arguments \
                        '*:server:'
                    ;;
            esac
            ;;
    esac
}

_vttlstest "$@"
