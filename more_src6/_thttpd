#compdef thttpd
# Documentation: https://acme.com/software/thttpd/thttpd_man.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '-C[config file]:file:_files' \
  '-p[alternate port number (default 80)]:port:' \
  '-d[chdir directory at startup]:dir:_files -/' \
  '-dd[directory to change to after chrooting]:dir:_files -/' \
  '-r[chroot at initialization time]' \
  '-nor[disable chroot if compiled-in default]' \
  '-s[enable symbolic link checking (default)]' \
  '-nos[do not do explicit symbolic link checking]' \
  '-v[do el-cheapo virtual hosting]' \
  '-nov[disable virtual hosting if compiled-in default]' \
  '-g[use a global passwd file]' \
  '-nog[disable global password file if compiled-in default]' \
  '-u[user to switch to after initialization]:user:_users' \
  '-c[wildcard pattern for CGI programs]:pattern:' \
  '-t[file containing throttle settings]:file:_files' \
  '-h[hostname to bind to for multihoming]:host:_hosts' \
  '-l[log file]:file:_files' \
  '-i[pid file]:file:_files' \
  '-T[charset for text MIME types (default UTF-8)]:charset:' \
  '-P[P3P server privacy header]:p3p:' \
  '-M[Cache-Control max-age seconds]:seconds:' \
  '-V[show version]' \
  '-D[prevent thttpd from making itself a background daemon]'
