#compdef techdocs-cli
# Documentation: https://backstage.io/docs/features/techdocs/cli/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'generate:generate TechDocs site using mkdocs'
  'build:alias for generate'
  'publish:publish generated site to cloud storage'
  'serve:local preview in Backstage-like environment'
  'serve\:mkdocs:direct mkdocs preview server'
  'migrate:convert case-sensitive paths to case-insensitive'
  'help:display help for command'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'techdocs-cli command' commands && ret=0 ;;
  args)
    case ${words[1]} in
      generate|build)
        _arguments -s -S \
          '--source-dir=[documentation source location]:dir:_directories' \
          '--output-dir=[where to store generated files]:dir:_directories' \
          '--docker-image=[MkDocs container to use]:image:' \
          '--no-docker[use local MkDocs instead of Docker]' \
          '--techdocs-ref=[repository hosting documentation]:ref:' \
          '--etag=[unique identifier for prepared tree]:etag:' \
          '--defaultPlugin=[auto-add plugins to mkdocs.yaml]:plugin:' \
          '--omitTechdocsCoreMkdocsPlugin[disable automatic plugin addition]' \
          '--legacyCopyReadmeMdToIndexMd[fallback to README.md if no index.md]' \
          '--runAsDefaultUser[skip container user/group matching]' \
          '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
          && ret=0 ;;
      publish)
        _arguments -s -S \
          '--publisher-type=[cloud publisher]:type:(awsS3 googleGcs azureBlobStorage openStackSwift)' \
          '--storage-name=[bucket or container name]:name:' \
          '--entity=[Backstage entity identifier (namespace/kind/name)]:entity:' \
          && ret=0 ;;
      serve)
        _arguments -s -S \
          '(-i --docker-image)'{-i+,--docker-image=}'[MkDocs container]:image:' \
          '--no-docker[use local MkDocs installation]' \
          '--mkdocs-port=[MkDocs server port]:port:' \
          '--preview-app-bundle-path=[custom preview app bundle]:path:_files' \
          '--preview-app-port=[preview port]:port:' \
          '(-c --mkdocs-config-file-name)'{-c+,--mkdocs-config-file-name=}'[config file to use]:file:_files' \
          && ret=0 ;;
      migrate)
        _arguments -s -S '--removeOriginal[move files instead of copying]' && ret=0 ;;
      *) _files && ret=0 ;;
    esac ;;
esac

return ret
