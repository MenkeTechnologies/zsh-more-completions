#compdef zet
# Documentation: https://github.com/yarrow/zet
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--count-files[show the number of files each line occurs in]' \
  '--count-lines[show the number of times each line occurs in the input]' \
  '--count-none[turn off counting]' \
  '(-c --count)'{-c,--count}'[count lines; with --files counts files]' \
  '--files[treat operands as per-file sets for single/multiple]' \
  '--file[alias of --files]' \
  '1:operation:(intersect union diff single multiple help)' \
  '*:input file:_files'
