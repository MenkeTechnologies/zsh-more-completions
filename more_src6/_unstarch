#compdef unstarch
# Documentation: https://bedops.readthedocs.io/en/latest/content/reference/file-management/compression/unstarch.html
# Documentation: https://github.com/bedops/bedops/blob/master/applications/bed/starch/src/unstarch.c
# Reference accessed: 2026-05-27
# Verified: upstream unstarch.c argument parser

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '--help[show help message and exit]' \
  '--version[show program version and citation info]' \
  '--is-starch[print 1 if input is a Starch archive, 0 otherwise]' \
  '--list[list per-chromosome archive metadata as a table]' \
  '--listJSON[list per-chromosome archive metadata as JSON]' \
  '--list-json[list per-chromosome archive metadata as JSON (alias)]' \
  '--list-json-no-trailing-newline[list metadata as JSON without trailing newline]' \
  '(--list-chr --list-chromosomes --listchr)--list-chr[list chromosomes contained in archive]' \
  '(--list-chr --list-chromosomes --listchr)--list-chromosomes[list chromosomes contained in archive (alias)]' \
  '(--list-chr --list-chromosomes --listchr)--listchr[list chromosomes contained in archive (alias)]' \
  '(--archive-version --archiveVersion)--archive-version[print archive format version]' \
  '(--archive-version --archiveVersion)--archiveVersion[print archive format version (alias)]' \
  '--archive-timestamp[print ISO-8601 archive creation timestamp]' \
  '--archive-type[print backend compression type (bzip2 or gzip)]' \
  '--note[print user-supplied archive note]' \
  '--sha1-signature[print archive base64-encoded SHA1 signature]' \
  '--signature[print per-chromosome base64-encoded SHA1 signature]' \
  '--verify-signature[verify per-chromosome signatures against archive metadata]' \
  '--elements[print total element count]:chromosome:' \
  '--elements-max-string-length[print maximum BED element string length]:chromosome:' \
  '--bases[print total base count]:chromosome:' \
  '--bases-uniq[print unique base count]:chromosome:' \
  '--has-duplicate[print 1 if duplicate elements exist, 0 otherwise]:chromosome:' \
  '--has-duplicate-as-string[print yes/no string for duplicate elements]:chromosome:' \
  '--has-nested[print 1 if nested elements exist, 0 otherwise]:chromosome:' \
  '--has-nested-as-string[print yes/no string for nested elements]:chromosome:' \
  '*:starch file:_files -g "*.starch(-.)"' && ret=0

return ret
