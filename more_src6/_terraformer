#compdef terraformer
# Documentation: https://github.com/GoogleCloudPlatform/terraformer
# Reference accessed: 2026-05-21
# Verified: upstream cmd/import.go.
# Real import/plan flags: -r/--resources, -x/--excludes, -f/--filter,
# -O/--output (hcl|json), -s/--state, -b/--bucket, -p/--path-pattern,
# -o/--path-output, -C/--compact, -c/--connect, -n/--retry-number,
# -m/--retry-sleep-ms, -S/--no-sort, -v/--verbose.
# Removed from prior file: -R/--regions (real shorts are -z/--regions),
# -o/--output (real short for output is -O), --compact without short,
# --resource-group (Azure-only, not in baseProviderFlags),
# --profile (struct-only, not exposed as flag in baseProviderFlags),
# top-level -v/--verbose (real -v is per-subcommand).
# Note: terraformer archived 2026-03-16, no further changes upstream.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'import:import current state to Terraform configuration'
  'plan:plan to import current state'
  'list:list supported resources for a provider'
  'version:show version'
  'help:show help'
  'completion:generate shell completion'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'terraformer command' commands && ret=0
    ;;
  args)
    case $words[1] in
      import|plan)
        _arguments \
          '(-r --resources)'{-r+,--resources=}'[resources to import]:resources' \
          '(-x --excludes)'{-x+,--excludes=}'[resources to exclude]:excludes' \
          '(-f --filter)'{-f+,--filter=}'[filter resources]:filter' \
          '(-O --output)'{-O+,--output=}'[output format]:format:(hcl json)' \
          '(-s --state)'{-s+,--state=}'[state storage]:state:(local bucket)' \
          '(-b --bucket)'{-b+,--bucket=}'[GCS bucket for state]:bucket' \
          '(-p --path-pattern)'{-p+,--path-pattern=}'[directory pattern]:pattern' \
          '(-o --path-output)'{-o+,--path-output=}'[output directory]:path:_directories' \
          '(-C --compact)'{-C,--compact}'[generate compact output]' \
          '(-c --connect)'{-c+,--connect=}'[connect resources to each other]:bool:(true false)' \
          '(-n --retry-number)'{-n+,--retry-number=}'[number of retries]:num' \
          '(-m --retry-sleep-ms)'{-m+,--retry-sleep-ms=}'[retry sleep in ms]:ms' \
          '(-S --no-sort)'{-S,--no-sort}'[disable HCL sorting]' \
          '(-v --verbose)'{-v,--verbose}'[verbose logging]' && ret=0
        ;;
      list)
        _arguments \
          '--provider=[provider]:provider' && ret=0
        ;;
    esac
    ;;
esac

return ret
