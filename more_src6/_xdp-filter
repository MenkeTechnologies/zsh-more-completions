#compdef xdp-filter
# _xdp-filter — simple high-performance XDP packet filter (xdp-project/xdp-tools)
# upstream: https://github.com/xdp-project/xdp-tools
# Subcommands + per-command flags from xdp-filter/xdp-filter.8.

_xdp-filter() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_xdp-filter_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                load)
                    _arguments \
                        '(-m --mode)'{-m+,--mode=}'[XDP attach mode]:mode:(native skb hw unspecified)' \
                        '(-p --policy)'{-p+,--policy=}'[default policy]:policy:(allow deny)' \
                        '(-f --features)'{-f+,--features=}'[features to enable (comma-separated)]:features:(ipv4 ipv6 tcp udp ethernet all)' \
                        '*'{-v,--verbose}'[increase verbosity]' \
                        '1:ifname:_net_interfaces' && ret=0 ;;
                unload)
                    _arguments \
                        '(-a --all)'{-a,--all}'[unload from all interfaces]' \
                        '(-k --keep-maps)'{-k,--keep-maps}'[keep BPF maps after unloading]' \
                        '*'{-v,--verbose}'[increase verbosity]' \
                        '1:ifname:_net_interfaces' && ret=0 ;;
                port)
                    _arguments \
                        '(-r --remove)'{-r,--remove}'[remove instead of adding the port]' \
                        '(-m --mode)'{-m+,--mode=}'[match mode]:mode:(src dst src,dst)' \
                        '(-p --proto)'{-p+,--proto=}'[protocol]:proto:(tcp udp)' \
                        '(-s --status)'{-s,--status}'[print status after the change]' \
                        '*'{-v,--verbose}'[increase verbosity]' \
                        '1:port number:' && ret=0 ;;
                ip)
                    _arguments \
                        '(-r --remove)'{-r,--remove}'[remove the address from the filter list]' \
                        '(-m --mode)'{-m+,--mode=}'[match mode]:mode:(src dst src,dst)' \
                        '(-s --status)'{-s,--status}'[print status after the change]' \
                        '*'{-v,--verbose}'[increase verbosity]' \
                        '1:IP address:' && ret=0 ;;
                ether)
                    _arguments \
                        '(-r --remove)'{-r,--remove}'[remove the MAC from the filter list]' \
                        '(-m --mode)'{-m+,--mode=}'[match mode]:mode:(src dst src,dst)' \
                        '(-s --status)'{-s,--status}'[print status after the change]' \
                        '*'{-v,--verbose}'[increase verbosity]' \
                        '1:MAC address:' && ret=0 ;;
                status)
                    _arguments \
                        '*'{-v,--verbose}'[increase verbosity]' && ret=0 ;;
                poll)
                    _arguments \
                        '(-i --interval)'{-i+,--interval=}'[poll interval in seconds]:seconds:' \
                        '*'{-v,--verbose}'[increase verbosity]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_xdp-filter_commands] )) ||
_xdp-filter_commands() {
    local -a commands
    commands=(
        'load:load xdp-filter on an interface'
        'unload:unload xdp-filter from an interface'
        'port:add or remove a port in the filter list'
        'ip:add or remove an IP address in the filter list'
        'ether:add or remove an Ethernet MAC in the filter list'
        'status:show current xdp-filter status'
        'poll:periodically poll statistics output'
        'help:show available commands'
    )
    _describe -t commands 'xdp-filter command' commands
}

_xdp-filter "$@"
