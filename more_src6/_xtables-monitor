#compdef xtables-monitor
# _xtables-monitor — netfilter xtables-monitor (stream live netlink notifications about iptables / ip6tables / nftables rule, set, table, chain, counter and trace events; -e EVENTS comma list, -t TABLE filter, -c COMMAND filter, -V version, -h help; common with --trace to follow packets through the rules)
# upstream: https://git.netfilter.org/iptables
# Flags from netfilter/iptables iptables/xtables-monitor.c on tip.

_xtables-monitor() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-e+[event mask]:events:(trace events all newrule delrule newchain delchain newtable deltable newobj delobj newset delset newgen genfamily)' \
        '-t+[table filter]:table:(filter nat mangle raw security)' \
        '-c+[command filter]:cmd:'
}

_xtables-monitor "$@"
