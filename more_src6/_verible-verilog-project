#compdef verible-verilog-project
# Documentation: https://chipsalliance.github.io/verible/
# Source: chipsalliance/verible verible/verilog/tools/project/project-tool.cc — file-dependency / symbol-reference analyzer.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--file_list_path=[file list (SV files ordered by definition dependency)]:path:_files' \
    '--file_list_root=[absolute root prepended to relative paths in file list]:dir:_directories' \
    '--include_dir_paths=[comma-separated include search dirs (first match wins)]:dirs:' \
    '--output_format=[file-deps output format]:fmt:(human tsort dot)' \
    '--flagfile=[load flags from comma-separated files]:files:_files' \
    '--fromenv=[set flags from env (comma-separated)]:flags:' \
    '--tryfromenv=[try to set flags from env if present]:flags:' \
    '--undefok=[flag names ok to specify on CLI]:flags:' \
    && ret=0

return ret
