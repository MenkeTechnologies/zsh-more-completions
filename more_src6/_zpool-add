#compdef zpool-add
# _zpool-add — OpenZFS zpool add (add new top-level vdevs to an existing pool; -f forces, -n dry-run, -g show pool config, -L resolve symlinks, -P print full pathnames, -o ashift sets sector size for the new vdev; positional pool followed by vdev specifications (mirror/raidz1/raidz2/...))
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zpool/zpool_main.c (zpool_do_add) on tip.

_zpool-add() {
    _arguments \
        '-f[force]' \
        '-n[dry run (no changes)]' \
        '-g[show GUIDs]' \
        '-L[resolve symlinks]' \
        '-P[print full path]' \
        '*-o+[property=value]:property=value:(ashift= cachefile=)' \
        '1:pool:' \
        '*:vdev type or device:(mirror raidz raidz1 raidz2 raidz3 draid log cache spare special dedup)'
}

_zpool-add "$@"
