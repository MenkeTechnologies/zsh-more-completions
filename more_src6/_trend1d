#compdef trend1d
# Documentation: https://docs.generic-mapping-tools.org/latest/trend1d.html
# Source: GenericMappingTools/gmt classic-mode trend1d — fit polynomial/Fourier/Chebyshev/cosine model to 1-D data.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-F+[output cols: xymrw / coefficients p / P / c]:cols:_default' \
    '-N+[model components (p/P polynomial, f/F Fourier, c/C cosine, s/S sine, x)]:model:_default' \
    '-C+[max condition number]:value:_default' \
    '-I+[iterative significance refinement]:level:_default' \
    '*-V[verbose (stackable)]' \
    '-W+[weighted LSQ (+s for sigmas)]:opts:_default' \
    '-bi+[binary input format]:format:_default' \
    '-bo+[binary output format]:format:_default' \
    '-d+[nodata replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-q+[row selection]:opts:_default' \
    '-s+[NaN-record handling]:opts:_default' \
    '-:[swap first two columns]' \
    '*:input table:_files' \
    && ret=0

return ret
