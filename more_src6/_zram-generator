#compdef zram-generator
# _zram-generator — systemd zram device generator (systemd team, Rust); clap-rs
# upstream: https://github.com/systemd/zram-generator

_zram-generator() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--root=+[root dir]:dir:_files -/' \
        '*:arg:'
}

_zram-generator "$@"
