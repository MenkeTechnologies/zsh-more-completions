#compdef yayo
# Documentation: clap-generated completion produced by the real binary
# Reference accessed: 2026-05-21
# Verified: body of this file is the verbatim output of `yayo completion zsh`
#           at v0.2.7 (clap is the spec; no separate prose docs exist).
# Source: cargo binstall yayo@0.2.7 (probed via `completion zsh`)
# Repository: https://github.com/nickjer/yayo

autoload -U is-at-least

_yayo() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_yayo_commands" \
"*::: :->yayo" \
&& ret=0
    case $state in
    (yayo)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:yayo-command-$line[1]:"
        case $line[1] in
            (add)
_arguments "${_arguments_options[@]}" : \
'-a+[Algorithm used to generate code]:ALGORITHM:(SHA1 SHA256 SHA512)' \
'--algorithm=[Algorithm used to generate code]:ALGORITHM:(SHA1 SHA256 SHA512)' \
'-d+[Number of digits composing code]:DIGITS:' \
'--digits=[Number of digits composing code]:DIGITS:' \
'-s+[Duration in seconds of step]:STEP:' \
'--step=[Duration in seconds of step]:STEP:' \
'-h[Print help]' \
'--help[Print help]' \
':account -- Name of the account:' \
':secret -- Secret key used to generate code:' \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Name of the shell:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(delete)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':account -- Name of the account:' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(view)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':account -- Name of the account:' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_yayo__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:yayo-help-command-$line[1]:"
        case $line[1] in
            (add)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(delete)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(view)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_yayo_commands] )) ||
_yayo_commands() {
    local commands; commands=(
'add:Add a new account' \
'completion:Output shell completion' \
'delete:Delete an account' \
'list:List all accounts' \
'view:View the code for an account' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'yayo commands' commands "$@"
}
