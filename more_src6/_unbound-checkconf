#compdef unbound-checkconf
# _unbound-checkconf — NLnet Labs Unbound config validator (parses unbound.conf, reports syntax/semantic errors, optionally prints the resolved value of one option)
# upstream: https://github.com/NLnetLabs/unbound
# Flags from smallapp/unbound-checkconf.c + doc/unbound-checkconf.8.in on tip.

_unbound-checkconf() {
    _arguments \
        '(- *)-h[show help + version]' \
        '-f[print full pathname with chroot applied (use with -o)]' \
        '-q[quiet — suppress output on success]' \
        '-o+[print value of this option after check]:option:' \
        '1:cfgfile:_files'
}

_unbound-checkconf "$@"
