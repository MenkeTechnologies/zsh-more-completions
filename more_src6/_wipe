#compdef wipe
# Documentation: https://man.archlinux.org/man/wipe.1.en
# Reference accessed: 2026-05-21
# Verified: upstream wipe(1) man page at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show help]' \
  '-V[show version]' \
  '-a[abort on errors]' \
  '-A[do not abort on errors]' \
  '-c[do a chmod on write-protected files]' \
  '-d[do not wipe filenames]' \
  '-D[follow symlinks]' \
  '-e[use exact file size]' \
  '-E[do not use exact file size]' \
  '-f[force wipe without confirmation]' \
  '-i[informational (verbose) mode]' \
  '-I[non-interactive mode]' \
  '-k[keep files after wiping]' \
  '-K[do not keep files after wiping]' \
  '-n[do not actually wipe data]' \
  '-N[wipe normally]' \
  '-o[start at offset]:offset:' \
  '-O[do not skip beginning]' \
  '-r[recurse into subdirectories]' \
  '-R[recursive remove without prompting]' \
  '-s[silent mode]' \
  '-t[test mode]' \
  '-T[do not test mode]' \
  '-u[show usage]' \
  '-v[verbose output]' \
  '-w[wipe filenames only]' \
  '-x[secure mode (default)]' \
  '-X[do not use secure mode]' \
  '-z[also wipe with zeros]' \
  '-Z[do not wipe with zeros]' \
  '-B+[block device sector count]:count:' \
  '-S+[block device sector size]:size:' \
  '-C+[chunk size]:size:' \
  '-l+[security level (0-2)]:level:(0 1 2)' \
  '-p+[loop passes (1-32)]:passes:' \
  '-b+[custom byte value (0-255)]:byte:' \
  '*:file:_files' && ret=0

return ret
