#compdef telnyx
# Documentation: https://github.com/team-telnyx/telnyx-cli
# Reference accessed: 2026-05-21
# Verified: upstream README. The README documents the global-flag set in
# detail but enumerates only one resource ('calls' in the dial example) and
# directs users to '--help' for the resource list.
# Removed from prior file: fabricated subcommands 'auth', 'message', 'call'
# (singular), 'number', 'voice-profile', 'messaging-profile', 'connection',
# 'webhook', 'address', 'fax', 'storage', 'wireless', 'verify', 'audit',
# 'help', 'version' and their sub-subcommands (none of these are in the
# upstream README; the CLI is resource-driven and resource names are not
# enumerated upstream — leaving them open).

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(-v --version)'{-v,--version}'[show CLI version]' \
  '--api-key=[Telnyx API key (or TELNYX_API_KEY)]:key:' \
  '--public-key=[Telnyx public key (or TELNYX_PUBLIC_KEY)]:key:' \
  '--client-id=[OAuth client id (or TELNYX_CLIENT_ID)]:id:' \
  '--client-secret=[OAuth client secret (or TELNYX_CLIENT_SECRET)]:secret:' \
  '--base-url=[custom API backend URL]:url:' \
  '--format=[output format]:format:(auto explore json jsonl pretty raw yaml)' \
  '--format-error=[error output format]:format:(auto explore json jsonl pretty raw yaml)' \
  '--transform=[GJSON transform of output]:expression:' \
  '--transform-error=[GJSON transform of error output]:expression:' \
  '--debug[enable debug logging]' \
  '1: :' \
  '*:: :_default' && ret=0

return ret
