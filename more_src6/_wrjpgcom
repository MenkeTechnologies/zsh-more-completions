#compdef wrjpgcom rdjpgcom
# Documentation: man wrjpgcom(1) / man rdjpgcom(1) (libjpeg)
# Source: libjpeg wrjpgcom/rdjpgcom — JPEG COM-block (comment) insert / read.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-replace)-replace[delete existing COM blocks]' \
    '(-comment -cfile)-comment+[new COM block text]:text:' \
    '(-comment -cfile)-cfile+[read new COM block from FILE]:file:_files' \
    '-raw[(rdjpgcom) print raw (unprocessed) comment text]' \
    '-verbose[(rdjpgcom) include filename in output]' \
    '*:JPEG file:_files -g "*.{jpg,jpeg,jpe,jif,jfif}"' \
    && ret=0

return ret
