#compdef vboxballoonctrl VBoxBalloonCtrl
# Documentation: https://github.com/mirror/vbox/blob/master/src/VBox/Frontends/VBoxBalloonCtrl/VBoxWatchdog.cpp
# Reference accessed: 2026-05-21
# Verified: upstream VirtualBox VBoxWatchdog.cpp source.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-b --background)'{-b,--background}'[run in daemon mode (Unix-like)]' \
  '--disable-=[disable a module]:module:' \
  '--dryrun[run without performing actions]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-P --pidfile)'{-P+,--pidfile=}'[PID file]:file:_files' \
  '(-F --logfile)'{-F+,--logfile=}'[log file]:file:_files' \
  '(-R --logrotate)'{-R+,--logrotate=}'[log rotation count]:n:' \
  '(-S --logsize)'{-S+,--logsize=}'[max log size bytes]:bytes:' \
  '(-I --loginterval)'{-I+,--loginterval=}'[log rotation interval sec]:sec:' && ret=0

return ret
