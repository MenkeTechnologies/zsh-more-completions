#compdef texindy
# _texindy — TeX Live texindy (xindy wrapper preconfigured for LaTeX with -M tex/inputenc/latex prepended; same option vocabulary as xindy, default input encoding follows the .idx file)
# upstream: https://github.com/ku-tex/xindy
# Flags from xindy texindy.pl on tip.

_texindy() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-q[quiet]' \
        '-d[debug]' \
        '-L+[language module]:lang:' \
        '-C+[codepage]:codepage:' \
        '*-M+[style module]:module:' \
        '-I+[input encoding]:enc:(latin xindy utf8)' \
        '-o+[output index]:file:_files -g "*.ind"' \
        '-t+[log file]:file:_files -g "*.ilg"' \
        '-g[merge rules off]' \
        '*:idx file:_files -g "*.idx"'
}

_texindy "$@"
