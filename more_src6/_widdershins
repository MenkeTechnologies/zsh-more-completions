#compdef widdershins
# _widdershins — OpenAPI to Slate/Shins-compatible Markdown converter (Mermade/widdershins)
# upstream: https://github.com/Mermade/widdershins
# Flags from widdershins.js (yargs).

_widdershins() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-a --abstract)'{-a+,--abstract=}'[ReSpec abstract include file]:file:_files -g "*.md"' \
        '--clipboard[set code_clipboard header]' \
        '(-c --code)'{-c,--code}'[omit generated code samples]' \
        '--customApiKeyValue=[custom API key value in examples]:value:' \
        '*'{-i+,--includes=}'[include file (repeatable)]:file:_files' \
        '(-d --discovery)'{-d,--discovery}'[include schema.org WebAPI discovery data]' \
        '(-e --environment)'{-e+,--environment=}'[config file]:file:_files' \
        '--expandBody[expand schema in request body]' \
        '--experimental[enable experimental features]' \
        '--headings=[headingLevel for table of contents]:n:' \
        '--httpsnippet[use httpsnippet for code samples]' \
        '--html[output HTML instead of Markdown]' \
        '(-l --lang)'{-l,--lang}'[generate language tabs from x-code-samples]' \
        '--language_tabs=[language tabs (language[\:label[\:client]])]:tabs:' \
        '(-m --maxDepth)'{-m+,--maxDepth=}'[max schema example depth]:n:' \
        '--omitBody[omit body parameter from params table]' \
        '--omitHeader[omit YAML front-matter]' \
        '(-o --outfile)'{-o+,--outfile=}'[output Markdown file]:file:_files' \
        '(-r --raw)'{-r,--raw}'[output raw schemas]' \
        '--resolve[resolve external $refs]' \
        '--respec=[ReSpec config object filename]:file:_files' \
        '(-s --search)'{-s,--search}'[enable Slate search]' \
        '--shallowSchemas[do not expand $refs]' \
        '--sotd=[ReSpec SotD include file]:file:_files -g "*.md"' \
        '--summary[use operation summary as TOC entry]' \
        '(-t --theme)'{-t+,--theme=}'[syntax-highlighter theme]:theme:' \
        '--useBodyName[use bodyName for request body]' \
        '--user_templates=[user template dir]:dir:_files -/' \
        '--verbose[verbose output]' \
        '-y[output YAML front-matter]' \
        '--yaml[output YAML front-matter]' \
        '1:input file or URL:_files -g "*.{yaml,yml,json}"' \
        '2:output file:_files'
}

_widdershins "$@"
