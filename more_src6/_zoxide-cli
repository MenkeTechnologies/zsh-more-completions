#compdef zoxide-cli
# Documentation: https://github.com/ajeetdsouza/zoxide
# Reference accessed: 2026-05-21
# Verified: upstream man pages (zoxide-*.1) and edit.rs source.
# Removed from prior file: --no-aliases (not a real flag; only --no-cmd
# exists) and `edit add` subcommand (real edit subcommands are
# decrement, delete, increment, reload per src/cmd/edit.rs).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add a directory to the database'
  'edit:edit the database'
  'import:import entries from another tool'
  'init:print init script for shell'
  'query:search for a directory'
  'remove:remove a directory'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'zoxide command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (add)
        _arguments '*: :_files -/' && ret=0 ;;
      (remove)
        _arguments \
          '(-i --interactive)'{-i,--interactive}'[interactive selection]' \
          '*: :_files -/' && ret=0 ;;
      (query)
        _arguments \
          '--all[show deleted directories]' \
          '(-i --interactive)'{-i,--interactive}'[interactive fzf selection]' \
          '(-l --list)'{-l,--list}'[list matches]' \
          '(-s --score)'{-s,--score}'[show scores]' \
          '*--exclude=[exclude path]:dir:_files -/' \
          '*: :' && ret=0 ;;
      (edit)
        _arguments \
          '1:subcommand:(decrement delete increment reload)' \
          '*: :_files' && ret=0 ;;
      (import)
        _arguments \
          '--from=[source format]:format:(autojump z)' \
          '--merge[merge into existing db]' \
          '*: :_files' && ret=0 ;;
      (init)
        _arguments \
          '--cmd=[prefix for z/zi commands]:cmd:' \
          '--hook=[hook frequency]:hook:(none prompt pwd)' \
          '--no-cmd[do not define z/zi commands]' \
          '1:shell:(bash elvish fish nushell posix powershell xonsh zsh)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
