#compdef zot-cli zli
# _zot-cli — Project Zot zli CLI alias for OCI registry (Project Zot / zot-cli, Go); spf13/cobra
# upstream: https://github.com/project-zot/zot

_zot-cli() {
    local -a sub=(
        'config:manage CLI config'
        'image:image commands'
        'cve:CVE search commands'
        'repos:list repositories'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g "*.json"' \
        '-c+[config file]:file:_files -g "*.json"' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '--user=+[username:password]:str:' \
        '--insecure[skip TLS verify]' \
        '--output=+[output format]:fmt:(text json yaml)' \
        '-o+[output format]:fmt:(text json yaml)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zli subcommand' sub ;;
        args)
            case $words[1] in
                config) _arguments \
                    '1:cmd:(add update remove list reset)' \
                    '*:arg:' ;;
                image) _arguments \
                    '1:cmd:(list name digest cve)' \
                    '--repo=+[repo]:str:' \
                    '--tag=+[tag]:str:' \
                    '--digest=+[digest]:str:' \
                    '*:arg:' ;;
                cve) _arguments \
                    '1:cmd:(list image affected fixed)' \
                    '--cve=+[CVE]:str:' \
                    '--image=+[image]:str:' \
                    '--severity=+[severity]:s:(critical high medium low none unknown)' \
                    '*:arg:' ;;
                repos) _arguments \
                    '--last-update[order by last update]' \
                    '--with-tags[include tags]' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_zot-cli "$@"
