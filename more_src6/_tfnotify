#compdef tfnotify
# Documentation: https://github.com/mercari/tfnotify
# Reference accessed: 2026-05-30
# tfnotify — Mercari's Go-based wrapper that pipes Terraform output through
# template processing and posts to GitHub/GitLab/Bitbucket as PR comments.
# Operates stdin-driven: pipe `terraform plan` output via `tfnotify plan`.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'plan:format and post a terraform plan output as a notification'
  'apply:format and post a terraform apply output as a notification'
  'fmt:format and post a terraform fmt output as a notification'
)

_arguments -C -s -S \
  '(- *)--help[show help]' \
  '--config=[configuration file path (default ./.tfnotify.y{,a}ml)]:file:_files -g "*.(yml|yaml)"' \
  '--message=[custom message passed to templates]:message:' \
  '(-): :->subcmd' \
  '(-)*:: :->subcmd_args' \
  && ret=0

case $state in
  subcmd)
    _describe -t commands 'tfnotify subcommand' _subcmds && ret=0
    ;;
  subcmd_args)
    # Each subcommand consumes stdin and accepts only the global flags
    # (--config / --message / --help). No per-subcommand flags documented.
    _arguments \
      '--config=[configuration file path]:file:_files -g "*.(yml|yaml)"' \
      '--message=[custom message]:message:' \
      && ret=0
    ;;
esac

return ret
