#compdef vapor-cli
# _vapor-cli — Laravel Vapor serverless deployment CLI alias (laravel team, PHP); symfony console
# upstream: https://github.com/laravel/vapor-cli

_vapor-cli() {
    local -a sub=(
        'login:login to vapor'
        'logout:logout'
        'team:show team'
        'teams:list teams'
        'team:switch:switch team'
        'init:init project'
        'app:show app'
        'apps:list apps'
        'app:create:create app'
        'app:delete:delete app'
        'env:list:list envs'
        'env:show:show env'
        'env:pull:pull env'
        'env:push:push env'
        'env:edit:edit env'
        'env:clone:clone env'
        'env:create:create env'
        'env:delete:delete env'
        'deploy:deploy project'
        'deployments:list deployments'
        'rollback:rollback deployment'
        'cache:list:list caches'
        'cache:create:create cache'
        'cache:delete:delete cache'
        'database:list:list databases'
        'database:create:create database'
        'database:delete:delete database'
        'database:restore:restore database'
        'database:backups:list backups'
        'metrics:show metrics'
        'jumpbox:provision jumpbox'
        'network:show network'
        'networks:list networks'
        'network:create:create network'
        'queue:show:show queue'
        'queue:work:start queue worker'
        'logs:tail logs'
        'cert:create:create cert'
        'cert:delete:delete cert'
        'cert:list:list certs'
        'domain:list:list domains'
        'domain:create:add domain'
        'domain:delete:remove domain'
        'completion:dump completion'
        'help:show help'
        'list:list commands'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vapor subcommand' sub ;;
        args)
            case $words[1] in
                deploy) _arguments '1:environment:' \
                    '--fresh-assets[fresh assets]' \
                    '--without-waiting[no wait]' \
                    '--commit=+[commit]:str:' \
                    '--message=+[message]:str:' ;;
                rollback) _arguments '1:environment:' '2:deployment id:' ;;
                logs) _arguments '1:environment:' '--start=+[start time]:str:' '--end=+[end time]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_vapor-cli "$@"
