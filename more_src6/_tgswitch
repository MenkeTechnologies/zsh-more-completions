#compdef tgswitch
# Documentation: https://github.com/warrensbox/tgswitch
# Reference accessed: 2026-05-21
# Verified: upstream main.go at the URL above.

_tgswitch() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments \
        '(-b --bin)'{-b,--bin}'+[Custom binary path for Terragrunt]:path:_files' \
        '(-c --chdir)'{-c,--chdir}'+[Working directory]:dir:_directories' \
        '(-h --help)'{-h,--help}'[Show help]' \
        '(-v --version)'{-v,--version}'[Show tgswitch version]' \
        '1:version:'
}

_tgswitch "$@"
