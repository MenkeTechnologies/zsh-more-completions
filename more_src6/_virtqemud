#compdef virtqemud virtxend virtbhyved virtlxcd virtvboxd virtvzd
# _virtqemud — libvirt per-driver daemons (virtqemud / virtxend / virtbhyved / virtlxcd / virtvboxd / virtvzd manage their respective hypervisor connections in the split-daemon architecture replacing monolithic libvirtd; -d daemonize, -f config, -p pidfile, -t timeout seconds, -v verbose)
# upstream: https://gitlab.com/libvirt/libvirt (src/remote/remote_daemon.c per-driver wrappers)
# Flags from libvirt src/remote/remote_daemon.c on tip.

_virtqemud() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-d[daemonize]' \
        '-f+[config file]:file:_files' \
        '-p+[pidfile]:file:_files' \
        '-t+[timeout seconds]:seconds:'
}

_virtqemud "$@"
