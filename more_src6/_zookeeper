#compdef zkServer.sh zookeeper-server zookeeper
# _zookeeper — Apache ZooKeeper server launcher (zkServer.sh start|start-foreground|stop|restart|status|upgrade|print-cmd|version on the local ensemble node; positional argument is the subcommand, optional second positional is the zoo.cfg path overriding the bundled config)
# upstream: https://github.com/apache/zookeeper
# Subcommands from Apache ZooKeeper zookeeper-server/bin/zkServer.sh on tip.

_zookeeper() {
    _arguments \
        '-h[show help]' \
        '1:command:(start start-foreground stop restart status upgrade print-cmd version)' \
        '2:zoo.cfg:_files -g "*.cfg"'
}

_zookeeper "$@"
