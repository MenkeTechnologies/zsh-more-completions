#compdef valhalla_expand_bounding_box
# Documentation: https://github.com/valhalla/valhalla
# Source: valhalla/valhalla src/valhalla_expand_bounding_box.cc — expand a bbox by the configured padding.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '(-c --config)'{-c+,--config=}'[path to JSON config file]:file:_files -g "*.json(-.)"' \
    '(-i --inline-config)'{-i+,--inline-config=}'[inline JSON config]:json:_default' \
    '(-b --bounding-box)'{-b+,--bounding-box=}'[bbox to expand: min_x,min_y,max_x,max_y]:bbox:_default' \
    && ret=0

return ret
