#compdef zfs-release
# _zfs-release — OpenZFS zfs release release a hold on a snapshot CLI alias (openzfs team, C); custom argparse
# upstream: https://github.com/openzfs/zfs

_zfs-release() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-r[recursive]' \
        '*:tag snapshot:'
}

_zfs-release "$@"
