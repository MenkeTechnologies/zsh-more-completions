#compdef wal-e
# Documentation: https://github.com/wal-e/wal-e
# Source: wal-e/wal-e wal_e/cmd.py — continuous archiving for Postgres (Python, argparse).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _wale_cmds
_wale_cmds=(
    'backup-fetch:fetch a base backup'
    'backup-list:list base backups'
    'backup-push:perform a base backup push'
    'wal-fetch:fetch a WAL segment'
    'wal-push:push a WAL segment'
    'wal-prefetch:prefetch a WAL segment'
    'delete:delete backups by various criteria'
    'version:print wal-e version'
)

_arguments -C \
    '--s3-prefix=[S3 prefix for backups]:url:_default' \
    '--gs-prefix=[Google Storage prefix for backups]:url:_default' \
    '--wabs-prefix=[Azure Blob Storage prefix for backups]:url:_default' \
    '--swift-prefix=[Swift prefix for backups]:url:_default' \
    '--file-prefix=[file prefix for backups]:url:_default' \
    '--terse[show less information]' \
    '--aws-instance-profile[use AWS instance profile]' \
    '--k=[encryption key]:keyid:_default' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[print version]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'wal-e command' _wale_cmds && ret=0
        ;;
    args)
        case $line[1] in
            delete)
                _values 'delete strategy' \
                    'before[delete backups before a given backup or LSN]' \
                    'retain[retain the N most recent backups]' \
                    'everything[delete all backups]' \
                    'old-versions[delete old-format backups]' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
