#compdef talwani3d
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/potential/talwani3d.html
# Source: GenericMappingTools/gmt supplements/potential — 3-D Talwani body gravity / VGG / geoid.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-I+[grid spacing dx/dy]:spacing:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-A[z-axis positive upwards (default down)]' \
    '-D+[fixed density contrast]:density:_default' \
    '-F+[field type]:type:(f n v)' \
    '-G+[output grid file]:file:_files' \
    '-M+[distance units (h/v km or m)]:opts:_default' \
    '-N+[observation track file]:file:_files' \
    '*-V[verbose (stackable)]' \
    '-Z+[observation level (constant or grid)]:opts:_default' \
    '-bo+[binary output format]:format:_default' \
    '-d+[nodata replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-o+[output column selection]:cols:_default' \
    '-r[pixel registration (default gridline)]' \
    '-x+[CPU cores limit]:n:_default' \
    '-:[swap first two columns]' \
    '*:input polygon file:_files' \
    && ret=0

return ret
