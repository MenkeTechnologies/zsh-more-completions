#compdef zbarimg
# Documentation: zbarimg --help (zbar)
# Source: scan and decode barcodes from image files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '--polygon[output points delimiting code zone]' \
    {-q,--quiet}'[minimal output]' \
    {-v,--verbose}'[increase debug output level]' \
    '--verbose=[set specific debug level]:level:' \
    '(-D --nodisplay)'{-d,--display}'[enable display of following images]' \
    '(-d --display)'{-D,--nodisplay}'[disable display of following images]' \
    '(--noxml)--xml[enable XML output format]' \
    '(--xml)--noxml[disable XML output format]' \
    '--raw[output decoded data without charset conversion]' \
    '(-1 --oneshot)'{-1,--oneshot}'[exit after one bar code]' \
    '*'{-S+,--set=}'[set decoder/scanner CONFIG[=VALUE]]:config:' \
    '*:image:_files -g "*.(png|jpg|jpeg|gif|tiff|tif|bmp|pbm|pgm|ppm|pnm|webp)"' \
    && ret=0

return ret
