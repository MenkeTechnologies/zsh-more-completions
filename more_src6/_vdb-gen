#compdef vdb-gen
# _vdb-gen — Vertica Kubernetes operator helper that inspects a running Vertica database and emits a matching VerticaDB CR YAML
# upstream: https://github.com/vertica/vertica-kubernetes
# Flags from cmd/vdb-gen/main.go on tip; positional args: <host> <db>.

_vdb-gen() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--user=[Vertica user with rights to inspect the schema]:user:' \
        '--password=[password for --user]:password:' \
        '--tls-mode=[TLS mode used when connecting]:mode:(none server server-strict)' \
        '--name=[name of the generated VerticaDB CR]:name:' \
        '--port=[Vertica server port]:port:' \
        '--ignore-cluster-lease[ignore the cluster lease check]' \
        '--image=[container image referenced by the generated VerticaDB]:image:' \
        '--license=[license file referenced by the generated VerticaDB]:file:_files' \
        '--cafile=[CA cert file referenced by the generated VerticaDB]:file:_files' \
        '--cacert-name=[name of the Secret holding the CA cert]:name:' \
        '--hadoop-config=[HDFS hadoop-config directory referenced by the generated VerticaDB]:dir:_files -/' \
        '--account-name=[Azure storage account name referenced by the generated VerticaDB]:name:' \
        '--krb5-conf=[krb5.conf referenced by the generated VerticaDB]:file:_files' \
        '--krb5-keytab=[keytab referenced by the generated VerticaDB]:file:_files' \
        '--depot-volume=[depot volume type]:type:(PersistentVolume EmptyDir)' \
        '1:host:' \
        '2:db:'
}

_vdb-gen "$@"
