#compdef xmlif
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/xmlif.1.html
# Reference accessed: 2026-05-21
# Verified: upstream xmlif(1) manpage. xmlif takes only attribute=value pairs;
# no -D/-h/-v flags exist in the documented interface.

local curcontext="$curcontext" state line ret=1
_arguments -s -S '*:attribute=value pair: ' && ret=0
return ret
