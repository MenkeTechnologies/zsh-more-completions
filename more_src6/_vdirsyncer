#compdef vdirsyncer
# Documentation: https://www.mankier.com/1/vdirsyncer
# Reference accessed: 2026-05-21
# Verified: upstream vdirsyncer(1) manpage on mankier.

# completions for vdirsyncer CardDAV/CalDAV synchronization

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message and exit]' \
  '(- *)--version[show version and exit]' \
  {-c+,--config=}'[configuration file]:file:_files' \
  '-v[verbose output]' \
  '--verbosity=[set verbosity level]:level:(CRITICAL WARNING INFO DEBUG)' \
  '*::args:->subcmds' && ret=0

case $state in
  subcmds)
    local -a commands
    commands=(
      'discover:discover collections on servers'
      'metasync:synchronize metadata'
      'repair:repair storage'
      'sync:synchronize collections'
      'showconfig:display configuration as JSON'
    )
    _describe -t commands 'vdirsyncer command' commands && ret=0
    ;;
esac

return ret
