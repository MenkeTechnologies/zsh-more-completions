#compdef verible-verilog-obfuscate
# Documentation: https://chipsalliance.github.io/verible/
# Source: chipsalliance/verible verible/verilog/tools/obfuscator/verilog-obfuscate.cc — identifier obfuscation / de-obfuscation.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--load_map=[pre-load existing translation dictionary]:map:_files' \
    '--save_map=[save translation to dictionary for later reuse]:map:_files' \
    '--decode[with --load_map, apply translation dictionary in reverse to de-obfuscate]' \
    '--preserve_interface[preserve module/port/parameter names; identity maps in saved map]' \
    '--preserve_builtin_functions[preserve built-in function names like sin(), ceil()]' \
    '--flagfile=[load flags from comma-separated files]:files:_files' \
    '--fromenv=[set flags from env (comma-separated)]:flags:' \
    '--tryfromenv=[try to set flags from env if present]:flags:' \
    '--undefok=[flag names ok to specify on CLI]:flags:' \
    '*:SV source file:_files' \
    && ret=0

return ret
