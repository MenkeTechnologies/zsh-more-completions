#compdef vlogscli
# _vlogscli — VictoriaLogs interactive query CLI (LogsQL REPL against /select/logsql/query + live-tail)
# upstream: https://github.com/VictoriaMetrics/VictoriaLogs
# Flags from app/vlogscli/main.go on tip; all flags can also be set via the matching VL_<flag> environment variable.

_vlogscli() {
    _arguments \
        '(- *)'{-h,-help,--help}'[show help]' \
        '-datasource.url=[VictoriaLogs query URL]:url:_urls' \
        '-tail.url=[VictoriaLogs live-tail URL (auto from -datasource.url if empty)]:url:_urls' \
        '-historyFile=[history file path]:file:_files' \
        '*-header=[header to pass to -datasource.url (HeaderName: value, repeatable)]:hdr:' \
        '-accountID=[multitenancy account id]:n:' \
        '-projectID=[multitenancy project id]:n:' \
        '-username=[basic-auth username]:user:' \
        '-password=[basic-auth password]:pwd:' \
        '-bearerToken=[bearer auth token]:token:' \
        '-tlsCAFile=[TLS CA file for verifying -datasource.url]:file:_files' \
        '-tlsCertFile=[client-side TLS cert file]:file:_files' \
        '-tlsKeyFile=[client-side TLS key file]:file:_files' \
        '-tlsServerName=[TLS server name override]:name:' \
        '-tlsInsecureSkipVerify[skip TLS verification]'
}

_vlogscli "$@"
