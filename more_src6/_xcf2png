#compdef xcf2png xcf2pnm
# Documentation: https://manpages.debian.org/xcf2png
# Source: xcftools xcf2png.c — convert GIMP .xcf to PNG (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-A --force-alpha)'{-A,--force-alpha}'[force alpha channel]' \
    '(-b --background)'{-b+,--background=}'[background colour]:color:_default' \
    '(-c --color --colour)'{-c,--color,--colour}'[force RGB output]' \
    '(-C --autocrop)'{-C,--autocrop}'[autocrop to visible layers]' \
    '(-D --dissolve)'{-D,--dissolve}'[dissolve partial transparency]' \
    '(-f --full-image)'{-f,--full-image}'[flatten entire image in memory]' \
    '(-g --gray --grey)'{-g,--gray,--grey}'[force grayscale output]' \
    '(-G --for-gif)'{-G,--for-gif}'[assume no partial transparency for GIF]' \
    '(-j --bzip)'{-j,--bzip}'[input is .xcf.bz2]' \
    '(-z --gzip)'{-z,--gzip}'[input is .xcf.gz]' \
    '-Z+[command to uncompress input]:command:_command_names' \
    '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
    '(-O --offset)'{-O+,--offset=}'[offset x,y]:x,y:_default' \
    '(-S --size)'{-S+,--size=}'[output size WxH]:WxH:_default' \
    '(-T --truecolor)'{-T,--truecolor}'[force truecolor output]' \
    '(-u --unpack)'{-u,--unpack}'[unpack input without converting]' \
    '1:xcf file:_files -g "*.{xcf,xcf.gz,xcf.bz2}"' \
    '*:layer names:_default' \
    && ret=0

return ret
