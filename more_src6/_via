#compdef via via-cli
# _via — VIA mechanical keyboard configurator (caksoylar/via team, TypeScript); commander
# upstream: https://github.com/the-via/app

_via() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--keyboard=+[keyboard]:str:' \
        '-k+[keyboard]:str:' \
        '--port=+[serial port]:str:_files -g "/dev/tty.*"' \
        '-p+[serial port]:str:_files -g "/dev/tty.*"' \
        '--definition=+[keyboard definition v3 file]:file:_files -g "*.json"' \
        '-d+[keyboard definition file]:file:_files -g "*.json"' \
        '--no-internet[no internet]' \
        '--enable-debug[enable debug]' \
        '--list-devices[list HID devices]' \
        '-l[list HID devices]' \
        '--list-keyboards[list known keyboards]' \
        '--save=+[save keymap]:file:_files -g "*.json"' \
        '-s+[save keymap]:file:_files -g "*.json"' \
        '--load=+[load keymap]:file:_files -g "*.json"' \
        '-L+[load keymap]:file:_files -g "*.json"' \
        '--reset-keymap[reset keymap to default]' \
        '--reset-eeprom[reset EEPROM]' \
        '--layer=+[set layer]:n:' \
        '--set-key=+[set key row,col,layer=keycode]:str:' \
        '--get-key=+[get key row,col,layer]:str:' \
        '--macro=+[macro index]:n:' \
        '--rgb=+[rgb option]:str:' \
        '--api[run rest api]' \
        '--api-port=+[api port]:port:' \
        '*:arg:'
}

_via "$@"
