#compdef zipalign
# Documentation: https://developer.android.com/tools/zipalign
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for zipalign (Android ZIP alignment tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c[check alignment only]' \
  '-f[overwrite existing output file]' \
  '-h[show help]' \
  '-P+[page-align uncompressed .so files to specified KiB]:pagesize_kb:(4 16 64)' \
  '-p[4KiB page-align uncompressed .so files (deprecated; prefer -P 16)]' \
  '-v[verbose output]' \
  '-z[recompress using Zopfli]' \
  '1:alignment (bytes):(4 8 16)' \
  '2:input file:_files -g "*.{apk,zip}"' \
  '3:output file:_files -g "*.{apk,zip}"' && ret=0

return ret
