# tailon — webapp for looking at and searching through files and streams
#          (Go, 354★)
#
# upstream: https://github.com/gvalkov/tailon
# author : Georgi Valkov (gvalkov)
# license: Apache-2.0
#
# Source-direct completion: every flag below is verbatim from main.go on
# the gvalkov/tailon tip — spf13/pflag `flag.BoolP` / `flag.StringP` /
# `flag.StringVarP` / `flag.BoolVarP` registrations parsed exactly as
# declared.  The scriptEpilog comment documents the filespec syntax
# (`[alias=name,group=name]<source>` where source is a filename, glob,
# or directory).
#
# Direct deps from go.mod (selected):
#   github.com/pelletier/go-toml  v1.9.5  ← canonical Go TOML library
#                                            (this axis) — by Thomas
#                                            Pelletier (pelletier);
#                                            reference Go implementation
#                                            of the TOML 0.5 / 1.0 spec
#                                            with both load+dump
#                                            (typed-struct) and AST-
#                                            level (tree-walking) APIs.
#                                            v2 successor (`pelletier/
#                                            go-toml/v2`) is the modern
#                                            format-preserving editor;
#                                            v1 series remains widely
#                                            used by tools that just
#                                            need TOML parsing.
#   github.com/spf13/pflag                  (POSIX-style flag parser —
#                                            cobra's underlying flag
#                                            library, also used
#                                            standalone here)
#   github.com/mitchellh/mapstructure       (struct ↔ map conversion —
#                                            consumes the TOML AST into
#                                            tailon's typed config
#                                            structs)
#
# tailon is a self-hosted web app that exposes one or more log files,
# globs, or directories over HTTP with browser-side tail/grep/sed/awk
# pipelines.  Files are addressable as URL paths; the UI lets you
# select a file, then layer shell commands (whitelisted in config) over
# the stream.  Useful as a lightweight Loki/Splunk alternative for
# small fleets where running a full log aggregator is overkill.
#
# === AXIS 176 CONTINUES — format-preserving TOML editors ================
# Axis position: Go=231 continues Axis 176 (slot 2/0/0).  Canonical Go
# TOML library is `github.com/pelletier/go-toml` by Thomas Pelletier —
# reference Go implementation of the TOML 0.5/1.0 spec.  v1 series
# (still used by tailon) provides typed-struct load+dump plus AST-level
# tree-walking; v2 successor (`pelletier/go-toml/v2`) adds format-
# preserving edit + cleaner unmarshal/marshal API mirroring
# encoding/json.  The other major Go TOML library is `BurntSushi/toml`
# by Andrew Gallant (the same BurntSushi behind ripgrep/xsv/aho-corasick)
# but BurntSushi/toml does NOT preserve formatting — pelletier is the
# canonical answer when format-preserving TOML editing is required
# (e.g. for tools that mutate Cargo.toml-style config files).
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=231     _fallow              ← previous round (axis 176 OPENS, 1/0/0)
#   Go=231       ← THIS FILE          (axis 176 continues, slot 2/0/0)
#   TS-Node=231  ← next round         (axis 176 CLOSES at triple-231, 1/1/1)
# ---------------------------------------------------------------------------

_tailon() {
    _arguments -s \
        '(-h --help)'{-h,--help}'[show help message and exit]' \
        '(-e --help-config)'{-e,--help-config}'[show configuration file help and exit (prints the full TOML schema with defaults)]' \
        '(-b --bind)'{-b,--bind=}'[address(es) to listen on (comma-separated, e.g. :8080,localhost:8081)]:addresses:' \
        '(-r --relative-root)'{-r,--relative-root=}'[webapp relative root (e.g. /tailon/ if behind a reverse proxy at that prefix)]:path:' \
        '(-a --allow-download)'{-a,--allow-download}'[allow file downloads of files matched by a filespec]' \
        '(-c --config)'{-c,--config=}'[path to TOML configuration file (overrides defaults; see --help-config for schema)]:TOML config:_files -g "*.(toml|TOML)"' \
        '*:filespec ([alias=name,group=name]<source>; source = filename, glob, or directory):_files'
}

_tailon "$@"
