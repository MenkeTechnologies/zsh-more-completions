#compdef ttf2woff2 woff2_compress
# Documentation: https://github.com/google/woff2
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# google/woff2: woff2_compress takes a single TTF/OTF filename and writes
# .woff2 next to it. No flags documented.
# nfroidure/ttf2woff2 (NodeJS wrapper, same binary name on some installs)
# reads stdin and writes stdout — also no flags.

local curcontext="$curcontext" ret=1
_arguments -C \
  '*:input TTF/OTF font file:_files -g "*.(#i)(ttf|otf)"' && ret=0
return ret
