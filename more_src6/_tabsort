#compdef tabsort
# Documentation: https://astrometry.net/
# Source: dstndstn/astrometry.net util/tabsort-main.c — sort a FITS table by a column.
# Reference accessed: 2026-06-10
#
# Usage: tabsort [-d] column-name input-file output-file

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '-d[sort descending (default ascending)]' \
    '1:column name:_default' \
    '2:input FITS file:_files -g "*.(fits|fit|fts)(-.)"' \
    '3:output FITS file:_files -g "*.(fits|fit|fts)(-.)"' \
    && ret=0

return ret
