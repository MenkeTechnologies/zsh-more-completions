#compdef ypset
# _ypset — OpenBSD ypset (tell ypbind(8) on this host which YP server process to communicate with; useful when the YP server is off the local broadcast network)
# upstream: https://github.com/openbsd/src (usr.sbin/ypset)
# Flags from usr.sbin/ypset/ypset.8 on tip.

_ypset() {
    _arguments \
        '-d+[domain]:domain:' \
        '-h+[host whose ypbind to update]:host:_hosts' \
        '1:server:_hosts'
}

_ypset "$@"
