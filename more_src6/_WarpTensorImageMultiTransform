#compdef WarpTensorImageMultiTransform
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/WarpTensorImageMultiTransform.cxx — apply transforms to a DT tensor image (C++, mixed flags).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-R+[reference image]:file:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '--tightest-bounding-box[use tightest bounding box]' \
    '--reslice-by-header[reslice using header info]' \
    '--use-NN[nearest-neighbour interpolation]' \
    '--use-BSpline[B-spline interpolation]' \
    '*-i[invert the next affine transform]' \
    '1:ImageDimension:(2 3 4)' \
    '2:moving_tensor_image:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3:output_tensor_image:_files' \
    '*:warp/affine files (right-to-left order):_files' \
    && ret=0

return ret
