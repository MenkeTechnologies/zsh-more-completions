#compdef terminalizer
# Documentation: https://github.com/faressoft/terminalizer
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (commands/*.js yargs definitions).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:create a global config directory'
  'config:generate a config file in the current directory'
  'record:record a terminal session'
  'play:play a recorded session'
  'render:render a recording to GIF'
  'share:share a recording online'
  'generate:generate web player for a recording'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'terminalizer command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (record)
        _arguments \
          '(-c --config)'{-c,--config=}'[overwrite default configurations]:config file:_files -g "*.yml"' \
          '(-d --command)'{-d,--command=}'[command to be executed]:command:' \
          '(-k --skip-sharing)'{-k,--skip-sharing}'[skip sharing prompt]' \
          '1:output file:_files -g "*.yml"' && ret=0
        ;;
      (play)
        _arguments \
          '(-r --real-timing)'{-r,--real-timing}'[use actual recorded delays]' \
          '(-s --speed-factor)'{-s,--speed-factor=}'[speed factor multiplier]:speed:' \
          '1:recording file:_files -g "*.yml"' && ret=0
        ;;
      (render)
        _arguments \
          '(-o --output)'{-o,--output=}'[output file]:output file:_files -g "*.gif"' \
          '(-q --quality)'{-q,--quality=}'[quality (1-100)]:quality' \
          '(-s --step)'{-s,--step=}'[frame step (>1 reduces frames)]:step' \
          '1:recording file:_files -g "*.yml"' && ret=0
        ;;
      (share)
        _arguments '1:recording file:_files -g "*.yml"' && ret=0
        ;;
      (generate)
        _arguments \
          '(-o --output)'{-o,--output=}'[output directory]:directory:_directories' \
          '1:recording file:_files -g "*.yml"' && ret=0
        ;;
    esac
    ;;
esac

return ret
