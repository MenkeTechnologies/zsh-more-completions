#compdef zcashd zcash-qt
# Documentation: https://github.com/zcash/zcash (src/init.cpp SetupServerArgs)
# Reference accessed: 2026-05-29
# CLI bootstrap flags. zcash.conf settings (hundreds of -opt=value) not enumerated.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-version[print version and exit]' \
  '(- *)-?[print help message and exit]' \
  '(- *)-help[print help message and exit]' \
  '(- *)-help-debug[show all debugging options and exit]' \
  '-conf=-[path to configuration file]:file:_files' \
  '-datadir=-[data directory (cannot use ~)]:dir:_directories' \
  '-paramsdir=-[Zcash network parameters directory]:dir:_directories' \
  '-pid=-[specify PID file]:file:_files' \
  '-daemon[run in the background as a daemon and accept commands]' \
  '-printtoconsole[send trace/debug info to console instead of debug log]' \
  '-testnet[run on testnet network]' \
  '-regtest[run in regression test mode]' \
  '-debug=-[output debugging information for category]:category:' \
  '-debugexclude=-[exclude debugging category]:category:' \
  '-logips[include IP addresses in debug output]' \
  '-logtimestamps[prepend debug output with timestamps]' \
  '-logthreadnames[prepend debug output with thread name]' \
  '-shrinkdebugfile[shrink debug.log file on startup]' \
  '*:: :->args' && ret=0

return ret
