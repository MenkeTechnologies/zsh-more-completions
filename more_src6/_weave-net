#compdef weave-net
# Documentation: https://github.com/weaveworks/weave
# Reference accessed: 2026-05-21
# Verified: upstream prog/weaver/main.go flag definitions.

# weave-net (weaver binary): Weave Net per-node network agent
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--version[show version]' \
  '--print-peer-name[print peer name and exit]' \
  '--resume[resume existing peer state]' \
  '--expect-npc[expect NPC controller]' \
  '--pkt-debug[enable packet debug logging]' \
  '--no-discovery[disable peer discovery]' \
  '--no-dns[disable DNS server]' \
  '--no-fastdp[disable fast datapath]' \
  '--no-bridged-fastdp[disable bridged fastdp]' \
  '--awsvpc[enable AWS VPC mode]' \
  '--no-masq-local[do not masquerade traffic between local pods]' \
  '--proxy[run proxy]' \
  '--tls[enable TLS for proxy]' \
  '--tlsverify[verify TLS peer]' \
  '--rewrite-inspect[rewrite docker inspect output]' \
  '--no-default-ipalloc[disable default IPAM]' \
  '--no-rewrite-hosts[do not rewrite /etc/hosts]' \
  '--without-dns[disable proxy DNS]' \
  '--no-multicast-route[do not add multicast route]' \
  '--plugin[enable docker plugin]' \
  '--plugin-v2[enable docker plugin v2]' \
  '--plugin-v2-multicast[enable v2 multicast]' \
  '--host=[bind host]:host:_hosts' \
  '--name=[peer name]:name:' \
  '--nickname=[peer nickname]:nickname:' \
  '--password=[shared password]:password:' \
  '--weave-bridge=[weave bridge name]:bridge:' \
  '--docker-bridge=[docker bridge name]:bridge:' \
  '--datapath=[datapath device]:device:' \
  '--trusted-subnets=[trusted subnets CIDR list]:cidrs:' \
  '--db-prefix=[database file prefix]:prefix:' \
  '--host-root=[host root path]:dir:_files -/' \
  '--proc-path=[proc path]:dir:_files -/' \
  '--peer-discovery-url=[peer discovery URL]:url:' \
  '--token=[discovery token]:token:' \
  '--advertise-address=[advertise address]:addr:' \
  '--ipalloc-init=[IPAM init mode]:mode:' \
  '--ipalloc-range=[IPAM CIDR range]:cidr:' \
  '--ipalloc-default-subnet=[default subnet]:cidr:' \
  '--http-addr=[HTTP API bind addr]:addr:' \
  '--status-addr=[status server bind addr]:addr:' \
  '--metrics-addr=[metrics bind addr]:addr:' \
  '--plugin-socket=[plugin socket path]:path:_files' \
  '--plugin-mesh-socket=[plugin mesh socket]:path:_files' \
  '--hostname-from-label=[label name for hostname]:label:' \
  '--hostname-match=[hostname regex]:regex:' \
  '--hostname-replacement=[hostname replacement]:replacement:' \
  '--dns-domain=[DNS domain]:domain:' \
  '--dns-listen-address=[DNS listen addr]:addr:' \
  '--resolv-conf=[resolv.conf path]:file:_files' \
  '--tlscacert=[TLS CA cert]:file:_files' \
  '--tlscert=[TLS cert]:file:_files' \
  '--tlskey=[TLS key]:file:_files' \
  '--profile=[profile name]:profile:' \
  '--docker-api=[docker API endpoint]:endpoint:' \
  '*-H+[proxy listen address]:addr:' \
  '--port=[bind port]:port:' \
  '--min-protocol-version=[min protocol version]:n:' \
  '--conn-limit=[connection limit]:n:' \
  '--bufsz=[buffer size]:n:' \
  '--mtu=[MTU]:n:' \
  '--dns-ttl=[DNS TTL]:n:' \
  '--dns-fallback-timeout=[DNS fallback timeout]:duration:' \
  '*::peers:_hosts' && ret=0
return ret
