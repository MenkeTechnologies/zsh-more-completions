#compdef tldr
# Documentation: https://github.com/tldr-pages/tldr/blob/main/CLIENT-SPECIFICATION.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-v,--version}'[display version]' \
  '(-u --update)'{-u,--update}'[update local cache]' \
  '(-l --list)'{-l,--list}'[list all available commands]' \
  '(-p --platform)'{-p,--platform}'[override default platform]:platform:(linux osx sunos windows common android freebsd netbsd openbsd)' \
  '(-L --language)'{-L,--language}'[override default language]:language' \
  '--short-options[prefer shortform options in examples]' \
  '--long-options[prefer longform options in examples]' \
  '*:command:->commands' \
  && ret=0

case $state in
  commands)
    local -a tldr_commands
    local cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/tldr"
    if [[ -d "$cache_dir" ]]; then
      tldr_commands=( ${cache_dir}/pages/common/*(N:t:r) ${cache_dir}/pages/linux/*(N:t:r) )
    elif (( $+commands[tldr] )); then
      tldr_commands=( ${(f)"$(tldr --list 2>/dev/null)"} )
    fi
    _describe -t commands 'tldr command' tldr_commands && ret=0
    ;;
esac

return ret
