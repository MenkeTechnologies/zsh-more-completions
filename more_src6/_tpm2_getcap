#compdef tpm2_getcap
# _tpm2_getcap — tpm2-software tpm2_getcap display TPM capability properties commands handles algorithms (tpm2-software team, C); custom argparse
# upstream: https://github.com/tpm2-software/tpm2-tools

_tpm2_getcap() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-l[list capability properties]' \
        '--list[list capability properties]' \
        '-Q[do not output anything]' \
        '*:capability:(algorithms commands pcrs properties-fixed properties-variable ecc-curves handles-pcr handles-permanent handles-persistent handles-saved-session handles-loaded-session handles-transient-keys handles-platform-keys handles-nv-index pp-commands audit-commands)'
}

_tpm2_getcap "$@"
