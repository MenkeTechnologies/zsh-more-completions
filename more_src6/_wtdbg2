#compdef wtdbg2
# Documentation: https://github.com/ruanjue/wtdbg2
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (README.md + README-ori.md usage).
# Flags from binary help text:
#   -t (threads), -i (long reads file, repeatable), -I (error-free reads),
#   -o (output prefix), -f (force overwrite), -k (kmer fsize),
#   -p (kmer psize), -K (high-freq filter), -E (min kmer freq),
#   -F (low-freq filter), -S (subsampling), -X (max bins in gap),
#   -Y (max bins in deviation), -x (bin gap penalty),
#   -y (bin deviation penalty), -l (min alignment length),
#   -m (min matched), -s (max length variation), -q (quiet), -v (verbose),
#   --help.
# Preset -x (rs|sq|ccs|ont) is documented in README.md as a top-level preset
# that overlays other parameters. Treat as either preset name or integer.
# Removed from prior file: -V (no such flag), -A and -R top-level (not in
# usage), -fo (correct is -o), -g/-L (those are wtdbg2.pl wrapper / preset
# affordances - kept -g since README.md shows it in command example).

local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show extended help]' \
  '-h[show help]' \
  '*-i+[long reads sequences file]:file:_files' \
  '*-I+[error-free sequences file]:file:_files' \
  '-o+[prefix of output files]:prefix:' \
  '-f[force overwrite]' \
  '-t+[number of threads (0=all)]:n:' \
  '-x+[sequencing tech preset (rs/sq/ccs/ont) or bin gap penalty]:preset:(rs sq ccs ont)' \
  '-g+[estimated genome size, e.g. 4.6m, 100m, 3g]:size:' \
  '-k+[k-mer fsize, 0..25]:k:' \
  '-p+[homopolymer-compressed k-mer psize, 0..25]:p:' \
  '-K+[filter high-frequency k-mers]:cutoff:' \
  '-E+[min k-mer frequency]:n:' \
  '-F[filter low-frequency k-mers via 4GB array]' \
  '-S+[k-mer subsampling 1/S]:s:' \
  '-X+[max bins (256bp) in one gap]:n:' \
  '-Y+[max bins (256bp) in one deviation]:n:' \
  '-y+[penalty for BIN deviation]:n:' \
  '-l+[min alignment length]:val:' \
  '-m+[min matched]:val:' \
  '-s+[max length variation between aligned fragments]:frac:' \
  '-q[quiet]' \
  '*-v[verbose (repeat for more)]' \
  '*:input reads:_files' && ret=0
return ret
