#compdef xboxdrv
# _xboxdrv — Ingo Ruhnke xboxdrv Linux userspace Xbox Xbox360 and XInput-style USB controller driver and remapper (Grumbel team, C++); custom argparse
# upstream: https://gitlab.com/xboxdrv/xboxdrv

_xboxdrv() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[config file]:file:_files -g "*.xboxdrv *.ini *.conf"' \
        '--config=+[config file]:file:_files -g "*.xboxdrv *.ini *.conf"' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-D[detach daemon]' \
        '--daemon[detach daemon]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--silent[silent]' \
        '-s[scan and list controllers]' \
        '--list-controller[list controllers]' \
        '-i+[controller id]:n:' \
        '--id=+[controller id]:n:' \
        '-w+[wireless id]:n:' \
        '--wid=+[wireless id]:n:' \
        '-l[led pattern]' \
        '--led=+[led pattern]:n:' \
        '-r[rumble test]' \
        '--rumble=+[strength]:str:' \
        '-d+[device]:file:_files -g "/dev/*"' \
        '--device-by-id=+[VID:PID]:str:' \
        '--device-by-path=+[path]:str:' \
        '-t+[controller type]:t:(xbox xbox360 xbox360-wireless xbox360-guitar firestorm-vsb playstation3)' \
        '--type=+[controller type]:t:(xbox xbox360 xbox360-wireless xbox360-guitar firestorm-vsb playstation3)' \
        '-R[force feedback]' \
        '--force-feedback[force feedback]' \
        '-S[show events]' \
        '--no-uinput[no uinput]' \
        '-T[try detect]' \
        '--test-rumble[test rumble]' \
        '--list-all[list all]' \
        '--list-supported-devices[list supported]' \
        '--list-keys[list keys]' \
        '--list-axes[list axes]' \
        '--ui-axismap=+[axis mappings csv]:str:' \
        '--ui-buttonmap=+[button mappings csv]:str:' \
        '--device-name=+[uinput device name]:str:' \
        '--evdev=+[event device]:file:_files -g "/dev/*"' \
        '--axismap=+[axis remap]:str:' \
        '--buttonmap=+[button remap]:str:' \
        '--mouse[mouse mode]' \
        '--guitar[guitar mode]' \
        '--mimic-xpad[mimic xpad driver]' \
        '--no-extra-events[no extra events]' \
        '--detach-kernel-driver[detach kernel driver]' \
        '--led-effect=+[effect]:str:'
}

_xboxdrv "$@"
