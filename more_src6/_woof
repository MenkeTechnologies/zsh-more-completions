#compdef woof
# Documentation: https://manpages.debian.org/testing/woof/woof.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# woof: web one-shot file delivery
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[display help summary]' \
  '-i+[IP address to bind to]:address:' \
  '-p+[port number]:port:' \
  '-c+[number of times to serve the file]:count:' \
  '-z+[serve directory as gzip-compressed tarball]:directory:_files -/' \
  '-j+[serve directory as bzip2-compressed tarball]:directory:_files -/' \
  '-Z+[serve directory as ZIP archive]:directory:_files -/' \
  '-u+[serve directory as uncompressed tarball]:directory:_files -/' \
  '-s[distribute woof itself]' \
  '-U[provide an upload form and allow uploading files]' \
  '*:file:_files' && ret=0

return ret
