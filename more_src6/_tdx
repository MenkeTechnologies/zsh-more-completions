# -----------------------------------------------------------------------------
#
# THE tdx CLI
#
# tdx is a hybrid TUI + scriptable-subcommand CLI built
# on a manual argv parser (no cobra/urfave/viper).
# Invocation:
#   tdx [file.md] [command] [args] [options]
#
# If no command is given, tdx launches an interactive
# TUI for the specified (or default) file.  If a
# command is given, tdx runs it as a scriptable one-
# shot operation + exits.
#
# Positional arguments:
#   [file.md]                         path to a markdown
#                                     file (default
#                                     from user config;
#                                     typically
#                                     `todo.md`)
#   [command]                         subcommand (see
#                                     below)
#   [args...]                         arguments to the
#                                     subcommand
#
# Global flags:
#   -r, --read-only                   don't save changes
#                                     to disk
#       --show-headings               display markdown
#                                     headings between
#                                     task groups
#   -m, --max-visible <N>             max visible items
#                                     (0 = unlimited)
#   -h, --help, help                  show help
#   -v, --version                     show version
#       --debug-config                dump effective
#                                     config + exit
#
# Subcommands (scriptable mode):
#   (none)                            launch interactive TUI
#   list                              list all todos
#   add "<text>"                      add a new todo
#   toggle <index>                    toggle todo completion
#   edit <index> "<text>"             edit todo text
#   delete <index>                    delete a todo
#   last                              open most recent file
#   recent                            list recently opened files
#   recent <number>                   open recent file by number
#   recent clear                      clear recent file history
#   help                              show help
#
# Common invocations:
#   # Launch the TUI on the default file (todo.md)
#   tdx
#
#   # Launch the TUI on a specific file
#   tdx ~/work/project-todos.md
#
#   # List todos non-interactively
#   tdx list
#   tdx ~/work/todos.md list
#
#   # Add a new todo
#   tdx add "Write the deployment runbook"
#   tdx ~/work/todos.md add "Review PR #123"
#
#   # Toggle todo #3 (1-indexed)
#   tdx toggle 3
#
#   # Edit todo #5's text
#   tdx edit 5 "Updated text for this todo"
#
#   # Delete todo #2
#   tdx delete 2
#
#   # Read-only TUI (don't save toggles)
#   tdx -r ~/work/teammate-todos.md
#   tdx --read-only ~/work/teammate-todos.md
#
#   # Show markdown headings between tasks
#   tdx --show-headings ~/work/structured-todos.md
#
#   # Cap visible items to 20
#   tdx -m 20 ~/work/very-long-todos.md
#   tdx --max-visible 20 ~/work/very-long-todos.md
#
#   # Open the most recently used file
#   tdx last
#
#   # List recent files + jump to one
#   tdx recent
#   tdx recent 3
#   tdx recent clear
#
#   # Dump current config for debugging
#   tdx --debug-config
#
#   # Show version
#   tdx --version
#   tdx -v
#
# OPTIONS (sourced directly from
# https://github.com/niklas-heer/tdx/blob/main/cmd/tdx/main.go):
#
#   -r, --read-only                   don't save changes
#       --show-headings               show MD headings
#   -m, --max-visible <N>             max visible (0 = unlimited)
#   -h, --help                        show help
#   -v, --version                     show version
#       --debug-config                dump config
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _tdx_subcommands
_tdx_subcommands=(
    'list:list all todos in the file'
    'add:add a new todo (next arg = "text")'
    'toggle:toggle completion of todo by index'
    'edit:edit todo text by index'
    'delete:delete a todo by index'
    'last:open the most recently used file'
    'recent:list / open / clear recently opened files'
    'help:show help'
)

local -a _tdx_recent_subs
_tdx_recent_subs=(
    'clear:clear recent files history'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '(-r --read-only)'{-r,--read-only}'[do not save changes to disk]' \
    '--show-headings[display markdown headings between task groups]' \
    '(-m --max-visible)'{-m,--max-visible}'+[max visible items (0 = unlimited)]:N: ' \
    '--debug-config[dump effective config and exit]' \
    '*::arg:->args' \
    && ret=0

case $state in
    args)
        # First positional: usually a .md file, or directly a subcommand
        case $CURRENT in
            1)
                _alternative \
                    'files:markdown file:_files -g "*.md"' \
                    'subcmds:tdx subcommand:_describe -t subcmds "subcommand" _tdx_subcommands' \
                    && ret=0
                ;;
            *)
                # Earlier positional was a .md file or subcommand
                case $words[1] in
                    list|last|help)
                        ret=0
                        ;;
                    add)
                        _arguments '1:todo text: ' && ret=0
                        ;;
                    toggle|delete)
                        _arguments '1:todo index: ' && ret=0
                        ;;
                    edit)
                        _arguments \
                            '1:todo index: ' \
                            '2:new text: ' \
                            && ret=0
                        ;;
                    recent)
                        if (( CURRENT == 2 )); then
                            _alternative \
                                'subcmds:recent subcommand:_describe -t recentsubs "recent" _tdx_recent_subs' \
                                'numbers:recent file number: ' \
                                && ret=0
                        fi
                        ;;
                    *.md|*.MD)
                        # File was first; now expect a subcommand
                        if (( CURRENT == 2 )); then
                            _describe -t subcmds 'tdx subcommand' _tdx_subcommands && ret=0
                        else
                            # Subcommand args (delegate to subcommand handling above)
                            case $words[2] in
                                add)
                                    _arguments '2:todo text: ' && ret=0 ;;
                                toggle|delete)
                                    _arguments '2:todo index: ' && ret=0 ;;
                                edit)
                                    _arguments '2:todo index: ' '3:new text: ' && ret=0 ;;
                            esac
                        fi
                        ;;
                esac
                ;;
        esac
        ;;
esac

return ret
