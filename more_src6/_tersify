#compdef tersify
# Documentation: https://man.archlinux.org/search?q=tersify
# Reference accessed: 2026-05-16
# Source: cargo binstall tersify@0.5.0
# Probed via: completions zsh
# Repository: https://github.com/rustkit-ai/tersify

autoload -U is-at-least

_tersify() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-t+[Force content type\: rust | python | js | ts | go | ruby | java | c | swift | kotlin | html | css | sql | shell | yaml | json | logs | diff | text]:TYPE:_default' \
'--type=[Force content type\: rust | python | js | ts | go | ruby | java | c | swift | kotlin | html | css | sql | shell | yaml | json | logs | diff | text]:TYPE:_default' \
'-b+[Max token budget for output]:BUDGET:_default' \
'--budget=[Max token budget for output]:BUDGET:_default' \
'*-p+[Custom regex pattern to strip (repeatable\: --pattern '\''console\\.log\\(.*?\\)'\'')]:PATTERNS:_default' \
'*--pattern=[Custom regex pattern to strip (repeatable\: --pattern '\''console\\.log\\(.*?\\)'\'')]:PATTERNS:_default' \
'-v[Show token count before/after on stderr]' \
'--verbose[Show token count before/after on stderr]' \
'-a[Extract function signatures only — stub all function bodies with \`{ /* ... */ }\`]' \
'--ast[Extract function signatures only — stub all function bodies with \`{ /* ... */ }\`]' \
'-s[Enable semantic near-duplicate deduplication (MinHash-based)]' \
'--smart[Enable semantic near-duplicate deduplication (MinHash-based)]' \
'--strip-docs[Also strip doc comments (///, //!, /** */, Python docstrings)]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::inputs -- Files or directories to compress (defaults to stdin):_default' \
":: :_tersify_commands" \
"*::: :->tersify" \
&& ret=0
    case $state in
    (tersify)
        words=($line[2] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tersify-command-$line[2]:"
        case $line[2] in
            (install)
_arguments "${_arguments_options[@]}" : \
'(--windsurf --copilot --all)--cursor[Install for Cursor IDE (~/.cursor/rules/tersify.mdc)]' \
'(--cursor --copilot --all)--windsurf[Install for Windsurf IDE (~/.windsurf/rules/tersify.md)]' \
'(--cursor --windsurf --all)--copilot[Install for GitHub Copilot (.github/copilot-instructions.md in current directory)]' \
'(--cursor --windsurf --copilot)--all[Auto-detect and install for all present editors (Claude Code + Cursor + Windsurf)]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(uninstall)
_arguments "${_arguments_options[@]}" : \
'(--windsurf --copilot --all)--cursor[Remove Cursor IDE rule]' \
'(--cursor --copilot --all)--windsurf[Remove Windsurf IDE rule]' \
'(--cursor --windsurf --all)--copilot[Remove GitHub Copilot instructions]' \
'(--cursor --windsurf --copilot)--all[Remove hooks from all detected editors]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(stats)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(stats-reset)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(bench)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(token-cost)
_arguments "${_arguments_options[@]}" : \
'-m+[Filter to a specific model (e.g. claude-sonnet, gpt-4o)]:MODEL:_default' \
'--model=[Filter to a specific model (e.g. claude-sonnet, gpt-4o)]:MODEL:_default' \
'-t+[Force content type]:TYPE:_default' \
'--type=[Force content type]:TYPE:_default' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'*::inputs -- Files or directories to analyse (defaults to stdin):_default' \
&& ret=0
;;
(mcp)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':shell -- Target shell:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(hook)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_tersify__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tersify-help-command-$line[1]:"
        case $line[1] in
            (install)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(uninstall)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(stats)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(stats-reset)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(bench)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(token-cost)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(mcp)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(hook)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_tersify_commands] )) ||
_tersify_commands() {
    local commands; commands=(
'install:Install tersify hooks into your AI coding environment' \
'uninstall:Remove tersify hooks' \
'stats:Show token savings statistics' \
'stats-reset:Reset saved statistics' \
'bench:Benchmark compression savings across all content types' \
'token-cost:Estimate LLM API cost before and after compression' \
'mcp:Start an MCP server over stdio (register with\: claude mcp add tersify -- tersify mcp)' \
'completions:Print shell completion script' \
'hook:Internal PostToolUse hook handler for Claude Code (reads hook JSON from stdin)' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'tersify commands' commands "$@"
}
