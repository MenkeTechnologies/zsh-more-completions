#compdef x2sys_list
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/x2sys/x2sys_list.html
# Source: GenericMappingTools/gmt supplements/x2sys — extract crossover errors with filtering.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-C+[data column to process]:column:_default' \
    '-T+[x2sys TAG]:tag:_default' \
    '-A+[max asymmetry threshold]:value:_default' \
    '-E[GMT segment headers with track names]' \
    '-F+[output column codes]:flags:_default' \
    '-I+[exclude tracks from file]:file:_files' \
    '-L+[apply optimal correction table]:file:_files' \
    '-N+[suppress tracks with too few crossings]:n:_default' \
    '-Q+[external/internal crossovers only]:scope:(e i)' \
    '-R+[region west/east/south/north]:region:_default' \
    '-S+[limit to crossovers with track]:track:_default' \
    '*-V[verbose (stackable)]' \
    '-W+[track weights for composite weight calc]:opts:_default' \
    '-bo+[binary output format]:format:_default' \
    '*:crossover database (coedbase.txt):_files' \
    && ret=0

return ret
