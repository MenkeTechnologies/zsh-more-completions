#compdef xentop
# Documentation: https://github.com/xen-project/xen/blob/master/docs/man/xentop.1.pod
# Reference accessed: 2026-05-21
# Verified: upstream xentop(1) pod source.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(- *)'{-V,--version}'[show version and exit]' \
  '(-d --delay)'{-d+,--delay=}'[seconds between updates (default 3)]:seconds:' \
  '(-n --networks)'{-n,--networks}'[output network information]' \
  '(-x --vbds)'{-x,--vbds}'[output vbd block device data]' \
  '(-r --repeat-header)'{-r,--repeat-header}'[repeat table header before each domain]' \
  '(-v --vcpus)'{-v,--vcpus}'[output VCPU data]' \
  '(-f --full-name)'{-f,--full-name}'[output the full domain name (not truncated)]' \
  '(-b --batch)'{-b,--batch}'[output data in batch mode (to stdout)]' \
  '(-i --iterations)'{-i+,--iterations=}'[maximum number of iterations]:iterations:' \
  '(-z --dom0-first)'{-z,--dom0-first}'[display dom0 first, ignoring interactive sorting]' \
  '(-p --pcpus)'{-p,--pcpus}'[display physical CPU utilization metrics]' && ret=0

return ret
