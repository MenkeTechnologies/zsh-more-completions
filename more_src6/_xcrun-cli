#compdef xcrun-cli
# _xcrun-cli — Apple xcrun Xcode developer tool wrapper CLI alias (Apple, C); custom argparse
# upstream: https://developer.apple.com/xcode

_xcrun-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--find=+[find tool]:str:' \
        '-f+[find tool]:str:' \
        '--run[run tool]' \
        '-r[run tool]' \
        '--sdk=+[SDK]:s:(macosx iphoneos iphonesimulator appletvos appletvsimulator watchos watchsimulator xros xrsimulator)' \
        '-sdk+[SDK]:s:(macosx iphoneos iphonesimulator appletvos appletvsimulator watchos watchsimulator xros xrsimulator)' \
        '--toolchain=+[toolchain]:str:' \
        '-toolchain+[toolchain]:str:' \
        '--log[log calls]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--no-cache[no cache]' \
        '-n[no cache]' \
        '--kill-cache[kill cache]' \
        '-k[kill cache]' \
        '--show-sdk-path[show SDK path]' \
        '--show-sdk-platform-path[show SDK platform path]' \
        '--show-sdk-platform-version[show SDK platform version]' \
        '--show-sdk-version[show SDK version]' \
        '--show-sdk-build-version[show SDK build version]' \
        '--show-cache[show cache]' \
        '--show-cache-files[show cache files]' \
        '--show-cache-paths[show cache paths]' \
        '*:tool-and-args:_command_names -e'
}

_xcrun-cli "$@"
