#compdef xfce4-screenshooter
# _xfce4-screenshooter — Xfce xfce4-screenshooter (region/window/fullscreen capture for Xfce; -f fullscreen, -w window, -r region, -d delay seconds, -s save dir, -o open with app, --upload Imgur, --clipboard copy to clipboard, --mouse include cursor)
# upstream: https://gitlab.xfce.org/apps/xfce4-screenshooter
# Flags from xfce4-screenshooter src/main.c on tip.

_xfce4-screenshooter() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '(-w -r)-f[fullscreen capture]' \
        '(-f -r)-w[active window capture]' \
        '(-f -w)-r[region capture]' \
        '-d+[delay seconds]:seconds:' \
        '-s+[save directory]:dir:_files -/' \
        '-o+[open with app]:app:_command_names -e' \
        '-u[upload to Imgur]' \
        '--upload[upload to host]' \
        '-c[copy to clipboard]' \
        '--clipboard[copy to clipboard]' \
        '-m[include mouse pointer]' \
        '--mouse[include mouse pointer]' \
        '--no-border[no window border]' \
        '--region[region select]' \
        '*:file:_files'
}

_xfce4-screenshooter "$@"
