#compdef task-spooler
# _task-spooler — unix batch job scheduler (task spooler)
# upstream: https://vicerveza.homeunix.net/~viric/soft/ts/
# Note: the binary is typically installed as 'tsp' or 'ts'

_arguments -s -S \
    '(- *)-h[show help]' \
    '(- *)-V[show version]' \
    '-K[kill the task spooler server]' \
    '-C[clear finished jobs from the list]' \
    '-l[list queued jobs]' \
    '-t=[set tail lines to show on finish]:lines:' \
    '-c=[show the output of a job]:job ID:' \
    '-p=[show the PID of a job]:job ID:' \
    '-o=[show the output file of a job]:job ID:' \
    '-s=[show the state of a job]:job ID:' \
    '-r=[remove a queued job]:job ID:' \
    '-w=[wait for a job to finish]:job ID:' \
    '-k=[kill a running job]:job ID:' \
    '-u=[urgently run a job (put at front of queue)]:job ID:' \
    '-i=[show info about a job]:job ID:' \
    '-U=[swap two jobs in the queue]:job IDs (id1-id2):' \
    '-B[run in the background (will be in a new session)]' \
    '-n[do not store output]' \
    '-f[do not fork, run in the foreground]' \
    '-g[run task with the default nice value]' \
    '-d[run dependent on the previous task]' \
    '-D=[run dependent on specific job]:job ID:' \
    '-L=[set label for the job]:label:' \
    '-S=[set number of slots]:slots:' \
    '-N=[set max number of finished jobs to keep]:count:' \
    '-E[pass stderr through to the client]' \
    '*:command and arguments: _normal' \
    && return 0
