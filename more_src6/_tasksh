#compdef tasksh
# Documentation: https://github.com/GothenburgBitFactory/tasksh
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (tasksh man page).

local curcontext="$curcontext" state line ret=1
local -a builtins
builtins=(
  'diagnostics:show tasksh diagnostic settings'
  'exec:run a system shell command'
  'exit:terminate the tasksh session'
  'quit:terminate the tasksh session'
  'help:show command summary'
  'review:interactive task review (optional [N] limit)'
)

_arguments -s -S \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t builtins 'tasksh builtin' builtins && ret=0 ;;
  (args)
    case $line[1] in
      (review) _arguments '1:N:' && ret=0 ;;
      (exec) _arguments '*::command:' && ret=0 ;;
    esac
    ;;
esac

return ret
