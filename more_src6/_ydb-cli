#compdef ydb-cli ydb
# _ydb-cli — Yandex YDB distributed open-source SQL database CLI alias (ydb-platform team, Go); cobra
# upstream: https://github.com/ydb-platform/ydb

_ydb-cli() {
    local -a sub=(
        'admin:cluster admin operations'
        'auth:auth commands'
        'cluster:cluster operations'
        'completion:generate shell completion'
        'config:config operations'
        'config:info:show config info'
        'config:profile:list:list profiles'
        'config:profile:get:get profile'
        'config:profile:create:create profile'
        'config:profile:delete:delete profile'
        'config:profile:activate:activate profile'
        'config:profile:replace:replace profile'
        'config:profile:update:update profile'
        'debug:debug commands'
        'discovery:discovery commands'
        'export:export commands'
        'export:s3:export to S3'
        'export:yt:export to YT'
        'import:import commands'
        'import:file:csv:import CSV file'
        'import:file:json:import JSON file'
        'import:s3:import from S3'
        'init:initialize ydb cli'
        'monitoring:healthcheck:show health check'
        'operation:list:list operations'
        'operation:get:get operation'
        'operation:cancel:cancel operation'
        'operation:forget:forget operation'
        'scheme:describe:describe scheme object'
        'scheme:ls:list scheme objects'
        'scheme:mkdir:make directory'
        'scheme:rmdir:remove directory'
        'scheme:permissions:permissions ops'
        'scripting:yql:execute YQL script'
        'sql:execute SQL/YQL'
        'table:attribute:add:add table attribute'
        'table:attribute:drop:drop table attribute'
        'table:drop:drop table'
        'table:index:add:add table index'
        'table:index:drop:drop table index'
        'table:query:execute:execute query'
        'table:query:explain:explain query'
        'table:readtable:read table'
        'table:ttl:set:set TTL'
        'table:ttl:reset:reset TTL'
        'tools:cp:copy table'
        'tools:dump:dump table'
        'tools:restore:restore table'
        'tools:rename:rename table'
        'tools:infer:csv:infer CSV schema'
        'topic:create:create topic'
        'topic:alter:alter topic'
        'topic:drop:drop topic'
        'topic:read:read from topic'
        'topic:write:write to topic'
        'topic:consumer:add:add consumer'
        'topic:consumer:drop:drop consumer'
        'topic:describe:describe topic'
        'update:update CLI'
        'version:show CLI version'
        'workload:run benchmark workload'
        'workload:stock:run stock workload'
        'workload:kv:run KV workload'
        'workload:clickbench:run ClickBench'
        'workload:tpcc:run TPC-C'
        'workload:tpch:run TPC-H'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--endpoint=+[endpoint]:url:_urls' \
        '-e+[endpoint]:url:_urls' \
        '--database=+[database path]:str:' \
        '-d+[database path]:str:' \
        '--profile=+[profile name]:str:' \
        '-p+[profile name]:str:' \
        '--user=+[user]:user:_users' \
        '--token-file=+[token file]:file:_files' \
        '--iam-token-file=+[iam token file]:file:_files' \
        '--yc-token-file=+[yc token file]:file:_files' \
        '--sa-key-file=+[service account key file]:file:_files' \
        '--use-metadata-credentials[use metadata credentials]' \
        '--use-token-credentials[use token credentials]' \
        '--ca-file=+[ca file]:file:_files' \
        '--grpcs[use gRPCS (TLS)]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--json[json output]' \
        '--time[show duration]' \
        '--format=+[format]:f:(default pretty tsv csv json-unicode json-base64 proto-text-format)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ydb subcommand' sub ;;
        args)
            case $words[1] in
                sql|scripting:yql|table:query:execute|table:query:explain) _arguments \
                    '--query=+[query]:str:' \
                    '-q+[query]:str:' \
                    '--file=+[query file]:file:_files' \
                    '-f+[query file]:file:_files' \
                    '--explain[explain only]' \
                    '--stats=+[stats mode]:m:(none basic full profile)' \
                    '--syntax=+[syntax]:s:(yql_v1 pg)' \
                    '--timeout=+[ms]:n:' ;;
                tools:dump) _arguments \
                    '--path=+[scheme path]:str:' \
                    '--output=+[output dir]:dir:_files -/' \
                    '-o+[output dir]:dir:_files -/' \
                    '--scheme-only[scheme only]' \
                    '--consistency-level=+[level]:l:(database table)' ;;
                tools:restore) _arguments \
                    '--path=+[restore path]:str:' \
                    '--input=+[input dir]:dir:_files -/' \
                    '-i+[input dir]:dir:_files -/' \
                    '--restore-data=+[bool]:b:(true false)' \
                    '--restore-indexes=+[bool]:b:(true false)' \
                    '--restore-acl=+[bool]:b:(true false)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_ydb-cli "$@"
