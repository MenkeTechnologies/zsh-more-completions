#compdef wdogctl
# Documentation: man wdogctl(8)
# Source: netbsd/src sbin/wdogctl — watchdog timer control (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A[audible alarm on watchdog expiry]' \
    '(-e -k -u -x -t)-d[disarm active timer]' \
    '(-d -k -u -x -t)-e[arm timer in external tickle mode]' \
    '(-d -e -u -x -t)-k[arm timer in kernel tickle mode]' \
    '-p+[timer period in seconds]:seconds:_default' \
    '(-d -e -k -u -x)-t[tickle an external mode timer]' \
    '(-d -e -k -x -t)-u[arm timer in user tickle mode]' \
    '(-d -e -k -u -t)-x[arm timer in modified user mode]' \
    '1::timer:_default' \
    && ret=0

return ret
