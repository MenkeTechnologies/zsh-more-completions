#compdef TimeSCCAN
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/TimeSCCAN.cxx — sparse CCA for time-series functional data (C++, itk parser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-o --output)'{-o+,--output=}'[output image]:file:_files' \
    '(-l --number-consecutive-labels --l1)'{-l+,--number-consecutive-labels=}'[number of consecutive labels]:n:_default' \
    '(-R --minimum-region-size)'{-R+,--minimum-region-size=}'[minimum region size]:n:_default' \
    '(-i --iterations)'{-i+,--iterations=}'[iterations (default 20)]:n:_default' \
    '(-s --sparsity)'{-s+,--sparsity=}'[sparsity]:n:_default' \
    '(-n --n_eigenvectors)'{-n+,--n_eigenvectors=}'[number of eigenvectors]:n:_default' \
    '(-r --robustify)'{-r+,--robustify=}'[robustify (0/1)]:n:(0 1)' \
    '--ClusterThresh=[cluster threshold]:n:_default' \
    '(-e --ridge_cca)'{-e+,--ridge_cca=}'[ridge CCA]:n:_default' \
    '--partial-scca-option=[partial SCCA option]:n:_default' \
    '--timeseriesimage-to-matrix=[convert time-series image to matrix]:spec:_default' \
    '--labelsimage-to-matrix=[convert labels image to matrix]:spec:_default' \
    '--network=[network spec]:spec:_default' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
