#compdef xnec2c
# Documentation: https://github.com/KJ7LNW/xnec2c
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above documents -i and -j only;
# all other flags removed as unverifiable from public docs.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-i+[input NEC2 file at startup]:file:_files -g "*.nec"' \
  '-j+[number of threads for SMP]:n:' \
  '*:nec file:_files -g "*.nec"' && ret=0

return ret
