#compdef varscan VarScan VarScan2
# _varscan — Daniel Koboldt varscan CLI VarScan 2 variant detector calling SNVs indels somatic variants copy-number variation from pileup BAM mpileup input producing VCF for tumor-normal pairs single samples integrated with samtools mpileup workflow Bayesian heuristic filter-based SNV indel inference (Daniel Koboldt team, Java); custom argparse
# upstream: https://dkoboldt.github.io/varscan/

_varscan() {
    local -a sub=(
        'pileup2snp:call SNPs from pileup'
        'pileup2indel:call indels from pileup'
        'pileup2cns:call consensus from pileup'
        'mpileup2snp:call SNPs from mpileup'
        'mpileup2indel:call indels from mpileup'
        'mpileup2cns:call consensus from mpileup'
        'somatic:call somatic SNV/indel'
        'copynumber:call CNV from mpileup'
        'readcounts:report base counts at positions'
        'filter:filter variants'
        'somaticFilter:filter somatic variants'
        'processSomatic:process somatic output'
        'compare:compare two VCFs'
        'limit:limit by positions'
        'fpfilter:false-positive filter'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'varscan subcommand' sub ;;
        args)
            case $words[1] in
                somatic) _arguments \
                    '--normal-purity=+[N]:str:' \
                    '--tumor-purity=+[N]:str:' \
                    '--min-coverage=+[N]:n:' \
                    '--min-coverage-normal=+[N]:n:' \
                    '--min-coverage-tumor=+[N]:n:' \
                    '--min-var-freq=+[N]:str:' \
                    '--min-freq-for-hom=+[N]:str:' \
                    '--normal-mpileup=+[file]:file:_files' \
                    '--tumor-mpileup=+[file]:file:_files' \
                    '--output-snp=+[file]:file:_files' \
                    '--output-indel=+[file]:file:_files' \
                    '--p-value=+[N]:str:' \
                    '--somatic-p-value=+[N]:str:' \
                    '--strand-filter=+[N]:n:(0 1)' \
                    '--output-vcf=+[N]:n:(0 1)' ;;
                mpileup2snp|mpileup2indel|mpileup2cns) _arguments \
                    '--min-coverage=+[N]:n:' \
                    '--min-reads2=+[N]:n:' \
                    '--min-avg-qual=+[N]:n:' \
                    '--min-var-freq=+[N]:str:' \
                    '--min-freq-for-hom=+[N]:str:' \
                    '--p-value=+[N]:str:' \
                    '--strand-filter=+[N]:n:(0 1)' \
                    '--output-vcf=+[N]:n:(0 1)' \
                    '*:mpileup file:_files' ;;
            esac
            ;;
    esac
}

_varscan "$@"
