#compdef tte
# Documentation: https://github.com/ChrisBuilds/terminaltexteffects
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Top-level flags verified against README; effect list verified against
# README effect index. Per-effect arguments are not enumerated here because
# each effect has its own distinct parameter set (use `tte <effect> --help`).

local curcontext="$curcontext" state line ret=1

local -a effects=(
  'beams:Create beams which travel over the canvas illuminating characters'
  'binarypath:Display binary strings flowing through the terminal'
  'blackhole:Characters are pulled into a black hole'
  'bouncyballs:Characters bounce around the terminal like balls'
  'bubbles:Characters float upward like bubbles'
  'burn:Characters burn away with a fire effect'
  'colorshift:Shift through colors across the terminal'
  'crumble:Characters crumble apart'
  'decrypt:Text appears to be decrypted character by character'
  'errorcorrect:Text is corrected character by character'
  'expand:Text expands outward from the center'
  'fireworks:Characters launch and explode like fireworks'
  'highlight:Run a specular highlight across the text'
  'laseretch:A laser etches characters onto the terminal'
  'matrix:Matrix digital rain effect'
  'middleout:Text appears from the middle outward'
  'orbittingvolley:Launchers orbit canvas firing volleys inward'
  'overflow:Text overflows from the edges'
  'pour:Characters pour down like liquid'
  'print:Text is printed character by character'
  'rain:Characters rain down the terminal'
  'randomsequence:Text appears in random order'
  'rings:Characters appear in expanding rings'
  'scattered:Characters scatter and reform'
  'slice:Slices input in half and slides it into place'
  'slide:Text slides in from a direction'
  'smoke:Smoke floods the canvas colorizing characters it crosses'
  'spotlights:Characters are illuminated by spotlights'
  'spray:Characters spray across the terminal'
  'swarm:Characters swarm into position'
  'sweep:Sweep across canvas to reveal then color text'
  'synthgrid:Display a synthwave grid effect'
  'thunderstorm:Create a thunderstorm in the terminal'
  'unstable:Text appears with an unstable glitch effect'
  'vhstape:Text appears with VHS tape artifacts'
  'waves:Text flows with a wave animation'
  'wipe:Text appears with a wipe transition'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-i --input-file)'{-i,--input-file}'=[read input from file]:file:_files' \
  '(-R --random-effect)'{-R,--random-effect}'[randomly select an effect]' \
  '--seed=[seed for reproducible random selection]:seed' \
  '--print-completion=[generate shell completions]:shell:(bash zsh)' \
  '--include-effects=[limit random selection to specific effects]:effects' \
  '--exclude-effects=[exclude effects from random selection]:effects' \
  '--tab-width=[spaces per tab character]:int' \
  '--xterm-colors[convert RGB hex to XTerm-256 colors]' \
  '--no-color[disable all colors]' \
  '--terminal-background-color=[set terminal background for fade effects]:color' \
  '--wrap-text[wrap text wider than canvas]' \
  '--frame-rate=[target frames per second (0 for unlimited)]:int' \
  '--no-eol[suppress trailing newline]' \
  '--no-restore-cursor[do not restore cursor visibility]' \
  '--canvas-width=[set canvas width]:int' \
  '--canvas-height=[set canvas height]:int' \
  '--anchor-canvas=[canvas positioning]:anchor:(sw s se e ne n nw w c)' \
  '--anchor-text=[text positioning within canvas]:anchor:(n ne e se s sw w nw c)' \
  '--ignore-terminal-dimensions[ignore terminal size limits]' \
  '--reuse-canvas[reuse existing canvas rows]' \
  '--existing-color-handling=[handle input ANSI colors]:mode:(always dynamic ignore)' \
  '1:effect:->effect' \
  '*::: :->args' && ret=0

case $state in
  (effect)
    _describe -t effects 'effect' effects && ret=0
    ;;
  (args)
    _arguments '*:: :_default' && ret=0
    ;;
esac

return ret
