#compdef usermod-cli
# _usermod-cli — shadow usermod modify a user account CLI alias (shadow-maint team, C); custom argparse
# upstream: https://github.com/shadow-maint/shadow

_usermod-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-a[append to existing groups]' \
        '--append[append to existing groups]' \
        '-c+[comment]:str:' \
        '--comment=+[comment]:str:' \
        '-d+[home dir]:dir:_files -/' \
        '--home=+[home dir]:dir:_files -/' \
        '-e+[expire date]:str:' \
        '--expiredate=+[expire date]:str:' \
        '-f+[inactive days]:n:' \
        '--inactive=+[inactive days]:n:' \
        '-g+[group]:_groups' \
        '--gid=+[group]:_groups' \
        '-G+[groups list]:str:' \
        '--groups=+[groups list]:str:' \
        '-l+[login]:str:' \
        '--login=+[login]:str:' \
        '-L[lock]' \
        '--lock[lock]' \
        '-m[move home]' \
        '--move-home[move home]' \
        '-o[non unique]' \
        '--non-unique[non unique]' \
        '-p+[password]:str:' \
        '--password=+[password]:str:' \
        '-P+[prefix]:dir:_files -/' \
        '--prefix=+[prefix]:dir:_files -/' \
        '-r[remove user from supplementary groups]' \
        '--remove[remove user from supplementary groups]' \
        '-R+[chroot]:dir:_files -/' \
        '--root=+[chroot]:dir:_files -/' \
        '-s+[shell]:str:' \
        '--shell=+[shell]:str:' \
        '-u+[uid]:n:' \
        '--uid=+[uid]:n:' \
        '-U[unlock]' \
        '--unlock[unlock]' \
        '-Z+[selinux user]:str:' \
        '--selinux-user=+[selinux user]:str:' \
        '*:user:_users'
}

_usermod-cli "$@"
