  '(-T --margin-top)'{-T+,--margin-top=}'[top margin]:pixels:' \
  '(-B --margin-bottom)'{-B+,--margin-bottom=}'[bottom margin]:pixels:' \
  '(-p --protocol)'{-p+,--protocol=}'[Wayland protocol]:protocol:(layer-shell xdg)' \
  '(-s --show-binds)'{-s,--show-binds}'[show keybinds on corresponding button]' \
  '(-n --no-span)'{-n,--no-span}'[do not span across multiple monitors]' \
