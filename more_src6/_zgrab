#compdef zgrab zgrab2

_zgrab() {
    local curcontext="$curcontext" state line ret=1

    _arguments -C \
        '(- *)--help[show help message and exit]' \
        '1:subcommand:->subcmd' \
        '*::args:->args' && ret=0

    case $state in
        subcmd)
            local -a subcmds=(
                'http:scan HTTP services'
                'ssh:scan SSH services'
                'tls:scan TLS services'
                'smtp:scan SMTP services'
                'ftp:scan FTP services'
                'pop3:scan POP3 services'
                'imap:scan IMAP services'
                'mysql:scan MySQL services'
                'mssql:scan MSSQL services'
                'postgres:scan PostgreSQL services'
                'redis:scan Redis services'
                'mongodb:scan MongoDB services'
                'bacnet:scan BACnet services'
                'fox:scan Fox (Niagara) services'
                'modbus:scan Modbus services'
                'dnp3:scan DNP3 services'
                'siemens:scan Siemens S7 services'
            )
            _describe -t commands 'zgrab subcommand' subcmds && ret=0
            ;;
        args)
            _arguments \
                '--input-file=[file with input targets]:input file:_files' \
                '--output-file=[file to write results]:output file:_files' \
                '--metadata-file=[file to write scan metadata]:metadata file:_files' \
                '--log-file=[file to write log output]:log file:_files' \
                '--timeout=[connection timeout]:timeout:' \
                '--port=[target port]:port:' \
                '--senders=[number of concurrent senders]:count:' \
                '--debug[enable debug output]' \
                '--flush[flush output after each result]' \
                '--gomaxprocs=[number of OS threads]:threads:' && ret=0
            ;;
    esac

    return ret
}

_zgrab "$@"
