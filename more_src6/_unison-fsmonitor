#compdef unison-fsmonitor
# Documentation: Unison fsmonitor
# Source: bcpierce00/unison src/fsmonitor.py (master) — file-system change monitor for Unison (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-w --sinceWhen)'{-w+,--sinceWhen=}'[start point for fs updates]:sincewhen:_default' \
    '(-l --latency)'{-l+,--latency=}'[notification latency seconds]:seconds:_default' \
    '(-f --flags)'{-f+,--flags=}'[macOS flags]:flags:_default' \
    '(-s --flushseconds)'{-s+,--flushseconds=}'[macOS flush interval seconds]:seconds:_default' \
    '(-o --outfile)'{-o+,--outfile=}'[output file path]:file:_files' \
    '(-t --statefile)'{-t+,--statefile=}'[state file path]:file:_files' \
    '(-u --unisonconfig)'{-u+,--unisonconfig=}'[unison config directory]:dir:_files -/' \
    '(-z --follow)'{-z+,--follow=}'[follow these symlinks]:list:_default' \
    '(-q --quiet)'{-q,--quiet}'[quiet]' \
    '(-d --debug)'{-d,--debug}'[debug]' \
    && ret=0

return ret
