#compdef the-lounge thelounge
# _the-lounge — The Lounge self-hosted web IRC client (Node.js); persistent bouncer + multi-user web UI
# upstream: https://github.com/thelounge/thelounge

_the-lounge() {
    local -a sub=(
        'start:start the server'
        'install:install package (theme/plugin)'
        'uninstall:uninstall package'
        'upgrade:upgrade installed packages'
        'list:list installed packages'
        'add:add a user'
        'remove:remove a user'
        'reset:reset user password'
        'config:show resolved config'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--home+[home dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'the-lounge subcommand' sub ;;
        args)
            case $words[1] in
                add|remove|reset) _arguments '1:username:_users' ;;
                install|uninstall) _arguments '1:package:' ;;
            esac
            ;;
    esac
}

_the-lounge "$@"
