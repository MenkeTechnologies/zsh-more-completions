#compdef tpm2_policyauthorizenv tpm2_policycountertimer tpm2_policycphash tpm2_policyduplicationselect tpm2_policylocality tpm2_policynamehash tpm2_policynv tpm2_policynvwritten tpm2_policysigned tpm2_policytemplate tpm2_policyticket
# Documentation: source-direct extraction from upstream
# tpm2-software/tpm2-tools.  Per-tool `struct option topts[]`
# table decoded source-direct from each tools/tpm2_<name>.c.
# Shared $tpm2_common + $tpm2_hashalgs + $tpm2_signschemes +
# $tpm2_policy_base re-extracted source-direct from
# lib/tpm2_options.c / lib/tpm2_alg_util.c / lib/tpm2_policy.c
# — see R193-R202 HARVEST_LOG entries for the full extraction
# notes.
# Reference accessed: 2026-05-30 via gh api.
# tpm2-software tpm2-tools R203 — follow-up to R202's hunt-skip
# on "rest of policy* family (tpm2_policyauthorizenv,
# tpm2_policycountertimer, tpm2_policycphash, tpm2_policy-
# duplicationselect, tpm2_policylocality, tpm2_policynamehash,
# tpm2_policynv, tpm2_policynvwritten, tpm2_policysigned,
# tpm2_policytemplate, tpm2_policyticket - ~10 more policy*
# binaries)".  This round completes the policy* family in
# tandem with R202's createpolicy/policypcr/policyauthorize/
# policysecret/policycommandcode/policyor/policyrestart/
# policypassword/policyauthvalue.  20 policy* tools now covered
# across R202+R203.  Sister tools to R193-R202's tpm2_* family
# already in the corpus.

local -a tpm2_common=(
  '(-T --tcti)'{-T+,--tcti=}'[TCTI library + options (e.g. "device:/dev/tpmrm0" or "swtpm:port=2321")]:tcti:'
  '(-h --help)'{-h-,--help=-}'[print help (optional arg = topic)]::topic:'
  '(-v --version)'{-v,--version}'[print version and exit]'
  '(-V --verbose)'{-V,--verbose}'[verbose mode]'
  '(-Q --quiet)'{-Q,--quiet}'[quiet mode]'
  '(-Z --enable-errata)'{-Z,--enable-errata}'[enable TPM2 errata workarounds]'
  '(-z --pwd-session)'{-z,--pwd-session}'[use password-authorized session]'
)
local -a tpm2_hashalgs=(sha1 sha256 sha384 sha512 sm3_256)
local -a tpm2_signschemes=(rsassa rsapss ecdsa ecdaa ecschnorr sm2 hmac null)
local -a tpm2_policy_base=(
  '(-L --policy)'{-L+,--policy=}'[output policy-digest file]:file:_files'
  '(-S --session)'{-S+,--session=}'[policy-session context file]:file:_files'
  '--cphash=[output command-parameter hash for off-line audit]:file:_files'
)

case $service in

  tpm2_policyauthorizenv)
    # TPM2_PolicyAuthorizeNV: bind the policy to a policy
    # digest stored in NV (the policy can be updated by
    # modifying the NV-stored digest without re-signing).
    # Like R202's tpm2_policyauthorize but the authorizing
    # source is an NV index, not a signing key.
    _arguments -s -S \
      $tpm2_common \
      $tpm2_policy_base \
      '(-C --hierarchy)'{-C+,--hierarchy=}'[NV-index hierarchy (owner|platform)]:hierarchy:(owner platform o p)' \
      '(-P --auth)'{-P+,--auth=}'[hierarchy authorization]:auth:' \
      ':NV index handle (hex e.g. 0x1500001):'
    ;;

  tpm2_policycountertimer)
    # TPM2_PolicyCounterTimer: bind the policy to a comparison
    # of the TPM clock/counter against a value.  Critical
    # extraction note: tpm2_policycountertimer has a **12-way
    # comparison-operator mutex** (--eq XOR --neq XOR --sgt XOR
    # --ugt XOR --slt XOR --ult XOR --sge XOR --uge XOR --sle
    # XOR --ule XOR --bs XOR --bc) - decoded source-direct
    # from upstream's topts[] entries which use TPM2_EO_*
    # constants as the val column (eq=TPM2_EO_EQ,
    # neq=TPM2_EO_NEQ, signed/unsigned gt/lt/ge/le, bs=BITSET,
    # bc=BITCLEAR).  This is the heaviest mutex group in the
    # entire R193-R203 tpm2_* set.
    _arguments -s -S \
      $tpm2_common \
      $tpm2_policy_base \
      '(--eq --neq --sgt --ugt --slt --ult --sge --uge --sle --ule --bs --bc)--eq[equal to operand]' \
      '(--eq --neq --sgt --ugt --slt --ult --sge --uge --sle --ule --bs --bc)--neq[not equal to operand]' \
      '(--eq --neq --sgt --ugt --slt --ult --sge --uge --sle --ule --bs --bc)--sgt[signed greater than operand]' \
      '(--eq --neq --sgt --ugt --slt --ult --sge --uge --sle --ule --bs --bc)--ugt[unsigned greater than operand]' \
      '(--eq --neq --sgt --ugt --slt --ult --sge --uge --sle --ule --bs --bc)--slt[signed less than operand]' \
      '(--eq --neq --sgt --ugt --slt --ult --sge --uge --sle --ule --bs --bc)--ult[unsigned less than operand]' \
      '(--eq --neq --sgt --ugt --slt --ult --sge --uge --sle --ule --bs --bc)--sge[signed greater than or equal to operand]' \
      '(--eq --neq --sgt --ugt --slt --ult --sge --uge --sle --ule --bs --bc)--uge[unsigned greater than or equal to operand]' \
      '(--eq --neq --sgt --ugt --slt --ult --sge --uge --sle --ule --bs --bc)--sle[signed less than or equal to operand]' \
      '(--eq --neq --sgt --ugt --slt --ult --sge --uge --sle --ule --bs --bc)--ule[unsigned less than or equal to operand]' \
      '(--eq --neq --sgt --ugt --slt --ult --sge --uge --sle --ule --bs --bc)--bs[all operand bits SET in counter]' \
      '(--eq --neq --sgt --ugt --slt --ult --sge --uge --sle --ule --bs --bc)--bc[all operand bits CLEAR in counter]' \
      ':TPM2 counter/timer field (clock|reset-count|restart-count|tpm-time|safe):(clock reset-count restart-count tpm-time safe)' \
      ':operand value (hex or decimal):'
    ;;

  tpm2_policycphash)
    # TPM2_PolicyCpHash: bind the policy to a command-parameter
    # hash (cpHash) computed from a future command's parameters.
    # Used to lock a policy to a specific command invocation
    # (e.g. "only allow tpm2_nvwrite if its parameters hash to
    # this cpHash").  Sister to the ubiquitous --cphash output
    # flag across R193-R202.
    _arguments -s -S \
      $tpm2_common \
      '(-L --policy)'{-L+,--policy=}'[output policy-digest file]:file:_files' \
      '(-S --session)'{-S+,--session=}'[policy-session context file]:file:_files' \
      '--cphash-input=[input cpHash digest file (from a previous --cphash output)]:file:_files' \
      '--cphash=[output command-parameter hash for off-line audit]:file:_files'
    ;;

  tpm2_policyduplicationselect)
    # TPM2_PolicyDuplicationSelect: restrict which parent an
    # object can be duplicated under (used with R201's
    # tpm2_duplicate).  -n/--object-name + -N/--parent-name are
    # the object-to-duplicate name and the allowed new-parent
    # name.  --include-object long-only (val=0): include the
    # object's name in the policy hash.
    _arguments -s -S \
      $tpm2_common \
      $tpm2_policy_base \
      '(-n --object-name)'{-n+,--object-name=}'[input object-to-duplicate name file]:file:_files' \
      '(-N --parent-name)'{-N+,--parent-name=}'[input new-parent name file]:file:_files' \
      '--include-object[include the object name in the policy hash]'
    ;;

  tpm2_policylocality)
    # TPM2_PolicyLocality: bind the policy to a TPM locality
    # (0-4 for hardware, plus extended 32-255 for software).
    # Positional accepts a locality number or symbolic name
    # (locality-zero through locality-four).
    _arguments -s -S \
      $tpm2_common \
      $tpm2_policy_base \
      ':TPM locality (0-4 or 32-255):(0 1 2 3 4 locality-zero locality-one locality-two locality-three locality-four)'
    ;;

  tpm2_policynamehash)
    # TPM2_PolicyNameHash: bind the policy to a hash of one or
    # more object names (similar to policy-duplicationselect
    # but for non-duplication commands).
    _arguments -s -S \
      $tpm2_common \
      '(-L --policy)'{-L+,--policy=}'[output policy-digest file]:file:_files' \
      '(-S --session)'{-S+,--session=}'[policy-session context file]:file:_files' \
      '(-n --name)'{-n+,--name=}'[input name-hash file]:file:_files'
    ;;

  tpm2_policynv)
    # TPM2_PolicyNV: bind the policy to a comparison of an NV-
    # index value against an input value.  Sister to
    # tpm2_policycountertimer but for NV values rather than
    # TPM clock/counter.
    _arguments -s -S \
      $tpm2_common \
      $tpm2_policy_base \
      '(-C --hierarchy)'{-C+,--hierarchy=}'[NV-index hierarchy (owner|platform)]:hierarchy:(owner platform o p)' \
      '(-P --auth)'{-P+,--auth=}'[hierarchy authorization]:auth:' \
      '(-i --input)'{-i+,--input=}'[input value to compare against]:file:_files' \
      '--offset=[offset (bytes) within the NV index to compare from]:bytes:' \
      ':NV index handle (hex e.g. 0x1500001):' \
      ':comparison operator (eq|neq|sgt|ugt|slt|ult|sge|uge|sle|ule|bs|bc):(eq neq sgt ugt slt ult sge uge sle ule bs bc)'
    ;;

  tpm2_policynvwritten)
    # TPM2_PolicyNvWritten: bind the policy to whether an NV
    # index has been written-to since define-time.  Positional
    # accepts set|clear (or yes|no aliases).
    _arguments -s -S \
      $tpm2_common \
      $tpm2_policy_base \
      ':NV-written state:(set clear yes no s c y n 0 1)'
    ;;

  tpm2_policysigned)
    # TPM2_PolicySigned: bind the policy to a signature from a
    # given key.  Similar to R202's tpm2_policyauthorize but
    # the signature is verified at policy-build time rather
    # than at policy-evaluation time.  Heavier topts[] than
    # other policy tools - 13 flags - because it carries
    # signing-key + signature + ticket + cphash inputs all in
    # one tool.
    _arguments -s -S \
      $tpm2_common \
      '(-L --policy)'{-L+,--policy=}'[output policy-digest file]:file:_files' \
      '(-S --session)'{-S+,--session=}'[policy-session context file]:file:_files' \
      '(-g --hash-algorithm)'{-g+,--hash-algorithm=}'[hash algorithm for the signing scheme]:alg:($tpm2_hashalgs)' \
      '(-s --signature)'{-s+,--signature=}'[input signature file]:file:_files' \
      '(-f --format)'{-f+,--format=}'[signature input format]:format:(tss plain)' \
      '(-c --key-context)'{-c+,--key-context=}'[signing-key context (handle or context file)]:key:' \
      '(-t --expiration)'{-t+,--expiration=}'[expiration time in seconds]:sec:' \
      '(-q --qualification)'{-q+,--qualification=}'[qualifying data (binding nonce)]:nonce:' \
      '(-x --nonce-tpm)'{-x,--nonce-tpm}'[include a TPM-supplied nonce for replay protection]' \
      '--ticket=[output ticket file (for off-line replay)]:file:_files' \
      '--timeout=[output timeout file]:file:_files' \
      '--raw-data=[input raw data being signed (for cpHash computation)]:file:_files' \
      '--cphash-input=[input cpHash digest file (when policy binds future-command params)]:file:_files'
    ;;

  tpm2_policytemplate)
    # TPM2_PolicyTemplate: bind the policy to a TPM2B_TEMPLATE
    # hash (the canonical hash of a key-creation template).
    # Used to restrict policy to keys with specific creation
    # parameters.
    _arguments -s -S \
      $tpm2_common \
      '(-L --policy)'{-L+,--policy=}'[output policy-digest file]:file:_files' \
      '(-S --session)'{-S+,--session=}'[policy-session context file]:file:_files' \
      '--template-hash=[input template-hash file]:file:_files'
    ;;

  tpm2_policyticket)
    # TPM2_PolicyTicket: revive an expired tpm2_policysigned or
    # tpm2_policysecret session by replaying a ticket + timeout
    # (the off-line policy-replay mechanism).  Sister to
    # tpm2_policysigned and tpm2_policysecret tickets.
    _arguments -s -S \
      $tpm2_common \
      '(-L --policy)'{-L+,--policy=}'[output policy-digest file]:file:_files' \
      '(-S --session)'{-S+,--session=}'[policy-session context file]:file:_files' \
      '(-n --name)'{-n+,--name=}'[input name file of the authorizing object]:file:_files' \
      '(-q --qualification)'{-q+,--qualification=}'[qualifying data (binding nonce)]:nonce:' \
      '--ticket=[input ticket file (from a previous policysigned/policysecret)]:file:_files' \
      '--timeout=[input timeout file]:file:_files'
    ;;

esac
