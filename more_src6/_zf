#compdef zf
# Documentation: https://github.com/natecraddock/zf/blob/main/doc/zf.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments \
  '(- *)'{-h,--help}'[display help and exit]' \
  '(- *)'{-v,--version}'[show version information and exit]' \
  '(-d --delimiter)'{-d+,--delimiter=}'[set the delimiter used to split the input]:delimiter:' \
  '-0[shorthand for -d=NUL to split on null bytes]' \
  '(-f --filter)'{-f+,--filter=}'[skip interactive use and filter using the given query]:query:' \
  '--height=[the height of the interface in rows]:rows:' \
  '(-k --keep-order)'{-k,--keep-order}'[do not sort by rank; preserve order of lines read on stdin]' \
  '(-l --lines)'{-l+,--lines=}'[alias of --height (deprecated)]:rows:' \
  '(-p --plain)'{-p,--plain}'[treat input as plaintext and disable filepath matching features]' \
  '--preview=[command displayed in side column with {} substituted for selection]:command:' \
  '--preview-width=[preview column width]:width:' \
  '*:file:_files'
