#compdef vegeta-bin
# _vegeta-bin — vegeta HTTP load tester (Tomás Senart, Go); same flags as vegeta with -bin suffix variant
# upstream: https://github.com/tsenart/vegeta

_vegeta-bin() {
    local -a sub=(
        'attack:execute an attack'
        'encode:convert between formats'
        'plot:render results as HTML+SVG plot'
        'report:generate a report'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vegeta subcommand' sub ;;
        args)
            case $words[1] in
                attack) _arguments \
                    '-targets+[targets file]:file:_files' \
                    '-rate+[req rate]:rate:' \
                    '-duration+[duration]:duration:' \
                    '-timeout+[timeout]:duration:' \
                    '-output+[output file]:file:_files' \
                    '-cert+[client cert]:file:_files' \
                    '-key+[client key]:file:_files' \
                    '-insecure[skip TLS verify]' \
                    '-h2c[force HTTP/2 cleartext]' \
                    '-http2+[allow HTTP/2]:bool:(true false)' \
                    '-keepalive+[keep alive]:bool:(true false)' \
                    '-workers+[workers]:n:' \
                    '-redirects+[max redirects]:n:' \
                    '-format+[targets format]:fmt:(http json)' \
                    '-header+[header]:str:' \
                    '-name+[run name]:name:' \
                    '-laddr+[local addr]:addr:' ;;
                report) _arguments \
                    '-type+[report type]:type:(text json hist hdrplot)' \
                    '-output+[output file]:file:_files' \
                    '-buckets+[histogram buckets]:str:' \
                    '-every+[every duration]:duration:' \
                    '*:file:_files' ;;
                plot) _arguments \
                    '-output+[output html]:file:_files' \
                    '-threshold+[threshold]:n:' \
                    '-title+[title]:title:' \
                    '*:file:_files' ;;
                encode) _arguments \
                    '-output+[output file]:file:_files' \
                    '-to+[target format]:fmt:(csv gob json)' \
                    '*:file:_files' ;;
            esac
            ;;
    esac
}

_vegeta-bin "$@"
