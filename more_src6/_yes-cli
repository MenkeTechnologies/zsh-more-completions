#compdef yes-cli
# _yes-cli — GNU coreutils yes output string repeatedly CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_yes-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '*:string:'
}

_yes-cli "$@"
