#compdef mkzonefs zonefs-tools
# _zonefs-tools — Western Digital zonefs-tools mkzonefs CLI formatting tool for the Linux kernel zonefs filesystem on host-managed host-aware SMR ZBC ZAC and ZNS NVMe zoned block devices exposing per-zone files in conventional sequential aggregation modes for sequential append workloads (WDC team, C); getopt
# upstream: https://github.com/westerndigitalcorporation/zonefs-tools

_zonefs-tools() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-f[force]' \
        '-o+[options]:o:(aggr_cnv pwropt explicit_open immediate disable_zone_reset)' \
        '-s[show only]' \
        '-q[quiet]' \
        '-L+[volume label]:str:' \
        '-U+[uuid]:str:' \
        '*:device:_files -g "/dev/sd* /dev/nvme* /dev/zonefs*"'
}

_zonefs-tools "$@"
