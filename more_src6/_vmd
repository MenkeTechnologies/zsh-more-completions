#compdef vmd
# Documentation: https://www.ks.uiuc.edu/Research/vmd/vmd_help.html
# Reference accessed: 2026-05-21
# Verified: upstream VMD documentation at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h -\?)'{-h,-\?}'[show help]' \
  '-e+[execute commands from file]:script:_files' \
  '-disp+[display type]:device:(win text cave none)' \
  '-pos+[window position x y]:x y:' \
  '-size+[window size x y]:width height:' \
  '-nt[do not show VMD title at startup]' \
  '-startup+[startup script]:script:_files' \
  '-init+[init data file]:file:_files' \
  '-psf+[load PSF file]:file:_files -g "*.psf"' \
  '-pdb+[load PDB file]:file:_files -g "*.pdb"' \
  '-dcd+[load DCD trajectory]:file:_files -g "*.dcd"' \
  '*:file:_files' && ret=0

return ret
