#compdef tcpdump
# _tcpdump-bin — classic libpcap network sniffer (Van Jacobson et al, C); print packets matching a BPF filter
# upstream: https://www.tcpdump.org

_tcpdump-bin() {
    _arguments \
        '-A[print payload as ASCII]' \
        '-B+[buffer size KB]:n:' \
        '-b[show AS number in BGP]' \
        '-c+[stop after N packets]:n:' \
        '-C+[file size MB before rotate]:n:' \
        '-D[list interfaces]' \
        '-d[dump compiled filter]' \
        '-dd[dump filter as C code]' \
        '-ddd[dump filter as decimal numbers]' \
        '-e[print link-level header]' \
        '-F+[filter file]:file:_files' \
        '-f[do not translate addresses]' \
        '-G+[rotate every N sec]:n:' \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-I[monitor mode]' \
        '-i+[interface]:iface:_net_interfaces' \
        '-J[list time-stamp types]' \
        '-j+[time-stamp type]:type:' \
        '-K[no checksum verification]' \
        '-L[list link-layer types]' \
        '-l[buffered output]' \
        '-M+[shared secret for TCP-MD5]:str:' \
        '-m+[load SMI mib]:file:_files' \
        '-N[shorten host names]' \
        '-n[no name resolution]' \
        '-nn[no protocol resolution]' \
        '-O[no optimize filter]' \
        '-p[no promiscuous]' \
        '-Q+[direction]:dir:(inout in out)' \
        '-q[quick output]' \
        '-r+[read from file]:file:_files' \
        '-S[absolute TCP seq numbers]' \
        '-s+[snaplen bytes]:n:' \
        '-T+[protocol decoder]:proto:(aodv carp cnfp lmp pgm pgm_zmtp1 ptp radius rpc rtcp rtp snmp sctp tftp vat vrrp wb zmtp1)' \
        '-t[no timestamp]' \
        '-tt[absolute timestamp]' \
        '-ttt[delta time since previous packet]' \
        '-tttt[both delta and abs timestamp]' \
        '-ttttt[delta time since start]' \
        '-U[unbuffered file output]' \
        '-u[print undecoded NFS handles]' \
        '-V+[file list]:file:_files' \
        '-v[verbose]' \
        '-vv[very verbose]' \
        '-vvv[full verbose]' \
        '-W+[max number of rotated files]:n:' \
        '-w+[write to file]:file:_files' \
        '-X[hex+ASCII dump]' \
        '-XX[hex+ASCII incl link-level]' \
        '-x[hex dump]' \
        '-xx[hex dump incl link-level]' \
        '-y+[data link type]:type:' \
        '-Z+[drop privileges to user]:user:_users' \
        '-z+[postrotate cmd]:cmd:_command_names -e' \
        '*:filter:'
}

_tcpdump-bin "$@"
