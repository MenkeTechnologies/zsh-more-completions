#compdef untwine
# untwine — fast point cloud indexer for EPT/COPC

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-i,--input}'=[input file]:input file:_files -g "*.(las|laz|LAS|LAZ)(-.)"' \
  {-o,--output}'=[output directory]:output dir:_directories' \
  '--temp_dir=[temp directory]:temp dir:_directories' \
  '--threads=[number of threads]:threads:' \
  '--a_srs=[assign spatial reference system]:SRS:' \
  '--dims=[dimension specification]:dimensions:' \
  '--single_file[output single COPC file]' \
  '--stats[compute statistics]' && ret=0

return ret
