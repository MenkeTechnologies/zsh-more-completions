#compdef w3af w3af_console w3af_gui
# _w3af — Andrés Riancho w3af Web Application Attack and Audit Framework console and GUI for vulnerability scanning (andresriancho team, Python); custom argparse
# upstream: https://github.com/andresriancho/w3af

_w3af() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-s+[script file]:file:_files -g "*.w3af *.script"' \
        '--script=+[script file]:file:_files -g "*.w3af *.script"' \
        '-P+[profile file]:file:_files -g "*.pw3af"' \
        '--profile=+[profile file]:file:_files -g "*.pw3af"' \
        '-S+[session file]:file:_files' \
        '--session=+[session file]:file:_files' \
        '-y+[scan target url]:url:_urls' \
        '--target=+[scan target url]:url:_urls' \
        '-i+[plugin info]:str:' \
        '--info=+[plugin info]:str:' \
        '-A[no auto update check]' \
        '--no-update[no auto update check]' \
        '--force-update[force update]' \
        '-r[disable readline]' \
        '--no-readline[disable readline]' \
        '-d[debug mode]' \
        '--debug[debug mode]' \
        '-c+[ca cert file]:file:_files' \
        '--cert=+[ca cert file]:file:_files' \
        '--no-color[disable color]' \
        '-e+[exec command]:str:' \
        '--exec=+[exec command]:str:' \
        '--no-banner[no banner]' \
        '--silent[silent]'
}

_w3af "$@"
