#compdef whipper
# _whipper — whipper secure audio CD ripper (Python); CDDA → FLAC ripper with AccurateRip / MusicBrainz verification
# upstream: https://github.com/whipper-team/whipper

_whipper() {
    local -a sub=(
        'cd:CD operations'
        'offset:detect drive offset'
        'drive:show drive info'
        'image:image operations (rip from image)'
        'accurip:AccurateRip queries'
        'mblookup:MusicBrainz lookup'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-R --record)'{-R,--record}'[record session]' \
        '(-v --verbose)'{-v,--verbose}'[verbose log]' \
        '(-e --eject)'{-e,--eject}'+[eject behavior]:behavior:(always success never)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'whipper subcommand' sub ;;
        args)
            case $words[1] in
                cd) _arguments \
                    '1:cd cmd:(info rip)' \
                    '(-d --device)'{-d,--device}'+[device]:device:_files' \
                    '(-o --offset)'{-o,--offset}'+[offset]:n:' \
                    '(-O --output-directory)'{-O,--output-directory}'+[output dir]:dir:_files -/' \
                    '(-W --working-directory)'{-W,--working-directory}'+[working dir]:dir:_files -/' \
                    '(-T --track-template)'{-T,--track-template}'+[track template]:template:' \
                    '(-D --disc-template)'{-D,--disc-template}'+[disc template]:template:' \
                    '(--release-id)--release-id+[MusicBrainz release id]:id:' \
                    '(--cdr)--cdr[force CD-R]' \
                    '(-U --unknown)'{-U,--unknown}'[allow unknown disc]' ;;
                offset) _arguments '1:offset cmd:(find)' '(-d --device)'{-d,--device}'+[device]:device:_files' ;;
            esac
            ;;
    esac
}

_whipper "$@"
