#compdef x2sys_get
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/x2sys/x2sys_get.html
# Source: GenericMappingTools/gmt supplements/x2sys — find tracks in x2sys database matching criteria.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-T+[x2sys TAG identifying data attributes]:tag:_default' \
    '-C[output bin centers (not track names)]' \
    '-D[report track names only (no data availability)]' \
    '-F+[required column names from format]:flags:_default' \
    '-G[report data flags for entire track, not just region]' \
    '-L+[crossover mode: track-pair list]:opts:_default' \
    '-N+[columns that must be absent]:flags:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '*-V[verbose (stackable)]' \
    && ret=0

return ret
