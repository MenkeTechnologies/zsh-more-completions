#compdef taf_dump
# Documentation: https://confluence.ecmwf.int/display/ECC/taf_dump
# Source: ecmwf/eccodes tools/taf_dump.cc — dump TAF (Terminal Aerodrome Forecast) messages (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-O[octet mode (WMO documentation style)]' \
    '-D[debug mode]' \
    '-d[print all data values]' \
    '-t[print type information]' \
    '-C[C code mode (generate C program)]' \
    '-S[strict, only messages matching all constraints]' \
    '-H[print octet content in hex]' \
    '-a[dump aliases]' \
    '-w+[where clause filter]:filter:_default' \
    '-M[turn off multi-field support]' \
    '-T+[message type]:type:(T B M A)' \
    '-7[do not fail on wrong message length]' \
    '-q[quiet]' \
    '(- *)-V[show version]' \
    '-x[fast parsing (headers only)]' \
    '*:taf file:_files' \
    && ret=0

return ret
