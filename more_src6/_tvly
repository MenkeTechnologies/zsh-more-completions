#compdef tvly
# Documentation: https://docs.tavily.com/documentation/tavily-cli
# Reference accessed: 2026-05-23
# Verified: Tavily CLI reference (tvly search, extract, crawl, map, research).

# Zsh completion for tvly - official Tavily CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'search:web search'
  'extract:extract URL content'
  'crawl:crawl a website'
  'map:discover site URLs'
  'research:deep research job'
  'login:save API credentials'
  'logout:clear credentials'
  'status:auth and version summary'
  'doctor:diagnostics'
  'init:setup skills and MCP'
  'setup:install skill or MCP integration'
  'env:write API key to .env'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--json[JSON output]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'tvly command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (search)
        _arguments \
          '--depth[search depth]:depth:(ultra-fast fast basic advanced)' \
          '--max-results[max results 0-20]:n:' \
          '--topic[topic filter]:topic:(general news finance)' \
          '--time-range[relative window]:range:(day week month year)' \
          '--include-domains[include domains]:domains:' \
          '--exclude-domains[exclude domains]:domains:' \
          '--country[country boost]:code:' \
          '--include-answer[include AI answer]:level:(basic advanced)' \
          '--include-raw-content[include page content]:fmt:(markdown text)' \
          '(-o --output)'{-o+,--output=}'[save to file]:file:_files' \
          ':query:' && ret=0
        ;;
      (extract|crawl|map)
        _arguments ':url:_urls' && ret=0
        ;;
      (research)
        _arguments ':topic:' && ret=0
        ;;
      (setup)
        _arguments '1:target:(skill mcp)' && ret=0
        ;;
      (login|logout|status|doctor|init|env)
        _arguments '*::args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
