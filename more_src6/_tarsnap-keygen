#compdef tarsnap-keygen
# _tarsnap-keygen — register a Tarsnap account and create a key file (Tarsnap/tarsnap)
# upstream: https://github.com/Tarsnap/tarsnap
# Flags from keygen/keygen.c (getopt).

_tarsnap-keygen() {
    _arguments \
        '(- *)--version[print version]' \
        '--user=[Tarsnap account email address]:email:' \
        '--machine=[machine name (identifies this client)]:name:' \
        '--keyfile=[key file to create]:file:_files' \
        '--passphrase-mem=[max memory used for passphrase derivation]:bytes:' \
        '--passphrase-time=[max time used for passphrase derivation]:seconds:' \
        '--passphrased[passphrase-protect the new key]'
}

_tarsnap-keygen "$@"
