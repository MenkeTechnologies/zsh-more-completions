#compdef whisper-talk-llama
# Documentation: https://github.com/ggml-org/whisper.cpp/blob/master/examples/talk-llama/talk-llama.cpp
# Reference accessed: 2026-05-27
# Verified: upstream whisper_params_parse() in examples/talk-llama/talk-llama.cpp (ggml-org/whisper.cpp).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-t --threads)'{-t+,--threads=}'[number of threads]:n:' \
  '(-vms --voice-ms)'{-vms+,--voice-ms=}'[voice capture duration in ms]:ms:' \
  '(-c --capture)'{-c+,--capture=}'[capture device id (-1 for default)]:id:' \
  '(-mt --max-tokens)'{-mt+,--max-tokens=}'[maximum number of tokens per response]:n:' \
  '(-ac --audio-ctx)'{-ac+,--audio-ctx=}'[audio context size]:n:' \
  '(-ngl --n-gpu-layers)'{-ngl+,--n-gpu-layers=}'[number of llama layers to offload to GPU]:n:' \
  '--seed=[RNG seed for llama sampling]:seed:' \
  '--top-k=[top-k sampling]:n:' \
  '--min-keep=[minimum tokens to keep in sampling]:n:' \
  '--top-p=[top-p (nucleus) sampling]:float:' \
  '--min-p=[min-p sampling]:float:' \
  '--temp=[llama sampling temperature]:float:' \
  '(-vth --vad-thold)'{-vth+,--vad-thold=}'[VAD threshold]:float:' \
  '(-fth --freq-thold)'{-fth+,--freq-thold=}'[high-pass frequency cutoff]:float:' \
  '(-tr --translate)'{-tr,--translate}'[translate whisper output to English]' \
  '(-ps --print-special)'{-ps,--print-special}'[print special tokens]' \
  '(-pe --print-energy)'{-pe,--print-energy}'[print audio energy levels]' \
  '(-vp --verbose-prompt)'{-vp,--verbose-prompt}'[print verbose prompt info]' \
  '(-ng --no-gpu)'{-ng,--no-gpu}'[disable GPU]' \
  '(-fa --flash-attn)'{-fa,--flash-attn}'[enable flash attention]' \
  '(-nfa --no-flash-attn)'{-nfa,--no-flash-attn}'[disable flash attention]' \
  '(-p --person)'{-p+,--person=}'[name of the user persona]:name:' \
  '(-bn --bot-name)'{-bn+,--bot-name=}'[name of the bot persona]:name:' \
  '--session=[path to save/load llama session state]:file:_files' \
  '(-w --wake-command)'{-w+,--wake-command=}'[wake-word command to trigger interaction]:text:' \
  '(-ho --heard-ok)'{-ho+,--heard-ok=}'[acknowledgement phrase after hearing wake word]:text:' \
  '(-l --language)'{-l+,--language=}'[spoken language code]:lang:(auto en zh de es ru ko fr ja pt tr pl ca nl ar sv it id hi fi vi he uk el ms cs ro da hu ta no th ur hr bg lt la mi ml cy sk te fa lv bn sr az sl kn et mk br eu is hy ne mn bs kk sq sw gl mr pa si km sn yo so af oc ka be tg sd gu am yi lo uz fo ht ps tk nn mt sa lb my bo tl mg as tt haw ln ha ba jw su)' \
  '(-mw --model-whisper)'{-mw+,--model-whisper=}'[whisper model path]:file:_files' \
  '(-ml --model-llama)'{-ml+,--model-llama=}'[llama model path]:file:_files' \
  '(-s --speak)'{-s+,--speak=}'[TTS speak script path]:file:_files' \
  '(-sf --speak-file)'{-sf+,--speak-file=}'[file to write spoken text to]:file:_files' \
  '--prompt-file=[file containing the initial prompt]:file:_files' \
  '(-f --file)'{-f+,--file=}'[output text file path]:file:_files' && ret=0

return ret
