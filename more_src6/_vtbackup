#compdef vtbackup
# _vtbackup — Vitess shard backup helper
# upstream: https://github.com/vitessio/vitess
# Flags from go/cmd/vtbackup/cli/vtbackup.go on tip.

_vtbackup() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--min-backup-interval=[min duration since last backup]:dur:' \
        '--min-retention-time=[min retention for old backups (0=no prune)]:dur:' \
        '--min-retention-count=[always keep at least N recent backups]:n:' \
        '--initial-backup=[take first backup of an empty shard]:bool:(true false)' \
        '--allow-first-backup=[allow taking first backup of an existing shard]:bool:(true false)' \
        '--restart-before-backup=[clean restart mysqld before backup]:bool:(true false)' \
        '--upgrade-safe=[use innodb_fast_shutdown=0 for backup]:bool:(true false)' \
        '--init-backup-sql-queries=[SQL queries before backup (csv)]:csv:' \
        '--init-backup-tablet-types=[tablet types for init SQL]:csv:' \
        '--init-backup-sql-timeout=[init SQL timeout]:dur:' \
        '--init-backup-sql-fail-on-error[fail backup on init SQL error]' \
        '--init-db-name-override=[override db name used by vttablet]:name:' \
        '--init-keyspace=[init keyspace]:name:' \
        '--init-shard=[init shard]:shard:' \
        '--concurrency=[concurrent restore file count]:n:' \
        '--incremental-from-pos=[position/backup name for incremental backup]:spec:' \
        '--restore-with-clone=[restore using MySQL CLONE]:bool:(true false)' \
        '--mysql-port=[MySQL port]:port:' \
        '--mysql-socket=[mysqld socket path]:path:_files' \
        '--mysql-timeout=[mysqld startup wait]:dur:' \
        '--mysql-shutdown-timeout=[mysqld shutdown wait]:dur:' \
        '--init-db-sql-file=[.sql file run after mysql_install_db]:file:_files' \
        '--detach[detach from terminal]' \
        '--keep-alive-timeout=[wait after backup before shutdown]:dur:' \
        '--disable-redo-log=[disable InnoDB redo log during replication]:bool:(true false)' \
        '-v[verbosity level]:n:'
}

_vtbackup "$@"
