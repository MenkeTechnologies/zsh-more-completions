#compdef zappa-cli zappa
# _zappa-cli — Rich Jones Zappa serverless Python on AWS Lambda CLI alias (zappa team, Python); argparse
# upstream: https://github.com/zappa/Zappa

_zappa-cli() {
    local -a sub=(
        'init:initialize zappa project'
        'deploy:deploy app'
        'update:update deployed app'
        'undeploy:undeploy app'
        'rollback:rollback'
        'invoke:invoke function'
        'manage:run management command (Django)'
        'tail:tail logs'
        'status:show status'
        'schedule:schedule events'
        'unschedule:unschedule events'
        'package:package app'
        'template:generate cloudformation template'
        'shell:open Python shell'
        'certify:apply SSL cert'
        'save-python-settings-file:save settings file'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--all[run for all]' \
        '--app_function=+[entrypoint]:str:' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--disable_progress[disable progress]' \
        '--json[json output]' \
        '-j[json output]' \
        '--no_color[no color]' \
        '--settings_file=+[settings file]:file:_files -g "zappa_settings.{json,yaml,yml}"' \
        '-s+[settings file]:file:_files -g "zappa_settings.{json,yaml,yml}"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zappa subcommand' sub ;;
        args)
            case $words[1] in
                deploy|update|undeploy|rollback|tail|status|schedule|unschedule|certify|package|template|shell) _arguments \
                    '1:stage:' \
                    '--zip=+[zip file]:file:_files -g "*.zip"' \
                    '--no-cleanup[no cleanup]' \
                    '--no-upload[no upload]' \
                    '--docker[use docker]' \
                    '--docker-image-uri=+[image]:str:' \
                    '--manual_path=+[manual path]:dir:_files -/' \
                    '--skip-on-failure[skip on failure]' \
                    '--keep_local[keep local]' ;;
                invoke) _arguments \
                    '1:stage:' \
                    '2:command:' \
                    '--raw[raw mode]' \
                    '--no_color[no color]' \
                    '--manage[manage command]' ;;
                tail) _arguments \
                    '1:stage:' \
                    '--since=+[time]:str:' \
                    '--non_http[non http]' \
                    '--http[http]' \
                    '--filter=+[filter]:str:' \
                    '--force-color[force color]' \
                    '--disable-keep-open[disable keep open]' \
                    '--colorize[colorize]' ;;
                init) ;;
            esac
            ;;
    esac
}

_zappa-cli "$@"
