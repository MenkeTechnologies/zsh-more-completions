#compdef wvunpack
# Documentation: wvunpack --help (WavPack 5.x)
# Source: WavPack wvunpack — unpack or verify existing WavPack files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(--aif --aif-le --w64 --caf-be --caf-le -r --raw --raw-pcm --dff --dsdiff --dsf -w)--aif[force Apple AIFF (.aif)]' \
    '(--aif --aif-le --w64 --caf-be --caf-le -r --raw --raw-pcm --dff --dsdiff --dsf -w)--aif-le[force Apple AIFF-C/sowt (.aif)]' \
    '-b[blindly decode all stream blocks (ignore length)]' \
    '-c[extract cuesheet only to stdout]' \
    '-cc[extract cuesheet file (.cue) in addition]' \
    '(--aif --aif-le --w64 --caf-be --caf-le -r --raw --raw-pcm --dff --dsdiff --dsf -w)--caf-be[force big-endian Core Audio (.caf)]' \
    '(--aif --aif-le --w64 --caf-be --caf-le -r --raw --raw-pcm --dff --dsdiff --dsf -w)--caf-le[force little-endian Core Audio (.caf)]' \
    '-d[delete source file if successful]' \
    '(--aif --aif-le --w64 --caf-be --caf-le -r --raw --raw-pcm --dff --dsdiff --dsf -w)--dff[force Philips DSDIFF (.dff)]' \
    '(--aif --aif-le --w64 --caf-be --caf-le -r --raw --raw-pcm --dff --dsdiff --dsf -w)--dsdiff[alias for --dff]' \
    '(--aif --aif-le --w64 --caf-be --caf-le -r --raw --raw-pcm --dff --dsdiff --dsf -w)--dsf[force Sony DSF (.dsf)]' \
    '-f+[file info to stdout (1-10 = specific item)]::n:' \
    '(- *)--help[extended help display]' \
    '-i[ignore .wvc file (force hybrid lossy decompression)]' \
    '-m[calculate + display MD5 signature]' \
    '-n[no audio decoding (with -xx for tags only)]' \
    '--no-overwrite[never overwrite existing files]' \
    '--no-threads[single-threaded]' \
    '--normalize-floats[normalize float audio to ±1.0]' \
    '--no-utf8-convert[leave tag items in UTF-8]' \
    '-o+[output filename or path]:file:_files' \
    '-q[quiet (minimal console output)]' \
    '(--aif --aif-le --w64 --caf-be --caf-le -r --raw --raw-pcm --dff --dsdiff --dsf -w)-r[force raw audio decode]' \
    '(--aif --aif-le --w64 --caf-be --caf-le -r --raw --raw-pcm --dff --dsdiff --dsf -w)--raw[force raw audio decode]' \
    '(--aif --aif-le --w64 --caf-be --caf-le -r --raw --raw-pcm --dff --dsdiff --dsf -w)--raw-pcm[force raw decode, DSD as 24-bit PCM]' \
    '-s[summary info only]' \
    '-ss[super summary with tags]' \
    '--skip=[start decoding at sample or hh\:mm\:ss.ss (- = from end)]:position:' \
    '-t[copy input timestamp to output]' \
    '--threads=[N worker threads (1..12)]:n:' \
    '(--aif --aif-le --w64 --caf-be --caf-le -r --raw --raw-pcm --dff --dsdiff --dsf -w)-w[force RIFF WAV output]' \
    '(--aif --aif-le --w64 --caf-be --caf-le -r --raw --raw-pcm --dff --dsdiff --dsf -w)--w64[force Sony Wave64 (.w64)]' \
    '-x+[extract single tag item by name (or all by num)]:item:' \
    '-xx+[extract tags to .ext files using template]:template:' \
    '-y[supress overwrite prompts]' \
    '-z[do not store extra wrappers]' \
    '--until=[stop decoding at sample or hh\:mm\:ss.ss]:position:' \
    '*:WavPack file:_files -g "*.wv"' \
    && ret=0

return ret
