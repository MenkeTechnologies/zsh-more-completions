#compdef xte
# Documentation: https://man.archlinux.org/man/xte.1.en
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (xautomation xte(1)).
# Removed: --version, --delay (-d) — not in upstream man page OPTIONS.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-x+[send commands to remote X display]:display:' \
  '-i+[XInput 2.x device id]:id:' \
  '*: :' && ret=0

return ret
