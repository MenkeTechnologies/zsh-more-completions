#compdef tikv-cdc
# _tikv-cdc — TiKV-CDC (raw KV change-data-capture) CLI
# upstream: https://github.com/tikv/migration
# Subcommands + server flags from cdc/pkg/cmd on tip.

_tikv-cdc() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'server:run a TiKV-CDC server (capture)'
                'cli:CLI for managing changefeeds, captures, tso, processors'
                'version:print version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                server)
                    _arguments \
                        '--addr=[listen host\:port]:host\:port:' \
                        '--advertise-addr=[advertised host\:port]:host\:port:' \
                        '--tz=[cluster time zone]:tz:' \
                        '--gc-ttl=[GC safepoint TTL (s)]:s:' \
                        '--log-file=[log file path]:file:_files' \
                        '--log-level=[log level]:level:(debug info warn error)' \
                        '--data-dir=[data directory]:dir:_files -/' \
                        '--owner-flush-interval=[owner status flush interval]:dur:' \
                        '--processor-flush-interval=[processor status flush interval]:dur:' \
                        '--sorter-num-workerpool-goroutine=[sorter workerpool size]:n:' \
                        '--sorter-num-concurrent-worker=[sorter concurrency]:n:' \
                        '--sorter-chunk-size-limit=[sorter heap chunk size]:bytes:' \
                        '--sorter-max-memory-percentage=[memory %% threshold for spill]:n:' \
                        '--sorter-max-memory-consumption=[max in-memory sort consumption]:bytes:' \
                        '--sort-dir=[sorter temp file dir]:dir:_files -/' \
                        '--pd=[PD endpoints (csv)]:csv:' \
                        '--config=[server config file]:file:_files' \
                        '--ca=[TLS CA cert file]:file:_files' \
                        '--cert=[TLS client cert file]:file:_files' \
                        '--key=[TLS client key file]:file:_files'
                    ;;
                cli)
                    local -a subs=(
                        'changefeed:manage changefeeds (create/list/pause/resume/remove/query/statistics/update)'
                        'capture:list captures'
                        'processor:list/query processors'
                        'tso:query the current TSO'
                        'unsafe:dangerous admin ops (delete service GC safepoint / reset / show metadata)'
                    )
                    _describe -t commands subcommand subs
                    ;;
            esac
            ;;
    esac
}

_tikv-cdc "$@"
