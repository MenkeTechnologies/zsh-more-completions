#compdef unbound-cli
# _unbound-cli — NLnet Labs unbound validating recursive DNS resolver CLI alias (NLnetLabs team, C); custom argparse
# upstream: https://github.com/NLnetLabs/unbound

_unbound-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-d[debug, do not detach]' \
        '-p[do not write pid file]' \
        '-c+[config file]:file:_files -g "unbound.conf"' \
        '-v[verbose]' \
        '-vv[more verbose]' \
        '-vvv[even more verbose]' \
        '-vvvv[max verbose]' \
        '*:arg:'
}

_unbound-cli "$@"
