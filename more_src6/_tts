#compdef tts
# _tts — Coqui TTS command-line synthesizer (coqui-ai/TTS)
# upstream: https://github.com/coqui-ai/TTS
# Flags from TTS/bin/synthesize.py (argparse).

_tts() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--list_models[list provided models]' \
        '--model_info_by_name=[query model info by full name]:name:' \
        '--model_info_by_idx=[query model info by index]:idx:' \
        '--text=[text to synthesize]:text:' \
        '--out_path=[output WAV file]:file:_files -g "*.wav"' \
        '--pipe_out[pipe generated WAV to stdout]' \
        '--model_name=[TTS model name]:name:' \
        '--model_path=[TTS model checkpoint]:file:_files' \
        '--config_path=[model config file]:file:_files' \
        '--vocoder_name=[vocoder model name]:name:' \
        '--vocoder_path=[vocoder checkpoint]:file:_files' \
        '--vocoder_config_path=[vocoder config file]:file:_files' \
        '--encoder_path=[speaker encoder checkpoint]:file:_files' \
        '--encoder_config_path=[speaker encoder config]:file:_files' \
        '--use_cuda[run on CUDA]:bool:(true false)' \
        '--device=[device]:device:(cpu cuda mps)' \
        '--speakers_file_path=[multi-speaker JSON]:file:_files -g "*.json"' \
        '--speaker_idx=[speaker name or index]:speaker:' \
        '--list_speaker_idxs[list speaker indices]' \
        '--speaker_wav=[speaker reference WAV]:file:_files -g "*.wav"' \
        '--language_ids_file_path=[multi-lingual JSON]:file:_files -g "*.json"' \
        '--language_idx=[language id]:lang:' \
        '--list_language_idxs[list language indices]' \
        '--gst_style=[GST style reference WAV]:file:_files -g "*.wav"' \
        '--capacitron_style_text=[Capacitron style transcript]:text:' \
        '--capacitron_style_wav=[Capacitron style reference WAV]:file:_files -g "*.wav"' \
        '--save_spectogram[save predicted spectrogram]' \
        '--reference_wav=[voice conversion reference WAV]:file:_files -g "*.wav"' \
        '--reference_speaker_idx=[voice conversion reference speaker]:speaker:' \
        '--source_wav=[source WAV for voice conversion]:file:_files -g "*.wav"' \
        '--target_wav=[target WAV for voice conversion]:file:_files -g "*.wav"' \
        '--voice_dir=[directory for trained voice]:dir:_files -/' \
        '--progress_bar[show progress bar]:bool:(true false)'
}

_tts "$@"
