#compdef terrascan2
# _terrascan2 — Tenable Accurics terrascan2 CLI command-line frontend wrapping the Terrascan open-source static code analyzer for Infrastructure as Code IaC tool written in Go integrates with Terraform Kubernetes Helm Kustomize Dockerfile CloudFormation ARM Bicep CRD detect security vulnerabilities and compliance violations across IaC mitigate risk before provisioning enable security workflows via SCM-Git-VCS-CI-CD-Bitbucket-GitHub-GitLab-Atlantis hub providers init scan server version run rules check format remote-url remote-type IaC type all-iac trojan TFlint Cloudformation (Tenable Accurics team Cesar Rodriguez Hooman Rashidi, Go); cobra
# upstream: https://github.com/tenable/terrascan

_terrascan2() {
    local -a sub=(
        'init:initialize policies'
        'scan:scan IaC for violations'
        'server:run as REST server'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "*.toml *.yaml *.yml"' \
        '--config-path=+[file]:file:_files -g "*.toml *.yaml *.yml"' \
        '--log-level=+[l]:l:(debug info warn error fatal panic)' \
        '-l+[log level]:l:(debug info warn error fatal panic)' \
        '--log-output=+[fmt]:f:(console json)' \
        '-x+[log output]:f:(console json)' \
        '-i+[IaC type]:i:(terraform helm k8s kustomize docker arm cfn tfplan)' \
        '--iac-type=+[t]:t:(terraform helm k8s kustomize docker arm cfn tfplan)' \
        '--iac-version=+[v]:str:' \
        '-d+[IaC dir]:dir:_files -/' \
        '--iac-dir=+[dir]:dir:_files -/' \
        '-f+[IaC file]:file:_files' \
        '--iac-file=+[file]:file:_files' \
        '-t+[cloud type]:t:(aws azure gcp github docker k8s)' \
        '*-t+[cloud type]:t:(aws azure gcp github docker k8s)' \
        '--cloud-type=+[t]:t:(aws azure gcp github docker k8s)' \
        '--policy-path=+[dir]:dir:_files -/' \
        '*--policy-path=+[dir]:dir:_files -/' \
        '-p+[policy path]:dir:_files -/' \
        '--policy-type=+[t]:str:' \
        '*--policy-type=+[t]:str:' \
        '--repo-url=+[url]:str:' \
        '-r+[remote URL]:str:' \
        '--remote-url=+[url]:str:' \
        '--remote-type=+[t]:t:(git s3 gcs http terraform-registry)' \
        '-o+[output type]:o:(human json yaml xml junit-xml github-sarif sarif)' \
        '--output=+[o]:o:(human json yaml xml junit-xml github-sarif sarif)' \
        '--scan-rules=+[rules]:str:' \
        '--skip-rules=+[rules]:str:' \
        '--severity=+[s]:s:(LOW MEDIUM HIGH CRITICAL)' \
        '--categories=+[cats]:str:' \
        '--config-only[config only]' \
        '--show-passed[show passed]' \
        '--use-colors=+[c]:c:(auto t f)' \
        '--use-terraform-cache[use TF cache]' \
        '--non-recursive[non-recursive]' \
        '--find-vuln[find vulnerabilities]' \
        '--scan-rules-file=+[file]:file:_files' \
        '--skip-rules-file=+[file]:file:_files' \
        '--skip-default-policies[skip default policies]' \
        '--no-color[no color]' \
        '--bundle-file=+[file]:file:_files' \
        '--no-banner[no banner]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'terrascan subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_terrascan2 "$@"
