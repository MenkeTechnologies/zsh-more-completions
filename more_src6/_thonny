#compdef thonny
# Documentation: https://github.com/thonny/thonny/blob/master/thonny/main.py
# Reference accessed: 2026-05-21
# Verified: upstream argparse definitions at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--profile=[profile to create or open]:profile:' \
  '--replayer=[open log file in Replayer tool (empty to launch Replayer)]:logfile:_files' \
  '*:file:_files -g "*.py"' && ret=0

return ret
