#compdef xmr-stak xmr-stak-cpu xmr-stak-gpu xmr-stak-amd xmr-stak-nvidia xmr-stak-rx
# _xmr-stak — fireice-uk xmr-stak unified CPU GPU AMD NVIDIA Monero family CryptoNight RandomX mining CLI supporting low-power devices fancy reporting failover pools algorithms ringbuffer (fireice-uk team, C++); cxxopts
# upstream: https://github.com/fireice-uk/xmr-stak

_xmr-stak() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--currency=+[c]:c:(monero aeon turtlecoin masari graft bittube electroneum stellite haven plenteum loki bbscoin)' \
        '-c+[config file]:file:_files -g "*.txt *.json config*.txt"' \
        '--config=+[config file]:file:_files -g "*.txt *.json config*.txt"' \
        '-C+[config file dir]:dir:_files -/' \
        '--cuda=+[file]:file:_files -g "cuda.txt"' \
        '--cuda-devices=+[csv]:str:' \
        '--amd=+[file]:file:_files -g "amd.txt"' \
        '--amd-devices=+[csv]:str:' \
        '--noCPU[disable CPU]' \
        '--noAMD[disable AMD]' \
        '--noNVIDIA[disable NVIDIA]' \
        '--openCLLoader=+[file]:file:_files' \
        '-o+[pool url]:str:' \
        '--url=+[pool url]:str:' \
        '-u+[user.worker]:str:' \
        '--user=+[user.worker]:str:' \
        '-p+[password]:str:' \
        '--pass=+[password]:str:' \
        '-r+[rigid]:str:' \
        '--rigid=+[rigid]:str:' \
        '--tls[use TLS]' \
        '--nicehash[use NiceHash]' \
        '--currency-set-default[set default currency]' \
        '--print-config-options[print config options]' \
        '--benchmark[run benchmark]' \
        '--benchmark-block-version=+[N]:n:' \
        '--benchmark-wait-sec=+[N]:n:' \
        '--benchmark-work-sec=+[N]:n:' \
        '--http-port=+[port]:n:' \
        '--auto-add-hugepages[auto add hugepages]' \
        '--use-tcp[use TCP]'
}

_xmr-stak "$@"
