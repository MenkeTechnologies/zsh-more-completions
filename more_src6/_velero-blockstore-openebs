#compdef velero-blockstore-openebs velero-plugin-openebs
# _velero-blockstore-openebs — Velero OpenEBS plugin (registers openebs.io/cstor-blockstore + openebs.io/zfspv-blockstore VolumeSnapshotters)
# upstream: https://github.com/openebs/velero-plugin
# Plugin runs as go-plugin gRPC server; framework Config exposes --log-level and --features. OpenEBS / cStor / ZFS connection details come from VolumeSnapshotLocation spec.

_velero-blockstore-openebs() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--log-level=[plugin log level]:level:(trace debug info warning error fatal panic)' \
        '--features=[csv of velero feature flags]:csv:'
}

_velero-blockstore-openebs "$@"
