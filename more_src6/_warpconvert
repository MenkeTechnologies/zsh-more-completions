#compdef warpconvert
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/warpconvert.html
# Source: MRtrix3/mrtrix3 cmd/warpconvert.cpp — convert between deformation/displacement/full warp formats (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-template+[template image grid for output warp]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-midway_space[warp into midway space]' \
    '-from+[which input image when converting warpfull (1 or 2)]:n:(1 2)' \
    '1:in (input warp image):_files -g "*.{nii,nii.gz,mif}"' \
    '2:type:(deformation2displacement displacement2deformation warpfull2deformation warpfull2displacement)' \
    '3:out (output warp image):_files' \
    && ret=0

return ret
