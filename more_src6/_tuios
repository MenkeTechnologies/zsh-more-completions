#compdef tuios
# Documentation: https://github.com/Gaurav-Gosain/tuios
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for tuios - TUI operating system / tiling terminal

local curcontext="$curcontext" state line ret=1
local -a _tuios_cmds

_tuios_cmds=(
  'new:create persistent session'
  'attach:connect to existing session'
  'ls:list all sessions'
  'kill-session:terminate specific session'
  'kill-server:stop daemon (kills all sessions)'
  'daemon:run daemon in foreground'
  'send-keys:send keystrokes to session'
  'run-command:execute TUIOS commands'
  'set-config:change runtime configuration'
  'list-windows:list session windows'
  'get-window:get window details'
  'session-info:get session state information'
  'ssh:run SSH server'
  'config:configuration subcommands'
  'keybinds:keybindings subcommands'
  'layout:layout template subcommands'
  'completion:generate shell completions'
  'help:get command help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--theme=[color theme]:theme' \
  '--list-themes[list available themes]' \
  '--preview-theme=[preview a theme]:theme' \
  '--ascii-only[use ASCII instead of Nerd Font]' \
  '--show-keys[enable key display overlay]' \
  '--border-style=[window border style]:style:(rounded normal thick double hidden block ascii)' \
  '--dockbar-position=[dockbar location]:pos:(bottom top hidden)' \
  '--hide-window-buttons[hide window control buttons]' \
  '--scrollback-lines=[scrollback buffer lines]:num' \
  '--window-title-position=[title position]:pos:(bottom top hidden)' \
  '--hide-clock[hide clock overlay]' \
  '--show-clock[show clock overlay]' \
  '--show-cpu[show CPU stats in dock]' \
  '--show-ram[show RAM stats in dock]' \
  '--shared-borders[enable shared borders between tiled windows]' \
  '--no-animations[disable UI animations]' \
  '--debug[enable debug logging]' \
  '--cpuprofile=[write CPU profile to file]:file:_files' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'tuios command' _tuios_cmds && ret=0
    ;;
esac

return ret
