#compdef tiffset
# Documentation: tiffset (libtiff)
# Source: set TIFF tag values on an existing TIFF file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '*-s+[set tag value]:tagname:' \
    '*-u+[unset tag]:tagname:' \
    '*-d+[select directory number]:dirno:' \
    '*-sd+[select subdirectory offset]:diroff:' \
    '*-sf+[read tag value from file (ASCII tags)]:tagname:' \
    '-m+[max memory MiB (0=none, must be first)]:mib:' \
    ':tiff file:_files -g "*.(tif|tiff|TIF|TIFF)"' \
    && ret=0

return ret
