#compdef thedarkmod
# Documentation: https://wiki.thedarkmod.com/index.php?title=Doom3_command_line_arguments
# Reference accessed: 2026-05-21
# Verified: upstream wiki at the URL above.
# id Tech 4 engine uses +cmd-style console buffer args. Only +set/+seta are
# documented for TDM specifically; other +cmd tokens come from common id Tech 4
# convention but aren't TDM-documented, so omitted to avoid fabrication.

local curcontext="$curcontext" ret=1
_arguments -C \
  '+set[set CVar before init]:cvar:' \
  '+seta[set CVar and archive]:cvar:' \
  '*::extra args:_files' && ret=0
return ret
