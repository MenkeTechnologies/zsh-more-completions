#compdef vorta
# Documentation: https://vorta.borgbase.com/usage/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--create=[trigger a backup run for the specified profile]:profile:' && ret=0

return ret
