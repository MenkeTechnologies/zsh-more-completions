#compdef vgcfgrestore
# _vgcfgrestore — restore volume group metadata from backup (LVM2); revert VG descriptor area to a saved state
# upstream: https://gitlab.com/lvmteam/lvm2

_vgcfgrestore() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-f --file)'{-f,--file}'+[input file]:file:_files' \
        '(-l --list)'{-l,--list}'[list available backups]' \
        '(-M --metadatatype)'{-M,--metadatatype}'+[metadata type]:type:(lvm1 lvm2)' \
        '(-t --test)'{-t,--test}'[dry run]' \
        '--force[force]' \
        '--reportformat+[report format]:fmt:(basic json)' \
        '*:vg:'
}

_vgcfgrestore "$@"
