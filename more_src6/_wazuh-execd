#compdef wazuh-execd
# Documentation: https://documentation.wazuh.com/current/user-manual/reference/daemons/wazuh-execd.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version and license info]' \
  '-c[config file]:file:_files' \
  '*-d[debug mode (repeatable)]' \
  '-f[run in foreground]' \
  '-g[run as group]:group:_groups' \
  '-t[test configuration]' && ret=0
return ret
