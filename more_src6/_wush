_wush() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--version[print version + exit]' \
        '--help[show help]' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _wush_cmds=(
                'serve:start the wush server + print an auth key'
                'ssh:open a shell to a wush server'
                'cp:copy a single file to a wush server'
                'rsync:transfer files to a wush server with rsync'
                'port-forward:forward TCP/UDP ports between local + peer'
                'version:print version + commit'
            )
            _describe -t commands 'wush command' _wush_cmds && ret=0
            ;;
        args)
            case $words[1] in
                serve)
                    _arguments \
                        '--overlay-type=[overlay type]:type:(derp stun)' \
                        '--enable=[server features to enable]:features:(ssh cp port-forward)' \
                        '--disable=[server features to disable]:features:(ssh cp port-forward)' \
                        '--derp-config-file=[custom DERPMap JSON file]:file:_files -g "*.json"' \
                        '--verbose[enable verbose logging]' \
                        '--help[show help]' && ret=0
                    ;;
                ssh)
                    _arguments \
                        '--auth-key=[peer auth key from wush serve]:key:' \
                        '--derp-config-file=[custom DERPMap JSON]:file:_files -g "*.json"' \
                        '--stun-ip-override=[override STUN server]:ip:' \
                        '--quiet[silence all output]' \
                        '--wait-p2p[wait for direct P2P (not DERP-relayed)]' \
                        '--verbose[enable verbose logging]' \
                        '--help[show help]' && ret=0
                    ;;
                cp)
                    _arguments \
                        '1:file to copy:_files' \
                        '--auth-key=[peer auth key]:key:' \
                        '--derp-config-file=[custom DERPMap JSON]:file:_files -g "*.json"' \
                        '--stun-ip-override=[override STUN server]:ip:' \
                        '--wait-p2p[wait for P2P]' \
                        '--verbose[verbose]' \
                        '--help[show help]' && ret=0
                    ;;
                rsync)
                    _arguments \
                        '--auth-key=[peer auth key]:key:' \
                        '--stun-ip-override=[override STUN server]:ip:' \
                        '--wait-p2p[wait for P2P]' \
                        '--verbose[verbose]' \
                        '--help[show help]' \
                        '*: :_files' && ret=0
                    ;;
                port-forward)
                    _arguments \
                        '*--tcp=[forward TCP port LOCAL:PEER]:port:' \
                        '*--udp=[forward UDP port LOCAL:PEER]:port:' \
                        '--auth-key=[peer auth key]:key:' \
                        '--derp-config-file=[custom DERPMap JSON]:file:_files -g "*.json"' \
                        '--stun-ip-override=[override STUN server]:ip:' \
                        '--wait-p2p[wait for P2P]' \
                        '--verbose[verbose]' \
                        '--help[show help]' && ret=0
                    ;;
                version)
                    _arguments '--help[show help]' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_wush "$@"
