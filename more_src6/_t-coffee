#compdef t-coffee
# Documentation: https://tcoffee.readthedocs.io/en/latest/tcoffee_main_documentation.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# T-Coffee: consistency-based multiple sequence alignment
local curcontext="$curcontext" ret=1
_arguments -C \
  '-other_pg[run other programs (seq_reformat, etc.)]' \
  '-version[show version]' \
  '-in[input sequence file(s)]:file:_files' \
  '-infile[input file for evaluation mode]:file:_files' \
  '-seq[provide multiple dataset files]:file:_files' \
  '-aln[combine multiple pre-computed alignments]:file:_files' \
  '-method[methods used to compute pairwise alignments]:methods:' \
  '-mode[mode preset]:mode:(expresso 3dcoffee rcoffee rmcoffee accurate)' \
  '-template_file[template file (e.g. PDB list)]:file:_files' \
  '-output[output format(s)]:fmt:' \
  '-outfile[output alignment file]:file:_files' \
  '-matrix[substitution matrix]:matrix:(blosum62mt blosum30mt pam250mt)' \
  '-gapopen[gap opening penalty (-500 to -5000)]:value:' \
  '-gapext[gap extension penalty (-1 to -10)]:value:' \
  '-multi_core[multicore mode]:mode:' \
  '-n_core=[number of cores]:n:' \
  '-quiet[reduce output]' \
  '-no_warning[silence warnings]' \
  '-blast[BLAST location or LOCAL]:value:' \
  '-pdb_db[PDB database location]:path:_files -/' \
  '*::t-coffee options:_files' && ret=0
return ret
