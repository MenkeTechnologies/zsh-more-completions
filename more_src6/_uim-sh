#compdef uim-sh
# Documentation: https://github.com/uim/uim/blob/master/uim/uim-sh.c
# Reference accessed: 2026-05-16
# Verified: upstream uim/uim uim-sh.c. Interactive Scheme REPL for uim
# debugging; arguments parsed at Scheme layer (uim-sh.scm), not at C
# getopt. No documented user-facing CLI flags.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# uim-sh: uim interactive Scheme debug shell
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:scheme script:_files -g "*.scm(-.)"' && ret=0
return ret
