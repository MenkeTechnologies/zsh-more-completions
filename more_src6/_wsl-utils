#compdef wslu wslsys wslgsu wslupath wslfetch wslview wsl-open
# _wsl-utils — wslutilities wslu (wslu/wslsys/wslfetch/wslview/wslupath/wsl-open utility scripts for WSL; subcommand-style flags vary per binary; common shared flags: -h help, -V version, -d debug; positional arguments are the in-WSL path or URL to act on)
# upstream: https://github.com/wslutilities/wslu
# Flags from wslu src/wsl* on tip.

_wsl-utils() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-d[debug]' \
        '*:path or URL:_files'
}

_wsl-utils "$@"
