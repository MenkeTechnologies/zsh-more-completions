#compdef tifftopnm
# Documentation: man tifftopnm (Netpbm)
# Source: convert a TIFF image to PNM (libtiff-based).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-alphaout=[alpha output file (- for stdout)]:file:_files' \
    '-headerdump[dump TIFF header info]' \
    '-verbose[verbose output]' \
    '-respectfillorder[respect TIFF FillOrder tag]' \
    '-byrow[stream row by row]' \
    '-orientraw[do not adjust for Orientation tag]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:tiff file:_files -g "*.(tif|tiff)"' \
    && ret=0

return ret
