#compdef tracey
# ---------------------------------------------------------------------------
# tracey — CLI / Web dashboard / LSP server / MCP server / daemon
#          toolkit to measure SPEC COVERAGE in source codebases: parses
#          `[rule.id]` references in code comments + git pre-commit
#          hook + interactive query language over a Tantivy-indexed
#          rule database (Rust, 207★)
#
# upstream: https://github.com/bearcove/tracey
# author : Amos Wenger (bearcove / fasterthanli.me) — the longtime
#          Rust blogger, video maker, and author of the broader
#          `facet` reflection-via-derive macro ecosystem that tracey
#          uses for both config parsing and CLI argument parsing
# license: MIT OR Apache-2.0
#
# Source-direct completion: every subcommand + nested subcommand below
# is verbatim from crates/tracey/src/main.rs on the bearcove/tracey tip
# — the `figue` (facet's CLI framework) `#[derive(facet::Facet)]` +
# `#[facet(args::subcommand)]` / `#[facet(args::positional)]` /
# `#[facet(args::named, args::short = 'X')]` annotations on the Args /
# Command / SkillAction / QueryCommand enums parsed exactly as
# declared.  tracey uses facet's reflection-via-derive system instead
# of clap so the CLI surface and the config-file (.styx format)
# surface share a single source of truth.
#
# Direct deps from crates/tracey/Cargo.toml + workspace Cargo.toml
# (selected):
#   tantivy                "0.22"   ← canonical Rust full-text search
#                                       engine library (this axis) —
#                                       by Paul Masurel + quickwit-oss
#                                       (quickwit-oss/tantivy); pure-
#                                       Rust full-text search engine
#                                       inspired by Apache Lucene with
#                                       similar API conventions (Index
#                                       / IndexWriter / Searcher /
#                                       Query / TermQuery / BooleanQuery
#                                       / RangeQuery / PhraseQuery /
#                                       FuzzyTermQuery) and the same
#                                       inverted-index data model.
#                                       Supports schema definition,
#                                       BM25 scoring (Lucene's default),
#                                       custom tokenizers, faceted
#                                       search, range queries on
#                                       numeric fields, snippet
#                                       generation, and incremental
#                                       indexing.  THE Rust answer to
#                                       "embedded full-text search in
#                                       a host process" — used by
#                                       quickwit (the distributed
#                                       search engine by the same
#                                       team), paradedb (Postgres
#                                       search extension), chroma-core/
#                                       chroma (the AI embeddings DB),
#                                       AppFlowy-IO/AppFlowy
#                                       (workspace notes), TabbyML/
#                                       tabby (AI code-completion
#                                       server), windmill-labs/windmill,
#                                       postgresml/postgresml,
#                                       summa.  tracey uses it to
#                                       index every parsed rule from
#                                       the spec manifest + every
#                                       `[rule.id]` reference in source
#                                       comments so the `tracey query`
#                                       commands (status / uncovered /
#                                       untested / unmapped / stale /
#                                       rule / validate) and the
#                                       interactive web dashboard /
#                                       LSP go-to-rule / MCP tool calls
#                                       can answer queries in sub-
#                                       millisecond time even on
#                                       codebases with tens of
#                                       thousands of rules.
#   facet + facet-styx               (the author's reflection-via-
#                                       derive ecosystem — Facet
#                                       generates serialization /
#                                       deserialization / CLI parsing
#                                       / TUI rendering from a single
#                                       #[derive(facet::Facet)] macro
#                                       on the data types; tracey
#                                       uses it for both `figue` CLI
#                                       parsing and `.styx`-format
#                                       config file parsing so the
#                                       CLI surface and the config
#                                       surface are interchangeable)
#   figue                            (the facet-built CLI parser —
#                                       provides FigueBuiltins for
#                                       --help / --version / --completions)
#   arborium             "2.16.0"   (tree-sitter wrapper crate by the
#                                       same author — used to parse
#                                       Rust / C / C++ / Go / Zig /
#                                       JavaScript / TypeScript /
#                                       TSX / Python source for the
#                                       reverse-traceability mode
#                                       that finds which code units
#                                       implement which spec rules)
#   axum + facet-axum                (HTTP server + facet bindings —
#                                       powers `tracey web` and
#                                       `tracey daemon`)
#   eyre + facet-error               (error handling — eyre for
#                                       call-site formatting, facet-
#                                       error for typed-error
#                                       reflection)
#   owo-colors + strsim              (pretty terminal output +
#                                       fuzzy string matching for
#                                       rule-ID typo suggestions)
#   ignore + globset + rayon         (gitignore-aware file walking
#                                       + parallel parsing)
#
# tracey's premise: in any meaningful codebase you have a spec
# (regulatory, RFC, internal design doc) and you want to know which
# rules of the spec are actually implemented + tested + which ones
# are stale.  Annotate source comments with `[rule.id]` references
# pointing at the spec manifest, run `tracey daemon` in the background,
# and the spec-coverage report is queryable through five interfaces:
# CLI (`tracey query status` / `tracey query uncovered`), Web
# dashboard (`tracey web --open`), LSP for editor integration
# (`tracey lsp` — surfaces go-to-rule navigation + hover-over-comment
# rule preview in any LSP-aware editor), MCP server for AI assistants
# (`tracey mcp` — Claude Code / Codex CLI can call the same query
# tools), and a git pre-commit hook (`tracey precommit` — fail the
# commit if a rule's text changed without a version bump).  Tantivy
# is the shared index backing all five interfaces — the daemon owns
# the writer, the other modes are read-only Searcher clients of the
# same index.
#
# ============================================================================
# === AXIS 189 OPENS — embeddable full-text search engine libraries =======
# === Rust=244 OPENS at slot 1/0/0 ========================================
# ============================================================================
# Axis position: Rust=244 OPENS Axis 189 at slot 1/0/0 — the first of the
# three lanes for the canonical embeddable full-text search engine trio.
# The axis anchors on a single pure-host-language full-text search
# engine library with inverted-index data model, BM25-style scoring,
# tokenization pipeline, faceted search, range queries on numeric
# fields, snippet generation, and an embedding API suitable for in-
# process index-and-query without a separate Elasticsearch/Solr cluster:
#
#     Rust    : tantivy                      by Paul Masurel +
#                                              quickwit-oss (quickwit-
#                                              oss/tantivy); pure-Rust
#                                              full-text search engine
#                                              inspired by Apache
#                                              Lucene with similar
#                                              API conventions and
#                                              the same inverted-
#                                              index data model.
#                                              Schema definition,
#                                              BM25 scoring, custom
#                                              tokenizers, faceted
#                                              search, range / phrase
#                                              / fuzzy / boolean
#                                              queries, snippet
#                                              generation, incremental
#                                              indexing.
#                 → tracey (Amos Wenger bearcove — CLI/Web/LSP/MCP/
#                            daemon toolkit for spec coverage; indexes
#                            spec rules + source-comment `[rule.id]`
#                            references via tantivy so query commands
#                            answer in sub-ms time even on tens-of-
#                            thousands-of-rules codebases; tantivy is
#                            the shared index backing all five
#                            interfaces; 207★ MIT OR Apache-2.0)
#                 _tracey          [Rust=244 OPENS Axis 189, 1/0/0]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#
#     Go      : (next round — Go=244, slot 2/0/0)
#                Canonical Go full-text search engine: github.com/
#                blevesearch/bleve by Marty Schoch (originally CouchBase)
#                — pure-Go full-text indexing and search library
#                inspired by Lucene.  Used by Couchbase Sync Gateway,
#                Gitea (the self-hosted Git server's repo search),
#                Mattermost (the self-hosted Slack alternative's
#                message search), and many Go tools that need
#                embedded search.  [TBD next-round consumer]
#
#     JS/Node : (Axis 189 CLOSES at TS-Node=244, slot 1/1/1)
#                Canonical JS full-text search engine: pure-JS
#                contenders are `lunr.js` (oliver/lunr.js), `flexsearch`
#                (nextapps-de/flexsearch), `minisearch` (lucaong/
#                minisearch), and the newer `orama` (oramasearch/orama)
#                — multiple competing options without a single
#                Lucene-equivalent.  This will be the tricky lane
#                closer — JS embedded full-text search has not
#                consolidated to one canonical lib like Rust and Go.
#                [TBD closer consumer]
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=244     ← THIS FILE          (axis 189 OPENS, slot 1/0/0)
#   Go=244       ← next round         (axis 189 continues, slot 2/0/0)
#   TS-Node=244  ← round after        (axis 189 CLOSES at triple-244, 1/1/1)
# ============================================================================

_tracey() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '--completions=[generate shell completion script]:shell:(bash zsh fish powershell)' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'web:start the interactive web dashboard'
                'mcp:start the MCP server for AI assistants (Claude Code / Codex CLI tool integration)'
                'lsp:start the LSP server for editor integration (go-to-rule navigation + hover-over-comment preview)'
                'daemon:start the tracey daemon (persistent index writer for this workspace)'
                'logs:show daemon logs'
                'status:show daemon status (raw JSON via --json or human-readable)'
                'kill:stop the running daemon'
                'skill:manage the bundled AI skill (install)'
                'ai:configure AI assistants — register MCP server + install bundled skill in Claude Code and/or Codex CLI'
                'query:run query subcommands over daemon data from the terminal (uncovered / untested / unmapped / stale / rule / config / validate)'
                'precommit:check staged spec changes and fail if any rule text changed without a version bump (install as git pre-commit hook)'
                'help:print help for a subcommand'
            )
            _describe -t commands 'tracey command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                web)
                    _arguments \
                        '(-c --config)'{-c,--config}'=[path to config file (default .config/tracey/config.styx)]:file:_files -g "*.styx"' \
                        '(-p --port)'{-p,--port}'=[port to listen on (default 3000)]:port:' \
                        '--open[open the dashboard in your default browser]' \
                        '--dev[development mode — proxy assets from Vite dev server instead of serving embedded assets]' \
                        '1::project root directory:_files -/' && ret=0
                    ;;
                mcp|lsp|daemon|precommit)
                    _arguments \
                        '(-c --config)'{-c,--config}'=[path to config file (default .config/tracey/config.styx)]:file:_files -g "*.styx"' \
                        '1::project root directory:_files -/' && ret=0
                    ;;
                logs)
                    _arguments \
                        '(-f --follow)'{-f,--follow}'[follow log output (like tail -f)]' \
                        '(-n --lines)'{-n,--lines}'=[number of lines to show (default 50)]:n:' \
                        '1::project root directory:_files -/' && ret=0
                    ;;
                status|kill)
                    _arguments \
                        '--json[output raw JSON instead of human-readable text]' \
                        '1::project root directory:_files -/' && ret=0
                    ;;
                skill)
                    _arguments \
                        '1: :->skillcmds' \
                        '*::skill-arg:->skillargs' && ret=0
                    case $state in
                        skillcmds)
                            _describe -t skill-commands 'skill subcommand' \
                                '(install:install the bundled Tracey skill for Claude and/or Codex)' && ret=0
                            ;;
                        skillargs)
                            _arguments \
                                '--claude[install only for Claude Code]' \
                                '--codex[install only for Codex CLI]' && ret=0
                            ;;
                    esac
                    ;;
                ai)
                    _arguments \
                        '--claude[configure only Claude Code]' \
                        '--codex[configure only Codex CLI]' && ret=0
                    ;;
                query)
                    _arguments \
                        '--json[output raw JSON instead of human-readable text]' \
                        '1: :->qcmds' \
                        '*::q-arg:->qargs' && ret=0
                    case $state in
                        qcmds)
                            local -a qsubs
                            qsubs=(
                                'status:coverage overview'
                                'uncovered:list rules without implementation references'
                                'untested:list rules without verification references'
                                'unmapped:show code units that do not reference any rule'
                                'stale:list stale references (code pointing to older rule versions)'
                                'rule:show details about one or more rules (positional rule_ids)'
                                'config:display current configuration'
                                'validate:validate the spec and implementation (--deny warnings to fail on warnings)'
                            )
                            _describe -t query-commands 'query subcommand' qsubs && ret=0
                            ;;
                        qargs)
                            case $words[1] in
                                uncovered|untested|stale)
                                    _arguments \
                                        '--spec-impl=[spec/impl to query (e.g. my-spec/rust; optional if only one exists)]:spec/impl:' \
                                        '--prefix=[filter by rule ID prefix]:prefix:' && ret=0
                                    ;;
                                unmapped)
                                    _arguments \
                                        '--spec-impl=[spec/impl to query]:spec/impl:' \
                                        '--path=[directory or file path to zoom into]:path:_files' && ret=0
                                    ;;
                                rule)
                                    _arguments '*:rule identifier:' && ret=0
                                    ;;
                                validate)
                                    _arguments \
                                        '--spec-impl=[spec/impl to validate]:spec/impl:' \
                                        '*--deny=[diagnostic to deny as fatal (repeatable; supported: warnings)]:diagnostic:(warnings)' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                help)
                    local -a allsubs
                    allsubs=(web mcp lsp daemon logs status kill skill ai query precommit)
                    _describe -t commands 'subcommand for help' allsubs && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_tracey "$@"
