#compdef tup
# Documentation: https://gittup.org/tup/manual.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:Initialize a tup database'
      'upd:Update build outputs (legacy alias for plain tup)'
      'monitor:Run the file monitor (Linux only)'
      'stop:Terminate a running monitor'
      'scan:Update database to reflect filesystem'
      'refactor:Parse Tupfiles without executing commands'
      'graph:Output graphviz dot dependency graph'
      'todo:Print next build steps'
      'variant:Create variant directories with config files'
      'dbconfig:Display current database configuration'
      'options:Show all current tup options and origins'
      'varsed:Substitute @VARIABLE@ references in files'
      'generate:Create shell script for building without tup'
      'compiledb:Generate compile_commands.json'
      'commandline:Print compilation information in JSON'
    )
    _describe -t commands 'tup command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      upd|scan)
        _arguments -s -S \
          '--no-environ-check[skip environment variable check]' \
          '--debug-logging[enable debug logging]' \
          '--verbose[verbose output]' \
          '--quiet[quiet output]' \
          '--keep-going[continue after errors]' \
          '--no-sync[disable filesystem sync]' && ret=0
        ;;
      monitor)
        _arguments -s -S \
          '-d[debug]' \
          {-f,--foreground}'[run in foreground]' \
          {-b,--background}'[run in background]' \
          {-a,--autoupdate}'[automatically update on changes]' \
          {-n,--no-autoupdate}'[disable autoupdate]' \
          '--autoparse[enable autoparse]' \
          '--no-autoparse[disable autoparse]' && ret=0
        ;;
      todo)
        _arguments -s -S \
          '--no-scan[skip filesystem scan]' \
          '--verbose[verbose output]' && ret=0
        ;;
      generate)
        _arguments -s -S \
          '--config=[config file]:file:_files' \
          '--builddir=[build directory]:dir:_files -/' \
          '*:script:_files' && ret=0
        ;;
      graph)
        _arguments -s -S \
          '--dirs[show directories]' \
          '--ghosts[show ghost nodes]' \
          '--env[show environment variables]' \
          '--combine[combine identical nodes]' \
          '--stickies[show sticky links]' && ret=0
        ;;
      init)
        _arguments -s -S \
          ':directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
