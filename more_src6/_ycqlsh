#compdef ycqlsh ysqlsh
# Documentation: https://docs.yugabyte.com/preview/api/ycqlsh/  https://docs.yugabyte.com/preview/api/ysqlsh/
# Reference accessed: 2026-05-21
# Verified: upstream Yugabyte ycqlsh and ysqlsh references at the URLs above.

local curcontext="$curcontext" state line ret=1

case $service in
  (ycqlsh)
    _arguments -C \
      '(- *)--help[show help]' \
      '(-C --color)'{-C,--color}'[force color output]' \
      '--no-color[disable color output]' \
      '--browser=[browser for ycqlsh help]:browser:' \
      '--ssl[use SSL]' \
      '(-u --user)'{-u+,--user=}'[authentication user]:user:_users' \
      '(-p --password)'{-p+,--password=}'[authentication password]:password:' \
      '(-k --keyspace)'{-k+,--keyspace=}'[keyspace to authenticate to]:keyspace:' \
      '(-f --file)'{-f+,--file=}'[execute commands from file then exit]:file:_files -g "*.cql"' \
      '--debug[print debugging information]' \
      '--encoding=[output encoding (default UTF-8)]:enc:(utf-8 ascii)' \
      '--cqlshrc=[location of cqlshrc file]:file:_files' \
      '(-e --execute)'{-e+,--execute=}'[execute statement then exit]:cmd:' \
      '--connect-timeout=[connect timeout seconds (default 2)]:s:' \
      '--request-timeout=[request timeout seconds (default 10)]:s:' \
      '(-t --tty)'{-t,--tty}'[force tty mode]' \
      '(-r --refresh_on_describe)'{-r,--refresh_on_describe}'[force schema refresh on DESCRIBE]' \
      '*:host port:' && ret=0 ;;
  (ysqlsh)
    _arguments -C \
      '(- *)'{-?,--help}'[show help]' \
      '(-V --version)'{-V,--version}'[show version]' \
      '(-h --host)'{-h+,--host=}'[host]:host:_hosts' \
      '(-p --port)'{-p+,--port=}'[port]:port:' \
      '(-U --username)'{-U+,--username=}'[username]:user:_users' \
      '(-d --dbname)'{-d+,--dbname=}'[database]:db:' \
      '(-W --password)'{-W,--password}'[force password prompt]' \
      '(-w --no-password)'{-w,--no-password}'[never prompt for password]' \
      '(-c --command)'{-c+,--command=}'[execute command]:cmd:' \
      '(-f --file)'{-f+,--file=}'[execute file]:file:_files -g "*.sql"' \
      '(-l --list)'{-l,--list}'[list databases]' \
      '*'{-v+,--set=,--variable=}'[set variable]:var:' \
      '(-X --no-psqlrc)'{-X,--no-psqlrc}'[no psqlrc]' \
      '(-1 --single-transaction)'{-1,--single-transaction}'[wrap in single transaction]' \
      '(-a --echo-all)'{-a,--echo-all}'[echo all nonempty input lines]' \
      '(-b --echo-errors)'{-b,--echo-errors}'[echo failed SQL statements]' \
      '(-e --echo-queries)'{-e,--echo-queries}'[echo queries]' \
      '(-E --echo-hidden)'{-E,--echo-hidden}'[echo hidden meta-command queries]' \
      '(-A --no-align)'{-A,--no-align}'[unaligned output]' \
      '(-F --field-separator)'{-F+,--field-separator=}'[field separator]:sep:' \
      '(-H --html)'{-H,--html}'[HTML output]' \
      '(-L --log-file)'{-L+,--log-file=}'[log file]:file:_files' \
      '(-n --no-readline)'{-n,--no-readline}'[disable readline]' \
      '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
      '(-P --pset)'{-P+,--pset=}'[printing option]:opt:' \
      '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
      '(-R --record-separator)'{-R+,--record-separator=}'[record separator]:sep:' \
      '(-s --single-step)'{-s,--single-step}'[single step]' \
      '(-S --single-line)'{-S,--single-line}'[single line]' \
      '(-t --tuples-only)'{-t,--tuples-only}'[tuples only]' \
      '(-T --table-attr)'{-T+,--table-attr=}'[HTML table attrs]:attr:' \
      '(-x --expanded)'{-x,--expanded}'[expanded output]' \
      '(-z --field-separator-zero)'{-z,--field-separator-zero}'[zero-byte field separator]' \
      '(-0 --record-separator-zero)'{-0,--record-separator-zero}'[zero-byte record separator]' \
      '*: :' && ret=0 ;;
esac

return ret
