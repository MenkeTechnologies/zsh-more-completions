#compdef zoekt-webserver
# _zoekt-webserver — Sourcegraph Zoekt search frontend (HTTP server)
# upstream: https://github.com/sourcegraph/zoekt
# Flags from cmd/zoekt-webserver/main.go on tip.

_zoekt-webserver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-log_dir=[log to this directory rather than stderr]:dir:_files -/' \
        '-log_refresh=[log rotation interval]:dur:' \
        '-listen=[bind host\:port]:host\:port:' \
        '-index=[index directory]:dir:_files -/' \
        '-html=[enable HTML interface]:bool:(true false)' \
        '-rpc=[enable Go net/rpc]:bool:(true false)' \
        '-indexserver_proxy=[proxy /indexserver/ to indexserver.sock]:bool:(true false)' \
        '-print=[enable local result URLs]:bool:(true false)' \
        '-pprof=[enable pprof endpoints]:bool:(true false)' \
        '-ssl_cert=[TLS cert PEM file]:file:_files' \
        '-ssl_key=[TLS key PEM file]:file:_files' \
        '-host_customization=[per-vhost customization rules]:rules:' \
        '-template_dir=[directory with custom .html.tpl templates]:dir:_files -/' \
        '-dump_templates=[dump templates to template_dir and exit]:bool:(true false)' \
        '-cors_origin=[CORS allowed origin]:origin:'
}

_zoekt-webserver "$@"
