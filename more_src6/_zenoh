#compdef zenoh z_pub z_sub z_get z_put z_query
# _zenoh — Eclipse ZettaScale Zenoh zero-overhead pub/sub/query for IoT/edge (eclipse-zenoh team, Rust); clap-derive
# upstream: https://github.com/eclipse-zenoh/zenoh

_zenoh() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g "*.json5 *.json"' \
        '-c+[config file]:file:_files -g "*.json5 *.json"' \
        '--mode=+[mode]:m:(peer client router)' \
        '-m+[mode]:m:(peer client router)' \
        '--connect=+[endpoint]:endpoint:' \
        '-e+[endpoint]:endpoint:' \
        '--listen=+[endpoint]:endpoint:' \
        '-l+[endpoint]:endpoint:' \
        '--no-multicast-scouting[disable mcast scouting]' \
        '--cfg=+[config option]:str:' \
        '--rest-http-port=+[REST port]:port:_ports' \
        '--adminspace-permissions=+[perms]:p:(none read write rw)' \
        '--plugin-search-dir=+[dir]:dir:_files -/' \
        '*--plugin=+[plugin name]:str:' \
        '--id=+[zenoh id]:str:' \
        '*:key:'
}

_zenoh "$@"
