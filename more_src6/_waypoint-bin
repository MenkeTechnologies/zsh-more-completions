#compdef waypoint
# _waypoint-bin — HashiCorp Waypoint application delivery CLI (HashiCorp, Go); build + deploy + release apps to any platform
# upstream: https://github.com/hashicorp/waypoint

_waypoint-bin() {
    local -a sub=(
        'artifact:artifact commands'
        'auth-method:auth method commands'
        'build:build new artifact'
        'config:config commands'
        'context:context commands'
        'deploy:deploy artifact'
        'deployment:deployment commands'
        'destroy:destroy app'
        'docs:open docs'
        'exec:exec command in deployment'
        'fmt:format waypoint.hcl'
        'hostname:hostname commands'
        'init:initialize project'
        'install:install Waypoint server'
        'job:job commands'
        'login:login'
        'logs:show logs'
        'logout:logout'
        'plugin:plugin commands'
        'project:project commands'
        'release:release commands'
        'runner:runner commands'
        'server:server commands'
        'snapshot:snapshot commands'
        'status:show status'
        'task:task commands'
        'token:token commands'
        'trigger:trigger commands'
        'ui:open UI'
        'uninstall:uninstall Waypoint server'
        'up:run init + up + deploy + release'
        'upgrade:upgrade Waypoint server'
        'user:user commands'
        'version:show version'
        'workspace:workspace commands'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '-version[show version]' \
        '-no-color[disable color]' \
        '-app+[app]:app:' \
        '-project+[project]:project:' \
        '-workspace+[workspace]:workspace:' \
        '-W+[workspace]:workspace:' \
        '-plain[plain output]' \
        '-quiet[quiet]' \
        '-V[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'waypoint subcommand' sub ;;
    esac
}

_waypoint-bin "$@"
