#compdef trz
# Documentation: https://github.com/trzsz/trzsz-go/blob/main/trzsz/comm.go
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# trzsz/trzsz-go receive binary (`trzsz/comm.go` baseArgs + `trzsz/trz.go`)

local ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-q[quiet: hide progress bar]' \
  '-y[overwrite existing file(s) without confirmation]' \
  '-b[binary transfer mode]' \
  '-e[escape all known control characters]' \
  '-d[transfer directories and files]' \
  '-r[same as -d (recursive / directory transfer)]' \
  '-f[fork: transfer in background (implies -q)]' \
  '-B+[max buffer chunk size (1K–1G, e.g. 10M)]:size:' \
  '-t+[timeout seconds per buffer chunk; 0 = never]:timeout:' \
  '-c+[compress: yes/no/auto]:compress:(yes no auto)' \
  '*:directory to save into:_files -/' && ret=0
return ret
