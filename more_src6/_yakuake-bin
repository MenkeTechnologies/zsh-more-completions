#compdef yakuake
# _yakuake-bin — Yakuake KDE drop-down terminal (Eike Hein, Qt/KDE); Quake-style drop-down terminal
# upstream: https://invent.kde.org/utilities/yakuake

_yakuake-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--display+[X display]:display:' \
        '--style+[Qt style]:style:(default fusion windows macintosh)' \
        '--platform+[Qt platform]:platform:'
}

_yakuake-bin "$@"
