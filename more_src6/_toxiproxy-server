#compdef toxiproxy-server
# Documentation: https://github.com/Shopify/toxiproxy
# Reference accessed: 2026-05-29

_arguments -s \
  '(- *)-version[show version]' \
  '-host[host for the API server]:host: ' \
  '-port[port for the API server]:port: ' \
  '-config[config file]:config file:_files' \
  '-seed[seed file with initial proxies]:seed file:_files' \
  '-proxy-metrics[enable proxy metrics]' \
  '-runtime-metrics[enable Go runtime metrics]'
