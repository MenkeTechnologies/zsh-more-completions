#compdef valhalla_export_edges
# Documentation: https://github.com/valhalla/valhalla
# Source: valhalla/valhalla src/valhalla_export_edges.cc — export tiled-graph edges as records.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '(-c --config)'{-c+,--config=}'[path to JSON config file]:file:_files -g "*.json(-.)"' \
    '(-i --inline-config)'{-i+,--inline-config=}'[inline JSON config]:json:_default' \
    '(-x --column)'{-x+,--column=}'[column separator (default \\0)]:sep:_default' \
    '(-r --row)'{-r+,--row=}'[row separator (default \\n)]:sep:_default' \
    '(-f --ferries)'{-f,--ferries}'[also export ferries]' \
    '(-u --unnamed)'{-u,--unnamed}'[also export unnamed edges]' \
    && ret=0

return ret
