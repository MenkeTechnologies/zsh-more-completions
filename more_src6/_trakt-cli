#compdef trakt-cli
# Documentation: https://github.com/angristan/trakt-cli (cmd/{root,auth,history,search}.go cobra)
# Reference accessed: 2026-05-29
# CLI for trakt.tv watch/history tracking.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'auth:authenticate with trakt.tv via OAuth device-code flow'
  'history:show watch history for the authenticated user'
  'search:search trakt.tv catalog'
  'completion:generate shell completions'
  'help:show help for a subcommand'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--config=[config file (default ~/.trakt.yaml)]:file:_files -g "*.(yaml|yml)"' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'trakt-cli subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      auth)
        _arguments \
          '--client-id=[trakt application client ID]:id:' \
          '--client-secret=[trakt application client secret]:secret:' && ret=0
        ;;
      history)
        _arguments \
          '--type=[filter by item type]:type:(movies shows seasons episodes)' \
          '--limit=[max number of items]:n:' \
          '--start-at=[start date]:date:' \
          '--end-at=[end date]:date:' && ret=0
        ;;
      search)
        _arguments \
          '--type=[filter by item type]:type:(movie show episode person list)' \
          '--query=[search query string]:query:' \
          '*:query:' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
