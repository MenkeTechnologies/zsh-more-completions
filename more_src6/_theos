#compdef nic theos
# _theos — Theos jailbreak iOS tweak SDK (Perl/Make); nic.pl creates new tweak projects via templates
# upstream: https://github.com/theos/theos

_theos() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--list[list available templates]' \
        '--templates[show NIC templates]' \
        '--name+[project name]:name:' \
        '--bundle-id+[bundle id]:id:' \
        '--package-name+[package name]:name:' \
        '--author+[author name]:name:' \
        '--mobile-substrate-bundle-filter+[bundle filter]:filter:' \
        '*:template:'
}

_theos "$@"
