#compdef tere
# Documentation: https://github.com/mgunyho/tere
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for tere (terminal file explorer)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Print help]' \
  '(-V --version)'{-V,--version}'[Print version]' \
  '(-f --filter-search -F --no-filter-search)'{-f,--filter-search}'[start in filter-search mode]' \
  '(-f --filter-search -F --no-filter-search)'{-F,--no-filter-search}'[do not start in filter-search mode]' \
  '--files=[file handling mode]:mode:(ignore hide match)' \
  '(-S --smart-case -i --ignore-case -s --case-sensitive)'{-S,--smart-case}'[smart case matching]' \
  '(-S --smart-case -i --ignore-case -s --case-sensitive)'{-i,--ignore-case}'[case-insensitive matching]' \
  '(-S --smart-case -i --ignore-case -s --case-sensitive)'{-s,--case-sensitive}'[case-sensitive matching]' \
  '(-g --gap-search -G --gap-search-anywhere -n --normal-search -N --normal-search-anywhere)'{-g,--gap-search}'[gap search from start]' \
  '(-g --gap-search -G --gap-search-anywhere -n --normal-search -N --normal-search-anywhere)'{-G,--gap-search-anywhere}'[gap search anywhere]' \
  '(-g --gap-search -G --gap-search-anywhere -n --normal-search -N --normal-search-anywhere)'{-n,--normal-search}'[normal search from start]' \
  '(-g --gap-search -G --gap-search-anywhere -n --normal-search -N --normal-search-anywhere)'{-N,--normal-search-anywhere}'[normal search anywhere]' \
  '--sort=[sort files]:sort:(name created modified)' \
  '--autocd-timeout=[autocd timeout ms or off]:timeout:' \
  '--history-file=[history file path]:file:_files' \
  '--mouse=[mouse support]:mode:(on off)' \
  '(-m --map)'{-m,--map=}'[key mapping key-combination:action]:mapping:' \
  ':starting directory:_files -/' && ret=0

return ret
