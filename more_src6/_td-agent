#compdef td-agent fluentd
# Documentation: https://docs.fluentd.org/deployment/command-line-option
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-s --setup)'{-s+,--setup=}'[install sample config]:directory:_directories' \
  '(-c --config)'{-c+,--config=}'[configuration file]:config file:_files' \
  '--dry-run[validate fluentd setup]' \
  '--show-plugin-config[display plugin configuration (deprecated)]' \
  '(-p --plugin)'{-p+,--plugin=}'[add plugin directory]:plugin directory:_directories' \
  '-I+[add library path]:library path:_directories' \
  '-r+[load library]:library:' \
  '(-d --daemon)'{-d+,--daemon=}'[daemonize and write PID]:PID file:_files' \
  '--under-supervisor[run under supervisor (internal)]' \
  '--no-supervisor[run without supervisor]' \
  '--workers=[number of workers]:count:' \
  '--user=[change user]:user:_users' \
  '--group=[change group]:group:_groups' \
  '--umask=[change umask]:umask:' \
  '(-o --log)'{-o+,--log=}'[log file path]:log file:_files' \
  '--log-rotate-age=[log rotation generations]:age:' \
  '--log-rotate-size=[log rotation byte size]:size:' \
  '--log-event-verbose[enable verbose startup/shutdown logging]' \
  '(-i --inline-config)'{-i+,--inline-config=}'[append inline configuration]:config:' \
  '--emit-error-log-interval=[suppress error log interval]:n:' \
  '--suppress-repeated-stacktrace[suppress duplicate stacktraces]' \
  '--without-source[run without input plugins]' \
  '--with-source-only[run with input plugins only]' \
  '--use-v1-config[use v1 config format]' \
  '--use-v0-config[use v0 config format]' \
  '--strict-config-value[parse config values strictly]' \
  '--enable-input-metrics[enable input metrics (deprecated)]' \
  '--disable-input-metrics[disable input metrics]' \
  '--enable-size-metrics[enable record size metrics]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[decrease verbosity]' \
  '--suppress-config-dump[hide config in logs]' \
  '(-g --gemfile)'{-g+,--gemfile=}'[Gemfile path]:Gemfile:_files' \
  '-G+[set Gemfile install path]:path:_directories' \
  '--conf-encoding=[set config file encoding]:encoding:' \
  '--disable-shared-socket[do not use shared socket]' && ret=0

return ret
