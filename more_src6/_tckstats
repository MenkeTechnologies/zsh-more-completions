#compdef tckstats
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/tckstats.html
# Source: MRtrix3/mrtrix3 cmd/tckstats.cpp — calculate per-streamline length statistics (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '*-output+[print statistic field]:field:(mean median std min max count)' \
    '-histogram+[output a histogram of streamline lengths]:path:_files' \
    '-dump+[dump streamline lengths to text file]:path:_files' \
    '-ignorezero[suppress warning on zero-length streamlines]' \
    '-tck_weights_in+[per-streamline weights for input]:file:_files' \
    '1:tracks (input):_files -g "*.{tck,trk}"' \
    && ret=0

return ret
