#compdef zbarimg zbarcam
# _zbar-bin — ZBar bar-code reader (C); zbarimg decodes images, zbarcam reads from camera; supports EAN/Code128/QR/Data Matrix
# upstream: https://github.com/mchehab/zbar

_zbar-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-d --display)'{-d,--display}'[display intermediate images]' \
        '(-D --nodisplay)'{-D,--nodisplay}'[do not display]' \
        '--xml[XML output]' \
        '--noxml[disable XML]' \
        '--raw[raw symbol data only]' \
        '(-S --set)'{-S,--set}'+[set config option]:key=val:' \
        '(-1 --oneshot)'{-1,--oneshot}'[exit after first symbol]' \
        '*:image:_files'
}

_zbar-bin "$@"
