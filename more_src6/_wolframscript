#compdef wolframscript
# _wolframscript — Wolfram Research wolframscript command-line interface for the Wolfram Language and Mathematica kernel (wolfram team, C++); custom argparse
# upstream: https://www.wolfram.com/wolframscript/

_wolframscript() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '--version[show version]' \
        '-f+[file to execute]:file:_files -g "*.wls *.wl *.m"' \
        '-file=+[file to execute]:file:_files -g "*.wls *.wl *.m"' \
        '-c+[code to execute]:str:' \
        '-code=+[code to execute]:str:' \
        '-e+[expression]:str:' \
        '-expression=+[expression]:str:' \
        '-i+[interactive prompt]' \
        '-interactive[interactive prompt]' \
        '-a+[arguments csv]:str:' \
        '-args=+[arguments csv]:str:' \
        '-pi+[parsing mode]:m:(InputForm StandardForm BoxForm OutputForm WolframLanguage)' \
        '-print=+[mode]:m:(InputForm StandardForm OutputForm None all)' \
        '-format=+[output format]:f:(InputForm StandardForm OutputForm UnicodeBoxForm)' \
        '-encoding=+[encoding]:e:(UTF8 ASCII Latin1)' \
        '-debug[debug mode]' \
        '-rawterm[raw terminal mode]' \
        '-noinit[no init file]' \
        '-noprompt[no prompts]' \
        '-cloud=+[cloud env]:c:(Public Private)' \
        '-cloudbase=+[base url]:url:_urls' \
        '-authenticate=+[credentials]:str:' \
        '-username=+[user]:user:_users' \
        '-password=+[password]:str:' \
        '-cloudconnect[cloud connect]' \
        '-deletecloudobject=+[obj]:str:' \
        '-local[run locally]' \
        '-localkernel=+[mode]:m:(Local LocalKernel ExternalKernel)' \
        '-kernel=+[kernel path]:file:_files' \
        '-noteboomode=+[mode]:str:' \
        '-cloudbasemode=+[mode]:str:' \
        '-script[script mode]' \
        '-sh[shell mode]' \
        '-eval=+[expression]:str:' \
        '-evaluate=+[expression]:str:' \
        '-charset=+[charset]:str:' \
        '-load=+[file]:file:_files' \
        '-linewise[linewise output]' \
        '-recover[recover from error]' \
        '-disablewindowtitle[disable window title]' \
        '-progress[show progress]' \
        '-installpath=+[install path]:dir:_files -/' \
        '*:script file:_files -g "*.wls *.wl *.m"'
}

_wolframscript "$@"
