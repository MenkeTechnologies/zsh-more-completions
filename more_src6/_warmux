#compdef warmux
# Documentation: https://manpages.debian.org/bookworm/warmux/warmux.6.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Note: project effectively abandoned since 2017.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-p --play)'{-p,--play}'[start a local game]' \
  '(-i --internet)'{-i,--internet}'[connect via internet]' \
  '(-s --server)'{-s,--server}'[start as server]' \
  '(-c --client)'{-c+,--client=}'[connect to client server]:ip:' \
  '(-d --debug)'{-d+,--debug=}'[debug mask]:mask:' && ret=0
return ret
