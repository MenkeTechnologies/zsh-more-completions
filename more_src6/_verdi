#compdef verdi
# verdi — AiiDA command-line interface for computational science workflows

local -a subcommands=(
  'calcjob:inspect and manage calculation jobs'
  'code:setup and manage codes'
  'computer:setup and manage computers'
  'daemon:manage the AiiDA daemon'
  'data:inspect, create, and manage data nodes'
  'database:manage the database'
  'group:create, inspect, and manage groups'
  'node:inspect, create, and manage nodes'
  'plugin:manage plugins'
  'process:inspect and manage processes'
  'profile:manage AiiDA profiles'
  'quicksetup:quick setup of an AiiDA profile'
  'restapi:run the AiiDA REST API server'
  'run:execute a Python script with AiiDA'
  'setup:setup a new AiiDA profile'
  'shell:start an interactive IPython shell'
  'status:show AiiDA status'
  'storage:manage the file repository and database'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-p[AiiDA profile to use]:profile:' \
  '1:command:->command' \
  '*::args:->args'

case $state in
  (command)
    _describe -t commands 'verdi command' subcommands
    ;;
esac
