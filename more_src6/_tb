#compdef tb tinybird
# Documentation: https://www.tinybird.co/docs/forward/commands
# Reference accessed: 2026-05-21
# Verified: upstream Tinybird Forward CLI docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:scaffold a new Tinybird project'
  'build:build the current project'
  'deploy:deploy to production'
  'dev:run local development server'
  'pull:pull resources from cloud'
  'push:push resources to cloud'
  'datasource:manage data sources'
  'pipe:manage pipes'
  'endpoint:manage API endpoints'
  'sink:manage data sinks'
  'materialization:manage materialized views'
  'connection:manage external connections'
  'test:run tests'
  'fmt:format Tinybird files'
  'copy:copy pipes'
  'job:manage workspace jobs'
  'login:authenticate'
  'logout:logout'
  'workspace:manage workspaces'
  'branch:manage cloud branches'
  'token:manage tokens'
  'secret:manage secrets'
  'infra:manage infrastructure'
  'local:local Docker container ops'
  'info:show project information'
  'open:open a resource in browser'
  'deployment:manage deployments'
  'sql:execute SQL queries'
  'update:update the CLI'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--cloud[target cloud workspace]' \
  '--local[target local workspace]' \
  '--branch=[target a specific branch]:branch:' \
  '--token=[auth token]:token:' \
  '--host=[Tinybird API host]:url:' \
  '--config=[CLI config file]:file:_files' \
  '--no-color[disable colored output]' \
  '--debug[debug output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'tb command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (init)
        _arguments \
          '--folder=[target folder]:dir:_files -/' \
          '--ignore-sql-errors[ignore SQL errors]' \
          '--force[overwrite existing files]' && ret=0 ;;
      (build)
        _arguments \
          '--watch[watch for changes]' \
          '--check[run pre-deployment checks]' && ret=0 ;;
      (deploy)
        _arguments \
          '--check[run validation only]' \
          '--auto[auto-deploy]' \
          '--allow-destructive-operations[allow destructive ops]' \
          '--wait[wait for deployment]' \
          '--yes[skip confirmation]' && ret=0 ;;
      (dev)
        _arguments \
          '--port=[port to listen on]:port:' \
          '--watch[watch for changes]' && ret=0 ;;
      (datasource|pipe|endpoint|sink|materialization|connection|workspace|branch|token|secret|deployment|job)
        _arguments \
          '*::subcmd_arg:_files' && ret=0 ;;
      (test)
        _arguments \
          '*::test_file:_files -g "*.yaml"' \
          '--watch[watch for changes]' && ret=0 ;;
      (sql)
        _arguments \
          '(-q --query)'{-q+,--query=}'[SQL query]:query:' \
          '--format=[output format]:format:(JSON CSV TSV pretty)' && ret=0 ;;
      (local)
        local -a local_cmds=(
          'start:start local container'
          'stop:stop local container'
          'restart:restart local container'
          'clear:reset local workspace'
          'logs:show container logs'
          'status:show local status'
        )
        _describe -t lcmds 'local command' local_cmds && ret=0 ;;
      (infra)
        local -a infra_cmds=(
          'init:initialize infra'
          'deploy:deploy infra'
          'add:add resource'
          'remove:remove resource'
          'list:list resources'
        )
        _describe -t icmds 'infra command' infra_cmds && ret=0 ;;
    esac ;;
esac

return ret
