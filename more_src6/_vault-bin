#compdef vault
# _vault-bin — HashiCorp Vault secrets management CLI (HashiCorp, Go); manage secrets, encryption, identity
# upstream: https://github.com/hashicorp/vault

_vault-bin() {
    local -a sub=(
        'agent:run a Vault agent'
        'audit:audit device commands'
        'auth:auth method commands'
        'debug:capture debug output'
        'delete:delete secret/data'
        'events:event commands'
        'kv:key/value secrets engine'
        'lease:lease commands'
        'list:list secrets'
        'login:login to Vault'
        'monitor:stream logs'
        'namespace:namespace commands'
        'operator:operator commands'
        'patch:patch a secret'
        'path-help:print api path help'
        'plugin:plugin commands'
        'pki:pki secrets engine'
        'policy:policy commands'
        'print:print env info'
        'proxy:run vault proxy'
        'read:read data'
        'secrets:secrets engine commands'
        'server:run Vault server'
        'ssh:initiate SSH connection'
        'status:show status'
        'token:token commands'
        'transform:transform secrets engine'
        'transit:transit secrets engine'
        'unwrap:unwrap a wrapping token'
        'version:show version'
        'version-history:show version history'
        'write:write data'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '-version[show version]' \
        '-autocomplete-install[install autocomplete]' \
        '-autocomplete-uninstall[uninstall autocomplete]' \
        '-no-color[disable color]' \
        '-address+[Vault server address]:url:_urls' \
        '-namespace+[Vault namespace]:ns:' \
        '-ca-cert+[CA cert]:file:_files' \
        '-ca-path+[CA path]:dir:_files -/' \
        '-client-cert+[client cert]:file:_files' \
        '-client-key+[client key]:file:_files' \
        '-tls-server-name+[server name]:str:' \
        '-tls-skip-verify[skip TLS verify]' \
        '-format+[output format]:fmt:(table json yaml pretty raw)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vault subcommand' sub ;;
        args)
            case $words[1] in
                kv) _arguments '1:kv cmd:(delete destroy enable-versioning get list metadata patch put rollback undelete)' '*:path:' ;;
                auth) _arguments '1:auth cmd:(disable enable help list move tune)' '*:args:' ;;
                secrets) _arguments '1:secrets cmd:(disable enable list move tune)' '*:args:' ;;
                policy) _arguments '1:policy cmd:(delete fmt list read write)' '*:args:' ;;
                token) _arguments '1:token cmd:(capabilities create lookup renew revoke)' '*:args:' ;;
                operator) _arguments '1:operator cmd:(diagnose generate-root init key-status members migrate raft rekey rotate seal step-down unseal usage utilization)' '*:args:' ;;
            esac
            ;;
    esac
}

_vault-bin "$@"
