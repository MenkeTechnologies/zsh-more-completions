#compdef velero-plugin-for-gcp
# _velero-plugin-for-gcp — Velero GCP provider plugin (registers velero.io/gcp ObjectStore + VolumeSnapshotter)
# upstream: https://github.com/vmware-tanzu/velero-plugin-for-gcp
# Plugins are run as go-plugin gRPC servers by velero; framework Config exposes --log-level and --features. GCS bucket, KMS key, IAM service-account, project come from the BackupStorageLocation / VolumeSnapshotLocation spec.

_velero-plugin-for-gcp() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--log-level=[plugin log level]:level:(trace debug info warning error fatal panic)' \
        '--features=[csv of velero feature flags]:csv:'
}

_velero-plugin-for-gcp "$@"
