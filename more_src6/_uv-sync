#compdef uv-sync
# _uv-sync — uv project sync (astral-sh/uv)
# upstream: https://github.com/astral-sh/uv

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--frozen[use existing lockfile]' \
  '--locked[assert lockfile is up-to-date]' \
  '--python=[Python version]:version:' \
  '--extra=[extra to include]:extra:' \
  '--all-extras[include all extras]' \
  '--no-dev[exclude dev dependencies]' \
  '--no-install-project[do not install the project itself]' \
  '--no-install-workspace[do not install workspace members]' \
  '--inexact[do not remove extra packages]' \
  '--index-url=[package index URL]:url:' \
  '--extra-index-url=[extra index URL]:url:' \
  '--quiet[quiet output]' \
  '--verbose[verbose output]'
