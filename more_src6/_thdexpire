#compdef thdexpire
# Documentation: man thdexpire(8)
# Source: InterNetNews/inn contrib/thdexpire.in — dynamic expire daemon for timehash/timecaf (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-r[make a report only, do not run as daemon]' \
    '-t+[check interval in minutes]:mins:_default' \
    '-f+[required free space in kilobytes]:kb:_default' \
    '-i+[required free inodes]:N:_default' \
    '-m+[minimum normal-class hold time in days]:days:_default' \
    '-x+[absolute minimum hold time in seconds]:secs:_default' \
    '-N[no-op: do not delete articles]' \
    '-v+[verbosity level]:level:_default' \
    '-M[install man page]' \
    && ret=0

return ret
