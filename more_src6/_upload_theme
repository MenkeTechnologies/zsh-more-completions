#compdef upload_theme
# Documentation: https://github.com/gradio-app/gradio
# Reference accessed: 2026-05-23
# Verified: upload_theme --help (gradio PyPI console script).

# Zsh completion for upload_theme - upload Gradio theme demo to Hugging Face Space

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--org_name[HF org name]:org:' \
  '--version[semver theme version]:version:' \
  '--token[Hugging Face token]:token:' \
  '--theme-name[theme name]:name:' \
  '--description[theme description]:description:' \
  '1:theme json file:_files -g "*.json"' \
  '2:HF repo name:repo:' && ret=0

return ret
