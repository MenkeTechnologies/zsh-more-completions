#compdef tup-cli
# _tup-cli — Mike Shal tup file-based build system CLI alias (Mike Shal / gittup, C); custom argparse
# upstream: https://github.com/gittup/tup

_tup-cli() {
    local -a sub=(
        'compiledb:emit JSON compile commands'
        'config:show/edit tup config'
        'dag:print build DAG'
        'database:database commands'
        'fuse:start FUSE monitor'
        'generate:generate scripts'
        'graph:print build graph'
        'help:show help'
        'init:init tup project'
        'monitor:run filesystem monitor'
        'options:show options'
        'parse:parse Tupfiles only'
        'read:show tracked deps for command'
        'refactor:apply refactoring'
        'scan:scan for changes'
        'stop:stop background monitor'
        'todo:show pending tasks'
        'touch:touch a node'
        'upd:update / build (default)'
        'variant:variant commands'
        'wait:wait until idle'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--debug-logging[debug logging]' \
        '--debug-stop[debug stop]' \
        '--debug-run[debug run]' \
        '--debug-rule[debug rule]' \
        '--debug-execute[debug execute]' \
        '--debug-server[debug server]' \
        '--debug-progress[debug progress]' \
        '--no-environ-check[no env check]' \
        '--no-keep-going[no keep going]' \
        '--keep-going[keep going]' \
        '-k[keep going]' \
        '--monitor-events[monitor events]' \
        '--no-color[no color]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '--d[debug]' \
        '--jobs=+[parallel jobs]:n:' \
        '-j+[parallel jobs]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'tup subcommand' sub ;;
        args)
            case $words[1] in
                upd) _arguments \
                    '--no-environ-check[no env check]' \
                    '--no-color[no color]' \
                    '*:target:_files' ;;
                init) _arguments '*:dir:_files -/' ;;
                config) _arguments \
                    '1:key:' \
                    '2:value:' ;;
                monitor) _arguments \
                    '-d[debug]' \
                    '-f[foreground]' \
                    '-r[refresh]' \
                    '-q[quiet]' \
                    '-a[auto update]' ;;
                graph|dag) _arguments \
                    '--combine[combine outputs]' \
                    '--show-dirs[show dirs]' \
                    '*:target:_files' ;;
                generate) _arguments \
                    '--config=+[config file]:file:_files' \
                    '*:script:_files' ;;
                read|todo|touch|refactor|fuse|parse|wait|stop) _arguments '*:arg:' ;;
                variant) _arguments \
                    '1:cmd:(create remove enable disable)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_tup-cli "$@"
