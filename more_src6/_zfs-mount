#compdef zfs-mount
# _zfs-mount — OpenZFS zfs mount (mount one or all ZFS filesystems; -a all auto-mountable datasets, -l load encryption key if needed, -O override clean, -o sets mount options, -r recursive, -v verbose, -f override mount busy/non-empty; positional is the dataset to mount)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zfs/zfs_main.c on tip.

_zfs-mount() {
    _arguments \
        '-a[mount all]' \
        '-l[load encryption key]' \
        '-o+[mount options]:options:' \
        '-O[overlay (replace existing dir contents)]' \
        '-r[recursive]' \
        '-v[verbose]' \
        '-f[force]' \
        '1:dataset:'
}

_zfs-mount "$@"
