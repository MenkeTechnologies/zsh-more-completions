#compdef toil toil-cwl-runner toil-wdl-runner cwltoil
# _toil — Benedict Paten Toil scalable scientific workflow engine in Python supports CWL WDL and Toil scripts (DataBiosphere team, Python); argparse
# upstream: https://github.com/DataBiosphere/toil

_toil() {
    local -a sub=(
        'launch-cluster:launch a cloud cluster'
        'destroy-cluster:destroy a cluster'
        'rsync-cluster:rsync to cluster'
        'ssh-cluster:ssh to cluster'
        'kill:kill a job store'
        'status:show job store status'
        'stats:print job statistics'
        'clean:clean a job store'
        'restart:restart a workflow'
        'debug-job:debug a job'
        'debug-file:debug a file'
        'config:configure Toil'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--batchSystem=+[batch system]:b:(single_machine parasol gridengine lsf slurm mesos kubernetes torque htcondor aws_batch tes)' \
        '--workDir=+[work dir]:dir:_files -/' \
        '--coordinationDir=+[coord dir]:dir:_files -/' \
        '--logFile=+[log file]:file:_files' \
        '--logLevel=+[level]:l:(off critical error warning info debug trace)' \
        '--logCritical[critical log]' \
        '--logError[error log]' \
        '--logWarning[warning log]' \
        '--logInfo[info log]' \
        '--logDebug[debug log]' \
        '--logTrace[trace log]' \
        '--noStdOutErr[no stdout/stderr]' \
        '--clean=+[mode]:m:(always onError onSuccess never)' \
        '--cleanWorkDir=+[mode]:m:(always onError onSuccess never)' \
        '--clusterStats[cluster stats]' \
        '--restart[restart]' \
        '--retryCount=+[N]:n:' \
        '--maxJobDuration=+[seconds]:n:' \
        '--rescueJobsFrequency=+[seconds]:n:' \
        '--maxLocalJobs=+[N]:n:' \
        '--manualMemArgs[manual memory args]' \
        '--maxNodes=+[N]:n:' \
        '--minNodes=+[N]:n:' \
        '--targetTime=+[seconds]:n:' \
        '--betaInertia=+[F]:f:' \
        '--scaleInterval=+[seconds]:n:' \
        '--awsBatchRegion=+[region]:str:' \
        '--awsBatchQueue=+[queue]:str:' \
        '--scaler[enable autoscaler]' \
        '--preemptableNodeTypes=+[types csv]:str:' \
        '--nodeTypes=+[types csv]:str:' \
        '--minPreemptableNodes=+[N]:n:' \
        '--maxPreemptableNodes=+[N]:n:' \
        '--clusterID=+[id]:str:' \
        '--noUbuntu[no ubuntu]' \
        '--installSingularity[install singularity]' \
        '--installDocker[install docker]' \
        '--installNvidia[install nvidia]' \
        '--installCertificate[install cert]' \
        '--leaderType=+[type]:str:' \
        '--keyPairName=+[name]:str:' \
        '--sshKey=+[key file]:file:_files' \
        '--vpcSubnet=+[id]:str:' \
        '--zone=+[zone]:str:' \
        '--cleanLogFiles[clean log files]' \
        '--defaultMemory=+[size]:str:' \
        '--defaultCores=+[N]:n:' \
        '--defaultDisk=+[size]:str:' \
        '--defaultAccelerators=+[csv]:str:' \
        '--defaultPreemptable=+[bool]:b:(true false)' \
        '--maxCores=+[N]:n:' \
        '--maxMemory=+[size]:str:' \
        '--maxDisk=+[size]:str:' \
        '--moveOutputs[move outputs]' \
        '--writeLogs=+[dir]:dir:_files -/' \
        '--writeLogsGzip=+[dir]:dir:_files -/' \
        '--writeMessages=+[file]:file:_files' \
        '--realTimeLogging[real time logging]' \
        '--disableProgress[no progress bar]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'toil subcommand' sub ;;
        args)
            case $words[1] in
                launch-cluster|destroy-cluster|rsync-cluster|ssh-cluster) _arguments \
                    '--provisioner=+[provisioner]:p:(aws gce azure)' \
                    '--leaderNodeType=+[type]:str:' \
                    '*:cluster name:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_toil "$@"
