#compdef vernemq vmq-admin vernemq-admin vernemqctl
# _vernemq — VerneMQ vmq-admin CLI for the VerneMQ distributed MQTT 3.x and 5.x broker managing cluster sessions retain messages bridges plugins listeners ACLs metrics WebSocket subscribers (vernemq team, Erlang); getopt
# upstream: https://github.com/vernemq/vernemq

_vernemq() {
    local -a sub=(
        'api-key:API key management'
        'cluster:cluster operations'
        'config:configuration operations'
        'listener:listener operations'
        'metrics:metric operations'
        'mqtt:mqtt subscriber operations'
        'node:node operations'
        'plugin:plugin operations'
        'retain:retained message operations'
        'session:session operations'
        'trace:trace operations'
        'webhooks:webhook operations'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--node=+[name]:str:' \
        '-n+[name]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vernemq subcommand' sub ;;
        args)
            case $words[1] in
                cluster) _arguments \
                    '1:action:(join leave show status reset replace)' \
                    '*:node:' ;;
                listener) _arguments \
                    '1:action:(start stop show restart)' \
                    '--port=+[port]:n:' \
                    '--ip=+[addr]:str:' \
                    '--ssl[enable SSL]' \
                    '--websocket[websocket]' \
                    '--proxy-protocol[enable proxy proto]' ;;
                session) _arguments \
                    '1:action:(show list disconnect reauthorize)' \
                    '*:client id:' ;;
                retain) _arguments \
                    '1:action:(show clear)' \
                    '*:topic:' ;;
                plugin) _arguments \
                    '1:action:(show enable disable)' \
                    '*:name:' ;;
                trace) _arguments \
                    '1:action:(client topic)' \
                    '--client-id=+[id]:str:' \
                    '--topic=+[topic]:str:' ;;
            esac
            ;;
    esac
}

_vernemq "$@"
