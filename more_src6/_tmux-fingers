#compdef tmux-fingers
# ============================================================================
#  _tmux-fingers — tmux-fingers: vimperator-like hint-based text selection
#                  for tmux panes (copy/paste via key hints)
#
#  Source-direct extraction from
#    https://github.com/Morantron/tmux-fingers/blob/master/src/fingers/cli.cr
#    https://github.com/Morantron/tmux-fingers/blob/master/src/fingers/commands/start.cr
#    https://github.com/Morantron/tmux-fingers/blob/master/src/fingers/commands/send_input.cr
#    https://github.com/Morantron/tmux-fingers/blob/master/src/fingers/commands/load_config.cr
#    https://github.com/Morantron/tmux-fingers/blob/master/src/fingers/commands/info.cr
#    https://github.com/Morantron/tmux-fingers/blob/master/src/fingers/commands/version.cr
#    https://github.com/devnote-dev/cling (the Cling library by Devonte W
#    / devnote-dev)
#
#  Maintained by Toni Reina (Morantron/tmux-fingers).  1414 GH stars.
#  tmux-fingers brings VIMIUM/VIMPERATOR-LIKE HINT NAVIGATION to tmux —
#  press the configured tmux-fingers keybinding (typically prefix+F),
#  and tmux-fingers overlays single-letter hints on every URL, file
#  path, IP address, git SHA, etc. visible in the pane.  Press the
#  hint letter to copy/paste/open the matched text.  Sister tools:
#  tmux-thumbs (Rust alternative IN CORPUS via _thumbs), tmux-copycat
#  (older Bash version, replaced by tmux-fingers), extrakto (tmux
#  text extractor in Python).  Built in Crystal — fast startup,
#  small binary, native compilation.
#
#  CLI library taxonomy update: 5th Crystal CLI library — devnote-dev's
#  **Cling** (devnote-dev/cling).  Crystal ecosystem now has 5
#  documented CLI libraries (Crystal OptionParser stdlib + commander
#  + commander.cr R332 + clim R348 + Cling R381).
#
#  Cling (devnote-dev/cling) is Devonte W's INHERITANCE-BASED Crystal
#  CLI framework — uses Crystal class inheritance (`< Cling::Command`)
#  and method overrides (`setup`, `run`) to define commands.  Distinct
#  from clim's macro-based block DSL and commander.cr's builder DSL.
#  Used by tmux-fingers (1414 stars, tmux navigation plugin), Geode
#  (Crystal alternative package manager), Docr (Crystal docs search
#  CLI), Crimson (Crystal Version Manager), Lucid Crystal compiler,
#  Pterodactyl Soar (panel CLI), Fossil (Pterodactyl daemon CLI),
#  Iris (Pterodactyl SFTP CLI), Focus (SQL query builder), Tanda
#  CLI, dkeygen, and many modern Crystal CLI tools that prefer
#  OOP-based command definition.
#
#  Cling API:
#    require "cling"
#
#    class MyCommand < Cling::Command
#      def setup : Nil
#        @name = "mytool"
#        @description = "my CLI tool"
#        add_command Subcommand1.new
#        add_command Subcommand2.new
#      end
#
#      def run(arguments, options) : Nil
#        puts help_template  # default: show help
#      end
#    end
#
#    class BuildCommand < Cling::Command
#      def setup : Nil
#        @name = "build"
#        @description = "build the project"
#
#        add_argument "target",
#                     description: "build target",
#                     required: true
#
#        add_option "output",
#                   short: 'o',
#                   description: "output file",
#                   type: :single,
#                   default: "a.out"
#
#        add_option "verbose",
#                   short: 'v',
#                   description: "verbose output",
#                   type: :none
#
#        add_option "includes",
#                   short: 'I',
#                   description: "include paths",
#                   type: :multiple
#      end
#
#      def run(arguments, options) : Nil
#        target = arguments.get("target").as_s
#        output = options.get("output").as_s
#        verbose = options.has?("verbose")
#        # ...
#      end
#    end
#
#    MyCommand.new.execute ARGV
#
#  Cling distinctive features:
#    - INHERITANCE-BASED — define commands as subclasses of
#      `Cling::Command`, override `setup` for configuration and `run`
#      for execution
#    - CRYSTAL OOP semantics — class hierarchy + method overriding +
#      typed Crystal language features
#    - `setup : Nil` method — call from constructor to set `@name`,
#      `@description`, `@summary`, and register `add_argument` /
#      `add_option` / `add_command` declarations
#    - `run(arguments, options) : Nil` method — command body receives
#      parsed `Cling::Arguments` and `Cling::Options` containers
#    - `@name` instance variable — sets command name (used in help)
#    - `@description` instance variable — sets long description
#    - `@summary` instance variable — sets short summary line
#    - `add_command Subclass.new` — register a SUBCOMMAND (Crystal
#      object instance, not a class — instances allow per-cmd state)
#    - `add_argument NAME, description: "...", required: true|false`
#      — positional argument
#    - `add_option NAME, short: 'c', description: "...", type: :none |
#      :single | :multiple, default: V` — flag declaration
#    - SHORT NAMES via `short: 'c'` Crystal CHAR literal (single
#      quotes — distinct from Crystal STRING `"c"` and Cling's long
#      name)
#    - TYPE via `type: :none` (boolean flag, no value), `:single`
#      (one value), or `:multiple` (repeatable, returns Array)
#    - DEFAULT via `default: VALUE` — fallback when flag not provided
#    - HELP via `add_option 'h', "help", description: "prints help"`
#      — Cling does NOT auto-inject --help; caller defines it
#    - `execute ARGV` — entry point on root command instance
#    - `arguments.get("name").as_s` / `.as_i` / `.as_a` — typed
#      result accessors with explicit conversions
#    - `options.get("name").as_s` — option value access
#    - `options.has?("name")` — boolean check for flag presence
#    - `help_template` — auto-generated help text from command
#      structure
#    - PROCESS EXIT model — caller decides via `exit` calls; Cling
#      itself does not halt on parse errors (caller handles)
#    - NO auto-coloured help (unlike clap-derive) — plain text output
#    - NO subcommand abbreviation matching by default
#  Distinct from R332 Crystal mosop/commander (BLOCK-BASED DSL with
#  `Commander::Command.new do |cmd| ... end`), R348 Crystal at-grandpa/
#  clim (MACRO-BASED block DSL with `option`/`command` macros inside
#  a class), Crystal stdlib OptionParser (LOW-LEVEL imperative
#  `OptionParser.parse { |parser| parser.on(...) }`), Crystal
#  commander (different `commander.cr` library — block-DSL style),
#  R275 Rust clap-derive (struct + macros), R322 Java JCommander
#  (annotations + reflection — closest concept analog but Java).
#  Cling's approach: CRYSTAL CLASS INHERITANCE (`< Cling::Command`) +
#  `setup` / `run` METHOD OVERRIDES + `@name`/`@description` INSTANCE
#  VARIABLE METADATA + `add_argument`/`add_option`/`add_command`
#  REGISTRATION CALLS in setup + CRYSTAL CHAR LITERAL `short: 'c'`
#  + `type: :none | :single | :multiple` TYPED FLAG VARIANTS + TYPED
#  RESULT ACCESSORS `.as_s`/`.as_i`/`.as_a` + `execute ARGV` entry
#  point — corpus's **first documented inheritance-based-Crystal CLI
#  library**.  Brings cross-language CLI library taxonomy variant
#  count to 120; Crystal ecosystem now has 5 documented CLI libraries
#  — tied for third-most-documented with Java/OCaml/Scala (all 5),
#  behind Rust/Go (9) and Python (6).
#
#  Surface (verbatim from `src/fingers/cli.cr` MainCommand subcommand
#  registration + per-subcommand `setup` methods):
#
#  Subcommands:
#    tmux-fingers version           Print version
#    tmux-fingers load-config       Load tmux-fingers configuration from
#                                   the active tmux session's environment
#    tmux-fingers send-input INPUT  Send input back to the tmux pane that
#                                   triggered fingers mode (used after
#                                   text selection to paste into pane)
#    tmux-fingers info              Print runtime info (debug)
#    tmux-fingers start PANE_ID     Start fingers mode on the specified
#                                   tmux pane
#
#  Options for `start`:
#    PANE_ID                        Required positional: pane id (also
#                                   accepts tmux target-pane tokens
#                                   from tmux(1) man page)
#    --mode MODE                    Operation mode: "default" (copy
#                                   selected text) or "jump" (move
#                                   cursor to hint) (default: default)
#    --patterns PATTERN_LIST        Comma-separated list of pattern
#                                   names to override config (urls,
#                                   files, ips, sha, ...)
#    --main-action CMD              Command to pipe output to (main
#                                   action; typically clipboard
#                                   command like pbcopy)
#    --ctrl-action CMD              Command to pipe output to when
#                                   CTRL held (e.g. xdg-open)
#    --alt-action CMD               Command to pipe output when ALT
#                                   held
#    --shift-action CMD             Command to pipe output when SHIFT
#                                   held
#    -h, --help                     Show help
#
#  Options for `send-input`:
#    INPUT                          Required positional: input string
#                                   to send to pane
#
#  Default keybindings (configured via tmux config / tmux options;
#  set in load-config command, NOT exposed as CLI flags):
#    prefix + F                     Activate tmux-fingers (default
#                                   mode — copy)
#    prefix + Alt-F                 Activate tmux-fingers (jump mode)
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also Cling-based):
#    - thumbs / tmux-thumbs (IN CORPUS via _thumbs — Rust tmux-fingers
#      alternative by fcsonline; already documented under different
#      attribution)
#    - geode (devnote-dev/geode 12 stars — Crystal package manager,
#      smaller community; FUTURE candidate)
#    - docr (devnote-dev/docr 18 stars — Crystal docs search,
#      smaller community)
#    - crimson (crimson-crystal 18 stars — Crystal Version Manager,
#      smaller community)
#    - soar / fossil / iris (PteroPackages 7/few stars each — niche
#      Pterodactyl panel CLIs)
#    - focus (matthewmcgarvey/focus 23 stars — SQL query builder,
#      Crystal library not user-facing CLI)
#    - lucid-crystal/compiler (5 stars — Crystal language compiler
#      research, niche)
# ============================================================================

_tmux-fingers() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '1: :->cmd' \
    '*:: :->subargs'

  case $state in
    cmd)
      local -a verbs=(
        'version:print tmux-fingers version'
        'load-config:load tmux-fingers configuration from tmux env'
        'send-input:send input string back to the triggering tmux pane'
        'info:print runtime info (debug)'
        'start:start fingers mode on a tmux pane'
      )
      _describe -t commands 'tmux-fingers subcommand' verbs
      ;;
    subargs)
      case $line[1] in
        start)
          _arguments -s -S \
            '--mode=[operation mode]:mode:(default jump)' \
            '--patterns=[comma-separated pattern names]:patterns' \
            '--main-action=[command to pipe output to]:cmd' \
            '--ctrl-action=[command to pipe to when CTRL held]:cmd' \
            '--alt-action=[command to pipe to when ALT held]:cmd' \
            '--shift-action=[command to pipe to when SHIFT held]:cmd' \
            '(-h --help)'{-h,--help}'[show help]' \
            '1:pane id (tmux target-pane token):'
          ;;
        send-input)
          _arguments \
            '(-h --help)'{-h,--help}'[show help]' \
            '1:input string to send:'
          ;;
        version|load-config|info)
          _arguments '(-h --help)'{-h,--help}'[show help]'
          ;;
      esac
      ;;
  esac
}

_tmux-fingers "$@"
