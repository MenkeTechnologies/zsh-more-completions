#compdef x2vnc
# Documentation: https://manpages.debian.org/testing/x2vnc/x2vnc.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-version[show version]' \
  '-display+[X display to connect from]:display:' \
  '-shared[allow multiple connections to VNC server]' \
  '-north[server screen is north]' \
  '-south[server screen is south]' \
  '-east[server screen is east]' \
  '-west[server screen is west]' \
  '-hotkey+[hotkey to warp pointer]:key:' \
  '-passwdfile+[VNC password file]:file:_files' \
  '-resurface[auto re-surface window when covered]' \
  '-edgewidth+[edge width in pixels]:px:' \
  '-desktop+[non-sticky on desktop number]:n:' \
  '-timeout+[idle warp-back timeout (seconds)]:sec:' \
  '-wheelhack[translate wheel events to arrow keys]' \
  '-nowheel[no-op (backwards compat)]' \
  '-reversewheel[invert wheel direction]' \
  '-scrolllines+[events per wheel tick]:n:' \
  '-navhack[map buttons 6/7 to Alt+Left/Right]' \
  '-mac[Mac mode: button 2 = ctrl-click]' \
  '-trimsel[trim leading/trailing spaces in selections]' \
  '-noblank[prevent remote screen blanking]' \
  '-lockdelay+[idle delay before no wake (seconds)]:sec:' \
  '-debug[print event info]' \
  '-accel+[remote mouse speed multiplier]:mult:' \
  '-noreconnect[disable auto-reconnect]' \
  '-tunnel[use SSH tunnel]' \
  '-via+[SSH via host]:host:_hosts' \
  '-listen+[listen for VNC reverse connection]:display:' \
  '*:vnc_server:_hosts' && ret=0

return ret
