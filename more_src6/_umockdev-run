# similar GLib.OptionContext usage).

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# 6 FILENAME_ARRAY repeatable flags + --version +
# program-args positional.  Decoded source-direct
# from OptionEntry[] table at umockdev-run.vala:41-60.
# `*` prefix marks repeatability in zsh _arguments.
_arguments -s -S \
  '*'{-d+,--device=}'[load umockdev-record device description (repeatable)]:device description file:_files' \
  '*'{-i+,--ioctl=}'[load umockdev-record ioctl dump (repeatable; format: devname=ioctlfilename)]:devname=ioctlfilename:' \
  '*'{-p+,--pcap=}'[load pcap/pcapng USB dump (repeatable; format: sysfs=pcapfilename)]:sysfs=pcapfilename:' \
  '*'{-s+,--script=}'[load umockdev-record script (repeatable; format: devname=scriptfilename)]:devname=scriptfilename:' \
  '*'{-u+,--unix-stream=}'[load script for mocked Unix stream socket (repeatable; format: socket_path=scriptfilename)]:socket_path=scriptfilename:' \
  '*'{-e+,--evemu-events=}'[load evemu .events file (repeatable; format: devname=eventsfilename)]:devname=eventsfilename:' \
  '--version[output version information and exit]' \
  '(- *)'{-h,--help}'[display GLib auto-generated help and exit]' \
  '(- *)--help-all[display all help (including hidden) and exit]' \
  '1:program to run under testbed:_command_names -e' \
  '*::program args:_normal' && ret=0

return ret
