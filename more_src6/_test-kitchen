#compdef test-kitchen kitchen-cli
# _test-kitchen — Chef Test Kitchen integration testing for Chef CLI alias (test-kitchen team, Ruby); thor
# upstream: https://github.com/test-kitchen/test-kitchen

_test-kitchen() {
    local -a sub=(
        'console:run kitchen console'
        'converge:converge instance'
        'create:create instance'
        'destroy:destroy instance'
        'diagnose:diagnose'
        'doctor:run doctor'
        'driver:driver commands'
        'driver create:create driver gem'
        'driver discover:discover drivers'
        'driver help:driver help'
        'exec:exec on instance'
        'help:show help'
        'init:initialize project'
        'list:list instances'
        'login:login to instance'
        'package:package instance'
        'setup:setup instance'
        'sink:sink output'
        'sshrc:sshrc instance'
        'test:run full test cycle'
        'verify:verify instance'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kitchen subcommand' sub ;;
        args)
            case $words[1] in
                converge|create|destroy|exec|list|login|setup|test|verify|diagnose) _arguments \
                    '*:instance regex:' \
                    '-c+[concurrency]:n:' \
                    '--concurrency=+[concurrency]:n:' \
                    '--parallel[parallel]' \
                    '--no-parallel[no parallel]' \
                    '-l+[log level]:l:(debug info warn error fatal)' \
                    '--log-level=+[log level]:l:(debug info warn error fatal)' \
                    '--log-overwrite=+[bool]:b:(true false)' \
                    '--log-root=+[dir]:dir:_files -/' \
                    '--color[colorize output]' \
                    '--no-color[no color]' \
                    '--debug[debug]' \
                    '-d[debug]' \
                    '--destroy=+[mode]:m:(passing always never)' \
                    '--test-base-path=+[dir]:dir:_files -/' ;;
                init) _arguments \
                    '--driver=+[driver]:str:' \
                    '-D+[driver]:str:' \
                    '--provisioner=+[provisioner]:p:(chef_zero chef_apply chef_infra chef_solo)' \
                    '-P+[provisioner]:p:(chef_zero chef_apply chef_infra chef_solo)' \
                    '--create-gemfile[create Gemfile]' \
                    '--driver-version=+[version]:str:' ;;
                package) _arguments \
                    '*:instance regex:' \
                    '--destination=+[path]:dir:_files -/' ;;
            esac
            ;;
    esac
}

_test-kitchen "$@"
