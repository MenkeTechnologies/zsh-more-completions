#compdef trilium trilium-server
# _trilium — zadam TriliumNext hierarchical personal-knowledge-base notes app with revisions and scripting (TriliumNext team, TypeScript/JavaScript); standard argv
# upstream: https://github.com/TriliumNext/Notes

_trilium() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--port=+[http port]:port:_ports' \
        '-p+[http port]:port:_ports' \
        '--host=+[bind host]:host:_hosts' \
        '--data-dir=+[data dir]:dir:_files -/' \
        '--config=+[config file]:file:_files -g "*.ini"' \
        '--auth-token=+[auth token]:str:' \
        '--no-authentication[disable auth]' \
        '--no-backup[disable backups]' \
        '--no-desktop-icon[no desktop icon]' \
        '--disable-multi-factor-auth[no MFA]' \
        '--readonly[read only]' \
        '--debug[debug logs]' \
        '--trust-proxy=+[bool]:b:(true false)' \
        '--certificate=+[tls cert]:file:_files' \
        '--key=+[tls key]:file:_files' \
        '--electron-no-sandbox[no sandbox electron]' \
        '--log-dir=+[log dir]:dir:_files -/' \
        '--log-level=+[level]:l:(trace debug info warn error)' \
        '--export-dir=+[export dir]:dir:_files -/' \
        '--import-dir=+[import dir]:dir:_files -/' \
        '*:notes:_files'
}

_trilium "$@"
