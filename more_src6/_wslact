#compdef wslact
# wslact — perform miscellaneous Windows actions from WSL
# Part of wslu (https://github.com/wslutilities/wslu)

local -a subcommands=(
  'default-terminal:set default terminal for WSL'
  'time-sync:sync time between Windows and WSL'
  'smart-mount:manage DrvFs mount with metadata'
  'gpu-selection:select GPU for WSL'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:action:->action' \
  '*::arguments:->args'

case $state in
  (action)
    _describe -t actions 'action' subcommands
    ;;
esac
