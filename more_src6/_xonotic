#compdef xonotic xonotic-sdl xonotic-glx xonotic-dedicated
# Documentation: (no Debian/Ubuntu manpage; DarkPlaces engine convention)
# Reference accessed: 2026-05-21
# Verified: no upstream manpage retrievable. Xonotic runs on the DarkPlaces
# engine; engine convention uses +cmd cbuf parsing plus single-dash long
# flags (-window, -fullscreen, -width, -height, -game, -basedir, -userdir).

# Xonotic: open-source arena FPS (DarkPlaces engine)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-window[run in windowed mode]' \
  '-fullscreen[run in fullscreen]' \
  '-width[window width]:width:' \
  '-height[window height]:height:' \
  '-game[load game/mod]:mod:' \
  '-basedir[base data directory]:dir:_files -/' \
  '-userdir[user data directory]:dir:_files -/' \
  '+set[set cvar before init]:cvar:: :' \
  '+exec[execute config at startup]:file:_files -g "*.cfg"' \
  '+map[load map at startup]:map:' \
  '+connect[connect to server]:host:_hosts' \
  '*::extra args:_files' && ret=0
return ret
