#compdef tdengine-cli taos2 taosdump2 taosadapter2 taoskeeper
# _tdengine-cli — TAOS TDengine tdengine-cli CLI command-line frontend wrapping the TDengine open-source big-data platform for time-series IoT data providing taos taosd taosadapter taosdump taosbenchmark taoskeeper taosx super-table sub-table tag column index continuous-query stream-processing data-subscription cluster mnode dnode vnode (TAOS Data team Jeff Tao, C/Go); custom argparse
# upstream: https://tdengine.com/

_tdengine-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-H+[host]:_hosts' \
        '-P+[port]:n:' \
        '-u+[user]:_users' \
        '-p+[password]:str:' \
        '-d+[database]:str:' \
        '-s+[sql]:str:' \
        '-f+[file]:file:_files -g "*.sql"' \
        '-w+[width]:n:' \
        '-A[show config]' \
        '-c+[config dir]:dir:_files -/' \
        '-C[query check]' \
        '-r[raw output]' \
        '-z+[timezone]:str:' \
        '-B[bi mode]' \
        '-D+[dump dir]:dir:_files -/' \
        '-N+[netrole]:r:(startup sync rpc speed fqdn endpoint)' \
        '-n[network test]' \
        '-l+[pkt length]:n:' \
        '-S+[pkt type]:t:(TCP UDP)' \
        '-t+[threads]:n:' \
        '-T+[parallel]:n:' \
        '-k[check]' \
        '-K+[key]:str:' \
        '-G+[group id]:str:' \
        '-E+[endpoint]:_hosts' \
        '-R[restful interface]' \
        '-Z[remove duplicates]' \
        '-y[yes]' \
        '*:database:'
}

_tdengine-cli "$@"
