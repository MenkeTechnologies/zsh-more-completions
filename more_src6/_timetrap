#compdef timetrap
# Documentation: https://github.com/samg/timetrap
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for timetrap - simple time tracking (Ruby)

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-r --round)'{-r,--round}'[round times to nearest 15 minutes]' \
  '(-y --yes)'{-y,--yes}'[skip confirmation prompts]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'archive:archive entries'
      'backend:interactive database session'
      'configure:create/update configuration file'
      'display:display entries'
      'd:display entries'
      'edit:edit an entry'
      'in:start an entry'
      'kill:delete timesheet or entry'
      'list:list timesheets'
      'l:list timesheets'
      'now:show running entries'
      'out:stop current entry'
      'resume:resume a previous entry'
      'sheet:switch to a timesheet'
      's:switch to a timesheet'
      'today:display today entries'
      'yesterday:display yesterday entries'
      'week:display this week entries'
      'month:display this month entries'
    )
    _describe -t commands 'timetrap command' commands && ret=0
    ;;
  args)
    case ${line[1]} in
      in)
        _arguments -s \
          '--at[set start time]:time' \
          '*:note' && ret=0
        ;;
      out)
        _arguments -s \
          '--at[set stop time]:time' \
          '1:timesheet' && ret=0
        ;;
      display|d)
        _arguments -s \
          '--ids[show entry ids]' \
          '(-r --round)'{-r,--round}'[round times]' \
          '(-s --start)'{-s,--start}'[start date]:date' \
          '(-e --end)'{-e,--end}'[end date]:date' \
          '(-f --format)'{-f,--format}'[output format]:format' \
          '(-g --grep)'{-g,--grep}'[filter by regex]:pattern' \
          '1:sheet' && ret=0
        ;;
      edit)
        _arguments -s \
          '--id[entry id]:id' \
          '--start[set start time]:time' \
          '--end[set end time]:time' \
          '--append[append to note]' \
          '*:note' && ret=0
        ;;
      kill)
        _arguments -s \
          '--id[entry id]:id' \
          '1:timesheet' && ret=0
        ;;
      sheet|s)
        _arguments ':sheet name' && ret=0
        ;;
      resume)
        _arguments -s \
          '--id[entry id]:id' \
          '--at[start time]:time' && ret=0
        ;;
      archive)
        _arguments -s \
          '(-s --start)'{-s,--start}'[start date]:date' \
          '(-e --end)'{-e,--end}'[end date]:date' \
          '--grep[filter by regex]:pattern' && ret=0
        ;;
      today|yesterday)
        _arguments -s \
          '--ids[show entry ids]' \
          '(-f --format)'{-f,--format}'[output format]:format' && ret=0
        ;;
      week)
        _arguments -s \
          '--ids[show entry ids]' \
          '(-e --end)'{-e,--end}'[end date]:date' \
          '(-f --format)'{-f,--format}'[output format]:format' && ret=0
        ;;
      month)
        _arguments -s \
          '--ids[show entry ids]' \
          '(-s --start)'{-s,--start}'[start month]:month' \
          '(-f --format)'{-f,--format}'[output format]:format' && ret=0
        ;;
    esac
    ;;
esac

return ret
