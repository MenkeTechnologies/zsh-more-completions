#compdef zita-mu1
# _zita-mu1 — JACK monitoring unit (Fons Adriaensen)
# upstream: https://kokkinizita.linuxaudio.org/linuxaudio/index.html
# Flags from zita-mu1(1) man page.

_zita-mu1() {
    _arguments \
        '(- *)-h[show help]' \
        '-name[JACK client name]:name:' \
        '-s[JACK server name]:server:' \
        '-g[window geometry / position]:geometry:'
}

_zita-mu1 "$@"
