#compdef udisksd
# Documentation: https://manpages.debian.org/testing/udisks2/udisksd.8.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help options]' \
  '--replace[replace existing daemon]' \
  '--debug[print debug or informational messages]' \
  '--no-sigint[do not handle SIGINT for controlled shutdown]' \
  '--force-load-modules[activate modules on startup]' && ret=0

return ret
