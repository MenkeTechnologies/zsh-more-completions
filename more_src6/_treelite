#compdef treelite treelite-compile treelite-test
# _treelite — DMLC Treelite model compiler converts XGBoost LightGBM scikit-learn boosted trees to deployable C library (DMLC team, C++); argparse
# upstream: https://github.com/dmlc/treelite

_treelite() {
    local -a sub=(
        'compile:compile model to C source or shared library'
        'export:export model to treelite serialized format'
        'predict:run prediction with compiled model'
        'info:show model info'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--model-format=+[format]:f:(xgboost xgboost_json lightgbm sklearn treelite-checkpoint)' \
        '--toolchain=+[toolchain]:t:(gcc clang msvc cl)' \
        '--params=+[params dict]:str:' \
        '--parallel-comp=+[N]:n:' \
        '--quantize=+[bool]:b:(0 1)' \
        '--annotate-in=+[branch annotation]:file:_files' \
        '--cl-runtime=+[runtime]:str:' \
        '--verbose=+[level]:n:' \
        '--output=+[output dir]:dir:_files -/' \
        '-o+[output dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'treelite subcommand' sub ;;
        args)
            case $words[1] in
                compile|export|info) _arguments \
                    '*:model file:_files -g "*.model *.json *.bin *.txt"' ;;
                predict) _arguments \
                    '--data=+[input data]:file:_files -g "*.csv *.libsvm *.svmlight"' \
                    '--output=+[output predictions]:file:_files' \
                    '*:compiled library:_files -g "*.so *.dll *.dylib *.a"' ;;
            esac
            ;;
    esac
}

_treelite "$@"
