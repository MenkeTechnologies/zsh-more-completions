#compdef xenstore
# Documentation: https://github.com/xen-project/xen/blob/master/docs/man/xenstore.1.pod
# Reference accessed: 2026-05-21
# Verified: upstream xenstore(1) pod lists chmod, exists, list, ls, read, rm, watch, write.

local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'chmod:set the permissions of keys'
  'exists:test for the existence of a key'
  'list:list keys'
  'ls:list keys, values and permissions'
  'read:read the value of a key'
  'rm:remove keys'
  'watch:watch for changes to keys or values'
  'write:add or modify keys and values'
)
_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'xenstore command' commands && ret=0 ;;
esac
return ret
