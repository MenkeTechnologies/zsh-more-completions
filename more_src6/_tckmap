#compdef tckmap
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/tckmap.html
# Source: MRtrix3/mrtrix3 cmd/tckmap.cpp — track-weighted image generation (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-template+[template image grid]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-vox+[voxel size (comma-separated)]:size:_default' \
    '-datatype+[output datatype]:spec:(float16 cfloat16 float32 cfloat32 float64 cfloat64 int8 uint8 int16 uint16 int32 uint32 int64 uint64 bit)' \
    '-dec[output directionally-encoded colour]' \
    '-dixel+[output as dixel image]:path:_files' \
    '-tod+[output as track orientation distribution, given lmax]:lmax:_default' \
    '-contrast+[contribution to each voxel]:type:(tdi length invlength scalar_map scalar_map_count fod_amp curvature vector_file)' \
    '-image+[scalar image (for scalar_map contrasts)]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-vector_file+[vector text file (for vector_file contrast)]:path:_files' \
    '-stat_vox+[voxel-wise statistic]:type:(sum min mean max)' \
    '-stat_tck+[track-wise statistic]:type:(sum min mean max median mean_nonzero gaussian ends_min ends_mean ends_max ends_prod)' \
    '-fwhm_tck+[Gaussian FWHM for stat_tck=gaussian]:value:_default' \
    '-map_zero[map streamlines even with zero contribution]' \
    '-backtrack[backtrack streamline endpoints]' \
    '-upsample+[upsample streamlines by factor]:factor:_default' \
    '-precise[precise streamline-to-voxel mapping]' \
    '-ends_only[only contribute streamline endpoints]' \
    '-tck_weights_in+[per-streamline weights for input]:file:_files' \
    '1:tracks (input):_files -g "*.{tck,trk}"' \
    '2:output (TW image):_files' \
    && ret=0

return ret
