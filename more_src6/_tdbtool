#compdef tdbtool
# _tdbtool — Samba tdb_tools tdbtool (interactive Trivial Database (TDB) inspector and editor; subcommands: create, open, list, list_keys, dump KEY, write KEY VALUE, delete KEY, traverse, transaction_start, transaction_commit, transaction_cancel, info, dbcheck, mv KEY NEWKEY; -h help, -v version)
# upstream: https://github.com/samba-team/samba (lib/tdb)
# Subcommands from samba lib/tdb/tools/tdbtool.c on tip.

_tdbtool() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-h[show help]' \
        '-v[show version]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'tdbtool command' '(create open close list keys dump write store delete traverse transaction_start transaction_commit transaction_cancel info dbcheck mv quit help)' ;;
        args) _arguments '*:key or path:_files' ;;
    esac
}

_tdbtool "$@"
