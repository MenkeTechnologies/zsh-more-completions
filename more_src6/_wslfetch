#compdef wslfetch
# wslfetch — display system information for WSL, similar to neofetch
# Part of wslu (https://github.com/wslutilities/wslu)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-v,--version}'[show version]' \
  '-l[use text-based logo instead of image]' \
  '-L[do not display logo]' \
  '-c[use custom color scheme]:color1,color2:'
