#compdef vnstati
# Documentation: vnstati --help (vnStat)
# Source: render PNG bandwidth-usage images from vnstat database.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-?,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '-5+[output 5 minutes]:limit:' \
    '-5g+[output 5 minutes graph]:limit height:' \
    {-h,--hours}'[output hours]' \
    {-hg,--hoursgraph}'[output hours graph]' \
    {-d,--days}'[output days]' \
    {-m,--months}'[output months]' \
    {-y,--years}'[output years]' \
    {-t,--top}'[output top days]' \
    {-s,--summary}'[output summary]' \
    {-hs,--hsummary}'[horizontal summary with graph]' \
    {-vs,--vsummary}'[vertical summary with graph]' \
    '--95th=[output 95th percentile graph]:mode:' \
    {-nh,--noheader}'[remove header from output]' \
    {-ne,--noedge}'[remove edge from output]' \
    {-nl,--nolegend}'[remove legend from output]' \
    {-ru,--rateunit=-}'[swap configured rate unit]::mode:' \
    {-ic,--invert-colors=-}'[invert image colors]::mode:' \
    '(-L --large)'{-S,--small}'[use small fonts (default)]' \
    '(-S --small)'{-L,--large}'[use large fonts]' \
    {-o+,--output=}'[output filename]:file:_files -g "*.png"' \
    {-c+,--cache=}'[update only when too old (minutes)]:minutes:' \
    {-i+,--iface=}'[select interface]:iface:' \
    {-b+,--begin=}'[list begin date]:date:' \
    {-e+,--end=}'[list end date]:date:' \
    {-D,--debug}'[show debug info]' \
    '--limit=[set list entry limit]:limit:' \
    '--db=[database file]:file:_files' \
    '--dbiflist=-[show interfaces in database]::mode:' \
    '--dbdir=[database directory]:dir:_files -/' \
    '--style=[output style 0-3]:style:(0 1 2 3)' \
    '--locale=[locale]:locale:' \
    '--config=[config file]:file:_files' \
    '--altdate[alternative date location]' \
    '--headertext=[header text]:text:' \
    && ret=0

return ret
