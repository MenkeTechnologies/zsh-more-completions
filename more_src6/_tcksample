#compdef tcksample
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/tcksample.html
# Source: MRtrix3/mrtrix3 cmd/tcksample.cpp — sample image values along streamlines (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-stat_tck+[per-streamline statistic]:statistic:(mean median min max)' \
    '-nointerp[do not use trilinear interpolation]' \
    '-precise[use precise streamline-to-voxel mapping]' \
    '-use_tdi_fraction[scale by TDI fraction]' \
    '1:tracks (input):_files -g "*.{tck,trk}"' \
    '2:image (to be sampled):_files -g "*.{nii,nii.gz,mif}"' \
    '3:values (output text):_files -g "*.txt"' \
    && ret=0

return ret
