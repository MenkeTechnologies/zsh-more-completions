#compdef vulkan-info vulkaninfo-cli
# _vulkan-info — Khronos Vulkan vulkaninfo report CLI alias (Khronos Group, C); custom argparse
# upstream: https://github.com/KhronosGroup/Vulkan-Tools

_vulkan-info() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--summary[summary mode]' \
        '-s[summary mode]' \
        '--html[output HTML]' \
        '--text[output text]' \
        '--json[output json]' \
        '-j[output json]' \
        '--vkjson[output vkjson]' \
        '-J[output vkjson]' \
        '--portability[include portability]' \
        '--show-tool-props[show tool properties]' \
        '--show-formats[show formats]' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '*:arg:'
}

_vulkan-info "$@"
