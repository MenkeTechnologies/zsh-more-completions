#compdef tiffgt
# Documentation: http://www.libtiff.org/tools.html
# Source: libtiff tools/tiffgt.c — display TIFF images via OpenGL (C, getopt).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-c[use colormap visual]' \
    '-d+[initial directory index]:dirnum:_default' \
    '-e[enable display of TIFF error messages]' \
    '(-m)-l[force LSB-to-MSB FillOrder]' \
    '(-l)-m[force MSB-to-LSB FillOrder]' \
    '-o+[initial directory offset]:offset:_default' \
    '-p+[override photometric interpretation]:photo:_default' \
    '-r[use fullcolor visual]' \
    '-s[stop decoding on first error]' \
    '-v[verbose mode]' \
    '-w[display TIFF warning messages]' \
    '1:file.tif:_files -g "*.{tif,tiff,TIF,TIFF}"' \
    && ret=0

return ret
