#compdef tmate
# Documentation: https://manpages.debian.org/bookworm/tmate/tmate.1.en.html
# Reference accessed: 2026-05-21
# Verified: Debian bookworm tmate(1) manpage OPTIONS list.
# Removed from prior file: fabricated -k API-key flag and -r/--read-only
# flag (tmate's -r is read-only-mode for attach-session, not top-level);
# fabricated -F format flag and --help/--version long forms; bogus
# man.archlinux.org search URL.

# tmate: terminal sharing fork of tmux
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'new-session:create a new session'
  'attach-session:attach to existing session'
  'detach-client:detach a client'
  'kill-session:kill session'
  'kill-server:kill the tmate server'
  'list-sessions:list sessions'
  'list-windows:list windows'
  'list-panes:list panes'
  'has-session:check session existence'
  'rename-session:rename session'
  'rename-window:rename window'
  'new-window:create a new window'
  'split-window:split a window'
  'send-keys:send keys to a window'
  'select-pane:select a pane'
  'select-window:select a window'
  'swap-pane:swap two panes'
  'swap-window:swap two windows'
  'resize-pane:resize a pane'
  'source-file:source a config file'
  'set-option:set a session/server option'
  'show-options:show options'
  'display-message:display a message'
  'show-messages:show messages'
  'wait-for:wait for event'
)

_arguments -C \
  '-2[force 256-color terminal]' \
  '-C[control mode]' \
  '-CC[control mode (extended)]' \
  '-c[execute shell command]:cmd:_command_names' \
  '-f[alternative config file]:file:_files' \
  '-L[named socket in standard dir]:name:' \
  '-l[login-shell compat (no-op)]' \
  '-S[full socket path]:path:_files' \
  '-u[force UTF-8]' \
  '*-v[verbose (repeatable)]' \
  '-V[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'tmate command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (new-session)
        _arguments \
          '-d[do not attach]' \
          '-s[session name]:name:' \
          '-n[window name]:name:' \
          '-x[width]:width:' \
          '-y[height]:height:' && ret=0
        ;;
      (attach-session)
        _arguments \
          '-t[target session]:session:' \
          '-r[read-only mode]' && ret=0
        ;;
      (wait-for) _arguments '1:channel:(tmate-ready)' && ret=0 ;;
    esac
    ;;
esac
return ret
