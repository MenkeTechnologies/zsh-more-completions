#compdef tjs txiki
# _txiki — txiki.js QuickJS-NG + libuv tiny JavaScript runtime (Saúl Ibarra Corretgé); ES2023 + WHATWG fetch/streams + WASI
# upstream: https://github.com/saghul/txiki.js

_txiki() {
    local -a sub=(
        'run:run a script (default)'
        'eval:evaluate expression'
        'test:run test files'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '-q[quiet]' \
        '--unhandled-rejection[error on unhandled rejection]' \
        '--memory-limit=+[memory limit bytes]:n:' \
        '--stack-size=+[stack size bytes]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'tjs subcommand' sub ;;
        args)
            _arguments '*:script:_files -g "*.js"'
            ;;
    esac
}

_txiki "$@"
