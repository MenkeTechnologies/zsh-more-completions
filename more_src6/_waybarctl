#compdef waybarctl
# _waybarctl — bash script to switch Waybar themes via CLI (elrondforwin/waybarctl)
# upstream: https://github.com/elrondforwin/waybarctl
# Subcommands from waybarctl script case statement.

_waybarctl() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'reload:reload Waybar (SIGUSR2 or launch)'
                'theme:set / list / remove a Waybar theme'
                'help:show help'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                theme)
                    local -a themes=(list remove)
                    if [[ -d $HOME/.config/waybar/themes ]]; then
                        themes+=( $HOME/.config/waybar/themes/*(:t) )
                    fi
                    _arguments "1:theme:($themes)"
                    ;;
            esac
            ;;
    esac
}

_waybarctl "$@"
