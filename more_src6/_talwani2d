#compdef talwani2d
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/potential/talwani2d.html
# Source: GenericMappingTools/gmt supplements/potential — Talwani 2-D gravity / VGG / geoid over polygonal bodies.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A[z-axis positive upwards (default: down)]' \
    '-D+[override body density (kg/m³ or g/cm³)]:density:_default' \
    '-F+[field type]:type:(f n v)' \
    '-M+[distance units]:units:(h v)' \
    '-N+[observation track file]:file:_files' \
    '-T+[equidistant output (min/max/inc)]:opts:_default' \
    '-Z+[observation level (default 0) + 2.5D limits]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-bi+[binary input format]:format:_default' \
    '-d+[nodata replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-o+[output column selection]:cols:_default' \
    '-x+[CPU cores limit]:n:_default' \
    '*:input polygon file:_files' \
    && ret=0

return ret
