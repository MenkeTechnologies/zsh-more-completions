_vmr() {
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_vmr_commands' \
        '*::arg:->args'
}

(( $+functions[_vmr_commands] )) ||
_vmr_commands() {
    local -a commands
    commands=(
        'version:show version info of version-manager'
        'v:show version info (alias for version)'
        'show:show available SDKs'
        'S:show available SDKs (alias for show)'
        'search:search available versions for an SDK'
        's:search available versions (alias for search)'
        'use:install and switch to a version for an SDK'
        'u:install and switch to a version (alias for use)'
        'h:install and switch to a version (alias for use)'
        'local:show installed versions for an SDK'
        'l:show installed versions (alias for local)'
        'installed-sdks:show installed SDKs'
        'in:show installed SDKs (alias for installed-sdks)'
        'installed-info:show installed SDK info'
        'ii:show installed SDK info (alias for installed-info)'
        'uninstall:uninstall versions for an SDK'
        'uni:uninstall versions (alias for uninstall)'
        'r:uninstall versions (alias for uninstall)'
        'update-plugins:update plugins for vmr'
        'up:update plugins (alias for update-plugins)'
        'install-self:install version-manager onto the current host'
        'i:install version-manager (alias for install-self)'
        'is:install version-manager (alias for install-self)'
        'uninstall-self:uninstall version-manager (script-only)'
        'Uins:uninstall version-manager (alias for uninstall-self)'
        'set-proxy:set proxy for version-manager'
        'sp:set proxy (alias for set-proxy)'
        'set-reverse-proxy:set reverse proxy for version-manager'
        'sr:set reverse proxy (alias for set-reverse-proxy)'
        'srp:set reverse proxy (alias for set-reverse-proxy)'
        'set-download-threads:set default threads number for downloading'
        'sdt:set download threads (alias for set-download-threads)'
        'st:set download threads (alias for set-download-threads)'
        'toggle-customed-mirrors:toggle customized mirrors on/off'
        'tcm:toggle customized mirrors (alias for toggle-customed-mirrors)'
        'tm:toggle customized mirrors (alias for toggle-customed-mirrors)'
        'add-completions:add auto-completions for vmr to current shell profile'
        'ac:add auto-completions (alias for add-completions)'
        'nested-sessions:toggle nested sessions'
        'ns:toggle nested sessions (alias for nested-sessions)'
        'is-session-mode:show if current shell is in session mode'
        'ism:show if in session mode (alias for is-session-mode)'
    )
    _describe -t commands 'vmr command' commands
}

_vmr "$@"
