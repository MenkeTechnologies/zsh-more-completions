#compdef wingpanel io.elementary.wingpanel
# Documentation: https://github.com/elementary/wingpanel
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: wingpanel is the elementary OS top panel GTK application; no CLI options are documented.
# Standard GTK/GApplication runtime flags only.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)--help-gapplication[show GApplication options]' \
  '(- *)--version[show version]' \
  '*::wingpanel args:_files' && ret=0
return ret
