#compdef vela-core
# _vela-core — KubeVela core controller manager (kubevela/kubevela)
# upstream: https://github.com/kubevela/kubevela
# Flags from cmd/core/app/config/ (pflag).

_vela-core() {
    _arguments \
        '--health-addr=[health probe bind address]:host\:port:' \
        '--metrics-addr=[metrics bind address]:host\:port:' \
        '--storage-driver=[storage driver]:driver:' \
        '--enable-leader-election[enable leader election]' \
        '--leader-election-namespace=[leader election namespace]:ns:' \
        '--use-webhook[enable admission webhook]' \
        '--webhook-cert-dir=[webhook cert directory]:dir:_files -/' \
        '--webhook-port=[webhook server port]:port:' \
        '--log-file-path=[log file path]:file:_files' \
        '--log-debug[enable debug log level]' \
        '--dev-logs[development log format]' \
        '--kube-api-qps=[kubernetes API client QPS]:f:' \
        '--kube-api-burst=[kubernetes API client burst]:n:' \
        '--informer-sync-period=[informer resync period]:duration:'
}

_vela-core "$@"
