autoload -U is-at-least

_tidy-browser() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-o+[Specify output dir binary-cookies ignore the arg]:OUTPUT_DIR:_files -/' \
'--output-dir=[Specify output dir binary-cookies ignore the arg]:OUTPUT_DIR:_files -/' \
'--sep=[Csv separator]:SEP:' \
'--host=[Filter by host/domain]:domain:_urls' \
'--out-format=[Out format]:OUT_FORMAT:(csv json jsonl)' \
'-a[All browsers data]' \
'--all-browsers[All browsers data]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_tidy-browser_commands" \
"*::: :->tidy-browser" \
&& ret=0
    case $state in
    (tidy-browser)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tidy-browser-command-$line[1]:"
        case $line[1] in
            (chromium)
_arguments "${_arguments_options[@]}" : \
'-n+[]:NAME:(Chrome Edge Chromium Brave Vivaldi Yandex Opera Arc OperaGx CocCoc)' \
'--name=[]:NAME:(Chrome Edge Chromium Brave Vivaldi Yandex Opera Arc OperaGx CocCoc)' \
'--user-data-dir=[When browser is started with \`--user-data-dir=DIR   Specify the directory that user data (your "profile") is kept in.\` \[example value\: ~/Library/Application Support/Google/Chrome\]]:DIR:_files -/' \
'*-v+[]:VALUES:(cookie login)' \
'*--values=[]:VALUES:(cookie login)' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(firefox)
_arguments "${_arguments_options[@]}" : \
'-n+[]:NAME:(Firefox Librewolf Floorp Zen)' \
'--name=[]:NAME:(Firefox Librewolf Floorp Zen)' \
'--base=[Browser data dir. \[example value\: ~/Library/Application Support/Firefox\]]:DIR:_files -/' \
'-P+[When browser is started with \`-P <profile>       Start with <profile>.\`]:profile:' \
'--profile=[When browser is started with \`--profile <path>   Start with profile at <path>.\` When the arg is used, other args (such as \`--base\`, \`-P\`) are ignore.]:path:_files' \
'*-v+[Only support cookie]:VALUES:(cookie login)' \
'*--values=[Only support cookie]:VALUES:(cookie login)' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(binary-cookies)
_arguments "${_arguments_options[@]}" : \
'-i+[]:COOKIES_PATH:_files' \
'--cookies-path=[]:COOKIES_PATH:_files' \
'-o+[]:OUT_FILE:_files' \
'--out-file=[]:OUT_FILE:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(safari)
_arguments "${_arguments_options[@]}" : \
'*-v+[Only support cookie]:VALUES:(cookie login)' \
'*--values=[Only support cookie]:VALUES:(cookie login)' \
'--cookies-path=[]:COOKIES_PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell:(bash elvish fish nushell powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_tidy-browser__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tidy-browser-help-command-$line[1]:"
        case $line[1] in
            (chromium)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(firefox)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(binary-cookies)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(safari)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_tidy-browser_commands] )) ||
_tidy-browser_commands() {
    local commands; commands=(
'chromium:Chromium based' \
'firefox:Firefox based' \
'binary-cookies:Parse BinaryCookies' \
'safari:Safari' \
'completions:Generates completions for the specified SHELL, sends them to \`stdout\` and exits' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'tidy-browser commands' commands "$@"
}
