#compdef tcping
# Documentation: https://github.com/pouriyajamshidi/tcping
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for tcping - ping over TCP

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show help]' \
  '-4[only use IPv4 addresses]' \
  '-6[only use IPv6 addresses]' \
  '-r[retry resolving hostname after N failed probes]:n' \
  '-c[stop after N probes]:n' \
  '-t[response timeout in seconds (0 = infinite)]:seconds' \
  '-D[display date and time in output]' \
  '-i[interval between probes]:seconds' \
  '-I[interface name to use]:interface:_net_interfaces' \
  '-v[print version]' \
  '-u[check for updates]' \
  '-j[output in JSON format]' \
  '--no-color[do not colorize output]' \
  '--csv=[path to store output in CSV format]:file:_files' \
  '--pretty[prettify the JSON output]' \
  '--db=[path to store output in sqlite database]:file:_files' \
  '--show-failures-only[only show probe failures]' \
  '--show-source-address[show source IP and port used]' \
  '--non-interactive[run in background mode]' \
  '1:hostname' \
  '2:port' && ret=0

return ret
