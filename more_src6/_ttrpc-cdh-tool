#compdef ttrpc-cdh-tool
# _ttrpc-cdh-tool — Confidential Data Hub ttRPC test client (talks to a running ttrpc-cdh; unseal-secret/unwrap-key/get-resource/secure-mount/pull-image)
# upstream: https://github.com/confidential-containers/guest-components
# Subcommands + flags from confidential-data-hub/hub/src/bin/ttrpc-cdh-tool.rs Cli on tip (clap).

_ttrpc-cdh-tool() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '(-s --socket)'{-s,--socket}'=[ttRPC socket path (unix:///run/confidential-containers/cdh.sock)]:uri:' \
        '(-t --timeout)'{-t,--timeout}'=[request timeout (seconds)]:s:' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                unseal-secret:'unseal a sealed secret'
                unwrap-key:'unwrap an OCI image encryption key'
                get-resource:'fetch a confidential resource from the KBS'
                secure-mount:'mount a Storage object via the CDH secure-mount provider'
                pull-image:'pull an image and store it as an OCI bundle'
            )
            _describe -t commands 'ttrpc-cdh-tool subcommand' subs
            ;;
        args)
            case $line[1] in
                unseal-secret)
                    _arguments \
                        '(-s --secret-path)'{-s,--secret-path}'=[file containing the sealed secret]:file:_files'
                    ;;
                unwrap-key)
                    _arguments \
                        '(-a --annotation-path)'{-a,--annotation-path}'=[file containing the AnnotationPacket]:file:_files'
                    ;;
                get-resource)
                    _arguments \
                        '(-r --resource-uri)'{-r,--resource-uri}'=[KBS Resource URI]:uri:'
                    ;;
                secure-mount)
                    _arguments \
                        '(-s --storage-path)'{-s,--storage-path}'=[file containing the Storage object]:file:_files'
                    ;;
                pull-image)
                    _arguments \
                        '(-i --image-url)'{-i,--image-url}'=[image reference to pull]:ref:' \
                        '(-b --bundle-path)'{-b,--bundle-path}'=[path to store the bundle]:dir:_files -/'
                    ;;
            esac
            ;;
    esac
}

_ttrpc-cdh-tool "$@"
