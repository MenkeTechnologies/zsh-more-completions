#compdef virt-launcher-monitor
# _virt-launcher-monitor — KubeVirt supervisor PID 1 that exec's and reaps virt-launcher inside the VMI pod
# upstream: https://github.com/kubevirt/kubevirt
# Flags from cmd/virt-launcher-monitor/virt-launcher-monitor.go on tip.

_virt-launcher-monitor() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--container-disk-dir=[base directory for container disk data]:dir:_files -/' \
        '--keep-after-failure=[keep virt-launcher alive after failure for debugging]:bool:(true false)' \
        '--uid=[UID of the VirtualMachineInstance]:uid:' \
        '-v[klog verbosity level]:n:'
}

_virt-launcher-monitor "$@"
