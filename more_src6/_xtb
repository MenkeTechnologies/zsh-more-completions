#compdef xtb
# Documentation: https://xtb-docs.readthedocs.io/en/latest/commandline.html
# Source: grimme-lab/xtb (Grimme group GFN-xTB semiempirical quantum chemistry).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '--citation[print citation and exit]' \
    '--license[print license and exit]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-s --silent)'{-s,--silent}'[quieter output]' \
    '--strict[turn warnings into hard errors]' \
    '--scc[self-consistent charge calculation]' \
    '--grad[SCC + gradient (Turbomole format)]' \
    '--vip[vertical ionisation potential]' \
    '--vea[vertical electron affinity]' \
    '--vipea[both IP and EA]' \
    '--vomega[global electrophilicity index]' \
    '--vfukui[Fukui indices via Mulliken partial charges]' \
    '--dipro[electronic coupling integrals J_ab]' \
    '--esp[electrostatic potential on VdW grid]' \
    '--stm[simulate STM measurement]' \
    '--opt=[geometry optimization (level)]:level:_default' \
    '--metaopt[conformer search via biased optimization]' \
    '--path=[generate path between input/target geometry]:file:_files' \
    '--modef=[follow nth eigenmode]:mode:_default' \
    '--hess[Hessian (vibrational frequencies)]' \
    '--ohess[geometry opt + Hessian]' \
    '--bhess[biased Hessian]' \
    '--md[MD simulation]' \
    '--omd[geometry opt + MD]' \
    '--metadyn=[metadynamics (snapshots)]:n:_default' \
    '--siman[simulated annealing (deprecated)]' \
    '(-c --chrg)'{-c+,--chrg=}'[molecular charge]:int:_default' \
    '(-u --uhf)'{-u+,--uhf=}'[Nalpha-Nbeta (unpaired electrons)]:int:_default' \
    '--gfn=[GFN-xTB parametrisation]:n:(0 1 2)' \
    '--etemp=[electronic temperature (K, default 300)]:K:_default' \
    '(-a --acc)'{-a+,--acc=}'[SCC accuracy (default 1.0, lower=better)]:value:_default' \
    '--vparam=[vTB parameter file]:file:_files' \
    '--alpb=[ALPB implicit solvation]:solvent:_default' \
    '(-g --gbsa)'{-g+,--gbsa=}'[GB+SASA implicit solvation]:solvent:_default' \
    '--cma[shift molecule to centre of mass]' \
    '--pop[Mulliken population analysis]' \
    '--molden[write molden output]' \
    '--dipole[print dipole moment]' \
    '--wbo[Wiberg bond orders]' \
    '--lmo[localized orbitals]' \
    '--fod[fractional occupation density]' \
    '(-I --input)'{-I+,--input=}'[xcontrol input file]:file:_files' \
    '--namespace=[namespace for this xtb run]:string:_default' \
    '--copy[copy xcontrol file at startup]' \
    '--nocopy[do not copy xcontrol file]' \
    '--restart[restart from xtbrestart]' \
    '--norestart[ignore xtbrestart]' \
    '(-P --parallel)'{-P+,--parallel=}'[parallel processes]:n:_default' \
    '--define[check input and terminate]' \
    '--iterations=[SCC max iterations]:n:_default' \
    '--tblite[use tblite library backend]' \
    '*:coordinate file:_files -g "*.(xyz|coord|sdf|mol|tmol|TURBOMOLE)(-.)"' \
    && ret=0

return ret
