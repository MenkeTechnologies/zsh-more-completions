#compdef tut
# Documentation: https://github.com/RasmusLindroth/tut
# Reference accessed: 2026-05-21
# Verified: upstream README.

# Zsh completion for tut - TUI for Mastodon

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'[load config.toml from path]:config file:_files' \
  '(-d --config-dir)'{-d,--config-dir}'[load all config from directory]:config dir:_files -/' \
  '(-u --user)'{-u,--user}'[login directly to a user account]:user account' \
  '(-n --new-user)'{-n,--new-user}'[add a new user account]'
