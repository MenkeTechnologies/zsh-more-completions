#compdef wasmdeployqt wasmdeployqt6
# Documentation: https://doc.qt.io/qt-6/wasm.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '--qt-wasm-dir=[Qt for WebAssembly installation directory]:dir:_directories' \
  '--qml-root-path=[root directory for QML files]:dir:_directories' \
  '--qt-host-dir=[Qt host installation directory]:dir:_directories' \
  '*:WASM binary or HTML:_files -g "*.(wasm|html|js)"' && ret=0

return ret
