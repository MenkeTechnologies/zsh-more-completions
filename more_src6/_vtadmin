#compdef vtadmin
# _vtadmin — Vitess multi-cluster admin gRPC/HTTP server (vitessio/vitess)
# upstream: https://github.com/vitessio/vitess
# Flags from go/cmd/vtadmin/main.go on tip.

_vtadmin() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '--addr=[gRPC/HTTP serve address]:host\:port:' \
        '--lmux-read-timeout=[connection mux read timeout]:dur:' \
        '--lame-duck-duration=[shutdown lame-duck window]:dur:' \
        '*--cluster=[per-cluster YAML config (overrides defaults)]:cfg:' \
        '--cluster-config=[path to YAML cluster configuration]:file:_files' \
        '--cluster-defaults=[default options applied to all clusters]:cfg:' \
        '--enable-dynamic-clusters[allow per-request cluster headers]' \
        '--grpc-tracing[enable tracing on the gRPC server]' \
        '--http-tracing[enable tracing on the HTTP server]' \
        '--grpc-allow-reflection[register the gRPC reflection service]' \
        '--grpc-enable-channelz[enable the gRPC channelz service]' \
        '--http-no-compress[disable HTTP response compression]' \
        '--http-no-debug[disable /debug/pprof/* and /debug/env HTTP endpoints]' \
        '*--http-debug-omit-env=[env var to omit from /debug/env]:name:_parameters' \
        '*--http-debug-sanitize-env=[env var to sanitize in /debug/env]:name:_parameters' \
        '--http-metrics-endpoint=[Prometheus metrics HTTP path]:path:' \
        '*--http-origin=[allowed CORS origin]:origin:' \
        '--rbac[enable RBAC (requires --rbac-config)]' \
        '--no-rbac[disable RBAC]' \
        '--rbac-config=[RBAC config YAML file]:file:_files' \
        '--cache-refresh-key=[HTTP cache-refresh header key]:key:' \
        '--tracer=[tracing backend]:tracer:(noop jaeger opentelemetry)'
}

_vtadmin "$@"
