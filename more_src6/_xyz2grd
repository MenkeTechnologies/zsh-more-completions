#compdef xyz2grd
# Documentation: https://docs.generic-mapping-tools.org/latest/xyz2grd.html
# Source: GenericMappingTools/gmt classic-mode xyz2grd — convert a 3-column table to a grid.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-G+[output grid file]:file:_files' \
    '-I+[grid spacing dx/dy]:spacing:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-A+[duplicate-value reducer]:directive:(d f l m n r S s u z)' \
    '-D+[netCDF metadata (names/units/attrs)]:opts:_default' \
    '-J+[map projection (georef metadata)]:proj:_default' \
    '-S+[byte-swap input z-table]:file:_files' \
    '*-V[verbose (stackable)]' \
    '-Z+[single-column read directives]:flags:_default' \
    '-bi+[binary input format]:format:_default' \
    '-di+[input nodata→NaN replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-r[pixel registration (default gridline)]' \
    '-w+[cyclical coordinate conversion]:opts:_default' \
    '-:[swap first two columns]' \
    '*:input table:_files' \
    && ret=0

return ret
