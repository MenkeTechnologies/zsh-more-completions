#compdef tcoffee t_coffee
# Documentation: https://tcoffee.readthedocs.io/en/latest/tcoffee_main_documentation.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '-other_pg[invoke auxiliary tool (seq_reformat, aln_compare, extract_from_pdb)]' \
  '-version[show version]' \
  '-in[input file(s)]:file:_files' \
  '-in2[secondary input]:file:_files' \
  '-infile[input alignment file]:file:_files' \
  '-seq[sequence input]:file:_files' \
  '-aln[combine pre-computed alignments]:file:_files' \
  '-profile[profile alignment input]:file:_files' \
  '-method[methods to use]:methods:' \
  '-mode[preset mode]:mode:(regular expresso 3dcoffee psicoffee rcoffee mcoffee saracoffee accurate)' \
  '-evaluate[evaluate existing alignment]' \
  '-output[output format]:fmt:' \
  '-out[output file]:file:_files' \
  '-outfile[output file]:file:_files' \
  '-matrix[substitution matrix]:matrix:' \
  '-gapopen[gap opening penalty]:n:' \
  '-gapext[gap extension penalty]:n:' \
  '-n_core[number of cores]:n:' \
  '-multi_core[parallel processing cores]:n:' \
  '-template_file[structural templates]:file:_files' \
  '-blast[BLAST specification]:spec:' \
  '-pdb_db[PDB database location]:path:' \
  '-pdb_type[structure type]:type:(d n e)' \
  '-pdb_min_sim[minimum identity threshold]:n:' \
  '-pdb_min_cov[minimum coverage threshold]:n:' \
  '-cache[cache directory]:dir:_directories' \
  '-no_warning[suppress warnings]' \
  '-quiet[minimal output]' \
  '*::t-coffee args:_files' && ret=0
return ret
