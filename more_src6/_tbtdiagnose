#compdef tbtdiagnose
# Documentation: https://keith.github.io/xcode-man-pages/tbtdiagnose.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: macOS tbtdiagnose man page documents no flags ("Usage: tbtdiagnose"
# only); the tool collects Thunderbolt diagnostics and exits.

local curcontext="$curcontext" state line ret=1
_arguments -s -S '*:file:_files' && ret=0
return ret
