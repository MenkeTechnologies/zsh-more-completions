#compdef tun2proxy-bin
# Documentation: https://github.com/blechschmidt/tun2proxy
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for tun2proxy TUN to SOCKS/HTTP proxy

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-p --proxy)'{-p,--proxy}'=[proxy URL (socks4|socks5|http)]:url' \
  '(-t --tun)'{-t,--tun}'=[TUN interface name]:if' \
  '--tun-fd=[existing TUN file descriptor]:fd' \
  '--close-fd-on-drop[close received raw FD on drop]' \
  '(-6 --ipv6-enabled)'{-6,--ipv6-enabled}'[enable IPv6 support]' \
  '--setup[enable routing and system configuration (requires root)]' \
  '--unshare[create TUN in unprivileged namespace]' \
  '--unshare-pidfile=[create pidfile for unshare process]:file:_files' \
  '(-d --dns)'{-d,--dns}'=[DNS handling strategy]:strategy:(virtual over-tcp direct)' \
  '--dns-addr=[DNS resolver address]:ip' \
  '--virtual-dns-pool=[virtual DNS IP pool CIDR]:cidr' \
  '*--bypass=[IPs/CIDRs to bypass tunnel]:cidr' \
  '--tcp-timeout=[TCP timeout seconds]:sec' \
  '--udp-timeout=[UDP timeout seconds]:sec' \
  '(-v --verbosity)'{-v,--verbosity}'=[log verbosity]:level:(off error warn info debug trace)' \
  '--daemonize[run as daemon/service]' \
  '--exit-on-fatal-error[exit on fatal error]' \
  '--max-sessions=[concurrent sessions limit]:n' \
  '--udpgw-server=[UDP-over-TCP helper host:port]:endpoint' \
  '--udpgw-connections=[max parallel udpgw sockets]:n' \
  '--udpgw-keepalive=[udpgw keepalive seconds]:sec' && ret=0

return ret
