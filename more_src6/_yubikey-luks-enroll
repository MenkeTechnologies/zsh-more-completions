#compdef yubikey-luks-enroll
# Documentation: https://github.com/cornelinux/yubikey-luks/blob/master/yubikey-luks-enroll
# Reference accessed: 2026-05-21
# Verified: upstream getopts string ":s:d:y:hcv" in the script at the URL above.

_arguments -s \
  '-d[partition device]:device:_files -g "/dev/*"' \
  '-s[LUKS slot]:slot:' \
  '-y[YubiKey slot]:slot:(1 2)' \
  '-c[clear slot before writing]' \
  '-v[verbose (cleartext debug)]' \
  '-h[show help]'
