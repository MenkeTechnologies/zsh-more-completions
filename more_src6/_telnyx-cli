#compdef telnyx-cli telnyx
# _telnyx-cli — Telnyx telnyx-cli CLI command-line frontend wrapping the Telnyx Communications Platform REST API managing messages calls verifications numbers phone-numbers porting media-storage outbound-voice-profiles applications connections webhook-deliveries dedicated-IP-domain wireless authentication-keys identity verify TeXML notifications (Telnyx team, Go); cobra
# upstream: https://telnyx.com/

_telnyx-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'message:message operations'
        'call:call operations'
        'verify:verify operations'
        'number:number operations'
        'porting:porting operations'
        'media:media storage'
        'voice-profile:voice profile operations'
        'application:application operations'
        'connection:connection operations'
        'webhook:webhook delivery operations'
        'ip-connection:IP connection operations'
        'wireless:wireless operations'
        'auth-key:authentication key operations'
        'identity:identity operations'
        'texml:TeXML operations'
        'fax:fax operations'
        'phone-number:phone number operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--public-key=+[key]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'telnyx-cli subcommand' sub ;;
        args)
            case $words[1] in
                message|call|verify|number|porting|media|voice-profile|application|connection|webhook|ip-connection|wireless|auth-key|identity|texml|fax|phone-number) _arguments '1:op:(list get create update delete send hangup transfer answer reject deliver retry)' '*:id:' ;;
            esac
            ;;
    esac
}

_telnyx-cli "$@"
