#compdef wchisp
# Documentation: https://github.com/ch32-rs/wchisp
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_wchisp_commands() {
  local -a commands=(
    'flash:flash firmware to device'
    'verify:verify flash content against file'
    'reset:reset the target device'
    'erase:erase device flash'
    'info:show device information'
    'config:show or modify device configuration'
  )
  _describe -t commands 'wchisp command' commands
}

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--chip=[specify chip type]:chip:' \
  '--port=[specify USB port]:port:' \
  '--speed=[specify communication speed]:speed:' \
  '--log=[set log level]:level:(trace debug info warn error)' \
  '1:command:_wchisp_commands' \
  '*:file:_files' && ret=0

return ret
