#compdef vina

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--receptor[rigid receptor PDBQT file]:receptor file:_files -g "*.pdbqt"' \
  '--flex[flexible side chains PDBQT file]:flex file:_files -g "*.pdbqt"' \
  '--ligand[ligand PDBQT file]:ligand file:_files -g "*.pdbqt"' \
  '--batch[batch mode ligand directory]:ligand directory:_files -/' \
  '--scoring[scoring function]:scoring function:(ad4 vina)' \
  '--maps[affinity maps prefix]:maps prefix:_files' \
  '--center_x[X coordinate of search box center]:X coordinate:' \
  '--center_y[Y coordinate of search box center]:Y coordinate:' \
  '--center_z[Z coordinate of search box center]:Z coordinate:' \
  '--size_x[size of search box in X dimension]:X size:' \
  '--size_y[size of search box in Y dimension]:Y size:' \
  '--size_z[size of search box in Z dimension]:Z size:' \
  '--out[output PDBQT file]:output file:_files -g "*.pdbqt"' \
  '--dir[output directory for batch mode]:output directory:_files -/' \
  '--write_maps[write affinity maps prefix]:maps prefix:_files' \
  '--cpu[number of CPUs to use]:threads:' \
  '--seed[explicit random seed]:seed:' \
  '--exhaustiveness[exhaustiveness of search (default 8)]:exhaustiveness:' \
  '--max_evals[maximum number of evaluations]:max evaluations:' \
  '--num_modes[maximum number of binding modes (default 9)]:num modes:' \
  '--min_rmsd[minimum RMSD between output poses (default 1)]:min RMSD:' \
  '--energy_range[maximum energy difference (default 3)]:energy range:' \
  '--spacing[grid spacing (default 0.375)]:spacing:' \
  '--verbosity[verbosity level]:verbosity:(0 1 2)' \
  '--score_only[score only, no search]' \
  '--local_only[do local search only]' \
  '--no_refine[skip refinement step]' \
  '--autobox[compute box from ligand]' \
  '--help[show help message]' \
  '--version[show version]' && ret=0

return ret
