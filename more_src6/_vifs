#compdef vifs
# Documentation: man 8 vifs (macOS/BSD); no online canonical URL.
# Reference accessed: 2026-05-21
# Verified: local `man vifs` on macOS 26.4 - "safely edit fstab".
# SYNOPSIS is literally `vifs` (no options); the utility locks /etc/fstab
# and invokes $EDITOR on it. Nothing else to complete.
# STUB: command accepts no command-line flags or arguments.

local curcontext="$curcontext" state line ret=1
_arguments && ret=0
return ret
