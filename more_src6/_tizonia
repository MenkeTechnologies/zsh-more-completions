#compdef tizonia

local curcontext="$curcontext" state line ret=1

_arguments \
  '(--help)--help[show help message]' \
  '(--version)--version[show version]' \
  '(--shuffle)--shuffle[shuffle playback]' \
  '(--recurse)--recurse[recurse into directories]' \
  '(--daemon)--daemon[run as daemon]' \
  '(--port)--port[HTTP server port]:port number' \
  '(--chromecast-name-or-ip)--chromecast-name-or-ip[Chromecast device name or IP]:name or IP' \
  '(--spotify-user)--spotify-user[Spotify user name]:username' \
  '(--spotify-password)--spotify-password[Spotify password]:password' \
  '(--spotify-owner)--spotify-owner[Spotify playlist owner]:owner' \
  '(--spotify-tracks)--spotify-tracks[play Spotify tracks]:search term' \
  '(--spotify-artist)--spotify-artist[play Spotify artist]:artist name' \
  '(--spotify-album)--spotify-album[play Spotify album]:album name' \
  '(--spotify-playlist)--spotify-playlist[play Spotify playlist]:playlist name' \
  '(--spotify-recommendations-by-track-id)--spotify-recommendations-by-track-id[Spotify recommendations by track ID]:track ID' \
  '(--spotify-recommendations-by-artist-id)--spotify-recommendations-by-artist-id[Spotify recommendations by artist ID]:artist ID' \
  '(--spotify-recommendations-by-genre)--spotify-recommendations-by-genre[Spotify recommendations by genre]:genre' \
  '(--gmusic-user)--gmusic-user[Google Music user]:username' \
  '(--gmusic-password)--gmusic-password[Google Music password]:password' \
  '(--gmusic-device-id)--gmusic-device-id[Google Music device ID]:device ID' \
  '(--gmusic-library)--gmusic-library[play Google Music library]' \
  '(--gmusic-tracks)--gmusic-tracks[play Google Music tracks]:search term' \
  '(--gmusic-artist)--gmusic-artist[play Google Music artist]:artist name' \
  '(--gmusic-album)--gmusic-album[play Google Music album]:album name' \
  '(--gmusic-playlist)--gmusic-playlist[play Google Music playlist]:playlist name' \
  '(--soundcloud-oauth-token)--soundcloud-oauth-token[SoundCloud OAuth token]:token' \
  '(--soundcloud-user-stream)--soundcloud-user-stream[play SoundCloud user stream]' \
  '(--soundcloud-user-likes)--soundcloud-user-likes[play SoundCloud user likes]' \
  '(--soundcloud-user-playlist)--soundcloud-user-playlist[play SoundCloud user playlist]:playlist name' \
  '(--soundcloud-creator)--soundcloud-creator[play SoundCloud creator]:creator name' \
  '(--soundcloud-tracks)--soundcloud-tracks[play SoundCloud tracks]:search term' \
  '(--soundcloud-playlists)--soundcloud-playlists[play SoundCloud playlists]:search term' \
  '(--youtube-audio-stream)--youtube-audio-stream[play YouTube audio stream]:video URL or ID' \
  '(--youtube-audio-playlist)--youtube-audio-playlist[play YouTube audio playlist]:playlist URL or ID' \
  '(--youtube-audio-mix)--youtube-audio-mix[play YouTube audio mix]:video URL or ID' \
  '(--youtube-audio-search)--youtube-audio-search[search and play YouTube audio]:search term' \
  '(--youtube-audio-mix-search)--youtube-audio-mix-search[search and play YouTube audio mix]:search term' \
  '(--youtube-audio-channel)--youtube-audio-channel[play YouTube channel audio]:channel URL or name' \
  '(--tunein-search)--tunein-search[search and play TuneIn station]:search term' \
  '(--plex-server-base-url)--plex-server-base-url[Plex server base URL]:URL' \
  '(--plex-auth-token)--plex-auth-token[Plex authentication token]:token' \
  '(--plex-audio-tracks)--plex-audio-tracks[play Plex audio tracks]:search term' \
  '(--plex-audio-artist)--plex-audio-artist[play Plex audio artist]:artist name' \
  '(--plex-audio-album)--plex-audio-album[play Plex audio album]:album name' \
  '(--plex-audio-playlist)--plex-audio-playlist[play Plex audio playlist]:playlist name' \
  '*:audio files:_files -g "*.{mp3,ogg,flac,wav,aac,m4a,opus,wma}"' \
  && ret=0

return ret
