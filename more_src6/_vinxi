#compdef vinxi
# Documentation: https://github.com/nksaraf/vinxi
# Reference accessed: 2026-05-21
# Verified: upstream packages/vinxi/bin/cli.mjs (citty command definitions).

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S -C \
  '(- *)--help[show help]' \
  '(- *)--version[print versions of core dependencies]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'dev:Start development server'
      'build:Build for production'
      'start:Start production server'
      'deploy:Deploy to preset target'
      'serve:Serve a static directory'
      'run:Run a script'
      'version:Print version'
    )
    _describe -t commands 'vinxi commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      dev)
        _arguments -s -S \
          '--help[show help]' \
          '--config=[path to config file]:file:_files' \
          '--mode=[Vite mode]:mode:' \
          '--force[force optimize deps]' \
          '--devtools[enable devtools]' \
          '--port=[port to listen on]:port:' \
          '--host[expose to host]' \
          '--version[print versions]' && ret=0
        ;;
      build)
        _arguments -s -S \
          '--help[show help]' \
          '--config=[path to config file]:file:_files' \
          '--mode=[Vite mode]:mode:' \
          '--preset=[server preset]:preset:' \
          '--router=[router to build]:router:' \
          '--version[print versions]' && ret=0
        ;;
      start)
        _arguments -s -S \
          '--help[show help]' \
          '--config=[path to config file]:file:_files' \
          '--preset=[server preset]:preset:' \
          '--port=[port to listen on]:port:' \
          '--host=[expose to host]:host:' && ret=0
        ;;
      deploy)
        _arguments -s -S \
          '--preset=[server preset]:preset:' \
          '--port=[port to listen on]:port:' \
          '--host[expose to host]' && ret=0
        ;;
      serve)
        _arguments -s -S \
          '--port=[port to listen on]:port:' \
          '--host[expose to host]' \
          '--dir=[directory to serve]:dir:_files -/' \
          '--base=[base path]:base:' && ret=0
        ;;
      run)
        _arguments -s -S \
          '--port=[port to listen on]:port:' \
          '--router=[router to run]:router:' \
          '--config=[path to config file]:file:_files' \
          '--mode=[Vite mode]:mode:' \
          '*:script:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
