#compdef wtype
# Documentation: https://github.com/atx/wtype
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Flags from README (short forms only, no documented long forms):
#   -M (press modifier), -m (release modifier),
#   -d (delay between keystrokes), -s (insert delays into key stream),
#   -P (press named key), -p (release named key).
# Removed from prior file: -h/--help, -v/--version (not in README; though
# the binary may exit early on -h, README doesn't document it), -k/--key
# (no such flag - typed text is positional), long forms like --modifier
# (README only shows short forms).

_arguments \
  '-M+[hold modifier]:modifier:(shift ctrl alt logo win super)' \
  '-m+[release modifier]:modifier:(shift ctrl alt logo win super)' \
  '-d+[delay between keystrokes in ms]:ms:' \
  '-s+[insert sleep delay (ms) into key event stream]:ms:' \
  '-P+[press named key]:key:' \
  '-p+[release named key]:key:' \
  '*:text to type:'
