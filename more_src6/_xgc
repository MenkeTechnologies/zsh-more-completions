#compdef xgc
# Documentation: https://manpages.debian.org/bookworm/x11-apps/xgc.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Note: xgc accepts standard X Toolkit options only (no app-specific flags);
# -display, -geometry, -fn are standard Xt options.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-display+[X server display]:display:' \
  '-geometry+[geometry]:geometry:' \
  '-fn+[font]:font:' \
  '-bg+[background color]:color:' \
  '-fg+[foreground color]:color:' \
  '-bd+[border color]:color:' \
  '-bw+[border width]:n:' \
  '-name+[application name]:name:' \
  '-title+[window title]:title:' \
  '-rv[reverse video]' \
  '+rv[no reverse video]' \
  '-synchronous[run in synchronous mode]' \
  '-xrm+[resource string]:resource:' && ret=0

return ret
