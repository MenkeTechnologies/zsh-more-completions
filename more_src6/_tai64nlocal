#compdef tai64nlocal
# _tai64nlocal — daemontools tai64nlocal (convert TAI64N timestamps in input lines to local ISO format YYYY-MM-DD HH:MM:SS.SSSSSSSSS; companion to tai64n)
# upstream: https://github.com/schmonz/daemontools-encore
# Source: tai64nlocal.8 on tip; no flags.

_tai64nlocal() {
    _arguments '(- *)-h[show help]'
}

_tai64nlocal "$@"
