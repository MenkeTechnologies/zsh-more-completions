#compdef uffizzi
# _uffizzi — Uffizzi Cloud preview-environment CLI (Ruby CLI; preview/cluster/project/disconnect/connect/account/install)
# upstream: https://github.com/UffizziCloud/uffizzi_cli
# Subcommands derived from upstream `uffizzi help` output on tip.

_uffizzi() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[print version and exit]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                login:'log in to your Uffizzi account'
                logout:'log out of your Uffizzi account'
                preview:'manage preview environments (list/create/describe/delete/update/events/url)'
                cluster:'manage ephemeral Uffizzi clusters'
                'connect-cluster':'create a kubeconfig context for a cluster'
                project:'manage projects (list/create/describe/delete/compose/secret/set-default)'
                disconnect:'disconnect from a docker/github/heroku/azure/gcs/aws/quay registry'
                connect:'connect a docker/github/heroku/azure/gcs/aws/quay registry'
                account:'switch the active account (set/list/clear)'
                install:'install Uffizzi cluster on the current kubectl cluster'
                config:'show / set local CLI configuration'
                help:'show help for a command'
            )
            _describe -t commands 'uffizzi subcommand' subs
            ;;
    esac
}

_uffizzi "$@"
