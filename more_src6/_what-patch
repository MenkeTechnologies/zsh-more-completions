#compdef what-patch
# Documentation: https://manpages.debian.org/what-patch
# Source: debian/devscripts scripts/what-patch.sh — detect which patch system is used by a Debian source (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '(-h --help)'{-h,--help}'[show help]' \
    '-v[verbose mode]' \
    && ret=0

return ret
