#compdef tlsx
# Documentation: https://github.com/projectdiscovery/tlsx
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for tlsx - fast and configurable TLS grabber

_arguments -s -S \
  '(-u -host)'{-u,-host}'=[target host to scan]:host:' \
  '(-l -list)'{-l,-list}'=[target list file]:file:_files' \
  '(-p -port)'{-p,-port}'=[target port]:port:' \
  '(-sm -scan-mode)'{-sm,-scan-mode}'=[TLS connection mode]:mode:(ctls ztls openssl auto)' \
  '(-ps -pre-handshake)'{-ps,-pre-handshake}'[enable pre-handshake TLS connection]' \
  '(-sa -scan-all-ips)'{-sa,-scan-all-ips}'[scan all IPs for a host]' \
  '(-iv -ip-version)'{-iv,-ip-version}'=[IP version]:version:(4 6)' \
  '-san[display subject alternative names]' \
  '-cn[display common names]' \
  '-so[display subject organization]' \
  '(-tv -tls-version)'{-tv,-tls-version}'[display TLS version used]' \
  '-cipher[display cipher used]' \
  '-hash=[display certificate fingerprint hash]:algo:(md5 sha1 sha256)' \
  '-jarm[display JARM fingerprint]' \
  '-ja3[display JA3 fingerprint]' \
  '(-wc -wildcard-cert)'{-wc,-wildcard-cert}'[display wildcard certificates]' \
  '(-tps -probe-status)'{-tps,-probe-status}'[display probe status]' \
  '(-ve -version-enum)'{-ve,-version-enum}'[enumerate TLS versions]' \
  '(-ce -cipher-enum)'{-ce,-cipher-enum}'[enumerate ciphers]' \
  '(-ct -cipher-type)'{-ct,-cipher-type}'=[cipher types to enumerate]:type:' \
  '(-ch -client-hello)'{-ch,-client-hello}'[include client hello in output]' \
  '(-sh -server-hello)'{-sh,-server-hello}'[include server hello in output]' \
  '(-se -serial)'{-se,-serial}'[display certificate serial number]' \
  '(-ex -expired)'{-ex,-expired}'[detect expired certificates]' \
  '(-ss -self-signed)'{-ss,-self-signed}'[detect self-signed certificates]' \
  '(-mm -mismatched)'{-mm,-mismatched}'[detect mismatched certificates]' \
  '(-re -revoked)'{-re,-revoked}'[detect revoked certificates]' \
  '(-un -untrusted)'{-un,-untrusted}'[detect untrusted certificates]' \
  '-config=[configuration file path]:file:_files' \
  '(-r -resolvers)'{-r,-resolvers}'=[list of resolvers]:resolver:' \
  '(-cc -cacert)'{-cc,-cacert}'=[client CA file]:file:_files' \
  '(-ci -cipher-input)'{-ci,-cipher-input}'=[ciphers to use]:ciphers:' \
  '-sni=[TLS SNI hostname]:hostname:' \
  '(-rs -random-sni)'{-rs,-random-sni}'[use random SNI]' \
  '(-rps -rev-ptr-sni)'{-rps,-rev-ptr-sni}'[reverse PTR for SNI]' \
  '-min-version=[minimum TLS version]:version:(ssl30 tls10 tls11 tls12 tls13)' \
  '-max-version=[maximum TLS version]:version:(ssl30 tls10 tls11 tls12 tls13)' \
  '(-cert -certificate)'{-cert,-certificate}'[include certificates in output]' \
  '(-tc -tls-chain)'{-tc,-tls-chain}'[include certificate chain]' \
  '(-vc -verify-cert)'{-vc,-verify-cert}'[enable certificate verification]' \
  '(-ob -openssl-binary)'{-ob,-openssl-binary}'=[OpenSSL binary path]:file:_files' \
  '(-hf -hardfail)'{-hf,-hardfail}'[revocation check strategy]' \
  '-proxy=[SOCKS5 proxy]:url:' \
  '(-c -concurrency)'{-c,-concurrency}'=[concurrent threads]:N:' \
  '(-cec -cipher-concurrency)'{-cec,-cipher-concurrency}'=[cipher enum concurrency]:N:' \
  '-timeout=[connection timeout]:seconds:' \
  '-retry=[retry attempts]:N:' \
  '-delay=[delay between connections]:duration:' \
  '(-o -output)'{-o,-output}'=[output file]:file:_files' \
  '(-j -json)'{-j,-json}'[JSON output format]' \
  '-dns[display unique hostnames from certificates]' \
  '(-ro -resp-only)'{-ro,-resp-only}'[display response only]' \
  '-silent[silent output]' \
  '(-nc -no-color)'{-nc,-no-color}'[disable colored output]' \
  '(-v -verbose)'{-v,-verbose}'[verbose output]' \
  '-version[display version]' \
  '(-pd -dashboard)'{-pd,-dashboard}'[upload to PDCP dashboard]' \
  '(-pdu -dashboard-upload)'{-pdu,-dashboard-upload}'=[upload existing file]:file:_files' \
  '-auth=[PDCP API key]:key:' \
  '(-tid -team-id)'{-tid,-team-id}'=[Team ID]:id:' \
  '(-aid -asset-id)'{-aid,-asset-id}'=[Asset ID]:id:' \
  '(-aname -asset-name)'{-aname,-asset-name}'=[Asset name]:name:' \
  '-ctl[stream CT logs]' \
  '(-cb -ctl-beginning)'{-cb,-ctl-beginning}'[start from index 0]' \
  '(-cti -ctl-index)'{-cti,-ctl-index}'=[custom per-log index]:index:' \
  '(-up -update)'{-up,-update}'[update to latest version]' \
  '(-duc -disable-update-check)'{-duc,-disable-update-check}'[disable update checks]' \
  '(-hc -health-check)'{-hc,-health-check}'[run diagnostic check]' \
  '(-h -help)'{-h,-help}'[show help]'
