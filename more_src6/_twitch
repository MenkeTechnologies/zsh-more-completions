#compdef twitch
# Documentation: https://github.com/twitchdev/twitch-cli/tree/main/docs
# Reference accessed: 2026-05-21
# Verified: upstream twitch-cli docs (api.md, event.md, token.md, configure.md, mock-api.md).

local curcontext="$curcontext" state line ret=1
local -a subcommands event_subs

subcommands=(
  'api:make Twitch API requests'
  'mock-api:run mock Twitch API server'
  'configure:configure CLI credentials'
  'event:trigger and verify EventSub events'
  'token:manage user/app access tokens'
  'version:print CLI version'
  'completion:generate shell completions'
  'help:show help'
)

event_subs=(
  'trigger:fire a mock event'
  'retrigger:retrigger a previous event'
  'verify-subscription:verify EventSub subscription'
  'websocket:control mock EventSub websocket server'
  'configure:configure event defaults'
)

_arguments -C \
  '--config=[config file path]:file:_files' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'twitch subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (api)
        _arguments \
          '*'{-q,--query-param}'=[query param key=value]:kv:' \
          '(-b --body)'{-b,--body}'=[request body]:body:' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' \
          '(-u --unformatted)'{-u,--unformatted}'[unformatted output]' \
          '(-p --pretty-print)'{-p,--pretty-print}'[pretty print]' \
          '(-P --autopaginate)'{-P,--autopaginate}'[auto-paginate]:limit:' \
          '1:method:(get post patch delete put)' \
          '*:path: ' && ret=0
        ;;
      (mock-api)
        if (( CURRENT == 2 )); then
          _values 'mock-api action' \
            'start[start mock server]' \
            'generate[generate fake data]' && ret=0
        else
          case $line[2] in
            (start)
              _arguments \
                '(-p --port)'{-p,--port}'=[port number]:port:' && ret=0
              ;;
            (generate)
              _arguments \
                '(-c --count)'{-c,--count}'=[user count]:n:' && ret=0
              ;;
          esac
        fi
        ;;
      (configure)
        _arguments \
          '(-i --client-id)'{-i,--client-id}'=[client id]:id:' \
          '(-s --client-secret)'{-s,--client-secret}'=[client secret]:secret:' && ret=0
        ;;
      (event)
        if (( CURRENT == 2 )); then
          _describe -t event_subs 'event subcommand' event_subs && ret=0
        else
          case $line[2] in
            (trigger)
              _arguments \
                '(-F --forward-address)'{-F,--forward-address}'=[forward URL]:url:' \
                '(-T --transport)'{-T,--transport}'=[transport]:transport:(webhook websocket)' \
                '(-s --secret)'{-s,--secret}'=[secret]:secret:' \
                '(-t --to-user)'{-t,--to-user}'=[to user id]:id:' \
                '(-f --from-user)'{-f,--from-user}'=[from user id]:id:' \
                '(-g --gift-user)'{-g,--gift-user}'=[gift user id]:id:' \
                '(-a --anonymous)'{-a,--anonymous}'[anonymous]' \
                '(-c --count)'{-c,--count}'=[count]:n:' \
                '(-C --cost)'{-C,--cost}'=[cost]:n:' \
                '(-d --description)'{-d,--description}'=[stream title]:title:' \
                '(-S --event-status)'{-S,--event-status}'=[event status]:status:' \
                '(-D --no-config)'{-D,--no-config}'[ignore config values]' \
                '(-G --game-id)'{-G,--game-id}'=[game id]:id:' \
                '(-i --item-id)'{-i,--item-id}'=[item id]:id:' \
                '(-n --item-name)'{-n,--item-name}'=[item name]:name:' \
                '--from-user-name=[sender username]:name:' \
                '--to-user-name=[receiver username]:name:' \
                '--session=[websocket session]:session:' \
                '(-u --subscription-id)'{-u,--subscription-id}'=[event id]:id:' \
                '(-r --subscription-status)'{-r,--subscription-status}'=[subscription status]:status:' \
                '--tier=[subscription tier]:tier:' \
                '--timestamp=[RFC3339Nano timestamp]:ts:' \
                '--client-id=[client id]:id:' \
                '--ban-start=[ban start]:ts:' \
                '--ban-end=[ban end]:ts:' \
                '--charity-current-value=[charity current]:n:' \
                '--charity-target-value=[charity target]:n:' \
                '*:event: ' && ret=0
              ;;
            (retrigger)
              _arguments \
                '(-F --forward-address)'{-F,--forward-address}'=[forward URL]:url:' \
                '(-i --id)'{-i,--id}'=[event id]:id:' \
                '(-s --secret)'{-s,--secret}'=[secret]:secret:' \
                '(-D --no-config)'{-D,--no-config}'[ignore config values]' && ret=0
              ;;
            (verify-subscription)
              _arguments \
                '(-F --forward-address)'{-F,--forward-address}'=[forward URL]:url:' \
                '(-T --transport)'{-T,--transport}'=[transport]:transport:(webhook websocket)' \
                '(-s --secret)'{-s,--secret}'=[secret]:secret:' \
                '(-b --broadcaster)'{-b,--broadcaster}'=[broadcaster user id]:id:' \
                '(-D --no-config)'{-D,--no-config}'[ignore config values]' \
                '*:event: ' && ret=0
              ;;
            (websocket)
              _arguments \
                '(-p --port)'{-p,--port}'=[port]:port:' \
                '(-S --require-subscription)'{-S,--require-subscription}'[require subscriptions]' \
                '(-s --session)'{-s,--session}'=[client session id]:session:' \
                '--reason=[close code]:reason:' \
                '--status=[subscription status override]:status:' \
                '--subscription=[target subscription id]:id:' \
                '--enabled=[enable/disable feature]:bool:(true false)' \
                '*:action:(start-server reconnect close subscription keepalive)' && ret=0
              ;;
            (configure)
              _arguments \
                '(-F --forward-address)'{-F,--forward-address}'=[webhook forwarding address]:url:' \
                '(-s --secret)'{-s,--secret}'=[webhook secret]:secret:' && ret=0
              ;;
          esac
        fi
        ;;
      (token)
        _arguments \
          '(-u --user-token)'{-u,--user-token}'[generate user token]' \
          '(-s --scopes)'{-s,--scopes}'=[scopes]:scopes:' \
          '(-r --revoke)'{-r,--revoke}'[revoke token]' \
          '(-v --validate)'{-v,--validate}'[validate token]' \
          '(-R --refresh)'{-R,--refresh}'[refresh token]' \
          '--client-id=[client id]:id:' \
          '--secret=[client secret]:secret:' \
          '(-p --port)'{-p,--port}'=[port]:port:' \
          '--ip=[bind IP]:ip:' \
          '--dcf[device code flow]' \
          '--forceverify[force scope verification]' \
          '--redirect-host=[override redirect host]:host:' && ret=0
        ;;
    esac
    ;;
esac

return ret
