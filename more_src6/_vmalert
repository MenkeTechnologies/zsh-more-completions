#compdef vmalert
# Documentation: https://docs.victoriametrics.com/vmalert/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '*-rule=[rule file glob]:file:_files -g "*.(yaml|yml)"' \
  '-rule.evalDelay=[query latency compensation delay]:duration:' \
  '-rule.defaultRuleType=[default rule expression type]:type:(prometheus graphite vlogs)' \
  '-rule.templates=[reusable annotation templates]:file:_files' \
  '-rule.stripFilePath[strip file paths from logs/UI]' \
  '-evaluationInterval=[evaluation interval]:duration:' \
  '-datasource.url=[Prometheus-like datasource URL]:url:' \
  '-datasource.queryStep=[step for instant queries]:duration:' \
  '-datasource.basicAuth.username=[datasource basic auth user]:user:' \
  '-datasource.basicAuth.password=[datasource basic auth password]:password:' \
  '-datasource.bearerToken=[datasource bearer token]:token:' \
  '-datasource.showURL[expose datasource URL]' \
  '-remoteWrite.url=[remote write URL]:url:' \
  '-remoteRead.url=[remote read URL]:url:' \
  '-remoteRead.lookback=[lookback window for state restore]:duration:' \
  '*-notifier.url=[Alertmanager URL]:url:' \
  '-notifier.config=[notifier config file]:file:_files -g "*.(yaml|yml)"' \
  '-notifier.showURL[expose notifier URL]' \
  '-external.url=[external URL]:url:' \
  '-external.alert.source=[alert source template]:tpl:' \
  '*-external.label=[KEY=VALUE label]:label:' \
  '-replay.timeFrom=[replay start timestamp]:ts:' \
  '-replay.timeTo=[replay end timestamp]:ts:' \
  '-replay.maxDatapointsPerQuery=[replay datapoints per query]:n:' \
  '-replay.rulesDelay=[replay rule delay]:duration:' \
  '-httpListenAddr=[HTTP listen address]:addr:' \
  '-tls[enable TLS]' \
  '-tlsCertFile=[TLS cert file]:file:_files' \
  '-tlsKeyFile=[TLS key file]:file:_files' \
  '-mtls[enable mTLS]' \
  '-loggerLevel=[log level]:level:(INFO WARN ERROR FATAL PANIC)' \
  '-loggerFormat=[log format]:format:(default json)' \
  '(- *)-version[show version]' \
  '(- *)-help[show help]'
