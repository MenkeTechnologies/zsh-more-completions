#compdef zimbra zmprov zmcontrol
# _zimbra — Synacor Zimbra Collaboration enterprise mail/calendar/contacts server CLI suite (zimbra team, Java/Perl); custom argparse
# upstream: https://github.com/zimbra

_zimbra() {
    local -a sub=(
        'start:start zimbra services'
        'stop:stop zimbra services'
        'restart:restart zimbra services'
        'status:show service status'
        'reload:reload configuration'
        'rolloverlog:rollover log files'
        'shutdown:shutdown services'
        'maintenance:maintenance mode'
        'createAccount:create user account'
        'modifyAccount:modify user account'
        'deleteAccount:delete user account'
        'getAccount:get account info'
        'getAllAccounts:list all accounts'
        'createDomain:create domain'
        'deleteDomain:delete domain'
        'getDomain:get domain info'
        'createCos:create class of service'
        'getCos:get class of service'
        'createDistributionList:create distribution list'
        'addDistributionListMember:add list member'
        'removeDistributionListMember:remove list member'
        'getServer:get server config'
        'modifyServer:modify server config'
        'getAllConfig:dump global config'
        'modifyConfig:modify global config'
        'createCalendarResource:create calendar resource'
        'flushCache:flush ldap cache'
        'autoCompleteGal:autocomplete GAL'
        'searchGal:search GAL'
        'createIdentity:create identity'
        'getAuthTokenInfo:get auth token info'
        'getMailboxInfo:get mailbox info'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-l[ldap direct]' \
        '--ldap[ldap direct]' \
        '-z[zsoap]' \
        '--zadmin[zadmin auth]' \
        '-s+[server]:host:_hosts' \
        '--server=+[server]:host:_hosts' \
        '-a+[account]:str:' \
        '--account=+[account]:str:' \
        '-p+[password]:str:' \
        '--password=+[password]:str:' \
        '-u+[admin user]:user:_users' \
        '--user=+[admin user]:user:_users' \
        '-f+[file]:file:_files' \
        '--file=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zimbra subcommand' sub ;;
        args)
            case $words[1] in
                createAccount|modifyAccount|deleteAccount|getAccount) _arguments '*:email:_email_addresses' ;;
                createDomain|deleteDomain|getDomain) _arguments '*:domain:_hosts' ;;
                addDistributionListMember|removeDistributionListMember) _arguments \
                    '1:list:_email_addresses' \
                    '*:member:_email_addresses' ;;
            esac
            ;;
    esac
}

_zimbra "$@"
