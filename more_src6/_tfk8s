#compdef tfk8s
# Documentation: https://github.com/jrhouston/tfk8s
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# tfk8s: convert Kubernetes YAML manifests to Terraform HCL
local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-f --file)'{-f,--file}'=[input Kubernetes YAML manifests file]:file:_files' \
  '(-M --map-only)'{-M,--map-only}'[output only HCL map structure]' \
  '(-o --output)'{-o,--output}'=[output file for Terraform config]:file:_files' \
  '(-p --provider)'{-p,--provider}'=[provider alias]:provider:' \
  '(-s --strip)'{-s,--strip}'[strip server-side fields]' \
  '(-Q --strip-key-quotes)'{-Q,--strip-key-quotes}'[remove quotes from HCL map keys]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:file:_files -g "*.(yaml|yml)"' && ret=0

return ret
