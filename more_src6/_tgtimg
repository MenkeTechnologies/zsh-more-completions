#compdef tgtimg
# Documentation: https://manpages.debian.org/bookworm/tgt/tgtimg.8.en.html
# Reference accessed: 2026-05-21
# Verified: upstream man page at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-o --op)'{-o,--op}'+[operation]:op:(new show)' \
  '(-Y --device-type)'{-Y,--device-type}'+[device type]:type:(disk cd tape)' \
  '(-t --type)'{-t,--type}'+[media type]:type:' \
  '(-b --barcode)'{-b,--barcode}'+[barcode label]:label:' \
  '(-s --size)'{-s,--size}'+[size in MB]:mb:' \
  '(-f --file)'{-f,--file}'+[image file]:file:_files' \
  '(-T --thin-provisioning)'{-T,--thin-provisioning}'[enable sparse file allocation]' && ret=0

return ret
