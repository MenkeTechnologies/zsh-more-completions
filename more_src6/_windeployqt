#compdef windeployqt windeployqt6
# _windeployqt — Qt windeployqt (Windows deployment helper that copies all dependent Qt DLLs, plugins, and QML imports into the target binary directory; supports --release/--debug, --qmldir/--qmlimport, --no-translations, --compiler-runtime)
# upstream: https://github.com/qt/qttools (src/windeployqt)
# Flags from qttools src/windeployqt/main.cpp on tip.

_windeployqt() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-v+[verbose level]:level:(0 1 2 3)' \
        '--dry-run[do nothing; print actions]' \
        '--no-plugins[do not deploy plugins]' \
        '--no-libraries[do not deploy libraries]' \
        '--no-translations[no translations]' \
        '--no-system-d3d-compiler[no D3D compiler]' \
        '--no-virtualkeyboard[no virtual keyboard plugin]' \
        '--no-compiler-runtime[no MSVC runtime]' \
        '--no-opengl-sw[no software OpenGL]' \
        '--list+[mapping mode]:mode:(source target relative mapping)' \
        '--release[deploy release build]' \
        '--debug[deploy debug build]' \
        '--pdb[copy .pdb files]' \
        '--force[force overwrite]' \
        '--qmldir+[QML import root]:dir:_files -/' \
        '--qmlimport+[additional QML import dir]:dir:_files -/' \
        '--release-with-debug-info[release + .pdb]' \
        '--dir+[output dir]:dir:_files -/' \
        '*:binary:_files'
}

_windeployqt "$@"
