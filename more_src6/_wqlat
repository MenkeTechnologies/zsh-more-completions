#compdef wqlat wqlat-bpfcc
# _wqlat — kernel workqueue latency histogram (iovisor/bcc)
# upstream: https://github.com/iovisor/bcc
# Flags from tools/wqlat.py (argparse).

_wqlat() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-T --timestamp)'{-T,--timestamp}'[include timestamp on output]'
        '(-N --nanoseconds)'{-N,--nanoseconds}'[output in nanoseconds]'
        '(-W --workqueues)'{-W,--workqueues}'[print a histogram per workqueue]'
        '(-w --wqname)'{-w+,--wqname=}'[only print this workqueue]:name:'
        '1:interval (seconds):'
        '2:output count:'
    )
    _arguments $args
}

_wqlat "$@"
