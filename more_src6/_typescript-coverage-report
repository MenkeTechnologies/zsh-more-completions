    _arguments -s \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V -v --version)'{-V,-v,--version}'[show version]' \
        '(-o --outputDir)'{-o+,--outputDir=}'[output directory for HTML + terminal report (default coverage-ts)]:directory:_files -/' \
        '(-t --threshold)'{-t+,--threshold=}'[minimum percentage of coverage required (default 80)]:percentage:' \
        '(-s --strict)'{-s+,--strict=}'[run in strict mode]:bool:(true false)' \
        '(-d --debug)'{-d+,--debug=}'[show debug information]:bool:(true false)' \
        '(-c --cache)'{-c+,--cache=}'[save and reuse type check result from cache]:bool:(true false)' \
        '(-p --project)'{-p+,--project=}'[file path to tsconfig.json (default .)]:tsconfig file:_files -g "*.json"' \
        '*'{-i+,--ignore-files=}'[ignore specified files (repeat for multiple)]:glob:' \
        '--ignore-catch=[ignore any type for (try-)catch clause variable]:bool:(true false)' \
        '(-u --ignore-unread)'{-u+,--ignore-unread=}'[allow writes to variables with implicit any types]:bool:(true false)' \
        '*:files to check (after --):_files -g "*.(ts|tsx)"'
}

