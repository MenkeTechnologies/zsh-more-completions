#compdef waypipe
# Documentation: https://manpages.debian.org/testing/waypipe/waypipe.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'ssh:run waypipe over SSH'
      'server:run as server (acts as Wayland compositor for command)'
      'client:run as client (connect to local Wayland compositor)'
      'bench:estimate compression options for lowest latency'
    )
    _describe -t commands 'waypipe command' commands && ret=0
    ;;
  (args)
    # Global flags shared by all subcommands
    local -a _waypipe_globals=(
      '(-c --compress)'{-c,--compress}'=[compression method]:method:(none lz4 zstd)'
      '(-d --debug)'{-d,--debug}'[enable debug logging]'
      '(-h --help)'{-h,--help}'[show help]'
      '(-n --no-gpu)'{-n,--no-gpu}'[block GPU-related protocols]'
      '(-o --oneshot)'{-o,--oneshot}'[permit only a single connection]'
      '(-s --socket)'{-s,--socket}'=[unix socket path]:socket:_files'
      '--version[show version and features]'
      '--display=[wayland display socket]:display'
      '--drm-node=[DRM device path]:node:_files -W /dev/dri'
      '--threads=[thread count for compression]:threads'
      '--title-prefix=[prefix prepended to window titles]:prefix'
      '--video=[lossy video codec compression]:video'
      '--vsock[use vsock instead of unix sockets]'
    )
    case ${line[1]} in
      (ssh)
        _arguments -s -S \
          ${_waypipe_globals[@]} \
          '--remote-node=[remote DRM render node]:node' \
          '--ssh-bin=[ssh binary to use locally]:bin:_command_names' \
          '--remote-bin=[waypipe binary path on remote]:bin' \
          '--remote-socket=[socket path on remote]:socket' \
          '--secctx[use security-context Wayland protocol]' \
          '*:ssh arguments' && ret=0
        ;;
      (server)
        _arguments -s -S \
          ${_waypipe_globals[@]} \
          '--login-shell[wrap command in login shell]' \
          '--unlink-socket[unlink socket before binding]' \
          '--xwls[allow Xwayland clients]' \
          '*:command:_command_names' && ret=0
        ;;
      (client)
        _arguments -s -S \
          ${_waypipe_globals[@]} \
          '--secctx[use security-context Wayland protocol]' && ret=0
        ;;
      (bench)
        _arguments -s -S \
          ${_waypipe_globals[@]} && ret=0
        ;;
    esac
    ;;
esac

return ret
