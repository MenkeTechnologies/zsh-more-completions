#compdef wing
# Documentation: https://github.com/winglang/wing/blob/main/packages/winglang/src/cli.ts
# Reference accessed: 2026-05-21
# Verified: upstream source at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:Start local simulator (alias: it)'
  'it:Start local simulator (alias: run)'
  'compile:Compile Wing file'
  'test:Run tests'
  'secrets:Manage secrets'
  'new:Create new project from a template'
  'pack:Pack project into tarball'
  'lsp:Start the Wing Language Server'
  'docs:Open Wing documentation'
  'help:Show help'
)

_arguments -s -S \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'wing command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (run|it)
        _arguments -s -S \
          '(-p --port)'{-p,--port}'[port for Wing Console]:port:' \
          '--no-open[prevent browser from opening]' \
          '(-w --watch)'{-w,--watch}'[watch mode]' \
          '(-t --platform)'{-t,--platform}'+[platform provider]:platform:' \
          '--statedir[state directory]:dir:_directories' \
          '1:file:_files -g "*.w"' && ret=0
        ;;
      (compile)
        _arguments -s -S \
          '(-t --platform)'{-t,--platform}'+[platform provider]:platform:' \
          '(-r --rootId)'{-r,--rootId}'+[root construct id]:rootId:' \
          '(-o --output)'{-o,--output}'+[output directory]:dir:_directories' \
          '(-v --value)'{-v,--value}'+[platform value]:value:' \
          '--values[values file]:file:_files' \
          '1:file:_files -g "*.w"' && ret=0
        ;;
      (test)
        _arguments -s -S \
          '(-t --platform)'{-t,--platform}'+[platform provider]:platform:' \
          '(-s --snapshots)'{-s,--snapshots}'+[snapshot mode]:mode:(deploy never assert update)' \
          '(-r --rootId)'{-r,--rootId}'+[root construct id]:rootId:' \
          '(-f --test-filter)'{-f,--test-filter}'+[only run tests matching regex]:regex:' \
          '--no-clean[do not clean test outputs]' \
          '--no-stream[do not stream test logs]' \
          '(-o --output-file)'{-o,--output-file}'+[output file path]:file:_files' \
          '(-R --retry)'{-R,--retry}'+[retry failing tests]:count:' \
          '(-p --parallel)'{-p,--parallel}'+[number of tests to run in parallel]:n:' \
          '*:file:_files -g "*.w"' && ret=0
        ;;
      (secrets)
        _arguments -s -S \
          '(-t --platform)'{-t,--platform}'+[platform provider]:platform:' \
          '(-v --value)'{-v,--value}'+[secret value]:value:' \
          '--values[values file]:file:_files' \
          '--list[list secrets]' \
          '1:file:_files -g "*.w"' && ret=0
        ;;
      (new)
        _arguments -s -S \
          '(-l --language)'{-l,--language}'+[language]:language:' \
          '--list-templates[list available templates]' \
          '1:template:' && ret=0
        ;;
      (pack)
        _arguments -s -S \
          '(-o --out-file)'{-o,--out-file}'+[output tarball file]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
