#compdef zulip-term
# _zulip-term — official Zulip terminal client (zulip/zulip-terminal)
# upstream: https://github.com/zulip/zulip-terminal
# Flags from zulipterminal/cli/run.py (argparse).

_zulip-term() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-c --config-file)'{-c+,--config-file=}'[zuliprc config file]:file:_files' \
        '(-t --theme)'{-t+,--theme=}'[theme name]:theme:' \
        '--list-themes[list available themes]' \
        '--color-depth=[terminal color depth]:depth:(1 16 256 24bit)' \
        '(-d --debug)'{-d,--debug}'[debug mode]' \
        '(-e --explore)'{-e,--explore}'[explore mode (no read state changes)]' \
        '--profile[run with cProfile profiling]' \
        '(--autohide --no-autohide)--autohide[autohide right column]' \
        '(--autohide --no-autohide)--no-autohide[do not autohide right column]' \
        '(--notify --no-notify)--notify[enable desktop notifications]' \
        '(--notify --no-notify)--no-notify[disable desktop notifications]' \
        '(--transparency --no-transparency)--transparency[transparent background]' \
        '(--transparency --no-transparency)--no-transparency[opaque background]'
}

_zulip-term "$@"
