#compdef whatnow
# Documentation: man whatnow(1)
# Source: nmh uip/whatnowsbr.c (master) — prompt for disposition of a draft (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-draftfolder+[draft folder]:folder:_default' \
    '-draftmessage+[draft message]:msg:_default' \
    '-nodraftfolder[no draft folder]' \
    '-editor+[editor]:cmd:_command_names -e' \
    '-noedit[no edit]' \
    '-prompt+[prompt string]:prompt:_default' \
    '-version[show version]' \
    '-help[show help]' \
    '(-attach -noattach)*-attach+[attach header field]:field:_default' \
    '(-attach -noattach)-noattach[no attach header]' \
    '1::draft file:_files' \
    && ret=0

return ret
