#compdef wsmuxctl
# Documentation: man wsmuxctl(8)
# Source: netbsd/src usr.sbin/wsmuxctl — wsmux input multiplexer control (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a+[add device to the mux]:device (wsmouseN, wskbdN, wsmuxN):_default' \
    '-f+[control device (or mux number)]:ctldev:_default' \
    '-l[list devices connected to the mux]' \
    '-L[list devices, recurse into mux subdevices]' \
    '-r+[remove device from the mux]:device (wsmouseN, wskbdN, wsmuxN):_default' \
    && ret=0

return ret
