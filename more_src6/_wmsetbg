#compdef wmsetbg
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/wmsetbg.1.html
# Reference accessed: 2026-05-21
# Verified: upstream Ubuntu jammy wmsetbg(1) man page OPTIONS list.
# Previous file had fabricated -W/-back/-update-domain etc; replaced with the
# documented long/short forms.

# wmsetbg: Window Maker tool to set root background
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '-display+[X display]:display' \
  '(-b --back-color)'{-b,--back-color}'+[background color for texture]:color' \
  '(-d --dither)'{-d,--dither}'[enable color dithering]' \
  '(-m --match)'{-m,--match}'[use best-matching-color algorithm]' \
  '(-S --smooth)'{-S,--smooth}'[use smooth scaling algorithm]' \
  '(-c --colors)'{-c,--colors}'+[limit colors per channel]:count' \
  '(-t --tile)'{-t,--tile}'[tile image]' \
  '(-e --center)'{-e,--center}'[center image on screen]' \
  '(-s --scale)'{-s,--scale}'[scale to fill screen (default)]' \
  '(-a --maxscale)'{-a,--maxscale}'[scale to fit, preserving aspect ratio]' \
  '(-f --fillscale)'{-f,--fillscale}'[scale to fill, preserving aspect ratio]' \
  '(-X --xinerama)'{-X,--xinerama}'[stretch across Xinerama heads]' \
  '(-D --update-domain)'{-D,--update-domain}'+[update specified domain database]:domain' \
  '(-u --update-wmaker)'{-u,--update-wmaker}'[update Window Maker defaults]' \
  '(-w --workspace)'{-w,--workspace}'+[update background for workspace]:workspace' \
  '(-p --parse)'{-p,--parse}'+[parse texture as proplist style]:texture' \
  '*:image:_files' && ret=0
return ret
