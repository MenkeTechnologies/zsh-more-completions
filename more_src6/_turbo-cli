#compdef turbo-cli
# _turbo-cli — Vercel Turborepo high-perf monorepo build orchestrator CLI alias (Vercel, Go); spf13/cobra
# upstream: https://github.com/vercel/turborepo

_turbo-cli() {
    local -a sub=(
        'run:run pipeline tasks'
        'prune:produce subset of monorepo'
        'login:login to Vercel'
        'logout:logout from Vercel'
        'link:link to Vercel team'
        'unlink:unlink from Vercel team'
        'bin:print binary path'
        'completion:generate shell completion'
        'config:read configuration'
        'daemon:daemon commands'
        'gen:generate code with workflows'
        'generate:run code generator (alias)'
        'info:show project info'
        'ls:list workspaces and tasks'
        'tel:telemetry commands'
        'telemetry:telemetry commands (alias)'
        'unwatch:cancel watch session'
        'watch:run pipeline in watch mode'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--cwd=+[change working dir]:dir:_files -/' \
        '--single-package[single package mode]' \
        '--cache-dir=+[cache dir]:dir:_files -/' \
        '--cache-workers=+[cache workers]:n:' \
        '--api=+[api url]:url:_urls' \
        '--team=+[team slug]:str:' \
        '--token=+[api token]:str:' \
        '--login=+[login url]:url:_urls' \
        '--remote-cache-timeout=+[remote cache timeout]:n:' \
        '--no-cache[no cache]' \
        '--no-update-notifier[no update notifier]' \
        '--summarize[summarize execution]' \
        '--no-summarize[no summarize]' \
        '--anon-profile=+[anonymous profile]:str:' \
        '--profile=+[profile]:str:' \
        '--trace=+[trace file]:file:_files' \
        '--heap=+[heap profile]:file:_files' \
        '--cpuprofile=+[cpu profile]:file:_files' \
        '--verbosity=+[verbosity]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'turbo subcommand' sub ;;
        args)
            case $words[1] in
                run|watch) _arguments \
                    '--filter=+[filter]:list:' \
                    '-F+[filter]:list:' \
                    '--continue[continue on error]' \
                    '--force[force]' \
                    '--parallel[parallel]' \
                    '--concurrency=+[concurrency]:n:' \
                    '--cache-dir=+[cache dir]:dir:_files -/' \
                    '--cache-workers=+[cache workers]:n:' \
                    '--dry-run[dry run]' \
                    '--dry-run=json[dry run json]' \
                    '--env-mode=+[env mode]:m:(strict loose)' \
                    '--framework-inference[framework inference]' \
                    '--global-deps=+[global deps]:list:' \
                    '--graph=+[graph file]:str:' \
                    '--ignore=+[ignore patterns]:list:' \
                    '--include-dependencies[include dependencies]' \
                    '--include-dependents[include dependents]' \
                    '--no-cache[no cache]' \
                    '--no-daemon[no daemon]' \
                    '--no-deps[no deps]' \
                    '--only[only run task]' \
                    '--output-logs=+[output logs]:m:(full none hash-only new-only errors-only)' \
                    '--log-order=+[log order]:o:(grouped stream)' \
                    '--log-prefix=+[log prefix]:p:(auto none task)' \
                    '--log-level=+[log level]:level:(silent error warn info debug)' \
                    '--pkg-inference-root=+[pkg inference root]:dir:_files -/' \
                    '--remote-only[remote cache only]' \
                    '--remote-cache-read-only[remote cache read only]' \
                    '*:task:' ;;
                prune) _arguments \
                    '--scope=+[scope]:str:' \
                    '--docker[docker mode]' \
                    '--out-dir=+[out dir]:dir:_files -/' \
                    '*:arg:' ;;
                gen|generate) _arguments \
                    '--config=+[config file]:file:_files' \
                    '--root=+[root dir]:dir:_files -/' \
                    '*:generator:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_turbo-cli "$@"
