#compdef wasirun
# _wasi — WASI runtime wasirun (aspect-build/wasirun)
# upstream: https://github.com/aspect-build/wasirun

_wasi() {
    _arguments -s -S \
        '*--dir=[preopen directory]:dir:_directories' \
        '*--mapdir=[map guest dir to host dir]:mapping:' \
        '*--env=[set environment variable]:var=value:' \
        '--help[show help]' \
        '--version[show version]' \
        '1:wasm file:_files -g "*.wasm"' \
        '*:args:'
}

_wasi "$@"
