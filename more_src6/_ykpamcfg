#compdef ykpamcfg
# _ykpamcfg — Yubico ykpamcfg CLI helper for configuring pam_yubico challenge-response-based PAM authentication enrolling a YubiKey HMAC-SHA1 challenge-response credential file in ~/.yubico/challenge for offline Linux PAM sudo/login/screensaver flows (Yubico team, C); custom argparse
# upstream: https://developers.yubico.com/yubico-pam/

_ykpamcfg() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-2[use slot 2]' \
        '-1[use slot 1]' \
        '-A+[action]:a:(add_hmac_chalresp)' \
        '--action=+[action]:a:(add_hmac_chalresp)' \
        '-p+[path]:dir:_files -/' \
        '--path=+[path]:dir:_files -/' \
        '-i+[iteration count]:n:' \
        '--iterations=+[count]:n:' \
        '*:action:'
}

_ykpamcfg "$@"
