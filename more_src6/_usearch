#compdef usearch
# _usearch — Robert Edgar usearch CLI ultra-fast sequence database search clustering OTU-picking taxonomic classification chimera detection alpha beta diversity 16S 18S ITS amplicon-pipeline UPARSE UNOISE SINTAX OTUcluster sintax_lca closed-reference reference-free pipelines 32-bit free 64-bit licensed (Robert Edgar team, C++); getopt
# upstream: https://www.drive5.com/usearch/

_usearch() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-quiet[quiet]' \
        '-threads+[N]:n:' \
        '-cluster_fast+[file]:file:_files -g "*.fa *.fasta"' \
        '-cluster_otus+[file]:file:_files -g "*.fa *.fasta"' \
        '-cluster_smallmem+[file]:file:_files -g "*.fa *.fasta"' \
        '-cluster_agg+[file]:file:_files -g "*.fa *.fasta"' \
        '-unoise3+[file]:file:_files -g "*.fa *.fasta"' \
        '-uparse_ref+[file]:file:_files -g "*.fa *.fasta"' \
        '-uchime2_ref+[file]:file:_files -g "*.fa *.fasta"' \
        '-uchime3_denovo+[file]:file:_files -g "*.fa *.fasta"' \
        '-usearch_global+[file]:file:_files -g "*.fa *.fasta"' \
        '-usearch_local+[file]:file:_files -g "*.fa *.fasta"' \
        '-fastq_filter+[file]:file:_files -g "*.fq *.fastq *.gz"' \
        '-fastq_mergepairs+[file]:file:_files -g "*.fq *.fastq *.gz"' \
        '-fastq_eestats+[file]:file:_files -g "*.fq *.fastq"' \
        '-fastq_chars+[file]:file:_files -g "*.fq *.fastq"' \
        '-fastx_truncate+[file]:file:_files -g "*.fa *.fastq"' \
        '-fastx_uniques+[file]:file:_files -g "*.fa *.fastq"' \
        '-fastx_subsample+[file]:file:_files -g "*.fa *.fastq"' \
        '-makeudb_usearch+[file]:file:_files -g "*.fa *.fasta"' \
        '-makeudb_sintax+[file]:file:_files -g "*.fa *.fasta"' \
        '-sintax+[file]:file:_files -g "*.fa *.fasta"' \
        '-id+[N]:n:' \
        '-strand+[s]:s:(plus both)' \
        '-centroids+[file]:file:_files' \
        '-consout+[file]:file:_files' \
        '-uc+[file]:file:_files' \
        '-db+[file]:file:_files' \
        '-output+[file]:file:_files' \
        '-fastaout+[file]:file:_files' \
        '-fastqout+[file]:file:_files' \
        '-blast6out+[file]:file:_files' \
        '-samout+[file]:file:_files' \
        '-tabbedout+[file]:file:_files' \
        '-minsize+[N]:n:' \
        '-maxaccepts+[N]:n:' \
        '-maxrejects+[N]:n:' \
        '-top_hits_only[top hits only]' \
        '-sizein[size annotation in]' \
        '-sizeout[size annotation out]' \
        '-relabel+[prefix]:str:' \
        '-otutab+[file]:file:_files' \
        '-alpha_div+[file]:file:_files' \
        '*::'
}

_usearch "$@"
