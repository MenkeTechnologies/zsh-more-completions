#compdef veritysetup
# _veritysetup — cryptsetup veritysetup (manage dm-verity volumes: format builds a hash tree, verify checks data + hash device match, open/close attaches the dm-verity device-mapper target; --hash chooses the digest, --data-block-size and --hash-block-size, --salt, --fec-device for forward error correction)
# upstream: https://gitlab.com/cryptsetup/cryptsetup
# Subcommands from cryptsetup src/veritysetup.c on tip.

_veritysetup() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '--hash+[hash algorithm]:hash:(sha256 sha384 sha512 sha224 sha1)' \
        '--data-block-size+[bytes]:bytes:' \
        '--hash-block-size+[bytes]:bytes:' \
        '--data-blocks+[number]:n:' \
        '--hash-offset+[bytes]:bytes:' \
        '--salt+[hex salt]:salt:' \
        '--uuid+[UUID]:uuid:' \
        '--fec-device+[FEC device]:device:_files' \
        '--fec-offset+[bytes]:bytes:' \
        '--fec-roots+[roots]:roots:' \
        '--root-hash-file+[file]:file:_files' \
        '--root-hash-signature+[file]:file:_files' \
        '--ignore-corruption[do not panic on corruption]' \
        '--restart-on-corruption[restart on corruption]' \
        '--panic-on-corruption[kernel panic on corruption]' \
        '--ignore-zero-blocks[trust zero blocks]' \
        '--check-at-most-once[check each block once]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'veritysetup command' '(format verify open close status dump)' ;;
        args) _arguments '*:device or name:_files' ;;
    esac
}

_veritysetup "$@"
