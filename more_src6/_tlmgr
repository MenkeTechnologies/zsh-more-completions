#compdef tlmgr
# Documentation: tlmgr help
# Source: TeX Live tlmgr — native TeX Live package manager.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a verbs
verbs=(
    'backup:back up a package'
    'bug:open a bug report'
    'candidates:list candidate versions'
    'check:check installation (depends/executes/files/runfiles/texmfdbs/all)'
    'conf:show/set tlmgr/tex/texmf-config settings'
    'dump-tlpdb:dump TeX Live package database'
    'generate:generate config files (fmtutil/language/updmap)'
    'gui:start the tlmgr GUI'
    'help:show help'
    'info:show info on a package'
    'init-usertree:initialize a user TeX tree'
    'install:install packages'
    'key:add/list/remove repository keys'
    'list:list packages (collections/schemes/all)'
    'option:set/get configuration option'
    'paper:set/show paper size'
    'path:add/remove tlmgr to/from PATH symlink dirs'
    'pinning:list/add/remove repository pinnings'
    'platform:list/add/remove/set platforms'
    'postaction:install/remove postactions'
    'print-platform:print current platform tag'
    'print-platform-info:print platform detection details'
    'remove:remove packages'
    'repository:list/add/remove/status repositories'
    'restore:restore previously backed-up package'
    'search:search for packages/files'
    'shell:start interactive tlmgr shell'
    'show:show package details (alias for info)'
    'uninstall:uninstall TeX Live'
    'update:update installed packages'
    'version:show version'
)

local -a global_opts
global_opts=(
    '--gui[start the GUI]'
    '--gui-lang=[GUI language]:lang:'
    '*--repository=[repository URL or alias]:url:'
    '(-q --quiet)'{-q,--quiet}'[no informational output]'
    '--verify-repo=[repository verification level]:level:(all main none)'
    '--no-execute-actions[skip postactions]'
    '--machine-readable[machine-readable output]'
    '(--usermode --user-mode)'{--usermode,--user-mode}'[work on per-user tree]'
    '--debug-translation[debug language translations]'
    '(--persistent-downloads --no-persistent-downloads)--persistent-downloads[enable persistent downloads]'
    '(--persistent-downloads --no-persistent-downloads)--no-persistent-downloads[disable persistent downloads]'
    '--pause[pause before exit]'
    '--pin-file=[pinning file]:file:_files'
    '(- *)--print-platform[print current platform tag]'
    '(- *)--print-platform-info[print platform detection details]'
    '(- *)--version[show version]'
    '(- *)--help[show help]'
)

_arguments -C \
    $global_opts \
    '1: :->verb' \
    '*:: :->args' \
    && ret=0

case $state in
    verb)
        _describe -t tlmgr-verbs 'tlmgr command' verbs && ret=0
        ;;
    args)
        case $line[1] in
            install|remove|update|info|show|search|backup|restore|candidates)
                _arguments \
                    $global_opts \
                    '--all[apply to all packages]' \
                    '--list[show what would be done]' \
                    '--reinstall-forcibly-removed[reinstall force-removed]' \
                    '--dry-run[no-op]' \
                    '*:package:' \
                    && ret=0
                ;;
            *) _files && ret=0 ;;
        esac
        ;;
esac

return ret
