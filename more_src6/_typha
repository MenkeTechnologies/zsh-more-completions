#compdef typha calico-typha
# Documentation: https://github.com/projectcalico/calico
# Reference accessed: 2026-05-21
# Verified: upstream typha/cmd/typha/command.go cobra arg parser.

# Typha: Calico datastore fan-out proxy
local curcontext="$curcontext" state line ret=1
local -a _typha_cmds

_typha_cmds=(
  'version:print version information'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --config-file)'{-c+,--config-file=}'[config file to load]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'typha command' _typha_cmds && ret=0 ;;
esac

return ret
