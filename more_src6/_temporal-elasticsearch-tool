#compdef temporal-elasticsearch-tool
# _temporal-elasticsearch-tool — Temporal Elasticsearch index/schema tool (temporalio/temporal)
# upstream: https://github.com/temporalio/temporal
# Subcommands from tools/elasticsearch/main.go (urfave/cli).

_temporal-elasticsearch-tool() {
    local context state state_descr line
    typeset -A opt_args
    local -a common=(
        '--endpoint=[elasticsearch endpoint URL]:url:_urls'
        '--user=[ES user or aws_access_key_id]:user:'
        '--password=[ES password or aws_secret_access_key]:pw:'
        '(--aws --aws-credentials)'{--aws=,--aws-credentials=}'[AWS credentials provider]:provider:(static environment aws-sdk-default)'
        '--aws-session-token=[AWS session token (with static provider)]:token:'
        '(-q --quiet)'{-q,--quiet}'[do not log errors to stderr]'
        '--tls[enable TLS]'
        '--tls-cert-file=[TLS cert file]:file:_files'
        '--tls-key-file=[TLS key file]:file:_files'
        '--tls-ca-file=[TLS CA file]:file:_files'
        '--tls-disable-host-verification[disable TLS host verification]'
        '--tls-server-name=[TLS server name for verification]:host:'
    )

    _arguments -C \
        $common \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                setup-schema:'setup Elasticsearch index template'
                update-schema:'update Elasticsearch index template'
                create-index:'create an Elasticsearch index'
                drop-index:'drop an Elasticsearch index'
                ping:'ping the Elasticsearch server'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                setup-schema|update-schema)
                    _arguments $common \
                        '(-f --schema-file)'{-f+,--schema-file=}'[ES schema file]:file:_files' \
                        '--skip-cluster-settings[skip applying cluster settings]' \
                        '--fail[fail silently if version already applied]' ;;
                create-index)
                    _arguments $common \
                        '(-i --index)'{-i+,--index=}'[index name]:name:' \
                        '(-f --schema-file)'{-f+,--schema-file=}'[index mapping file]:file:_files' ;;
                drop-index)
                    _arguments $common \
                        '(-i --index)'{-i+,--index=}'[index name]:name:' \
                        '(-f --force)'{-f,--force}'[do not prompt]' ;;
            esac
            ;;
    esac
}

_temporal-elasticsearch-tool "$@"
