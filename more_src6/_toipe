#compdef toipe
# Documentation: https://github.com/Samyak2/toipe
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-n+[number of words]:count:' \
  '-w+[word list]:word list:(top250 os)' \
  '-f+[custom word file]:word file:_files' \
  '-p[add punctuation and sentence case]' && ret=0

return ret
