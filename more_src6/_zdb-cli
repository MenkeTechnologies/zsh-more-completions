#compdef zdb-cli
# _zdb-cli — OpenZFS zdb debugger CLI alias (openzfs team, C); custom argparse
# upstream: https://github.com/openzfs/zfs

_zdb-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-V[show version]' \
        '-A[ignore errors]' \
        '-AAA[corruption tolerance high]' \
        '-b[block statistics]' \
        '-B+[uberblock]:n:' \
        '-c[verify checksums]' \
        '-cc[verify checksums (also gang blocks)]' \
        '-C[config printout]' \
        '-d[dataset statistics]' \
        '-dd[dataset statistics with detail]' \
        '-D[deduplicated block statistics]' \
        '-DD[ddt verbose]' \
        '-e[exported pool]' \
        '-E+[dataset]:str:' \
        '-F[force pool open]' \
        '-G[debug messages]' \
        '-h[print history]' \
        '-i[dump intent log entries]' \
        '-I+[depth]:n:' \
        '-K+[hex]:str:' \
        '-l+[device]:_files' \
        '-L[disable leak]' \
        '-m[show metaslab info]' \
        '-M[show metaslab info verbose]' \
        '-n+[uberblock]:n:' \
        '-N[force open pool no DSL]' \
        '-O+[options]:str:' \
        '-o+[option]:str:' \
        '-p+[path]:dir:_files -/' \
        '-P[plain text]' \
        '-q[quiet]' \
        '-R+[poolname:vdev:offset:size:flags]:str:' \
        '-r+[copy file from snapshot]:str:' \
        '-s[stats]' \
        '-S+[options]:str:' \
        '-t+[txg]:n:' \
        '-T+[txg]:n:' \
        '-u[show uberblock]' \
        '-U+[cachefile]:file:_files' \
        '-v[verbose]' \
        '-vv[more verbose]' \
        '-vvv[max verbose]' \
        '-V+[txg]:n:' \
        '-x+[block]:str:' \
        '-X[extreme rewind]' \
        '-Y[txg rewind]' \
        '-y[validate block layout]' \
        '*:pool dataset:'
}

_zdb-cli "$@"
