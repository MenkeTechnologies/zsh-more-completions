#compdef vim-tiny
# Documentation: https://vimhelp.org/starting.txt.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above. vim-tiny is a minimal build
# with no GUI and many features disabled, but the CLI flag set is the
# same subset of vim's standard options.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-v[start in Vi mode (when invoked as ex or gvim)]' \
  '-e[start in Ex mode]' \
  '-E[start in improved Ex mode]' \
  '-s[silent (batch) Ex mode (with -e or as ex)]' \
  '-R[read-only mode]' \
  '-d[start in diff mode]' \
  '-y[easy mode (insert mode, click-and-type)]' \
  '-Z[restricted mode (no external shell)]' \
  '-m[modifications not allowed to be written]' \
  '-M[modifications not allowed (no commands)]' \
  '-N[no-compatible (default for vim)]' \
  '-V+[verbose level (default 10)]:level:' \
  '-D[debug mode]' \
  '-r[recover edit session (list swap files if no name)]' \
  '-L[same as -r]' \
  '-T+[set terminal type]:term:' \
  '-u+[use this vimrc; skip most other init]:file:_files' \
  '-i+[use this viminfo instead of default]:file:_files' \
  '--noplugin[skip loading plugins]' \
  '-p+[open N tab pages (or one per file)]:n:' \
  '-o+[open N horizontal split windows]:n:' \
  '-O+[open N vertical split windows]:n:' \
  '-S+[source file after first file is read]:file:_files -g "*.vim"' \
  '-W+[record keystrokes (overwrite)]:file:_files' \
  '-w+[record keystrokes (append)]:file:_files' \
  '*-c+[execute Ex command after first file]:cmd:' \
  '*--cmd+[execute Ex command before vimrc]:cmd:' \
  '-C[compatible mode (set compatible option)]' \
  '-X[do not connect to X server]' \
  '--not-a-term[suppress warning when stdin/stdout is not a terminal]' \
  '*:files:_files' && ret=0
return ret
