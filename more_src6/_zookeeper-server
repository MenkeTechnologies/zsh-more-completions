#compdef zookeeper-server
# Documentation: https://zookeeper.apache.org/doc/r3.9.1/zookeeperAdmin.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# zookeeper-server wraps zkServer.sh: start|stop|restart|status|upgrade|print-cmd

local curcontext="$curcontext" ret=1
_arguments -C \
  '1:action:(start stop restart status upgrade print-cmd help)' \
  '*::zookeeper-server args:_files' && ret=0
return ret
