#compdef textual
# Documentation: https://github.com/Textualize/textual-dev (src/textual_dev/cli.py click)
# Reference accessed: 2026-05-30
# textual — development tools CLI for Textual (TUI framework). Ships separately as textual-dev package.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'run:execute a Textual application (FILE or FILE\:APP)'
  'serve:run a local web server hosting the application'
  'console:launch the textual development console (log viewer)'
  'borders:explore available border styles in Textual'
  'easing:explore animation easing functions available in Textual'
  'colors:explore the Textual design system colors'
  'keys:show key events (useful for binding development)'
  'diagnose:print Textual environment information'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show textual-dev version]' \
  '1: :->subcmd' \
  '*:: :->args' && ret=0

case $state in
  subcmd)
    _describe -t commands 'textual subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      console)
        _arguments \
          '--port=[port for development mode console (default DEVTOOLS_PORT)]:port:' \
          '(-v --verbose)'{-v,--verbose}'[enable verbose logs]' \
          '*'{-x,--exclude=}'[exclude log group(s); repeatable]:group:(EVENT DEBUG INFO WARNING ERROR SYSTEM LOGGING PRINT)' \
          && ret=0
        ;;
      run)
        _arguments \
          '--dev[enable development mode (connects to console)]' \
          '--host=[development console host (default DEVTOOLS_HOST)]:host:_hosts' \
          '--port=[development console port (default DEVTOOLS_PORT)]:port:' \
          '--press=[CSV keys to simulate]:keys:' \
          '--screenshot=[capture screenshot after DELAY seconds]:delay:' \
          '--screenshot-path=[target directory for screenshot]:dir:_directories' \
          '--screenshot-filename=[screenshot filename]:name:' \
          '(-c --command)'{-c,--command}'[run as command rather than file/module]' \
          '(-r --show-return)'{-r,--show-return}'[display return value on exit]' \
          '1:import_name (FILE or FILE\:APP):_files -g "*.py"' \
          '*:extra args:' \
          && ret=0
        ;;
      serve)
        _arguments \
          '--dev[enable debug mode]' \
          '(-h --host)'{-h,--host=}'[server host (default localhost)]:host:_hosts' \
          '(-p --port)'{-p,--port=}'[server port (default 8000)]:port:' \
          '(-t --title)'{-t,--title=}'[app name being served (default "Textual App")]:title:' \
          '(-u --url)'{-u,--url=}'[public URL]:url:' \
          '(-c --command)'{-c,--command}'[run as command]' \
          '1:import_name (FILE or FILE\:APP):_files -g "*.py"' \
          '*:extra args:' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
