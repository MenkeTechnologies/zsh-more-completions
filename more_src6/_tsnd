#compdef tsnd ts-node-dev
# Documentation: https://github.com/wclr/ts-node-dev

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--respawn[restart on file changes even if script exits]' \
  '--deps=[watch node_modules dependencies]:level:(-1 0 1)' \
  '--notify=[notify on restart (desktop notification)]:notify:(true false)' \
  '*--ignore-watch=[file patterns to ignore]:pattern:' \
  '--interval=[poll interval for file watcher in ms]:ms:' \
  '--debounce=[debounce restart delay in ms]:ms:' \
  '--clear[clear screen on restart]' \
  '--cls[clear screen on restart]' \
  '--exit-child[exit child process on termination]' \
  '--rs[allow restart by typing "rs" in terminal]' \
  '--poll[use polling for file watching]' \
  '--watch=[paths to watch (comma-separated)]:paths:_files -/' \
  '--debug[enable debug output]' \
  '--quiet[suppress output from ts-node-dev]' \
  '--transpile-only[skip type checking (pass to ts-node)]' \
  '--type-check[enable type checking]' \
  '--compiler=[compiler to use]:compiler:(ts-node ttypescript)' \
  '--project=[TypeScript config file]:file:_files -g "*.json"' \
  '--compiler-options=[JSON string of compiler options]:options:' \
  '--prefer-ts[prefer .ts over .js when resolving]' \
  '--prefer-ts-exts[prefer .ts extensions over .js]' \
  '--log-error[log errors to stderr]' \
  '--no-deps[do not watch dependencies]' \
  '--cache-directory=[custom cache directory]:dir:_files -/' \
  '*:script:_files -g "*.ts"' \
  && return 0
