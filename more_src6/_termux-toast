#compdef termux-toast
# Documentation: https://github.com/termux/termux-api-package/blob/master/scripts/termux-toast.in
# Reference accessed: 2026-05-27
# Verified: upstream termux-api-package scripts/termux-toast.in show_usage()/getopts.


# Show text in a Toast (a transient popup)

_arguments \
  '-h[show this help]' \
  '-b+[set background color (default\: gray)]:value:' \
  '-c+[set text color (default\: white)]:value:' \
  '-g+[set position of toast\: \[top, middle, or bottom\] (default\: middle)]:value:' \
  '-s[only show the toast for a short while]'
