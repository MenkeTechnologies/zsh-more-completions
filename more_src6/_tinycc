#compdef tcc tinycc
# Documentation: https://bellard.org/tcc/tcc-doc.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-v[show version]' \
  '-vv[show included files]' \
  '-vvv[show include search attempts]' \
  '-c[compile only, do not link]' \
  '-o+[set output file]:output file:_files' \
  '-E[preprocess only]' \
  '-run[compile and run source immediately]' \
  '-I+[add include directory]:directory:_directories' \
  '-L+[add library search directory]:directory:_directories' \
  '-l+[link with library]:library' \
  '-D+[define preprocessor symbol]:name[=value]' \
  '-U+[undefine preprocessor symbol]:name' \
  '-w[suppress all warnings]' \
  '-Wall[enable most warnings]' \
  '-Werror[treat warnings as errors]' \
  '-Wimplicit-function-declaration[warn on implicit fn declaration]' \
  '-Wunsupported[warn about unsupported GCC features]' \
  '-Wwrite-strings[const string pointers]' \
  '-g[generate debug information]' \
  '-O+[optimization level]:level' \
  '-m32[generate 32-bit code]' \
  '-m64[generate 64-bit code]' \
  '-mms-bitfields[use MSVC bitfield alignment]' \
  '-mfloat-abi=[ARM float ABI]:abi' \
  '-mno-sse[disable SSE on x86_64]' \
  '-shared[generate a shared library]' \
  '-soname+[set shared library runtime name]:name' \
  '-rdynamic[export all global symbols to dynamic linker]' \
  '-r[combine inputs into one object file]' \
  '-static[link statically]' \
  '-Wl,[pass option to linker]:linker option' \
  '-b[runtime bounds checking (i386 only)]' \
  '-bt+[stack trace caller count]:count' \
  '-bench[output compilation statistics]' \
  '-B+[set tcc internal library path]:directory:_directories' \
  '-MD[generate dependency makefile fragment]' \
  '-MF+[set dependency output file]:file:_files' \
  '-dumpversion[display version and exit]' \
  '-print-search-dirs[print installation paths]' \
  '-funsigned-char[unsigned char type]' \
  '-fsigned-char[signed char type]' \
  '-fno-common[no common symbols for uninitialized data]' \
  '-fleading-underscore[prepend underscore to symbols]' \
  '-fms-extensions[Microsoft C extensions]' \
  '-fdollars-in-identifiers[allow $ in identifiers]' \
  '*:source file:_files -g "*.(c|h|i|s|S|o|a|so)"' && ret=0

return ret
