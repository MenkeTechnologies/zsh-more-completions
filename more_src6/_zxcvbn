#compdef zxcvbn
# Documentation: https://github.com/dropbox/zxcvbn
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# dropbox/zxcvbn ships only as a library (no official CLI binary). This
# completion targets the common third-party wrappers (gamontal/zxcvbn-cli
# npm + zxcvbn-cli Rust crate). Flags: -h/--help, -V/--version,
# -l/--limit-results, -S/--sequence, -s/--crack-times-sec, -j/--json,
# -i/--stdin.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --user-input and --max-length (those are library options,
# not CLI flags).

local ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-l --limit-results)'{-l,--limit-results}'[show only score+warning+suggestions]' \
  '(-S --sequence)'{-S,--sequence}'[show match sequence]' \
  '(-s --crack-times-sec)'{-s,--crack-times-sec}'[show crack times in seconds]' \
  '(-j --json)'{-j,--json}'[JSON output]' \
  '(-i --stdin)'{-i,--stdin}'[read password from stdin]' \
  '1:password:' && ret=0
return ret
