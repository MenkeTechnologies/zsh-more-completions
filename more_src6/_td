#compdef td
# Documentation: https://github.com/Swatto/td
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Swatto/td — urfave/cli/v2 todo manager

local curcontext="$curcontext" ret=1 expl

_arguments -C \
  '(-d --done)'{-d,--done}'[print completed todos]' \
  '(-a --all)'{-a,--all}'[print all todos]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[print version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  local -a commands
  commands=(
    'init:Initialize a collection of todos'
    'i:Initialize a collection of todos'
    'add:Add a new todo'
    'a:Add a new todo'
    'modify:Modify the text of an existing todo'
    'm:Modify the text of an existing todo'
    'toggle:Toggle the status of a todo by giving its id'
    't:Toggle the status of a todo by giving its id'
    'clean:Remove finished todos from the list'
    'reorder:Reset ids or swap position of two todos'
    'r:Reset ids or swap position of two todos'
    'search:Search a string in all todos'
    's:Search a string in all todos'
    'help:Show help'
    'h:Show help'
  )
  _describe -t cmds 'td command' commands && ret=0
  ;;
rest)
  case $line[1] in
    add|a|modify|m|search|s)
      _arguments '1:todo text:' && ret=0
      ;;
    toggle|t)
      _arguments '1:todo id:' && ret=0
      ;;
    reorder|r)
      _arguments '1:id A:' '2:id B:' && ret=0
      ;;
    *)
      _normal && ret=0
      ;;
  esac
  ;;
esac

return ret
