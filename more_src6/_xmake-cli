#compdef xmake-cli
# _xmake-cli — TBoox xmake modern cross-platform build tool CLI alias (TBoox, Lua); custom argparse
# upstream: https://github.com/xmake-io/xmake

_xmake-cli() {
    local -a sub=(
        'build:build targets'
        'clean:clean artifacts'
        'config:configure build'
        'create:scaffold a new project'
        'doxygen:run doxygen'
        'environment:show environment'
        'env:show environment (alias)'
        'fetch:fetch upstream'
        'format:format xmake.lua'
        'global:set global config'
        'install:install targets'
        'l:run lua script'
        'log:show log'
        'macro:run macro'
        'package:create package'
        'plugin:plugin commands'
        'project:project commands'
        'pack:create package alias'
        'remote:remote commands'
        'repo:manage repos'
        'require:manage required packages'
        'run:run targets'
        'show:show information'
        'service:remote build service'
        'test:run tests'
        'uninstall:uninstall'
        'update:update xmake'
        'upgrade:upgrade xmake'
        'watch:watch files and rebuild'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-D[show debug info]' \
        '--diagnosis[show debug info]' \
        '--backtrace[show backtrace]' \
        '--profile[profile]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-y[yes]' \
        '--yes[yes]' \
        '--confirm=+[confirm]:b:(y n d)' \
        '--root[run as root]' \
        '-F+[xmake.lua file]:file:_files -g "xmake.lua"' \
        '--file=+[xmake.lua file]:file:_files -g "xmake.lua"' \
        '-P+[project dir]:dir:_files -/' \
        '--project=+[project dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'xmake subcommand' sub ;;
        args)
            case $words[1] in
                build|b) _arguments \
                    '--all[all targets]' \
                    '-a[all targets]' \
                    '--jobs=+[jobs]:n:' \
                    '-j+[jobs]:n:' \
                    '--rebuild[rebuild]' \
                    '-r[rebuild]' \
                    '*:target:' ;;
                config|f) _arguments \
                    '--plat=+[platform]:p:(android cross iphoneos linux macosx mingw msys wasm watchos windows)' \
                    '-p+[platform]:p:(android cross iphoneos linux macosx mingw msys wasm watchos windows)' \
                    '--arch=+[arch]:a:(i386 x86_64 x64 x86 arm armv7 armv7s arm64 aarch64 mips mipsel mips64 mips64el ppc ppc64 sparc sparc64)' \
                    '-a+[arch]:a:(i386 x86_64 x64 x86 arm armv7 armv7s arm64 aarch64 mips mipsel mips64 mips64el ppc ppc64 sparc sparc64)' \
                    '--mode=+[mode]:m:(debug release minsizerel releasedbg profile coverage check)' \
                    '-m+[mode]:m:(debug release minsizerel releasedbg profile coverage check)' \
                    '--kind=+[kind]:k:(static shared binary)' \
                    '-k+[kind]:k:(static shared binary)' \
                    '--toolchain=+[toolchain]:str:' \
                    '--menu[show menu]' \
                    '--check[check]' ;;
                run) _arguments \
                    '--debug[debug]' \
                    '-d[debug]' \
                    '--workdir=+[working dir]:dir:_files -/' \
                    '-w+[working dir]:dir:_files -/' \
                    '*:target-and-args:' ;;
                install) _arguments \
                    '--installdir=+[install dir]:dir:_files -/' \
                    '-o+[install dir]:dir:_files -/' \
                    '*:target:' ;;
                uninstall) _arguments \
                    '--installdir=+[install dir]:dir:_files -/' \
                    '*:target:' ;;
                create) _arguments \
                    '--language=+[language]:l:(c c++ rust go d swift fortran objc objc++ asm)' \
                    '-l+[language]:l:(c c++ rust go d swift fortran objc objc++ asm)' \
                    '--template=+[template]:str:' \
                    '-t+[template]:str:' \
                    '*:project-name:' ;;
                require) _arguments \
                    '1:cmd:(check clean download info install list search uninstall update upgrade)' \
                    '*:package:' ;;
                repo) _arguments \
                    '1:cmd:(add clear list remove)' \
                    '*:arg:' ;;
                package) _arguments \
                    '--archs=+[archs]:list:' \
                    '--debug[debug]' \
                    '*:target:' ;;
                show) _arguments \
                    '--list=+[list type]:t:(plats archs modes targets options keys envs apis features rules toolchains projects)' \
                    '-l+[list type]:t:(plats archs modes targets options keys envs apis features rules toolchains projects)' \
                    '*:topic:' ;;
                project) _arguments \
                    '--kind=+[project kind]:k:(make vsxmake vsxmake2010 vsxmake2013 vsxmake2015 vsxmake2017 vsxmake2019 vsxmake2022 vs vs2002 vs2003 vs2005 vs2008 vs2010 vs2013 vs2015 vs2017 vs2019 vs2022 cmake cmakelists ninja compile_commands compile_flags codeblocks bear xcode)' \
                    '-k+[project kind]:k:(make vsxmake vsxmake2010 vsxmake2013 vsxmake2015 vsxmake2017 vsxmake2019 vsxmake2022 vs vs2002 vs2003 vs2005 vs2008 vs2010 vs2013 vs2015 vs2017 vs2019 vs2022 cmake cmakelists ninja compile_commands compile_flags codeblocks bear xcode)' \
                    '--outputdir=+[output dir]:dir:_files -/' \
                    '-o+[output dir]:dir:_files -/' ;;
                update|upgrade) _arguments \
                    '--all[update all]' \
                    '-s[scriptdir]' \
                    '*:version-or-flag:' ;;
                plugin) _arguments \
                    '1:cmd:(install uninstall list)' \
                    '*:plugin:' ;;
            esac
            ;;
    esac
}

_xmake-cli "$@"
