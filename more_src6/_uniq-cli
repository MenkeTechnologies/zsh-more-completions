#compdef uniq-cli
# _uniq-cli — GNU coreutils uniq report or omit repeated lines CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_uniq-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c[prefix count]' \
        '--count[prefix count]' \
        '-d[only print duplicates]' \
        '--repeated[only print duplicates]' \
        '-D[print all duplicates]' \
        '--all-repeated[print all duplicates]' \
        '--all-repeated=+[mode]:m:(none prepend separate)' \
        '-f+[skip first n fields]:n:' \
        '--skip-fields=+[skip first n fields]:n:' \
        '--group[show groups]' \
        '--group=+[mode]:m:(separate prepend append both)' \
        '-i[ignore case]' \
        '--ignore-case[ignore case]' \
        '-s+[skip first n chars]:n:' \
        '--skip-chars=+[skip first n chars]:n:' \
        '-u[only print unique lines]' \
        '--unique[only print unique lines]' \
        '-w+[compare no more than n chars]:n:' \
        '--check-chars=+[compare no more than n chars]:n:' \
        '-z[NUL terminator]' \
        '--zero-terminated[NUL terminator]' \
        '*:files:_files'
}

_uniq-cli "$@"
