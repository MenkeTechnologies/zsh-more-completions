#compdef yuvtoppm
# Documentation: man yuvtoppm (Netpbm)
# Source: convert Abekas YUV bytes to a PPM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:width:' \
    '2:height:' \
    '3:yuv data file:_files' \
    && ret=0

return ret
