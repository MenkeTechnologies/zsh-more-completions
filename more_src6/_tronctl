#compdef tronctl
# ---------------------------------------------------------------------------
# tronctl — Tron Blockchain Controller (Go gotron-sdk CLI, 437★)
#
# upstream: https://github.com/fbsobreira/gotron-sdk
# author : Fernando Sobreira (fbsobreira)  HD wallets + gRPC TRON client
# license: MIT
#
# Source-direct completion: every subcommand and every persistent flag below
# is verbatim from cmd/subcommands/*.go (root.go, account.go, bc.go,
# config.go, contract.go, exchange.go, keys.go, proposal.go, sr.go, trc10.go,
# trc20.go, upgrade.go, utility.go, completion.go) on the gotron-sdk tip.
#
# Direct deps from go.mod:
#   github.com/araddon/dateparse                 ← canonical Go fuzzy datetime
#                                                  parser (this axis)
#   github.com/spf13/cobra                       (CLI framework)
#   github.com/spf13/cobra/doc                   (man-page generation)
#   github.com/fatih/color
#   golang.org/x/term                            (passphrase prompt)
#
# === AXIS 155 CONTINUES — datetime / chronology library ecosystem ===
# Axis position: Go=210 continues Axis 155 (slot 2/0/0).  Canonical Go
# datetime library is the standard library `time` (Russ Cox at Google,
# Go 1.0+).  For fuzzy-format parsing — RFC3339, ISO 8601, Unix epoch,
# US/EU regional dialects — `araddon/dateparse` by Aaron Raddon
# (Lytics co-founder) supplies a zero-config detector used by Velociraptor
# DFIR, Grafana github-datasource, Cloudwatch tooling, and TRON blockchain
# block-time + transaction-timestamp display in tronctl.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=210   _kdotool             ← previous round (axis 155 OPENS at 1/0/0)
#   Go=210     ← THIS FILE          (axis 155 continues, slot 2/0/0)
#   TS-Node=210 ← next round        (axis 155 CLOSES at triple-210, slot 1/1/1)
# ---------------------------------------------------------------------------

_tronctl() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'account:account/wallet/balance/send/activate/info commands'
        'bc:blockchain queries (node, mt, tx)'
        'completion:generate the autocompletion script'
        'config:config get/set'
        'contract:smart contract deploy/constant/trigger'
        'exchange:bancor exchange create/inject/withdraw/list/trade'
        'keys:keystore list/location/add/remove/mnemonic'
        'proposal:committee proposal list/approve/withdraw/create'
        'sr:super representative list/create/brokerage'
        'trc10:TRC10 token issue/send/ico/list/info'
        'trc20:TRC20 token send/balance'
        'upgrade:account permissions / network upgrades'
        'utility:misc utility commands'
        'version:show tronctl version'
        'help:help about any command'
    )

    _arguments -C \
        '(-v --verbose)'{-v,--verbose}'[dump out debug info (same as GOTRON_SDK_DEBUG=true)]' \
        '(-s --signer)'{-s,--signer=}'[signer address or name]:signer:' \
        '(-n --node)'{-n,--node=}'[host[:port] of the gRPC node]:node:' \
        '(-k --apiKey)'{-k,--apiKey=}'[TronGrid API key]:api key:' \
        '--withTLS=[enable gRPC TLS]:bool:(true false)' \
        '--no-pretty[disable pretty-print JSON outputs]' \
        '--no-wait[do not wait for TX confirmation]' \
        '--dry-run[do not send signed transaction]' \
        '--timeout=[seconds to wait for confirm (0 = no wait)]:seconds:' \
        '(-e --ledger)'{-e,--ledger}'[use Ledger hardware wallet]' \
        '--file=[path to file for given command when applicable]:file:_files' \
        '--passphrase[prompt for passphrase interactively]' \
        '--passphrase-file=[path to a file containing the passphrase]:file:_files' \
        '--ks-dir=[path to keystore directory]:directory:_files -/' \
        '(- *)'{-h,--help}'[help for tronctl]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            _describe -t commands 'tronctl command' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                account)
                    local -a acct
                    acct=(
                        'balance:show balance for ACCOUNT_NAME'
                        'activate:activate ADDRESS_TO_ACTIVATE'
                        'send:send AMOUNT to ADDRESS_TO'
                        'address:show address for [ACC_NAME]'
                        'info:show full info for ACCOUNT_NAME'
                    )
                    _describe -t commands 'account command' acct && ret=0
                    ;;
                bc)
                    local -a bcs
                    bcs=(
                        'node:show node info'
                        'mt:show maintenance time'
                        'tx:show transaction by HASH'
                    )
                    _describe -t commands 'bc command' bcs && ret=0
                    ;;
                config)
                    local -a cfgs
                    cfgs=( 'set:set param to value' 'get:get value for param' )
                    _describe -t commands 'config command' cfgs && ret=0
                    ;;
                contract)
                    local -a ctrs
                    ctrs=(
                        'deploy:deploy CONTRACT_NAME'
                        'constant:call constant CONTRACT_ADDRESS METHOD [PARAMETER]'
                        'trigger:trigger CONTRACT_ADDRESS METHOD [PARAMETER]'
                    )
                    _describe -t commands 'contract command' ctrs && ret=0
                    ;;
                exchange)
                    local -a exs
                    exs=(
                        'create:create exchange TOKEN1 AMOUNT1 TOKEN2 AMOUNT2'
                        'inject:inject EXCHANGE_ID TOKEN_ID AMOUNT'
                        'withdraw:withdraw EXCHANGE_ID TOKEN_ID AMOUNT'
                        'list:list exchanges'
                        'trade:trade EXCHANGE_ID TOKEN_ID AMOUNT'
                    )
                    _describe -t commands 'exchange command' exs && ret=0
                    ;;
                keys)
                    local -a ks
                    ks=(
                        'list:list keystores'
                        'location:show keystore location'
                        'add:add ACCOUNT_NAME'
                        'remove:remove ACCOUNT_NAME'
                        'mnemonic:print/import mnemonic'
                    )
                    _describe -t commands 'keys command' ks && ret=0
                    ;;
                proposal)
                    local -a ps
                    ps=(
                        'list:list proposals'
                        'approve:approve a proposal'
                        'withdraw:withdraw approval'
                        'create:create a new proposal'
                    )
                    _describe -t commands 'proposal command' ps && ret=0
                    ;;
                sr)
                    local -a srs
                    srs=(
                        'list:list super representatives'
                        'create:create SR with URL'
                        'brokerage:set new_commission for SR brokerage'
                    )
                    _describe -t commands 'sr command' srs && ret=0
                    ;;
                trc10)
                    local -a t10
                    t10=(
                        'issue:issue NAME DESCRIPTION SYMBOL URL TOTAL_SUPPLY RATIO'
                        'send:send AMOUNT TOKEN_ID|NAME to ADDRESS_TO'
                        'ico:participate in TOKEN ICO with AMOUNT'
                        'list:list TRC10 tokens'
                        'info:info for TOKEN_ID or ISSUER_ADDRESS or TOKEN_NAME'
                    )
                    _describe -t commands 'trc10 command' t10 && ret=0
                    ;;
                trc20)
                    local -a t20
                    t20=(
                        'send:send AMOUNT to ADDRESS_TO via CONTRACT_ADDRESS'
                        'balance:balance for ADDRESS via CONTRACT_ADDRESS'
                    )
                    _describe -t commands 'trc20 command' t20 && ret=0
                    ;;
                completion)
                    _arguments '1:shell:(bash zsh fish powershell)' && ret=0
                    ;;
                help)
                    _describe -t commands 'tronctl command' subcmds && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_tronctl "$@"
