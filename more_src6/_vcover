#compdef vcover
# _vcover — Mentor Siemens EDA ModelSim/Questa vcover CLI managing UCDB Unified Coverage Database files merging ranking reporting statement branch toggle expression FSM functional cover-group coverage statistics (Siemens team, C++); custom argparse
# upstream: https://eda.sw.siemens.com/en-US/ic/questa/simulation/advanced-simulator/

_vcover() {
    local -a sub=(
        'merge:merge UCDB files'
        'rank:rank test cases by coverage'
        'report:report coverage'
        'rebuild:rebuild UCDB'
        'attribute:set UCDB attribute'
        'stats:show stats'
        'memory:memory stats'
        'testname:rename test name'
        'merge_tracker:merge tracker'
    )
    _arguments -C \
        '-help[show help]' \
        '-version[show version]' \
        '-quiet[quiet]' \
        '-verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vcover subcommand' sub ;;
        args)
            case $words[1] in
                merge) _arguments \
                    '-out=+[ucdb]:file:_files -g "*.ucdb"' \
                    '-strip=+[N]:n:' \
                    '-totals[include totals]' \
                    '-testassociated[associate to tests]' \
                    '-onerror=+[m]:m:(continue stop)' \
                    '*:ucdb file:_files -g "*.ucdb"' ;;
                report) _arguments \
                    '-details[show details]' \
                    '-byinstance[by instance]' \
                    '-cvg[functional coverage]' \
                    '-assert[assertions]' \
                    '-output=+[file]:file:_files' \
                    '-html[html output]' \
                    '-htmldir=+[dir]:dir:_files -/' \
                    '*:ucdb file:_files -g "*.ucdb"' ;;
                rank) _arguments \
                    '-out=+[file]:file:_files' \
                    '-rule=+[r]:r:(default greedy heuristic exhaustive)' \
                    '-percent=+[N]:n:' \
                    '*:ucdb file:_files -g "*.ucdb"' ;;
                attribute) _arguments \
                    '-name=+[name]:str:' \
                    '-value=+[value]:str:' \
                    '*:ucdb file:_files -g "*.ucdb"' ;;
                stats|memory) _arguments \
                    '*:ucdb file:_files -g "*.ucdb"' ;;
            esac
            ;;
    esac
}

_vcover "$@"
