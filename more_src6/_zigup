#compdef zigup
# Documentation: https://github.com/marler8997/zigup
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed from prior file: fabricated --force flag for fetch (not in README).

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'fetch:fetch compiler without setting as default'
      'list:list installed compiler versions'
      'default:print or set the default compiler'
      'clean:remove non-default compilers'
      'keep:mark a compiler to keep'
      'run:run specific compiler version with arguments'
      'get-install-dir:display the install directory path'
      'set-install-dir:change the install directory'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (fetch|default|clean|keep)
        _arguments '1:version:' && ret=0
        ;;
      (run)
        _arguments \
          '1:version:' \
          '*:arguments:' && ret=0
        ;;
      (set-install-dir)
        _arguments '1:path:_files -/' && ret=0
        ;;
    esac
    ;;
esac

return ret
