#compdef tstclnt
# Documentation: man tstclnt(1)
# Source: nss-dev/nss cmd/tstclnt/tstclnt.c (master) — NSS test SSL/TLS client (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a+[SNI name (1st_hs_name,2nd_hs_name)]:name:_default' \
    '-h+[hostname]:host:_hosts' \
    '-p+[port]:port:_default' \
    '-d+[NSS cert database directory]:dir:_files -/' \
    '-D[run without cert database]' \
    '-b[load default builtins root CA module]' \
    '-R+[root CA module]:module:_files' \
    '*-C[print certificate chain (stackable for detail)]' \
    '-n+[nickname of key and cert]:nickname:_default' \
    '-V+[restrict SSL/TLS versions (min:max)]:version range:_default' \
    '-K[send TLS_FALLBACK_SCSV]' \
    '-S[print payload only, skip HTTP header]' \
    '-f[client speaks first]' \
    '-O[synchronous cert selection/validation]' \
    '-o[override bad server cert]' \
    '-s[disable SSL socket locking]' \
    '-v[verbose progress]' \
    '-q[ping server then exit]' \
    '-t+[server ping timeout (seconds)]:seconds:_default' \
    '-r+[renegotiate N times]:N:_default' \
    '-u[enable session ticket extension]' \
    '-g[enable false start]' \
    '-T[enable cert_status (OCSP stapling)]' \
    '-U[enable signed_certificate_timestamp]' \
    '-B[enable delegated credentials extension]' \
    '*-F[require fresh revocation info (stackable)]' \
    '-M+[test mode (0=any 1=OCSP 2=CRL)]:mode:(0 1 2)' \
    '-c+[restrict ciphers (letter codes)]:ciphers:_default' \
    '-Y[list cipher values for -c and exit]' \
    '(-4 -6)-4[force IPv4]' \
    '(-4 -6)-6[force IPv6]' \
    '-G[enable extended master secret extension]' \
    '-H+[require FFDHE supported groups]:groups:_default' \
    '-A+[read input from file instead of stdin]:file:_files' \
    '-Z[allow 0-RTT data (TLS 1.3)]' \
    '-L+[disconnect/reconnect up to N times]:N:_default' \
    '-P+[use DTLS]:role:(client server)' \
    '-Q[exit after handshake]' \
    '-N+[Encrypted Client Hello ECHConfigs (base64)]:configs:_default' \
    '-i+[ECH GREASE padding size 0-255]:size:_default' \
    '-e[enable middlebox compatibility (TLS 1.3)]' \
    '-z+[external PSK]:psk:_default' \
    && ret=0

return ret
