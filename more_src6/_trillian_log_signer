#compdef trillian_log_signer
# _trillian_log_signer — Trillian log sequencer/signer
# upstream: https://github.com/google/trillian
# Flags from cmd/trillian_log_signer/main.go on tip.

_trillian_log_signer() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-rpc_endpoint=[gRPC bind host\:port]:host\:port:' \
        '-http_endpoint=[HTTP bind host\:port (empty=disabled)]:host\:port:' \
        '-tls_cert_file=[TLS server cert]:file:_files' \
        '-tls_key_file=[TLS server key]:file:_files' \
        '-sequencer_interval=[interval between sequencing passes]:dur:' \
        '-batch_size=[max leaves per batch]:n:' \
        '-num_sequencers=[parallel sequencer workers]:n:' \
        '-sequencer_guard_window=[delay before submitted leaves become eligible]:dur:' \
        '-force_master=[assume master for all logs]:bool:(true false)' \
        '-etcd_http_service=[etcd HTTP service name]:name:' \
        '-healthz_timeout=[healthz check timeout]:dur:' \
        '-quota_system=[quota system]:name:' \
        '-quota_increase_factor=[per-batch quota increase factor]:f:' \
        '-storage_system=[storage system]:name:' \
        '-election_system=[election system]:name:' \
        '-pre_election_pause=[max wait before starting election]:dur:' \
        '-master_hold_interval=[min mastership hold duration]:dur:' \
        '-master_hold_jitter=[random jitter added to master_hold_interval]:dur:' \
        '-config=[config file]:file:_files' \
        '-cpuprofile=[write CPU profile to file]:file:_files' \
        '-memprofile=[write memory profile to file]:file:_files' \
        '-max_msg_size_bytes=[max gRPC message size]:bytes:'
}

_trillian_log_signer "$@"
