#compdef xfce4-screensaver
# Documentation: https://github.com/xfce-mirror/xfce4-screensaver/blob/master/src/xfce4-screensaver.c
# Reference accessed: 2026-05-21
# Verified: xfce4-screensaver.c GOptionEntry table defines --version and --debug;
# remaining options are added by gtk_init_with_args().

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--help-all[show all command line options]' \
  '--display=[X display to use]:display:' \
  '--debug[enable debugging code]' \
  '--version[version of this application]' && ret=0
return ret
