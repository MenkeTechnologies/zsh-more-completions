#compdef vault-csi-provider
# Documentation: https://github.com/hashicorp/vault-csi-provider (main.go flag definitions)
# Reference accessed: 2026-05-21
# Verified: upstream main.go flag.* definitions.

# vault-csi-provider: Vault provider for Kubernetes Secrets Store CSI Driver
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-version[show version]' \
  '-endpoint=[Unix socket path]:file:_files' \
  '-debug[enable debug logging (deprecated, use -log-level)]' \
  '-log-level=[log level]:level:(trace debug info warn error off)' \
  '-output=[output format]:format:(json text)' \
  '-health-addr=[health address]:addr:' \
  '-hmac-secret-name=[name of HMAC key secret]:name:' \
  '-cache-size=[lease cache size]:n:' \
  '-vault-addr=[Vault address]:url:' \
  '-vault-mount=[Vault auth mount]:mount:' \
  '-vault-namespace=[Vault namespace]:ns:' \
  '-vault-tls-ca-cert=[Vault TLS CA cert]:file:_files' \
  '-vault-tls-ca-directory=[Vault TLS CA directory]:dir:_files -/' \
  '-vault-tls-server-name=[Vault TLS server name]:name:' \
  '-vault-tls-client-cert=[Vault TLS client cert]:file:_files' \
  '-vault-tls-client-key=[Vault TLS client key]:file:_files' \
  '-vault-tls-skip-verify[skip TLS verification]' && ret=0
return ret
