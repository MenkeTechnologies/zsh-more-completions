#compdef vectorctl
# _vectorctl — Datadog Vector observability data router subcommand alias (Datadog, Rust); clap-rs
# upstream: https://github.com/vectordotdev/vector

_vectorctl() {
    local -a sub=(
        'config:print compiled config'
        'generate:scaffold a config'
        'graph:graph component connections'
        'list:list components'
        'top:live top of components'
        'tap:tap events'
        'validate:validate config'
        'vrl:run VRL programs'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g "*.(toml|yaml|json)"' \
        '-c+[config file]:file:_files -g "*.(toml|yaml|json)"' \
        '--config-dir=+[config dir]:dir:_files -/' \
        '-C+[config dir]:dir:_files -/' \
        '--config-toml=+[config toml]:file:_files -g "*.toml"' \
        '--config-yaml=+[config yaml]:file:_files -g "*.yaml *.yml"' \
        '--config-json=+[config json]:file:_files -g "*.json"' \
        '--require-healthy[require healthy on startup]' \
        '-r[require healthy on startup]' \
        '--threads=+[threads]:n:' \
        '-t+[threads]:n:' \
        '--watch-config[watch config]' \
        '-w[watch config]' \
        '--allow-empty-config[allow empty config]' \
        '--openssl-no-probe[no openssl probe]' \
        '--allocation-tracing[allocation tracing]' \
        '--log-format=+[log format]:fmt:(text json)' \
        '-f+[log format]:fmt:(text json)' \
        '--color=+[color]:c:(auto always never)' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vectorctl subcommand' sub ;;
        args)
            case $words[1] in
                tap) _arguments \
                    '--inputs=+[component inputs]:list:' \
                    '--outputs=+[component outputs]:list:' \
                    '--format=+[format]:fmt:(json yaml logfmt)' \
                    '--interval=+[interval ms]:n:' \
                    '--limit=+[limit]:n:' \
                    '--quiet=+[quiet]' ;;
                validate) _arguments \
                    '--no-environment[no environment]' \
                    '--deny-warnings[deny warnings]' \
                    '*:file:_files' ;;
                graph) _arguments \
                    '*:file:_files' ;;
                generate) _arguments \
                    '1:expression:' \
                    '--fragment[generate fragment]' \
                    '--file=+[output file]:file:_files' ;;
                vrl) _arguments \
                    '--input=+[input file]:file:_files' \
                    '--object=+[object file]:file:_files' \
                    '--program=+[program string]:str:' \
                    '*:file:_files -g "*.vrl"' ;;
                completion) _arguments '1:shell:(bash zsh fish elvish powershell)' ;;
            esac
            ;;
    esac
}

_vectorctl "$@"
