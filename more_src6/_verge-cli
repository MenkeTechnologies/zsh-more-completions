#compdef verge-cli
# _verge-cli — Verge Currency verge-cli JSON-RPC client CLI for the privacy-focused Tor-i2p multi-algo Scrypt X17 Lyra2REv2 myr-groestl Blake2s daemon issuing wallet getbalance sendtoaddress getnewaddress getrawtransaction listunspent listtransactions importprivkey (vergecurrency team, C++); custom argparse
# upstream: https://github.com/vergecurrency/verge

_verge-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-?[show help]' \
        '-conf=+[file]:file:_files -g "*.conf verge.conf"' \
        '-datadir=+[dir]:dir:_files -/' \
        '-testnet[use testnet]' \
        '-regtest[use regtest]' \
        '-named[use named JSON-RPC]' \
        '-rpcconnect=+[host]:h:_hosts' \
        '-rpcport=+[port]:n:' \
        '-rpcwait[wait for RPC server]' \
        '-rpcuser=+[user]:str:' \
        '-rpcpassword=+[password]:str:' \
        '-rpcclienttimeout=+[seconds]:n:' \
        '-rpccookiefile=+[file]:file:_files' \
        '-stdin[read input from stdin]' \
        '-stdinrpcpass[read RPC password from stdin]' \
        '-getinfo[print info]' \
        '*:rpc command:(getblockchaininfo getblockcount getblockhash getblock getnetworkinfo getmempoolinfo getbalance listunspent listtransactions sendtoaddress getnewaddress validateaddress dumpprivkey importprivkey importwallet dumpwallet getrawtransaction createrawtransaction signrawtransaction sendrawtransaction decoderawtransaction addnode getpeerinfo getnettotals setban listbanned)'
}

_verge-cli "$@"
