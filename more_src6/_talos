#compdef talos talosctl
# Documentation: https://www.talos.dev/v1.7/reference/cli/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'apply-config:apply a new configuration to a node'
  'bootstrap:bootstrap the etcd cluster on the specified node'
  'cluster:manage local docker-based or QEMU-based clusters'
  'completion:generate completion script'
  'config:manage the client configuration file (talosconfig)'
  'conformance:run conformance tests'
  'containers:list containers'
  'copy:copy data out from a node'
  'dashboard:cluster dashboard with node overview, logs, command-line and monitoring'
  'disks:get the list of disks from /sys/block on the machine'
  'dmesg:retrieve kernel logs'
  'edit:edit a resource from the default editor'
  'etcd:manage etcd'
  'events:stream runtime events'
  'gen:generate certificates, keys, and tokens'
  'get:get a specific resource or list of resources'
  'health:check cluster health'
  'image:manage CRI containerd images'
  'inspect:inspect internals of Talos'
  'kubeconfig:download the admin kubeconfig from the node'
  'list:retrieve a directory listing'
  'logs:retrieve logs for a service'
  'machineconfig:machine config related commands'
  'memory:show memory usage'
  'meta:write and delete keys in the META partition'
  'netstat:show network connections and sockets'
  'patch:update field(s) of a resource'
  'pcap:capture the network packets from the node'
  'processes:list running processes'
  'read:read a file on the machine'
  'reboot:reboot a node'
  'reset:reset a node'
  'restart:restart a process'
  'rollback:rollback a node to the previous installation'
  'service:retrieve the state of a service (or all services), start/stop/restart a service'
  'shutdown:shutdown a node'
  'stats:get container stats'
  'support:dump debug information about the cluster'
  'time:get the time'
  'upgrade:upgrade Talos on the target node'
  'upgrade-k8s:upgrade Kubernetes control plane in the Talos cluster'
  'usage:retrieve a disk usage'
  'validate:validate config'
  'version:prints the version'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--cluster=[cluster to connect to (defaults to current)]:name:' \
  '--context=[context to use]:context:' \
  {-e,--endpoints}'=[override default endpoints in talosconfig]:endpoints:' \
  {-n,--nodes}'=[target the specified nodes]:nodes:' \
  '--talosconfig=[path to talosconfig file (default $TALOSCONFIG or ~/.talos/config)]:config:_files' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  (commands)
    _describe -t commands 'talosctl command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (apply-config)
        _arguments \
          '--file=[config file]:file:_files' \
          '--insecure[skip TLS verification (use maintenance mode)]' \
          '--mode=[apply mode]:mode:(auto no-reboot reboot staged try)' \
          '--dry-run[validate without applying]' \
          '--timeout=[timeout]:timeout:' && ret=0
        ;;
      (cluster)
        local -a cluster_cmds=(
          'create:create a local cluster'
          'destroy:destroy a local cluster'
          'show:show cluster info'
        )
        _describe -t commands 'cluster command' cluster_cmds && ret=0
        ;;
      (completion)
        _arguments '1:shell:(bash fish zsh)' && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
