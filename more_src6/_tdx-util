#compdef tdx-util
# Documentation: man tdx-util(8)
# Source: InterNetNews/inn storage/tradindexed/tdx-util.c — manage tradindexed overview (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a+[article number or range]:range:_default' \
    '-f+[group status flag]:flag:_default' \
    '-n+[newsgroup]:group:_default' \
    '-p+[pathoverview directory]:dir:_files -/' \
    '(-A -F -R -c -g -i -O -o)-A[audit and report issues]' \
    '(-A -F -R -c -g -i -O -o)-F[fix issues found by audit]' \
    '(-A -F -R -c -g -i -O -o)-R+[rebuild group from spool path]:path:_files' \
    '(-A -F -R -c -g -i -O -o)-c[check overview]' \
    '(-A -F -R -c -g -i -O -o)-g[show group index entry]' \
    '(-A -F -R -c -g -i -O -o)-i[show group info]' \
    '(-A -F -R -c -g -i -O -o)-O[print overview lines for group]' \
    '(-A -F -R -c -g -i -O -o)-o[print overview index entries]' \
    && ret=0

return ret
