#compdef torchvision torchvision-cli torchvision-info
# _torchvision — Meta AI PyTorch torchvision computer vision datasets models transforms operators CLI helpers (pytorch team, Python); argparse
# upstream: https://github.com/pytorch/vision

_torchvision() {
    local -a sub=(
        'download:download a dataset'
        'info:show dataset info'
        'transform:apply image transforms'
        'detect:run object detection model'
        'classify:run classification model'
        'segment:run segmentation model'
        'video:run video classification'
        'eval:evaluate model'
        'video-info:show video info'
        'video-extract:extract frames'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--device=+[device]:d:(cpu cuda mps auto)' \
        '--backend=+[backend]:b:(pil tensor opencv)' \
        '--num-workers=+[N]:n:' \
        '--batch-size=+[N]:n:' \
        '--seed=+[seed]:n:' \
        '--debug[debug]' \
        '--verbose[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'torchvision subcommand' sub ;;
        args)
            case $words[1] in
                download) _arguments \
                    '--dataset=+[name]:d:(MNIST CIFAR10 CIFAR100 ImageNet COCO LSUN STL10 SBD VOCDetection VOCSegmentation USPS Flickr8k Flickr30k Country211 EuroSAT GTSRB FashionMNIST KMNIST QMNIST EMNIST Omniglot SEMEION SUN397 SVHN INaturalist Kitti Cityscapes Caltech101 Caltech256 CelebA UCF101 HMDB51 Kinetics400 ImageNetV2 Places365 RenderedSST2 Food101 OxfordIIITPet StanfordCars FGVCAircraft Country211 DTD)' \
                    '--root=+[output dir]:dir:_files -/' \
                    '--split=+[split]:s:(train test val val_set)' ;;
                detect|classify|segment) _arguments \
                    '--model=+[model name]:str:' \
                    '--weights=+[weights]:str:' \
                    '--input=+[image file]:file:_files -g "*.jpg *.png *.jpeg *.bmp *.tiff"' \
                    '--output=+[output file]:file:_files' \
                    '--threshold=+[F]:f:' \
                    '--top-k=+[N]:n:' ;;
                video|video-info|video-extract) _arguments \
                    '--input=+[video file]:file:_files -g "*.mp4 *.mkv *.avi *.mov *.webm"' \
                    '--output=+[output]:file:_files' \
                    '--frame-rate=+[fps]:n:' \
                    '--start=+[seconds]:f:' \
                    '--end=+[seconds]:f:' ;;
                eval) _arguments \
                    '--dataset=+[dataset]:str:' \
                    '--model=+[model]:str:' \
                    '--metric=+[metric]:m:(accuracy top5 iou map mAP precision recall f1)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_torchvision "$@"
