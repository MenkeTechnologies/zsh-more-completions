#compdef wesnoth
# Documentation: https://man.archlinux.org/man/wesnoth.6.en
# Reference accessed: 2026-05-21
# Verified: upstream wesnoth(6) manpage at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)--simple-version[show simple version string]' \
  '--all-translations[show all translations, even incomplete ones]' \
  '(-R --report)'{-R,--report}'[generate problem report]' \
  '(-c --campaign)'{-c-,--campaign=-}'[start campaign (optionally with id)]::campaign id:' \
  '--campaign-difficulty=-[campaign difficulty]::difficulty:' \
  '--campaign-scenario=[start at given scenario]:scenario id:' \
  '--campaign-skip-story[skip campaign story]' \
  '(-e --editor)'{-e-,--editor=-}'[start map editor (optionally with file)]::file:_files' \
  '(-m --multiplayer)'{-m,--multiplayer}'[start multiplayer game]' \
  '(-t --test)'{-t-,--test=-}'[run a unit test scenario]::scenario id:' \
  '(-u --unit)'{-u,--unit}'[run unit test scenario]:scenario id:' \
  '(-s --server)'{-s-,--server=-}'[connect to multiplayer server]::host:_hosts' \
  '(-f --fullscreen)'{-f,--fullscreen}'[fullscreen]' \
  '(-w --windowed)'{-w,--windowed}'[windowed]' \
  '(-r --resolution)'{-r,--resolution}'[resolution WxH]:WxH:' \
  '--max-fps=[set max FPS]:fps:' \
  '--fps[show FPS]' \
  '--clock[show in-game clock]' \
  '(-L --language)'{-L,--language}'[language code]:lang:' \
  '--rng-seed=[RNG seed]:number:' \
  '--core=[set core id]:core id:' \
  '--data-dir=[data directory]:dir:_directories' \
  '--data-path[print data path]' \
  '--userdata-dir=[user data directory]:dir:_directories' \
  '--userdata-path[print user data path]' \
  '--userconfig-dir=[user config directory]:dir:_directories' \
  '--userconfig-path[print user config path]' \
  '(-l --load)'{-l,--load}'[load saved game]:file:_files' \
  '--bzip2=[bzip2 a file]:file:_files' \
  '--bunzip2=[bunzip2 a file]:file:_files -g "*.bz2"' \
  '--gzip=[gzip a file]:file:_files' \
  '--gunzip=[gunzip a file]:file:_files -g "*.gz"' \
  '(-D --diff)'{-D,--diff}'[diff two WML files]:left file:_files' \
  '(-P --patch)'{-P,--patch}'[apply patch to a WML file]:base file:_files' \
  '--output=[output file]:file:_files' \
  '(-p --preprocess)'{-p,--preprocess}'[preprocess a file/folder]:source:_files' \
  '--preprocess-defines=[preprocessor defines]:defines:' \
  '--preprocess-input-macros=[input macros file]:file:_files' \
  '--preprocess-output-macros=-[output macros file]::file:_files' \
  '--validate=[validate path]:path:_files' \
  '--validate-addon=[validate addon]:addon id:' \
  '--validate-core[validate core]' \
  '--validate-schema=[validate schema]:path:_files' \
  '(-S --use-schema)'{-S,--use-schema}'[use schema file]:path:_files' \
  '--strict-validation[strict validation]' \
  '--render-image=[render image]:image:_files' \
  '--screenshot[take screenshot]:map:_files' \
  '--nomusic[disable music]' \
  '--nosound[disable sound]' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '--debug-lua[debug Lua]' \
  '--strict-lua[strict Lua mode]' \
  '--log-level=[log level for domains]:level:' \
  '--log-precise[precise log timestamps]' \
  '--log-strict[strict log mode]' \
  '--logdomains=-[list log domains]::filter:' \
  '--no-log-to-file[do not log to file]' \
  '--log-to-file[log to file]' \
  '--wnoconsole[no console on Windows]' \
  '--nodelay[no AI move delay]' \
  '--nogui[no GUI]' \
  '--showgui[force show GUI]' \
  '--nobanner[no banner]' \
  '--nocache[disable cache]' \
  '--validcache[assume cache valid]' \
  '--noreplaycheck[disable replay check]' \
  '--with-replay[record a replay]' \
  '--mp-test[run multiplayer test]' \
  '--noaddons[disable add-ons]' \
  '--new-widgets[enable new widget system]' \
  '--script=[Lua script]:file:_files' \
  '--plugin=[plugin script]:script:_files' \
  '--unsafe-scripts[allow unsafe scripts]' \
  '--username=[username]:user:' \
  '--password=[password]:pw:' && ret=0

return ret
