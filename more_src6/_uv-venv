#compdef uv-venv
# _uv-venv — uv virtual environment manager (astral-sh/uv)
# upstream: https://github.com/astral-sh/uv

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--python=[Python interpreter]:python:_files' \
  '--system-site-packages[give access to system site-packages]' \
  '--seed[install seed packages (pip, setuptools, wheel)]' \
  '--allow-existing[allow creation over existing directory]' \
  '--prompt=[virtual environment prompt]:prompt:' \
  '--index-url=[package index URL]:url:' \
  '--extra-index-url=[extra index URL]:url:' \
  '--relocatable[make relocatable venv]' \
  '--quiet[quiet output]' \
  '--verbose[verbose output]' \
  '1:venv path:_files -/'
