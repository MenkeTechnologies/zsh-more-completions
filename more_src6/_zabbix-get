#compdef zabbix-get zabbix_get
# Documentation: https://www.zabbix.com/documentation/current/en/manpages/zabbix_get
# Reference accessed: 2026-05-21
# Verified: upstream Zabbix zabbix_get manpage at the URL above.

# zabbix-get: query data from a Zabbix agent
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-s --host)'{-s,--host=}'[host name or IP]:host:_hosts' \
  '(-p --port)'{-p,--port=}'[agent port (default 10050)]:port:' \
  '(-I --source-address)'{-I,--source-address=}'[source IP]:ip:' \
  '(-t --timeout)'{-t,--timeout=}'[timeout 1-600 seconds (default 30)]:seconds:' \
  '(-k --key)'{-k,--key=}'[item key]:key:' \
  '(-P --protocol)'{-P,--protocol=}'[communication method]:method:(auto json plaintext)' \
  '--tls-connect=[TLS connection method]:method:(unencrypted psk cert)' \
  '--tls-ca-file=[CA certificate file]:file:_files' \
  '--tls-crl-file=[CRL file]:file:_files' \
  '--tls-agent-cert-issuer=[expected agent cert issuer]:issuer:' \
  '--tls-agent-cert-subject=[expected agent cert subject]:subject:' \
  '--tls-cert-file=[client cert file]:file:_files' \
  '--tls-key-file=[client key file]:file:_files' \
  '--tls-psk-identity=[PSK identity]:identity:' \
  '--tls-psk-file=[PSK file]:file:_files' \
  '--tls-cipher13=[TLS 1.3 cipher suites]:ciphers:' \
  '--tls-cipher=[TLS 1.2 cipher suites]:ciphers:' && ret=0
return ret
