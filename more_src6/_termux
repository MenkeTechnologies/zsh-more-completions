#compdef termux termux-cli
# _termux — Termux Android Linux env CLI alias (Fredrik Fornwall / termux team, C/Bash); custom argparse
# upstream: https://github.com/termux/termux-app

_termux() {
    local -a sub=(
        'open:open a file with default app'
        'open-url:open a URL'
        'share:share a file'
        'reload-settings:reload settings'
        'setup-storage:setup storage'
        'fix-shebang:fix shebangs'
        'change-repo:change package repo'
        'chroot:enter chroot'
        'clipboard-get:get clipboard'
        'clipboard-set:set clipboard'
        'create-shortcut:create launcher shortcut'
        'download:download file via API'
        'fingerprint:read fingerprint'
        'info:show info'
        'install:install a package'
        'micropbar:show notification'
        'notification:show notification'
        'notification-remove:remove notification'
        'sensor:read sensors'
        'sms-send:send SMS'
        'volume:set volume'
        'wake-lock:acquire wake lock'
        'wake-unlock:release wake lock'
        'wifi-connectioninfo:Wi-Fi connection info'
        'wifi-scaninfo:Wi-Fi scan info'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'termux subcommand' sub ;;
        args)
            case $words[1] in
                open|open-url|share|download) _arguments '*:file-or-url:_files' ;;
                clipboard-set|sms-send|notification|micropbar) _arguments '*:str:' ;;
                install) _arguments '*:package:' ;;
            esac
            ;;
    esac
}

_termux "$@"
