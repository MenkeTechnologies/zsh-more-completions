#compdef vorbisgain
# Documentation: https://manpages.debian.org/bookworm/vorbisgain/vorbisgain.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream man page at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show command help]' \
  '(- *)'{-v,--version}'[display the version of the program]' \
  '(-a --album)'{-a,--album}'[activate album mode (calculates album gain in addition to track gain)]' \
  '(-g --album-gain)'{-g+,--album-gain=}'[set specific album gain value in dB (implies -a)]:n:' \
  '(-c --clean)'{-c,--clean}'[remove ReplayGain tags from specified files]' \
  '(-C --convert)'{-C,--convert}'[convert old format ReplayGain tags to new format]' \
  '(-d --display-only)'{-d,--display-only}'[display the result only; do not write anything to disk]' \
  '(-f --fast)'{-f,--fast}'[only calculate gain for files without all replay gain tags]' \
  '(-n --no-progress)'{-n,--no-progress}'[only display results, do not show progress]' \
  '(-p --preserve-mtime)'{-p,--preserve-mtime}'[do not trample timestamps of files]' \
  '(-q --quiet)'{-q,--quiet}'[do not display output while processing]' \
  '(-r --recursive)'{-r,--recursive}'[enter directories recursively to search for files]' \
  '(-s --skip)'{-s,--skip}'[silently skip non-Vorbis files]' \
  '*:ogg vorbis file:_files -g "*.ogg(-.)"' && ret=0

return ret
