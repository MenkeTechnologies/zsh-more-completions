#compdef xfce4-clipman xfce4-clipman-history xfce4-clipman-settings
# Documentation: https://github.com/xfce-mirror/xfce4-clipman-plugin/blob/master/panel-plugin/main-status-icon.c
# Reference accessed: 2026-05-21
# Verified: main-status-icon.c, xfce4-clipman-history.c, xfce4-clipman-settings.c
# all call gtk_init() / g_application_run() with no custom GOptionEntry table.
# Only standard GTK options are accepted.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)--help-gtk[show GTK options]' \
  '--display=[X display]:display:' && ret=0

return ret
