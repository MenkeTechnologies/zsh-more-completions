#compdef zoekt-indexserver
# _zoekt-indexserver — Sourcegraph Zoekt periodic mirror + indexer daemon
# upstream: https://github.com/sourcegraph/zoekt
# Flags from cmd/zoekt-indexserver/main.go on tip.

_zoekt-indexserver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-index_timeout=[index job timeout]:dur:' \
        '-max_log_age=[recycle index logs after this duration]:dur:' \
        '-fetch_interval=[periodic fetch interval]:dur:' \
        '-mirror_config=[mirror config file]:file:_files' \
        '-mirror_duration=[find + clone new repos at this frequency]:dur:' \
        '-cpu_fraction=[CPU fraction to use (0.0-1.0)]:f:' \
        '-git_index_flags=[pass-through flags for zoekt-git-index]:flags:' \
        '-data_dir=[data directory (mirrors + logs)]:dir:_files -/' \
        '-index_dir=[index shard directory (default: data_dir/index)]:dir:_files -/'
}

_zoekt-indexserver "$@"
