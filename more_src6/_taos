#compdef taos

local curcontext="$curcontext" state line ret=1

_arguments \
  '(-h --host)'{-h,--host}'[server host]:host:_hosts' \
  '(-P --port)'{-P,--port}'[server port]:port' \
  '(-u --user)'{-u,--user}'[username]:username' \
  '(-p --password)'{-p,--password}'[prompt for password]' \
  '(-a --auth)'{-a,--auth}'[auth string]:auth string' \
  '(-A --password-raw)'{-A,--password-raw}'[raw password]:password' \
  '(-c --config-dir)'{-c,--config-dir}'[configuration directory]:config dir:_directories' \
  '(-C --commands)'{-C,--commands}'[run commands then exit]:commands' \
  '(-s --commands)'{-s,--commands}'[SQL command to execute]:SQL command' \
  '(-f --file)'{-f,--file}'[SQL file to execute]:SQL file:_files -g "*.sql"' \
  '(-l --packet-length)'{-l,--packet-length}'[network packet length]:length' \
  '(-N --null)'{-N,--null}'[display NULL as string]' \
  '(-r --raw-time)'{-r,--raw-time}'[display raw timestamp]' \
  '(-t --timezone)'{-t,--timezone}'[set timezone]:timezone' \
  '(-n --net-role)'{-n,--net-role}'[network test role]:role:(client server)' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--help[show help message]' \
  && ret=0

return ret
