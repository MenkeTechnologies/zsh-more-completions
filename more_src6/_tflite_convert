#compdef tflite_convert
# Documentation: https://github.com/tensorflow/tensorflow/blob/master/tensorflow/lite/python/tflite_convert.py
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# tflite_convert: convert TensorFlow models to TFLite format
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--output_file=[output .tflite file]:file:_files -g "*.tflite"' \
  '--graph_def_file=[input frozen GraphDef .pb file]:file:_files -g "*.pb"' \
  '--saved_model_dir=[SavedModel directory]:dir:_files -/' \
  '--keras_model_file=[input Keras HDF5 file]:file:_files -g "*.(h5|keras)"' \
  '--output_format=[output format]:fmt:(TFLITE GRAPHVIZ_DOT)' \
  '--inference_type=[data type for arrays]:type:(FLOAT INT8 UINT8)' \
  '--inference_input_type=[input array data type]:type:(FLOAT INT8 UINT8)' \
  '--input_arrays=[input array names csv]:arrays:' \
  '--input_shapes=[input shapes colon-separated]:shapes:' \
  '--output_arrays=[output array names csv]:arrays:' \
  '--saved_model_tag_set=[MetaGraphDef tags]:tags:' \
  '--saved_model_signature_key=[SignatureDef key]:key:' \
  '--mean_values=[training data means]:values:' \
  '--std_dev_values=[training data std deviations]:values:' \
  '--default_ranges_min=[default min range]:n:' \
  '--default_ranges_max=[default max range]:n:' \
  '--post_training_quantize[post-training quantize weights]' \
  '--quantize_to_float16[quantize weights to float16]' \
  '--allow_custom_ops[allow custom ops]' \
  '--custom_opdefs=[custom operator definitions]:opdefs:' \
  '--target_ops=[target ops set]:ops:(TFLITE_BUILTINS SELECT_TF_OPS TFLITE_BUILTINS_INT8)' \
  '--experimental_new_converter[enable MLIR conversion]' \
  '--dump_graphviz_dir=[GraphViz output directory]:dir:_files -/' \
  '--enable_v1_converter[use TF 1.x converter flags]' \
  '*::tflite_convert args:_files' && ret=0
return ret
