#compdef xkbevd
# Documentation: man xkbevd (X.Org)
# Source: XKB event daemon — performs actions on XKB events.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[show usage]' \
    '(- *)-version[show version]' \
    '-cfg+[config file]:file:_files' \
    '-sc+[command to play sounds]:cmd:_command_names -e' \
    '-sd+[sound directory]:dir:_files -/' \
    '-display+[X display]:display:' \
    '-bg[fork into background]' \
    '-synch[force synchronization of X requests]' \
    '*-v[print more information (repeatable)]' \
    && ret=0

return ret
