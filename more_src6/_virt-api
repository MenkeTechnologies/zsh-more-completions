#compdef virt-api
# _virt-api — KubeVirt API server (kubevirt/kubevirt)
# upstream: https://github.com/kubevirt/kubevirt
# Flags from pkg/virt-api/api.go + pkg/service/service.go on tip.

_virt-api() {
    _arguments \
        '--listen=[bind address]:ip:' \
        '--port=[bind port]:port:' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--master=[apiserver URL override]:url:_urls' \
        '-v[klog verbosity level]:n:' \
        '--subresources-only[serve only subresource APIs]' \
        '--console-server-port=[console server port]:port:' \
        '--ca-configmap-name=[CA configmap name]:name:' \
        '--tls-cert-file=[TLS cert file]:file:_files' \
        '--tls-key-file=[TLS key file]:file:_files' \
        '--handler-cert-file=[virt-handler client cert]:file:_files' \
        '--handler-key-file=[virt-handler client key]:file:_files' \
        '--externally-managed[treat certs as externally managed]'
}

_virt-api "$@"
