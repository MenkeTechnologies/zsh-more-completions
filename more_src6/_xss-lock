#compdef xss-lock
# Documentation: https://man.archlinux.org/man/xss-lock.1.en
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-n --notifier)'{-n+,--notifier=}'[notifier command]:cmd:_command_names' \
  '(-l --transfer-sleep-lock)'{-l,--transfer-sleep-lock}'[pass sleep lock to locker]' \
  '(-s --session)'{-s+,--session=}'[session ID]:session id:' \
  '--ignore-sleep[do not lock on suspend/hibernate]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*:locker command:_command_names' && ret=0

return ret
