#compdef wfuzz
# _wfuzz-bin — Wfuzz web app fuzzer (Christian Martorella, Python); authorized recon + brute force HTTP fuzzing tool
# upstream: https://github.com/xmendez/wfuzz

_wfuzz-bin() {
    _arguments \
        '(-h)-h[show help]' \
        '--version[show version]' \
        '-c[colored output]' \
        '-v[verbose]' \
        '-f+[output file:file_type]:str:' \
        '-o+[output format]:fmt:(raw json csv xml ftw magictree)' \
        '-p+[proxy]:proxy:' \
        '-u+[target URL]:url:_urls' \
        '-w+[wordlist file]:file:_files' \
        '-z+[payload]:payload:' \
        '-b+[cookies]:str:' \
        '-d+[POST data]:data:' \
        '-H+[header]:str:' \
        '-X+[HTTP method]:method:(GET POST PUT DELETE HEAD OPTIONS PATCH)' \
        '-A+[basic auth user:pass]:auth:' \
        '-D+[domain]:domain:' \
        '-Z[scan mode]' \
        '-R+[recursion level]:n:' \
        '-L[follow redirects]' \
        '-q[quiet]' \
        '--ip+[bind ip]:ip:_hosts' \
        '--no-cache[disable cache]' \
        '--prev[print previous request]' \
        '--ss+[regex match show]:regex:' \
        '--hs+[regex hide]:regex:' \
        '--sc+[show code]:codes:' \
        '--hc+[hide code]:codes:' \
        '--sl+[show line count]:n:' \
        '--hl+[hide line count]:n:' \
        '--sw+[show word count]:n:' \
        '--hw+[hide word count]:n:' \
        '--sh+[show char count]:n:' \
        '--hh+[hide char count]:n:' \
        '--sleep+[seconds between requests]:n:' \
        '--script+[plugin]:plugin:' \
        '--field+[show field]:field:' \
        '--no-follow[disable follow]' \
        '--filter+[filter expr]:str:' \
        '--prefilter+[pre-filter expr]:str:' \
        '--limitrequests[limit requests]' \
        '-t+[threads]:n:' \
        '-s+[delay sec]:n:' \
        '-m+[iterator]:str:(product combinations zip chain)' \
        '*:URL:_urls'
}

_wfuzz-bin "$@"
