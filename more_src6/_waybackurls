#compdef waybackurls
# Documentation: https://github.com/tomnomnom/waybackurls
# Reference accessed: 2026-05-21
# Verified: upstream main.go uses Go flag package (single-dash long names).

_arguments -s -S \
  '-dates[show date of fetch in the first column]' \
  '-no-subs[do not include subdomains of the target domain]' \
  '-get-versions[list URLs for crawled versions of input URL(s)]' \
  '*:domain:_hosts'
