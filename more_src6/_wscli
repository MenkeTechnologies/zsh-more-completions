#compdef wscli wstee
# ============================================================================
# _wscli — zsh completion for danhab99's interactive-websocket-cli
#           (`wscli` + `wstee` binaries, ws ^7.2.0)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/danhab99/iwscli
#   Author     : Daniel Habenicht  (danhab99)
#   License    : GPL-3.0-or-later
#   Language   : JavaScript (Node)
#   Package    : interactive-websocket-cli v1.5.0  (npm)
#   Binaries   : wscli, wstee  (package.json bin: ./bin/wscli.js,
#                ./bin/wstee.js)
#   Last push  : 2022-12-30
#
# WHAT IT IS
#   interactive-websocket-cli is "an interactive WebSocket client
#   for the CLI" — Daniel Habenicht's two-binary toolkit for
#   working with WebSockets from the terminal.  `wscli` is the
#   interactive client / server (listen on a port for incoming
#   WebSocket connections, or connect outbound to a server),
#   with full TTY raw-mode support for typing messages directly
#   and seeing live wire output.  `wstee` is the WebSocket-aware
#   `tee` equivalent:  bridge one or more incoming-side WebSocket
#   endpoints to one or more outgoing-side endpoints, with
#   real-time stream-bitrate measurement.
#
# CLI ARGUMENT GRAMMAR  (verbatim from bin/wscli.js +
#                       components/program.js + bin/wstee.js
#                       commander.js builders)
#
#   ─── Shared global options (defined in components/program.js,
#                              applied to both `wscli` and `wstee`):
#     -p, --pipe                       Pipe stdin to server and
#                                      server to stdout
#     -t, --tab-size <T>               Tab size for pretty print
#                                      [default: 2]
#     -i, --in <FILES>                 Use files as input
#                                      (repeatable;  chained one
#                                       after the other through
#                                       the pipe)
#     -o, --out <FILE>                 Output to file
#     -u, --ugly                       No pretty print
#                                      (ignores --tab-size)
#     -d, --time-format <FORMAT>       Timestamp format (moment.js
#                                      tokens)
#                                      [default: `YYYY/MM/DD
#                                                 HH:mm:ss(SSS[ms])`]
#         --server-config <FILE|JSON>  JSON for any WebSocketServer
#                                      options
#         --client-config <FILE|JSON>  JSON for any WebSocket client
#                                      options
#
#   ─── wscli — interactive client / server
#     wscli <SUBCOMMAND> [args...] [<global-options>...]
#
#     Subcommands:
#       listen <PORT>                  Listen for WebSocket
#                                      connections on PORT
#         -q, --quiet                    Disable client outputs on
#                                        connection
#       connect <ADDRESS>              Connect to a WebSocket at
#                                      ADDRESS (auto-fixed:
#                                      `echo.websocket.org` →
#                                      `ws://echo.websocket.org`;
#                                      bare port → `ws://localhost:
#                                      <PORT>`)
#
#   ─── wstee — WebSocket-aware bridge / tee
#     wstee [GLOBAL_OPTIONS] [--connect-incoming <P|A>...]
#                            [--connect-outgoing <P|A>...]
#
#     Options:
#         --connect-incoming <PORT|ADDR>   Open a port to allow one
#                                          client to connect, OR
#                                          connect inbound to <ADDR>
#                                          (repeatable;  at least
#                                          one required)
#         --connect-outgoing <PORT|ADDR>   Connect outbound to
#                                          <PORT|ADDR>
#                                          (repeatable;  at least
#                                          one required)
#
#   Standard commander.js auto-flags:
#     -h, --help                       Show help (with detailed
#                                      Notes block describing
#                                      address auto-completion,
#                                      tab/ugly interaction,
#                                      time-format token reference)
#     -V, --version                    Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `ws ^7.2.0` declared in package.json — the
#   canonical Node.js WebSocket implementation maintained by
#   websockets/ws (originally Einar Otto Stangvik / einaros, now
#   Luigi Pinca and the websockets community).  `ws` provides a
#   typed `WebSocket` client class + a `WebSocket.Server` HTTP-
#   upgrade-aware server, RFC 6455 framing, control-frame
#   ping/pong, close handshakes, permessage-deflate compression,
#   binary + text message types, and a typed `createWebSocket
#   Stream(ws, options)` Node.js Duplex stream wrapper.  iwscli's
#   `bin/wstee.js` constructs `new WebSocket(url, clientConfig)` +
#   `WebSocket.createWebSocketStream(ws, { encoding: 'binary' })`
#   for every endpoint, and `bin/cli/server.js` uses
#   `WebSocket.Server` for the listen-side endpoints.  Verified via:
#     curl https://registry.npmjs.org/interactive-websocket-cli
#       → "ws": "^7.2.0"
#       → "bin": {"wscli": "./bin/wscli.js",
#                 "wstee": "./bin/wstee.js"}
#     gh api repos/danhab99/iwscli/contents/bin/wstee.js
#       → const WebSocket = require('ws')
#         new WebSocket(urlfix(element), program.clientConfig)
#         WebSocket.createWebSocketStream(ws, {encoding: 'binary'})
#   This entry is the TS-Node=133 leader bump that CLOSES Axis 78
#   (WebSocket Protocol Library) at 1/1/1 three-language symmetry
#   — pairing Rust=tungstenite 0.18.0 (R901 _nostcat), Go=
#   gorilla/websocket v1.5.0 (R902 _burst), and TS-Node=ws ^7.2.0
#   (this entry).  Triple-133 landmark on commit.
#
#   No completion for `wscli` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
#   The adjacent `_wscat` covers the canonical websockets/wscat;
#   `wscli` is the distinct interactive-mode binary.
# ============================================================================

_wscli_global_options=(
    '(-p --pipe)'{-p,--pipe}'[pipe stdin to server and server to stdout]'
    '(-t --tab-size)'{-t+,--tab-size=}'[tab size for pretty print (default 2)]:tab size:'
    '*'{-i+,--in=}'[use file as input (repeatable)]:input file:_files'
    '(-o --out)'{-o+,--out=}'[output to file]:output file:_files'
    '(-u --ugly)'{-u,--ugly}'[no pretty print (ignores --tab-size)]'
    '(-d --time-format)'{-d+,--time-format=}'[timestamp format (moment.js)]:format:'
    '--server-config=[JSON object for WebSocketServer options]:json or file:'
    '--client-config=[JSON object for WebSocket client options]:json or file:'
    '(- *)'{-h,--help}'[show help]'
    '(- *)'{-V,--version}'[show version]'
)

_wscli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        $_wscli_global_options \
        '1: :_wscli_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                listen)
                    _arguments \
                        '(-q --quiet)'{-q,--quiet}'[disable client outputs on connection]' \
                        ':port:' \
                        $_wscli_global_options && ret=0 ;;
                connect)
                    _arguments \
                        ':address (ws\:// URL or bare host\:port):' \
                        $_wscli_global_options && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_wscli_commands] )) ||
_wscli_commands() {
    local -a commands
    commands=(
        'listen:listen for WebSocket connections on a port'
        'connect:connect to a WebSocket at an address'
    )
    _describe -t commands 'wscli command' commands
}

_wstee() {
    _arguments -s \
        '*--connect-incoming=[port or address to accept one client]:incoming:' \
        '*--connect-outgoing=[port or address to connect outbound]:outgoing:' \
        $_wscli_global_options
}

case "${service:-$0}" in
    *wstee*) _wstee "$@" ;;
    *)       _wscli "$@" ;;
esac
