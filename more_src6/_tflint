#compdef tflint
# Documentation: https://github.com/terraform-linters/tflint
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for tflint - Terraform linter

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --config)'{-c,--config}'=[config file path]:file:_files' \
  '--init[install plugins]' \
  '--langserver[start language server]' \
  '--force[return zero exit status even with issues]' \
  '(-f --format)'{-f,--format}'=[output format]:format:(default json checkstyle junit compact sarif)' \
  '--recursive[run in each directory recursively]' \
  '*--filter=[filter issues by file names or globs]:file:_files' \
  '--color[enable colorized output]' \
  '--no-color[disable colorized output]' \
  '--call-module-type=[types of module to call]:type:(all local none)' \
  '--minimum-failure-severity=[minimum severity for exit code]:severity:(error warning notice)' \
  '--chdir=[switch to a different working directory]:dir:_directories' \
  '*--var=[set a Terraform variable]:key=value:' \
  '*--var-file=[Terraform variable file]:file:_files' \
  '*--enable-rule=[enable rule from command line]:rule:' \
  '*--disable-rule=[disable rule from command line]:rule:' \
  '*--only=[enable only specified rule]:rule:' \
  '*--enable-plugin=[enable plugin from command line]:plugin:' \
  '*--ignore-module=[ignore module sources]:source:' \
  '--fix[fix issues automatically]' \
  '--no-parallel-runners[disable per-runner parallelism]' \
  '--max-workers=[maximum number of workers]:n:' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:file:_files' && ret=0

return ret
