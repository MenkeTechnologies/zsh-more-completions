#compdef tiffinfo
# Documentation: tiffinfo usage on libtiff 4.7.1
# Source: libtiff tiffinfo — display information about TIFF files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-D[read data]' \
    '-i[ignore read errors]' \
    '-c[display gray/color response curve or colormap]' \
    '-d[display raw/decoded image data]' \
    '-f+[force input FillOrder]:order:(lsb2msb msb2lsb)' \
    '-j[show JPEG tables]' \
    '-o+[initial directory offset]:offset:' \
    '-r[read raw image data instead of decoded]' \
    '-s[display strip offsets and byte counts]' \
    '-w[display raw data as 16-bit words]' \
    '-z[enable strip chopping]' \
    '-M+[memory allocation limit (MiB; 0 = no limit)]:size:' \
    '-W[warn about unknown tags]' \
    '*:input TIFF:_files -g "*.{tif,tiff,TIF,TIFF}"' \
    && ret=0

return ret
