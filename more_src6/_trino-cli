#compdef trino-cli trino-cli2
# _trino-cli — Trino Software Foundation trino-cli CLI command-line frontend wrapping the Trino distributed SQL query engine fork of Presto interactive shell-mode batch-mode supporting catalog schema session execute SQL output-format CSV JSON JSON-LINES ALIGNED VERTICAL NULL TABLE AUTO COSE COSE-WITHOUT-HEADER (Trino team, Java); custom argparse
# upstream: https://trino.io/

_trino-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--server=+[host:port]:str:' \
        '--catalog=+[name]:str:' \
        '--schema=+[name]:str:' \
        '--user=+[user]:str:' \
        '--password[prompt for password]' \
        '--krb5-config-path=+[file]:file:_files' \
        '--krb5-credential-cache-path=+[file]:file:_files' \
        '--krb5-keytab-path=+[file]:file:_files' \
        '--krb5-principal=+[principal]:str:' \
        '--krb5-remote-service-name=+[name]:str:' \
        '--krb5-disable-remote-service-hostname-canonicalization[disable canonicalization]' \
        '--source=+[name]:str:' \
        '--client-info=+[info]:str:' \
        '--client-tags=+[tags]:str:' \
        '--client-request-timeout=+[duration]:str:' \
        '--trace-token=+[token]:str:' \
        '--debug[debug]' \
        '--insecure[insecure]' \
        '--keystore-path=+[file]:file:_files' \
        '--keystore-password=+[password]:str:' \
        '--truststore-path=+[file]:file:_files' \
        '--truststore-password=+[password]:str:' \
        '--access-token=+[token]:str:' \
        '--external-authentication[external auth]' \
        '--http-proxy=+[host:port]:str:' \
        '--socks-proxy=+[host:port]:str:' \
        '--output-format=+[fmt]:f:(CSV CSV_HEADER CSV_HEADER_UNQUOTED CSV_UNQUOTED TSV TSV_HEADER JSON JSON_LINES ALIGNED VERTICAL TABLE AUTO NULL MARKDOWN)' \
        '--no-progress[disable progress]' \
        '--pager=+[program]:_command_names' \
        '--history-file=+[file]:file:_files' \
        '--editor=+[editor]:_command_names' \
        '--execute=+[SQL]:str:' \
        '-e+[SQL]:str:' \
        '-f+[SQL file]:file:_files -g "*.sql"' \
        '--file=+[file]:file:_files -g "*.sql"' \
        '--session=+[k=v]:str:' \
        '--session-user=+[name]:str:' \
        '--client-options=+[opts]:str:' \
        '--resource-estimate=+[k=v]:str:' \
        '*:trino URL:'
}

_trino-cli "$@"
