#compdef yadm
# Documentation: https://github.com/yadm-dev/yadm/blob/master/yadm.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for yadm - Yet Another Dotfiles Manager

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'init:initialize a new empty yadm repository'
  'clone:clone a remote repository for tracking dotfiles'
  'list:print files managed by yadm'
  'add:add file contents to the index'
  'commit:record changes to the repository'
  'push:update remote refs'
  'pull:fetch from and integrate with another repository'
  'fetch:download objects and refs'
  'status:show working tree status'
  'alt:create links and process templates for managed files'
  'perms:update permissions for sensitive files'
  'encrypt:encrypt files matching encrypt patterns'
  'decrypt:decrypt files stored in the archive'
  'config:get and set yadm configuration'
  'gitconfig:run git config on the yadm managed repo'
  'bootstrap:execute the configured bootstrap program'
  'enter:run a sub-shell with yadm environment set'
  'git-crypt:interface for transparent file encryption'
  'transcrypt:configure transparent encryption'
  'upgrade:upgrade yadm repository to latest format'
  'introspect:report internal yadm data for command completion'
  'version:display yadm version'
  'help:display help information'
)

_arguments -s -S \
  '(-Y --yadm-dir)'{-Y,--yadm-dir}'[override the yadm directory]:dir:_files -/' \
  '--yadm-data[override the yadm data directory]:dir:_files -/' \
  '--yadm-repo[override path to yadm repository]:path:_files -/' \
  '--yadm-config[override path to yadm config file]:file:_files' \
  '--yadm-encrypt[override path to encrypt patterns file]:file:_files' \
  '--yadm-archive[override path to encrypted archive file]:file:_files' \
  '--yadm-bootstrap[override path to bootstrap program]:file:_files' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      add|rm|checkout|diff|reset|restore|status)
        _arguments '*:tracked file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
