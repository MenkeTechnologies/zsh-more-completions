#compdef whisper-ctranslate2
# _whisper-ctranslate2 — fast Whisper via CTranslate2 (Softcatala/whisper-ctranslate2)
# upstream: https://github.com/Softcatala/whisper-ctranslate2
# Flags from src/whisper_ctranslate2/commandline.py (argparse).

_whisper-ctranslate2() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--model=[Whisper model]:model:(tiny tiny.en base base.en small small.en medium medium.en large-v1 large-v2 large-v3 large-v3-turbo turbo distil-large-v2 distil-large-v3 distil-large-v3.5 distil-medium.en distil-small.en)' \
        '--model_dir=[model cache directory]:dir:_files -/' \
        '--model_directory=[explicit model dir]:dir:_files -/' \
        '--local_files_only[do not download models]' \
        '--hf_token=[HuggingFace API token]:token:' \
        '--device=[compute device]:device:(auto cpu cuda)' \
        '--device_index=[device index]:idx:' \
        '--compute_type=[compute precision]:type:(default int8 int8_float16 int8_bfloat16 int8_float32 int16 float16 bfloat16 float32 float64)' \
        '--threads=[CPU threads]:n:' \
        '--batched[use BatchedInferencePipeline]' \
        '--batch_size=[batch size]:n:' \
        '--task=[task]:task:(transcribe translate)' \
        '--language=[language code]:lang:' \
        '--multilingual[force multilingual mode]' \
        '--initial_prompt=[initial prompt for first window]:text:' \
        '--prefix=[prefix for first window]:text:' \
        '--prompt_reset_on_temperature=[reset prompt above this temperature]:value:' \
        '--temperature=[sampling temperature]:value:' \
        '--temperature_increment_on_fallback=[temp step on fallback]:value:' \
        '--beam_size=[beam size]:n:' \
        '--best_of=[best-of candidates]:n:' \
        '--patience=[beam search patience]:value:' \
        '--length_penalty=[length penalty]:value:' \
        '--repetition_penalty=[repetition penalty]:value:' \
        '--no_repeat_ngram_size=[ngram repeat blocker]:n:' \
        '--suppress_blank[suppress blank outputs]' \
        '--suppress_tokens=[comma-separated tokens to suppress]:list:' \
        '--no_speech_threshold=[no-speech threshold]:value:' \
        '--logprob_threshold=[log probability threshold]:value:' \
        '--compression_ratio_threshold=[compression ratio threshold]:value:' \
        '--condition_on_previous_text=[condition on previous text]:bool:(true false)' \
        '--hallucination_silence_threshold=[hallucination silence threshold]:value:' \
        '--vad_filter[apply VAD filter]' \
        '--word_timestamps[output per-word timestamps]' \
        '--highlight_words[highlight spoken words]' \
        '--prepend_punctuations=[chars to prepend to next word]:str:' \
        '--append_punctuations=[chars to append to previous word]:str:' \
        '--max_words_per_line=[max words per subtitle line]:n:' \
        '--max_line_width=[max characters per line]:n:' \
        '--max_line_count=[max number of lines]:n:' \
        '--hotwords=[hotwords for biasing]:list:' \
        '--print_colors[print transcript with color]' \
        '--pretty_json[pretty-print JSON]' \
        '--speaker_name=[speaker name (diarization)]:name:' \
        '--speaker_num=[expected number of speakers]:n:' \
        '--output_dir=[output directory]:dir:_files -/' \
        '--output_format=[output format]:format:(srt vtt txt tsv json all)' \
        '--live_transcribe[live transcribe from microphone]' \
        '--live_input_device=[live input device]:device:' \
        '--live_input_device_sample_rate=[live input sample rate]:rate:' \
        '--live_volume_threshold=[live volume threshold]:value:' \
        '*:audio file:_files -g "*.{wav,mp3,m4a,flac,ogg,opus,webm,mp4}"'
}

_whisper-ctranslate2 "$@"
