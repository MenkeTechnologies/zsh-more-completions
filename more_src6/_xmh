#compdef xmh
# Documentation: man xmh (X.Org)
# Source: X interface to MH mail (legacy MIT MH client).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-path+[MH mail path]:directory:_files -/' \
    '-initial+[initial folder]:folder:' \
    '-flag[flag this xmh for new mail (alters appearance)]' \
    '-display+[X display]:display:' \
    '-geometry+[window geometry]:geom:' \
    '-bg+[background color]:color:' \
    '-fg+[foreground color]:color:' \
    && ret=0

return ret
