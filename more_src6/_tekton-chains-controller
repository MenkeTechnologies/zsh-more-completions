#compdef tekton-chains-controller
# _tekton-chains-controller — Tekton Chains supply-chain signing controller (tektoncd/chains)
# upstream: https://github.com/tektoncd/chains
# Flags from cmd/controller/main.go + knative.dev/pkg/injection/sharedmain on tip.

_tekton-chains-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--threads-per-controller=[goroutines per controller]:n:' \
        '--namespace=[comma-sep informer namespaces (empty = all)]:list:' \
        '--disable-controllers=[comma-sep disabled controllers]:list:' \
        '--disable-ha[disable high-availability/leader election]' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr[log to stderr]'
}

_tekton-chains-controller "$@"
