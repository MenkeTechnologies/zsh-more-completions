#compdef xen-bugtool
# Documentation: https://github.com/xenserver/status-report (xen-bugtool script)
# Reference accessed: 2026-05-21
# Verified: upstream xen-bugtool getopt.gnu_getopt() parser quoted from source.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '--capabilities[list capabilities and exit]' \
  '(-y --yestoall)'{-y,--yestoall}'[answer yes to all prompts]' \
  '(-s --silent)'{-s,--silent}'[silent: no progress output]' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '(-a --all)'{-a,--all}'[include all capabilities]' \
  '(-u --unlimited)'{-u,--unlimited}'[unlimited collection size]' \
  '--entries=[capability list (comma-separated, optional :verbosity)]:entries:' \
  '--output=[output format]:fmt:(tar tar.bz2 zip)' \
  '--outfd=[write archive to this file descriptor]:fd:' && ret=0
return ret
