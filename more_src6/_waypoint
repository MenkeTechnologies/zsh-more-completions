#compdef waypoint
# Documentation: https://github.com/hashicorp/waypoint/tree/main/website/content/commands
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above. NOTE: HashiCorp Waypoint
# Community Edition is archived (Jan 2024), no longer actively maintained.

_waypoint_commands() {
  local -a commands=(
    'artifact:Manage artifacts'
    'auth-method:Manage auth methods'
    'build:Build a new versioned artifact'
    'config:Manage application configuration'
    'config-source:Manage config sources'
    'context:Manage CLI contexts'
    'deploy:Deploy a built artifact'
    'deployment:Manage deployments'
    'destroy:Destroy all resources'
    'docs:Open documentation'
    'exec:Execute a command in a container'
    'fmt:Format HCL config'
    'hostname:Manage hostnames'
    'init:Initialize a new project'
    'install:Install the Waypoint server'
    'job:Manage jobs'
    'k8s:Kubernetes related commands'
    'login:Log in to Waypoint server'
    'logs:Show application logs'
    'pipeline:Manage pipelines'
    'plugin:Manage plugins'
    'project:Manage projects'
    'release:Release a deployed artifact'
    'runner:Manage runners'
    'server:Manage the Waypoint server'
    'status:Show project status'
    'task:Manage tasks'
    'token:Manage tokens'
    'trigger:Manage triggers'
    'ui:Open the Waypoint UI'
    'up:Build, deploy, and release'
    'user:Manage users'
    'version:Print version'
    'workspace:Manage workspaces'
  )
  _describe 'command' commands
}

_waypoint() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '-app[Application name]:app:' \
    '-project[Project name]:project:' \
    '-workspace[Workspace name]:workspace:' \
    '-plain[Plain output]' \
    '-v[Verbose output]' \
    '1:command:_waypoint_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        init)
          _arguments \
            '-from-project[Initialize from existing project]:project:' \
            '-into[Directory to initialize into]:dir:_directories'
          ;;
        up|build|deploy|release)
          _arguments \
            '-app[Application]:app:' \
            '-workspace[Workspace]:workspace:' \
            '-prune[Prune old resources]' \
            '-prune-retain[Resources to retain]:count:' \
            '-label[Labels]:label:'
          ;;
        destroy)
          _arguments \
            '-app[Application]:app:' \
            '-workspace[Workspace]:workspace:' \
            '-auto-approve[Auto approve destroy]'
          ;;
        logs)
          _arguments \
            '-app[Application]:app:' \
            '-workspace[Workspace]:workspace:' \
            '-deployment-seq[Deployment sequence]:seq:'
          ;;
        exec)
          _arguments \
            '-app[Application]:app:' \
            '-workspace[Workspace]:workspace:' \
            '-deployment-seq[Deployment sequence]:seq:' \
            '*:command:'
          ;;
        config)
          local -a subcmds=(
            'set:Set a config variable'
            'get:Get config variable(s)'
            'delete:Delete a config variable'
            'sync:Sync config'
            'source-set:Set a config source'
            'source-get:Get config sources'
            'source-delete:Delete a config source'
          )
          _describe 'config subcommand' subcmds
          ;;
        install)
          _arguments \
            '-platform[Platform to install on]:platform:(docker ecs kubernetes nomad)' \
            '-accept-tos[Accept terms of service]'
          ;;
        context)
          local -a subcmds=(
            'create:Create a new context'
            'delete:Delete a context'
            'list:List contexts'
            'use:Set default context'
            'rename:Rename a context'
            'verify:Verify context connection'
          )
          _describe 'context subcommand' subcmds
          ;;
        server)
          local -a subcmds=(
            'install:Install server'
            'uninstall:Uninstall server'
            'upgrade:Upgrade server'
            'run:Run server'
            'bootstrap:Bootstrap server'
            'config-set:Set server config'
            'snapshot:Create server snapshot'
            'restore:Restore server snapshot'
          )
          _describe 'server subcommand' subcmds
          ;;
      esac
      ;;
  esac
}

_waypoint "$@"
