#compdef yosys-abc
# Documentation: https://github.com/berkeley-abc/abc
# Reference accessed: 2026-05-21
# Verified: upstream sources src/base/main/mainReal.c + mainUtils.c
# (Abc_UtilsPrintUsage).

local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-c+[execute command]:cmd:' \
  '-q+[execute commands quietly]:cmd:' \
  '-C+[execute commands then continue interactive]:cmd:' \
  '-Q+[execute quietly then continue interactive]:cmd:' \
  '-F+[run commands from script file with echo]:file:_files' \
  '-f+[run commands from script file]:file:_files' \
  '-o+[output filename]:file:_files' \
  '-s[skip reading initialization files]' \
  '-t+[input file type]:type:(blif_mv blif_mvs blif none)' \
  '-T+[output file type]:type:(blif_mv blif_mvs blif none)' \
  '-x[equivalent to -t none -T none]' \
  '-b[enable bridge mode]' \
  '*:input netlist or script:_files' && ret=0
return ret
