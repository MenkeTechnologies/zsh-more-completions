#compdef telepresence
# _telepresence-bin — Telepresence local + remote k8s dev (Ambassador Labs, Go); transparently proxy traffic between local + cluster
# upstream: https://github.com/telepresenceio/telepresence

_telepresence-bin() {
    local -a sub=(
        'config:manage config'
        'connect:connect to traffic-manager'
        'completion:print shell completion'
        'curl:curl from inside cluster'
        'dashboard:open dashboard'
        'gather-logs:gather logs from local + traffic-manager'
        'gather-traces:gather traces from local + traffic-manager'
        'genyaml:generate sidecar yaml'
        'helm:helm subcommand'
        'image-info:list cluster images'
        'intercept:intercept a service'
        'leave:leave an intercept'
        'license:license install/uninstall'
        'list:list current intercepts'
        'login:login to Ambassador'
        'logout:logout'
        'loglevel:set local log level'
        'quit:quit user-daemon'
        'status:show status'
        'test-vpn:test VPN setup'
        'uninstall:uninstall traffic-agent or manager'
        'upload-traces:upload traces'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--allow-conflicting-subnets+[allow conflicting subnets]:subnets:' \
        '-c+[context]:context:' \
        '--context+[kube context]:context:' \
        '--kubeconfig+[kubeconfig]:file:_files' \
        '-n+[namespace]:namespace:' \
        '--namespace+[namespace]:namespace:' \
        '--manager-namespace+[traffic-manager namespace]:ns:' \
        '--use-cluster-from-kubeconfig+[use kubeconfig cluster]:bool:(true false)' \
        '--no-output[no output]' \
        '--no-report[no report]' \
        '--use+[selector]:selector:' \
        '--workload+[workload]:str:' \
        '-w+[workload]:str:' \
        '-v+[verbosity]:n:' \
        '--verbose[verbose]' \
        '--cmd-time-format+[time format]:fmt:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'telepresence subcommand' sub ;;
        args)
            case $words[1] in
                connect) _arguments \
                    '--also-proxy+[proxy subnets]:subnets:' \
                    '--mapped-namespaces+[mapped namespaces]:ns:' \
                    '--never-proxy+[never proxy subnets]:subnets:' \
                    '--dns+[dns server]:dns:' ;;
                intercept) _arguments \
                    '1:service:' \
                    '--port+[port:remote_port:protocol]:port:' \
                    '-p+[port:remote_port:protocol]:port:' \
                    '--service+[service name]:str:' \
                    '--workload+[workload]:str:' \
                    '--global[global intercept]' \
                    '--mount+[mount remote pod fs]:str:' \
                    '--env-file+[env file]:file:_files' \
                    '--env-json+[env json file]:file:_files' \
                    '--header+[header match]:str:' \
                    '--path-equal+[path equal]:str:' \
                    '--path-prefix+[path prefix]:str:' \
                    '--path-regex+[path regex]:regex:' \
                    '--http-meta+[meta]:str:' \
                    '--detail+[level detail]:n:' \
                    '*::args:_command_names -e' ;;
                leave) _arguments '*:intercept name:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_telepresence-bin "$@"
