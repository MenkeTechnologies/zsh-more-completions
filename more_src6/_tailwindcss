#compdef tailwindcss
# Documentation: https://github.com/tailwindlabs/tailwindcss/tree/main/packages/%40tailwindcss-cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for Tailwind CSS CLI (v4)

_tailwindcss() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '(-i --input)'{-i,--input}'=[input file]:input file:_files -g "*.css"' \
    '(-o --output)'{-o,--output}'=[output file]:output file:_files -g "*.css"' \
    '(-w --watch)'{-w,--watch}'[watch for changes and rebuild as needed]' \
    '(-m --minify)'{-m,--minify}'[optimize and minify the output]' \
    '--optimize[optimize the output without minifying]' \
    '--cwd=[current working directory]:dir:_directories' \
    '--map=[generate a source map]' \
    '(-h --help)'{-h,--help}'[display usage information]' \
    '1:command:(build canonicalize)' \
    && ret=0

  return ret
}

_tailwindcss "$@"
