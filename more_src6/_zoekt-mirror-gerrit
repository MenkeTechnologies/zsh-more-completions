#compdef zoekt-mirror-gerrit
# _zoekt-mirror-gerrit — Zoekt Gerrit repository mirror
# upstream: https://github.com/sourcegraph/zoekt
# Flags from cmd/zoekt-mirror-gerrit/main.go on tip.

_zoekt-mirror-gerrit() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-dest=[destination directory]:dir:_files -/' \
        '-name=[regex of repo names to clone]:regex:' \
        '-repo-name-format=[local repo name format]:fmt:' \
        '-exclude=[regex of repo names to skip]:regex:' \
        '-delete=[delete missing repos]:bool:(true false)' \
        '-fetch-meta-config=[fetch Gerrit meta/config branch]:bool:(true false)' \
        '-http-credentials=[file holding user:password HTTP credentials]:file:_files' \
        '-active=[mirror only active projects]:bool:(true false)' \
        '*:url:_urls'
}

_zoekt-mirror-gerrit "$@"
