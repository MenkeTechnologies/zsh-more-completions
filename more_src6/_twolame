#compdef twolame
# Documentation: https://manpages.debian.org/bookworm/twolame/twolame.1.en.html
# Reference accessed: 2026-05-21
# Verified: Debian twolame.1 manpage and TwoLAME upstream docs.

_arguments -s \
  '(-r --raw-input)'{-r,--raw-input}'[raw PCM input]' \
  '(-x --byte-swap)'{-x,--byte-swap}'[byte swap]' \
  '(-s --samplerate)'{-s,--samplerate}'=[sample rate]:rate:(16000 22050 24000 32000 44100 48000)' \
  '--samplesize=[bits]:bits:(8 16 24 32)' \
  '(-N --channels)'{-N,--channels}'=[channels]:n:' \
  '(-g --swap-channels)'{-g,--swap-channels}'[swap channels]' \
  '--scale=[gain]:gain:' \
  '--scale-l=[L gain]:gain:' \
  '--scale-r=[R gain]:gain:' \
  '(-m --mode)'{-m,--mode}'=[mode]:mode:(a s d j m)' \
  '(-a --downmix)'{-a,--downmix}'[downmix]' \
  '(-b --bitrate)'{-b,--bitrate}'=[kbps]:kbps:' \
  '(-P --psyc-mode)'{-P,--psyc-mode}'=[model]:n:' \
  '(-v --vbr)'{-v,--vbr}'[VBR]' \
  '(-V --vbr-level)'{-V,--vbr-level}'=[quality]:n:' \
  '(-l --ath)'{-l,--ath}'=[ATH]:n:' \
  '(-q --quick)'{-q,--quick}'=[interval]:n:' \
  '(-S --single-frame)'{-S,--single-frame}'[single frame]' \
  '(-c --copyright)'{-c,--copyright}'[copyright]' \
  '(-o --non-original)'{-o,--non-original}'[non-original]' \
  '--original[original flag]' \
  '(-p --protect)'{-p,--protect}'[CRC]' \
  '(-d --padding)'{-d,--padding}'[padding]' \
  '(-R --reserve)'{-R,--reserve}'=[bits]:n:' \
  '(-e --deemphasis)'{-e,--deemphasis}'=[char]:char:(n c 5)' \
  '(-E --energy)'{-E,--energy}'[energy ext]' \
  '(-t --talkativity)'{-t,--talkativity}'=[level]:n:' \
  '--quiet[quiet]' \
  '--brief[brief]' \
  '--verbose[verbose]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:file:_files'
