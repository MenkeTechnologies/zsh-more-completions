#compdef vue
# _vue-cli-bin — Vue CLI 3-5 (Vue Team); legacy scaffolding before create-vue/vite era
# upstream: https://github.com/vuejs/vue-cli

_vue-cli-bin() {
    local -a sub=(
        'create:create new project'
        'add:install a plugin and invoke its generator'
        'invoke:invoke a plugin generator'
        'inspect:inspect resolved webpack config'
        'serve:run dev server'
        'build:build for production'
        'ui:start Vue UI'
        'init:legacy init (vue-init)'
        'config:read or set config'
        'outdated:check outdated packages'
        'upgrade:upgrade Vue CLI plugins'
        'migrate:legacy migration helper'
        'info:print env info'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vue subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '(-p --preset)'{-p,--preset}'+[preset]:preset:' \
                    '(-d --default)'{-d,--default}'[default preset]' \
                    '(-i --inlinePreset)'{-i,--inlinePreset}'+[inline preset JSON]:json:' \
                    '(-m --packageManager)'{-m,--packageManager}'+[package manager]:pm:(yarn npm pnpm)' \
                    '(-r --registry)'{-r,--registry}'+[npm registry]:url:_urls' \
                    '(-g --git)'{-g,--git}'+[git commit message]:msg:' \
                    '(-n --no-git)'{-n,--no-git}'[skip git init]' \
                    '(-f --force)'{-f,--force}'[overwrite target]' \
                    '--merge[merge with existing]' \
                    '(-c --clone)'{-c,--clone}'[clone remote preset]' \
                    '(-x --proxy)'{-x,--proxy}'+[proxy]:proxy:' \
                    '(-b --bare)'{-b,--bare}'[bare scaffolding]' \
                    '--skipGetStarted[skip welcome msg]' \
                    '1:project name:' ;;
                serve) _arguments \
                    '--open[open browser]' \
                    '--copy[copy URL]' \
                    '--mode+[mode]:mode:(development production test)' \
                    '--host+[host]:host:_hosts' \
                    '--port+[port]:port:' \
                    '--https[serve over HTTPS]' \
                    '--public+[public URL]:url:_urls' \
                    '--skip-plugins+[skip plugins]:plugins:' ;;
                build) _arguments \
                    '--mode+[mode]:mode:(development production test)' \
                    '--dest+[output dir]:dir:_files -/' \
                    '--modern[modern build]' \
                    '--no-unsafe-inline[no unsafe-inline]' \
                    '--target+[target]:target:(app lib wc wc-async)' \
                    '--inline-vue[inline vue]' \
                    '--formats+[formats]:fmt:' \
                    '--name+[lib name]:name:' \
                    '--filename+[filename]:name:' \
                    '--no-clean[do not clean output]' \
                    '--report[generate stats report]' \
                    '--report-json[report JSON]' \
                    '--skip-plugins+[skip plugins]:plugins:' \
                    '--watch[watch and rebuild]' \
                    '--stdin[read entry from stdin]' ;;
                add) _arguments '*:plugin:' ;;
                invoke) _arguments '1:plugin:' ;;
                ui) _arguments \
                    '--host+[host]:host:_hosts' \
                    '--port+[port]:port:' \
                    '--headless[headless mode]' \
                    '--dev[dev mode]' \
                    '--quiet[quiet]' \
                    '--https[serve over HTTPS]' \
                    '--public+[public URL]:url:_urls' ;;
                inspect) _arguments \
                    '--mode+[mode]:mode:(development production test)' \
                    '--rule+[rule name]:rule:' \
                    '--plugin+[plugin name]:plugin:' \
                    '--rules[list rule names]' \
                    '--plugins[list plugin names]' \
                    '--verbose[verbose]' ;;
            esac
            ;;
    esac
}

_vue-cli-bin "$@"
