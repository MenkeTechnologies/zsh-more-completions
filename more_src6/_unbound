#compdef unbound
# Documentation: unbound -h (NLnetLabs)
# Source: validating, recursive, caching DNS resolver daemon.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(- *)-V[show version and build options]' \
    '-c+[config file path]:file:_files -g "*.conf"' \
    '-d[do not fork into background]' \
    '-p[do not create a pidfile]' \
    '*-v[increase verbosity (stackable)]' \
    && ret=0

return ret
