#compdef whom
# Documentation: man whom(1)
# Source: nmh uip/whom.c (master) — verify recipient addresses (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-alias+[alias file]:file:_files' \
    '(-check -nocheck)-check[contact SMTP server to verify]' \
    '(-check -nocheck)-nocheck[only parse addresses]' \
    '-draft[verify draft]' \
    '-draftfolder+[draft folder]:folder:_default' \
    '-draftmessage+[draft message]:msg:_default' \
    '-nodraftfolder[no draft folder]' \
    '-version[show version]' \
    '-help[show help]' \
    '-client+[client hostname]:host:_hosts' \
    '-server+[SMTP server]:host:_hosts' \
    '-snoop[show server transcript]' \
    '-sasl[use SASL]' \
    '-saslmech+[SASL mechanism]:mech:_default' \
    '-user+[username]:user:_default' \
    '-port+[port name/number]:port:_default' \
    '(-tls -notls -initialtls)-tls[STARTTLS]' \
    '(-tls -notls -initialtls)-initialtls[immediate TLS]' \
    '(-tls -notls -initialtls)-notls[no TLS]' \
    '-mts+[mail transport]:transport:(smtp sendmail/smtp sendmail/pipe)' \
    '*::msgs:_default' \
    && ret=0

return ret
