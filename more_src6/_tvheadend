#compdef tvheadend
# Documentation: https://github.com/tvheadend/tvheadend/blob/master/man/tvheadend.1
# Reference accessed: 2026-05-21
# Verified: upstream man/tvheadend.1.

# tvheadend: TV streaming server / DVR
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config=}'[alternative config path]:path:_files -/' \
  '(-B --nobackup)'{-B,--nobackup}'[do not backup config tree at upgrade]' \
  '-f[fork and become daemon]' \
  '(-u --user)'{-u,--user=}'[run as user]:user:_users' \
  '(-g --group)'{-g,--group=}'[run as group]:group:_groups' \
  '(-p --pid)'{-p,--pid=}'[PID file]:file:_files' \
  '(-C --firstrun)'{-C,--firstrun}'[first run (DANGEROUS: no auth)]' \
  '(-U --dbus)'{-U,--dbus}'[enable DBus]' \
  '(-e --dbus_session)'{-e,--dbus_session}'[use session DBus]' \
  '(-a --adapters)'{-a,--adapters=}'[only use specified DVB adapters]:list:' \
  '--satip_rtsp=[SAT>IP RTSP port]:port:' \
  '--nosatipcli[no SAT>IP client]' \
  '--satip_xml=[SAT>IP XML URL]:url:' \
  '(-6 --ipv6)'{-6,--ipv6}'[listen on IPv6]' \
  '(-b --bindaddr)'{-b,--bindaddr=}'[bind address]:addr:' \
  '--http_port=[HTTP port]:port:' \
  '--http_root=[HTTP root path]:path:' \
  '--htsp_port=[HTSP port]:port:' \
  '--htsp_port2=[HTSP port 2]:port:' \
  '--useragent=[User-Agent string]:string:' \
  '--xspf[use XSPF playlist instead of M3U]' \
  '(-d --stderr)'{-d,--stderr}'[debug to stderr]' \
  '(-n --nostderr)'{-n,--nostderr}'[no stderr]' \
  '(-s --syslog)'{-s,--syslog}'[enable syslog]' \
  '(-S --nosyslog)'{-S,--nosyslog}'[disable syslog]' \
  '(-l --logfile)'{-l,--logfile=}'[log file]:file:_files' \
  '--debug=[debug subsystems]:list:' \
  '--trace=[trace subsystems]:list:' \
  '--fileline[include file/line in log]' \
  '--threadid[include thread ID in log]' \
  '--libav[libav logging]' \
  '--uidebug[UI debug]' \
  '(-A --abort)'{-A,--abort}'[abort on startup (debug)]' \
  '(-D --dump)'{-D,--dump}'[enable coredumps]' \
  '--noacl[disable ACL]' \
  '--nobat[no BAT]' \
  '(-j --join)'{-j,--join=}'[join service]:service:' \
  '--tsfile_tuners=[TS file tuners]:n:' \
  '--tsfile=[TS file]:file:_files' && ret=0
return ret
