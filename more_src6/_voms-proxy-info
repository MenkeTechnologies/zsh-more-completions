#compdef voms-proxy-info
# Documentation: https://manpages.debian.org/testing/voms-clients-java/voms-proxy-info.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream man page at the URL above.

# voms-proxy-info: show information about a VOMS GSI proxy
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[display usage]' \
  '--usage[display usage]' \
  '--version[display version]' \
  '--debug[enable extra debug output]' \
  '--acexists=[check whether AC for the named VO exists]:voname:' \
  '--acissuer[print AC issuer]' \
  '--acsubject[print AC subject]' \
  '--actimeleft[print AC time left]' \
  '--all[print all information]' \
  '(-b --bits)'{-b,--bits}'=[key size in bits]:bits:' \
  '--chain[print full certificate chain]' \
  '--conf=[read options from file]:file:_files' \
  '(-e --exists)'{-e,--exists}'[check whether a proxy exists]' \
  '--file=[proxy file in a non-standard place]:file:_files' \
  '--fqan[print FQANs]' \
  '--hours=[check proxy is valid for at least H hours]:hours:' \
  '--identity[print identity]' \
  '--issuer[print issuer]' \
  '(-k --keyusage)'{-k,--keyusage}'[print key usage]' \
  '(-p --path)'{-p,--path}'[print path to proxy]' \
  '--serial[print serial number]' \
  '--strength[print key strength]' \
  '--subject[print subject]' \
  '--text[print all proxy information in text]' \
  '--timeleft[print time left for proxy]' \
  '--type[print proxy type]' \
  '--uri[print VOMS server URI]' \
  '--valid=[check proxy validity HH:MM]:duration:' \
  '--vo[print VO name]' \
  '*::voms-proxy-info args:_files' && ret=0
return ret
