#compdef tpm2_activatecredential
# _tpm2_activatecredential — tpm2-software tpm2_activatecredential validate an encrypted credential against a TPM2 attestation key (tpm2-software team, C); custom argparse
# upstream: https://github.com/tpm2-software/tpm2-tools

_tpm2_activatecredential() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[activate key context]:file:_files' \
        '--credentialedkey-context=+[activate key context]:file:_files' \
        '-C+[ek context]:file:_files' \
        '--credentialkey-context=+[ek context]:file:_files' \
        '-p+[activate key auth]:str:' \
        '--credentialedkey-auth=+[activate key auth]:str:' \
        '-P+[ek auth]:str:' \
        '--credentialkey-auth=+[ek auth]:str:' \
        '-i+[input credential blob]:file:_files' \
        '--credential-blob=+[input credential blob]:file:_files' \
        '-o+[output secret]:file:_files' \
        '--certinfo-data=+[output secret]:file:_files' \
        '-S+[session]:str:' \
        '--session=+[session]:str:' \
        '-Q[do not output anything]' \
        '--cphash=+[cp hash file]:file:_files'
}

_tpm2_activatecredential "$@"
