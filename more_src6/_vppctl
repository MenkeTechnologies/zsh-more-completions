#compdef vppctl
# _vppctl — fd.io VPP control CLI (FD.io / Cisco, C); custom argparse
# upstream: https://github.com/FDio/vpp

_vppctl() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-s+[socket path]:file:_files' \
        '--socket=+[socket path]:file:_files' \
        '--tcp=+[tcp address]:str:' \
        '*:cli-command:'
}

_vppctl "$@"
