#compdef zssh ztelnet
# Documentation: https://manpages.debian.org/bookworm/zssh/zssh.1.en.html
# Reference accessed: 2026-05-21
# Verified: Debian bookworm zssh(1) manpage SYNOPSIS + OPTIONS section.
# zssh is an interactive ssh/telnet wrapper for zmodem file transfer
# (rz/sz). NOT the OpenSSH client. Prior completion fabricated 30+
# openssh flags (-1 -2 -4 -6 -A -C -L -R etc.) that zssh does not
# accept — those were upstream-undocumented copies of ssh(1).
# After `--`, remaining args pass through to ssh/telnet — defer host
# completion to the underlying tool via _normal.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show basic help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-f --force)'{-f,--force}'[do not ask user any question]' \
  '(-s --shell)'{-s,--shell}'+[run CMD as remote shell instead of the default]:shell command' \
  '(-z --zssh-escape)'{-z,--zssh-escape}'+[set the escape sequence (default ^@)]:escape sequence' \
  '(-)--[end zssh options; pass remainder to ssh/telnet]' \
  '*::ssh/telnet args:_normal' && ret=0

return ret
