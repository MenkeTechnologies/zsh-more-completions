#compdef virt-format
# _virt-format — libguestfs virt-format (wipe one or more disk images and reinitialize them with a new partition table + filesystem; -a disk, --filesystem (ext4|xfs|btrfs|vfat|...), --partition=(mbr|gpt|none), --wipe extra zeroing, --lvm group, --label fs label; supports operating on disks within a libvirt domain via -d)
# upstream: https://github.com/libguestfs/libguestfs (format)
# Flags from libguestfs format/format.ml on tip.

_virt-format() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '*-a+[disk image]:file:_files' \
        '*-d+[domain]:domain:' \
        '-c+[libvirt URI]:uri:' \
        '--filesystem=*[fs type]:fs:(ext2 ext3 ext4 btrfs xfs vfat ntfs none)' \
        '--label+[fs label]:label:' \
        '--partition=*[partition table]:pt:(mbr gpt none)' \
        '--lvm+[VG name]:vg:' \
        '--wipe[wipe with zeros]'
}

_virt-format "$@"
