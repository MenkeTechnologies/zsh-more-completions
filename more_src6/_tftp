#compdef tftp
# _tftp — OpenBSD tftp (interactive TFTP client; opens a session with the given host:port and offers connect/get/put/status/ascii/binary/quit commands at the tftp> prompt)
# upstream: https://github.com/openbsd/src (usr.bin/tftp)
# Synopsis from usr.bin/tftp/tftp.1 on tip.

_tftp() {
    _arguments \
        '1:host:_hosts' \
        '2:port:'
}

_tftp "$@"
