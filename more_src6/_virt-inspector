#compdef virt-inspector
# _virt-inspector — libguestfs virt-inspector (probe a libvirt VM image and emit a structured XML report identifying installed OS, distro/version, mountpoints, applications, kernel, drivers; -a disk, -d domain, -c URI, --xpath query specific XPath, --no-applications skip rpm/dpkg scan, --no-icon)
# upstream: https://github.com/libguestfs/libguestfs (inspector)
# Flags from libguestfs inspector/inspector.ml on tip.

_virt-inspector() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '*-a+[disk image]:file:_files' \
        '*-d+[domain]:domain:' \
        '-c+[libvirt URI]:uri:' \
        '--xpath+[xpath]:xpath:' \
        '--no-applications[skip application list]' \
        '--no-icon[skip icon]' \
        '--no-cleanup[skip cleanup]' \
        '--format=*[disk format]:fmt:(raw qcow2 vmdk vdi)' \
        '--xpath-format=*[xpath output]:fmt:'
}

_virt-inspector "$@"
