#compdef timescale-cli tsdb-cli
# _timescale-cli — Timescale timescale-cli CLI command-line frontend wrapping the TimescaleDB open-source PostgreSQL-extension time-series database providing tsdb-tune timescaledb-tune timescaledb-parallel-copy timescaledb-backfill move-chunk drop-chunks reorder-chunk add-compression-policy add-retention-policy continuous-aggregate-policy hypertable convert-domain (Timescale team, Go/C); custom argparse
# upstream: https://www.timescale.com/

_timescale-cli() {
    local -a sub=(
        'tune:tune PostgreSQL config'
        'parallel-copy:parallel COPY'
        'backfill:backfill data'
        'move-chunk:move a chunk'
        'drop-chunks:drop chunks'
        'reorder-chunk:reorder a chunk'
        'add-compression-policy:add compression policy'
        'add-retention-policy:add retention policy'
        'add-continuous-aggregate-policy:add cagg policy'
        'create-hypertable:create hypertable'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--conf-path=+[file]:file:_files -g "postgresql.conf"' \
        '--postgres-version=+[v]:str:' \
        '--max-conns=+[N]:n:' \
        '--max-bg-workers=+[N]:n:' \
        '--memory=+[N]:str:' \
        '--cpus=+[N]:n:' \
        '--wal-disk-size=+[N]:str:' \
        '--type=+[type]:t:(timescaledb promscale)' \
        '--yes[answer yes]' \
        '--quiet[quiet]' \
        '--dry-run[dry run]' \
        '--connection=+[postgres uri]:str:' \
        '--db-name=+[db]:str:' \
        '--host=+[host]:_hosts' \
        '--port=+[port]:n:' \
        '--user=+[user]:_users' \
        '--password=+[password]:str:' \
        '--table=+[name]:str:' \
        '--schema=+[name]:str:' \
        '--workers=+[N]:n:' \
        '--batch-size=+[N]:n:' \
        '--copy-options=+[opts]:str:' \
        '--time-column=+[name]:str:' \
        '--chunk-time-interval=+[interval]:str:' \
        '--from=+[ts]:str:' \
        '--to=+[ts]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'timescale subcommand' sub ;;
        args) _arguments '*:arg:' ;;
    esac
}

_timescale-cli "$@"
