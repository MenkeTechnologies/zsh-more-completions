#compdef xdg-terminal-exec
# xdg-terminal-exec — launch programs in the user's preferred terminal emulator
# Part of the xdg-terminal-exec specification (https://github.com/Vladimir-csp/xdg-terminal-exec)

_arguments -s -S \
  '(- *)--help[show help message]' \
  '(- *)--version[show version]' \
  '1:command:_command_names -e' \
  '*:arguments: _normal'
