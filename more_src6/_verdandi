#compdef verdandi
# Documentation: https://wiki.panotools.org/Verdandi
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Verdandi is a Hugin/Panotools image blending tool.

local curcontext="$curcontext" ret=1

_arguments -C \
  '--output=[output filename (extension determines format)]:file:_files' \
  '--compression=[output compression (TIFF: PACKBITS DEFLATE LZW; JPEG: 0-100)]:compression:(PACKBITS DEFLATE LZW)' \
  '--seam=[blend mode]:mode:(hard blend)' \
  '--wrap[wraparound the 360 deg border]' \
  '*:image_files:_files -g "*.{tif,tiff,jpg,jpeg,png}"' && ret=0

return ret
