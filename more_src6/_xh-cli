#compdef xh-cli
# _xh-cli — ducaale xh friendly and fast HTTPie alternative in Rust CLI alias (ducaale team, Rust); clap-rs
# upstream: https://github.com/ducaale/xh

_xh-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-j[force JSON request type]' \
        '--json[force JSON request type]' \
        '-f[force form-encoded body]' \
        '--form[force form-encoded body]' \
        '-m[force multipart body]' \
        '--multipart[force multipart body]' \
        '--raw=+[raw body]:str:' \
        '--pretty=+[mode]:m:(all colors format none)' \
        '-s+[style]:s:(auto solarized monokai fruity native)' \
        '--style=+[style]:s:(auto solarized monokai fruity native)' \
        '--no-headers[no headers]' \
        '--print=+[parts]:str:' \
        '-p+[parts]:str:' \
        '-h[print response headers]' \
        '--headers[print response headers]' \
        '-b[print response body]' \
        '--body[print response body]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '--all[print everything]' \
        '--history-print=+[parts]:str:' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-S[stream response body]' \
        '--stream[stream response body]' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-d[download mode]' \
        '--download[download mode]' \
        '-c[continue download]' \
        '--continue[continue download]' \
        '--session=+[session name]:str:' \
        '--session-read-only=+[session name]:str:' \
        '-A+[auth-type]:a:(basic bearer digest)' \
        '--auth-type=+[auth-type]:a:(basic bearer digest)' \
        '-a+[user:password]:str:' \
        '--auth=+[user:password]:str:' \
        '--bearer=+[token]:str:' \
        '--ignore-netrc[ignore netrc]' \
        '--offline[offline]' \
        '--check-status[check status]' \
        '--curl[output curl command]' \
        '--curl-long[long curl command]' \
        '-F[follow redirects]' \
        '--follow[follow redirects]' \
        '--max-redirects=+[n]:n:' \
        '--timeout=+[seconds]:str:' \
        '--proxy=+[protocol:url]:str:' \
        '--verify=+[verify]:str:' \
        '--cert=+[file]:file:_files' \
        '--cert-key=+[file]:file:_files' \
        '--ssl=+[version]:v:(auto ssl2.3 tls1 tls1.1 tls1.2 tls1.3)' \
        '--https[force HTTPS]' \
        '-I[ignore HTTP redirect status]' \
        '--ignore-stdin[ignore stdin]' \
        '--no-keep-alive[no keep alive]' \
        '--default-scheme=+[scheme]:s:(http https)' \
        '-x+[client cert]:file:_files' \
        '*:METHOD URL ITEM:'
}

_xh-cli "$@"
