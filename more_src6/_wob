#compdef wob
# Documentation: https://man.archlinux.org/man/extra/wob/wob.1.en
# Reference accessed: 2026-05-21
# Verified: upstream wob(1) only documents -c/--config, -v/--verbose,
# -V/--version, -h/--help. Width/height/bar-color etc. moved to wob.ini(5).
# Removed previously fabricated CLI flags.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-c --config)'{-c,--config=}'[configuration file]:file:_files' && ret=0

return ret
