#compdef tcsh
# Documentation: https://manpages.debian.org/tcsh.1
# Source: TENEX C shell — csh with command-line editing and history mechanism.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-b[break option processing (treat remaining args as positional)]' \
    '-c[read commands from string argument]:command:' \
    '-d[load directory stack from ~/.cshdirs at startup]' \
    '*-D-[set environment variable (Domain/OS only)]:name=value:' \
    '-e[exit shell on any abnormal command termination]' \
    '-f[skip resource/startup files and command hashing]' \
    '-F[spawn via fork(2) instead of vfork(2)]' \
    '-i[force interactive prompt even on non-terminal stdin]' \
    '-l[login shell]' \
    '-m[load ~/.tcshrc even when not owned by effective user]' \
    '-n[parse but do not execute (syntax check)]' \
    '-q[accept SIGQUIT and disable job control (debugger use)]' \
    '-s[read commands from standard input]' \
    '-t[read and execute a single line of input]' \
    '-v[verbose mode: echo commands after history substitution]' \
    '-V[enable verbose mode before executing ~/.tcshrc]' \
    '-x[echo mode: display commands before execution]' \
    '-X[enable echo mode before executing ~/.tcshrc]' \
    '(- *)--help[show help and exit]' \
    '(- *)--version[show version and exit]' \
    '*:script + arguments:_files' \
    && ret=0

return ret
