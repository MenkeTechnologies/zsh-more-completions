#compdef virt-p2v
# Documentation: https://libguestfs.org/virt-p2v.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# virt-p2v: physical-to-virtual conversion client (boots from CD/USB)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[enable debugging output]' \
  '--cmdline=[parse the given string instead of /proc/cmdline]:cmdline:' \
  '--colors[colorize messages with ANSI sequences]' \
  '--colours[colorize messages with ANSI sequences]' \
  '--iso[enable virt-p2v-iso-only features (dangerous: shutdown button etc.)]' \
  '--nbd=[select NBD server]:server:(qemu-nbd qemu-nbd-no-sa nbdkit nbdkit-no-sa)' \
  '--test-disk=[for testing: replace /dev/sda with a local file]:file:_files' && ret=0
return ret
