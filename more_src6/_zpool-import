#compdef zpool-import
# _zpool-import — OpenZFS zpool import (search for and import existing pools; -a all importable, -c cachefile, -d search directory, -D include destroyed pools, -f force, -F rewind, -m allow missing log devices, -N no mount, -o mount options, -R altroot prefix, -t temporary name, -X may roll back further)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zpool/zpool_main.c (zpool_do_import) on tip.

_zpool-import() {
    _arguments \
        '-a[all importable pools]' \
        '-D[include destroyed pools]' \
        '-f[force]' \
        '-F[extreme rewind]' \
        '-m[allow missing log devices]' \
        '-N[no auto-mount datasets]' \
        '-X[broader rewind]' \
        '-l[load encryption keys]' \
        '-n[dry run with -F]' \
        '-V[verify only]' \
        '-c+[cachefile]:file:_files' \
        '*-d+[search dir or device]:dir:_files -/' \
        '*-o+[mount option]:option:' \
        '-O+[mountpoint override]:dir:_files -/' \
        '-R+[altroot prefix]:dir:_files -/' \
        '-s[only show summary]' \
        '-T+[transaction group]:txg:' \
        '-t+[temporary name]:name:' \
        '*:pool:'
}

_zpool-import "$@"
