#compdef xls2csv
# Documentation: https://manpages.debian.org/bookworm/catdoc/xls2csv.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream catdoc xls2csv(1) manpage.

# xls2csv: convert MS Excel files to CSV (part of catdoc)
_arguments -s -S \
  '-V[output version number]' \
  '-x[print unknown Unicode chars as \xNNNN rather than question marks]' \
  '-l[list known charsets and exit]' \
  '-c+[cell separator char (default comma)]:separator' \
  '-b+[sheet break string output at end of each workbook page]:string' \
  '-g+[number of decimal digits in numbers]:digits' \
  '-q+[quote mode]:mode:((0\:"never" 1\:"if needed" 2\:"always non-numeric" 3\:"always"))' \
  '-d+[destination charset name]:charset' \
  '-s+[source charset name]:charset' \
  '-f+[date/time format for Excel date and time values]:format' \
  '1:file:_files -g "*.(xls|XLS)"'
