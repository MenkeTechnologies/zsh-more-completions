#compdef who-uploads
# Documentation: https://manpages.debian.org/who-uploads
# Source: debian/devscripts scripts/who-uploads.sh — list signers of recent Debian uploads (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '--version[show version]' \
    '(-M --max-uploads)'{-M+,--max-uploads=}'[number of uploads to show]:n:_default' \
    '*--keyring=-[additional GPG keyring]:file:_files -g "*.{gpg,asc}"' \
    '--no-default-keyrings[do not use default keyrings]' \
    '(--no-date --nodate)--date[show upload dates (default)]' \
    '(--date)--no-date[hide upload dates]' \
    '(--date)--nodate[hide upload dates]' \
    '(--no-conf --noconf)'{--no-conf,--noconf}'[ignore conf files]' \
    '*:package:_default' \
    && ret=0

return ret
