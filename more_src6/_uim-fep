#compdef uim-fep
# Documentation: https://github.com/uim/uim/blob/master/fep/uim-fep.c
# Reference accessed: 2026-05-16
# Verified: upstream uim/uim fep/uim-fep.c getopt source.
# Removed from prior file: bogus man.archlinux.org search URL.

# uim-fep: uim front-end for terminal/console
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-v[show version]' \
  '-e[command to run on PTY]:cmd:_command_names' \
  '-s[status line type]:type:(none backtick lastline)' \
  '-u[input method engine]:im:' \
  '-b[backtick socket path]:path:_files' \
  '-w[status line width 1-10000]:n:' \
  '-t[input timeout seconds]:s:' \
  '-C[color escape FG\:BG]:fg\:bg:' \
  '-f[mode file suffix]:suffix:' \
  '-S[GNU Screen mode (no cursor reporting)]' \
  '-X[GNU Screen mode]' \
  '-d[ddskk compat mode]' \
  '-c[disable cursor reverse-video]' \
  '-i[control terminal cursor visibility]' \
  '-o[on-the-spot editing]' \
  '-K[print key codes]' && ret=0
return ret
