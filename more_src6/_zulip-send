#compdef zulip-send
# _zulip-send — send a message to Zulip recipients (zulip/python-zulip-api)
# upstream: https://github.com/zulip/python-zulip-api
# Flags from zulip/zulip/send.py (argparse).

_zulip-send() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-m --message)'{-m+,--message=}'[message text]:text:' \
        '(-s --stream)'{-s+,--stream=}'[target stream]:stream:' \
        '(-S --subject)'{-S+,--subject=}'[message subject]:subject:' \
        '--site=[Zulip server URL]:url:' \
        '--api-key=[API key]:key:' \
        '--user=[user email]:email:' \
        '--config-file=[config file]:file:_files' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '*:recipient email:'
}

_zulip-send "$@"
