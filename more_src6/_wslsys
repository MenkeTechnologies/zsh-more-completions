#compdef wslsys
# wslsys — display WSL system information
# Part of wslu (https://github.com/wslutilities/wslu)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-v,--version}'[show version]' \
  '-I[show Windows install date]' \
  '-B[show Windows OS build]' \
  '-b[show Windows branch]' \
  '-F[show Windows build with full information]' \
  '-U[show Windows uptime]' \
  '-R[show release ID]' \
  '-K[show Windows kernel version]' \
  '-P[show Windows display language]' \
  '-S[show Windows short path for current directory]' \
  '-l[show long path for current directory]' \
  '-T[show Windows default theme]'
