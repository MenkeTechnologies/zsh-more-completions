#compdef winemaker
# Documentation: https://wiki.winehq.org/Winemaker

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--nobanner[do not print the banner]' \
  '--backup[backup modified source files]' \
  '--nobackup[do not backup modified source files]' \
  '--nosource-fix[do not try to fix source files]' \
  '--source-fix[try to fix source files (default)]' \
  '--lower-none[do not lowercase filenames]' \
  '--lower-all[lowercase all filenames]' \
  '--lower-uppercase[lowercase only all-uppercase filenames]' \
  '--nolower-include[do not lowercase include paths]' \
  '--norecurse[do not recurse into subdirectories]' \
  '--nosymlinks[do not follow symlinks]' \
  '--dll[build a DLL]' \
  '--exe[build an executable (default)]' \
  '--nomfc[do not use MFC (default)]' \
  '--mfc[use MFC]' \
  '-D+[add preprocessor define]:define:' \
  '-I+[add include path]:directory:_files -/' \
  '-L+[add library path]:directory:_files -/' \
  '-l+[add library]:library:' \
  '-i+[add DLL to import]:dll:' \
  '--single-target=[generate a single target Makefile]:name:' \
  '--generated-files[auto-generate Makefile files]' \
  '--nogenerated-files[do not auto-generate Makefile files]' \
  '*:source directory:_files -/' \
  && return 0
