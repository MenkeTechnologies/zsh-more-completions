# Reference accessed: 2026-05-30 via gh api.
#
# typer is the **modern type-hint-driven Python CLI
# library** from tiangolo (FastAPI author) — built on
# Click but with cleaner ergonomics: function parameters
# with type hints become CLI args/options automatically,
# defaults become CLI defaults, no decorator stacking.
# Typer is also the binary name (`typer`) for the
# typer-cli tool that auto-generates CLIs from Python
# Typer apps in arbitrary files/modules.  Pivots from
# Python argparse (R267 alembic) to **complete the
# 3-way Python CLI taxonomy** (Click R266 / argparse
# R267 / Typer R268).  Sister to FastAPI (uses Click
# underneath via uvicorn R266), litestar, pydantic-cli.
#
# Critical extraction note: typer uses the **Typer
# library** at `import typer` — corpus's **first
# documented Typer CLI**.  **COMPLETES the 3-way Python
# CLI library taxonomy** (NOW COMPLETE): (a) argparse
# (R267 alembic — Python stdlib), (b) Click (R266
# uvicorn — decorator-based), (c) **Typer** (R268 typer
# — type-hint-driven; built on Click; modern).  Documents
# the **Typer pattern**: define function params with
# type hints (`path_or_module: str`); use `typer.Argument
# (default)` for positionals; use `typer.Option(default,
# "--name", help="...")` for flags; default values
# become CLI defaults; type hints become CLI types
# (str/int/bool/Path/etc.).  Distinct from Click's
# `@click.option/@click.argument` decorator stack.
# Typer wraps Click's mechanism but presents a cleaner
# API.  Distinct from argparse's imperative
# `parser.add_argument(...)` chains.  **MAJOR PATTERN
# MILESTONE**.  3-way Python CLI taxonomy NOW COMPLETE
# via cluster R266 (Click) + R267 (argparse) + R268
# (Typer).
#
# Critical extraction note: typer uses **`app =
# typer.Typer()` + `app.add_typer(utils_app, name=
# "utils")`** at cli.py:17-19 — the **nested-Typer-app
# pattern** for subcommand groups.  `typer.Typer()`
# creates a CLI app instance; `add_typer(sub_app, name=
# ...)` mounts the sub-app as a subcommand group.  Used
# for `typer utils docs ...` (where `utils` is the
# mounted group and `docs` is the `@utils_app.command()`).
# Documents the **declarative-mount subcommand
# grouping** — distinct from Click's `@click.group()`
# decorator and from argparse's `add_subparsers()` +
# `add_parser()`.  Typer's approach: each `Typer()`
# instance is a fully-formed CLI; you compose them via
# `add_typer`.  Corpus's **first documented
# add_typer-mounted subcommand group**.
#
# Critical extraction note: typer's CLI has a
# **DYNAMICALLY INJECTED `run` subcommand** via the
# custom `TyperCLIGroup` class at cli.py:54-69 — when
# `typer SOMEMODULE.py` is invoked, `TyperCLIGroup`'s
# overridden `list_commands` / `get_command` / `invoke`
# methods call `maybe_add_run_to_cli` which dynamically
# adds a `run` subcommand wrapping the user's discovered
# Typer app from the file/module.  So the CLI is:
# `typer myapp.py run --help` shows the user's Typer
# app's commands.  Documents the **runtime-injected
# subcommand pattern** — corpus's first.  The subcommand
# list is NOT FIXED at startup; depends on parsed
# positional `path_or_module`.  Powerful for "meta-CLI"
# tools that wrap arbitrary user CLIs.  Distinct from
# R267 alembic's introspection-driven registration
# (which happens ONCE at startup) — Typer-CLI's
# injection happens AT EVERY PARSE PHASE via the
# overridden Click Group methods.
#
# Critical extraction note: typer uses **`typer.Argument`
# / `typer.Option` factory functions** at cli.py:164-172
# — `typer.Argument(None)` creates a positional with
# default `None`; `typer.Option(False, "--version", ...
# callback=print_version)` creates an option.  These
# are FACTORY FUNCTIONS that return special sentinel
# values; Typer's main fn introspects parameter defaults
# to discover CLI structure.  Documents the **factory-
# default sentinel pattern** in Typer — distinct from
# Click's `@click.option` decorator (which stacks on
# the function) and from argparse's `add_argument` calls.
# Typer's sentinel-default approach lets the CLI
# definition be expressed IN THE FUNCTION SIGNATURE
# itself, not in separate decorators.  Corpus's **first
# documented Typer factory-sentinel pattern**.
#
# Critical extraction note: typer's `--version` uses
# **the same eager callback pattern as Click** at
# cli.py:167-172 + 153-157 — `callback=print_version`
# with `print_version` raising `typer.Exit()` after
# echoing.  Documents how Typer's `--version` is
# implemented via Click's eager-callback under the hood
# (since Typer is built on Click).  Distinct from R266
# uvicorn's explicit `is_eager=True, expose_value=False`
# — Typer wraps these as defaults of the Option factory.
# Documents the **Typer-as-Click-wrapper** observation:
# every Click feature is accessible through Typer with
# different surface syntax.
#
# Critical extraction note: typer's `docs` subcommand
# uses **`typer.Option(None, ... file_okay=True,
# dir_okay=False)`** at cli.py:282-287 — the `--output`
# option accepts a Path with VALIDATION: file_okay=True
# (file is OK), dir_okay=False (dir is NOT OK).
# Documents Typer's **Path-validation-by-keyword-args**
# pattern — when the parameter type is `Path | None`,
# Typer auto-detects it's a path and the additional
# `file_okay` / `dir_okay` / `exists` / `writable` /
# `readable` kwargs control validation behavior.
# Distinct from R266 uvicorn's `type=click.Path(exists=
# True)` (Click explicit wrapper) — Typer's Path
# validation kwargs are passed DIRECTLY to typer.Option.
# Corpus's **first documented Typer Path validation
# pattern**.
#
# Critical extraction note: typer uses **`no_args_is_help
# =True`** on the main callback at cli.py:160 — when
# the CLI is invoked with NO args (just `typer`), the
# help text is shown instead of running the callback
# fn.  Documents the **no_args_is_help shorthand** —
# Click has the same option as `@click.command(...,
# context_settings={...})`; Typer exposes it directly
# on the callback decorator.  Useful for top-level
# CLIs where running with no args is meaningless.

local curcontext="$curcontext" state line ret=1

# Top-level + nested subcommands.  `run` is DYNAMICALLY
# INJECTED based on parsed path_or_module — included
# here for muscle-memory completeness.
local -a subcommands=(
  'run:run the provided Typer app (DYNAMICALLY INJECTED when path_or_module given)'
  'utils:extra utility commands for Typer apps (sub: docs)'
)

local -a utils_subs=(
  'docs:generate Markdown docs for a Typer app'
)

# Typer auto-adds these for installed apps.
local -a typer_globals=(
  '(-h --help)'{-h,--help}'[show help]'
  '--version[print version and exit (eager callback via Click)]'
  '--install-completion[install completion for the typer command (Typer auto-feature)]'
  '--show-completion[show completion for the typer command (Typer auto-feature)]'
  '--app=[the Typer app object/variable name to use (overrides default discovery)]:name:'
  '--func=[the function to convert to Typer (use instead of an existing Typer app)]:name:'
)

_arguments -C \
  $typer_globals \
  '1: :->path_or_subcmd' \
  '*::args:->args' && ret=0

case $state in
  path_or_subcmd)
    # `typer` accepts EITHER:
    #   - a path-or-module string (positional Argument)
    #   - a subcommand (`utils` or DYNAMICALLY `run` after
    #     path_or_module is given)
    _alternative \
      'subcommands:typer subcommand:_describe -t subcommands "subcommand" subcommands' \
      'paths:Python file or module:_files -g "*.py"' && ret=0
    ;;
  args)
    case $words[1] in
      utils)
        if (( CURRENT == 2 )); then
          _describe -t utils-subs 'utils verb' utils_subs && ret=0
        else
          case $words[2] in
            docs)
              _arguments \
                '--name=[CLI program name to use in docs]:name:' \
                '--output=[output file (file_okay=True, dir_okay=False)]:file:_files -g "*.md"' \
                '--title=[documentation page title (default: program name)]:title:' && ret=0
              ;;
          esac
        fi
        ;;
      run)
        # `run` is the dynamically-injected user app.
        # Args depend on the user's Typer app discovered
        # from path_or_module — pass-through.
        _files && ret=0
        ;;
      *)
        # If the first positional was a path/module, the
        # second token is a subcommand of the discovered
        # user app.  Default to files for now.
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
