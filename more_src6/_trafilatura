#compdef trafilatura
# Documentation: https://trafilatura.readthedocs.io/en/latest/usage-cli.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for trafilatura - web content extraction

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-u --URL)'{-u+,--URL=}'[URL to process]:URL' \
  '(-i --input-file)'{-i+,--input-file=}'[file with URLs for batch processing]:file:_files' \
  '--input-dir=[input directory for files to process]:directory:_files -/' \
  '(-o --output-dir)'{-o+,--output-dir=}'[directory for results]:directory:_files -/' \
  '--backup-dir=[preserve copies of downloaded files]:directory:_files -/' \
  '--keep-dirs[maintain input directory structure]' \
  '(-b --blacklist)'{-b+,--blacklist=}'[file with unwanted URLs to exclude]:file:_files' \
  '--crawl=[crawl fixed number of pages from URL]:URL' \
  '--explore=[combine sitemap and crawl methods]:URL' \
  '--feed=[find feeds or pass feed URL]:URL' \
  '--sitemap=[locate sitemaps or enter sitemap URL]:URL' \
  '--probe=[probe for extractable content]:URL' \
  '--list[display URLs without downloading]' \
  '--parallel=[cores/threads for downloads and processing]:threads' \
  '--archived[fetch from Internet Archive if downloads fail]' \
  '--url-filter=[only process URLs matching patterns]:pattern' \
  '(-f --fast)'{-f,--fast}'[fast extraction without fallback detection]' \
  '--formatting[keep text formatting (bold, italic, etc.)]' \
  '--links[include link targets]' \
  '--images[include image sources]' \
  '--no-comments[exclude comments]' \
  '--no-tables[exclude tables]' \
  '--only-with-metadata[output documents with title, URL, date only]' \
  '--with-metadata[extract and add metadata]' \
  '--precision[prioritize precision over recall]' \
  '--recall[prioritize recall over precision]' \
  '--target-language=[ISO 639-1 target language code]:code' \
  '--deduplicate[remove duplicate documents]' \
  '--config-file=[use custom configuration file]:file:_files' \
  '--output-format=[output format]:format:(csv json html markdown txt xml xmltei)' \
  '--csv[shorthand for --output-format csv]' \
  '--json[shorthand for --output-format json]' \
  '--html[shorthand for --output-format html]' \
  '--markdown[shorthand for --output-format markdown]' \
  '--xml[shorthand for --output-format xml]' \
  '--xmltei[shorthand for --output-format xmltei]' \
  '--validate-tei[validate XML TEI output]' \
  '(-v --verbose)'{-v,--verbose}'[increase logging verbosity]' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--version[show version and exit]' && ret=0

return ret
