#compdef zpool-attach
# _zpool-attach — OpenZFS zpool attach (attach a new device to an existing vdev to make a mirror; -f force, -s allow attach of spare, -w wait until resilver done, -o ashift/cachefile, -P preserve attach order; positional pool, existing_device, new_device)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zpool/zpool_main.c (zpool_do_attach) on tip.

_zpool-attach() {
    _arguments \
        '-f[force]' \
        '-s[allow spare attach]' \
        '-w[wait until resilver done]' \
        '*-o+[property=value]:property=value:(ashift= cachefile=)' \
        '1:pool:' \
        '2:existing device:' \
        '3:new device:'
}

_zpool-attach "$@"
