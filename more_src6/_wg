#compdef wg
# Documentation: https://git.zx2c4.com/wireguard-tools/about/src/man/wg.8
# Reference accessed: 2026-05-21
# Verified: upstream wg(8) manpage at the URL above.

# Zsh completion for WireGuard (wg)

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'show:show current configuration and device information'
  'showconf:show current configuration in wg-quick INI format'
  'set:change current configuration of an interface'
  'setconf:replace configuration from a file'
  'addconf:append configuration from a file'
  'syncconf:synchronize configuration from a file, preserving peer sessions'
  'genkey:generate a new private key'
  'genpsk:generate a new preshared key'
  'pubkey:calculate the public key from a private key on stdin'
  'help:show help'
)

local -a interfaces
interfaces=( ${(f)"$(command wg show interfaces 2>/dev/null)"} )

_arguments -s -S \
  '1:subcommand:->subcmd' \
  '*::args:->args' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'wg subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (show)
        _arguments \
          "1:interface:(all interfaces ${interfaces})" \
          '2:field:(public-key private-key listen-port fwmark peers preshared-keys endpoints allowed-ips latest-handshakes transfer persistent-keepalive)' && ret=0
        ;;
      (showconf|syncconf|setconf|addconf)
        _arguments \
          "1:interface:(${interfaces})" \
          '2:config file:_files -g "*.conf"' && ret=0
        ;;
      (set)
        # Note: wg set uses positional word-pairs, not --flags
        _arguments "1:interface:(${interfaces})" '*:setting (listen-port|fwmark|private-key|peer|remove|preshared-key|endpoint|persistent-keepalive|allowed-ips):' && ret=0
        ;;
      (genkey|genpsk|pubkey|help)
        ;;
    esac
    ;;
esac

return ret
