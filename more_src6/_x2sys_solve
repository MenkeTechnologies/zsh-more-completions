#compdef x2sys_solve
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/x2sys/x2sys_solve.html
# Source: GenericMappingTools/gmt supplements/x2sys — solve for crossover-error corrections.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-T+[x2sys TAG]:tag:_default' \
    '-C+[data column to process]:column:_default' \
    '-E+[correction-type model]:type:(c d g h s t z)' \
    '*-V[verbose (stackable)]' \
    '-W+[weighted least squares (+u for unweighted stats)]:opts:_default' \
    '-bi+[binary input format]:format:_default' \
    '-di+[input nodata → NaN]:value:_default' \
    '-x+[CPU cores limit]:n:_default' \
    '*:COE list file:_files' \
    && ret=0

return ret
