#compdef tckglobal
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/tckglobal.html
# Source: MRtrix3/mrtrix3 cmd/tckglobal.cpp — multi-tissue global tractography via MCMC particle method (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-grad+[diffusion encoding scheme]:scheme:_files' \
    '-mask+[reconstruct within brain mask]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '*-riso+[isotropic response function]:response:_files' \
    '-lmax+[max harmonic order]:order:_default' \
    '-length+[particle (fibre segment) length in mm]:size:_default' \
    '-weight+[particle weight contribution to model]:w:_default' \
    '-ppot+[particle potential (segment cost)]:u:_default' \
    '-cpot+[connection potential (segment-pair energy)]:v:_default' \
    '-t0+[initial MH temperature]:start:_default' \
    '-t1+[final MH temperature]:end:_default' \
    '-niter+[number of MH iterations]:n:_default' \
    '-fod+[predicted fODF output image]:odf:_files' \
    '-noapo[do not include apodisation in fODF output]' \
    '-fiso+[predicted isotropic fraction(s) output image]:iso:_files' \
    '-eext+[output energy-history text file]:file:_files' \
    '-etrend+[output energy-trend text file]:file:_files' \
    '1:source (raw DWI):_files -g "*.{nii,nii.gz,mif}"' \
    '2:response (segment-on-DWI response):_files' \
    '3:tracks (output):_files -g "*.tck"' \
    && ret=0

return ret
