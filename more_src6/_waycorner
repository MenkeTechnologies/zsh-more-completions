#compdef waycorner
# Documentation: https://github.com/AndreasBackx/waycorner
# Reference accessed: 2026-05-21
# Verified: upstream src/main.rs at github.com/AndreasBackx/waycorner.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config}'+[config file path]:file:_files -g "*.toml"' \
  '(-p --preview)'{-p,--preview}'[preview corners on your screen]' && ret=0

return ret
