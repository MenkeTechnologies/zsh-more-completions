#compdef zulucrypt zuluCrypt-cli
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/zuluCrypt-cli.1.html
# Reference accessed: 2026-05-21
# Verified: Ubuntu focal zuluCrypt-cli(1) manpage.

# zulucrypt (zuluCrypt-cli): LUKS/TrueCrypt encrypted volume manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-c -o -O -q -r -a -i -s -b -A -N -S -T -Z -w -P -L -X -W -U -H -M -J -B -R)-c[create an encrypted volume]' \
  '(-c -o -O -q -r -a -i -s -b -A -N -S -T -Z -w -P -L -X -W -U -H -M -J -B -R)-o[open an encrypted volume]' \
  '(-c -o -O -q -r -a -i -s -b -A -N -S -T -Z -w -P -L -X -W -U -H -M -J -B -R)-O[open but do not mount]' \
  '(-c -o -O -q -r -a -i -s -b -A -N -S -T -Z -w -P -L -X -W -U -H -M -J -B -R)-q[close an opened volume]' \
  '(-c -o -O -q -r -a -i -s -b -A -N -S -T -Z -w -P -L -X -W -U -H -M -J -B -R)-r[remove a key from LUKS volume]' \
  '(-c -o -O -q -r -a -i -s -b -A -N -S -T -Z -w -P -L -X -W -U -H -M -J -B -R)-a[add a key to LUKS volume]' \
  '(-c -o -O -q -r -a -i -s -b -A -N -S -T -Z -w -P -L -X -W -U -H -M -J -B -R)-i[check if device contains LUKS volume]' \
  '(-c -o -O -q -r -a -i -s -b -A -N -S -T -Z -w -P -L -X -W -U -H -M -J -B -R)-s[print volume status and properties]' \
  '(-c -o -O -q -r -a -i -s -b -A -N -S -T -Z -w -P -L -X -W -U -H -M -J -B -R)-b[show LUKS slot status]' \
  '(-c -o -O -q -r -a -i -s -b -A -N -S -T -Z -w -P -L -X -W -U -H -M -J -B -R)-A[list all partitions]' \
  '(-c -o -O -q -r -a -i -s -b -A -N -S -T -Z -w -P -L -X -W -U -H -M -J -B -R)-N[list non-system partitions]' \
  '(-c -o -O -q -r -a -i -s -b -A -N -S -T -Z -w -P -L -X -W -U -H -M -J -B -R)-S[list system partitions]' \
  '(-c -o -O -q -r -a -i -s -b -A -N -S -T -Z -w -P -L -X -W -U -H -M -J -B -R)-T[detailed list of mounted partitions]' \
  '(-c -o -O -q -r -a -i -s -b -A -N -S -T -Z -w -P -L -X -W -U -H -M -J -B -R)-Z[detailed list of unmounted partitions]' \
  '(-c -o -O -q -r -a -i -s -b -A -N -S -T -Z -w -P -L -X -W -U -H -M -J -B -R)-w[check if UUID matches any partition]:uuid:' \
  '(-c -o -O -q -r -a -i -s -b -A -N -S -T -Z -w -P -L -X -W -U -H -M -J -B -R)-P[get device path from mapper]' \
  '(-c -o -O -q -r -a -i -s -b -A -N -S -T -Z -w -P -L -X -W -U -H -M -J -B -R)-L[list opened volumes and mount points]' \
  '(-c -o -O -q -r -a -i -s -b -A -N -S -T -Z -w -P -L -X -W -U -H -M -J -B -R)-X[open device and write random data]' \
  '(-c -o -O -q -r -a -i -s -b -A -N -S -T -Z -w -P -L -X -W -U -H -M -J -B -R)-W[check if device is TrueCrypt]' \
  '(-c -o -O -q -r -a -i -s -b -A -N -S -T -Z -w -P -L -X -W -U -H -M -J -B -R)-U[print UUID of device]' \
  '(-c -o -O -q -r -a -i -s -b -A -N -S -T -Z -w -P -L -X -W -U -H -M -J -B -R)-H[compare header to backup]' \
  '(-c -o -O -q -r -a -i -s -b -A -N -S -T -Z -w -P -L -X -W -U -H -M -J -B -R)-M[create public mirror of mount point]' \
  '(-c -o -O -q -r -a -i -s -b -A -N -S -T -Z -w -P -L -X -W -U -H -M -J -B -R)-J[create plain mapper owned by user]' \
  '(-c -o -O -q -r -a -i -s -b -A -N -S -T -Z -w -P -L -X -W -U -H -M -J -B -R)-B[create LUKS/TrueCrypt header backup]' \
  '(-c -o -O -q -r -a -i -s -b -A -N -S -T -Z -w -P -L -X -W -U -H -M -J -B -R)-R[restore header from backup]' \
  '-G[passphrase retrieval module]:module:' \
  '-e[access mode (ro/rw) or destination file path]:mode-or-path:' \
  '-k[skip confirmation prompts]' \
  '-d[device or file holding encrypted volume]:device:_files' \
  '-m[mount point suffix under /run/media/private/$USER]:dir:' \
  '-z[filesystem type or header backup path]:fs-or-path:' \
  '-t[volume type]:type:(luks plain vera)' \
  '-g[create-time options]:opts:' \
  '-p[direct passphrase]:passphrase:' \
  '-f[keyfile path]:file:_files' \
  '-h[prompt interactively for passphrase]' \
  '-y[existing volume passphrase]:passphrase:' \
  '-u[keyfile with existing passphrase]:file:_files' \
  '-l[new passphrase to add]:passphrase:' \
  '-n[keyfile with new passphrase]:file:_files' \
  '*-F[TrueCrypt keyfile (repeatable)]:file:_files' \
  '*-V[hidden TrueCrypt keyfile (repeatable)]:file:_files' \
  '--test[run a test operation]' && ret=0
return ret
