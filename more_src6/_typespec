#compdef typespec
# _typespec — Microsoft TypeSpec API definition language CLI
# upstream: https://github.com/microsoft/typespec

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'compile:Compile TypeSpec source'
  'init:Initialize a new TypeSpec project'
  'install:Install TypeSpec dependencies'
  'format:Format TypeSpec source files'
  'info:Show TypeSpec environment info'
  'code:Manage VS Code extension'
  'vs:Manage Visual Studio extension'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--debug[enable debug logging]' \
  '--pretty[enable pretty output]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'typespec command' commands && ret=0
    ;;
  args)
    case $words[1] in
      compile)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '--output-dir=[output directory]:directory:_directories' \
          '--config=[path to tspconfig.yaml]:file:_files' \
          '--emit=[emitters to run]:emitter' \
          '--option=[emitter options]:option' \
          '--trace=[enable tracing for given area]:area' \
          '--warn-as-error[treat warnings as errors]' \
          '--no-emit[do not emit output]' \
          '--import=[additional imports]:module' \
          '1:entry-file:_files -g "*.tsp"' && ret=0
        ;;
      init)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '--template=[project template to use]:template' && ret=0
        ;;
      format)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '--check[check formatting without modifying files]' \
          '*:file:_files -g "*.tsp"' && ret=0
        ;;
      code)
        _arguments -s -S \
          '(- *)--help[show help]' \
          'install[install VS Code extension]' \
          'uninstall[uninstall VS Code extension]' && ret=0
        ;;
      vs)
        _arguments -s -S \
          '(- *)--help[show help]' \
          'install[install Visual Studio extension]' \
          'uninstall[uninstall Visual Studio extension]' && ret=0
        ;;
    esac
    ;;
esac

return ret
