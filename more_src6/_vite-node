#compdef vite-node
# Documentation: https://vitest.dev (vite-node ships as part of the Vitest project)
# Reference accessed: 2026-05-21
# Verified: vite-node CLI is documented in package README; flags below are
# the ones consistently documented across releases. Removed unverified
# flags (-r, -m short forms, --script) that could not be confirmed.

# Zsh completion for vite-node - run TypeScript/ESM with Vite's resolver

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--root=[root directory]:directory:_directories' \
  '--config=[config file]:config:_files -g "vite.config.*"' \
  '--mode=[mode]:mode:(development production)' \
  '--watch[watch mode]' \
  '--options=[inline vite options]:options:' \
  '*:file:_files -g "*.(ts|mts|cts|tsx|js|mjs|cjs|jsx)"' && ret=0

return ret
