#compdef tidb-backup-manager
# _tidb-backup-manager — PingCAP TiDB Operator backup/restore helper container
# upstream: https://github.com/pingcap/tidb-operator
# Subcommands + flags from cmd/tidb-backup-manager/app/cmd on tip.

_tidb-backup-manager() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-k --kubeconfig)'{-k,--kubeconfig=}'[kubeconfig file (out-of-cluster)]:file:_files' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'backup:run a Backup CR (snapshot or log-backup)'
                'restore:run a Restore CR (snapshot or PITR)'
                'clean:clean up an old Backup'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                backup)
                    _arguments \
                        '--namespace=[Backup CR namespace]:ns:' \
                        '--backupName=[Backup CRD object name]:name:' \
                        '--tikvVersion=[TiKV version]:ver:' \
                        '--client-tls=[enable TiDB client TLS]:bool:(true false)' \
                        '--cluster-tls=[enable cluster TLS]:bool:(true false)' \
                        '--skipClientCA=[skip TiDB server cert validation]:bool:(true false)' \
                        '--mode=[backup mode]:mode:(snapshot log)' \
                        '--subcommand=[log-backup subcommand]:sub:(log-start log-stop log-pause log-resume log-truncate)' \
                        '--commit-ts=[log-backup start TS]:ts:' \
                        '--truncate-until=[log-backup truncate-until TS]:ts:' \
                        '--initialize=[run initialize phase for volume backup]:bool:(true false)' \
                        '--pd-addr=[PD address]:host\:port:'
                    ;;
                restore)
                    _arguments \
                        '--namespace=[Restore CR namespace]:ns:' \
                        '--restoreName=[Restore CRD object name]:name:' \
                        '--tikvVersion=[TiKV version]:ver:' \
                        '--client-tls=[enable TiDB client TLS]:bool:(true false)' \
                        '--cluster-tls=[enable cluster TLS]:bool:(true false)' \
                        '--skipClientCA=[skip TiDB server cert validation]:bool:(true false)' \
                        '--mode=[restore mode]:mode:(snapshot pitr)' \
                        '--pitrRestoredTs=[PITR restored TS]:ts:' \
                        '--prepare=[prepare phase only]:bool:(true false)' \
                        '--target-az=[target AZ for volume-snapshot restore]:az:'
                    ;;
                clean)
                    _arguments \
                        '--namespace=[Backup namespace]:ns:' \
                        '--backupName=[Backup CRD object name]:name:'
                    ;;
            esac
            ;;
    esac
}

_tidb-backup-manager "$@"
