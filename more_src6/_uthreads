#compdef uthreads uthreads-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/lib/uthreads.py argparse)
# Reference accessed: 2026-05-29
# uthreads — trace pthread/Java thread creation events (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-l --language)'{-l,--language=}'[language to trace (none = pthreads only)]:lang:(c java none)' \
  '(-v --verbose)'{-v,--verbose}'[verbose: print the BPF program (for debugging)]' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:pid (process id to attach to):_pids' \
  && ret=0

return ret
