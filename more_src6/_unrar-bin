#compdef unrar
# _unrar-bin — UnRAR command-line extractor (RARLAB); decompresses RAR/RAR5 archives
# upstream: https://www.rarlab.com/rar_add.htm

_unrar-bin() {
    local -a sub=(
        'e:extract (flat)'
        'l:list short'
        'lt:list technical'
        'p:print to stdout'
        't:test'
        'v:list verbose'
        'x:extract with paths'
    )
    _arguments -C \
        '-ad[append archive name to path]' \
        '-ap+[set path inside archive]:path:' \
        '-c-[disable comments]' \
        '-cfg-[disable rar config]' \
        '-cl[lowercase names]' \
        '-cu[uppercase names]' \
        '-dh[allow open shared]' \
        '-ep[exclude paths]' \
        '-ep1[exclude base dir]' \
        '-ep3[expand paths]' \
        '-f[freshen]' \
        '-id+[disable msgs]:flags:' \
        '-ierr[redirect msgs to stderr]' \
        '-inul[disable all messages]' \
        '-kb[keep broken extracted]' \
        '-n+[include filter]:filter:' \
        '-o+[overwrite mode]:mode:(+ - r)' \
        '-or[auto-rename]' \
        '-ow[save ownership]' \
        '-p+[password]:password:' \
        '-p-[do not query password]' \
        '-r[recurse]' \
        '-sl+[skip files larger than]:bytes:' \
        '-sm+[skip files smaller than]:bytes:' \
        '-ta+[after date]:date:' \
        '-tb+[before date]:date:' \
        '-tn+[newer than time]:str:' \
        '-to+[older than time]:str:' \
        '-ts+[save mod time/atime/ctime]:flags:' \
        '-u[update]' \
        '-v[volume info]' \
        '-ver+[extract version]:ver:' \
        '-vp[pause between volumes]' \
        '-x+[exclude filter]:filter:' \
        '-y[assume yes]' \
        '-z+[archive comment file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'unrar subcommand' sub ;;
        args)
            _arguments \
                '1:archive:_files -g "*.(rar|r0[0-9])"' \
                '*:file:_files'
            ;;
    esac
}

_unrar-bin "$@"
