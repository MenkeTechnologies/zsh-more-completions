#compdef xmonadctl xmonad-ctl
# _xmonadctl — XMonad Haskell tiling WM control client (XMonad team, Haskell); custom argparse
# upstream: https://github.com/xmonad/xmonad-contrib

_xmonadctl() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-d+[display]:display:' \
        '--display=+[display]:display:' \
        '-a+[atom name]:str:' \
        '--atom=+[atom name]:str:' \
        '*:command:'
}

_xmonadctl "$@"
