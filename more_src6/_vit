#compdef vit
# Documentation: https://github.com/vit-project/vit
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above and vit/option_parser.py
# master source. vit is Visual Interactive Taskwarrior (curses TUI).

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--list-actions[list all available actions]' \
  '--list-pids[list pids found in configured pid_dir]' \
  '*:report or filter:' && ret=0
return ret
