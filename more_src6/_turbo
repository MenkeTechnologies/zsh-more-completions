#compdef turbo
# Documentation: https://turborepo.dev/repo/docs/reference
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:run tasks across packages'
  'watch:watch and re-run tasks on file changes'
  'prune:generate a partial monorepo for a target'
  'boundaries:enforce package import boundaries'
  'ls:list packages in the monorepo'
  'query:run GraphQL queries against the monorepo'
  'generate:scaffold new packages or apps'
  'login:log in to the remote cache'
  'logout:log out from the remote cache'
  'link:link local directory to remote cache'
  'unlink:unlink from remote cache'
  'scan:run automated repo scan (deprecated)'
  'bin:get the path to the turbo binary'
  'docs:open Turborepo docs in browser'
  'telemetry:manage telemetry settings'
  'daemon:manage the turbo daemon'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--color[enable/disable color output]' \
  '--cpuprofile=[write CPU profile]:file:_files' \
  '--cwd=[working directory]:dir:_files -/' \
  '--heap=[write heap profile]:file:_files' \
  '--no-update-notifier[disable update notifications]' \
  '--verbosity=[set verbosity level]:level' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'turbo command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (run)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--cache-dir=[directory for turbo cache]:dir:_files -/' \
          '--concurrency=[max concurrent tasks]:concurrency' \
          '--continue[continue execution after errors]' \
          '--dry-run=[dry run]:format:(text json)' \
          '--env-mode=[environment variable handling]:mode:(strict loose)' \
          '*--filter=[filter packages]:filter' \
          '--force[ignore cache]' \
          '--framework-inference[enable framework inference]' \
          '*--global-deps=[global files to check for changes]:file:_files' \
          '--graph=[generate task graph]:file:_files' \
          '--log-order=[log ordering]:order:(auto grouped stream)' \
          '--log-prefix=[log prefix]:prefix:(auto none task)' \
          '--no-cache[do not use cache]' \
          '--no-daemon[do not use the daemon]' \
          '--output-logs=[output log mode]:mode:(full hash-only new-only errors-only none)' \
          '--parallel[run tasks in parallel]' \
          '--preflight[check remote cache settings]' \
          '--remote-only[only use remote cache]' \
          '--scope=[filter by scope]:scope' \
          '--since=[only run for changed packages since ref]:ref' \
          '--summarize[generate task summary]' \
          '--team=[remote cache team]:team' \
          '--token=[remote cache auth token]:token' \
          '--ui=[ui mode]:mode:(tui stream)' \
          '*:task' && ret=0
        ;;
      (prune)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--scope=[package to prune for]:scope' \
          '--docker[create Dockerfile-optimized output]' \
          '--out-dir=[output directory]:dir:_files -/' \
          '*:scope' && ret=0
        ;;
      (daemon)
        local -a daemon_cmds=(
          'start:start the daemon'
          'stop:stop the daemon'
          'status:show daemon status'
          'clean:clean daemon state'
        )
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:daemon command:->daemon_cmd' && ret=0
        case $state in
          (daemon_cmd)
            _describe -t commands 'daemon command' daemon_cmds && ret=0
            ;;
        esac
        ;;
      (generate)
        local -a gen_cmds=(
          'workspace:add a new workspace to the project'
          'run:run a custom generator'
        )
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:generator command:->gen_cmd' && ret=0
        case $state in
          (gen_cmd)
            _describe -t commands 'generator command' gen_cmds && ret=0
            ;;
        esac
        ;;
      (telemetry)
        local -a telemetry_cmds=(
          'enable:enable telemetry'
          'disable:disable telemetry'
          'status:show telemetry status'
        )
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:telemetry command:->telemetry_cmd' && ret=0
        case $state in
          (telemetry_cmd)
            _describe -t commands 'telemetry command' telemetry_cmds && ret=0
            ;;
        esac
        ;;
      (link|unlink|login|logout|ls|scan|query|bin|docs|boundaries|watch)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
