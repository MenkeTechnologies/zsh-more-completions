#compdef xfce4-terminal
# _xfce4-terminal-bin — XFCE4 Terminal (Nick Schermer et al, GTK); XFCE-native terminal with tabs, profiles, drop-down
# upstream: https://gitlab.xfce.org/apps/xfce4-terminal

_xfce4-terminal-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--default-display+[X display]:display:' \
        '--default-working-directory+[default cwd]:dir:_files -/' \
        '(-e --command)'{-e,--command}'+[command]:cmd:_command_names -e' \
        '(-x --execute)'{-x,--execute}'+[execute remainder]:str:' \
        '(-T --title)'{-T,--title}'+[title]:title:' \
        '--dynamic-title-mode+[dynamic title mode]:mode:(replace before after goes-after never)' \
        '--initial-title+[initial title]:title:' \
        '--working-directory+[cwd]:dir:_files -/' \
        '(-H --hold)'{-H,--hold}'[hold on exit]' \
        '--display+[X display]:display:' \
        '--geometry+[geometry]:geom:' \
        '--role+[wm role]:role:' \
        '--startup-id+[startup id]:id:' \
        '--maximize[maximize]' \
        '--minimize[minimize]' \
        '--fullscreen[fullscreen]' \
        '--font+[font]:font:' \
        '--hide-borders[hide borders]' \
        '--show-borders[show borders]' \
        '--hide-menubar[hide menubar]' \
        '--show-menubar[show menubar]' \
        '--hide-toolbar[hide toolbar]' \
        '--show-toolbar[show toolbar]' \
        '--hide-scrollbar[hide scrollbar]' \
        '--show-scrollbar[show scrollbar]' \
        '--zoom+[zoom level]:n:' \
        '--icon+[icon]:icon:' \
        '--drop-down[drop-down mode]' \
        '--color-text+[text color]:color:' \
        '--color-bg+[bg color]:color:' \
        '--tab[new tab]' \
        '--window[new window]' \
        '--sm-client-id+[session id]:id:' \
        '--disable-server[disable server mode]'
}

_xfce4-terminal-bin "$@"
