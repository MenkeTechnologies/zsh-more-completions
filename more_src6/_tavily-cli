#compdef tavily-cli
# Documentation: https://www.npmjs.com/package/tavily-cli
# Reference accessed: 2026-05-23
# Verified: npm package tavily-cli and Lag0/tavily-cli README.

# Zsh completion for tavily-cli - unofficial Tavily API CLI (api2cli)

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'search:web search'
  'extract:extract URLs'
  'crawl:crawl site'
  'map:map URLs'
  'research:start research'
  'research-status:research job status'
  'login:authenticate'
  'logout:clear auth'
  'status:show status'
  'doctor:diagnostics'
  'init:setup'
  'setup:install integrations'
  'env:write .env'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--json[JSON output]' \
  '--format[output format]:format:(text json csv yaml)' \
  '--verbose[verbose]' \
  '--no-color[disable color]' \
  '--no-header[omit table header]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'tavily-cli command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (search)
        _arguments \
          '--topic[topic]:topic:(news)' \
          '--time-range[time range]:range:(day week month year)' \
          '--depth[depth]:depth:(basic advanced)' \
          '--answer[answer mode]:mode:(basic advanced)' \
          '--max-results[max results]:n:' \
          '--include-domains[domains]:domains:' \
          ':query:' && ret=0
        ;;
      (extract|crawl|map)
        _arguments '*:url:_urls' && ret=0
        ;;
      (research|research-status)
        _arguments '*:arg:' && ret=0
        ;;
      (*)
        _arguments '*::args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
