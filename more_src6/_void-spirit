#compdef void-spirit vs
# Documentation: https://github.com/silverlion2/Void-spirit-CLI
# Reference accessed: 2026-05-22
# Verified: src/index.js Commander options.

# Zsh completion for void-spirit / vs - terminal AI coding assistant

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-p --provider)'{-p,--provider}'[provider preset]:provider:(openai gemini anthropic deepseek groq ollama together custom)' \
  '(-m --model)'{-m,--model}'[model name]:model:' \
  '(-k --api-key)'{-k,--api-key}'[API key]:key:' \
  '(-u --base-url)'{-u,--base-url}'[custom API base URL]:url:' \
  '(-r --resume)'{-r,--resume}'[resume last session]' \
  '--fast-model[fast model for summaries]:model:' \
  '--budget[per-session token budget]:tokens:' \
  '--budget-usd[per-session USD limit]:amount:' \
  '--export-audit[export audit log JSON]:file:_files' \
  '*:: :->args' && ret=0

return 0
