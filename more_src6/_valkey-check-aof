#compdef valkey-check-aof
# Documentation: https://valkey.io/topics/persistence/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# valkey-check-aof: check/fix Valkey AOF
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '--fix[truncate aof on first error]' \
  '*:AOF file:_files -g "*.aof"' && ret=0
return ret
