#compdef tavern-ci
# _tavern-ci — Tavern API testing CLI
# upstream: https://github.com/taverntesting/tavern

_arguments -s -S \
    '(- *)'{-h,--help}'[show help]' \
    '--in=[test file or directory]:file:_files -g "*.(yml|yaml)"' \
    '--stdout[send test results to stdout]' \
    '--log-to-file=[log to file]:file:_files' \
    '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
    '--debug[enable debug logging]' \
    '*:test files:_files -g "*.(yml|yaml)"' \
    && return 0
