#compdef tfsort
# Documentation: https://github.com/AlexNabokikh/tfsort
# Reference accessed: 2026-05-21
# Verified: upstream cmd/root.go at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-o --out)'{-o,--out}'=[output file path]:file:_files' \
  '(-d --dry-run)'{-d,--dry-run}'[preview changes without writing]' \
  '*:terraform file:_files -g "*.tf(-.)"'
