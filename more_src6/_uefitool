#compdef uefitool
# Documentation: https://github.com/LongSoft/UEFITool
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Note: UEFITool is primarily a Qt GUI; the binary accepts a firmware image
# path as a positional argument. CLI-specific extraction is handled by
# UEFIExtract / UEFIFind (separate binaries, not covered here).

local curcontext="$curcontext" ret=1
_arguments -C \
  '*:UEFI firmware image:_files -g "*.(rom|bin|cap|fd|img)"' && ret=0
return ret
