#compdef xfishtank
# Documentation: https://manpages.org/xfishtank
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed: fabricated -fish, -speed, -pause, -bw, -fg, -bg, -rv, -h, -display
# (none in upstream xfishtank(6) manpage).
# Added: -c, -b, -f, -i, -r, -m, -C, -d, -p (documented upstream flags).

local curcontext="$curcontext" ret=1

_arguments -C \
  '-c+[background color]:color:' \
  '-b+[number of bubbles]:n:' \
  '-f+[number of fishes]:n:' \
  '-i+[move interval]:interval:' \
  '-r+[move frequency]:rate:' \
  '-m+[median cut to this many colors]:n:' \
  '-C+[use only this many color cells]:n:' \
  '-d[clip fish, swim on root window]' \
  '-p+[fish swim on picture in file]:file:_files' \
  '*:host\:dpy:' && ret=0

return ret
