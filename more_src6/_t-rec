#compdef t-rec
# Documentation: https://github.com/sassman/t-rec-rs
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose insights]' \
  '(-q --quiet)'{-q,--quiet}'[suppress the banner message]' \
  '(-o --output)'{-o+,--output=}'[output filename without extension]:name:' \
  '(-m --video)'{-m,--video}'[generate both GIF and MP4 video]' \
  '(-M --video-only)'{-M,--video-only}'[generate only MP4, skip GIF]' \
  '(-d --decor)'{-d+,--decor=}'[border effects]:decoration:(shadow none)' \
  '(-b --bg)'{-b+,--bg=}'[background color]:color:(white black transparent)' \
  '(-p --wallpaper)'{-p+,--wallpaper=}'[wallpaper preset or image path]:wallpaper:' \
  '--wallpaper-padding=[padding pixels around recording]:pixels:' \
  '(-f --fps)'{-f+,--fps=}'[capture framerate 4-15 fps]:fps:' \
  '(-n --natural)'{-n,--natural}'[disable idle detection and optimization]' \
  '(-i --idle-pause)'{-i+,--idle-pause=}'[max idle time before optimization]:duration:' \
  '(-s --start-pause)'{-s+,--start-pause=}'[pause duration at animation start]:duration:' \
  '(-e --end-pause)'{-e+,--end-pause=}'[pause duration at animation end]:duration:' \
  '(-l --ls-win)'{-l,--ls-win}'[list available windows by ID]' \
  '(-w --win-id)'{-w+,--win-id=}'[record specific window by ID]:winid:' \
  '--profile=[use named profile from config]:profile:' \
  '--init-config[create starter config file]' \
  '--list-profiles[display available profiles]' \
  '*:program:_command_names -e'
