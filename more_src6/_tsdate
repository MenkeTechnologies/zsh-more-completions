#compdef tsdate
# _tsdate — TSDuck tsdate MPEG-2 TS DVB TDT/TOT and ATSC STT system-time table extractor for displaying or recording broadcast time references (tsduck team, C++); custom argparse
# upstream: https://github.com/tsduck/tsduck

_tsdate() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--version[show version]' \
        '-d+[debug level]:n:' \
        '--debug=+[debug level]:n:' \
        '-n+[N updates]:n:' \
        '--max-updates=+[N updates]:n:' \
        '-l+[log file]:file:_files' \
        '--log-file=+[log file]:file:_files' \
        '-t+[type]:t:(tdt tot stt all)' \
        '--type=+[type]:t:(tdt tot stt all)' \
        '--no-tdt[no TDT]' \
        '--no-tot[no TOT]' \
        '--time-reference=+[r]:r:(system tdt utc local)' \
        '--utc[UTC]' \
        '--local[local]' \
        '--display[display only]' \
        '--quiet[quiet]' \
        '--first-packet=+[N]:n:' \
        '--packet-count=+[N]:n:' \
        '-I+[input plugin]:p:(file null udp ip http https rist srt dektec dvb fork)' \
        '--input=+[input plugin]:p:(file null udp ip http https rist srt dektec dvb fork)' \
        '*:input ts file:_files -g "*.ts *.m2ts *.mpeg *.mpg"'
}

_tsdate "$@"
