#compdef try
# Documentation: https://github.com/binpash/try
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for try (binpash/try): execute commands in a sandboxed overlay.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-n[do not commit or prompt for commit (overrides -y)]' \
  '-y[assume yes to all prompts (overrides -n)]' \
  '-x[prevent network access (unshare the network namespace)]' \
  '-i+[ignore paths matching PATTERN on summary and commit]:pattern:' \
  '-D+[work in DIR (implies -n)]:dir:_directories' \
  '-U+[path to unionfs helper (e.g., mergerfs, unionfs-fuse)]:helper:_files' \
  '-L+[merge multiple lower directories (colon-separated, implies -n)]:dirs:' \
  '-v[show version information and exit]' \
  '-h[show usage and exit]' \
  '1: :->first' \
  '*::command and arguments:_normal' && ret=0

case $state in
  (first)
    local -a subcommands=(
      'summary:inspect changes made in an overlay directory'
      'commit:commit overlay directory contents to the live system'
      'explore:open a shell within the sandbox environment'
    )
    _alternative \
      'subcommands:try subcommand:_describe -t subcommands "try subcommand" subcommands' \
      'commands:command:_command_names -e' && ret=0
    ;;
esac

return ret
