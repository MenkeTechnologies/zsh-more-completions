  '-display=+[X display]:display:' \
  '-DotWhenNoCursor=+[dot when no cursor]:flag:(0 1)' \
  '-EmulateMiddleButton=+[emulate middle mouse button]:flag:(0 1)' \
  '-FullColor=+[full colour]:flag:(0 1)' \
  '-FullColour=+[full colour]:flag:(0 1)' \
  '-FullScreen=+[fullscreen]:flag:(0 1)' \
