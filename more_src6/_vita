#compdef vita

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-d --domain)'{-d,--domain}'[target domain]:domain' \
  '(-w --wordlist)'{-w,--wordlist}'[wordlist file]:wordlist:_files' \
  '(-r --resolvers)'{-r,--resolvers}'[resolvers file]:resolvers file:_files' \
  '(-t --threads)'{-t,--threads}'[number of threads]:threads' \
  '(-o --output)'{-o,--output}'[output file]:output file:_files' \
  '--timeout[request timeout]:timeout' \
  '--silent[suppress output]' \
  '--verbose[enable verbose output]' \
  '--no-color[disable colored output]' \
  '--all[run all modules]' \
  '1:command:->commands' \
  && ret=0

case $state in
  commands)
    local -a commands=(
      'host:resolve host information'
      'passive:passive enumeration'
      'enumerate:active enumeration'
      'all:run all modules'
    )
    _describe -t commands 'vita command' commands && ret=0
    ;;
esac

return ret
