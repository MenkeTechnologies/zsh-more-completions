#compdef tabby-cli
# Documentation: https://github.com/TabbyML/tabby
# Reference accessed: 2026-05-21
# Verified: upstream crates/tabby/src/main.rs Commands enum.

# tabby: self-hosted AI coding assistant
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'serve:start the api endpoint for IDE/Editor extensions'
  'download:download the language model for serving'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--otlp-endpoint=[OpenTelemetry endpoint]:url:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'tabby command' commands && ret=0 ;;
esac
return ret
