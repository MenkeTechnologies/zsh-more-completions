#compdef tracy-csvexport
# Documentation: https://github.com/wolfpld/tracy

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-f,--filter}'=[filter zones by name]:name:' \
  {-s,--sep}'=[CSV separator character]:separator:' \
  '--case-sensitive[case sensitive filter matching]' \
  '--self-time[report self time instead of inclusive time]' \
  '--unwrap[report unwrapped source locations]' \
  '1:input trace file:_files -g "*.tracy"' \
  && return 0
