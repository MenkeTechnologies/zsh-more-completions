#
#  GetOpt PHP distinctive features:
#    - COMPOSER-INSTALLABLE — `composer require ulrichsg/getopt-php`
#      via Packagist; NOT a stdlib (vs PHP's built-in `getopt()`)
#    - PSR-4 NAMESPACED CLASSES — `GetOpt\GetOpt`, `GetOpt\Option`,
#      `GetOpt\Argument`, `GetOpt\ArgumentException`, `GetOpt\Command`
#    - OBJECT-ORIENTED design — `new GetOpt(null, $settings)` parser
#      instance + `Option::create(...)` static factory method
#    - `Option::create($short, $long, $mode)` STATIC FACTORY — `$short`
#      is single-char string or null, `$long` is long name or null,
#      `$mode` is one of four GetOpt arg-mode constants
#    - ARG MODES (PHP class constants):
#      * `GetOpt::NO_ARGUMENT` — boolean flag (no value)
#      * `GetOpt::REQUIRED_ARGUMENT` — value required (`--opt value`)
#      * `GetOpt::OPTIONAL_ARGUMENT` — value optional (`--opt[=value]`)
#      * `GetOpt::MULTIPLE_ARGUMENT` — repeatable flag (returns array)
#    - CHAINED SETTERS — fluent builder via `->setDescription(...)`,
#      `->setArgumentName(...)`, `->setDefaultValue(...)`,
#      `->setValidation(callable)`
#    - `->setValidation(callable)` — closure-based validator returning
#      bool; throws on parse if validator returns false
#    - `$getOpt->addOptions([Option, Option, ...])` — register OPTION
#      ARRAY at once
#    - `$getOpt->addOption(Option)` — single option (imperative
#      alternative)
#    - `$getOpt->addCommand(Command)` — SUBCOMMAND support via
#      `GetOpt\Command` class
#    - GETOPT SETTINGS via constructor 2nd arg or `$getOpt->set($key,
#      $value)`:
#      * `GetOpt::SETTING_STRICT_OPERANDS` (true: error on extra args)
#      * `GetOpt::SETTING_STRICT_OPTIONS` (true: error on unknown opts)
#      * `GetOpt::SETTING_DEFAULT_MODE` (default arg mode for plain
#        addOption() calls)
#      * `GetOpt::SETTING_SCRIPT_NAME` (program name in help text)
#    - `$getOpt->process()` PARSE METHOD — parses `$_SERVER['argv']`
#      or explicit `$argv` argument; throws `GetOpt\ArgumentException`
#      subclasses on parse errors (`Missing`, `Unexpected`, `Invalid`)
#    - `$getOpt->getOption('name')` — fetch parsed value (string for
#      REQUIRED_ARGUMENT, int 1 for NO_ARGUMENT flag, array for
#      MULTIPLE_ARGUMENT)
#    - `$getOpt->getOptions()` — fetch all parsed options as
#      associative array
#    - `$getOpt->getOperands()` — fetch positional arguments after
#      options
#    - `$getOpt->getHelpText()` — AUTO-GENERATED help text using
#      terminal-width-aware formatting
#    - `GetOpt\Command` — SUBCOMMAND class for git-style multi-command
#      apps with separate options per command
#    - PARSE EXCEPTION HIERARCHY: `Missing`, `Unexpected`, `Invalid`
#      subclasses of `ArgumentException` for granular error handling
#    - NO process exit on parse error — caller catches exception and
#      decides exit code
#    - PHP 7.1+ MINIMUM — uses modern PHP features (typed properties,
#      strict types optional)
#  Distinct from R282 PHP stdlib `getopt()` (procedural function
#  returning mixed-key array — no objects, no validation, no help),
#  R356 Symfony Console (full FRAMEWORK with `Command` base class
#  subclassing + `configure()` / `execute()` methods + Container DI +
#  Application::run() event dispatcher), R270 Haskell optparse-
#  applicative (functional applicative combinator in different
#  language), R277 Java picocli (annotation-driven), R322 Java
#  JCommander (annotations + reflection), R343 commander.js (JS
#  fluent builder — CLOSEST concept analog with similar
#  `.option('-o', '--output', 'description', 'default')` chained API).
#  GetOpt PHP's approach: COMPOSER-INSTALLABLE PSR-4-NAMESPACED OOP
#  PHP CLI library + `Option::create($short, $long, $mode)` STATIC
#  FACTORY + 4 ARG MODES (`NO_ARGUMENT/REQUIRED_ARGUMENT/OPTIONAL_
#  ARGUMENT/MULTIPLE_ARGUMENT`) + CHAINED SETTER FLUENT BUILDER
#  (`->setDescription/setArgumentName/setDefaultValue/setValidation`)
#  + CLOSURE-BASED VALIDATION via `setValidation(callable)` +
#  GETOPT SETTINGS array via constructor or `set()` + `process()`
#  PARSE METHOD throwing `ArgumentException` subclasses + `getOption`/
#  `getOptions`/`getOperands` RESULT ACCESSORS + AUTO-GENERATED HELP
#  via `getHelpText()` + `GetOpt\Command` SUBCOMMAND SUPPORT + NO
#  process exit on error — corpus's **first documented Composer-
#  installable-PSR-4-namespaced-OOP PHP CLI library**.  Brings cross-
#  language CLI library taxonomy variant count to 127; PHP ecosystem
#  now has 3 documented CLI libraries.
#
#  Surface (verbatim from `lib/Weathermap/CLI/Runner.php`
#  `addMainOptions`/`addExpertOptions`/`addDevOptions` methods):
#
#  Main options:
#        --version                  Show version info and quit
#    -h, --help                     Show this help and quit
#        --config FILENAME          Filename to read (default
#                                   weathermap.conf)
#        --output FILENAME          Filename to write image (PNG/SVG)
#        --htmloutput FILENAME      Filename to write HTML wrapper
#        --image-uri URI            URI to prefix <img> tags in HTML
#
#  Expert options:
#        --define NAME=VALUE        Define internal variables (equiv to
#                                   global SET in config; REPEATABLE
#                                   via MULTIPLE_ARGUMENT mode)
#        --bulge                    Enable link-bulging mode
#        --no-data                  Skip data-reading process (grey map)
#        --sizedebug                Show max possible value, not current
#        --debug                    Produce LOTS of debug info
#        --no-warn WMxxx_errorcode  Suppress warnings (comma-separated
#                                   error codes like WM101,WM102)
#
#  Dev options:
#        --randomdata               Generate random data (debug)
#        --uberdebug                Produce even more debug info
#        --setdebug                 Debug info for map variables (SET)
#        --dump-config FILENAME     Dump config to new file (testing
#                                   editor)
#        --dump-json FILENAME       Dump JSON config to new file
#
#  Positional:
#    -                              (none; all input/output via flags;
#                                   STRICT_OPERANDS setting rejects
#                                   extra args)
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also GetOpt PHP users):
#    - cacti (IN CORPUS via _cacti — Cacti network monitoring;
#      sister tool that integrates weathermap, but Cacti's own CLI
#      uses stdlib getopt not GetOpt PHP)
#    - balloon (gyselroth/balloon 21 stars — Balloon ECM platform,
#      uses GetOpt PHP for console, smaller community)
#    - libremail (mikegioia/libremail 130 stars — IMAP-to-SQL email
#      client, uses League/CLImate not GetOpt PHP)
#    - phpx (swoole/phpx 854 stars — Swoole C++ wrapper, uses
#      League/CLImate, FUTURE candidate for league/climate as 4th PHP)
#    - PHPTv (mario-deluna/PHPTv — PHP TV streaming, League/CLImate)
#    - oms-api-php / google-ads-php / network-weathermap (Google Ads
#      SDK examples use GetOpt PHP but are SDK examples not
#      distributable binaries)
#    - php-ovh-cli (miklinux — OVH cloud CLI in PHP, smaller community)
#    - syncdrive (martok — Nextcloud-like sync client, FUTURE
#      candidate)
# ============================================================================

_weathermap() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '--version[show version info and quit]' \
    '(-h --help)'{-h,--help}'[show this help and quit]' \
    '--config=[filename to read (default weathermap.conf)]:file:_files -g "*.conf"' \
    '--output=[filename to write image]:file:_files -g "*.(png|svg|jpg)"' \
    '--htmloutput=[filename to write HTML wrapper]:file:_files -g "*.html"' \
    '--image-uri=[URI to prefix img tags in HTML]:uri' \
    '*--define=[define internal variable NAME=VALUE]:define' \
    '--bulge[enable link-bulging mode]' \
    '--no-data[skip data-reading process (grey map)]' \
    '--sizedebug[show max possible value, not current]' \
    '--debug[produce LOTS of debug info]' \
    '--no-warn=[suppress warnings (comma-separated codes)]:codes' \
    '--randomdata[generate random data (debug)]' \
    '--uberdebug[produce even more debug info]' \
    '--setdebug[debug info for map variables (SET)]' \
    '--dump-config=[dump config to new file]:file:_files' \
    '--dump-json=[dump JSON config to new file]:file:_files -g "*.json"'
}

_weathermap "$@"
