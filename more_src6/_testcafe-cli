#compdef testcafe-cli testcafe
# _testcafe-cli — DevExpress TestCafe testcafe-cli CLI command-line frontend wrapping the TestCafe open-source no-config browser testing tool for web applications written in TypeScript Node DevExpress originally Soft Industry now DevExpress no plugins no boilerplate no fluff no waiting test browsers built-in waiting Smart Smart Assertion Query Multiple browser support including headless Chrome Chromium Firefox Safari Edge Opera browser-emulation page-load-timeout selector-timeout assertion-timeout client-script reporter take-screenshots-on-fails video color hostname proxy ports concurrency speed test-name filter (DevExpress TestCafe team Vasiliy Loginevskiy Eugene Lazutkin, TypeScript); commander
# upstream: https://testcafe.io/

_testcafe-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-b[list browsers]' \
        '--list-browsers[list browsers]' \
        '--browser-init-timeout=+[ms]:n:' \
        '--port1=+[port]:n:' \
        '--port2=+[port]:n:' \
        '--hostname=+[host]:_hosts' \
        '--proxy=+[host:port]:str:' \
        '--proxy-bypass=+[hosts]:str:' \
        '--ssl=+[options]:str:' \
        '-S[take screenshots on fail]' \
        '--screenshots-on-fails[screenshots on fails]' \
        '--screenshots=+[opts]:str:' \
        '-s+[screenshots dir]:dir:_files -/' \
        '--video=+[dir]:dir:_files -/' \
        '--video-options=+[opts]:str:' \
        '--video-encoding-options=+[opts]:str:' \
        '--retry-test-pages[retry test pages]' \
        '--cache[cache resources]' \
        '-q+[quarantine mode]:n:' \
        '--quarantine-mode=+[opts]:str:' \
        '--debug-on-fail[debug on fail]' \
        '-e[skip JS errors]' \
        '--skip-js-errors[skip JS errors]' \
        '-u[skip uncaught errors]' \
        '--skip-uncaught-errors[skip uncaught]' \
        '-T+[test pattern]:str:' \
        '--test-grep=+[regex]:str:' \
        '-t+[test name]:str:' \
        '--test=+[name]:str:' \
        '*-t+[test]:str:' \
        '-F+[fixture pattern]:str:' \
        '--fixture-grep=+[regex]:str:' \
        '-f+[fixture name]:str:' \
        '--fixture=+[name]:str:' \
        '*-f+[fixture]:str:' \
        '--test-meta=+[k=v]:str:' \
        '--fixture-meta=+[k=v]:str:' \
        '--app=+[cmd]:str:' \
        '-a+[app cmd]:str:' \
        '--app-init-delay=+[ms]:n:' \
        '-c+[concurrency]:n:' \
        '--concurrency=+[N]:n:' \
        '-L[live mode]' \
        '--live[live mode]' \
        '-r+[reporter]:n:(spec list minimal xunit json)' \
        '*-r+[reporter]:n:(spec list minimal xunit json)' \
        '--reporter=+[r]:n:(spec list minimal xunit json)' \
        '-d[debug mode]' \
        '--debug-mode[debug mode]' \
        '--qr-code[show QR code]' \
        '--speed=+[N]:str:' \
        '--page-load-timeout=+[ms]:n:' \
        '--page-request-timeout=+[ms]:n:' \
        '--ajax-request-timeout=+[ms]:n:' \
        '--browser-init-timeout=+[ms]:n:' \
        '--test-execution-timeout=+[ms]:n:' \
        '--run-execution-timeout=+[ms]:n:' \
        '--selector-timeout=+[ms]:n:' \
        '--assertion-timeout=+[ms]:n:' \
        '--disable-page-caching[disable cache]' \
        '--disable-page-reloads[no reloads]' \
        '--disable-screenshots[no screenshots]' \
        '--disable-test-syntax-validation[no syntax validation]' \
        '--disable-http2[no HTTP/2]' \
        '--disable-multiple-windows[no multi window]' \
        '--client-scripts=+[file]:file:_files -g "*.js"' \
        '*--client-scripts=+[file]:file:_files' \
        '--filter=+[filter]:str:' \
        '--app-command=+[cmd]:str:' \
        '--color[force color]' \
        '--no-color[no color]' \
        '*:args:'
}

_testcafe-cli "$@"
