#compdef texdoc
# Documentation: texdoc --help
# Source: TeX Live texdoc — find and view TeX documentation.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-w --view -m --mixed -l --list -s --showall)'{-w,--view}'[viewer mode (default)]' \
    '(-w --view -m --mixed -l --list -s --showall)'{-m,--mixed}'[mixed mode]' \
    '(-w --view -m --mixed -l --list -s --showall)'{-l,--list}'[list mode]' \
    '(-w --view -m --mixed -l --list -s --showall)'{-s,--showall}'[show also bad results]' \
    '(-i --interact -I --nointeract -M --machine)'{-i,--interact}'[interactive menus (default)]' \
    '(-i --interact -I --nointeract -M --machine)'{-I,--nointeract}'[plain lists; no interaction]' \
    '(-i --interact -I --nointeract -M --machine)'{-M,--machine}'[machine-readable output (implies -I)]' \
    '(-q --quiet -v --verbose)'{-q,--quiet}'[suppress warnings]' \
    '(-q --quiet -v --verbose)'{-v,--verbose}'[print extra info]' \
    '(-D --debug -d --debug=)'{-D,--debug}'[all debug output]' \
    '(-D --debug -d --debug=)'{-d,--debug=}'[debug LIST]:list:' \
    '*-c+[set configuration item NAME=VALUE]:name=value:' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(- *)'{-f,--files}'[print list of config files used]' \
    '(- *)--just-view=[view FILE directly (no search)]:file:_files' \
    '(- *)--print-completion=[print shell completion script]:shell:(bash zsh fish)' \
    '*:TeX doc name:' \
    && ret=0

return ret
