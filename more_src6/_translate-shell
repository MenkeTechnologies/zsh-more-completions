# Zsh completion for translate-shell (trans) - command-line translator

_arguments \
  '(- *)'{-V,--version}'[show version]' \
  '(- *)'{-H,--help}'[show help]' \
  '(- *)'{-M,--man}'[show manual]' \
  '(- *)'{-T,--reference}'[print reference]' \
  '(- *)'{-R,--reference-english}'[print reference in English]' \
  '(- *)'{-S,--list-engines}'[list available engines]' \
  '(- *)--list-languages[list supported languages]' \
  '(- *)--list-languages-english[list languages in English]' \
  '(- *)--list-codes[list language codes]' \
  '(- *)--list-all[list everything]' \
  '(- *)'{-L,--linguist}'[show linguistic information]:codes' \
  '(- *)'{-U,--upgrade}'[upgrade trans]' \
  '(-e --engine)'{-e,--engine}'[set translation engine]:engine:(google bing yandex apertium aspell hazm spell)' \
  '--verbose[verbose mode]' \
  '(-b --brief)'{-b,--brief}'[brief mode]' \
  '(-d --dictionary)'{-d,--dictionary}'[dictionary mode]' \
  '--identify[identify language]' \
  '(-w --width)'{-w,--width}'[output width]:width' \
  '--indent=[indentation level]:n' \
  '--theme=[color theme]:file:_files' \
  '--no-theme[disable theme]' \
  '--no-ansi[disable ANSI escape codes]' \
  '--no-autocorrect[disable autocorrection]' \
  '--no-bidi[disable bidirectional output]' \
  '--bidi[enable bidirectional output]' \
  '--no-warn[disable warnings]' \
  '--dump[dump raw API response]' \
  '(-p --play)'{-p,--play}'[listen to translation]' \
  '--speak[speak translation only]' \
  '(-n --narrator)'{-n,--narrator}'[narrator voice]:voice' \
  '--player=[player program]:program:_command_names -e' \
  '--no-play[disable audio playback]' \
  '--no-translate[disable translation]' \
  '--download-audio[download pronunciation audio]' \
  '--download-audio-as=[save audio as]:file:_files' \
  '(-v --view)'{-v,--view}'[view in pager]' \
  '--pager=[pager program]:program:_command_names -e' \
  '--no-view[disable pager]' \
  '--no-pager[disable pager]' \
  '--browser=[browser program]:program:_command_names -e' \
  '--no-browser[disable browser]' \
  '(-x --proxy)'{-x,--proxy}'[use proxy]:host\:port' \
  '(-u --user-agent)'{-u,--user-agent}'[set user agent]:agent' \
  '(-4 --ipv4 --inet4-only)'{-4,--ipv4,--inet4-only}'[IPv4 only]' \
  '(-6 --ipv6 --inet6-only)'{-6,--ipv6,--inet6-only}'[IPv6 only]' \
  '(-I --interactive --shell)'{-I,--interactive,--shell}'[interactive shell]' \
  '(-E --emacs)'{-E,--emacs}'[start emacs frontend]' \
  '--no-rlwrap[disable rlwrap]' \
  '(-i --input)'{-i,--input}'[input file]:file:_files' \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '(-hl --host)'{-hl,--host}'[host language]:code' \
  '(-s --sl --source --from)'{-s,--sl,--source,--from}'[source language]:code' \
  '(-t --tl --target --to)'{-t,--tl,--target,--to}'[target language]:code' \
  '(-j --join-sentence)'{-j,--join-sentence}'[join input lines into a single sentence]' \
  '--no-init[disable init file]' \
  '*:text to translate'
