#compdef typo3cms typo3 typo3-cli
# _typo3cms — TYPO3 Enterprise PHP CMS CLI alias (typo3 team, PHP); symfony console
# upstream: https://github.com/TYPO3/typo3

_typo3cms() {
    local -a sub=(
        'help:show help'
        'list:list commands'
        'cache:flush:flush cache'
        'cache:flushcomplete:flush all caches'
        'cache:warmup:warm up caches'
        'install:setup:install typo3'
        'install:fixfolderstructure:fix folder structure'
        'install:generatepackagestates:regenerate PackageStates.php'
        'install:extensionsetupifpossible:setup extensions'
        'database:updateschema:update database schema'
        'database:export:export database'
        'database:import:import database'
        'extension:setupactive:setup active extensions'
        'extension:setup:setup extension'
        'extension:list:list extensions'
        'extension:list-keys:list extension keys'
        'extension:activate:activate extension'
        'extension:deactivate:deactivate extension'
        'extension:download:download extension'
        'extension:remove:remove extension'
        'language:update:update languages'
        'scheduler:run:run scheduler tasks'
        'redirects:cleanup:cleanup redirects'
        'site:show:show site config'
        'configuration:set:set configuration'
        'configuration:showactive:show active config'
        'backend:lock:lock backend'
        'backend:unlock:unlock backend'
        'frontend:request:simulate frontend request'
        'completion:dump completion'
        'mailer:spool:flush mail spool'
        'workspace:autopublish:autopublish workspace'
        'styleguide:create:create style guide'
        'styleguide:delete:delete style guide'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'typo3 subcommand' sub ;;
        args)
            case $words[1] in
                extension:activate|extension:deactivate|extension:download|extension:remove|extension:setup) _arguments '1:extension key:' ;;
                cache:flush) _arguments '--group=+[group]:g:(all system di pages)' '--force[force]' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_typo3cms "$@"
