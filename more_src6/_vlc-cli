#compdef vlc-cli
# _vlc-cli — VideoLAN VLC cross-platform media player CLI alias (videolan team, C); custom argparse
# upstream: https://github.com/videolan/vlc

_vlc-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--longhelp[long help]' \
        '-H[long help]' \
        '--full-help[full help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--list[list modules]' \
        '-l[list modules]' \
        '--list-verbose[list modules verbose]' \
        '--module=+[module help]:str:' \
        '-p+[module help]:str:' \
        '--ignore-config[ignore config]' \
        '--no-ignore-config[use config]' \
        '--save-config[save config]' \
        '--reset-config[reset config]' \
        '--reset-plugins-cache[reset plugins cache]' \
        '--config=+[config file]:file:_files -g "*.conf"' \
        '--no-color[no color]' \
        '--color[force color]' \
        '--intf=+[interface]:i:(qt ncurses dummy http rc oldrc telnet lirc lua)' \
        '-I+[interface]:i:(qt ncurses dummy http rc oldrc telnet lirc lua)' \
        '--extraintf=+[extra interface]:str:' \
        '--verbose=+[level]:n:' \
        '-v+[level]:n:' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--no-stats[no stats]' \
        '--stats[stats]' \
        '--volume=+[volume 0-512]:n:' \
        '--audio=+[bool]:b:(true false)' \
        '--no-audio[no audio]' \
        '--video=+[bool]:b:(true false)' \
        '--no-video[no video]' \
        '--fullscreen[fullscreen]' \
        '-f[fullscreen]' \
        '--no-fullscreen[no fullscreen]' \
        '--repeat[repeat all]' \
        '-R[repeat all]' \
        '--loop[loop]' \
        '-L[loop]' \
        '--random[random]' \
        '-Z[random]' \
        '--play-and-exit[play and exit]' \
        '--play-and-stop[play and stop]' \
        '--play-and-pause[play and pause]' \
        '--start-time=+[time]:str:' \
        '--stop-time=+[time]:str:' \
        '--run-time=+[time]:str:' \
        '--input-slave=+[slave]:str:' \
        '--audio-track=+[id]:n:' \
        '--sub-track=+[id]:n:' \
        '--audio-language=+[lang]:str:' \
        '--sub-language=+[lang]:str:' \
        '--subsdec-encoding=+[encoding]:str:' \
        '--sub-file=+[file]:file:_files' \
        '--metadata-network-access[allow network metadata]' \
        '--meta-author=+[author]:str:' \
        '--meta-title=+[title]:str:' \
        '--video-title-show[show title]' \
        '--no-video-title-show[no title]' \
        '--width=+[width]:n:' \
        '--height=+[height]:n:' \
        '--video-x=+[x]:n:' \
        '--video-y=+[y]:n:' \
        '--no-mouse-events[no mouse events]' \
        '--http-host=+[host]:host:_hosts' \
        '--http-port=+[port]:port:' \
        '--http-password=+[pass]:str:' \
        '--telnet-host=+[host]:host:_hosts' \
        '--telnet-port=+[port]:port:' \
        '--telnet-password=+[pass]:str:' \
        '--rc-host=+[host]:host:_hosts' \
        '--lua-script-file=+[file]:file:_files -g "*.lua"' \
        '--lua-config=+[config]:str:' \
        '--sout=+[output]:str:' \
        '--sout-keep[keep sout]' \
        '--sout-all[sout all]' \
        '--sout-display[sout display]' \
        '--sout-keep-streams[keep streams]' \
        '--vlm-conf=+[file]:file:_files' \
        '--snapshot-format=+[fmt]:f:(png jpg)' \
        '--snapshot-path=+[dir]:dir:_files -/' \
        '--snapshot-prefix=+[prefix]:str:' \
        '--quiet-synchro[quiet synchro]' \
        '--no-quiet-synchro[no quiet synchro]' \
        '--daemon[daemon mode]' \
        '-d[daemon mode]' \
        '--no-daemon[no daemon mode]' \
        '--pidfile=+[file]:file:_files' \
        '--file-caching=+[ms]:n:' \
        '--network-caching=+[ms]:n:' \
        '--disc-caching=+[ms]:n:' \
        '--live-caching=+[ms]:n:' \
        '--language=+[lang]:str:' \
        '--start-paused[start paused]' \
        '--minimize[minimized]' \
        '--high-priority[high priority]' \
        '*:files urls:_files'
}

_vlc-cli "$@"
