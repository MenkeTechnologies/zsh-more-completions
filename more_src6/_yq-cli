#compdef yq-cli
# _yq-cli — Mike Farah yq YAML processor CLI alias (Mike Farah, Go); spf13/cobra
# upstream: https://github.com/mikefarah/yq

_yq-cli() {
    local -a sub=(
        'eval:apply expression to each document'
        'eval-all:apply expression to all documents joined'
        'help:show help'
        '--input-format:input format'
        '--output-format:output format'
        'completion:generate shell completion'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--input-format=+[input format]:fmt:(yaml json props csv tsv xml lua toml uri shell base64)' \
        '-p+[input format]:fmt:(yaml json props csv tsv xml lua toml uri shell base64)' \
        '--output-format=+[output format]:fmt:(yaml json props csv tsv xml lua toml shell base64 uri raw)' \
        '-o+[output format]:fmt:(yaml json props csv tsv xml lua toml shell base64 uri raw)' \
        '--no-doc[strip document separators]' \
        '-N[strip document separators]' \
        '--no-colors[no colors]' \
        '-M[no colors]' \
        '--colors[force colors]' \
        '-C[force colors]' \
        '--inplace[in-place edit]' \
        '-i[in-place edit]' \
        '--indent=+[indent spaces]:n:' \
        '-I+[indent spaces]:n:' \
        '--prettyPrint[pretty print]' \
        '-P[pretty print]' \
        '--unwrapScalar=+[unwrap scalar]:b:(true false)' \
        '--null-input[null input]' \
        '-n[null input]' \
        '--from-file=+[expression file]:file:_files' \
        '--split-exp=+[split expression]:str:' \
        '-s+[split expression]:str:' \
        '--exit-status[exit status]' \
        '-e[exit status]' \
        '--front-matter=+[front matter]:f:(extract process)' \
        '--header-preprocess=+[header preprocess]:b:(true false)' \
        '--no-doc-separators[no doc separators]' \
        '--string-interpolation=+[string interpolation]:b:(true false)' \
        '--expression=+[expression]:str:' \
        '--xml-attribute-prefix=+[xml attribute prefix]:str:' \
        '--xml-content-name=+[xml content name]:str:' \
        '--xml-strict-mode[xml strict mode]' \
        '--xml-skip-directives[xml skip directives]' \
        '--xml-skip-procinst[xml skip procinst]' \
        '--csv-separator=+[csv separator]:str:' \
        '--tsv-separator=+[tsv separator]:str:' \
        '--lua-globals[lua globals]' \
        '--lua-unquoted[lua unquoted]' \
        '1:subcommand-or-expression:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'yq subcommand' sub
            _files ;;
        args)
            case $words[1] in
                eval|eval-all) _arguments \
                    '*:file:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_yq-cli "$@"
