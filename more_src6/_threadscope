#compdef threadscope
# _threadscope — GHC eventlog GUI visualizer (haskell/ThreadScope)
# upstream: https://github.com/haskell/ThreadScope
# Flags from Main.hs (System.Console.GetOpt).

_threadscope() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-t --test)'{-t+,--test=}'[load a named internal test]:name:' \
        '1:eventlog:_files -g "*.eventlog"'
}

_threadscope "$@"
