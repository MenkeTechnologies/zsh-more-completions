#compdef wslpath
# _wslpath — WSL wslpath (translate paths between Windows and Linux notations; -a force absolute, -u Windows -> Linux (default if input looks like Windows), -w Linux -> Windows, -m Linux -> Windows with forward slashes; positional argument is the path to convert)
# upstream: https://github.com/microsoft/WSL
# Flags from WSL wslpath on tip.

_wslpath() {
    _arguments \
        '-h[show help]' \
        '-a[force absolute]' \
        '(-w -m)-u[Windows -> Linux]' \
        '(-u -m)-w[Linux -> Windows]' \
        '(-u -w)-m[Linux -> Windows w/ forward slashes]' \
        '1:path:'
}

_wslpath "$@"
