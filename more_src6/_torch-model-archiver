#compdef torch-model-archiver
# Documentation: https://github.com/pytorch/serve/blob/master/model-archiver/README.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# torch-model-archiver: package PyTorch models into .mar for TorchServe
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version=}'[model version]:version:' \
  '--model-name=[model name]:name:' \
  '--serialized-file=[serialized .pt/.pth/.onnx file]:file:_files' \
  '--model-file=[model definition .py]:file:_files -g "*.py"' \
  '--handler=[handler file or built-in]:handler:' \
  '--extra-files=[extra files (comma list)]:files:' \
  '--runtime=[runtime]:runtime:(python java)' \
  '--export-path=[export path]:dir:_files -/' \
  '--archive-format=[archive format]:fmt:(default tgz no-archive zip-store)' \
  '(-f --force)'{-f,--force}'[overwrite existing archive]' \
  '(-r --requirements-file)'{-r,--requirements-file=}'[requirements.txt]:file:_files' \
  '(-c --config-file)'{-c,--config-file=}'[YAML config file]:file:_files' && ret=0
return ret
