# _xcremotecache — XCRemoteCache distributed Xcode build cache (Spotify); CCache-like layer for clang/swiftc, plus prebuild + prepare orchestrators
# upstream: https://github.com/spotify/XCRemoteCache

_xcremotecache() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[YAML config file]:file:_files -g "*.yaml"' \
        '-mode+[mode]:mode:(producer consumer producer-fast)' \
        '-final-producer-target+[final target]:name:' \
        '-config-file+[xcconfig]:file:_files -g "*.xcconfig"' \
        '-stats[print stats]' \
        '*::args:'
}

_xcremotecache "$@"
