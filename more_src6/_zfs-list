#compdef zfs-list
# _zfs-list — OpenZFS zfs list display datasets CLI alias (openzfs team, C); custom argparse
# upstream: https://github.com/openzfs/zfs

_zfs-list() {
    _arguments \
        '--help[show help]' \
        '-h[script mode, no headers]' \
        '-H[script mode, no headers]' \
        '-p[parsable]' \
        '-r[recursive]' \
        '-d+[depth]:n:' \
        '-o+[properties csv]:str:' \
        '-s+[sort prop]:str:' \
        '-S+[reverse sort prop]:str:' \
        '-t+[type csv]:t:(all filesystem snap snapshot volume bookmark)' \
        '*:dataset:'
}

_zfs-list "$@"
