#compdef xqilla
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/xqilla.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help and exit]' \
  '-p[parse in XPath 2 mode (default is XQuery mode)]' \
  '-P[parse in XPath 1.0 compatibility mode]' \
  '-s[parse XSLT 2.0]' \
  '-f[parse using W3C Full-Text extensions]' \
  '-u[parse using W3C Update extensions]' \
  '-e[parse using XQilla specific extensions]' \
  '-d[run the query in interactive debugging mode]' \
  '-x[use the Xerces-C data model (default is the FastXDM)]' \
  '-i+[load XML document and bind it as the context item]:file:_files' \
  '-b+[set the base URI for the context]:baseURI:' \
  '-v+[bind external variable name=value]:name: :value:' \
  '-o+[write the result to the specified file]:file:_files' \
  '-n+[run the queries a number of times]:number:' \
  '-q[quiet mode - no output]' \
  '-t[output an XML representation of the AST]' \
  '*:query_file:_files' && ret=0

return ret
