#compdef taskbook tb
# Documentation: https://github.com/klaussinani/taskbook
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-a --archive)'{-a,--archive}'[display archived items]' \
  '(-b --begin)'{-b+,--begin=}'[start/pause task]:id:' \
  '(-c --check)'{-c+,--check=}'[check/uncheck task]:id:' \
  '--clear[delete all checked items]' \
  '(-y --copy)'{-y+,--copy=}'[copy item description]:id:' \
  '(-d --delete)'{-d+,--delete=}'[delete item]:id:' \
  '(-e --edit)'{-e+,--edit=}'[edit item description]:id:' \
  '(-f --find)'{-f+,--find=}'[search items]:terms:' \
  '(-l --list)'{-l+,--list=}'[list items by attributes]:attrs:' \
  '(-m --move)'{-m+,--move=}'[move item between boards]:id+board:' \
  '(-n --note)'{-n+,--note=}'[create note]:text:' \
  '(-p --priority)'{-p+,--priority=}'[update task priority]:id+pri:' \
  '(-r --restore)'{-r+,--restore=}'[restore archived items]:ids:' \
  '(-s --star)'{-s+,--star=}'[star/unstar item]:id:' \
  '(-t --task)'{-t+,--task=}'[create task]:text:' \
  '--taskbook-dir=[custom taskbook dir]:dir:_files -/' \
  '(-i --timeline)'{-i,--timeline}'[display timeline view]' \
  '*: :' && ret=0

return ret
