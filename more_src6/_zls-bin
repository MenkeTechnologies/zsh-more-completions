#compdef zls
# _zls-bin — Zig Language Server (Zig community, Zig); LSP backend for Zig editors
# upstream: https://github.com/zigtools/zls

_zls-bin() {
    local -a sub=(
        'config:configure ZLS'
        'env:print env'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '--config-path+[config file]:file:_files -g "zls.json"' \
        '--show-config-path[show config path]' \
        '--log-level+[log level]:level:(debug info warn err critical)' \
        '--enable-debug-log[enable debug log]' \
        '--enable-message-tracing[enable message tracing]' \
        '--enable-stderr-logs[enable stderr logs]' \
        '--enable-time-warn[enable time warning]' \
        '--zls-version[show zls version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zls subcommand' sub ;;
        args)
            case $words[1] in
                config) _arguments '1:config cmd:(init list get set)' '*:args:' ;;
            esac
            ;;
    esac
}

_zls-bin "$@"
