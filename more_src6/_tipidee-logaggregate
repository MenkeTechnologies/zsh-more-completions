#compdef tipidee-logaggregate
# _tipidee-logaggregate — skarnet tipidee log aggregator (reads s6-log style entries from many concurrent tipideed children on stdin and emits one canonical merged log to stdout; -4 keeps IPv4 addrs literal)
# upstream: https://github.com/skarnet/tipidee
# Flags from src/misc/tipidee-logaggregate.c on tip.

_tipidee-logaggregate() {
    _arguments \
        '(-4 -6)-4[IPv4 literal output]' \
        '(-4 -6)-6[IPv6 literal output]'
}

_tipidee-logaggregate "$@"
