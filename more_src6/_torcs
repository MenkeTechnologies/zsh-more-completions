#compdef torcs
# Documentation: https://manpages.debian.org/bookworm/torcs/torcs.6.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# torcs: The Open Racing Car Simulator
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[display usage]' \
  '-l[list dynamically linked libraries]' \
  '-d[run under gdb and print stack trace on exit]' \
  '-g[run under valgrind]' \
  '-e[display commands to run under gdb]' \
  '-s[disable multitexturing]' \
  '-r[run race in command line mode]' \
  '-k[suppress dlclose for modules]' && ret=0
return ret
