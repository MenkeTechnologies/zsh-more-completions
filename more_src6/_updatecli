#compdef updatecli
# Documentation: https://www.updatecli.io/docs/prologue/quick-start/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a cmds=(
      'apply:apply changes'
      'compose:compose pipelines'
      'diff:show diff of changes'
      'jsonschema:generate JSON schema'
      'manifest:manage manifests'
      'pipeline:manage pipelines'
      'prepare:prepare pipelines'
      'show:show configuration'
      'udash:Updatecli dashboard'
      'version:show version'
      'completion:generate shell completion'
    )
    _describe -t commands 'updatecli command' cmds && ret=0
    ;;
  args)
    case "${words[1]}" in
      completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      compose)
        _arguments -s -S \
          '1:subcommand:(apply diff show)' && ret=0
        ;;
      manifest)
        _arguments -s -S \
          '1:subcommand:(init pull push show upgrade)' && ret=0
        ;;
      pipeline)
        _arguments -s -S \
          '1:subcommand:(apply diff prepare)' && ret=0
        ;;
      udash)
        _arguments -s -S \
          '1:subcommand:(config login logout)' && ret=0
        ;;
    esac
    ;;
esac
return ret
