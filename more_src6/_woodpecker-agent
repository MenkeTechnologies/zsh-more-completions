#compdef woodpecker-agent
# Documentation: https://woodpecker-ci.org/docs/administration/configuration/agent
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# woodpecker-agent: Woodpecker CI agent.
# Flags map 1:1 to documented WOODPECKER_* environment variables.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--server=[Woodpecker server gRPC URL]:url:' \
  '--username=[gRPC username]:user:_users' \
  '--grpc-secure[use secure gRPC transport]' \
  '--grpc-verify[verify server certificate]' \
  '--agent-config=[agent config file]:file:_files' \
  '--agent-labels=[agent labels (key=value)]:labels:' \
  '--hostname=[agent hostname]:host:_hosts' \
  '--backend-engine=[backend engine]:engine:(docker kubernetes local auto-detect)' \
  '--max-workflows=[parallel workflows per agent]:n:' \
  '--single-workflow[exit after one workflow]' \
  '--log-level=[log level]:level:(trace debug info warn error fatal panic disabled)' \
  '--debug-pretty[pretty-print debug output]' \
  '--debug-nocolor[disable colored output]' \
  '--healthcheck[enable health endpoint]' \
  '--healthcheck-addr=[healthcheck listener addr]:addr:' \
  '--keepalive-time=[gRPC keepalive ping interval]:duration:' \
  '--keepalive-timeout=[gRPC keepalive timeout]:duration:' \
  '--retry-timeout=[reconnection attempt duration]:duration:' \
  '--connect-retry-count=[connection retry attempts]:n:' \
  '--connect-retry-delay=[delay between retries]:duration:' && ret=0
return ret
