#compdef updatetree
# _updatetree — Trillian admin helper: update a tree's state/type
# upstream: https://github.com/google/trillian
# Flags from cmd/updatetree/main.go on tip.

_updatetree() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-admin_server=[Trillian Admin Server host\:port]:host\:port:' \
        '-rpc_deadline=[RPC request deadline]:dur:' \
        '-tree_id=[ID of the tree to update]:n:' \
        '-tree_state=[new tree state]:state:(ACTIVE FROZEN DRAINING)' \
        '-tree_type=[new tree type]:type:(LOG PREORDERED_LOG MAP)' \
        '-print=[print the resulting tree]:bool:(true false)'
}

_updatetree "$@"
