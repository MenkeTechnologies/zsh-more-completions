#compdef ulimit-adjuster
# _ulimit-adjuster — containerd NRI sample plugin: rewrites per-container rlimits (POSIX/extended) from a pod annotation
# upstream: https://github.com/containerd/nri
# Flags from plugins/ulimit-adjuster/adjuster.go on tip.

_ulimit-adjuster() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--name=[plugin name to register to NRI]:name:' \
        '--idx=[plugin index to register to NRI]:n:' \
        '--socket=[path to the plugin socket]:socket:_files' \
        '--verbose[enable verbose logging]'
}

_ulimit-adjuster "$@"
