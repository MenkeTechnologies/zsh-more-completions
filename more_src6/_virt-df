#compdef virt-df
# _virt-df — libguestfs virt-df (df(1)-like view of all guests on a host or a single VM image; -a disk, -d domain, -c URI, -h human-readable, --csv, --inodes report inodes, --one-per-guest skip per-fs lines, --uuid include UUID column; without arguments lists every libvirt domain known via -c URI)
# upstream: https://github.com/libguestfs/libguestfs (df)
# Flags from libguestfs df/df.ml on tip.

_virt-df() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '*-a+[disk image]:file:_files' \
        '*-d+[domain]:domain:' \
        '-c+[libvirt URI]:uri:' \
        '-h[human readable]' \
        '--csv[CSV output]' \
        '--inodes[report inodes]' \
        '--one-per-guest[one line per guest]' \
        '--uuid[include UUID]' \
        '--format=*[disk format]:fmt:(raw qcow2 vmdk vdi)'
}

_virt-df "$@"
