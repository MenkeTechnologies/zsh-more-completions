#compdef tpl
# Documentation: https://github.com/trealla-prolog/trealla
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-O0 --noopt)'{-O0,--noopt}'[no optimization]' \
  '-f[do not load .tplrc]' \
  '*-l+[load file]:file:_files -g "*.pl"' \
  '*-g+[query goal (only used once)]:goal' \
  '--library=[alternative to TPL_LIBRARY_PATH env var]:path:_files -/' \
  '(-t --trace)'{-t,--trace}'[trace]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode (no banner)]' \
  '(-d --daemonize)'{-d,--daemonize}'[daemonize]' \
  '(-w --watchdog)'{-w,--watchdog}'[create watchdog]' \
  '--autofail[autofail queries at the toplevel]' \
  '--consult[consult from STDIN]' \
  '*:Prolog source:_files -g "*.pl"'
