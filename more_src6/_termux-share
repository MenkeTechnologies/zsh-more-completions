#compdef termux-share
# Documentation: https://github.com/termux/termux-api-package/blob/master/scripts/termux-share.in
# Reference accessed: 2026-05-27
# Verified: upstream termux-api-package scripts/termux-share.in show_usage()/getopts.


# Share a file specified as argument or the text received on stdin if no file argument is given

_arguments \
  '-h[show this help]' \
  '-a+[which action to performed on the shared content\: edit/send/view (default\:view)]:action:' \
  '-c+[content-type to use (default\: guessed from file extension, text/plain for stdin)]:content-type:' \
  '-d[share to the default receiver if one is selected instead of showing a chooser]' \
  '-t+[title to use for shared content (default\: shared file name)]:title:'
