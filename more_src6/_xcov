#compdef xcov
# _xcov — xcov fastlane Xcode code-coverage HTML reporter (Ruby); part of fastlane suite
# upstream: https://github.com/nakiostudio/xcov

_xcov() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '-w+[xcworkspace]:file:_files -g "*.xcworkspace"' \
        '-p+[xcodeproj]:file:_files -g "*.xcodeproj"' \
        '-s+[scheme]:scheme:' \
        '-c+[configuration]:config:(Debug Release)' \
        '-D+[derived data dir]:dir:_files -/' \
        '-o+[output dir]:dir:_files -/' \
        '-t+[output types]:types:(html json markdown)' \
        '-m+[minimum coverage %]:n:' \
        '-i+[include targets]:globs:' \
        '-x+[exclude targets]:globs:' \
        '-r+[ignored files regex]:regex:' \
        '-J+[json scheme]:str:' \
        '--slack-url+[Slack webhook]:url:' \
        '--coveralls-service-name+[service]:str:' \
        '--coveralls-service-job-id+[job id]:str:' \
        '--coveralls-repo-token+[token]:str:' \
        '--skip-slack[skip Slack post]' \
        '--legacy-api[use legacy coverage API]'
}

_xcov "$@"
