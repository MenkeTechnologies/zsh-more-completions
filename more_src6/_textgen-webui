#compdef textgen
# _textgen-webui — text-generation-webui (oobabooga/text-generation-webui)
# upstream: https://github.com/oobabooga/text-generation-webui

_textgen-webui() {
    _arguments -s -S \
        '--model=[model name to load]:model:' \
        '--model-dir=[directory containing models]:dir:_directories' \
        '--lora=[LoRA adapter to apply]:lora:' \
        '--listen[listen on all interfaces]' \
        '--listen-port=[port to listen on]:port:' \
        '--listen-host=[host to listen on]:host:' \
        '--share[create a public Gradio URL]' \
        '--auto-launch[open browser on start]' \
        '--api[enable the API]' \
        '--api-port=[API port]:port:' \
        '--cpu[use CPU only]' \
        '--auto-devices[auto-select GPU/CPU split]' \
        '--gpu-memory=[GPU memory per device]:memory:' \
        '--cpu-memory=[CPU offload memory]:memory:' \
        '*--extensions=[extensions to load]:extension:' \
        '--chat[launch in chat mode]' \
        '--notebook[launch in notebook mode]' \
        '--verbose[increase verbosity]' \
        '--help[show help]'
}

_textgen-webui "$@"
