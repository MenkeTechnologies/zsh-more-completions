#compdef tolgee
# Documentation: https://docs.tolgee.io/tolgee-cli/usage
# Reference accessed: 2026-05-23
# Verified: Tolgee CLI global options and pull/push commands.

# Zsh completion for tolgee - Tolgee localization CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'pull:pull strings from Tolgee'
  'push:push strings to Tolgee'
  'login:save credentials'
  'logout:clear credentials'
  'extract:extract strings from code'
  'sync:sync with server'
  'compare:compare local and remote'
  'tag:tag keys'
  'delete:delete keys'
  'help:show help'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-au --api-url)'{-au+,--api-url=}'[Tolgee server URL]:url:_urls' \
  '(-ak --api-key)'{-ak+,--api-key=}'[API key]:key:' \
  '(-p --project-id)'{-p+,--project-id=}'[project id]:id:' \
  '(-b --branch)'{-b+,--branch=}'[project branch]:branch:' \
  '--format[file format]:format:' \
  '(-v --verbose)'{-v,--verbose}'[debug output]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'tolgee command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (pull)
        _arguments \
          '--path[output directory]:dir:_directories' \
          '--watch[watch for remote changes]' && ret=0
        ;;
      (push)
        _arguments \
          '(-f --force-mode)'{-f+,--force-mode=}'[conflict mode]:mode:(OVERRIDE KEEP NO_FORCE)' \
          '--files-template[files template]:template:' \
          '--remove-other-keys[remove keys not in import]' && ret=0
        ;;
      (*)
        _arguments '*::args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
