#compdef tikv-cdc-kafka-consumer
# _tikv-cdc-kafka-consumer — TiKV-CDC reference Kafka downstream consumer
# upstream: https://github.com/tikv/migration
# Flags from cdc/cmd/kafka-consumer/main.go on tip.

_tikv-cdc-kafka-consumer() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-upstream-uri=[upstream Kafka URI]:uri:' \
        '-downstream-uri=[downstream sink URI]:uri:' \
        '-log-file=[log file path]:file:_files' \
        '-log-level=[log level]:level:(debug info warn error)' \
        '-tz=[Kafka consumer time zone]:tz:' \
        '-ca=[Kafka CA cert file]:file:_files' \
        '-cert=[Kafka client cert file]:file:_files' \
        '-key=[Kafka client key file]:file:_files' \
        '-wait-topic=[duration to wait for topic creation]:dur:'
}

_tikv-cdc-kafka-consumer "$@"
