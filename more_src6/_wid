#compdef wid
# Documentation: https://github.com/lazToum/limen-os/blob/main/bin/wid
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (bin/wid usage block).

# Zsh completion for wid - WID/HLC-WID generator CLI

local curcontext="$curcontext" state line ret=1

local -a _wid_cmds
_wid_cmds=(
  'next:generate the next ID'
  'stream:emit a stream of IDs'
  'bench:run a benchmark'
  'validate:validate an ID'
  'healthcheck:print health info'
  'selftest:run selftest'
  'help-actions:print action matrix help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'wid command' _wid_cmds && ret=0
    ;;
  args)
    case $words[1] in
      next|stream|bench|healthcheck)
        _arguments \
          '--kind=[ID kind]:kind:(wid hlc)' \
          '--node=[node name]:name' \
          '--W=[W parameter]:n' \
          '--Z=[Z parameter]:n' \
          '--count=[count]:n' \
          '--time-unit=[time unit]:unit:(sec ms)' \
          '--json[JSON output (healthcheck)]' && ret=0
        ;;
      validate)
        _arguments \
          '1:id' \
          '--kind=[ID kind]:kind:(wid hlc)' \
          '--W=[W parameter]:n' \
          '--Z=[Z parameter]:n' \
          '--time-unit=[time unit]:unit:(sec ms)' && ret=0
        ;;
      selftest)
        _arguments \
          '--n=[number of IDs]:n' \
          '--procs=[parallel processes]:n' \
          '--per=[IDs per process]:n' \
          '--kind=[ID kind]:kind:(wid hlc)' \
          '--W=[W parameter]:n' \
          '--Z=[Z parameter]:n' && ret=0
        ;;
    esac
    ;;
esac

return ret
