#compdef xdg-settings
# _xdg-settings — XDG xdg-settings (read/write desktop-environment user defaults: default-web-browser, default-url-scheme-handler; get/check/set semantics, supports KDE/GNOME/Xfce backends)
# upstream: https://gitlab.freedesktop.org/xdg/xdg-utils
# Subcommands from xdg-utils scripts/xdg-settings.in on tip.

_xdg-settings() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--list[list known properties]' \
        '--manual[show full manual]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'xdg-settings command' '(get check set)' ;;
        args)
            _arguments \
                '1:property:(default-web-browser default-url-scheme-handler)' \
                '2:value:'
            ;;
    esac
}

_xdg-settings "$@"
