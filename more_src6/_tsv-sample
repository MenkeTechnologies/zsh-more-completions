#compdef tsv-sample
# Documentation: https://github.com/eBay/tsv-utils/blob/master/docs/tool_reference/tsv-sample.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-verbose[more detailed help]' \
  '(- *)--help-fields[help on specifying fields]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-H --header)'{-H,--header}'[treat first line as header]' \
  '(-n --num)'{-n,--num}'+[maximum number of lines to output]:count' \
  '(-p --prob)'{-p,--prob}'+[inclusion probability (0.0<NUM<=1.0)]:probability' \
  '(-k --key-fields)'{-k,--key-fields}'+[fields used as key for distinct sampling]:field-list' \
  '(-w --weight-field)'{-w,--weight-field}'+[field containing weights]:field' \
  '(-r --replace)'{-r,--replace}'[simple random sampling with replacement]' \
  '(-s --static-seed)'{-s,--static-seed}'[use the same random seed every run]' \
  '(-v --seed-value)'{-v,--seed-value}'+[set random seed via 32-bit positive integer]:seed' \
  '--print-random[output the random values that were assigned]' \
  '--gen-random-inorder[output all lines with assigned random values prepended]' \
  '--random-value-header=[header to use with print-random/gen-random-inorder]:header' \
  '--compatibility-mode[turn on compatibility mode]' \
  '(-d --delimiter)'{-d,--delimiter}'+[field delimiter]:char' \
  '--line-buffered[immediately output every sampled line]' \
  '--prefer-skip-sampling[prefer skip-sampling algorithm (diagnostics)]' \
  '--prefer-algorithm-r[prefer Algorithm R (diagnostics)]' \
  '*:file:_files' && return 0
