#compdef zstdzip
# ============================================================================
# zstdzip - ZSTD-compress files into the ZIP container
#            format with AES encryption (Go, MIT)
#
# Author : Harry Zhu (harryzhu)
# Upstream: https://github.com/harryzhu/zstdzip
#
# `zstdzip` is a Go CLI for creating + extracting ZIP
# archives that use ZSTD (instead of DEFLATE) as the
# entry compression method, with optional AES-GCM or
# AES-CTR encryption of each entry. The output is a
# `.zstd.zip` file - structurally a valid ZIP that any
# ZSTD-aware decompressor (7-Zip, libarchive, etc.) can
# read. The pitch is "faster than 7-Zip for typical
# multi-file mixed-content workloads" - ZSTD typically
# compresses 4-10x faster than DEFLATE at comparable
# ratio.
#
# Usage:
#   zstdzip <command> [flags]
#
# Commands (cobra Command tree):
#   zip                 - compress source files/dir into
#                          a .zstd.zip archive
#   unzip               - decompress a .zstd.zip archive
#                          into a target dir
#   hash                - compute a content hash of a file
#                          (blake3 / xxhash / md5 / sha1 /
#                          sha256)
#
# Persistent flags (all subcommands):
#   --source <path>     - source file or folder
#   --target <path>     - target file or folder
#   --password <pw>     - encryption / decryption password
#   --aes-method <m>    - AES mode: gcm or ctr
#                          (default gcm)
#   --serial            - sequential I/O optimization (set
#                          to false for SSDs) (default true)
#   --debug             - print debug info
#
# `zip` flags:
#   --level <0..3>      - ZSTD compression level (default 1)
#   --ignore-dot-file   - skip .DS_Store / .Thumb / ... -
#                          dotfiles (default true)
#   --ignore-empty-dir  - skip empty folders (default true)
#   --ext <regex>       - regex for file extensions
#                          (case-insensitive, e.g.
#                          .(mp4|txt|png))
#   --min-age <ts>      - skip files older than this
#                          timestamp (yyyy-MM-dd,HH:mm:ss)
#   --max-age <ts>      - skip files newer than this
#                          timestamp
#   --min-size <N>      - skip files smaller than N bytes
#                          (-1 = no min)
#   --max-size <N>      - skip files larger than N bytes
#                          (-1 = no max)
#
# `unzip` flags: same filter set as `zip`
#   --ext / --min-age / --max-age / --min-size / --max-size
#
# `hash` flags:
#   --sum <alg>         - hash algorithm: md5 / sha1 /
#                          sha256 / blake3 / xxhash
#                          (default sha256)
#
# The zeebo/blake3 lane is built on `github.com/zeebo/
# blake3 v0.2.4` (declared verbatim at upstream go.mod
# HEAD as a direct dep, imported from cmd/util.go as
# `case "blake3": hasher = blake3.New()`), the canonical
# Go BLAKE3 implementation by Jeff Wendling (zeebo) -
# github.com/zeebo/blake3, 700+ stars. Wendling is a
# founding engineer at Storj (content-addressed storage
# at multi-petabyte scale), so the library is battle-
# tested against very-large-content workloads where
# BLAKE3's SIMD-parallel throughput matters most.
#
# zeebo/blake3 includes hand-tuned assembly paths for
# AVX2 + AVX-512 + ARM NEON SIMD instructions, matching
# the BLAKE3-team reference C/assembly paths within ~95%
# of native throughput. The pure-Go fallback path is
# used when running on architectures without the assembly
# variants (e.g. RISC-V), maintaining cross-compile
# friendliness without sacrificing correctness.
#
# zstdzip uses `blake3.New()` to construct a streaming
# hasher in the `hash` subcommand's blake3 branch -
# parallel to its xxh3, md5, sha1, sha256 branches.
# The same source file gets compared against each
# selected algorithm's stream to produce the per-file
# digest.
#
# ----------------------------------------------------------------------------
# AXIS 245 :: BLAKE3 cryptographic hashing (SIMD-parallel
#              + tree-structured + verified-streaming)
# Round 1434 :: Go slot 2 of 4 :: continues Axis 245
#
# Cross-language canonical library family for this axis:
#   Rust    : BLAKE3-team/BLAKE3 (`blake3`) [R1433 _backdown]
#   Go      : zeebo/blake3                  [R1434 THIS FILE]
#   TS/Node : @node-rs/blake3               [R1435 closing]
#
# zeebo/blake3 is structurally interesting in this axis
# because of its *content-storage-engineer-authored*
# pattern. Unlike the Rust slot (BLAKE3-team/BLAKE3,
# written directly by the algorithm's inventors -
# O'Connor + Aumasson + Neves + Wilcox-O'Hearn) and the
# Node slot (@node-rs/blake3, a napi-rs wrapper around
# RustCrypto's separate-from-BLAKE3-team pure-Rust impl),
# the Go slot is written by a working storage engineer
# who chose BLAKE3 specifically for its real-world
# content-addressed-storage throughput characteristics.
#
# Wendling's hand-tuned AVX2 + AVX-512 + ARM NEON paths
# matter because Storj's content-addressed storage relies
# on BLAKE3 as the content-identifier function - every
# segment of every object in a multi-petabyte distributed
# store has to be hashed quickly enough that the hash
# computation isn't the bottleneck. zeebo/blake3's
# SIMD-tuned implementation hits within ~95% of native
# C/assembly throughput, which is the throughput floor
# needed for that use case.
#
# Cross-language interop at the hash-output level - 32
# bytes of BLAKE3 hash output from BLAKE3-team/BLAKE3 +
# zeebo/blake3 + @node-rs/blake3 are byte-identical for
# the same input, validated by the BLAKE3-team test
# vectors that all three implementations track.
# ============================================================================

_zstdzip() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '--source[source file or folder]:path:_files' \
        '--target[target file or folder]:path:_files' \
        '--password[encryption / decryption password]:password:' \
        '--aes-method[AES mode]:mode:(gcm ctr)' \
        '--serial[sequential I/O optimization (default true)]' \
        '--debug[print debug info]' \
        '(- *)'{-h,--help}'[print help]' \
        '1: :_zstdzip_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                zip)
                    _arguments \
                        '--level[ZSTD compression level (0-3, default 1)]:level:(0 1 2 3)' \
                        '--ignore-dot-file[skip dotfiles (default true)]' \
                        '--ignore-empty-dir[skip empty folders (default true)]' \
                        '--ext[regex for file extensions]:regex:' \
                        '--min-age[skip files older than ts (yyyy-MM-dd,HH:mm:ss)]:ts:' \
                        '--max-age[skip files newer than ts]:ts:' \
                        '--min-size[skip files smaller than N bytes]:N:' \
                        '--max-size[skip files larger than N bytes]:N:' \
                        '(- *)'{-h,--help}'[print subcommand help]'
                    ;;
                unzip)
                    _arguments \
                        '--ext[regex for file extensions]:regex:' \
                        '--min-age[skip files older than ts]:ts:' \
                        '--max-age[skip files newer than ts]:ts:' \
                        '--min-size[skip files smaller than N bytes]:N:' \
                        '--max-size[skip files larger than N bytes]:N:' \
                        '(- *)'{-h,--help}'[print subcommand help]'
                    ;;
                hash)
                    _arguments \
                        '--sum[hash algorithm]:alg:(md5 sha1 sha256 blake3 xxhash)' \
                        '(- *)'{-h,--help}'[print subcommand help]'
                    ;;
            esac
            ;;
    esac

    return ret
}

_zstdzip_cmds() {
    local -a cmds
    cmds=(
        'zip:compress source files/dir into a .zstd.zip archive'
        'unzip:decompress a .zstd.zip archive into a target dir'
        'hash:compute a content hash (blake3 / xxhash / md5 / sha1 / sha256)'
    )
    _describe -t commands 'zstdzip command' cmds
}

_zstdzip "$@"
