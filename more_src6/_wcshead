#compdef wcshead
# _wcshead — print WCS information from FITS image headers (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from wcshead.c (single-letter getopt-style).

_wcshead() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-d+[root directory for input files]:dir:_files -/' \
        '-h[hh:mm:ss output for CRVAL, CDELT]' \
        '-n+[decimal places]:n:' \
        '-r[print first dim as rest wavelength range]' \
        '-t[tab-table output]' \
        '-v[verbose]' \
        '-w[print first dim first/last value]' \
        '-z[use AIPS classic WCS]' \
        '-@+[file listing input filenames]:file:_files' \
        '*:FITS file:_files -g "*.(fits|fit|fts)"'
}

_wcshead "$@"
