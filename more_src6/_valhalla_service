#compdef valhalla_service
# Documentation: https://github.com/valhalla/valhalla
# Source: valhalla/valhalla src/valhalla_service.cc — Valhalla routing HTTP service / direct-request CLI.
# Reference accessed: 2026-06-10
#
# Usage:
#   valhalla_service CONFIG_JSON [CONCURRENCY]            # service mode
#   valhalla_service CONFIG_JSON ACTION JSON_REQUEST       # direct mode

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '1:config json:_files -g "*.json(-.)"' \
    '2:concurrency or action:(route locate optimized_route isochrone trace_route trace_attributes height transit_available expansion centroid status)' \
    '3:JSON request body:_default' \
    && ret=0

return ret
