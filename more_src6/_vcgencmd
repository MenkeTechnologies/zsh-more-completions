#compdef vcgencmd
# _vcgencmd — Raspberry Pi Foundation vcgencmd CLI for querying and controlling the Raspberry Pi VideoCore GPU runtime measure_temp measure_clock measure_volts get_throttled get_mem get_camera codec_enabled hdmi-status osd-version (raspberrypi team, C); custom argparse
# upstream: https://github.com/raspberrypi/userland

_vcgencmd() {
    local -a sub=(
        'measure_temp:show core temperature'
        'measure_clock:measure clock speed'
        'measure_volts:measure voltage'
        'get_throttled:show throttled status'
        'get_mem:show memory split'
        'get_camera:show camera status'
        'codec_enabled:show codec status'
        'hdmi_status_show:show HDMI status'
        'display_power:show or set display power'
        'osd_version:show OSD version'
        'version:show version info'
        'arm_out_of_memory:check ARM memory'
        'bootloader_version:show bootloader version'
        'bootloader_config:show bootloader config'
        'commands:list all commands'
        'cache_flush:flush cache'
        'mailbox:mailbox helpers'
        'mem_oom:check memory OOM'
        'mem_reloc_stats:show memory reloc stats'
        'firmware_revision:show firmware revision'
        'pmicrd:read PMIC register'
        'pmicwr:write PMIC register'
        'pmic_read_adc:read PMIC ADC'
        'cec_status:show CEC status'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vcgencmd subcommand' sub ;;
        args)
            case $words[1] in
                measure_clock) _arguments \
                    '*:clock:(arm core h264 isp v3d uart pwm emmc pixel vec hdmi dpi)' ;;
                measure_volts) _arguments \
                    '*:source:(core sdram_c sdram_i sdram_p)' ;;
                codec_enabled) _arguments \
                    '*:codec:(H264 MPG2 WVC1 MPG4 MJPG WMV9 PCM)' ;;
                display_power) _arguments \
                    '*:state:(0 1)' ;;
            esac
            ;;
    esac
}

_vcgencmd "$@"
