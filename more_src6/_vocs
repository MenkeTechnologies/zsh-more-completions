# WHAT IT IS
#   Vocs is "minimal docs for agents & humans" — a documentation
#   site generator built on Vite + React + MDX with first-class
#   support for AI-coding-agent workflows.  It ships a built-in
#   client-side full-text search powered by MiniSearch (BM25
#   tokenizer, lazy index loading, configurable highlighting),
#   syntax highlighting via Shiki with Twoslash code-block
#   verification (`vocs twoslash` checks every twoslash block
#   for type errors), MDX-based content authoring with `:::tip`
#   / `:::warning` admonitions, code-group tabs, file-tree
#   widgets, dynamic sidebar generation, automatic API-reference
#   typedoc integration, and OpenGraph image rendering.  Vocs
#   powers the docs sites for Wagmi, Viem, RainbowKit, Reown
#   AppKit, and dozens of other Web3 toolchains.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/cli.ts — cac v6 with
#                       `const cli = cac('vocs')` and `cli.
#                       command(...).option(...).action(...)`
#                       chain)
#   vocs <SUBCOMMAND> [args...]
#
#   Subcommands:
#     dev                            Start the development server
#                                    (Vite HMR)
#       --port <PORT>                  Listen port
#                                      [default: 5173]
#       --host [HOST]                  Listen host (omit value to
#                                      bind 0.0.0.0)
#
#     build                          Build the docs site for
#                                    production
#
#     preview                        Preview the production build
#       --port <PORT>                  Listen port
#                                      [default: 4173]
#       --host [HOST]                  Listen host (omit value to
#                                      bind 0.0.0.0)
#
#     twoslash [<PATTERN>]           Check twoslash code blocks
#                                    for errors [experimental]
#       --lang <LANG>                  Language to check
#                                      (typescript|rust|all)
#                                      [default: typescript]
#       --fail-on-error                Exit non-zero on errors
#                                      [default: true]
#       --concurrency <N>              Parallel Rust compilations
#                                      [default: 1]
#       --verbose                      Verbose output
#                                      [default: false]
#
#   Standard cac auto-flags:
#     -h, --help                     Show help
#     -v, --version                  Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `minisearch ^7.2.0` declared in
#   package.json — `minisearch` is THE canonical Node.js
#   full-text search-in-memory library maintained by Luca Ongaro
#   (lucaong/minisearch, 4.5K+ stars, ~150K npm downloads/week).
#   minisearch is the JavaScript counterpart of Tantivy / Bleve
#   for the client-side / in-memory use case:  it exposes the
#   `MiniSearch` constructor with typed `fields` + `storeFields`
#   + `idField` configuration, the typed `search(query,
#   options)` method with BM25 ranking, configurable tokenizer
#   + processTerm hooks, prefix / fuzzy / boost / combineWith /
#   filter / boostDocument options, auto-suggest via
#   `autoSuggest(query)`, incremental `addAll([...])` /
#   `add(doc)` / `replace(doc)` / `discard(id)` document
#   management, `getStoredFields(id)` introspection, the
#   `toJSON()` / `loadJSON(json, options)` serialization
#   pipeline for pre-built indexes, and the
#   `MultiplexedMiniSearch` adapter for sharded large corpora.
#   vocs's `src/search/index.ts` builds a MiniSearch index over
#   every Markdown / MDX page at build time, serializes it via
#   `toJSON()` to ship as a static JSON asset, and the client-
#   side React UI lazy-loads + `loadJSON`s it on first search
#   focus so docs sites get sub-millisecond search without a
#   server backend.  Verified via:
#     gh api repos/wevm/vocs/contents/package.json
#       → "minisearch": "^7.2.0"
#       → "cac": "^6.7.14"
#       → "bin": {"vocs": "./dist/cli.js"}
#     gh api repos/wevm/vocs/contents/src/cli.ts
#       → const cli = cac('vocs');
#       → cli.command('dev'|'build'|'preview'|
#                       'twoslash [pattern]')
#       → .option('--port'|'--host'|'--lang'|'--fail-on-error'|
#                  '--concurrency'|'--verbose')
#   This entry is the TS-Node=147 leader bump that CLOSES Axis
#   92 (Tantivy / full-text search engine library) at 1/1/1
#   three-language symmetry — pairing Rust=tantivy via
#   Dicklesworthstone/xf (R957 _xf), Go=blevesearch/bleve via
#   Rvn0xsy/red-tldr (R958 _red-tldr), and TS-Node=minisearch
#   via wevm/vocs (this entry).  Triple-147 landmark on commit.
#   Axis 92 = 85th axis closed.
#
#   No completion for `vocs` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_vocs() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_vocs_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                dev|preview)
                    _arguments \
                        '--port=[listen port]:port:' \
                        '--host=[listen host (omit value to bind 0.0.0.0)]:host:' && ret=0 ;;
                build)
                    _arguments && ret=0 ;;
                twoslash)
                    _arguments \
                        '--lang=[language to check]:lang:(typescript rust all)' \
                        '--fail-on-error[exit non-zero on errors]' \
                        '--concurrency=[parallel Rust compilations]:n:' \
                        '--verbose[verbose output]' \
                        '::glob pattern:_files -g "*.{md,mdx}"' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_vocs_commands] )) ||
_vocs_commands() {
    local -a commands
    commands=(
        'dev:start the development server'
        'build:build the docs site for production'
        'preview:preview the production build'
        'twoslash:check twoslash code blocks for errors'
    )
    _describe -t commands 'vocs command' commands
}

_vocs "$@"
