#compdef tiup-ctl
# _tiup-ctl — TiUP unified controller dispatcher (tidb/pd/tikv/binlog/etcd/cdc/tidb-lightning)
# upstream: https://github.com/pingcap/tiup
# Components from components/ctl/main.go on tip.

_tiup-ctl() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'tidb:dispatch to tidb-ctl'
                'pd:dispatch to pd-ctl'
                'tikv:dispatch to tikv-ctl'
                'binlog:dispatch to binlogctl'
                'etcd:dispatch to etcdctl'
                'cdc:dispatch to cdc cli'
                'tidb-lightning:dispatch to tidb-lightning-ctl'
            )
            _describe -t commands controller cmds
            ;;
    esac
}

_tiup-ctl "$@"
