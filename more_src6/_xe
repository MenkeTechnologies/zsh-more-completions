#compdef xe
# Documentation: https://github.com/leahneukirchen/xe
# Reference accessed: 2026-05-21
# Verified: upstream xe.1 man page. xargs-like simple command launcher.
# getopt string: +0A:FI:LN:Raf:j:npqs:v

local ret=1
_arguments -s -S \
  '-0[split stdin on NUL instead of newline]' \
  '-A+[argument separator string for -A mode]:sep:' \
  '-I+[replace string in command (default {})]:pattern:' \
  '-L[line-copy child for pipeline logging (repeat for prefix)]' \
  '-N+[max arguments per invocation]:n:' \
  '-R[pass unmatched patterns through instead of skipping]' \
  '-F[fail whole run if any job exits non-zero]' \
  '-a[read positional args after -- (or inline with -s)]' \
  '-f+[read args from file (use - for stdin)]:file:_files' \
  '-j+[parallel jobs (n, nx CPU fraction, or j=auto)]:jobspec:' \
  '-n[dry-run / print commands only]' \
  '-p[pattern dispatch mode (+ separates rule groups)]' \
  '-q[quote trace output]' \
  '-s+[shell script used with -p matches]:script:' \
  '-v[verbose trace (repeat for more)]' \
  '*::command:_normal' && ret=0
return ret
