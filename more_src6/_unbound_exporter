#compdef unbound_exporter
# _unbound_exporter — Unbound DNS metrics for Prometheus (letsencrypt/unbound_exporter)
# upstream: https://github.com/letsencrypt/unbound_exporter
# Flags from main.go (flag).

_unbound_exporter() {
    _arguments \
        '(- *)-h[show help]' \
        '-web.listen-address=[HTTP bind address]:addr:' \
        '-web.telemetry-path=[metrics URL path]:path:' \
        '-web.health-path=[healthcheck URL path]:path:' \
        '-unbound.host=[unix/tcp address of Unbound control socket]:addr:' \
        '-unbound.ca=[Unbound server cert]:file:_files -g "*.pem"' \
        '-unbound.cert=[Unbound client cert]:file:_files -g "*.pem"' \
        '-unbound.key=[Unbound client key]:file:_files -g "*.key"'
}

_unbound_exporter "$@"
