#compdef yabai
# Documentation: https://github.com/koekeishiya/yabai/blob/master/doc/yabai.1.asciidoc
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (yabai(1) OPTIONS section).
# Removed: --install-sa (not in man; only --uninstall-sa and --load-sa are
# documented), --check-sa (not in man).
# Fixed: -V/--verbose (was --verbose only), -v/--version (was --version only),
# -h/--help (was --help only).

_yabai() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-m --message)'{-m,--message}'[send message to running yabai instance]:domain:->domains' \
    '(-c --config)'{-c,--config}'[config file to use during startup]:file:_files' \
    '--uninstall-sa[uninstall scripting-addition (must run as root)]' \
    '--load-sa[load scripting-addition into Dock.app]' \
    '--install-service[install launchd service file to LaunchAgents]' \
    '--uninstall-service[remove launchd service file from LaunchAgents]' \
    '--start-service[enable, load, and start the launchd service]' \
    '--restart-service[restart the currently running service instance]' \
    '--stop-service[stop and unload an active service instance]' \
    '(-V --verbose)'{-V,--verbose}'[output debugging details to stdout]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '(-h --help)'{-h,--help}'[show help]'

  case $state in
    domains)
      local -a domains=(
        'config:Configure settings'
        'display:Manage displays'
        'space:Manage spaces'
        'window:Manage windows'
        'query:Query info'
        'rule:Manage rules'
        'signal:Manage signals'
      )
      _describe 'domain' domains
      # Could add more detailed sub-completion per domain but the
      # message syntax is complex (e.g. --space 2 --toggle float)
      ;;
  esac
}

_yabai "$@"
