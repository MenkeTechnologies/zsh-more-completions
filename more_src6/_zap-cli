#compdef zap-cli zap-baseline-cli zap-active-scan
# _zap-cli — Adam Pridgen Greynoise zap-cli CLI Python command-line wrapper around the OWASP ZAP Zed Attack Proxy Java application for automated security scans launching active spider passive scan ajax-spider crawling exploring quick-scan output session-state context configuration for CI integration vulnerability assessment (Adam Pridgen team, Python); click
# upstream: https://github.com/Grunny/zap-cli

_zap-cli() {
    local -a sub=(
        'start:start zap daemon'
        'shutdown:shutdown zap daemon'
        'status:show daemon status'
        'session:session management'
        'context:context management'
        'open-url:open URL in zap'
        'spider:run spider'
        'ajax-spider:run AJAX spider'
        'active-scan:run active scan'
        'alerts:list alerts'
        'quick-scan:run quick scan'
        'scripts:scripts management'
        'report:generate report'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-z+[zap port]:n:' \
        '--zap-port=+[port]:n:' \
        '-p+[zap path]:dir:_files -/' \
        '--zap-path=+[dir]:dir:_files -/' \
        '--api-key=+[key]:str:' \
        '-l+[log level]:l:(DEBUG INFO WARN ERROR CRITICAL)' \
        '--log-level=+[level]:l:(DEBUG INFO WARN ERROR CRITICAL)' \
        '--port=+[port]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zap-cli subcommand' sub ;;
        args)
            case $words[1] in
                open-url|spider|ajax-spider|active-scan|quick-scan) _arguments '*:url:' ;;
                report) _arguments \
                    '-o+[output]:file:_files' \
                    '-f+[format]:f:(html xml json)' ;;
            esac
            ;;
    esac
}

_zap-cli "$@"
