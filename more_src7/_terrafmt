#compdef terrafmt

# Zsh completion for terrafmt - format Terraform code blocks in documentation files

_terrafmt() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'fmt:format Terraform blocks in files'
    'diff:show formatting differences'
    'blocks:extract Terraform blocks from files'
    'upgrade012:upgrade Terraform blocks to 0.12 syntax'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*::arg:->args' \
    && ret=0

  case $state in
    command)
      _describe -t commands 'terrafmt command' commands && ret=0
      ;;
    args)
      case ${words[1]} in
        fmt)
          _arguments \
            '-f[format compatibility mode]' \
            '--check[check if files are formatted without modifying]' \
            '--verbose[show verbose output]' \
            '--diff[show diff of formatting changes]' \
            '--pattern=[file glob pattern]:pattern:' \
            '*:file:_files' \
            && ret=0
          ;;
        diff)
          _arguments \
            '--check[exit with error if differences found]' \
            '--verbose[show verbose output]' \
            '--pattern=[file glob pattern]:pattern:' \
            '*:file:_files' \
            && ret=0
          ;;
        blocks)
          _arguments \
            '--verbose[show verbose output]' \
            '--pattern=[file glob pattern]:pattern:' \
            '*:file:_files' \
            && ret=0
          ;;
        upgrade012)
          _arguments \
            '--verbose[show verbose output]' \
            '--pattern=[file glob pattern]:pattern:' \
            '*:file:_files' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_terrafmt "$@"
