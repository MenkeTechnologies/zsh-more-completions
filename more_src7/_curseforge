#compdef curseforge

_curseforge() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'search:search for mods'
    'install:install a mod'
    'update:update installed mods'
    'remove:remove a mod'
    'list:list installed mods'
    'info:show mod information'
    'export:export modpack'
    'import:import modpack'
  )

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1:command:->command' \
    '*::arg:->args' \
    && ret=0

  case $state in
    command)
      _describe -t commands 'curseforge command' commands && ret=0
      ;;
    args)
      case ${words[1]} in
        search)
          _arguments \
            '--game[game filter]:game:(minecraft)' \
            '--category[category filter]:category:' \
            '*:search query:' \
            && ret=0
          ;;
        install|remove|info|update)
          _arguments '*:mod name or ID:' && ret=0
          ;;
        export)
          _arguments '-o[output file]:file:_files' && ret=0
          ;;
        import)
          _arguments '1:modpack file:_files -g "*.zip"' && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_curseforge "$@"
