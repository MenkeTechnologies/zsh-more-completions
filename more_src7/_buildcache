#compdef buildcache

# Zsh completion for buildcache - compiler cache tool

_buildcache() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '-s[show cache statistics]' \
    '-z[zero cache statistics]' \
    '-C[clear the cache]' \
    '-c[set max cache size]:max cache size:' \
    '--accuracy=[cache accuracy level]:accuracy:(strict default sloppy)' \
    '--compress[enable cache compression]' \
    '--remote=[remote cache server URL]:URL:_urls' \
    '--debug[enable debug output]' \
    '--dir=[set cache directory]:directory:_directories' \
    '--help[show help]' \
    '--version[show version]' \
    '*:compiler arguments:_files' \
    && ret=0

  return ret
}

_buildcache "$@"
