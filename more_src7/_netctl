#compdef netctl

# Zsh completion for netctl - Arch Linux network management

_netctl_profiles() {
  local -a profiles
  profiles=( /etc/netctl/*~*.conf(N:t) )
  _describe -t profiles 'network profile' profiles
}

_netctl() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'list:list available profiles'
    'store:store which profiles are active'
    'restore:restore previously stored profiles'
    'stop-all:stop all active profiles'
    'start:start a network profile'
    'stop:stop a network profile'
    'restart:restart a network profile'
    'switch-to:switch to a network profile'
    'status:show profile status'
    'enable:enable a profile for automatic starting'
    'disable:disable a profile from automatic starting'
    'reenable:reenable a profile'
    'is-enabled:check if a profile is enabled'
    'edit:edit a profile'
    'wait-online:wait until the network is online'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*::arg:->args' \
    && ret=0

  case $state in
    command)
      _describe -t commands 'netctl command' commands && ret=0
      ;;
    args)
      case ${words[1]} in
        start|stop|restart|switch-to|status|enable|disable|reenable|is-enabled|edit)
          _arguments '1:profile:_netctl_profiles' && ret=0
          ;;
        wait-online)
          _arguments \
            '--timeout[timeout in seconds]:seconds:' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_netctl "$@"
