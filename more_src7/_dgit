#compdef dgit

_dgit() {
    local context state line
    typeset -A opt_args

    _arguments -C \
        '--no-hierarchical[disable hierarchical suite resolution]' \
        '-p[specify package name]:package name:' \
        '--clean[specify clean mode]:clean mode:(git dpkg-source check none)' \
        '--quilt[specify quilt mode]:quilt mode:(linear gbp dpm nofix smash nocheck)' \
        '-C[specify changes file]:changes file:_files -g "*.changes"' \
        '--build-products-dir[directory for build products]:directory:_directories' \
        '-k[specify GPG key ID]:key ID:' \
        '-d[specify distribution]:distribution:' \
        '1: :->cmd' \
        '*::arg:->args'

    case $state in
        cmd)
            local -a commands=(
                'clone:clone a package from the archive'
                'fetch:fetch updates from the archive'
                'pull:fetch and merge from the archive'
                'build:build the package'
                'sbuild:build with sbuild'
                'push:push to the archive'
                'push-source:push source to the archive'
                'rpush:push via remote system'
                'build-source:build source package'
                'clean:clean the build tree'
                'quilt-fixup:fix up quilt patches'
                'import-dsc:import a .dsc file'
                'setup-mergechangelogs:configure git mergechangelogs'
                'setup-useremail:configure git user email from DEBEMAIL'
                'setup-gitattributes:configure git attributes'
                'setup-new-tree:set up a new packaging tree'
            )
            _describe -t commands 'dgit command' commands
            ;;
        args)
            case ${words[1]} in
                clone)
                    _arguments \
                        '1:package name:' \
                        '2::directory:_directories'
                    ;;
                import-dsc)
                    _arguments '1:dsc file:_files -g "*.dsc"'
                    ;;
            esac
            ;;
    esac
}

_dgit "$@"
