#compdef mumble

_mumble() {
    local context state line
    typeset -A opt_args
    _arguments -s \
        '(-m --multiple)'{-m,--multiple}'[allow multiple instances]' \
        '(-n --noidentity)'{-n,--noidentity}'[suppress loading of identity files]' \
        '--license[show license]' \
        '--authors[show authors]' \
        '--third-party-licenses[show third-party licenses]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-h --help)'{-h,--help}'[show help]' \
        '--suppress-identity-prompt[suppress certificate identity prompt]' \
        '--rpc[specify RPC socket]:socket path:_files' \
        '*:server URL:'
}

_mumble "$@"
