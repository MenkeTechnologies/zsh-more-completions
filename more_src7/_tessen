#compdef tessen

_tessen() {
    local context state line
    typeset -A opt_args
    _arguments -s \
        '(-h --help)'{-h,--help}'[show help message]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '(-a --action)'{-a,--action}'[specify action]:action:(autotype copy both)' \
        '(-b --backend)'{-b,--backend}'[specify backend]:backend:(bemenu dmenu fuzzel rofi tofi wofi)' \
        '(-c --config)'{-c,--config}'[specify config file]:config file:_files' \
        '(-d --dmenu)'{-d,--dmenu}'[custom dmenu command]:command:' \
        '(-p --pass)'{-p,--pass}'[password store backend]:backend:(pass gopass)'
}

_tessen "$@"
