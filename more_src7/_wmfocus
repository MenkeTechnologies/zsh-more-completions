#compdef wmfocus

_wmfocus() {
    local context state line
    typeset -A opt_args

    _arguments -s \
        '(- *)'{-h,--help}'[show help message]' \
        '(-f --font)'{-f,--font}'[set font]:font' \
        '(-c --chars)'{-c,--chars}'[set characters to use for hints]:characters' \
        '--bgcolor[set background color]:color' \
        '--textcolor[set text color]:color' \
        '--textcolorinactive[set text color for inactive windows]:color' \
        '--textcolorcurrent[set text color for current window]:color' \
        '--offset[set hint offset]:x,y' \
        '--halign[set horizontal alignment]:alignment:(left center right)' \
        '--valign[set vertical alignment]:alignment:(top center bottom)' \
        '--margin[set margin around hint]:margin' \
        '--print-only[print selected window ID only]'
}

_wmfocus "$@"
