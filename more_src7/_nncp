#compdef nncp-xfer nncp-call nncp-daemon nncp-toss nncp-file nncp-freq nncp-exec nncp-bundle

_nncp() {
    local context state line
    typeset -A opt_args

    local -a common_flags=(
        '-node[specify node]:node ID:'
        '-nice[set niceness level]:nice level:'
        '-spool[specify spool directory]:spool dir:_directories'
        '-log[specify log file]:log file:_files'
        '-debug[enable debug output]'
        '-quiet[suppress output]'
        '-progress[show progress]'
        '-cfg[specify config file]:config file:_files'
    )

    case ${service} in
        nncp-xfer)
            _arguments -s \
                "${common_flags[@]}" \
                '-rx[receive only]' \
                '-tx[transmit only]' \
                '-keep[do not remove transferred files]' \
                '1:exchange directory:_directories'
            ;;
        nncp-call)
            _arguments -s \
                "${common_flags[@]}" \
                '-rx[receive only]' \
                '-tx[transmit only]' \
                '-onlinedeadline[online deadline]:seconds:' \
                '-maxonlinetime[max online time]:seconds:' \
                '1:node ID:'
            ;;
        nncp-daemon)
            _arguments -s \
                "${common_flags[@]}" \
                '-bind[bind address]:address:'
            ;;
        nncp-toss)
            _arguments -s \
                "${common_flags[@]}" \
                '-cycle[roles cycle interval]:seconds:'
            ;;
        nncp-file)
            _arguments -s \
                "${common_flags[@]}" \
                '1:source file:_files' \
                '2:node\:destination:'
            ;;
        nncp-freq)
            _arguments -s \
                "${common_flags[@]}" \
                '1:node\:source:' \
                '2:destination file:_files'
            ;;
        nncp-exec)
            _arguments -s \
                "${common_flags[@]}" \
                '1:node ID:' \
                '2:command:' \
                '*:arguments:'
            ;;
        nncp-bundle)
            _arguments -s \
                "${common_flags[@]}" \
                '-rx[receive mode]' \
                '-tx[transmit mode]' \
                '-delete[delete after bundling]'
            ;;
        *)
            _arguments -s "${common_flags[@]}"
            ;;
    esac
}

_nncp "$@"
