#compdef wonder-shaper

# Zsh completion for wonder-shaper - bandwidth limiter using tc

_wonder-shaper() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '-a[network adapter]:adapter:_net_interfaces' \
    '-d[download rate limit in Kbps]:download rate (Kbps):' \
    '-u[upload rate limit in Kbps]:upload rate (Kbps):' \
    '-c[clear limits]' \
    '-s[show current status]' \
    '-h[show help]' \
    '-v[show version]' \
    && ret=0

  return ret
}

_wonder-shaper "$@"
