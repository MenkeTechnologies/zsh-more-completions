#compdef ptunnel-ng

_ptunnel-ng() {
    local context state line
    typeset -A opt_args
    _arguments -s \
        '-p[specify proxy address]:proxy address:_hosts' \
        '-lp[local listen port]:port:' \
        '-da[destination address]:destination address:_hosts' \
        '-dp[destination port]:port:' \
        '-r[run as relay]' \
        '-R[remote port]:port:' \
        '-v[verbosity level]:level:(0 1 2 3 4 5)' \
        '-P[set tunnel password]:password:' \
        '-u[run in unprivileged mode]' \
        '-s[print statistics]' \
        '-e[max concurrent tunnels]:number:' \
        '-setuid[set UID after start]:user:_users' \
        '-setgid[set GID after start]:group:_groups' \
        '-chroot[chroot to directory]:directory:_directories'
}

_ptunnel-ng "$@"
