#compdef kdocker

_kdocker() {
    local context state line
    typeset -A opt_args
    _arguments -s \
        '-b[do not show balloon notifications]' \
        '-d[timeout in seconds before docking]:timeout (seconds):' \
        '-f[dock when focus is lost]' \
        '-i[custom tray icon]:icon file:_files -g "*.{png,xpm,svg}"' \
        '-l[lazy docking - wait for window to appear]' \
        '-m[skip taskbar]' \
        '-n[custom name for the docked window]:name:' \
        '-o[iconify on minimize]' \
        '-p[set tray icon position]:position:' \
        '-q[disable popup menu]' \
        '-r[skip pager]' \
        '-s[make window sticky]' \
        '-t[do not close to tray]' \
        '-w[dock window by window ID]:window ID:' \
        '-x[dock window by class name]:window class:' \
        '*:command:_command_names -e'
}

_kdocker "$@"
