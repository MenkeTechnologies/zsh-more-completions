#compdef nzbget

_nzbget() {
    local context state line
    typeset -A opt_args

    _arguments -s \
        '(-s --server)'{-s,--server}'[start as server]' \
        '(-D --daemon)'{-D,--daemon}'[start as daemon]' \
        '(-c --configfile)'{-c,--configfile}'[specify configuration file]:config file:_files' \
        '(-n --noconfigfile)'{-n,--noconfigfile}'[do not use configuration file]' \
        '*'{-o,--option}'[set option]:option=value' \
        '(-A --append)'{-A,--append}'[add file to download queue]:NZB file:_files -g "*.nzb"' \
        '(-C --connect)'{-C,--connect}'[connect to server]' \
        '(-L --list)'{-L,--list}'[list files in download queue]' \
        '(-P --pause)'{-P,--pause}'[pause download]' \
        '(-U --unpause)'{-U,--unpause}'[resume download]' \
        '(-R --rate)'{-R,--rate}'[set download rate limit]:rate' \
        '(-G --log)'{-G,--log}'[show log]:lines' \
        '(-T --top)'{-T,--top}'[add file to top of download queue]' \
        '(-K --scan)'{-K,--scan}'[scan incoming directory]' \
        '(-V --version)'{-V,--version}'[display version]' \
        '(-E --edit)'{-E,--edit}'[edit download queue]' \
        '--reload[reload server]'
}

_nzbget "$@"
