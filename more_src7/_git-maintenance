#compdef git-maintenance

_git-maintenance() {
    local context state line
    typeset -A opt_args

    _arguments -C \
        '--auto[run tasks based on heuristics]' \
        '--quiet[suppress output]' \
        '*--task[specify maintenance task]:task:(commit-graph prefetch gc loose-objects incremental-repack pack-refs)' \
        '--schedule[specify schedule frequency]:schedule:(hourly daily weekly)' \
        '1: :->cmd'

    case $state in
        cmd)
            local -a commands=(
                'register:register the repository for maintenance'
                'run:run maintenance tasks'
                'start:start background maintenance'
                'stop:stop background maintenance'
                'unregister:unregister the repository from maintenance'
            )
            _describe -t commands 'git maintenance command' commands
            ;;
    esac
}

_git-maintenance "$@"
