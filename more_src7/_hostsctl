#compdef hostsctl

# Zsh completion for hostsctl - /etc/hosts manager CLI

_hostsctl() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'add:add a host entry'
    'remove:remove a host entry'
    'list:list host entries'
    'enable:enable a disabled host entry'
    'disable:disable a host entry'
    'merge:merge hosts from a file'
    'export:export hosts to a file'
    'fetch:fetch hosts from a remote source'
    'restore:restore hosts file from backup'
    'update:update hosts from configured sources'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*::arg:->args' \
    && ret=0

  case $state in
    command)
      _describe -t commands 'hostsctl command' commands && ret=0
      ;;
    args)
      case ${words[1]} in
        add)
          _arguments \
            '1:hostname:' \
            '2:IP address:' \
            && ret=0
          ;;
        remove|enable|disable)
          _arguments \
            '1:hostname:' \
            && ret=0
          ;;
        merge|export)
          _arguments \
            '1:file:_files' \
            && ret=0
          ;;
        fetch)
          _arguments \
            '1:URL:_urls' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_hostsctl "$@"
