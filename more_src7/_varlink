#compdef varlink

# Zsh completion for varlink - IPC protocol CLI tool

_varlink() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'call:call a method'
    'help:show interface description'
    'info:show service information'
    'resolve:resolve an interface name'
    'bridge:bridge varlink connections'
    'format:format a varlink interface file'
    'completion:output shell completion code'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*::arg:->args' \
    && ret=0

  case $state in
    command)
      _describe -t commands 'varlink command' commands && ret=0
      ;;
    args)
      case ${words[1]} in
        call)
          _arguments \
            '1:method (address/interface.method):' \
            '2:parameters (JSON):' \
            && ret=0
          ;;
        help|info)
          _arguments \
            '1:address or interface:' \
            && ret=0
          ;;
        resolve)
          _arguments \
            '1:interface name:' \
            && ret=0
          ;;
        format)
          _arguments \
            '1:varlink interface file:_files' \
            && ret=0
          ;;
        completion)
          _arguments \
            '1:shell:(bash zsh fish)' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_varlink "$@"
