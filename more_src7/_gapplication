#compdef gapplication

# Zsh completion for gapplication - GNOME GIO application launcher

_gapplication() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'list-apps:list installed applications'
    'launch:launch an application'
    'action:activate an application action'
    'list-actions:list available actions for an application'
    'help:show help'
    'version:show version'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*::arg:->args' \
    && ret=0

  case $state in
    command)
      _describe -t commands 'gapplication command' commands && ret=0
      ;;
    args)
      case ${words[1]} in
        launch)
          _arguments \
            '1:application ID:' \
            '*:file:_files' \
            && ret=0
          ;;
        action)
          _arguments \
            '1:application ID:' \
            '2:action name:' \
            '3:parameter:' \
            && ret=0
          ;;
        list-actions)
          _arguments \
            '1:application ID:' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_gapplication "$@"
