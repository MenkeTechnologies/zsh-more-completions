#compdef sysprof-cli

_sysprof-cli() {
    local context state line
    typeset -A opt_args
    _arguments -s \
        '(-c --command)'{-c,--command}'[run command and profile it]:command:_command_names -e' \
        '(-p --pid)'{-p,--pid}'[profile existing process]:pid:_pids' \
        '--no-battery[disable battery profiling]' \
        '--no-cpu[disable CPU profiling]' \
        '--no-memory[disable memory profiling]' \
        '--no-network[disable network profiling]' \
        '--no-perf[disable perf profiling]' \
        '--no-disk[disable disk profiling]' \
        '(-d --duration)'{-d,--duration}'[set capture duration in seconds]:seconds:' \
        '(-f --force)'{-f,--force}'[overwrite output file]' \
        '--power[record power usage]' \
        '--aid[specify aid]:aid:' \
        '1::output file:_files -g "*.syscap"'
}

_sysprof-cli "$@"
