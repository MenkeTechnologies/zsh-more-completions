#compdef znapzend

_znapzend() {
    local context state line
    typeset -A opt_args
    _arguments \
        '--daemonize[run as daemon]' \
        '--debug[enable debug output]' \
        '--features[list supported features]:features' \
        '--logto[log destination]:log destination:(syslog stdout /path/to/logfile)' \
        '--loglevel[set log level]:log level:(debug info warning error fatal)' \
        '--noaction[dry run, do not actually perform actions]' \
        '--nodelay[do not delay the start of backups]' \
        '--runonce[run once then exit]:dataset' \
        '--since[only process snapshots since this time]:time' \
        '--inherited[also process inherited backup configurations]' \
        '--pidfile[write PID to file]:pid file:_files' \
        '--connectTimeout[SSH connection timeout in seconds]:seconds' \
        '--autoCreation[automatically create destination datasets]' \
        '--help[show help]'
}

_znapzend "$@"
