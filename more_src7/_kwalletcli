#compdef kwalletcli

_kwalletcli() {
    local context state line
    typeset -A opt_args
    _arguments -s \
        '-e[entry name]:entry name:' \
        '-f[folder name]:folder name:' \
        '-P[use password folder]' \
        '-a[application ID]:app ID:' \
        '-v[verbose output]' \
        '-q[quiet output]' \
        '-h[show help]'
}

_kwalletcli "$@"
