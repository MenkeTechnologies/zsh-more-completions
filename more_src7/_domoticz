#compdef domoticz

_domoticz() {
    local context state line
    typeset -A opt_args

    _arguments -s \
        '-www[set HTTP port]:port' \
        '-sslwww[set HTTPS port]:port' \
        '-wwwroot[set web root directory]:web root:_directories' \
        '-dbase[set database file]:database file:_files' \
        '-wwwbind[set bind address]:address' \
        '-sslcert[set SSL certificate file]:certificate file:_files' \
        '-sslkey[set SSL private key file]:key file:_files' \
        '-log[set log file]:log file:_files' \
        '-loglevel[set log level]:level:(0 1 2 3 4)' \
        '-nocache[disable static file caching]' \
        '-approot[set application root directory]:app root:_directories' \
        '-startupdelay[set startup delay in seconds]:seconds' \
        '-nowwwpwd[disable web authentication]' \
        '-pidfile[set PID file]:PID file:_files' \
        '-daemon[run as daemon]' \
        '-syslog[log to syslog]' \
        '-userdata[set user data directory]:data directory:_directories' \
        '-verbose[enable verbose output]'
}

_domoticz "$@"
