#compdef tnef

# Zsh completion for tnef - extract attachments from MS-TNEF (winmail.dat) files

_tnef() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '-f[input TNEF file]:file:_files' \
    '-C[extract files to directory]:directory:_directories' \
    '-t[list attachment information]' \
    '--list[list attachment information]' \
    '-v[verbose output]' \
    '-w[overwrite existing files]' \
    '--save-rtf[save RTF body to file]:file:_files' \
    '--save-body[save message body]:file:_files' \
    '--number-backups[use numbered backup files]' \
    '-x[extract only attachments of given size]:size:' \
    '--ignore-checksum[ignore checksum errors]' \
    '--help[show help message]' \
    '--version[show version information]' \
    '*:TNEF file:_files -g "*.tnef|winmail.dat"' \
    && ret=0

  return ret
}

_tnef "$@"
