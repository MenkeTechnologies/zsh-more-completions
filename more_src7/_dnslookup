#compdef dnslookup

# Zsh completion for dnslookup - DNS lookup tool by AdGuard

_dnslookup() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '--tls-server-name[TLS server name for authentication]:server name:' \
    '--tls-min-version[minimum TLS version]:version:(1.0 1.1 1.2 1.3)' \
    '--tls-max-version[maximum TLS version]:version:(1.0 1.1 1.2 1.3)' \
    '--https[use DNS-over-HTTPS]' \
    '--tls[use DNS-over-TLS]' \
    '--quic[use DNS-over-QUIC]' \
    '--dnscrypt[use DNSCrypt]' \
    '--ecs[send EDNS Client Subnet option]:subnet:' \
    '--subnet[set EDNS Client Subnet]:subnet:' \
    '--edns-version[set EDNS version]:version:' \
    '--type[query type]:type:(A AAAA CNAME MX NS PTR SOA SRV TXT CAA DNSKEY DS HTTPS SVCB TLSA)' \
    '--class[query class]:class:(IN CH HS)' \
    '--pad[enable EDNS padding]' \
    '--no-verify[disable TLS certificate verification]' \
    '--timeout[query timeout]:timeout:' \
    '--verbose[enable verbose output]' \
    '1:domain name:' \
    '2:server address:' \
    && ret=0

  return ret
}

_dnslookup "$@"
