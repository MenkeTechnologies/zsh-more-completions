#compdef proton

_proton() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'run:run a Windows executable'
    'waitforexitandrun:wait for wineserver to exit then run'
    'runinprefix:run in existing prefix'
    'destroyprefix:destroy the Wine prefix'
    'getcompatpath:get compatibility path for a Windows path'
    'getnativepath:get native path for a Windows path'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*::arg:->args' \
    && ret=0

  case $state in
    command)
      _describe -t commands 'proton command' commands && ret=0
      ;;
    args)
      _arguments '*:file:_files' && ret=0
      ;;
  esac

  return ret
}

_proton "$@"
