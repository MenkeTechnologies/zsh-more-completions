#compdef uvcdynctrl

_uvcdynctrl() {
    local context state line
    typeset -A opt_args

    _arguments -s \
        '(-d --device)'{-d,--device}'[specify video device]:device:_files -W /dev -g "video*"' \
        '(-l --list)'{-l,--list}'[list available controls]' \
        '(-g --get)'{-g,--get}'[get control value]:control name' \
        '(-s --set)'{-s,--set}'[set control value]:control name' \
        '(-f --format)'{-f,--format}'[list available formats]' \
        '(-i --import)'{-i,--import}'[import control definitions from XML]:XML file:_files -g "*.xml"' \
        '(-e --export)'{-e,--export}'[export control definitions to XML]:XML file:_files -g "*.xml"' \
        '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
        '(-c --clist)'{-c,--clist}'[list available controls with details]' \
        '(- *)'{-h,--help}'[show help message]'
}

_uvcdynctrl "$@"
