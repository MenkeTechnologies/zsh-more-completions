#compdef sonata

_sonata() {
    local context state line
    typeset -A opt_args
    _arguments -s \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '(-p --profile)'{-p,--profile}'[specify profile number]:profile number:' \
        '(-d --debug)'{-d,--debug}'[enable debug output]' \
        '--visible[start with visible window]' \
        '--hidden[start hidden in system tray]'
}

_sonata "$@"
