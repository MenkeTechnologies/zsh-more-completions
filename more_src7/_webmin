#compdef webmin

_webmin() {
    local -a commands
    commands=(
        'start:start Webmin service'
        'stop:stop Webmin service'
        'restart:restart Webmin service'
        'status:show Webmin service status'
    )

    _arguments \
        '1: :->cmd'

    case $state in
        cmd)
            _describe -t commands 'webmin command' commands
            ;;
    esac
}

_webmin "$@"
