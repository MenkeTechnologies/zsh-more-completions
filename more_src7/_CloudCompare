#compdef CloudCompare

_CloudCompare() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '-o[open file]:file:_files' \
    '-LOG_FILE[log to file]:log file:_files' \
    '-SILENT[suppress dialogs]' \
    '-AUTO_SAVE[auto-save results]:toggle:(ON OFF)' \
    '-C_EXPORT_FMT[cloud export format]:format:(ASC BIN PLY LAS LAZ E57 VTK PCD PV SHP)' \
    '-M_EXPORT_FMT[mesh export format]:format:(BIN PLY OBJ STL VTK OFF FBX)' \
    '-COMPUTE_NORMALS[compute normals]' \
    '-SS[subsample]:method:(RANDOM SPATIAL OCTREE)' \
    '-MERGE_CLOUDS[merge loaded clouds]' \
    '-ICP[perform ICP registration]' \
    '-CROP[crop to bounding box]:bbox:' \
    '-CROSS_SECTION[cross section]' \
    '-RASTERIZE[rasterize point cloud]' \
    '-FILTER_SF[filter by scalar field]' \
    '-DENSITY[compute density]:type:(KNN SURFACE VOLUME)' \
    '-CURV[compute curvature]:type:(GAUSS MEAN NORMAL_CHANGE)' \
    '-ROUGH[compute roughness]:kernel size:' \
    '-EXTRACT_CC[extract connected components]' \
    '-OCTREE_NORMALS[compute normals via octree]:radius:' \
    '-ORIENT_NORMS_MST[orient normals using MST]:knn:' \
    '-SAMPLE_MESH[sample points on mesh]:method:(DENSITY POINTS)' \
    '-STAT_TEST[statistical outlier removal]' \
    '-SOR[SOR filter]:knn:' \
    '-DELAUNAY[Delaunay triangulation]' \
    '*:input file:_files' \
    && ret=0

  return ret
}

_CloudCompare "$@"
