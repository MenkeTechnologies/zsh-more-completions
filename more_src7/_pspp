#compdef pspp

_pspp() {
    local context state line
    typeset -A opt_args

    _arguments -s \
        '(- *)--help[display help]' \
        '(- *)--version[display version]' \
        '*'{-o,--output}'[set output file]:output file:_files' \
        '*'{-O,--option}'[set output option]:option' \
        '*'{-I,--include}'[add include path]:include path:_directories' \
        '(-b --batch -i --interactive)'{-b,--batch}'[use batch mode]' \
        '(-i --interactive -b --batch)'{-i,--interactive}'[use interactive mode]' \
        '(-r --no-statrc)'{-r,--no-statrc}'[do not execute .pspp startup file]' \
        '(-s --safer)'{-s,--safer}'[do not allow unsafe operations]' \
        '(-e --error-file)'{-e,--error-file}'[send error messages to file]:error file:_files' \
        '--syntax[set syntax mode]:syntax mode:(compatible enhanced auto)' \
        '(-a --algorithm)'{-a,--algorithm}'[set algorithm compatibility]:algorithm:(compatible enhanced)' \
        '--testing-mode[enable testing mode]' \
        '*:syntax file:_files -g "*.sps"'
}

_pspp "$@"
