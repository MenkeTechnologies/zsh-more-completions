#compdef gokey

_gokey() {
    local context state line
    typeset -A opt_args

    _arguments -s \
        '-p[master password]:password' \
        '-r[realm (identifier for the key)]:realm' \
        '-l[output key length]:length' \
        '-s[seed file path]:seed file:_files' \
        '-t[key type]:key type:(raw ec256 ec521 rsa2048 rsa4096 x25519 ed25519)' \
        '-o[output file]:output file:_files'
}

_gokey "$@"
