#compdef oscap

# Zsh completion for openscap (oscap) - Security Content Automation Protocol scanner

_openscap() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'xccdf:XCCDF benchmark evaluation'
    'oval:OVAL definition evaluation'
    'ds:SCAP data stream operations'
    'cpe:CPE name and dictionary operations'
    'cvss:CVSS score calculation'
    'info:show information about SCAP content'
  )

  _arguments -s -S \
    '1:module:->module' \
    '*::arg:->args' \
    && ret=0

  case $state in
    module)
      _describe -t commands 'oscap module' commands && ret=0
      ;;
    args)
      case ${words[1]} in
        xccdf)
          local -a xccdf_commands=(
            'eval:evaluate XCCDF benchmark'
            'validate:validate XCCDF content'
            'resolve:resolve XCCDF document'
            'remediate:perform remediation'
            'generate:generate output'
          )
          _arguments \
            '1:xccdf command:_describe -t xccdf-commands "xccdf command" xccdf_commands' \
            '--profile[select profile by ID]:profile ID:' \
            '--results[write results to file]:results file:_files -g "*.xml"' \
            '--report[write HTML report]:report file:_files -g "*.html"' \
            '--fetch-remote-resources[fetch remote resources]' \
            '--remediate[perform automatic remediation]' \
            '--cpe[CPE dictionary or language]:CPE file:_files -g "*.xml"' \
            '--datastream-id[datastream ID]:datastream ID:' \
            '--xccdf-id[XCCDF component ID]:xccdf ID:' \
            '*:SCAP content file:_files -g "*.xml"' \
            && ret=0
          ;;
        oval)
          local -a oval_commands=(
            'eval:evaluate OVAL definitions'
            'collect:collect system characteristics'
            'analyse:analyse collected data'
            'validate:validate OVAL content'
            'generate:generate output'
          )
          _arguments \
            '1:oval command:_describe -t oval-commands "oval command" oval_commands' \
            '--results[write results to file]:results file:_files -g "*.xml"' \
            '--report[write HTML report]:report file:_files -g "*.html"' \
            '--id[evaluate specific definition]:definition ID:' \
            '*:OVAL definitions file:_files -g "*.xml"' \
            && ret=0
          ;;
        ds)
          local -a ds_commands=(
            'sds-compose:compose a source data stream'
            'sds-split:split a source data stream'
            'sds-validate:validate a source data stream'
            'rds-create:create a result data stream'
            'rds-validate:validate a result data stream'
          )
          _arguments \
            '1:ds command:_describe -t ds-commands "ds command" ds_commands' \
            '*:file:_files -g "*.xml"' \
            && ret=0
          ;;
        info)
          _arguments \
            '--fetch-remote-resources[fetch remote resources]' \
            '--profile[show profile details]:profile ID:' \
            '1:SCAP content file:_files -g "*.xml"' \
            && ret=0
          ;;
        cpe)
          _arguments \
            '1:CPE operation:(check match)' \
            '*:file:_files -g "*.xml"' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_openscap "$@"
