#compdef HandBrakeCLI

_handbrake_cli() {
    local context state line
    typeset -A opt_args

    _arguments -s \
        '(-i --input)'{-i,--input}'[set input file or device]:input:_files' \
        '(-o --output)'{-o,--output}'[set output file]:output:_files' \
        '(-t --title)'{-t,--title}'[select a title to encode (0 to scan all)]:title number' \
        '--min-duration[set minimum title duration in seconds]:seconds' \
        '--scan[scan input only, do not encode]' \
        '(-e --encoder)'{-e,--encoder}'[set video encoder]:encoder:(x264 x265 mpeg4 mpeg2 VP8 VP9 theora svt_av1)' \
        '(-q --quality)'{-q,--quality}'[set video quality]:quality' \
        '(-b --vb)'{-b,--vb}'[set video bitrate in kbps]:bitrate' \
        '(-r --rate)'{-r,--rate}'[set video framerate]:framerate:(5 10 12 15 20 23.976 24 25 29.97 30 48 50 59.94 60)' \
        '--cfr[use constant frame rate]' \
        '--pfr[use peak-limited frame rate]' \
        '--vfr[use variable frame rate]' \
        '(-a --audio)'{-a,--audio}'[select audio track(s)]:audio tracks' \
        '(-E --aencoder)'{-E,--aencoder}'[set audio encoder]:audio encoder:(copy av_aac ac3 mp3 vorbis flac opus)' \
        '(-B --ab)'{-B,--ab}'[set audio bitrate in kbps]:audio bitrate' \
        '(-R --arate)'{-R,--arate}'[set audio samplerate]:samplerate:(auto 22.05 24 44.1 48)' \
        '--mixdown[set audio mixdown format]:mixdown:(mono left_only right_only stereo dpl1 dpl2 5point1 6point1 7point1 5_2_lfe)' \
        '(-f --format)'{-f,--format}'[set output format]:format:(av_mp4 av_mkv av_webm)' \
        '(-Z --preset)'{-Z,--preset}'[select preset by name]:preset name' \
        '--preset-list[list available presets]' \
        '--encoder-preset[set video encoder preset]:encoder preset' \
        '--encoder-tune[set video encoder tuning]:encoder tune' \
        '--encoder-profile[set video encoder profile]:encoder profile' \
        '--encoder-level[set video encoder level]:encoder level' \
        '(-w --width)'{-w,--width}'[set output width]:width' \
        '(-l --height)'{-l,--height}'[set output height]:height' \
        '--crop[set crop values]:top\:bottom\:left\:right' \
        '--auto-anamorphic[automatically handle anamorphic content]' \
        '--modulus[set modulus for dimensions]:modulus' \
        '(-s --subtitle)'{-s,--subtitle}'[select subtitle track(s)]:subtitle tracks' \
        '--subtitle-burned[burn subtitle track into video]:track' \
        '--subtitle-default[set default subtitle track]:track' \
        '(-m --markers)'{-m,--markers}'[add chapter markers]' \
        '--optimize[optimize MP4 for HTTP streaming]' \
        '--turbo[enable turbo first pass]' \
        '--two-pass[enable two-pass encoding]' \
        '--deinterlace[deinterlace video]:filter settings' \
        '--detelecine[detelecine video]:filter settings' \
        '--denoise[denoise video]:filter settings' \
        '--nlmeans[NLMeans denoise]:preset:(ultralight light medium strong)' \
        '--rotate[rotate or flip image]:angle:(0 90 180 270)' \
        '--verbose[set verbosity level]:level:(0 1 2)' \
        '--json[output scan results in JSON]' \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version]'
}

_handbrake_cli "$@"
