#compdef winbindd

_winbindd() {
    local context state line
    typeset -A opt_args
    _arguments \
        '(-D --daemon)'{-D,--daemon}'[run as daemon]' \
        '(-F --foreground)'{-F,--foreground}'[run in foreground]' \
        '(-S --stdout)'{-S,--stdout}'[log to stdout]' \
        '(-i --interactive)'{-i,--interactive}'[run interactively]' \
        '(-n --no-caching)'{-n,--no-caching}'[disable caching]' \
        '--no-process-group[do not create a new process group]' \
        '(-d --debuglevel)'{-d,--debuglevel}'[set debug level]:level' \
        '(-s --configfile)'{-s,--configfile}'[specify config file]:config file:_files' \
        '(-l --log-basename)'{-l,--log-basename}'[set log file basename]:log basename:_files'
}

_winbindd "$@"
