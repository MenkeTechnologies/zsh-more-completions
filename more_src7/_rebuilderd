#compdef rebuilderd rebuildctl

_rebuilderd() {
  if [[ $service == rebuildctl ]]; then
    local -a commands=(
      'pkgs:manage packages'
      'queue:manage rebuild queue'
      'build:build packages'
      'status:show status'
      'completions:generate shell completions'
    )

    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '-H[rebuilderd host]:host:' \
      '--auth-cookie[auth cookie file]:file:_files' \
      '1:command:->command' \
      '*::arg:->args' && return

    case $state in
      command)
        _describe -t commands 'rebuildctl command' commands
        ;;
      args)
        case ${words[1]} in
          pkgs)
            _arguments \
              '1:subcommand:(ls sync-suite)' \
              '--distro[distribution]:distro:' \
              '--suite[suite]:suite:' \
              '--name[package name]:name:' \
              '--status[filter by status]:status:(GOOD BAD UNKWN)' \
              '--architecture[architecture]:arch:'
            ;;
          queue)
            _arguments \
              '1:subcommand:(ls push drop)' \
              '--distro[distribution]:distro:' \
              '--suite[suite]:suite:'
            ;;
        esac
        ;;
    esac
  else
    _arguments -s -S \
      '(-c --config)'{-c,--config}'[config file]:file:_files' \
      '--bind[bind address]:address:' \
      '-v[verbose]' \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]'
  fi
}

_rebuilderd "$@"
