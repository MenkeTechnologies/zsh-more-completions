#compdef csvdiff

# Zsh completion for csvdiff - CSV diff tool

_csvdiff() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '--columns[columns to compare]:columns:' \
    '--format[output format]:format:(json rowmark legacy-json diff word)' \
    '--include[columns to include in output]:columns:' \
    '--exclude[columns to exclude from output]:columns:' \
    '--separator[CSV field separator]:separator:' \
    '--lazyquotes[allow lazy quotes in CSV]' \
    '--primary-key[primary key columns]:columns:' \
    '--time[measure execution time]' \
    '--tolerance[numeric tolerance for comparison]:tolerance:' \
    '1:base CSV file:_files -g "*.csv"' \
    '2:delta CSV file:_files -g "*.csv"' \
    && ret=0

  return ret
}

_csvdiff "$@"
