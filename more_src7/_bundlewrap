#compdef bw

_bundlewrap() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'apply:apply configuration to nodes'
    'debug:start interactive debug session'
    'diff:show differences between repo and node'
    'groups:list groups'
    'hash:show item hashes'
    'items:list items for a node'
    'lock:manage locks'
    'metadata:show node metadata'
    'nodes:list nodes'
    'plot:generate DOT graph'
    'run:run command on nodes'
    'stats:show repository statistics'
    'test:run tests'
    'verify:verify node state'
    'zen:print wisdom'
  )

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '-a[add host key automatically]' \
    '-d[path to repo directory]:dir:_files -/' \
    '1:command:->command' \
    '*::arg:->args' \
    && ret=0

  case $state in
    command)
      _describe -t commands 'bundlewrap command' commands && ret=0
      ;;
    args)
      case ${words[1]} in
        apply|diff|items|metadata|verify)
          _arguments \
            '-f[force]' \
            '-i[interactive]' \
            '-p[parallel processes]:count:' \
            '-S[skip items]:items:' \
            '-o[only items]:items:' \
            '*:node:' \
            && ret=0
          ;;
        run)
          _arguments \
            '-f[force]' \
            '-p[parallel processes]:count:' \
            '1:command:' \
            '*:node:' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_bundlewrap "$@"
