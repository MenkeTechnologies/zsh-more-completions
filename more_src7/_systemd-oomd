#compdef systemd-oomd

_systemd-oomd() {
    local context state line
    typeset -A opt_args
    _arguments -s \
        '--dry-run[only log actions without killing]' \
        '--swap-used-limit[set swap used limit percentage]:percentage:' \
        '--mem-pressure-limit[set memory pressure limit percentage]:percentage:' \
        '--mem-pressure-duration[set memory pressure duration]:duration:' \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]'
}

_systemd-oomd "$@"
