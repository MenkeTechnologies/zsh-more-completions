#compdef orca-slicer

_orca-slicer() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '--export-gcode[export G-code]' \
    '--export-stl[export STL]' \
    '--export-3mf[export 3MF]' \
    '--info[show file info]' \
    '--load[load config]:config:_files -g "*.ini"' \
    '--merge[merge loaded files]' \
    '--output[output file]:file:_files' \
    '--repair[repair model]' \
    '--rotate[rotate around Z]:degrees:' \
    '--scale[scale factor]:factor:' \
    '--center[center object]:X,Y:' \
    '--split[split into parts]' \
    '--loglevel[log level]:level:(0 1 2 3 4 5)' \
    '--datadir[data directory]:dir:_files -/' \
    '--single-instance[single instance mode]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '*:input file:_files -g "*.{stl,obj,amf,3mf,step,stp}"' \
    && ret=0

  return ret
}

_orca-slicer "$@"
