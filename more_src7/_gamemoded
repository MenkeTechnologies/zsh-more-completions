#compdef gamemoded

_gamemoded() {
    local context state line
    typeset -A opt_args
    _arguments \
        '(-d --daemonize)'{-d,--daemonize}'[run as daemon]' \
        '(-l --log-to-syslog)'{-l,--log-to-syslog}'[log to syslog]' \
        '(-r --request)'{-r,--request}'[request GameMode for process]:pid' \
        '(-s --status)'{-s,--status}'[query GameMode status]:pid' \
        '(-t --test)'{-t,--test}'[run self-tests]' \
        '(-v --version)'{-v,--version}'[show version]'
}

_gamemoded "$@"
