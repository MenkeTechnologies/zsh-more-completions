#compdef timew

_timew() {
    local context state line
    typeset -A opt_args

    local -a commands
    commands=(
        'cancel:cancel active time tracking'
        'config:set or unset configuration values'
        'continue:resume tracking of closed interval'
        'day:show daily chart'
        'delete:delete an interval'
        'diagnostics:show diagnostic information'
        'dom:display object model reference'
        'export:export tracked time in JSON'
        'extensions:list available extensions'
        'fill:adjust intervals to fill gaps'
        'gaps:show gaps in tracked time'
        'get:get DOM values'
        'help:show help'
        'join:join two intervals'
        'lengthen:lengthen an interval'
        'modify:change start/end of an interval'
        'month:show monthly chart'
        'move:change start of an interval'
        'report:run an extension report'
        'resize:set interval duration'
        'shorten:shorten an interval'
        'show:show configuration'
        'split:split an interval'
        'start:start time tracking'
        'stop:stop time tracking'
        'summary:show summary report'
        'tag:add tags to an interval'
        'tags:list all tags'
        'track:add a completed interval'
        'undo:undo the last change'
        'untag:remove tags from an interval'
        'week:show weekly chart'
        'year:show yearly chart'
    )

    _arguments -C \
        ':quiet[suppress output]' \
        ':debug[enable debug mode]' \
        ':yes[answer yes to confirmation prompts]' \
        ':fill[fill gaps when tracking]' \
        ':adjust[adjust overlapping intervals]' \
        '1: :->cmd' \
        '*::arg:->args'

    case $state in
        cmd)
            _describe -t commands 'timew command' commands
            ;;
        args)
            case $line[1] in
                help)
                    _describe -t commands 'timew command' commands
                    ;;
                start|track)
                    _message 'tags and/or time range'
                    ;;
                stop)
                    _message 'tags'
                    ;;
                config)
                    _message 'name value'
                    ;;
                continue|delete|join|lengthen|modify|move|resize|shorten|split|tag|untag|fill)
                    _message 'interval ID'
                    ;;
                report)
                    _message 'report name'
                    ;;
                *)
                    _message 'arguments'
                    ;;
            esac
            ;;
    esac
}

_timew "$@"
