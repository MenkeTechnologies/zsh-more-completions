#compdef toxiproxy-cli

# Zsh completion for toxiproxy-cli - Toxiproxy fault injection proxy CLI

_toxiproxy-cli() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'list:list all proxies'
    'inspect:inspect a proxy'
    'create:create a new proxy'
    'delete:delete a proxy'
    'toggle:toggle a proxy (enable/disable)'
    'toxic:manage toxics on a proxy'
  )

  _arguments -s -S \
    '-h[Toxiproxy host address]:host:_hosts' \
    '1:command:->command' \
    '*::arg:->args' \
    && ret=0

  case $state in
    command)
      _describe -t commands 'toxiproxy-cli command' commands && ret=0
      ;;
    args)
      case ${words[1]} in
        inspect|delete|toggle)
          _arguments \
            '1:proxy name:' \
            && ret=0
          ;;
        create)
          _arguments \
            '-l[listen address]:listen address:' \
            '-u[upstream address]:upstream address:' \
            '1:proxy name:' \
            && ret=0
          ;;
        toxic)
          local -a toxic_commands=(
            'add:add a toxic to a proxy'
            'remove:remove a toxic from a proxy'
            'update:update a toxic on a proxy'
          )
          _arguments \
            '1:toxic action:_describe -t toxic-commands "toxic action" toxic_commands' \
            '-n[toxic name]:toxic name:' \
            '-t[toxic type]:type:(latency bandwidth slow_close timeout slicer limit_data)' \
            '-s[stream direction]:stream:(upstream downstream)' \
            '-a[toxic attributes (key=value)]:attributes:' \
            '-p[proxy name]:proxy name:' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_toxiproxy-cli "$@"
