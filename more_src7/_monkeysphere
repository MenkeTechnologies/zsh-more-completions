#compdef monkeysphere

_monkeysphere() {
    local context state line
    typeset -A opt_args

    _arguments -C \
        '1: :->cmd' \
        '*::arg:->args'

    case $state in
        cmd)
            local -a commands=(
                'update-known_hosts:update known_hosts file'
                'update-authorized_keys:update authorized_keys file'
                'gen-subkey:generate an authentication subkey'
                'ssh-proxycommand:SSH ProxyCommand for monkeysphere'
                'subkey-to-ssh-agent:load authentication subkey into ssh-agent'
                'keys-for-userid:output keys for a user ID'
                'sshfpr:output SSH fingerprints for a key'
                'version:show version'
            )
            _describe -t commands 'monkeysphere command' commands
            ;;
        args)
            case ${words[1]} in
                update-known_hosts)
                    _hosts
                    ;;
                gen-subkey)
                    _arguments '*:key ID:'
                    ;;
                keys-for-userid)
                    _arguments '*:user ID:'
                    ;;
                sshfpr)
                    _arguments '*:key ID:'
                    ;;
            esac
            ;;
    esac
}

_monkeysphere "$@"
