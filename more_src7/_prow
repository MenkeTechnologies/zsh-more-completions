#compdef prow

_prow() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'config:manage Prow configuration'
    'create-job:create a new Prow job'
    'jobs:list Prow jobs'
    'mkpj:make ProwJob from config'
    'mkpod:make Pod from ProwJob'
    'sub:subscribe to Pub/Sub events'
    'version:show version'
  )

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '--config-path[config file path]:file:_files -g "*.yaml"' \
    '--job-config-path[job config directory]:dir:_files -/' \
    '--kubeconfig[kubeconfig path]:file:_files' \
    '--context[kubeconfig context]:context:' \
    '1:command:->command' \
    '*::arg:->args' \
    && ret=0

  case $state in
    command)
      _describe -t commands 'prow command' commands && ret=0
      ;;
    args)
      case ${words[1]} in
        mkpj)
          _arguments \
            '--job[job name]:name:' \
            '--config-path[config path]:file:_files -g "*.yaml"' \
            '--job-config-path[job config path]:dir:_files -/' \
            '--base-ref[base ref]:ref:' \
            '--base-sha[base SHA]:sha:' \
            '--pull-number[pull request number]:number:' \
            '--pull-sha[pull SHA]:sha:' \
            '--pull-author[pull author]:author:' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_prow "$@"
