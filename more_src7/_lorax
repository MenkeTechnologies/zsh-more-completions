#compdef lorax

_lorax() {
    local context state line
    typeset -A opt_args
    _arguments \
        '(-p --product)'{-p,--product}'[product name]:product name' \
        '(-v --version)'{-v,--version}'[version string]:version' \
        '(-r --release)'{-r,--release}'[release string]:release' \
        '(-s --source)'{-s,--source}'[repository source URL (may be given multiple times)]:repo URL' \
        '--isfinal[mark as final release]' \
        '--buildarch[build architecture]:architecture' \
        '--volid[volume ID]:volume ID' \
        '--variant[variant name]:variant' \
        '--bugurl[bug reporting URL]:URL' \
        '--nomacboot[disable Mac boot support]' \
        '--noupgrade[disable upgrade image generation]' \
        '--logfile[path to log file]:log file:_files' \
        '--tmp[temporary directory]:temp directory:_directories' \
        '--cachedir[cache directory for downloaded packages]:cache directory:_directories' \
        '--sharedir[share directory with templates]:share directory:_directories' \
        '--add-template[additional template file]:template file:_files' \
        '--add-template-var[set template variable]:name=value' \
        '--add-arch-template[additional architecture template]:template file:_files' \
        '--add-arch-template-var[set architecture template variable]:name=value' \
        '--rootfs-size[size of root filesystem in GiB]:size' \
        '--force-new-sdk[force use of new SDK]' \
        '--old-chroot[use old chroot method]' \
        '*:output directory:_directories'
}

_lorax "$@"
