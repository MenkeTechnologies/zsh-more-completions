#compdef rsyslogd

_rsyslogd() {
    local context state line
    typeset -A opt_args
    _arguments \
        '-4[use IPv4 only]' \
        '-6[use IPv6 only]' \
        '-A[output action]' \
        '-c[compatibility mode]:compatibility level' \
        '-d[enable debug mode]' \
        '-D[debug mode without forking]' \
        '-e[log every message]' \
        '-f[specify configuration file]:config file:_files' \
        '-i[specify PID file]:pid file:_files' \
        '-l[strip specified hostnames of domain]:hostlist' \
        '-M[specify module load path]:module path:_directories' \
        '-n[do not fork]' \
        '-N[check configuration and exit]:level:(1 2 3)' \
        '-o[full startup even in compatibility mode]' \
        '-q[quiet mode, suppress startup messages]' \
        '-Q[very quiet mode]' \
        '-s[strip specified domains from hostnames]:domainlist' \
        '-S[specify source for log messages]:source' \
        '-T[chroot to specified directory]:directory:_directories' \
        '-u[run as specified user]:user:_users' \
        '-v[show version]' \
        '-w[suppress compatibility warnings]:level' \
        '-x[disable DNS lookups]'
}

_rsyslogd "$@"
