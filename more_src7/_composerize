#compdef composerize

_composerize() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '(- *)'{-v,--version}'[show version]' \
    '(- *)'{-h,--help}'[show help]' \
    '-i[indentation level]:indent:' \
    '*:docker run command:' \
    && ret=0

  return ret
}

_composerize "$@"
