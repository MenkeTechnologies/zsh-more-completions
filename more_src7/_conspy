#compdef conspy

_conspy() {
    local context state line
    typeset -A opt_args
    _arguments -s \
        '-d[delay between screen updates]:delay (ms):' \
        '-g[set geometry WxH]:geometry (WxH):' \
        '-G[use geometry from console]' \
        '-v[view only mode]' \
        '-V[show version]' \
        '1::console number:'
}

_conspy "$@"
