#compdef htmlproofer

_htmlproofer() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '--allow-hash-href[allow empty hash hrefs]' \
    '--allow-missing-href[allow missing href attributes]' \
    '--as-links[treat arguments as URLs instead of files]' \
    '--assume-extension[assume .html extension]:extension:' \
    '--checks[checks to run]:checks:' \
    '--check-external-hash[check external URL hashes]' \
    '--check-favicon[check for favicon]' \
    '--check-html[validate HTML]' \
    '--check-img-http[check images for HTTP URLs]' \
    '--check-opengraph[check OpenGraph tags]' \
    '--check-sri[check subresource integrity]' \
    '--directory-index-file[directory index file]:file:' \
    '--disable-external[disable external link checks]' \
    '--empty-alt-ignore[ignore empty alt attributes]' \
    '--enforce-https[require HTTPS links]' \
    '--extensions[file extensions to check]:extensions:' \
    '--external-only[only check external links]' \
    '--file-ignore[files to ignore]:pattern:' \
    '--ignore-files[files to ignore]:pattern:' \
    '--ignore-missing-alt[ignore missing alt attributes]' \
    '--ignore-status-codes[HTTP status codes to ignore]:codes:' \
    '--ignore-urls[URLs to ignore]:pattern:' \
    '--internal-domains[internal domains]:domains:' \
    '--log-level[log level]:level:(debug info warn error)' \
    '--no-enforce-https[do not enforce HTTPS]' \
    '--only-4xx[only report 4xx errors]' \
    '--root-dir[root directory]:directory:_files -/' \
    '--swap-urls[URL swap rules]:rules:' \
    '--url-ignore[URLs to ignore]:pattern:' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '*:file or directory:_files' \
    && ret=0

  return ret
}

_htmlproofer "$@"
