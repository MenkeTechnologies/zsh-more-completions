#compdef makeinfo texi2any

# Zsh completion for texinfo (makeinfo/texi2any) - GNU documentation system

_texinfo() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '--html[generate HTML output]' \
    '--plaintext[generate plain text output]' \
    '--xml[generate Texinfo XML output]' \
    '--docbook[generate DocBook XML output]' \
    '--info[generate Info output (default)]' \
    '-o[output to file or directory]:output:_files' \
    '--output=[output to file or directory]:output:_files' \
    '--force[preserve output even if errors]' \
    '--no-validate[suppress node cross-reference validation]' \
    '--no-warn[suppress warnings]' \
    '--no-headers[suppress node separators and menus in Info/plain text]' \
    '--split=[split output at]:split type:(chapter section node)' \
    '-I[append directory to @include search path]:include dir:_directories' \
    '-D[define texinfo variable]:variable:' \
    '-U[undefine texinfo variable]:variable:' \
    '--css-include=[include CSS file contents]:CSS file:_files -g "*.css"' \
    '--css-ref=[reference external CSS file]:CSS URL:' \
    '--verbose[explain what is being done]' \
    '--version[display version information]' \
    '--help[display help]' \
    '-P[prepend directory to @include search path]:include dir:_directories' \
    '--number-sections[output chapter and section numbers]' \
    '--no-number-sections[suppress chapter and section numbers]' \
    '--enable-encoding[handle special characters natively]' \
    '*:texinfo file:_files -g "*.texi(|nfo)"' \
    && ret=0

  return ret
}

_texinfo "$@"
