#compdef homebridge

_homebridge() {
    local context state line
    typeset -A opt_args

    _arguments -s \
        '(-C --color)'{-C,--color}'[force color in logging output]' \
        '(-D --debug)'{-D,--debug}'[turn on debug level logging]' \
        '(-I --insecure)'{-I,--insecure}'[allow unauthenticated requests]' \
        '(-P --plugin-path)'{-P,--plugin-path}'[look for plugins in specified directory]:plugin path:_directories' \
        '(-Q --no-qrcode)'{-Q,--no-qrcode}'[do not print QR code to terminal]' \
        '(-R --remove-orphans)'{-R,--remove-orphans}'[remove cached accessories for which the plugin is not loaded]' \
        '(-T --strict-plugin-resolution)'{-T,--strict-plugin-resolution}'[only load plugins installed in the global prefix]' \
        '(-U --user-storage-path)'{-U,--user-storage-path}'[set user storage path]:storage path:_directories' \
        '(-v --version)'{-v,--version}'[display version]' \
        '(-K --keep-orphans)'{-K,--keep-orphans}'[keep cached accessories for which the plugin is not loaded]' \
        '(- *)'{-h,--help}'[show help message]'
}

_homebridge "$@"
