#compdef mirrorselect

_mirrorselect() {
    local context state line
    typeset -A opt_args

    _arguments -s \
        '(-s --servers)'{-s,--servers}'[number of servers to select]:number' \
        '(-b --blocksize)'{-b,--blocksize}'[block size for test download]:block size' \
        '(-d --depth)'{-d,--depth}'[number of servers to test]:depth' \
        '(-D --debug)'{-D,--debug}'[enable debug output]' \
        '(-H --http)'{-H,--http}'[use HTTP for mirror testing]' \
        '(-4 --ipv4)'{-4,--ipv4}'[only use IPv4]' \
        '(-6 --ipv6)'{-6,--ipv6}'[only use IPv6]' \
        '(-o --output)'{-o,--output}'[output to file]:output file:_files' \
        '(-q --quiet)'{-q,--quiet}'[suppress output]' \
        '(-r --rsync)'{-r,--rsync}'[use rsync mirrors]' \
        '(-R --region)'{-R,--region}'[limit mirrors to specified region]:region' \
        '(-t --timeout)'{-t,--timeout}'[timeout for server tests]:timeout' \
        '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
        '(- *)'{-h,--help}'[show help message]'
}

_mirrorselect "$@"
