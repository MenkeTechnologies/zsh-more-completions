#compdef comgt

_comgt() {
    local context state line
    typeset -A opt_args

    _arguments -C \
        '-d[specify device]:device:_files -g "/dev/tty*"' \
        '-e[echo commands]' \
        '-s[run script file]:script file:_files' \
        '-t[set timeout in seconds]:timeout (seconds):' \
        '-v[verbose output]' \
        '-V[show version]' \
        '-h[show help]' \
        '1: :->cmd' \
        '*::arg:->args'

    case $state in
        cmd)
            local -a commands=(
                'info:display modem information'
                'sig:display signal quality'
                'reg:display registration status'
                'PIN:enter PIN code'
                'APN:set APN'
            )
            _describe -t commands 'comgt command' commands
            ;;
    esac
}

_comgt "$@"
