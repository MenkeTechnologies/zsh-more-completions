#compdef vpncmd

_softethervpn() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '/SERVER[connect to VPN server]:host\:port:' \
    '/CLIENT[connect to VPN client]:host\:port:' \
    '/TOOLS[use standalone tools]' \
    '/HUB[specify virtual hub name]:hub name:' \
    '/ADMINHUB[specify admin hub]:hub name:' \
    '/PASSWORD[specify password]:password:' \
    '/IN[input commands from file]:file:_files' \
    '/OUT[output to file]:file:_files' \
    '/CMD[execute single command]:command:' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

  return ret
}

_softethervpn "$@"
