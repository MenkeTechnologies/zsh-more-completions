#compdef avconv

_avconv() {
    local context state line
    typeset -A opt_args

    _arguments -s \
        '*-i[input file]:input file:_files' \
        '-f[force format]:format' \
        '-c[codec name]:codec' \
        '-c\:v[video codec]:video codec' \
        '-c\:a[audio codec]:audio codec' \
        '-b\:v[video bitrate]:video bitrate' \
        '-b\:a[audio bitrate]:audio bitrate' \
        '-r[frame rate]:frame rate' \
        '-s[frame size]:frame size' \
        '-ar[audio sampling rate]:sample rate' \
        '-ac[audio channels]:channels' \
        '-t[recording duration]:duration' \
        '-ss[start time offset]:start time' \
        '-to[stop time]:stop time' \
        '-vf[video filtergraph]:filter' \
        '-af[audio filtergraph]:filter' \
        '*-map[set input stream mapping]:map' \
        '-y[overwrite output files without asking]' \
        '-n[never overwrite output files]' \
        '-v[set logging verbosity]:loglevel:(quiet panic fatal error warning info verbose debug trace)' \
        '-threads[set number of threads]:threads' \
        '-preset[set encoding preset]:preset:(ultrafast superfast veryfast faster fast medium slow slower veryslow)' \
        '-crf[set constant rate factor]:crf' \
        '-pass[select pass number]:pass:(1 2)' \
        '-passlogfile[select two pass log file prefix]:log file prefix:_files' \
        '*:output file:_files'
}

_avconv "$@"
