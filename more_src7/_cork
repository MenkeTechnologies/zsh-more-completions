#compdef cork

_cork() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'search:search for casks'
    'info:show cask information'
    'install:install a cask'
    'uninstall:uninstall a cask'
    'update:update all casks'
    'outdated:list outdated casks'
    'upgrade:upgrade casks'
    'list:list installed casks'
  )

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1:command:->command' \
    '*::arg:->args' \
    && ret=0

  case $state in
    command)
      _describe -t commands 'cork command' commands && ret=0
      ;;
    args)
      case ${words[1]} in
        search)
          _arguments '*:query:' && ret=0
          ;;
        info|install|uninstall|upgrade)
          _arguments '*:cask:' && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_cork "$@"
