#compdef warpstream

_warpstream() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'agent:start a WarpStream agent'
    'playground:start a local playground'
    'demo:start a demo cluster'
    'iam:manage IAM'
    'acl:manage ACLs'
  )

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1:command:->command' \
    '*::arg:->args' \
    && ret=0

  case $state in
    command)
      _describe -t commands 'warpstream command' commands && ret=0
      ;;
    args)
      case ${words[1]} in
        agent)
          _arguments \
            '--agentKey[agent key]:key:' \
            '--bucketURL[object store bucket URL]:url:' \
            '--defaultVirtualClusterID[virtual cluster ID]:id:' \
            '--kafkaPort[Kafka port]:port:' \
            '--httpPort[HTTP port]:port:' \
            '--gracePeriod[grace period]:duration:' \
            && ret=0
          ;;
        playground)
          _arguments \
            '--kafkaPort[Kafka port]:port:' \
            '--httpPort[HTTP port]:port:' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_warpstream "$@"
