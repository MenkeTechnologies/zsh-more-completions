#compdef k3os

_k3os() {
    local context state line
    typeset -A opt_args

    local -a commands
    commands=(
        'config:configure k3OS'
        'install:install k3OS'
        'password:set password'
        'upgrade:upgrade k3OS'
    )

    _arguments -C \
        '--debug[enable debug logging]' \
        '--help[show help]' \
        '1: :->cmd' \
        '*::arg:->args'

    case $state in
        cmd)
            _describe -t commands 'k3os command' commands
            ;;
        args)
            case $line[1] in
                config)
                    _arguments \
                        '--debug[enable debug logging]' \
                        '--help[show help]'
                    ;;
                install)
                    _arguments \
                        '--debug[enable debug logging]' \
                        '--help[show help]'
                    ;;
                password)
                    _arguments \
                        '--debug[enable debug logging]' \
                        '--help[show help]'
                    ;;
                upgrade)
                    _arguments \
                        '--debug[enable debug logging]' \
                        '--help[show help]'
                    ;;
            esac
            ;;
    esac
}

_k3os "$@"
