#compdef svn2git

_svn2git() {
    local context state line
    typeset -A opt_args
    _arguments -s \
        '--trunk[specify trunk path]:trunk path:' \
        '--tags[specify tags path]:tags path:' \
        '--branches[specify branches path]:branches path:' \
        '--roottag[specify root tag]:tag name:' \
        '--rootisbranch[treat root as branch]' \
        '--notrunk[do not import trunk]' \
        '--notags[do not import tags]' \
        '--nobranches[do not import branches]' \
        '--no-minimize-url[do not minimize SVN URL]' \
        '--revision[specify revision range]:revision range:' \
        '--username[SVN username]:username:' \
        '--authors[authors mapping file]:authors file:_files' \
        '*--exclude[exclude path regex]:exclude pattern:' \
        '--metadata[include SVN metadata in commit messages]' \
        '--no-follow-parent[do not follow parent of copy]' \
        '--verbose[verbose output]' \
        '--rebase[rebase instead of clone]' \
        '--rebasebranch[specify rebase branch]:branch name:' \
        '1:SVN URL:'
}

_svn2git "$@"
