#compdef xscreensaver xscreensaver-command

_xscreensaver() {
    case $service in
        xscreensaver)
            _arguments -s \
                '-display[specify X display]:display' \
                '-verbose[enable verbose output]' \
                '-no-splash[disable splash screen at startup]' \
                '-nosplash[disable splash screen at startup]' \
                '-log[log to file]:log file:_files' \
                '-prefs[start with preferences dialog]'
            ;;
        xscreensaver-command)
            _arguments -s \
                '-activate[activate the screensaver]' \
                '-deactivate[deactivate the screensaver]' \
                '-lock[lock the screen]' \
                '-cycle[switch to next screensaver]' \
                '-next[switch to next screensaver]' \
                '-prev[switch to previous screensaver]' \
                '-exit[exit xscreensaver]' \
                '-restart[restart xscreensaver]' \
                '-time[print time since last user activity]' \
                '-watch[print status changes in real time]' \
                '-version[display version]'
            ;;
    esac
}

_xscreensaver "$@"
