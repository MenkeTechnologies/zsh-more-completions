#compdef rehype

_rehype() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '(-o --output)'{-o,--output}'[output file]:file:_files' \
    '(-t --tree)'{-t,--tree}'[output syntax tree]' \
    '(-q --quiet)'{-q,--quiet}'[suppress output]' \
    '(-f --frail)'{-f,--frail}'[exit with error on warnings]' \
    '(-s --setting)'{-s,--setting}'[configuration settings]:settings:' \
    '(-u --use)'{-u,--use}'[use a plugin]:plugin:' \
    '(-e --ext)'{-e,--ext}'[file extensions]:extensions:' \
    '(-w --watch)'{-w,--watch}'[watch for changes]' \
    '(-r --rc-path)'{-r,--rc-path}'[config file path]:file:_files' \
    '(-i --ignore-path)'{-i,--ignore-path}'[ignore file path]:file:_files' \
    '--no-stdout[do not write to stdout]' \
    '--no-color[disable color output]' \
    '--no-rc[do not load config files]' \
    '--no-ignore[do not load ignore files]' \
    '--file-path[file path for stdin]:path:_files' \
    '--color[force color output]' \
    '--report[reporter module]:reporter:' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '*:file:_files -g "*.{html,htm}"' \
    && ret=0

  return ret
}

_rehype "$@"
