#compdef elktail

# Zsh completion for elktail - tail Elasticsearch logs in real-time

_elktail() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '-url[Elasticsearch URL]:url:_urls' \
    '-i[index pattern to tail]:index pattern:' \
    '-f[output format]:format:' \
    '-n[number of initial entries to show]:entries:' \
    '-s[search query]:query:' \
    '-l[list available indices]' \
    '--ssh[SSH host for tunneling]:ssh host:_hosts' \
    '--ssh-user[SSH username]:username:_users' \
    '--ssh-tunnel[SSH tunnel specification]:tunnel spec:' \
    '*:search terms:' \
    && ret=0

  return ret
}

_elktail "$@"
