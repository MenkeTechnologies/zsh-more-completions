#compdef uxplay

_uxplay() {
    local context state line
    typeset -A opt_args
    _arguments -s \
        '-n[set server name]:name:' \
        '-s[set display resolution WxH]:size (WxH):' \
        '-fps[set framerate]:framerate:' \
        '-o[enable overlay mode]' \
        '-nh[no hold — exit when client disconnects]' \
        '-p[set network port]:port:' \
        '-m[set MAC address]:MAC address:' \
        '-a[specify audio sink]:audio sink:' \
        '-v[specify video sink]:video sink:' \
        '-nc[no interactive control]' \
        '-reset[reset after each session]' \
        '-vd[specify video decoder]:video decoder:' \
        '-vs[specify video sink element]:video sink element:' \
        '-as[specify audio sink element]:audio sink element:' \
        '-al[set audio latency in ms]:latency (ms):'
}

_uxplay "$@"
