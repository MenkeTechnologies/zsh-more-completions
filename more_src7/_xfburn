#compdef xfburn

_xfburn() {
    local context state line
    typeset -A opt_args

    _arguments -s \
        '(-b --blank)'{-b,--blank}'[blank a disc]' \
        '(-i --burn-image)'{-i,--burn-image}'[burn a disc image]:image file:_files -g "*.iso"' \
        '(-d --device)'{-d,--device}'[specify device]:device:_files -W /dev' \
        '(-V --version)'{-V,--version}'[display version]' \
        '(- *)'{-h,--help}'[show help message]'
}

_xfburn "$@"
