#compdef pptpd

_pptpd() {
    local context state line
    typeset -A opt_args
    _arguments -s \
        '-b[specify bcrelay interface]:interface:_net_interfaces' \
        '-c[specify config file]:config file:_files' \
        '-d[enable debug mode]' \
        '-e[enable ppp debug logging]' \
        '-f[run in foreground]' \
        '-h[show help]' \
        '-l[listen on IP address]:listen address:_hosts' \
        '-o[specify ppp options file]:options file:_files' \
        '-p[specify pid file]:pid file:_files' \
        '-s[set ppp speed]:speed:' \
        '-t[set timeout]:timeout (seconds):' \
        '-v[show version]' \
        '-w[log wtmp entries]'
}

_pptpd "$@"
