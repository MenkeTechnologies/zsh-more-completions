#compdef mkudffs

_mkudffs() {
    local context state line
    typeset -A opt_args

    _arguments -s \
        '(- *)--help[display help]' \
        '--blocksize[set block size]:block size:(512 1024 2048 4096)' \
        '--udfrev[set UDF revision]:revision:(0x0102 0x0150 0x0200 0x0201 0x0250 0x0260)' \
        '--lvid[set logical volume identifier]:identifier' \
        '--vid[set volume identifier]:identifier' \
        '--vsid[set volume set identifier]:identifier' \
        '--fsid[set file set identifier]:identifier' \
        '--uid[set default UID]:uid' \
        '--gid[set default GID]:gid' \
        '--mode[set default permissions]:mode' \
        '--bootarea[set boot area handling]:boot area:(erase preserve mbr)' \
        '--strategy[set allocation strategy]:strategy:(4 4096)' \
        '--spartable[set number of sparing tables]:count' \
        '--media-type[set media type]:media type:(hd dvd dvdram dvdrw dvdr worm mo cdrw cdr)' \
        '--space[set space handling]:space:(freedbitmap freedtable unallocbitmap unalloctable)' \
        '--ad[set allocation descriptor type]:type:(inicb short long)' \
        '--noefe[do not use extended file entries]' \
        '--locale[use locale for string encoding]' \
        '--u8[use 8-bit OSTA CS0 encoding]' \
        '--u16[use 16-bit OSTA CS0 encoding]' \
        '--utf8[use UTF-8 encoding]' \
        '--closed[close the disc after writing]' \
        '--bridge[create VAT and Sparing Table bridge]' \
        '--label[set volume label]:label' \
        '1:device:_files'
}

_mkudffs "$@"
