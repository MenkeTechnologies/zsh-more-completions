#compdef imwcs

_imwcs() {
    local context state line
    typeset -A opt_args
    _arguments \
        '-h[show help]' \
        '-v[verbose output]' \
        '-w[write WCS to file header]' \
        '-j[use J2000 coordinates]' \
        '-b[use B1950 coordinates]' \
        '-n[number of parameters to fit]:nfit' \
        '-s[set plate scale in arcsec/pixel]:secpix' \
        '-r[set rotation angle in degrees]:rotation' \
        '-d[enable debug mode]' \
        '-c[specify reference catalog]:catalog' \
        '*:FITS file:_files -g "*.{fits,fit,fts,FITS,FIT,FTS}"'
}

_imwcs "$@"
