#compdef CuraEngine

_curaengine() {
    local context state line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*::arg:->args'

    case $state in
        cmd)
            local -a commands=(
                'slice:slice a 3D model into gcode'
                'help:show help information'
                'connect:connect to a frontend'
            )
            _describe -t commands 'CuraEngine command' commands
            ;;
        args)
            case $line[1] in
                slice)
                    _arguments -s \
                        '*-j[load JSON settings file]:JSON file:_files -g "*.json"' \
                        '*-l[load STL model]:STL file:_files -g "*.stl"' \
                        '-o[output gcode file]:output file:_files -g "*.gcode"' \
                        '*-s[set a setting value]:key=value' \
                        '-v[increase verbosity]' \
                        '-p[show progress messages]' \
                        '*-e[set extruder number]:extruder number'
                    ;;
                connect)
                    _arguments -s \
                        '*-j[load JSON settings file]:JSON file:_files -g "*.json"' \
                        '*-s[set a setting value]:key=value' \
                        '-v[increase verbosity]'
                    ;;
            esac
            ;;
    esac
}

_curaengine "$@"
