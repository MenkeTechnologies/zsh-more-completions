#compdef cfn_nag

_cfn_nag() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '--allow-suppression[allow inline suppression]' \
    '--blacklist-path[path to blacklist]:file:_files' \
    '--condition-values-path[path to condition values]:file:_files -g "*.json"' \
    '--debug[enable debug output]' \
    '--deny-list-path[path to deny list]:file:_files' \
    '--fail-on-warnings[exit non-zero on warnings]' \
    '--force[force scan even on errors]' \
    '(- *)--help[show help]' \
    '--ignore-fatal[ignore fatal errors]' \
    '--input-path[input template path]:path:_files' \
    '--output-format[output format]:format:(txt json colortxt)' \
    '--parameter-values-path[parameter values file]:file:_files -g "*.json"' \
    '--print-suppression[print suppression rules]' \
    '--profile-path[path to profile]:file:_files -g "*.json"' \
    '--rule-directory[custom rule directory]:directory:_files -/' \
    '--rule-repository[custom rule repository]:repository:' \
    '--template-pattern[template filename pattern]:pattern:' \
    '(- *)--version[show version]' \
    '*:CloudFormation template:_files -g "*.{json,yaml,yml,template}"' \
    && ret=0

  return ret
}

_cfn_nag "$@"
