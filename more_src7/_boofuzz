#compdef boofuzz

_boofuzz() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '(-t --target)'{-t,--target}'[target address]:host\:port:' \
    '(-p --port)'{-p,--port}'[target port]:port:' \
    '(-r --restart-sleep)'{-r,--restart-sleep}'[sleep between restarts]:seconds:' \
    '--web-port[web UI port]:port:' \
    '--web-address[web UI address]:address:' \
    '--db-filename[session database file]:file:_files -g "*.db"' \
    '--csv-out[CSV output file]:file:_files -g "*.csv"' \
    '--log-level[logging level]:level:(debug info warning error critical)' \
    '--index-start[start at test case index]:index:' \
    '--index-end[end at test case index]:index:' \
    '--sleep-time[sleep time between mutations]:seconds:' \
    '--procmon-port[process monitor port]:port:' \
    '--crash-threshold[number of crashes before abort]:count:' \
    '--reuse-target-connection[reuse target connection]' \
    '(- *)'{-h,--help}'[show help]' \
    '*:fuzz script:_files -g "*.py"' \
    && ret=0

  return ret
}

_boofuzz "$@"
