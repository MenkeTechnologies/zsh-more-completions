#compdef vspipe

_vspipe() {
    local context state line
    typeset -A opt_args
    _arguments \
        '(-c --container)'{-c,--container}'[set output container format]:format:(y4m wav w64)' \
        '(-s --start)'{-s,--start}'[set output start frame]:frame number' \
        '(-e --end)'{-e,--end}'[set output end frame]:frame number' \
        '(-o --outputindex)'{-o,--outputindex}'[set output node index]:index' \
        '(-r --requests)'{-r,--requests}'[set number of concurrent frame requests]:requests' \
        '(-p --progress)'{-p,--progress}'[show progress]' \
        '(-i --info)'{-i,--info}'[show clip info and exit]' \
        '(-g --graph)'{-g,--graph}'[show filter graph and exit]:graph type:(simple full)' \
        '(-v --version)'{-v,--version}'[show version]' \
        '(-h --help)'{-h,--help}'[show help]' \
        '1:script file:_files -g "*.{vpy,py}"' \
        '2:output file:_files'
}

_vspipe "$@"
