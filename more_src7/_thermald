#compdef thermald

_thermald() {
    local context state line
    typeset -A opt_args
    _arguments \
        '--no-daemon[do not daemonize]' \
        '--loglevel[set log level]:level:(info debug)' \
        '--test-mode[run in test mode]' \
        '--poll-interval[set polling interval in seconds]:seconds' \
        '--dbus-enable[enable D-Bus interface]' \
        '--config-file[specify thermal configuration file]:config file:_files' \
        '--ignore-cpuid-check[ignore CPUID check]' \
        '--workaround-enabled[enable workarounds]' \
        '--adaptive[use adaptive thermal management]' \
        '--ignore-default-control[ignore default thermal controls]' \
        '--version[show version]' \
        '--help[show help]'
}

_thermald "$@"
