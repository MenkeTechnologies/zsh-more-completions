#compdef ssss-split ssss-combine

# Zsh completion for ssss - Shamir's Secret Sharing Scheme

_ssss() {
  local curcontext="$curcontext" state line ret=1

  case ${service} in
    ssss-split)
      _arguments -s -S \
        '-t[threshold of shares needed to reconstruct]:threshold:' \
        '-n[number of shares to generate]:shares:' \
        '-M[require shares to have a security level]' \
        '-w[specify token identifier]:token:' \
        '-s[security level in bits]:security level:' \
        '-q[quiet mode, suppress prompts]' \
        '-Q[quiet input, suppress echo of secret]' \
        '-D[disable diffusion layer]' \
        '-x[use hexadecimal mode]' \
        && ret=0
      ;;
    ssss-combine)
      _arguments -s -S \
        '-t[threshold of shares needed to reconstruct]:threshold:' \
        '-M[require shares to have a security level]' \
        '-D[disable diffusion layer]' \
        '-x[use hexadecimal mode]' \
        '-q[quiet mode, suppress prompts]' \
        '-Q[quiet input, suppress echo of shares]' \
        && ret=0
      ;;
  esac

  return ret
}

_ssss "$@"
