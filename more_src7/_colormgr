#compdef colormgr

_colormgr() {
    local context state line
    typeset -A opt_args

    _arguments -C \
        '1: :->cmd' \
        '*::arg:->args'

    case $state in
        cmd)
            local -a commands=(
                'create-device:create a device'
                'create-profile:create a profile'
                'delete-device:delete a device'
                'delete-profile:delete a profile'
                'device-add-profile:add a profile to a device'
                'device-get-default-profile:get the default profile for a device'
                'device-get-profile-for-qualifier:get profile for qualifier'
                'device-inhibit:inhibit color management for a device'
                'device-make-profile-default:make a profile default for a device'
                'device-set-enabled:enable or disable a device'
                'device-set-kind:set the kind of a device'
                'device-set-model:set the model of a device'
                'find-device:find a device by ID'
                'find-device-by-property:find a device by property'
                'find-profile:find a profile by ID'
                'find-profile-by-filename:find a profile by filename'
                'get-devices:get all devices'
                'get-devices-by-kind:get devices by kind'
                'get-profiles:get all profiles'
                'get-sensor-reading:get a sensor reading'
                'get-sensors:get all sensors'
                'get-standard-space:get a standard color space profile'
                'import-profile:import a profile'
                'sensor-lock:lock a sensor'
                'sensor-set-options:set sensor options'
            )
            _describe -t commands 'colormgr command' commands
            ;;
        args)
            case ${words[1]} in
                import-profile|find-profile-by-filename)
                    _arguments '*:profile file:_files -g "*.ic[cm](-.)"'
                    ;;
                get-devices-by-kind)
                    _arguments '1:device kind:(scanner display printer camera)'
                    ;;
                get-standard-space)
                    _arguments '1:color space:(srgb adobe-rgb)'
                    ;;
                device-set-enabled)
                    _arguments \
                        '1:device ID:' \
                        '2:enabled:(True False)'
                    ;;
            esac
            ;;
    esac
}

_colormgr "$@"
