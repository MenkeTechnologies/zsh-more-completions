#compdef flip

# Zsh completion for flip - line ending converter (DOS/Unix/Mac)

_flip() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '-d[convert to DOS line endings (CR/LF)]' \
    '-u[convert to Unix line endings (LF)]' \
    '-m[convert to Mac line endings (CR)]' \
    '-b[binary file check]' \
    '-t[test (report file types without converting)]' \
    '-v[verbose output]' \
    '*:file:_files' \
    && ret=0

  return ret
}

_flip "$@"
