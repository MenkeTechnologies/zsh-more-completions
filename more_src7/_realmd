#compdef realm

# Zsh completion for realmd - Active Directory/LDAP realm discovery and join

_realmd() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'discover:discover available realms/domains'
    'join:join a realm/domain'
    'leave:leave a realm/domain'
    'list:list joined realms'
    'permit:permit user logins from realm'
    'deny:deny user logins from realm'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*::arg:->args' \
    && ret=0

  case $state in
    command)
      _describe -t commands 'realm command' commands && ret=0
      ;;
    args)
      case ${words[1]} in
        discover)
          _arguments \
            '--verbose[show verbose discovery information]' \
            '--server-software[filter by server software]:software:' \
            '--client-software[filter by client software]:software:' \
            '--membership-software[filter by membership software]:software:' \
            '1:domain name:' \
            && ret=0
          ;;
        join)
          _arguments \
            '--user[user name for authentication]:user:' \
            '--computer-ou[organizational unit for computer account]:ou:' \
            '--computer-name[computer name to use]:name:' \
            '--os-name[OS name for computer account]:name:' \
            '--os-version[OS version for computer account]:version:' \
            '--verbose[show verbose output]' \
            '1:domain name:' \
            && ret=0
          ;;
        leave)
          _arguments \
            '--user[user name for authentication]:user:' \
            '--verbose[show verbose output]' \
            '1:domain name:' \
            && ret=0
          ;;
        permit|deny)
          _arguments \
            '--all[apply to all users]' \
            '--realm[specify the realm]:realm:' \
            '*:user:' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_realmd "$@"
