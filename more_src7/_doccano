#compdef doccano

_doccano() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'init:initialize database'
    'createuser:create a user account'
    'task:start celery worker'
    'webserver:start the web server'
    'help:show help'
  )

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1:command:->command' \
    '*::arg:->args' \
    && ret=0

  case $state in
    command)
      _describe -t commands 'doccano command' commands && ret=0
      ;;
    args)
      case ${words[1]} in
        createuser)
          _arguments \
            '--username[username]:username:' \
            '--password[password]:password:' \
            '--email[email]:email:' \
            '--noinput[no interactive input]' \
            && ret=0
          ;;
        webserver)
          _arguments \
            '--port[port number]:port:' \
            '--workers[number of workers]:workers:' \
            '--env-file[env file]:file:_files' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_doccano "$@"
