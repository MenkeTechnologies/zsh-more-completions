#compdef waagent

_waagent() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-install[install the agent]' \
        '-uninstall[uninstall the agent]' \
        '-verbose[enable verbose output]' \
        '-force[force operation]' \
        '-help[show help]' \
        '-version[show version]' \
        '-deprovision[deprovision the VM]' \
        '-deprovision+user[deprovision and delete user account]' \
        '-serialconsole[configure GRUB for serial console]' \
        '-daemon[run as daemon]' \
        '-start[start the agent]' \
        '-run-exthandlers[run extension handlers]' \
        '-show-configuration[show current configuration]' \
        '-collect-logs[collect agent logs into a zip file]'
}

_waagent "$@"
