#compdef mcomix

_mcomix() {
    local context state line
    typeset -A opt_args

    _arguments -s \
        '(-f --fullscreen)'{-f,--fullscreen}'[start in fullscreen mode]' \
        '(-s --slideshow)'{-s,--slideshow}'[start in slideshow mode]' \
        '(-l --library)'{-l,--library}'[show the library on startup]' \
        '(-w --window)'{-w,--window}'[start in windowed mode]' \
        '--no-minimize[do not minimize to tray on close]' \
        '(-d --double-page)'{-d,--double-page}'[start in double page mode]' \
        '(-m --manga)'{-m,--manga}'[start in manga mode]' \
        '(-z --zoom-best)'{-z,--zoom-best}'[use best fit zoom mode]' \
        '--zoom-fit-width[use fit width zoom mode]' \
        '--zoom-fit-height[use fit height zoom mode]' \
        '--zoom-manual[use manual zoom mode]' \
        '(- *)'{-h,--help}'[show help message]' \
        '*:file:_files'
}

_mcomix "$@"
