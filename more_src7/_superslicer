#compdef superslicer

_superslicer() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '--export-gcode[export G-code]' \
    '--export-obj[export OBJ]' \
    '--export-stl[export STL]' \
    '--export-3mf[export 3MF]' \
    '--info[show file info]' \
    '--load[load config file]:config:_files -g "*.ini"' \
    '--merge[merge loaded files]' \
    '--output[output file]:file:_files' \
    '--repair[repair model]' \
    '--rotate[rotate around Z axis]:degrees:' \
    '--rotate-x[rotate around X axis]:degrees:' \
    '--rotate-y[rotate around Y axis]:degrees:' \
    '--scale[scale factor]:factor:' \
    '--scale-to-fit[scale to fit volume]:WxHxD:' \
    '--center[center object]:X,Y:' \
    '--align-xy[align to XY]:X,Y:' \
    '--cut[cut at Z height]:height:' \
    '--split[split into parts]' \
    '--loglevel[log level]:level:(0 1 2 3 4 5)' \
    '--datadir[data directory]:dir:_files -/' \
    "--dont-arrange[don't arrange objects]" \
    '--single-instance[allow single instance only]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '*:input file:_files -g "*.{stl,obj,amf,3mf,step,stp}"' \
    && ret=0

  return ret
}

_superslicer "$@"
