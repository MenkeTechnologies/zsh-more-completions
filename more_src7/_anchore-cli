#compdef anchore-cli

# Zsh completion for anchore-cli - container security scanning CLI

_anchore-cli() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'image:image operations'
    'evaluate:evaluate image policy compliance'
    'policy:policy management'
    'subscription:subscription management'
    'registry:registry credential management'
    'repo:repository operations'
    'system:system operations'
    'account:account management'
    'analysis-archive:analysis archive operations'
    'event:event operations'
  )

  _arguments -s -S \
    '--url[Anchore Engine API URL]:URL:_urls' \
    '--u[username]:username:' \
    '--p[password]:password:' \
    '--json[output in JSON format]' \
    '--debug[enable debug output]' \
    '1:command:->command' \
    '*::arg:->args' \
    && ret=0

  case $state in
    command)
      _describe -t commands 'anchore-cli command' commands && ret=0
      ;;
    args)
      case ${words[1]} in
        image)
          local -a image_commands=(
            'add:add an image for analysis'
            'del:delete an image'
            'get:get image details'
            'list:list analyzed images'
            'wait:wait for image analysis to complete'
            'vuln:show image vulnerabilities'
            'content:show image content'
          )
          _describe -t image-commands 'image command' image_commands && ret=0
          ;;
        policy)
          local -a policy_commands=(
            'add:add a policy bundle'
            'del:delete a policy bundle'
            'get:get a policy bundle'
            'list:list policy bundles'
            'activate:activate a policy bundle'
          )
          _describe -t policy-commands 'policy command' policy_commands && ret=0
          ;;
        subscription)
          local -a sub_commands=(
            'activate:activate a subscription'
            'deactivate:deactivate a subscription'
            'del:delete a subscription'
            'get:get subscription details'
            'list:list subscriptions'
          )
          _describe -t sub-commands 'subscription command' sub_commands && ret=0
          ;;
        registry)
          local -a registry_commands=(
            'add:add registry credentials'
            'del:delete registry credentials'
            'get:get registry credentials'
            'list:list registries'
            'update:update registry credentials'
          )
          _describe -t registry-commands 'registry command' registry_commands && ret=0
          ;;
        system)
          local -a system_commands=(
            'feeds:show feed sync status'
            'status:show system status'
            'wait:wait for system to be ready'
            'del:delete system resources'
          )
          _describe -t system-commands 'system command' system_commands && ret=0
          ;;
        evaluate)
          _arguments \
            '--detail[show detailed output]' \
            '--policy[policy bundle ID]:policy ID:' \
            '--tag[image tag]:tag:' \
            '1:image reference:' \
            && ret=0
          ;;
        repo)
          local -a repo_commands=(
            'add:add a repository to watch'
            'del:delete a watched repository'
            'get:get repository details'
            'list:list watched repositories'
            'watch:enable repository watching'
            'unwatch:disable repository watching'
          )
          _describe -t repo-commands 'repo command' repo_commands && ret=0
          ;;
        account)
          local -a account_commands=(
            'add:add an account'
            'del:delete an account'
            'get:get account details'
            'list:list accounts'
            'enable:enable an account'
            'disable:disable an account'
            'whoami:show current account'
          )
          _describe -t account-commands 'account command' account_commands && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_anchore-cli "$@"
