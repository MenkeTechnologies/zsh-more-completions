#compdef parcimonie

_parcimonie() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '--gnupg-binary[path to gpg binary]:binary:_files -g "*gpg*"' \
    '--gnupg-homedir[GnuPG home directory]:dir:_files -/' \
    '--gnupg-keyserver[keyserver to use]:keyserver:' \
    '--gnupg-extra-args[extra arguments for gpg]:args:' \
    '--torsocks-binary[path to torsocks binary]:binary:_files' \
    '--torsocks-extra-args[extra torsocks arguments]:args:' \
    '--min-wait-time[minimum wait between refreshes]:seconds:' \
    '--avg-wait-time[average wait between refreshes]:seconds:' \
    '--tmpdir[temporary directory]:dir:_files -/' \
    '--verbose[be verbose]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

  return ret
}

_parcimonie "$@"
