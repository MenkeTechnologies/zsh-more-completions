#compdef pptx2md
# Documentation: https://github.com/ssine/pptx2md
# Convert PowerPoint files to Markdown

_arguments -s -S \
  '-o[output file]:output:_files' \
  '--image-dir[directory for extracted images]:directory:_files -/' \
  '--disable-image[do not extract images]' \
  '--disable-color[do not include color]' \
  '--disable-escaping[do not escape special characters]' \
  '--wiki[output in wiki format]' \
  '--min-block-size[minimum block size]:size:' \
  '*:PPTX files:_files -g "*.pptx *.ppt"' \
  && return 0
