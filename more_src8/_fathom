#compdef fathom
# Documentation: https://usefathom.com/
# Privacy-focused website analytics

_fathom() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'server:start the web server'
    'user:manage users'
    'site:manage sites'
    'stats:show statistics'
  )

  _arguments -s -S \
    '--config[config file]:config:_files' \
    '-h[show help]' \
    '1:command:->command' \
    '*::arg:->args' && ret=0

  case $state in
    command)
      _describe -t commands 'fathom command' commands && ret=0
      ;;
    args)
      case ${words[1]} in
        server)
          _arguments \
            '--addr[listen address]:address:' \
            '--debug[debug mode]' \
            && ret=0
          ;;
        user)
          _arguments \
            '1:action:(add delete)' \
            '--email[user email]:email:' \
            '--password[user password]:password:' \
            && ret=0
          ;;
        site)
          _arguments \
            '1:action:(add rm ls)' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_fathom "$@"
