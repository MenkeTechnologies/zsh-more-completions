#compdef lldap
# Documentation: https://github.com/lldap/lldap
# Light LDAP server for authentication

_arguments -s -S \
  '--config[config file]:config:_files' \
  '--ldap-host[LDAP listen host]:host:_hosts' \
  '--ldap-port[LDAP listen port]:port:' \
  '--http-host[HTTP listen host]:host:_hosts' \
  '--http-port[HTTP listen port]:port:' \
  '--database-url[database URL]:url:' \
  '--verbose[verbose output]' \
  '-h[show help]' \
  '-V[show version]' \
  && return 0
