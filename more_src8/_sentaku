#compdef sentaku
# Documentation: https://github.com/rcmdnk/sentaku
# Terminal-based interactive selection utility

_arguments -s -S \
  '-s[separator]:separator:' \
  '-H[header lines to skip]:count:' \
  '-N[no number display]' \
  '-r[reverse display order]' \
  '-m[multi-select mode]' \
  '-n[number of lines to display]:lines:' \
  '-c[command to execute on selection]:command:' \
  '-p[use pager mode]' \
  '-i[case-insensitive search]' \
  && return 0
