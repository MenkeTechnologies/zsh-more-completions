#compdef archey
# Documentation: https://github.com/HorlogeSkyworker/archey4
# System information display with ASCII art

_arguments -s -S \
  '(-j --json)'{-j,--json}'[output as JSON]' \
  '(-s --screenshot)'{-s,--screenshot}'[take a screenshot]:path:_files -/' \
  '(-c --config-path)'{-c,--config-path}'[path to config file]:config:_files' \
  '(-d --distro)'{-d,--distro}'[manually specify distribution]:distro:' \
  '(-l --logo-style)'{-l,--logo-style}'[logo style]:style:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  && return 0
