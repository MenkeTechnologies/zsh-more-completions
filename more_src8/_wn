#compdef wn
# Documentation: https://wordnet.princeton.edu/documentation
# WordNet lexical database lookup

_arguments -s -S \
  '-h[show help]' \
  '-g[display gloss (definition)]' \
  '-syns{n,v,a,r}[display synonyms]' \
  '-ants{n,v,a,r}[display antonyms]' \
  '-hype{n,v}[display hypernyms]' \
  '-hypo{n,v}[display hyponyms]' \
  '-mero{n}[display meronyms]' \
  '-holo{n}[display holonyms]' \
  '-over[overview of senses]' \
  '-n[search noun database]:count:' \
  '-a[search adjective database]' \
  '-v[search verb database]' \
  '-r[search adverb database]' \
  '*:word:' \
  && return 0
