#compdef jellyfish
# Documentation: https://github.com/gmarcais/Jellyfish
# Jellyfish: fast, memory-efficient k-mer counting

_jellyfish() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'count:count k-mers in FASTA/FASTQ files'
    'merge:merge multiple jellyfish databases'
    'dump:dump k-mer counts to text'
    'stats:print statistics of k-mer count database'
    'histo:create histogram of k-mer occurrences'
    'query:query k-mer counts from a database'
    'info:display information about a jellyfish database'
    'bc:count k-mers using a bloom counter'
    'cite:print citation information'
    'mem:estimate memory usage for counting'
  )

  _arguments -s -S -C \
    '1:command:->command' \
    '*::arg:->args' && ret=0

  case $state in
    command)
      _describe -t commands 'jellyfish command' commands && ret=0
      ;;
    args)
      case ${words[1]} in
        count)
          _arguments -s -S \
            '-m[mer/k-mer length]:length:' \
            '-s[initial hash size]:size:' \
            '-t[number of threads]:threads:' \
            '-C[count canonical k-mers (both strands)]' \
            '-o[output file]:output:_files' \
            '-c[length of counting field in bits]:bits:' \
            '-L[do not output k-mers with count less than]:lower:' \
            '-U[do not output k-mers with count greater than]:upper:' \
            '--disk[use disk storage to reduce memory usage]' \
            '(-g --generator)'{-g,--generator}'[command to generate sequences]:command:' \
            '-G[number of generator processes]:generators:' \
            '--out-counter-len[length of output counter field in bytes]:bytes:' \
            '--text[output in text format]' \
            '*:input files:_files -g "*.fa *.fasta *.fq *.fastq *.fa.gz *.fasta.gz *.fq.gz *.fastq.gz"' \
            && ret=0
          ;;
        merge)
          _arguments -s -S \
            '-o[output file]:output:_files' \
            '*:jellyfish databases:_files' \
            && ret=0
          ;;
        dump)
          _arguments -s -S \
            '-c[column format (tab-separated)]' \
            '-t[tab-separated format]' \
            '-L[lower count threshold]:lower:' \
            '-U[upper count threshold]:upper:' \
            '-o[output file]:output:_files' \
            '*:jellyfish database:_files' \
            && ret=0
          ;;
        stats)
          _arguments -s -S \
            '*:jellyfish database:_files' \
            && ret=0
          ;;
        histo)
          _arguments -s -S \
            '-l[low count threshold]:lower:' \
            '-h[high count threshold]:upper:' \
            '-i[bin increment]:increment:' \
            '-t[number of threads]:threads:' \
            '-o[output file]:output:_files' \
            '-f[full histogram (include zero count)]' \
            '*:jellyfish database:_files' \
            && ret=0
          ;;
        query)
          _arguments -s -S \
            '-s[query sequence]:sequence:' \
            '*:jellyfish database:_files' \
            && ret=0
          ;;
        info)
          _arguments -s -S \
            '*:jellyfish database:_files' \
            && ret=0
          ;;
        mem)
          _arguments -s -S \
            '-m[mer/k-mer length]:length:' \
            '-s[estimated number of distinct k-mers]:count:' \
            '-c[length of counting field in bits]:bits:' \
            '--text[output in text format]' \
            && ret=0
          ;;
        bc)
          _arguments -s -S \
            '-m[mer/k-mer length]:length:' \
            '-s[hash size]:size:' \
            '-t[number of threads]:threads:' \
            '-C[count canonical k-mers]' \
            '-o[output file]:output:_files' \
            '*:input files:_files -g "*.fa *.fasta *.fq *.fastq *.fa.gz *.fasta.gz *.fq.gz *.fastq.gz"' \
            && ret=0
          ;;
        cite)
          ret=0
          ;;
        *)
          _default && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_jellyfish "$@"
