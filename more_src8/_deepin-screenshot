#compdef deepin-screenshot
# Documentation: https://github.com/linuxdeepin/deepin-screenshot
# Deepin desktop screenshot tool

_arguments -s -S \
  '-s[save to directory]:directory:_files -/' \
  '-f[fullscreen mode]' \
  '-d[delay in seconds]:seconds:' \
  '-n[no notification]' \
  '-h[show help]' \
  && return 0
