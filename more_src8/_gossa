#compdef gossa
# Documentation: https://github.com/pldubouilh/gossa
# Fast minimal file server

_arguments -s -S \
  '-h[host to bind to]:host:_hosts' \
  '-p[port to listen on]:port:' \
  '-s[symlinks allowed]' \
  '-ro[read-only mode]' \
  '-verb[verbose logging]' \
  '-k[TLS key file]:key:_files' \
  '-c[TLS cert file]:cert:_files' \
  '-prefix[URL prefix]:prefix:' \
  '*:directory:_files -/' \
  && return 0
