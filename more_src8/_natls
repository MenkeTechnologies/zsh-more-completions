#compdef natls
# Documentation: https://github.com/willdoescode/nat
# Alternative ls with colors and icons

_arguments -s -S \
  '-l[long format]' \
  '-a[show hidden files]' \
  '-la[long format with hidden files]' \
  '-al[long format with hidden files]' \
  '-h[show help]' \
  '-v[show version]' \
  '*:files:_files' \
  && return 0
