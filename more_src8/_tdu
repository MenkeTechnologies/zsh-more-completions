#compdef tdu
# Documentation: https://github.com/josephpaul0/tdu
# Terminal disk usage analyzer

_arguments -s -S \
  '-a[show all files, not just directories]' \
  '-b[print sizes in bytes]' \
  '-c[colorize output]' \
  '-d[maximum depth]:depth:' \
  '-h[human-readable sizes]' \
  '*:directory:_files -/' \
  && return 0
