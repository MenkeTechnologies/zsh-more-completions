#compdef inferno-collapse-sample

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help information]' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '--no-extras[exclude extra sample info from output]' \
  '--nthreads=[number of threads to use]:threads:' \
  '*:input file:_files' \
  && return 0
