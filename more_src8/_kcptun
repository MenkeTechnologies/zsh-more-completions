#compdef kcptun client_linux_amd64 server_linux_amd64
# Documentation: https://github.com/xtaci/kcptun
# Secure tunnel based on KCP protocol

_arguments -s -S \
  '-l[local listen address]:address:' \
  '-r[remote server address]:address:' \
  '--key[pre-shared secret]:key:' \
  '--crypt[encryption method]:method:(aes aes-128 aes-192 salsa20 blowfish twofish cast5 3des tea xtea xor sm4 none)' \
  '--mode[KCP mode]:mode:(fast3 fast2 fast normal manual)' \
  '--conn[number of UDP connections]:connections:' \
  '--mtu[maximum transmission unit]:mtu:' \
  '--sndwnd[send window size]:window:' \
  '--rcvwnd[receive window size]:window:' \
  '--dscp[DSCP value]:dscp:' \
  '--nocomp[disable compression]' \
  '--sockbuf[socket buffer size]:size:' \
  '--keepalive[keepalive interval]:seconds:' \
  '--log[log file]:logfile:_files' \
  '--snmplog[SNMP log file]:logfile:_files' \
  '--tcp[tunnel TCP instead of raw KCP]' \
  '--pprof[enable profiling on port]:port:' \
  '-c[config file]:config:_files' \
  '-v[show version]' \
  && return 0
