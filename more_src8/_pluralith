#compdef pluralith
# Documentation: https://www.pluralith.com/
# Terraform infrastructure visualization

_pluralith() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'init:initialize Pluralith in project'
    'plan:run Terraform plan with visualization'
    'apply:run Terraform apply with visualization'
    'graph:generate infrastructure graph'
    'login:authenticate with Pluralith'
    'logout:log out from Pluralith'
    'version:show version'
  )

  _arguments -s -S \
    '--api-key[API key]:key:' \
    '--project-id[project ID]:id:' \
    '--config[config file]:config:_files' \
    '-h[show help]' \
    '1:command:->command' \
    '*::arg:->args' && ret=0

  case $state in
    command)
      _describe -t commands 'pluralith command' commands && ret=0
      ;;
    args)
      case ${words[1]} in
        plan|apply)
          _arguments \
            '--title[diagram title]:title:' \
            '--var-file[var file]:file:_files' \
            '--cost-usage-file[usage file]:file:_files' \
            '--show-costs[show cost estimates]' \
            '--show-changes[highlight changes]' \
            && ret=0
          ;;
        graph)
          _arguments \
            '--title[diagram title]:title:' \
            '--out[output file]:file:_files' \
            '--format[output format]:format:(pdf png svg)' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_pluralith "$@"
