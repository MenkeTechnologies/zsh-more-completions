#compdef paisa
# Documentation: https://github.com/ananthakumaran/paisa
# Personal finance manager with plain text accounting

_paisa() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'serve:start web server'
    'update:update prices'
    'init:initialize a new ledger'
    'completion:generate shell completions'
  )

  _arguments -s -S \
    '--config[config file]:config:_files' \
    '-h[show help]' \
    '--version[show version]' \
    '1:command:->command' \
    '*::arg:->args' && ret=0

  case $state in
    command)
      _describe -t commands 'paisa command' commands && ret=0
      ;;
    args)
      case ${words[1]} in
        serve)
          _arguments \
            '--port[port to listen on]:port:' \
            '--host[host to bind to]:host:_hosts' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_paisa "$@"
