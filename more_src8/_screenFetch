#compdef screenFetch
# Documentation: https://github.com/KittyKatt/screenFetch
# System information display with ASCII art

_arguments -s -S \
  '-v[verbose output]' \
  '-o[set distro detection override]:distro:' \
  '-n[no ASCII art, display info only]' \
  '-N[strip color from output]' \
  '-t[truncate output based on terminal width]' \
  '-p[portrait output mode]' \
  '-s[take screenshot after displaying info]' \
  '-c[set color scheme]:colors:' \
  '-a[set ASCII art file]:file:_files' \
  '-S[set screenshot command]:command:' \
  '-D[set distro logo]:distro:' \
  '-A[set ASCII art to distro]:distro:' \
  '-E[suppress errors]' \
  '-V[display version]' \
  '-h[display help]' \
  && return 0
