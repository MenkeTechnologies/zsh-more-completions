#compdef bonnie
# Documentation: https://www.coker.com.au/bonnie++/
# Filesystem benchmark tool

_arguments -s -S \
  '-d[directory for test files]:directory:_files -/' \
  '-s[file size for IO tests]:size:' \
  '-n[number of files for create/stat/unlink tests]:count:' \
  '-m[machine name for output]:name:' \
  '-r[RAM size in MB]:ram:' \
  '-x[number of test runs]:runs:' \
  '-u[user to run as]:user:_users' \
  '-g[group to run as]:group:_groups' \
  '-q[quiet mode]' \
  '-p[number of preallocated files]:count:' \
  '-b[no write buffering]' \
  '-D[use direct IO]' \
  '-f[fast mode, skip per-char IO tests]' \
  '-z[seed for random number generator]:seed:' \
  '-Z[enable zero buffers mode]' \
  && return 0
