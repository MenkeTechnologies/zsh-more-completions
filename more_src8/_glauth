#compdef glauth
# Documentation: https://github.com/glauth/glauth
# Lightweight LDAP server for testing and development

_arguments -s -S \
  '-c[config file]:config:_files' \
  '--ldap[LDAP listen address]:address:' \
  '--ldaps[LDAPS listen address]:address:' \
  '--version[show version]' \
  && return 0
