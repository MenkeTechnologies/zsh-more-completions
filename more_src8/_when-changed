#compdef when-changed
# Documentation: https://github.com/joh/when-changed
# Run a command when files change

_arguments -s -S \
  '-r[recursively watch directories]' \
  '-v[verbose output]' \
  '-1[run command once and exit]' \
  '-s[use polling instead of inotify]' \
  '-q[quiet mode, suppress output from when-changed]' \
  '*:files to watch:_files' \
  && return 0
