#compdef pyprland
# Documentation: https://github.com/hyprland-community/pyprland
# Pyprland: plugin system for Hyprland

_pyprland() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'init:initialize pyprland configuration'
    'reload:reload pyprland configuration'
    'version:show version information'
  )

  _arguments -s -S -C \
    '(-h --help)'{-h,--help}'[show help message]' \
    '1:command:->command' && ret=0

  case $state in
    command)
      _describe -t commands 'pyprland command' commands && ret=0
      ;;
  esac

  return ret
}

_pyprland "$@"
