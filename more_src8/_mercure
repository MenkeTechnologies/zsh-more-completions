#compdef mercure
# Documentation: https://mercure.rocks/docs
# Real-time push protocol server

_arguments -s -S \
  '--addr[listen address]:address:' \
  '--transport-url[transport URL]:url:' \
  '--jwt-key[JWT secret key]:key:' \
  '--publisher-jwt-key[publisher JWT key]:key:' \
  '--subscriber-jwt-key[subscriber JWT key]:key:' \
  '--cors-allowed-origins[allowed CORS origins]:origins:' \
  '--publish-allowed-origins[publish allowed origins]:origins:' \
  '--compress[enable compression]' \
  '--debug[debug mode]' \
  '--log-format[log format]:format:(json text)' \
  '--demo[enable demo mode]' \
  '--subscriptions[enable subscriptions]' \
  '--write-timeout[write timeout]:duration:' \
  '--read-timeout[read timeout]:duration:' \
  '--dispatch-timeout[dispatch timeout]:duration:' \
  '--heartbeat-interval[heartbeat interval]:duration:' \
  '--cert-file[TLS certificate]:cert:_files' \
  '--key-file[TLS key]:key:_files' \
  && return 0
