#compdef dockfmt
# Documentation: https://github.com/jessfraz/dockfmt
# Dockerfile formatter

_dockfmt() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'base:list base images in Dockerfiles'
    'dump:dump parsed Dockerfile AST'
    'fmt:format Dockerfiles'
    'maintainer:list maintainers in Dockerfiles'
    'workdir:list workdirs in Dockerfiles'
  )

  _arguments -s -S \
    '-D[enable debug logging]' \
    '-v[show version]' \
    '1:command:->command' \
    '*::arg:->args' && ret=0

  case $state in
    command)
      _describe -t commands 'dockfmt command' commands && ret=0
      ;;
    args)
      _arguments '*:Dockerfiles:_files -g "Dockerfile*"' && ret=0
      ;;
  esac

  return ret
}

_dockfmt "$@"
