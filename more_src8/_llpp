#compdef llpp
# Documentation: https://github.com/moosotc/llpp
# Lightweight PDF and DJVU viewer using MuPDF

_arguments -s -S \
  '-c[config file]:config:_files' \
  '-p[remote command pipe path]:pipe:_files' \
  '-C[CSS to use]:css:' \
  '-v[show version]' \
  '*:PDF/DJVU files:_files -g "*.pdf *.djvu *.djv *.xps *.cbz *.epub *.fb2"' \
  && return 0
