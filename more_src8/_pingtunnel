#compdef pingtunnel
# Documentation: https://github.com/esrrhs/pingtunnel
# Tunnel TCP/UDP/SOCKS5 over ICMP

_arguments -s -S \
  '-type[run mode]:mode:(server client)' \
  '-l[local listen address]:address:' \
  '-s[server address]:server:_hosts' \
  '-t[target address]:target:' \
  '-tcp[forward TCP connections]:bool:(0 1)' \
  '-sock5[enable SOCKS5 proxy]:bool:(0 1)' \
  '-noprint[disable log output]:bool:(0 1)' \
  '-nolog[disable log file]:bool:(0 1)' \
  '-loglevel[log level]:level:(0 1 2 3 4)' \
  '-key[password]:password:' \
  '-catch[catch ICMP packets]:bool:(0 1)' \
  && return 0
