#compdef cudatext
# Documentation: https://cudatext.github.io/
# Cross-platform code editor

_arguments -s -S \
  '-n[open new window]' \
  '-ns[open new instance in single-instance mode]' \
  '-nh[disable plugins at startup]' \
  '-z[open file and scroll to end]' \
  '-r[open file as read-only]' \
  '-e[set encoding]:encoding:' \
  '-el[set line endings]:ending:(lf crlf cr)' \
  '*:files:_files' \
  && return 0
