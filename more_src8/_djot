#compdef djot
# Documentation: https://github.com/jgm/djot
# Djot markup language tool

_arguments -s -S \
  '(-f --from)'{-f,--from}'[input format]:format:(djot)' \
  '(-t --to)'{-t,--to}'[output format]:format:(html djot ast)' \
  '(-o --output)'{-o,--output}'[output file]:output:_files' \
  '(-p --passthrough)'{-p,--passthrough}'[pass through raw content]' \
  '--sourcepos[include source positions in AST]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:input files:_files' \
  && return 0
