#compdef tmatrix
# Documentation: https://github.com/M4444/TMatrix
# Terminal-based Matrix rain effect

_arguments -s -S \
  '-s[characters per second (0-100)]:speed:' \
  '-f[characters fall speed (0-100)]:fall:' \
  '-c[color]:color:(default green red blue yellow magenta cyan white)' \
  '-t[title for the window]:title:' \
  '-C[use CJK characters]' \
  '-g[gap between columns]:gap:' \
  '-h[show help]' \
  '-v[show version]' \
  && return 0
