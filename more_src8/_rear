#compdef rear
# Documentation: https://relax-and-recover.org/documentation/
# Relax-and-Recover bare metal disaster recovery

_arguments -s -S \
  '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '(-D --debugscripts)'{-D,--debugscripts}'[debug with set -x]' \
  '(-S --simulate)'{-S,--simulate}'[simulation mode]' \
  '(-s --step-by-step)'{-s,--step-by-step}'[step-by-step mode]' \
  '(-n --non-interactive)'{-n,--non-interactive}'[non-interactive mode]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-r --recovery-mode)'{-r,--recovery-mode}'[use recovery mode]' \
  '(-C --config)'{-C,--config}'[config file]:config:_files' \
  '1:workflow:(mkbackup mkrescue recover restoreonly validate checklayout mkbackuponly mkopalpba mountonly opaladmin dump savelayout)' \
  && return 0
