#compdef xhtml2pdf
# Documentation: https://xhtml2pdf.readthedocs.io/
# Convert HTML/XHTML to PDF

_arguments -s -S \
  '-s[page size]:size:(A0 A1 A2 A3 A4 A5 A6 letter legal)' \
  '-o[output file]:output:_files' \
  '-d[debug mode]' \
  '-q[quiet mode]' \
  '--css[additional CSS file]:css:_files -g "*.css"' \
  '--encoding[input encoding]:encoding:' \
  '-h[show help]' \
  '--version[show version]' \
  '*:HTML files:_files -g "*.html *.xhtml *.htm"' \
  && return 0
