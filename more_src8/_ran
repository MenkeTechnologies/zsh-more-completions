#compdef ran
# Documentation: https://github.com/nicholasgasior/ran
# Simple static web server in Go

_arguments -s -S \
  '-p[listen port]:port:' \
  '-r[root directory]:directory:_files -/' \
  '-listdir[enable directory listing]' \
  '-404[custom 404 page]:file:_files' \
  '-tls-cert[TLS certificate]:cert:_files' \
  '-tls-key[TLS key]:key:_files' \
  '-auth[basic auth]:user\:pass:' \
  && return 0
