#compdef moro
# Documentation: https://github.com/getmoro/moro
# moro: CLI tool for tracking work hours (npm)

_moro() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'hi:clock in (optionally with a time like 9:00)'
    'bye:clock out (optionally with a time like 17:00)'
    'status:show today'\''s work status'
    'report:display a report of logged hours'
    'clear:clear all data'
    'config:configure settings'
    'note:add a note to the current day'
  )

  _arguments -s -S -C \
    '1:command:->command' \
    '*::arg:->args' && ret=0

  case $state in
    command)
      _describe -t commands 'moro command' commands && ret=0
      ;;
    args)
      case ${words[1]} in
        hi|bye)
          _message 'time (e.g. 9:00, 17:30)'
          ret=0
          ;;
        note)
          _message 'note text'
          ret=0
          ;;
        config)
          _message 'key value'
          ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_moro "$@"
