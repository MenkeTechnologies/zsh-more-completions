#compdef mkvtoolnix-gui
# Documentation: https://mkvtoolnix.download/
# MKVToolNix GUI for Matroska multimedia container tools

_arguments -s -S \
  '--edit-headers[open header editor for file]:file:_files -g "*.mkv *.mka *.mks *.mk3d *.webm"' \
  '--merge[open merge tool with files]:file:_files' \
  '--info[open info tool with file]:file:_files -g "*.mkv *.mka *.mks *.mk3d *.webm"' \
  '*:files:_files' \
  && return 0
