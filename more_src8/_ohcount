#compdef ohcount
# Documentation: https://github.com/blackducksoftware/ohcount
# Source code line counter

_arguments -s -S \
  '-a[annotate source code]' \
  '-d[show detected languages]' \
  '-e[show file extensions]' \
  '-h[show help]' \
  '-i[individual file analysis]' \
  '-l[show language summary]' \
  '-s[summary mode]' \
  '*:files or directories:_files' \
  && return 0
