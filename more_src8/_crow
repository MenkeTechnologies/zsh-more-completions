#compdef crow
# Documentation: https://github.com/nicedoc/crow
# Translate text from terminal using multiple engines

_arguments -s -S \
  '-e[translation engine]:engine:(google yandex bing)' \
  '-s[source language]:language:' \
  '-t[target language]:language:' \
  '-b[brief output]' \
  '-h[show help]' \
  '*:text to translate:' \
  && return 0
