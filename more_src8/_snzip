#compdef snzip snunzip
# Documentation: https://github.com/kubo/snzip
# Snappy compression tool

_arguments -s -S \
  '-d[decompress]' \
  '-c[write to stdout]' \
  '-k[keep input files]' \
  '-t[file format]:format:(snzip framing2 snappy-in-java snappy-java hadoop-snappy)' \
  '-h[show help]' \
  '*:files:_files' \
  && return 0
