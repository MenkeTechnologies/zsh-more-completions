#compdef utt
# Documentation: https://github.com/larose/utt
# Ultimate Time Tracker

_utt() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'hello:start tracking time'
    'stretch:continue previous task'
    'report:show time report'
    'edit:edit time entries'
  )

  _arguments -s -S \
    '--data[data directory]:directory:_files -/' \
    '--now[set current time]:time:' \
    '-h[show help]' \
    '--version[show version]' \
    '1:command:->command' \
    '*::arg:->args' && ret=0

  case $state in
    command)
      _describe -t commands 'utt command' commands && ret=0
      ;;
    args)
      case ${words[1]} in
        report)
          _arguments \
            '--from[start date]:date:' \
            '--to[end date]:date:' \
            '--current-activity[name of current activity]:activity:' \
            '--no-current-activity[do not show current activity]' \
            '--per-day[show per-day breakdown]' \
            && ret=0
          ;;
        hello|stretch)
          _arguments \
            '*:task name:' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_utt "$@"
