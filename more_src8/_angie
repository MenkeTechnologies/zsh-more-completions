#compdef angie
# Documentation: https://angie.software/en/
# Drop-in Nginx replacement web server

_arguments -s -S \
  '-c[config file]:config:_files' \
  '-e[error log file]:log:_files' \
  '-g[global directives]:directives:' \
  '-p[prefix path]:path:_files -/' \
  '-q[suppress non-error messages during config test]' \
  '-s[send signal to main process]:signal:(stop quit reopen reload)' \
  '-t[test configuration]' \
  '-T[test configuration and dump it]' \
  '-v[show version]' \
  '-V[show version and configure options]' \
  && return 0
