#compdef tilde
# Documentation: https://os.ghalber.nl/tilde/
# Terminal text editor with intuitive key bindings

_arguments -s -S \
  '-c[config directory]:directory:_files -/' \
  '-e[set encoding]:encoding:' \
  '-h[show help]' \
  '-T[set terminal type]:terminal:' \
  '-v[show version]' \
  '*:files:_files' \
  && return 0
