#compdef osync
# Documentation: https://github.com/deajan/osync
# Robust two-way file synchronization

_arguments -s -S \
  '--initiator[initiator replica path]:path:_files -/' \
  '--target[target replica path]:path:' \
  '--config-file[configuration file]:config:_files' \
  '--dry[dry run, simulate only]' \
  '--silent[silent mode]' \
  '--verbose[verbose output]' \
  '--no-maxtime[disable max execution time]' \
  '--force-unlock[force remove lock]' \
  '--on-changes[daemon mode, run on file changes]' \
  '--errors-only[log only errors]' \
  '--summary[print summary]' \
  '--no-prefix[do not add date/host prefix to logs]' \
  '--instance-id[instance identifier]:id:' \
  && return 0
