#compdef aid eid fid
# Documentation: https://www.gnu.org/software/idutils/
# GNU ID utilities for indexing and searching source code

_arguments -s -S \
  '(-f --file)'{-f,--file}'[ID database file]:file:_files' \
  '(-k --key-style)'{-k,--key-style}'[key display style]:style:(none token number)' \
  '(-R --result)'{-R,--result}'[result style]:style:(filenames grep edit)' \
  '(-s --separator)'{-s,--separator}'[separator for results]:sep:' \
  '--help[show help]' \
  '--version[show version]' \
  '*:pattern:' \
  && return 0
