#compdef devhelp
# Documentation: https://wiki.gnome.org/Apps/Devhelp
# GNOME developer documentation browser

_arguments -s -S \
  '-s[search for term]:term:' \
  '--search[search for term]:term:' \
  '--version[show version]' \
  '-h[show help]' \
  '*:devhelp book:_files -g "*.devhelp2"' \
  && return 0
