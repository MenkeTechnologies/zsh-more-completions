#compdef fuse-zip
# Documentation: https://bitbucket.org/agalanin/fuse-zip
# Mount ZIP archives as FUSE filesystems

_arguments -s -S \
  '-r[read-only mode]' \
  '-f[run in foreground]' \
  '-d[enable debug output]' \
  '-o[mount options]:options:' \
  '1:ZIP archive:_files -g "*.zip"' \
  '2:mount point:_files -/' \
  && return 0
