#compdef SubtitleEdit subtitleedit
# Documentation: https://www.nikse.dk/subtitleedit
# Subtitle editor and converter

_arguments -s -S \
  '/convert[convert subtitle format]:' \
  '/inputfolder[input folder]:folder:_files -/' \
  '/outputfolder[output folder]:folder:_files -/' \
  '/overwrite[overwrite existing files]' \
  '/encoding[set encoding]:encoding:' \
  '/fps[set frame rate]:fps:' \
  '/removetextforhi[remove text for hearing impaired]' \
  '/fixcommonerrors[fix common errors]' \
  '*:subtitle files:_files -g "*.srt *.ass *.ssa *.sub *.idx *.vtt *.smi *.sbv"' \
  && return 0
