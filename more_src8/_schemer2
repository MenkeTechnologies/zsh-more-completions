#compdef schemer2
# Documentation: https://github.com/thefryscorer/schemer2
# Generate color schemes from images

_arguments -s -S \
  '-format[output format]:format:(hex rgb)' \
  '-in[input image file]:image:_files' \
  '-out[output file]:output:_files' \
  '*:image files:_files -g "*.png *.jpg *.jpeg *.bmp *.gif *.tiff"' \
  && return 0
