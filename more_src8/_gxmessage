#compdef gxmessage
# Documentation: https://trmuber.net/gxmessage/
# GTK xmessage clone for displaying dialog boxes

_arguments -s -S \
  '-bg[background color]:color:' \
  '-borderless[remove window border]' \
  '-buttons[set buttons]:buttons:' \
  '-center[center window on screen]' \
  '-default[set default button]:button:' \
  '-entry[enable text entry]' \
  '-entrytext[default entry text]:text:' \
  '-file[read message from file]:file:_files' \
  '-fn[font]:font:' \
  '-font[font]:font:' \
  '-fg[foreground color]:color:' \
  '-geometry[window geometry]:geometry:' \
  '-help[show help]' \
  '-name[application name]:name:' \
  '-nearmouse[position near mouse cursor]' \
  '-noescape[do not close on Escape key]' \
  '-nofocus[do not focus window]' \
  '-print[print button label to stdout]' \
  '-sticky[make window sticky]' \
  '-timeout[auto-close timeout]:seconds:' \
  '-title[window title]:title:' \
  '-version[show version]' \
  '-wrap[wrap text]' \
  '-ontop[keep window on top]' \
  '*:message text:' \
  && return 0
