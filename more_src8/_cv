#compdef cv
# Documentation: https://github.com/Xfennec/progress
# cv (progress): monitor progress of coreutils commands (cp, mv, dd, etc.)

_arguments -s -S \
  '(-m --monitor)'{-m,--monitor}'[loop and monitor all running processes]' \
  '(-M --monitor-continuously)'{-M,--monitor-continuously}'[like --monitor but never stop]' \
  '(-p --pid)'{-p,--pid}'[monitor specific process by PID]:pid:_pids' \
  '(-c --command)'{-c,--command}'[monitor specific command name]:command name:' \
  '(-w --wait)'{-w,--wait}'[estimate remaining time and wait until completion]' \
  '(-W --wait-delay)'{-W,--wait-delay}'[set refresh delay in seconds for --wait]:seconds:' \
  '(-a --additional-command)'{-a,--additional-command}'[add additional command to monitor]:command name:' \
  '(-d --throughput)'{-d,--throughput}'[display throughput]' \
  '(-n --estimated-size)'{-n,--estimated-size}'[estimated file size]:size:' \
  '(-l --line-mode)'{-l,--line-mode}'[count lines instead of bytes]' \
  '(-q --quiet)'{-q,--quiet}'[hide all output]' \
  '(-s --spinners)'{-s,--spinners}'[show spinners for monitored processes]' \
  '(-i --idle)'{-i,--idle}'[display idle processes too]' \
  '(-o --open-mode)'{-o,--open-mode}'[monitor file open mode]:mode:(r w)' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  && return 0
