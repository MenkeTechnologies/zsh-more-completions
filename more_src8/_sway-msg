#compdef sway-msg
# Documentation: https://man.archlinux.org/man/sway-msg.1
# Send messages to sway window manager

_arguments -s -S \
  '(-t --type)'{-t,--type}'[message type]:type:(command get_workspaces get_outputs get_tree get_marks get_bar_config get_binding_modes get_config get_inputs get_seats subscribe)' \
  '(-s --socket)'{-s,--socket}'[socket path]:socket:_files' \
  '(-r --raw)'{-r,--raw}'[output raw JSON]' \
  '(-m --monitor)'{-m,--monitor}'[monitor for responses until killed]' \
  '(-p --pretty)'{-p,--pretty}'[pretty-print JSON output]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:message:' \
  && return 0
