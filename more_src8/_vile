#compdef vile xvile
# Documentation: https://invisible-island.net/vile/
# VI Like Emacs text editor

_arguments -s -S \
  '-R[read-only mode]' \
  '-v[view mode (read-only)]' \
  '-V[show version]' \
  '-h[show help]' \
  '+[start at line number]:line:' \
  '-g[start at line number]:line:' \
  '-t[find tag]:tag:' \
  '-s[search pattern]:pattern:' \
  '*:files:_files' \
  && return 0
