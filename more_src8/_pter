#compdef pter
# Documentation: https://github.com/vonshednob/pter
# pter: TUI for todo.txt / Taskwarrior

_arguments -s -S \
  '(-c --config)'{-c,--config}'[path to configuration file]:config file:_files' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --delegate-to)'{-d,--delegate-to}'[delegate task to someone]:delegate:' \
  '(-s --search-query)'{-s,--search-query}'[initial search query]:query:' \
  '--color[enable color output]' \
  '--no-color[disable color output]' \
  '*:todo file:_files -g "*.txt"' \
  && return 0
