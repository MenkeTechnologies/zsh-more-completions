#compdef roxterm
# Documentation: https://github.com/realh/roxterm
# ROXTerm terminal emulator

_arguments -s -S \
  '(-T --title)'{-T,--title}'[set window title]:title:' \
  '--tab[open in a new tab of an existing window]' \
  '(-d --directory)'{-d,--directory}'[set working directory]:directory:_files -/' \
  '--geometry[set window geometry]:geometry:' \
  '--profile[use named profile]:profile:' \
  '--colour-scheme[use named colour scheme]:scheme:' \
  '--shortcut-scheme[use named shortcut scheme]:scheme:' \
  '--separate[do not attempt to reuse an existing process]' \
  '--fork[fork into background]' \
  '--maximise[maximise window]' \
  '--fullscreen[open in fullscreen mode]' \
  '--zoom[set zoom factor]:zoom:' \
  '(-e --execute)'{-e,--execute}'[run command]:command:_command_names' \
  '--role[set window role for session management]:role:' \
  '*:command:_command_names' \
  && return 0
