#compdef sli
# Documentation: https://github.com/d0c-s4vage/lookatme
# Terminal presentation tool

_arguments -s -S \
  '-e[execute code blocks]' \
  '-t[theme]:theme:' \
  '-s[style]:style:' \
  '--live[live reload mode]' \
  '--help[show help]' \
  '--version[show version]' \
  '*:slide files:_files -g "*.md"' \
  && return 0
