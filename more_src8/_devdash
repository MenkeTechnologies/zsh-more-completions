#compdef devdash
# Documentation: https://github.com/Phantas0s/devdash
# DevDash: terminal dashboard for developers from YAML config

_arguments -s -S \
  '(-c --config)'{-c,--config}'[path to configuration file]:config file:_files -g "*.yml *.yaml"' \
  '(-l --logfile)'{-l,--logfile}'[path to log file]:log file:_files' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '(-e --edit)'{-e,--edit}'[edit configuration file]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  && return 0
