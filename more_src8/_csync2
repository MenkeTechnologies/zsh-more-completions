#compdef csync2
# Documentation: https://linuxha.com/csync2/
# Cluster file synchronization tool

_arguments -s -S \
  '-h[show help]' \
  '-v[verbose output]' \
  '-C[config file]:config:_files' \
  '-D[database directory]:directory:_files -/' \
  '-N[hostname override]:hostname:_hosts' \
  '-G[group name]:group:' \
  '-P[peer name]:peer:_hosts' \
  '-c[check for unsynced files]' \
  '-u[update files if check found unsynced]' \
  '-f[force this host to win a conflict]' \
  '-m[mark files as dirty]' \
  '-r[remove files from database]' \
  '-i[initialize database]' \
  '-x[run in xinetd mode]' \
  '-I[initialize SSL certificate]' \
  '-R[remove SSL certificate]' \
  '-T[test run, do not actually sync]' \
  '-B[block mode]' \
  '-A[activate special groups]' \
  '-L[list dirty files]' \
  '*:files:_files' \
  && return 0
