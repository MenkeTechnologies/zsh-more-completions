#compdef ultralytics yolo
# Documentation: https://docs.ultralytics.com/usage/cli/
# Ultralytics YOLO CLI for object detection, segmentation, classification, etc.

_ultralytics() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'predict:run inference on images, videos, or streams'
    'train:train a model on a dataset'
    'val:validate a trained model on a dataset'
    'export:export a model to a deployment format'
    'track:run object tracking on video streams'
    'benchmark:benchmark model speed and accuracy across export formats'
    'cfg:display or update default configuration'
    'copy-cfg:copy default configuration to current directory'
    'checks:run system checks and print environment info'
    'explorer:launch Ultralytics Explorer GUI'
    'solutions:run Ultralytics solutions'
    'help:show help information'
  )

  local -a common_args=(
    'model=[model file path or name]:model:_files'
    'data=[dataset config file path]:data:_files'
    'imgsz=[image size for training/inference]:size:'
    'device=[device to run on (cpu, 0, 0\,1, etc.)]:device:'
    'project=[project directory name]:project:_files -/'
    'name=[experiment name]:name:'
    'exist_ok=[overwrite existing project/name]:bool:(True False)'
    'verbose=[verbose output]:bool:(True False)'
  )

  local -a train_args=(
    'epochs=[number of training epochs]:epochs:'
    'batch=[batch size]:batch:'
    'lr0=[initial learning rate]:lr:'
    'lrf=[final learning rate factor]:lrf:'
    'optimizer=[optimizer]:optimizer:(SGD Adam AdamW NAdam RAdam RMSProp auto)'
    'patience=[early stopping patience]:patience:'
    'workers=[number of dataloader workers]:workers:'
    'seed=[random seed]:seed:'
    'resume=[resume training from checkpoint]:bool:(True False)'
    'amp=[automatic mixed precision training]:bool:(True False)'
    'pretrained=[use pretrained model]:bool:(True False)'
    'cos_lr=[use cosine learning rate scheduler]:bool:(True False)'
    'cache=[cache dataset]:cache:(True False ram disk)'
    'save=[save checkpoints]:bool:(True False)'
    'save_period=[save checkpoint every N epochs]:period:'
    'val=[run validation during training]:bool:(True False)'
    'plots=[generate plots during training]:bool:(True False)'
  )

  local -a predict_args=(
    'source=[input source (file, dir, URL, webcam)]:source:_files'
    'conf=[confidence threshold]:conf:'
    'iou=[IoU threshold for NMS]:iou:'
    'max_det=[maximum detections per image]:max_det:'
    'classes=[filter by class]:classes:'
    'save=[save results]:bool:(True False)'
    'save_txt=[save results as text]:bool:(True False)'
    'save_conf=[save confidence scores]:bool:(True False)'
    'save_crop=[save cropped predictions]:bool:(True False)'
    'show=[display results]:bool:(True False)'
    'show_labels=[show labels]:bool:(True False)'
    'show_conf=[show confidence]:bool:(True False)'
    'vid_stride=[video frame stride]:stride:'
    'line_width=[bounding box line width]:width:'
    'visualize=[visualize model features]:bool:(True False)'
    'augment=[use augmented inference]:bool:(True False)'
    'agnostic_nms=[class-agnostic NMS]:bool:(True False)'
    'stream=[stream results]:bool:(True False)'
  )

  local -a export_args=(
    'format=[export format]:format:(torchscript onnx openvino engine coreml saved_model pb tflite edgetpu tfjs paddle ncnn)'
    'half=[use FP16 half precision]:bool:(True False)'
    'int8=[use INT8 quantization]:bool:(True False)'
    'dynamic=[use dynamic axes for ONNX]:bool:(True False)'
    'simplify=[simplify ONNX model]:bool:(True False)'
    'opset=[ONNX opset version]:opset:'
    'workspace=[TensorRT workspace size in GB]:size:'
    'nms=[add NMS to model]:bool:(True False)'
    'batch=[export batch size]:batch:'
  )

  _arguments -s -S -C \
    '1:command:->command' \
    '*::arg:->args' && ret=0

  case $state in
    command)
      _describe -t commands 'ultralytics command' commands && ret=0
      ;;
    args)
      case ${words[1]} in
        train)
          _values -w 'option' $common_args $train_args && ret=0
          ;;
        predict)
          _values -w 'option' $common_args $predict_args && ret=0
          ;;
        val)
          _values -w 'option' $common_args \
            'conf=[confidence threshold]:conf:' \
            'iou=[IoU threshold for NMS]:iou:' \
            'split=[dataset split to use]:split:(val test train)' \
            'save_json=[save results to JSON]:bool:(True False)' \
            'plots=[generate plots]:bool:(True False)' && ret=0
          ;;
        export)
          _values -w 'option' $common_args $export_args && ret=0
          ;;
        track)
          _values -w 'option' $common_args $predict_args \
            'tracker=[tracker config file]:tracker:(botsort.yaml bytetrack.yaml)' && ret=0
          ;;
        benchmark)
          _values -w 'option' $common_args \
            'format=[export format]:format:(torchscript onnx openvino engine coreml saved_model pb tflite edgetpu tfjs paddle ncnn)' \
            'half=[use FP16]:bool:(True False)' \
            'int8=[use INT8]:bool:(True False)' && ret=0
          ;;
        *)
          _default && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_ultralytics "$@"
