#compdef rslsync resilio-sync
# Documentation: https://help.resilio.com/
# Resilio Sync peer-to-peer file synchronization

_arguments -s -S \
  '--config[config file]:config:_files' \
  '--storage[storage path]:directory:_files -/' \
  '--webui.listen[web UI listen address]:address:' \
  '--log[log file]:log:_files' \
  '--nodaemon[run in foreground]' \
  '--help[show help]' \
  && return 0
