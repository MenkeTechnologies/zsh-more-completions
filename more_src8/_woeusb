#compdef woeusb
# Documentation: https://github.com/WoeUSB/WoeUSB
# Create bootable Windows USB drives from Linux

_arguments -s -S \
  '(-d --device)'{-d,--device}'[install to device]:device:_files -g "/dev/sd*"' \
  '(-p --partition)'{-p,--partition}'[install to partition]:partition:_files -g "/dev/sd*"' \
  '--target-filesystem[target filesystem]:filesystem:(FAT NTFS)' \
  '--tgt-fs[target filesystem (alias)]:filesystem:(FAT NTFS)' \
  '--label[set filesystem label]:label:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--about[show about information]' \
  '*:ISO file:_files -g "*.iso *.ISO"' \
  && return 0
