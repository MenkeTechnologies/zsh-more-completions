#compdef tabview
# Documentation: https://github.com/TabViewer/tabview
# Python curses command-line CSV/tabular data viewer

_arguments -s -S \
  '-d[delimiter]:delimiter:' \
  '-h[show help]' \
  '-e[encoding]:encoding:' \
  '--header-line[number of header lines]:lines:' \
  '*:CSV file:_files -g "*.csv *.tsv *.txt"' \
  && return 0
