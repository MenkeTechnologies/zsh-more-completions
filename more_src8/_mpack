#compdef mpack
# Documentation: https://linux.die.net/man/1/mpack
# Pack a file in MIME format

_arguments -s -S \
  '-s[subject of message]:subject:' \
  '-d[description of file]:description:' \
  '-c[content type]:content-type:' \
  '-o[output to file instead of mailing]:output:_files' \
  '-e[encoding]:encoding:(base64 quoted-printable x-uue)' \
  '*:files:_files' \
  && return 0
