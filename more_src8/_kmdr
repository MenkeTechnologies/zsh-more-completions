#compdef kmdr
# Documentation: https://github.com/ediber/kmdr-cli
# CLI tool that explains shell commands

_kmdr() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'explain:explain a shell command'
    'suggest:suggest commands'
    'history:explore shell history'
    'info:show environment info'
  )

  _arguments -s -S \
    '-h[show help]' \
    '--version[show version]' \
    '1:command:->command' \
    '*::arg:->args' && ret=0

  case $state in
    command)
      _describe -t commands 'kmdr command' commands && ret=0
      ;;
  esac

  return ret
}

_kmdr "$@"
