#compdef xflux
# Documentation: https://justgetflux.com/linux.html
# Adjusts screen color temperature

_arguments -s -S \
  '-l[latitude]:latitude:' \
  '-g[longitude]:longitude:' \
  '-z[zipcode]:zipcode:' \
  '-k[color temperature (2700-6500K)]:temperature:' \
  '-nofork[run in foreground]' \
  '-p[preview mode]' \
  && return 0
