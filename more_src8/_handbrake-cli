#compdef handbrake-cli
# Documentation: https://handbrake.fr/docs/en/latest/cli/cli-options.html
# Video transcoder

_arguments -s -S \
  '(-i --input)'{-i,--input}'[input file or device]:input:_files' \
  '(-o --output)'{-o,--output}'[output file]:output:_files' \
  '(-f --format)'{-f,--format}'[output format]:format:(av_mp4 av_mkv av_webm)' \
  '(-e --encoder)'{-e,--encoder}'[video encoder]:encoder:(x264 x265 svt_av1 VP8 VP9 theora)' \
  '(-E --aencoder)'{-E,--aencoder}'[audio encoder]:encoder:(av_aac fdk_aac copy:aac ac3 eac3 copy:ac3 flac16 flac24 opus vorbis mp3 copy)' \
  '(-q --quality)'{-q,--quality}'[constant quality]:quality:' \
  '(-b --vb)'{-b,--vb}'[video bitrate in kbps]:bitrate:' \
  '(-r --rate)'{-r,--rate}'[framerate]:fps:(5 10 12 15 23.976 24 25 29.97 30 48 50 59.94 60)' \
  '(-w --width)'{-w,--width}'[output width]:pixels:' \
  '(-l --height)'{-l,--height}'[output height]:pixels:' \
  '--crop[set crop values]:top\:bottom\:left\:right:' \
  '--preset[use preset]:preset:' \
  '--preset-list[list available presets]' \
  '-t[select title by index]:title:' \
  '-c[select chapters]:chapters:' \
  '--start-at[start encoding at]:offset:' \
  '--stop-at[stop encoding at]:offset:' \
  '-s[select subtitle track]:subtitle:' \
  '-a[select audio track]:audio:' \
  '-m[add chapter markers]' \
  '-2[two-pass encoding]' \
  '-T[use turbo first pass]' \
  '--deinterlace[deinterlace video]:filter:' \
  '--denoise[denoise video]:filter:' \
  '--deblock[deblock video]:filter:' \
  '--rotate[rotate video]:angle:' \
  '--grayscale[grayscale encoding]' \
  '-v[verbosity level]:level:(0 1 2)' \
  '-Z[use named preset]:preset:' \
  '-z[list available presets]' \
  '--scan[scan title only]' \
  '--no-dvdnav[do not use dvdnav for reading DVDs]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  && return 0
