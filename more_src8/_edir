#compdef edir
# Documentation: https://github.com/bulletmark/edir
# edir: batch rename, remove, and copy files/dirs using your text editor

_arguments -s -S \
  '(-a --all)'{-a,--all}'[include hidden files]' \
  '(-r --recurse)'{-r,--recurse}'[recurse into subdirectories]' \
  '(-q --quiet)'{-q,--quiet}'[suppress non-essential messages]' \
  '(-d --dir)'{-d,--dir}'[show only directories]' \
  '(-f --files)'{-f,--files}'[show only files]' \
  '(-F --no-files)'{-F,--no-files}'[do not show files]' \
  '(-D --no-dirs)'{-D,--no-dirs}'[do not show directories]' \
  '(-t --trash)'{-t,--trash}'[use trash instead of deleting]' \
  '(-e --editor)'{-e,--editor}'[specify editor to use]:editor:_command_names' \
  '(-L --no-symlinks)'{-L,--no-symlinks}'[do not show symbolic links]' \
  '--suffix[set suffix for temporary file]:suffix:' \
  '--no-git[do not use git mv/rm]' \
  '*:file or directory:_files' \
  && return 0
