#compdef emelfm2
# Documentation: http://emelfm2.net/
# GTK+ dual-pane file manager

_arguments -s -S \
  '-1[start with one pane]' \
  '-e[run command in terminal]:command:_command_names' \
  '-h[show help]' \
  '-i[show config directory]' \
  '-r[run plugin]:plugin:' \
  '-s[set session]:session:' \
  '-t[open dir in new tab]:directory:_files -/' \
  '-v[show version]' \
  '*:files or directories:_files' \
  && return 0
