#compdef wl-clipboard-history
# Documentation: https://github.com/d-sr/wl-clipboard-history
# Wayland clipboard history manager (rofi integration)

_arguments -s -S \
  '-p[preview entry]' \
  '-d[delete entry]' \
  '-c[clear history]' \
  '-l[list entries]' \
  '-n[max entries to store]:count:' \
  '-h[show help]' \
  && return 0
