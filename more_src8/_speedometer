#compdef speedometer
# Documentation: https://excess.org/speedometer/
# Terminal-based real-time network/download speed monitor

_arguments -s -S \
  '-r[receive mode]:interface:' \
  '-t[transmit mode]:interface:' \
  '-f[monitor file growth]:file:_files' \
  '-i[update interval]:seconds:' \
  '-p[use plain text mode]' \
  '-b[display in bits per second]' \
  '-z[start from zero]' \
  '-rx[receive mode for specific interface]:interface:' \
  '-tx[transmit mode for specific interface]:interface:' \
  && return 0
