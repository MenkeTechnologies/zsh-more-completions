#compdef krusader
# Documentation: https://krusader.org/
# KDE twin-panel file manager

_arguments -s -S \
  '--left[left panel path]:directory:_files -/' \
  '--right[right panel path]:directory:_files -/' \
  '--profile[load panel profile]:profile:' \
  '*:files or directories:_files' \
  && return 0
