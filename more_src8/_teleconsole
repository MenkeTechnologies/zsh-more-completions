#compdef teleconsole
# Documentation: https://www.teleconsole.com/
# Share your terminal session via secure tunnel

_arguments -s -S \
  '-f[forward local port]:port:' \
  '-L[forward remote port to local]:local port:' \
  '-v[verbose output]' \
  '-s[server address]:server:_hosts' \
  '-insecure[do not verify server certificate]' \
  '1:session ID or command:(join)' \
  && return 0
