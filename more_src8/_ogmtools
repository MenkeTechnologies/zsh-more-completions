#compdef ogmmerge ogmsplit ogminfo ogmdemux
# Documentation: https://www.bunkus.org/videotools/ogmtools/
# OGM container format tools

local cmd=${words[1]}

case $cmd in
  ogmmerge)
    _arguments -s -S \
      '-o[output file]:output:_files' \
      '-A[no audio tracks]' \
      '-D[no video tracks]' \
      '-S[no subtitle tracks]' \
      '-v[verbose output]' \
      '-q[quiet mode]' \
      '*:input files:_files -g "*.ogm *.ogg *.avi *.srt *.ssa *.ac3 *.aac *.mp3"' \
      && return 0
    ;;
  ogmsplit)
    _arguments -s -S \
      '-o[output basename]:basename:' \
      '-s[split size in MB]:size:' \
      '-n[max number of files]:count:' \
      '-v[verbose output]' \
      '*:OGM files:_files -g "*.ogm *.ogg"' \
      && return 0
    ;;
  ogminfo)
    _arguments -s -S \
      '-v[verbose output]' \
      '-s[summary mode]' \
      '*:OGM files:_files -g "*.ogm *.ogg"' \
      && return 0
    ;;
  ogmdemux)
    _arguments -s -S \
      '-o[output directory]:directory:_files -/' \
      '-v[verbose output]' \
      '*:OGM files:_files -g "*.ogm *.ogg"' \
      && return 0
    ;;
esac
