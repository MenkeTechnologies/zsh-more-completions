#compdef enry
# Documentation: https://github.com/go-enry/enry
# Programming language detector

_arguments -s -S \
  '--json[output as JSON]' \
  '--all[show all files, not just programming languages]' \
  '--breakdown[show file breakdown by language]' \
  '--count[count files per language]' \
  '--prog[show only programming languages]' \
  '--help[show help]' \
  '--version[show version]' \
  '*:path:_files -/' \
  && return 0
