#compdef doublecmd
# Documentation: https://doublecmd.sourceforge.io/
# Twin-panel file manager inspired by Total Commander

_arguments -s -S \
  '--no-splash[do not show splash screen]' \
  '--client[pass files to existing instance]' \
  '--config-dir[custom config directory]:directory:_files -/' \
  '-L[open directory in left panel]:directory:_files -/' \
  '-R[open directory in right panel]:directory:_files -/' \
  '-P[active panel]:panel:(L R)' \
  '-T[open path in new tab]' \
  '*:files or directories:_files' \
  && return 0
