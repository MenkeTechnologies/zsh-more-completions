#compdef goatcounter
# Documentation: https://www.goatcounter.com/help/cli
# Privacy-focused web analytics

_goatcounter() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'serve:start the web server'
    'import:import pageviews from CSV'
    'db:database operations'
    'saas:run as SaaS'
    'buffer:start buffer for pageviews'
    'version:show version'
    'help:show help'
  )

  _arguments -s -S \
    '-h[show help]' \
    '1:command:->command' \
    '*::arg:->args' && ret=0

  case $state in
    command)
      _describe -t commands 'goatcounter command' commands && ret=0
      ;;
    args)
      case ${words[1]} in
        serve)
          _arguments \
            '-listen[listen address]:address:' \
            '-db[database connection]:connection:' \
            '-tls[TLS mode]:mode:(none proxy acme http)' \
            '-automigrate[run migrations automatically]' \
            '-smtp[SMTP server]:server:' \
            '-errors[error reporting]:addr:' \
            '-debug[module to debug]:module:' \
            && ret=0
          ;;
        import)
          _arguments \
            '-site[site to import to]:site:' \
            '-format[import format]:format:(csv)' \
            '*:files:_files -g "*.csv"' \
            && ret=0
          ;;
        db)
          _arguments \
            '-db[database connection]:connection:' \
            '1:action:(migrate create-site)' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_goatcounter "$@"
