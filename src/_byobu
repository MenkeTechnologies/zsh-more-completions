#compdef byobu

# Zsh completion for byobu - text-based window manager and terminal multiplexer

_arguments -s -S \
  '-2[force 256 colors]' \
  '-c[execute a command via shell]:command:_command_names' \
  '-d[detach from a session]' \
  '-e[set escape key]:key:' \
  '-f[set byobu configuration directory]:dir:_files -/' \
  '-h[show help]' \
  '--help[show help]' \
  '-l[select most recently used session]' \
  '-n[do not start or attach to any session]' \
  '-N[print the number of running byobu sessions]' \
  '-p[specify window position]:N:' \
  '-r[attach to named session]:session:' \
  '-R[reattach if session exists, otherwise create new]' \
  '-S[specify path to session socket]:path:_files' \
  '-s[session name]:name:' \
  '-t[attach to named session]:name:' \
  '-T[force to open a terminal]:mode:' \
  '-u[utf-8 mode]' \
  '-v[print version number and exit]' \
  '--version[print version number and exit]' \
  '-x[enable byobu if in new window]' \
  '*:command:_default'
