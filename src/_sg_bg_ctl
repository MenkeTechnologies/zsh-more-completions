#compdef sg_bg_ctl
# Documentation: https://man.archlinux.org/search?q=sg_bg_ctl
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--ctl[CTL CTL is background operation control value]'
  {--help,-h}'[print out usage message]'
  '--time[TN TN (units 100 ms) is max time to perform background]'
  {--verbose,-v}'[increase verbosity]'
  {--version,-V}'[print version string and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
