#compdef vit

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '--version[show version]' \
  '--help[show help]' \
  '(-c --config)'{-c,--config}'[config file]:config file:_files' \
  '(-r --report)'{-r,--report}'[report name]:report' \
  '--completion[output shell completion]' && ret=0
return ret
