#compdef hackrf_cpldjtag
# Documentation: https://man.archlinux.org/search?q=hackrf_cpldjtag
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[this help]'
  {-x,--xsvf}'[XSVF file to be written to CPLD.]'
  {-d,--device}'[serial number of device, if multiple devices]'
  '*:filename:_files'
)

_arguments -s -S $arguments
