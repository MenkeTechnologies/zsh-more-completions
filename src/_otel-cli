#compdef otel-cli

# Zsh completion for otel-cli - OpenTelemetry CLI for generating traces/spans

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'exec:execute a command and record it as a span'
  'span:create a span'
  'span-background:create a background span'
  'span-event:add an event to a background span'
  'span-end:end a background span'
  'status:check the status of the OTLP endpoint'
  'version:print version'
)

_arguments -s -S \
  '1:subcommand:->subcmd' \
  '*::args:->args' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'otel-cli subcommand' subcommands && ret=0
    ;;
  (args)
    local -a common_opts=(
      '--endpoint[OTLP endpoint URI]:uri:'
      '--protocol[OTLP protocol]:protocol:(grpc http/protobuf http/json)'
      '--service[service name]:name:'
      '--timeout[timeout for OTLP requests]:duration:'
      '--headers[additional headers]:headers:'
      '--insecure[disable TLS verification]'
      '--no-tls-verify[disable TLS certificate verification]'
      '--tls-ca-cert[TLS CA certificate file]:file:_files'
      '--tls-client-cert[TLS client certificate file]:file:_files'
      '--tls-client-key[TLS client key file]:file:_files'
      '--attrs[span attributes]:attributes:'
      '--tp-required[require traceparent propagation]'
      '--tp-carrier[traceparent carrier file]:file:_files'
      '--tp-print[print the traceparent]'
      '--tp-export[export traceparent to environment]'
      '--tp-ignore-env[ignore TRACEPARENT env var]'
      '--force-trace-id[force specific trace ID]:trace ID:'
      '--force-span-id[force specific span ID]:span ID:'
      '--force-parent-span-id[force specific parent span ID]:span ID:'
      '--verbose[enable verbose output]'
      '--fail[exit with error on OTLP failure]'
      '--no-fail[do not exit with error on OTLP failure]'
      '--csi[carrier signal injection]'
    )

    case ${line[1]} in
      (exec)
        _arguments \
          "${common_opts[@]}" \
          '--name[span name]:name:' \
          '--kind[span kind]:kind:(client server producer consumer internal)' \
          '--status-code[span status code]:code:(unset ok error)' \
          '--status-description[span status description]:description:' \
          '--tp-disable-inject[disable traceparent injection]' \
          '*:command:_command_names -e' && ret=0
        ;;
      (span)
        _arguments \
          "${common_opts[@]}" \
          '--name[span name]:name:' \
          '--kind[span kind]:kind:(client server producer consumer internal)' \
          '--start[span start time]:time:' \
          '--end[span end time]:time:' \
          '--status-code[span status code]:code:(unset ok error)' \
          '--status-description[span status description]:description:' && ret=0
        ;;
      (span-background)
        _arguments \
          "${common_opts[@]}" \
          '--name[span name]:name:' \
          '--kind[span kind]:kind:(client server producer consumer internal)' \
          '--sockdir[socket directory]:directory:_files -/' && ret=0
        ;;
      (span-event)
        _arguments \
          '--name[event name]:name:' \
          '--attrs[event attributes]:attributes:' \
          '--time[event time]:time:' \
          '--sockdir[socket directory]:directory:_files -/' && ret=0
        ;;
      (span-end)
        _arguments \
          '--status-code[span status code]:code:(unset ok error)' \
          '--status-description[span status description]:description:' \
          '--sockdir[socket directory]:directory:_files -/' && ret=0
        ;;
      (status)
        _arguments \
          '--endpoint[OTLP endpoint URI]:uri:' \
          '--protocol[OTLP protocol]:protocol:(grpc http/protobuf http/json)' \
          '--timeout[timeout]:duration:' && ret=0
        ;;
    esac
    ;;
esac

return ret
