#compdef katana

# Zsh completion for katana - next-generation crawling and spidering framework

_arguments -s -S \
  '(-u --url)'{-u,--url}'[target URL to crawl]:URL:' \
  '(-list --list)'{-list,-l}'[file containing list of URLs to crawl]:file:_files' \
  '(-d --depth)'{-d,--depth}'[maximum depth to crawl]:depth:' \
  '(-js-crawl --js-crawl)--js-crawl[enable JavaScript parsing and crawling]' \
  '(-headless --headless)--headless[enable headless hybrid crawling]' \
  '(-headless-options --headless-options)--headless-options[browser options for headless mode]:options:' \
  '(-sc --system-chrome)--system-chrome[use local installed chrome browser]' \
  '(-sb --show-browser)--show-browser[show the browser in headless mode]' \
  '(-xhr-extraction --xhr-extraction)--xhr-extraction[extract XHR request URL, method and body]' \
  '(-ct --crawl-duration)'{-ct,--crawl-duration}'[maximum duration to crawl (seconds)]:seconds:' \
  '(-kf --known-files)'{-kf,--known-files}'[enable crawling of known files]:mode:(all robotstxt sitemapxml)' \
  '(-mrs --max-response-size)'{-mrs,--max-response-size}'[maximum response size to read]:bytes:' \
  '(-timeout --timeout)--timeout[time to wait for request in seconds]:seconds:' \
  '(-aff --automatic-form-fill)'{-aff,--automatic-form-fill}'[enable automatic form filling]' \
  '(-fx --form-extraction)'{-fx,--form-extraction}'[extract form values]' \
  '(-retry --retry)--retry[number of times to retry request on failure]:N:' \
  '(-proxy --proxy)--proxy[HTTP/SOCKS5 proxy to use]:proxy:' \
  '(-H --headers)'{-H,--headers}'[custom header/cookie to include in requests]:header:' \
  '(-rl --rate-limit)'{-rl,--rate-limit}'[maximum requests per second]:rate:' \
  '(-rlm --rate-limit-minute)'{-rlm,--rate-limit-minute}'[maximum requests per minute]:rate:' \
  '(-c --concurrency)'{-c,--concurrency}'[number of concurrent threads]:N:' \
  '(-p --parallelism)'{-p,--parallelism}'[number of concurrent inputs to process]:N:' \
  '(-rd --delay)'{-rd,--delay}'[request delay between each request]:seconds:' \
  '(-nc --no-color)'{-nc,--no-color}'[disable output content coloring]' \
  '(-o --output)'{-o,--output}'[file to write output]:file:_files' \
  '(-od --output-dir)'{-od,--output-dir}'[output directory for storing crawled data]:dir:_files -/' \
  '(-json --json)--json[write output in JSON lines format]' \
  '(-irr --include-response-raw)'{-irr,--include-response-raw}'[include raw request/response in JSON output]' \
  '(-omit-raw --omit-raw-output)--omit-raw-output[omit raw input in favor of output]' \
  '(-field --field)'{-field,-f}'[field to display in output]:field:(url path fqdn rdn rurl qurl qpath file ufile key value kv dir udir)' \
  '(-sf --store-field)'{-sf,--store-field}'[field to store in per-host output]:field:(url path fqdn rdn rurl qurl qpath file ufile key value kv dir udir)' \
  '(-ef --extension-filter)'{-ef,--extension-filter}'[filter output by extension]:extensions:' \
  '(-mfl --match-field-length)'{-mfl,--match-field-length}'[match fields with specified length]:N:' \
  '(-wc --wildcard-domain)'{-wc,--wildcard-domain}'[enable wildcard domain handling]' \
  '(-fs --filter-scope)'{-fs,--filter-scope}'[filter scope by field]:scope:' \
  '(-fr --filter-regex)'{-fr,--filter-regex}'[filter output using regex]:regex:' \
  '(-mr --match-regex)'{-mr,--match-regex}'[match output using regex]:regex:' \
  '(-mdc --match-code)'{-mdc,--match-code}'[match response HTTP status codes]:codes:' \
  '(-fdc --filter-code)'{-fdc,--filter-code}'[filter response HTTP status codes]:codes:' \
  '(-silent --silent)--silent[display results only]' \
  '(-version --version)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[show verbose output]' \
  '(-h --help)'{-h,--help}'[show help]'
