#compdef mate-power-backlight-helper
# Documentation: https://man.archlinux.org/search?q=mate-power-backlight-helper
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  '--set-brightness[set the current brightness]'
  '--get-brightness[get the current brightness]'
  '--get-max-brightness[get the number of brightness levels supported]'
  '*:filename:_files'
)

_arguments -s -S $arguments
