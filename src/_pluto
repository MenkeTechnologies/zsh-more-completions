#compdef pluto

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'detect-files:detect deprecated APIs in files'
      'detect-helm:detect deprecated APIs in Helm releases'
      'detect-api-resources:detect deprecated APIs in cluster resources'
      'detect-all-in-cluster:detect all deprecated APIs in cluster'
      'list-versions:list supported API versions'
    )
    _describe -t commands 'pluto command' commands && ret=0
    ;;
  args)
    _arguments -s -S \
      {-o,--output}'=[output format]:format:(normal json yaml csv wide markdown custom)' \
      {-t,--target-versions}'=[target versions]:versions' \
      {-r,--only-show-removed}'[only show removed APIs]' \
      '--ignore-deprecations[ignore deprecations]' \
      '--ignore-removals[ignore removals]' \
      '--no-headers[hide headers]' \
      '--no-footer[hide footer]' \
      '--columns=[custom columns]:columns' \
      '*:file:_files' \
      && ret=0
    ;;
esac

return ret
