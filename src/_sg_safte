#compdef sg_safte
# Documentation: https://man.archlinux.org/search?q=sg_safte
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {--config,-c}'[output enclosure configuration]'
  {--devstatus,-d}'[output device slot status]'
  {--encstatus,-s}'[output enclosure status]'
  {--flags,-f}'[output global flags]'
  {--help,-h}'[output command usage message then exit]'
  {--hex,-H}'[output enclosure config in hex]'
  {--insertions,-i}'[output insertion statistics]'
  {--raw,-r}'[output enclosure config in binary to stdout]'
  {--usage,-u}'[output usage statistics]'
  {--verbose,-v}'[increase verbosity]'
  {--version,-v}'[output version then exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
