#compdef zola

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-r+[root directory]:directory:_directories' \
  '--root=[root directory]:directory:_directories' \
  '-c+[path to config file]:config file:_files' \
  '--config=[path to config file]:config file:_files' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:create a new Zola project'
      'build:build the site'
      'serve:serve the site, rebuild on changes'
      'check:check the site for errors'
      'completion:generate shell completion'
    )
    _describe -t commands 'zola command' commands && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--force[force creation even if directory exists]' \
          '1:directory name:_directories' && ret=0
        ;;
      build)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-u+[force the base URL]:url' \
          '--base-url=[force the base URL]:url' \
          '-o+[output directory]:directory:_directories' \
          '--output-dir=[output directory]:directory:_directories' \
          '--drafts[include drafts]' \
          '--force[force rebuilding all pages]' && ret=0
        ;;
      serve)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-i+[interface to bind]:interface' \
          '--interface=[interface to bind]:interface' \
          '-p+[port to use]:port' \
          '--port=[port to use]:port' \
          '-u+[force the base URL]:url' \
          '--base-url=[force the base URL]:url' \
          '-o+[output directory]:directory:_directories' \
          '--output-dir=[output directory]:directory:_directories' \
          '--drafts[include drafts]' \
          '--open[open site in default browser]' \
          '--fast[only rebuild on content/template changes]' && ret=0
        ;;
      check)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--drafts[include drafts]' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:shell:(bash fish zsh elvish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
