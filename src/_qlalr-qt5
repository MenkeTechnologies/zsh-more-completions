#compdef qlalr-qt5
# Documentation: https://man.archlinux.org/search?q=qlalr-qt5
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {--help,-h}'[display this help and exit]'
  {--verbose,-v}'[verbose output]'
  '--no-debug[no debug information]'
  '--no-lines[no #line directives]'
  '--dot[generate a graph]'
  '--qt[add the Qt copyright header and Qt-specific types and macros]'
  '*:filename:_files'
)

_arguments -s -S $arguments
