#compdef graphml2gv
# Documentation: https://man.archlinux.org/search?q=graphml2gv
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-g[use <name> as template for graph names]:name:'
  '-o[output to <file> (stdout)]:file:'
  '-v[verbose mode]'
  '*:filename:_files'
)

_arguments -s -S $arguments
