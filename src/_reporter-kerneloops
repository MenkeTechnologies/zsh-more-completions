#compdef reporter-kerneloops
# Documentation: https://man.archlinux.org/search?q=reporter-kerneloops
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-v,--verbose}'[be verbose]'
  '-d[problem directory]'
  '-c[configuration file]'
  '*:filename:_files'
)

_arguments -s -S $arguments
