#compdef lsusb

# zsh completions for 'lsusb'

_lsusb() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -s -S \
        {-v,--verbose}'[display detailed information about devices (descriptors)]' \
        '-s[show only devices with specified bus and/or device number]:bus\:devnum (\[\[bus\]\:\]\[devnum\]):' \
        '-d[show only devices with specified vendor and product ID]:vendor\:product (\[vendor\]\:\[product\]):' \
        '-D[examine only the specified device file (root required)]:device file:_files -W /dev/bus/usb' \
        {-t,--tree}'[dump the physical USB device hierarchy as a tree]' \
        {-V,--version}'[print version information and exit]' \
        '(- *)'{-h,--help}'[print usage message and exit]' \
        '*:device:_files' && ret=0

    return ret
}

_lsusb "$@"
