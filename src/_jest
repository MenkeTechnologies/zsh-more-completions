#compdef jest

# Zsh completion for Jest test runner
# https://jestjs.io/docs/cli

_jest() {
  local -a arguments

  arguments=(
    '(- *)'{-h,--help}'[Show help]'
    '(- *)--version[Show version number]'
    '--all[Run all tests instead of only changed ones]'
    '--automock[Automock all files by default]'
    {-b,--bail}'[Exit the test suite immediately after n number of failing tests]'
    '--cache[Whether to use the transform cache (disable with --no-cache)]'
    '--cacheDirectory=[The directory where Jest should store its cached dependency information]:dir:_directories'
    '--changedFilesWithAncestor[Run tests related to current changes and the last commit]'
    '--changedSince=[Run tests related to changes since the provided branch]:branch:'
    '--ci[Run Jest in continuous integration (CI) mode]'
    '--clearCache[Clear the configured Jest cache directory and then exit]'
    '--clearMocks[Automatically clear mock calls, instances, contexts and results before every test]'
    '--collectCoverage[Alias for --coverage]'
    '--collectCoverageFrom=[A glob pattern matching files for coverage collection]:glob pattern:'
    '--color[Force test results output color highlighting]'
    '--colors[Alias for --color]'
    {-c,--config}'=[Path to a Jest config file]:config file:_files'
    '--coverage[Collect and report test coverage information]'
    '--coverageDirectory=[Directory where Jest should output coverage files]:dir:_directories'
    '*--coveragePathIgnorePatterns=[Regexp patterns matched against file paths to skip coverage]:pattern:'
    '--coverageProvider=[Select coverage provider]:provider:(babel v8)'
    '*--coverageReporters=[Reporter names for writing coverage reports]:reporter:'
    '--coverageThreshold=[JSON string to configure minimum coverage thresholds]:JSON string:'
    '--debug[Print debugging info about your Jest config]'
    '--detectLeaks[Detect memory leaks in tests (experimental)]'
    '--detectOpenHandles[Print out remaining open handles preventing Jest from exiting]'
    '--errorOnDeprecated[Make calling deprecated APIs throw helpful error messages]'
    {-e,--expand}'[Show full diffs instead of a patch]'
    '--filter=[Path to a module exporting a filtering function]:module path:_files'
    '--findRelatedTests[Find related tests for a list of source files]'
    '--forceExit[Force Jest to exit after all tests have completed running]'
    '--globalSetup=[Path to a module that runs before all tests]:module path:_files'
    '--globalTeardown=[Path to a module that runs after all tests]:module path:_files'
    '--globals=[JSON string with map of global variables]:JSON string:'
    '--haste=[JSON string with map of variables for the haste module system]:JSON string:'
    '*--ignoreProjects=[Ignore the tests of the specified projects]:project name:'
    '--injectGlobals[Should Jest inject global variables or not]'
    '--json[Print test results in JSON]'
    '--lastCommit[Run all tests affected by file changes in the last commit]'
    '--listTests[List all tests Jest will run given the arguments and exit]'
    '--logHeapUsage[Log the heap usage after every test]'
    '--maxConcurrency=[Maximum number of tests allowed to run concurrently]:number:'
    {-w,--maxWorkers}'=[Maximum number of workers the worker-pool will spawn]:num or percentage:'
    '*--moduleDirectories=[Array of directory names to be searched recursively]:dir name:'
    '*--moduleFileExtensions=[Array of file extensions your modules use]:extension:'
    '--moduleNameMapper=[JSON string mapping regular expressions to module names]:JSON string:'
    '*--modulePathIgnorePatterns=[Array of regexp patterns matched against module paths]:pattern:'
    '*--modulePaths=[Array of absolute paths to additional locations to search for modules]:path:_directories'
    '--noStackTrace[Disable stack trace in test results output]'
    '--notify[Activate notifications for test results]'
    '--notifyMode=[When notifications will appear for test results]:mode:(always failure success change success-change failure-change)'
    {-o,--onlyChanged}'[Run tests based on which files have changed in the current repository]'
    {-f,--onlyFailures}'[Run tests that failed in the previous execution]'
    '--openHandlesTimeout=[Print a warning about probable open handles after this many ms]:milliseconds:'
    '--outputFile=[Write test results to a file when --json is specified]:path:_files'
    '--passWithNoTests[Will not fail if no tests are found]'
    '--preset=[A preset used as a base for Jest configuration]:preset:'
    '--prettierPath=[Path to the prettier module used for inline snapshots]:path:_files'
    '*--projects=[A list of projects that use Jest]:project:_directories'
    '--randomize[Shuffle the order of the tests within a file]'
    '*--reporters=[Custom reporters for the test suite]:reporter:'
    '--resetMocks[Automatically reset mock state between every test]'
    '--resetModules[Reset the module registry for every test]'
    '--resolver=[JSON string for custom resolver]:JSON string:'
    '--restoreMocks[Automatically restore mock state and implementation between every test]'
    '--rootDir=[Root directory that Jest should scan for tests]:dir:_directories'
    '*--roots=[Paths to directories that Jest should use to search for files]:path:_directories'
    {-i,--runInBand}'[Run all tests serially in the current process]'
    '--runTestsByPath[Treat provided patterns as exact file paths]'
    '--runner=[Use a custom runner instead of Jest default test runner]:runner:'
    '--seed=[Set the randomization seed for shuffling tests]:seed number:'
    '*--selectProjects=[Run the tests of the specified projects]:project name:'
    '*--setupFiles=[Paths to modules that run some code before each test suite]:path:_files'
    '*--setupFilesAfterFramework=[Paths to modules that run code before each test in a suite after the test framework]:path:_files'
    '--shard=[Shard tests and execute only the selected shard]:current/all:'
    '--showConfig[Print your Jest config and then exit]'
    '--showSeed[Print the seed value in the test report summary]'
    '--silent[Prevent tests from printing messages through the console]'
    '--skipFilter[Disable the filter provided by --filter]'
    '*--snapshotSerializers=[Paths to snapshot serializer modules]:path:_files'
    '--testEnvironment=[The test environment used for all tests]:environment:'
    '--env=[Alias for --testEnvironment]:environment:'
    '--testEnvironmentOptions=[JSON string with options passed to the testEnvironment]:JSON string:'
    '--testFailureExitCode=[Exit code if the test run failed]:code:'
    '--testLocationInResults[Add location information to the test results]'
    '*--testMatch=[Glob patterns Jest uses to detect test files]:glob pattern:'
    {-t,--testNamePattern}'=[Run only tests with a name matching the regex]:pattern:'
    '*--testPathIgnorePatterns=[Regexp patterns matched against test paths to skip]:pattern:'
    '*--testPathPatterns=[Regexp patterns matched against all test paths]:pattern:'
    '*--testRegex=[Regexp patterns that Jest uses to detect test files]:pattern:'
    '--testResultsProcessor=[Path to a custom results processor module]:path:_files'
    '--testRunner=[Specify a custom test runner]:runner path:'
    '--testSequencer=[Specify a custom test sequencer]:sequencer path:'
    '--testTimeout=[Default timeout of a test in milliseconds]:milliseconds:'
    '--transform=[JSON string mapping regexps to paths to transformers]:JSON string:'
    '*--transformIgnorePatterns=[Regexp patterns matched against source file paths before transformation]:pattern:'
    '*--unmockedModulePathPatterns=[Regexp patterns matched against all modules before returning a mock]:pattern:'
    {-u,--updateSnapshot}'[Re-record snapshots]'
    '--useStderr[Divert all output to stderr]'
    '--verbose[Display individual test results with the test suite hierarchy]'
    '--waitForUnhandledRejections[Give one event loop turn to handle rejectionHandled, uncaughtException or unhandledRejection]'
    '--watch[Watch files for changes and rerun tests related to changed files]'
    '--watchAll[Watch files for changes and rerun all tests]'
    '*--watchPathIgnorePatterns=[Regexp patterns matched against paths before triggering test re-run in watch mode]:pattern:'
    '--watchman[Whether to use watchman for file crawling (disable with --no-watchman)]'
    '--workerThreads[Use worker threads for parallelization instead of child processes]'
    '*:file or directory:_files'
  )

  _arguments -s -S $arguments
}

_jest "$@"
