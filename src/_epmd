#compdef epmd

local -a arguments

arguments=(
  '-address[let epmd listen only on the comma-separated list of IP addresses]:addresses:'
  '-port[let epmd listen to another port than default 4369]'
  '-d[enable debug output]'
  '-debug[enable debugging. This will give a log to]'
  '-daemon[start epmd detached (as a daemon)]'
  '-relaxed_command_check[allow kill and stop commands when epmd is started]'
  '-packet_timeout[set the timeout for response to an EPMD request]:seconds:'
  '-delay_accept[set the delay before accepting connections]:seconds:'
  '-delay_write[set the delay before writing responses]:seconds:'
  '-names[list names registered with the currently running epmd]'
  '-kill[kill the currently running epmd]'
  '-stop[forcibly unregisters a name with epmd]'
  '-systemd[wait for socket from systemd. The option makes sense]'
  '*:filename:_files'
)

_arguments -s -S $arguments
