#compdef qpdf

local -a arguments

arguments=(
  '--password[specify a password for accessing encrypted files]:password: '
  '--linearize[generate a linearized (web optimized) file]'
  '--copy-encryption[copy encryption parameters from specified file]:file:_files'
  '--encryption-file-password[password used to open the encryption source file]:password: '
  '--encrypt[generate an encrypted file]'
  '--decrypt[remove any encryption on the file]'
  '--pages[select specific pages from one or more files]'
  '--print[control printing access]:access:(y n)'
  '--modify[control modify access]:access:(y n)'
  '--extract[allow text/graphic extraction]:access:(y n)'
  '--annotate[allow comments and form fill-in and signing]:access:(y n)'
  '--accessibility[allow accessibility to visually impaired]:access:(y n)'
  '--cleartext-metadata[prevents encryption of metadata]'
  '--use-aes[indicates whether to use AES encryption]:yn:(y n)'
  '--force-V4[forces use of V=4 encryption handler]'
  '--force-R5[forces use of deprecated R=5 encryption]'
  '--stream-data[controls transformation of stream data]:mode:(compress preserve uncompress)'
  '--normalize-content[enables or disables normalization of content streams]:yn:(y n)'
  '--suppress-recovery[prevents qpdf from attempting to recover damaged files]'
  '--object-streams[controls handling of object streams]:mode:(disable preserve generate)'
  '--ignore-xref-streams[tells qpdf to ignore any cross-reference streams]'
  '--qdf[turns on QDF mode]'
  '--min-version[sets the minimum PDF version of the output file]:version: '
  '--force-version[forces this to be the PDF version of the output file]:version: '
  '--deterministic-id[generate deterministic /ID]'
  '--static-id[generate static /ID for testing only]'
  '--static-aes-iv[use a static initialization vector for AES-CBC]'
  '--no-original-object-ids[suppress original object ID comments in qdf mode]'
  '--show-encryption[quickly show encryption parameters]'
  '--check-linearization[check file integrity and linearization status]'
  '--show-linearization[check and show all linearization data]'
  '--show-xref[show the contents of the cross-reference table]'
  '--show-object[show the contents of the given object]:object: '
  '--raw-stream-data[show raw stream data instead of object contents]'
  '--filtered-stream-data[show filtered stream data instead of object contents]'
  '--show-npages[print the number of pages in the file]'
  '--show-pages[shows the object/generation number for each page]'
  '--with-images[also shows the object IDs for images on each page]'
  '--check[check file structure, encryption and linearization]'
  '*:filename:_files'
)

_arguments -s -S $arguments
