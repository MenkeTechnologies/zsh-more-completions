#compdef d2j-dex2smali
# Documentation: https://man.archlinux.org/search?q=d2j-dex2smali
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-b,--no-debug-info}'[\[not impl\] dont write out debug info (.local, .param, .line)]'
  {-f,--force}'[force overwrite]'
  '(- * :)'{-h,--help}'[print this help message]'
  {-l,--use-locals}'[output the .locals directive with the number of non-parameter registers]'
  {-o,--output}'[output dir of .smali files, default is $current_dir/\[file-name\]-out]:dir:_files -/'
  {-p,--no-parameter-registers}'[use the v<n> syntax instead of the p<n> syntax for registers]'
  '*:filename:_files'
)

_arguments -s -S $arguments
