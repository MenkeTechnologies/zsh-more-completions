#compdef v

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:compile and run a V program'
  'build:compile a V program'
  'test:run tests in the current directory'
  'fmt:format V source files'
  'vet:report suspicious code constructs'
  'doc:generate documentation'
  'repl:start the V REPL'
  'init:set up a V project'
  'new:set up a new V project'
  'install:install a module from VPM'
  'remove:remove a module'
  'update:update an installed module'
  'upgrade:upgrade the V compiler'
  'outdated:show outdated modules'
  'search:search for a module in VPM'
  'show:show information about a module'
  'self:rebuild V'
  'symlink:create a symlink to V'
  'translate:translate C code to V'
  'doctor:show useful diagnostic information'
  'version:show version'
  'where:show the location of a V entity'
  'watch:watch for file changes and recompile'
  'bug:file a bug report'
  'missdoc:detect missing documentation'
  'ast:output AST'
  'up:update V'
)

_arguments -s -S \
  '(- *)'{-h,-help,--help}'[show help]' \
  '(- *)-version[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'v command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (run|build)
        _arguments -s -S \
          '-o+[specify output filename]:filename:_files' \
          '-prod[compile in production mode]' \
          '-g[include debug info]' \
          '-cg[pass -g to the C compiler]' \
          '-shared[compile a shared library]' \
          '-cc+[specify the C compiler]:compiler:(gcc clang tcc msvc)' \
          '-cflags+[pass flags to the C compiler]:flags' \
          '-d+[define a compile-time constant]:constant' \
          '-W+[set warning mode]:mode:(all error)' \
          '-autofree[use autofree allocator]' \
          '-gc+[set garbage collector]:gc:(none boehm)' \
          '-skip-unused[skip unused functions]' \
          '-stats[show compilation statistics]' \
          '-os+[target OS]:os:(linux macos windows freebsd openbsd netbsd dragonfly haiku android)' \
          '-arch+[target architecture]:arch:(amd64 arm64 x86 arm32)' \
          '-backend+[set backend]:backend:(c js native interpret)' \
          '-show-timings[show compilation timings]' \
          '-show-callgraph[show call graph]' \
          '-showcc[show C compiler commands]' \
          '-compress[compress the output binary]' \
          '-obf[obfuscate the output]' \
          '-path+[add path to module search]:path:_directories' \
          '-keepc[keep the generated C file]' \
          '-parallel[compile in parallel]' \
          '-profile[enable profiling]' \
          '*:V file or directory:_files' && ret=0
        ;;
      (fmt)
        _arguments -s -S \
          '-w[overwrite the file with formatted output]' \
          '-diff[show diff of formatted changes]' \
          '-c[check if the file is formatted]' \
          '-l[list files that would be reformatted]' \
          '-verify[verify the output]' \
          '*:V file:_files -g "*.v"' && ret=0
        ;;
      (vet)
        _arguments -s -S \
          '-W+[set warning mode]:mode:(all error)' \
          '*:V file or directory:_files' && ret=0
        ;;
      (test)
        _arguments -s -S \
          '-stats[show test statistics]' \
          '*:V file or directory:_files' && ret=0
        ;;
      (doc)
        _arguments -s -S \
          '-f+[output format]:format:(text ansi html)' \
          '-o+[output file]:file:_files' \
          '-all[include private/internal docs]' \
          '-m+[module to document]:module' \
          '*:directory or module:_files' && ret=0
        ;;
      (install)
        _arguments '*:module name' && ret=0
        ;;
      (remove|update)
        _arguments '*:module name' && ret=0
        ;;
    esac
    ;;
esac

return ret
