#compdef nfsdclddb

local -a arguments

arguments=(
    '(- * :)'{-h,--help}'[show the help message and exit]'
    {-p,--path}'[open the sqlite database at specified path]:path:_files'
    {-v,--version}'[specify the schema version to downgrade to]:version:'
    {-s,--summary}'[print summary and clients in the reboot epoch tables]'
    '*:filename:_files'
)
_arguments -s -S $arguments
