#compdef tex

local -a arguments

arguments=(
  '-enc[enable encTeX extensions such as \mubyte]'
  '-fmt[use FMTNAME instead of program name or a %& line]:format:'
  '-halt-on-error[stop processing at the first error]'
  '-ini[be initex, for dumping formats]'
  '-interaction[set interaction mode]:mode:(batchmode nonstopmode scrollmode errorstopmode)'
  '-ipc[send DVI output to a socket as well as the usual output]'
  '-ipc-start[as -ipc, and also start the server at the other end]'
  '-jobname[set the job name to STRING]:name:'
  '-kpathsea-debug[set path searching debugging flags]:flags:'
  '-mltex[enable MLTeX extensions such as \charsubdef]'
  '-output-comment[use STRING for DVI file comment instead of date]:comment:'
  '-output-directory[use existing DIR as the directory to write files in]:directory:_directories'
  '-progname[set program (and fmt) name to STRING]:name:'
  '-recorder[enable filename recorder]'
  '-shell-restricted[enable restricted \write18]'
  '-src-specials[insert source specials into the DVI file]'
  '-src-specials[insert source specials in certain places of the DVI file]'
  '-translate-file[use the TCX file TCXNAME]:file:_files'
  '-8bit[make all characters printable by default]'
  '-help[display this help and exit]'
  '-version[output version information and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
