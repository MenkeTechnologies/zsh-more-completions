#compdef nice

# Zsh completion for nice (run a program with modified scheduling priority)
# Supports both BSD (macOS) and GNU coreutils variants

_nice() {
  local -a arguments

  arguments=(
    '-n[add specified value to the niceness (default 10)]:niceness increment:({-20..19})'
    '--adjustment=[add specified value to the niceness (default 10)]:niceness increment:({-20..19})'
    '(- *)--help[display help and exit]'
    '(- *)--version[output version information and exit]'
    '(-):command: _command_names -e'
    '*::arguments:_normal'
  )

  _arguments -s -S $arguments
}

_nice "$@"
