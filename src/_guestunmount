#compdef guestunmount
# Documentation: https://man.archlinux.org/search?q=guestunmount
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--fd[pipe file descriptor to monitor]'
  '--help[display help message and exit]'
  '(-q --quiet)'{-q,--quiet}'[dont print fusermount errors]'
  '--no-retry[dont retry fusermount]'
  '--retry[retry fusermount N times (default: 5)]'
  '(-v --verbose)'{-v,--verbose}'[verbose messages]'
  '(-V --version)'{-V,--version}'[display version and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
