#compdef brltty-ktb
# Documentation: https://man.archlinux.org/search?q=brltty-ktb
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-a,--audit}'[report problems with the key table.]'
  {-k,--keys}'[list key names.]'
  {-l,--list}'[list key table in help screen format.]'
  {-r,--reStructuredText}'[list key table in reStructuredText format.]'
  '(- * :)'{-h,--help}'[print a usage summary (commonly used options]'
  {-H,--full-help}'[print a usage summary (all options), and]'
  '*:filename:_files'
)

_arguments -s -S $arguments
