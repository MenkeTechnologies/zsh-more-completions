#compdef aichat

# Zsh completion for aichat - AI chat CLI

_arguments \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-m --model)'{-m,--model}'[select model]:model:' \
  '(-r --role)'{-r,--role}'[select role]:role:' \
  '(-s --session)'{-s,--session}'[start or reuse a session]:session name:' \
  '--save-session[save session messages]' \
  '(-e --execute)'{-e,--execute}'[execute commands from output]' \
  '(-c --code)'{-c,--code}'[output code only]' \
  '(-f --file)'{-f,--file}'[include file content]:file:_files' \
  '(-H --no-highlight)'{-H,--no-highlight}'[disable syntax highlighting]' \
  '(-S --no-stream)'{-S,--no-stream}'[disable streaming output]' \
  '(-w --wrap)'{-w,--wrap}'[wrap output]:wrap mode:(auto no)' \
  '--light-theme[use light theme]' \
  '--dry-run[run in dry-run mode]' \
  '--info[show information]' \
  '--list-models[list available models]' \
  '--list-roles[list available roles]' \
  '--list-sessions[list available sessions]' \
  '--list-agents[list available agents]' \
  '--list-rags[list available RAGs]' \
  '(-A --agent)'{-A,--agent}'[use an agent]:agent name:' \
  '(-R --rag)'{-R,--rag}'[use a RAG]:rag name:' \
  '--serve[start as a server]' \
  '--no-conversation[disable conversation context]' \
  '*:text:'
