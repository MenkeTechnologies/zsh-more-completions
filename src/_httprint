#compdef httprint

local -a arguments

arguments=(
  '-h[host to scan (IP address, hostname, or hostname:port)]:host:_hosts'
  '-i[file containing list of hosts]:file:_files'
  '-x[Nmap -oX option generated xml file as input]:file:_files'
  '-s[file containing http fingerprint signatures]:file:_files'
  '-o[output in html format]:file:_files'
  '-oc[output in csv format]:file:_files'
  '-ox[output in xml format]:file:_files'
  '-noautossl[disable automatic detection of SSL]'
  '-tp[ping timeout in milliseconds]:timeout:'
  '-ct[confidence threshold (1-100, default 75)]:threshold:'
  '-ua[user agent string]:user agent:'
  '-t[connection/read timeout in milliseconds]:timeout:'
  '-r[number of retries (default 3, max 30)]:retries:'
  '-P0[turn ICMP ping off]'
  '-nr[no redirection, do not follow 301 redirects]'
  '-th[number of threads (default 8, max 64)]:threads:'
  '*:filename:_files'
)

_arguments -s -S $arguments
