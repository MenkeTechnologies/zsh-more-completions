#compdef xpath5.30
# Documentation: https://man.archlinux.org/search?q=xpath5.30
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-q[only output the resulting PATH.]'
  '-s[use suffix instead of linefeed.]'
  '-p[use prefix instead of nothing.]'
  '-n[t use an external DTD.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
