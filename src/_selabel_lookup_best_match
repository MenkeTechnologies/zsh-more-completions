#compdef selabel_lookup_best_match
# Documentation: https://man.archlinux.org/search?q=selabel_lookup_best_match
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-v[validate file_contxts entries against loaded policy.]'
  '-r[use "raw" function.]'
  '-p[path to check for best match using the link(s) provided.]'
  '-m[optional mode (b, c, d, p, l, s or f) Defaults to 0.]'
  '-f[optional file containing the specs (defaults to]'
  '*:filename:_files'
)

_arguments -s -S $arguments
