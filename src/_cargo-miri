#compdef cargo-miri

local -a _miri_cmds

_miri_cmds=(
  'run:compile and run the current crate with Miri'
  'test:run tests with Miri'
  'nextest:run tests with Miri via cargo-nextest'
  'setup:only perform automatic setup steps'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '1:command:->cmds' \
  '*:: :->args'

case "$state" in
  cmds)
    _describe -t commands 'cargo miri command' _miri_cmds
    ;;
  args)
    case $words[1] in
      run)
        _arguments \
          '(-p --package)'{-p,--package}'[package to run]:package:' \
          '(-j --jobs)'{-j,--jobs}'[number of parallel jobs]:jobs:' \
          '--bin[run the specified binary]:binary:' \
          '--example[run the specified example]:example:' \
          '(-r --release)'{-r,--release}'[build artifacts in release mode]' \
          '--profile[build with the specified profile]:profile:' \
          '--target[build for the target triple]:target:' \
          '--target-dir[directory for all generated artifacts]:directory:_directories' \
          '(-F --features)'{-F,--features}'[features to activate]:features:' \
          '--all-features[activate all available features]' \
          '--no-default-features[do not activate default features]' \
          '--manifest-path[path to Cargo.toml]:path:_files -g "*.toml"' \
          '(-v --verbose)'{-v,--verbose}'[use verbose output]' \
          '(-q --quiet)'{-q,--quiet}'[do not print cargo log messages]' \
          '--color[coloring]:when:(auto always never)' \
          '--config[override a configuration value]:config:' \
          '-Z[unstable (nightly-only) flags]:flag:' \
          '*:extra arguments:'
        ;;
      test)
        _arguments \
          '(-p --package)'{-p,--package}'[package to test]:package:' \
          '(-j --jobs)'{-j,--jobs}'[number of parallel jobs]:jobs:' \
          '--lib[test only library]' \
          '*--bin[test only specified binary]:binary:' \
          '--bins[test all binaries]' \
          '*--test[test only the specified test target]:test:' \
          '--tests[test all test targets]' \
          '*--example[test only the specified example]:example:' \
          '--examples[test all examples]' \
          '--doc[test only documentation tests]' \
          '(-r --release)'{-r,--release}'[build artifacts in release mode]' \
          '--profile[build with the specified profile]:profile:' \
          '--target[build for the target triple]:target:' \
          '--target-dir[directory for all generated artifacts]:directory:_directories' \
          '(-F --features)'{-F,--features}'[features to activate]:features:' \
          '--all-features[activate all available features]' \
          '--no-default-features[do not activate default features]' \
          '--manifest-path[path to Cargo.toml]:path:_files -g "*.toml"' \
          '(-v --verbose)'{-v,--verbose}'[use verbose output]' \
          '(-q --quiet)'{-q,--quiet}'[do not print cargo log messages]' \
          '--color[coloring]:when:(auto always never)' \
          '--config[override a configuration value]:config:' \
          '-Z[unstable (nightly-only) flags]:flag:' \
          '--no-run[compile but do not run tests]' \
          '--no-fail-fast[run all tests regardless of failure]' \
          '*:test name or extra arguments:'
        ;;
      nextest)
        _arguments \
          '(-p --package)'{-p,--package}'[package to test]:package:' \
          '(-j --jobs)'{-j,--jobs}'[number of parallel jobs]:jobs:' \
          '(-F --features)'{-F,--features}'[features to activate]:features:' \
          '--all-features[activate all available features]' \
          '--no-default-features[do not activate default features]' \
          '--manifest-path[path to Cargo.toml]:path:_files -g "*.toml"' \
          '--target[build for the target triple]:target:' \
          '--target-dir[directory for all generated artifacts]:directory:_directories' \
          '*:extra arguments:'
        ;;
      setup)
        _arguments \
          '--print-sysroot[print the Miri sysroot path]' \
          '--subcommand[subcommand Miri is run for]:subcommand:(run test)'
        ;;
    esac
    ;;
esac
