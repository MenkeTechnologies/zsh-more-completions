#compdef docker-proxy
# Documentation: https://man.archlinux.org/search?q=docker-proxy
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-container-ip[container ip]'
  '-container-port[container port (default -1)]'
  '-host-ip[host ip]'
  '-host-port[host port (default -1)]'
  '-proto[proxy protocol (default "tcp")]'
  '*:filename:_files'
)

_arguments -s -S $arguments
