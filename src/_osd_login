#compdef osd_login
# Documentation: https://man.archlinux.org/search?q=osd_login
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-u[target uri e.g. iscsi://<ip>:<port>]'
  '-o[osdname of the target OSD]'
  '-s[systemid of the target OSD]'
  '*:filename:_files'
)

_arguments -s -S $arguments
