#compdef bw

# Zsh completion for bw - Bitwarden CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--pretty[format output with indentation]' \
  '--raw[return raw output]' \
  '--response[return a JSON formatted version of response output]' \
  '--quiet[do not print to stdout]' \
  '--nointeraction[do not prompt for interactive user input]' \
  '--session[pass session key]:session key:' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'login:log in to a user account'
      'logout:log out of the current user account'
      'lock:lock the vault'
      'unlock:unlock the vault'
      'sync:pull the latest vault data from server'
      'generate:generate a password or passphrase'
      'encode:base64 encode stdin'
      'config:manage settings'
      'update:check for updates'
      'completion:generate shell completion'
      'status:show server, last sync, user info, and vault status'
      'list:list an object type'
      'get:get an object from the vault'
      'create:create an object in the vault'
      'edit:edit an object from the vault'
      'delete:delete an object from the vault'
      'restore:restore a deleted object from the vault'
      'move:move an item to an organization'
      'confirm:confirm an object to the organization'
      'import:import vault data from a file'
      'export:export vault data'
      'share:move an item to an organization (deprecated, use move)'
      'send:manage Bitwarden Send'
      'receive:access a Bitwarden Send'
      'serve:start a RESTful API web server'
    )
    _describe -t commands 'bw command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (login)
        _arguments \
          '--method[two-step login method]:method:(0 1 3)' \
          '--code[two-step login code]:code:' \
          '--sso[log in with SSO]' \
          '--apikey[log in with API key]' \
          '--passwordenv[environment variable storing password]:var:' \
          '--passwordfile[file containing password]:file:_files' \
          '--check[check login status]' \
          '1:email:' \
          '2:password:' \
          && ret=0
        ;;
      (unlock)
        _arguments \
          '--check[check lock status]' \
          '--passwordenv[environment variable storing password]:var:' \
          '--passwordfile[file containing password]:file:_files' \
          '1:password:' \
          && ret=0
        ;;
      (generate)
        _arguments \
          {-u,--uppercase}'[include uppercase characters]' \
          {-l,--lowercase}'[include lowercase characters]' \
          {-n,--number}'[include numbers]' \
          {-s,--special}'[include special characters]' \
          {-p,--passphrase}'[generate passphrase]' \
          '--length[length of password]:length:' \
          '--words[number of words in passphrase]:words:' \
          '--separator[word separator for passphrase]:separator:' \
          '--capitalize[capitalize passphrase words]' \
          '--includeNumber[include number in passphrase]' \
          && ret=0
        ;;
      (list)
        _arguments \
          '--search[search term]:search:' \
          '--url[URL for items]:url:' \
          '--folderid[folder ID]:id:' \
          '--collectionid[collection ID]:id:' \
          '--organizationid[organization ID]:id:' \
          '--trash[list trashed items]' \
          '1:object type:(items folders collections organizations org-collections org-members)' \
          && ret=0
        ;;
      (get)
        _arguments \
          '--itemid[item ID]:id:' \
          '--output[output directory or file]:file:_files' \
          '--organizationid[organization ID]:id:' \
          '1:object type:(item username password uri totp exposed attachment folder collection org-collection organization template fingerprint send)' \
          '2:id:' \
          && ret=0
        ;;
      (create)
        _arguments \
          '--file[path to file for attachment]:file:_files' \
          '--itemid[item ID for attachment]:id:' \
          '--organizationid[organization ID]:id:' \
          '1:object type:(item attachment folder org-collection)' \
          '2:encoded json:' \
          && ret=0
        ;;
      (edit)
        _arguments \
          '--organizationid[organization ID]:id:' \
          '1:object type:(item item-collections folder org-collection)' \
          '2:id:' \
          '3:encoded json:' \
          && ret=0
        ;;
      (delete)
        _arguments \
          '--itemid[item ID for attachment]:id:' \
          '--organizationid[organization ID]:id:' \
          '--permanent[permanently delete]' \
          '1:object type:(item attachment folder org-collection)' \
          '2:id:' \
          && ret=0
        ;;
      (import)
        _arguments \
          '--formats[list available formats]' \
          '--organizationid[organization ID]:id:' \
          '1:format:(bitwardencsv bitwardenjson lastpasscsv chromecsv firefoxcsv 1aboratopasscsv keepass2xml)' \
          '2:file:_files' \
          && ret=0
        ;;
      (export)
        _arguments \
          '--output[output path]:file:_files' \
          '--format[export format]:format:(csv json encrypted_json)' \
          '--password[password for encrypted export]:password:' \
          '--organizationid[organization ID]:id:' \
          && ret=0
        ;;
      (config)
        _arguments \
          '1:setting:(server)' \
          '2:value:' \
          && ret=0
        ;;
      (send)
        _arguments -C \
          '1:subcommand:(list template get receive create edit remove-password delete)' \
          && ret=0
        ;;
      (serve)
        _arguments \
          '--hostname[hostname to bind to]:host:_hosts' \
          '--port[port to listen on]:port:' \
          && ret=0
        ;;
      (completion)
        _arguments \
          '--shell[shell type]:shell:(zsh)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
