#compdef flameshot
# Zsh completion for flameshot - Screenshot tool
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help information]' \
  '(- *)--version[show version]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a commands=(
      'gui:launch graphical capture mode'
      'full:take a full desktop screenshot'
      'config:configure flameshot'
      'launcher:open the launcher dialog'
      'screen:take a screenshot of a monitor'
    )
    _describe -t commands 'flameshot command' commands && ret=0
    ;;
  args)
    case $words[1] in
      gui)
        _arguments -s -S \
          '(-p --path)'{-p,--path}'[save path]:path:_directories' \
          '(-d --delay)'{-d,--delay}'[delay in milliseconds]:milliseconds:' \
          '--raw[print raw PNG to stdout]' \
          '(-c --clipboard)'{-c,--clipboard}'[copy to clipboard]' \
          '--pin[pin screenshot to screen]' \
          '--region[set initial capture region]:region (WxH+X+Y):' \
          '--accept-on-select[accept capture as soon as selection is made]' \
          '--last-region[use region from last capture]' && ret=0
        ;;
      full)
        _arguments -s -S \
          '(-p --path)'{-p,--path}'[save path]:path:_directories' \
          '(-d --delay)'{-d,--delay}'[delay in milliseconds]:milliseconds:' \
          '--raw[print raw PNG to stdout]' \
          '(-c --clipboard)'{-c,--clipboard}'[copy to clipboard]' \
          '--region[set capture region]:region (WxH+X+Y):' && ret=0
        ;;
      config)
        _arguments -s -S \
          '--check[check configuration]' \
          '--showhelp[show help in systray]' \
          '--maincolor[set main UI color]:color:' \
          '--contrastcolor[set contrast UI color]:color:' \
          '--trayicon[enable or disable tray icon]:bool:(true false)' && ret=0
        ;;
      screen)
        _arguments -s -S \
          '(-n --number)'{-n,--number}'[monitor number]:number:' \
          '(-p --path)'{-p,--path}'[save path]:path:_directories' \
          '(-d --delay)'{-d,--delay}'[delay in milliseconds]:milliseconds:' \
          '--raw[print raw PNG to stdout]' \
          '(-c --clipboard)'{-c,--clipboard}'[copy to clipboard]' \
          '--region[set capture region]:region (WxH+X+Y):' && ret=0
        ;;
      launcher)
        _arguments -s -S && ret=0
        ;;
    esac
    ;;
esac
return ret
