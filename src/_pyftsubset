#compdef pyftsubset

local -a arguments

arguments=(
  '--gids[specify glyph IDs to include in the subset]:gids'
  '--gids-file[like --gids but reads from a file]:file:_files'
  '--glyphs[specify glyph names to include in the subset]:glyphs'
  '--glyphs-file[like --glyphs but reads from a file]:file:_files'
  '--text[specify characters to include in the subset, as UTF-8 string]:text'
  '--text-file[like --text but reads from a file]:file:_files'
  '--unicodes[specify Unicode codepoints to include in the subset]:unicodes'
  '--unicodes-file[like --unicodes but reads from a file]:file:_files'
  '--ignore-missing-glyphs[do not fail if some requested glyphs or gids are not available]'
  '--no-ignore-missing-glyphs[stop and fail if some requested glyphs or gids are not available]'
  '--ignore-missing-unicodes[do not fail if some requested Unicode characters are not available]'
  '--no-ignore-missing-unicodes[stop and fail if some requested Unicode characters are not available]'
  '--output-file[the output font file]:file:_files'
  '--flavor[specify flavor of output font file]:flavor:(woff woff2)'
  '--with-zopfli[use the Google Zopfli algorithm to compress WOFF]'
  '--retain-gids[retain glyph indices; just empty glyphs not needed in-place.]'
  '--notdef-glyph[add the .notdef glyph to the subset (ie, keep it). \[default\]]'
  '--no-notdef-glyph[drop the .notdef glyph unless specified in the glyph set. This]'
  '--notdef-outline[keep the outline of .notdef glyph. The .notdef glyph outline is]'
  '--no-notdef-outline[when including a .notdef glyph, remove its outline. This saves]'
  '--recommended-glyphs[add glyphs 0, 1, 2, and 3 to the subset, as recommended for]'
  '--no-recommended-glyphs[do not add glyphs 0, 1, 2, and 3 to the subset, unless specified in]'
  '--no-layout-closure[do not expand glyph set to add glyphs produced by OpenType layout]'
  '--layout-features[OpenType layout features to keep]:features'
  '--layout-scripts[OpenType layout scripts to keep]:scripts'
  '--hinting[keep hinting \[default\]]'
  '--no-hinting[drop glyph-specific hinting and font-wide hinting tables, as well]'
  '--desubroutinize[remove CFF use of subroutinizes.  Subroutinization is a way to make CFF]'
  '--no-desubroutinize[leave CFF subroutinizes as is, only throw away unused subroutinizes.]'
  '--drop-tables[specify tables to drop]:tables'
  '--no-subset-tables[specify tables to include but not subset]:tables'
  '--passthrough-tables[do not drop tables that the tool does not know how to subset.]'
  '--no-passthrough-tables[tables that the tool does not know how to subset and are not specified]'
  '--hinting-tables[specify hinting tables to keep or drop]:tables'
  '--legacy-kern[keep TrueType kern table even when OpenType GPOS is available.]'
  '--no-legacy-kern[drop TrueType kern table if OpenType GPOS is available. \[default\]]'
  '--name-IDs[name IDs to include]:name-ids'
  '--name-legacy[keep legacy (non-Unicode) name table entries (0.x, 1.x etc.).]'
  '--no-name-legacy[drop legacy (non-Unicode) name table entries \[default\]]'
  '--name-languages[name languages to include]:lang-ids'
  '--obfuscate-names[make the font unusable as a system font by replacing name IDs 1, 2, 3, 4]'
  '--glyph-names[keep PS glyph names in TT-flavored fonts. In general glyph names are]'
  '--no-glyph-names[drop PS glyph names in TT-flavored fonts, by using post table]'
  '--legacy-cmap[keep the legacy cmap subtables (0.x, 1.x, 4.x etc.).]'
  '--no-legacy-cmap[drop the legacy cmap subtables. \[default\]]'
  '--symbol-cmap[keep the 3.0 symbol cmap.]'
  '--no-symbol-cmap[drop the 3.0 symbol cmap. \[default\]]'
  '--recalc-bounds[recalculate font bounding boxes.]'
  '--no-recalc-bounds[keep original font bounding boxes. This is faster and still safe]'
  '--recalc-timestamp[set font modified timestamp to current time.]'
  '--no-recalc-timestamp[do not modify font modified timestamp. \[default\]]'
  '--canonical-order[order tables as recommended in the OpenType standard. This is not]'
  '--no-canonical-order[keep original order of font tables. This is faster. \[default\]]'
  '--prune-unicode-ranges[update the OS/2 ulUnicodeRange* bits after subsetting. The Unicode]'
  '--no-prune-unicode-ranges[dont change the OS/2 ulUnicodeRange* bits.]'
  '--recalc-average-width[update the OS/2 xAvgCharWidth field after subsetting.]'
  '--no-recalc-average-width[dont change the OS/2 xAvgCharWidth field. \[default\]]'
  '--recalc-max-context[update the OS/2 usMaxContext field after subsetting.]'
  '--no-recalc-max-context[dont change the OS/2 usMaxContext field. \[default\]]'
  '--font-number[select font number for TrueType Collection (.ttc/.otc), starting from 0.]'
  '--pretty-svg[when subsetting SVG table, use lxml pretty_print=True option to indent]'
  '--verbose[display verbose information of the subsetting process.]'
  '--timing[display detailed timing information of the subsetting process.]'
  '--xml[display the TTX XML representation of subsetted font.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
