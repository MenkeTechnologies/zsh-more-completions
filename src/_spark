#compdef spark-submit

local -a arguments

arguments=(
    '--master[Spark master URL]:url:(local local\[\*\] yarn spark\://HOST\:PORT mesos\://HOST\:PORT k8s\://HOST\:PORT)'
    '--deploy-mode[Deploy mode]:mode:(client cluster)'
    '--class[Application main class]:class'
    '--name[Application name]:name'
    '--jars[Comma-separated jars]:jars:_files -g "*.jar"'
    '--packages[Comma-separated Maven coordinates]:packages'
    '--exclude-packages[Packages to exclude]:packages'
    '--repositories[Maven repositories]:repos'
    '--py-files[Python files for PYTHONPATH]:files:_files -g "*.{py,zip,egg}"'
    '--files[Files for working directory]:files:_files'
    '--archives[Archives to extract]:archives:_files -g "*.{tar.gz,tgz,zip}"'
    '--conf[Spark configuration property]:key=value'
    '--properties-file[Properties file]:file:_files -g "*.{properties,conf}"'
    '--driver-memory[Driver memory]:memory'
    '--driver-java-options[Driver Java options]:options'
    '--driver-library-path[Driver library path]:path:_directories'
    '--driver-class-path[Driver class path]:path'
    '--executor-memory[Executor memory]:memory'
    '--total-executor-cores[Total executor cores]:cores'
    '--num-executors[Number of executors]:count'
    '--executor-cores[Cores per executor]:cores'
    '--queue[YARN queue]:queue'
    '--proxy-user[User to impersonate]:user:_users'
    '--supervise[Restart on failure (standalone/Mesos)]'
    '--kill[Kill a submission]:submission_id'
    '--status[Check submission status]:submission_id'
    '--verbose[Print additional debug output]'
    '--version[Print version]'
    '--help[Show help]'
    '*:application jar or script:_files -g "*.{jar,py,R}"'
)

_arguments -s -S $arguments
