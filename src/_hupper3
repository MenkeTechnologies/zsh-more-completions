#compdef hupper3

local -a arguments

arguments=(
  {-h,--help}'[show this help message and exit]'
  '-m[mode or machine]'
  '-w[wait or width]'
  '-x[exclude pattern]'
  '-v[verbose output]'
  '-q[quiet/silent mode]'
  '--shutdown-interval[shutdown grace period in seconds]'
  '--reload-interval[reload poll interval in seconds]'
  '*:filename:_files'
)

_arguments -s -S $arguments
