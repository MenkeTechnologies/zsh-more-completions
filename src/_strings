#compdef strings

local arguments

arguments=(
  '-a[scan the entire file, including all sections]'
  '-[scan all bytes of the file (default for non-object files)]'
  '--[treat all following arguments as filenames]'
  '-o[precede each string by its offset in decimal (alias for --radix=o)]'
  '(-t --radix)'{-t,--radix}'[print offset in the given base before each string]:format:((d\:"decimal" o\:"octal" x\:"hexadecimal"))'
  '(-n --bytes)'{-n,--bytes}'[set minimum string length]:length:'
  '(-d --data)'{-d,--data}'[only scan the data sections in the file]'
  '(-f --print-file-name)'{-f,--print-file-name}'[print the name of the file before each string]'
  '(-w --include-all-whitespace)'{-w,--include-all-whitespace}'[include all whitespace as valid string characters]'
  '(-T --target)'{-T,--target}'[specify the binary file format]:format:'
  '(-e --encoding)'{-e,--encoding}'[select character size and endianness]:encoding:((s\:"7-bit" S\:"8-bit" b\:"16-bit big-endian" l\:"16-bit little-endian" B\:"32-bit big-endian" L\:"32-bit little-endian"))'
  '(-s --output-separator)'{-s,--output-separator}'[separator string between output strings]:separator:'
  '*-arch[architecture from universal file to operate on]:architecture:(x86_64 arm64 arm64e i386 all)'
  '(- * :)'{-h,--help}'[display help information]'
  '(-v -V --version)'{-v,-V,--version}'[display version information]'
  '*:file:_files'
)

_arguments -s $arguments
