#compdef svn-multi
# Documentation: https://man.archlinux.org/search?q=svn-multi
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--group[Use given group name <GN> for all following files]'
  '--fls[Read list of (additional) files from the file <jobname>.fls. This]'
  '*:filename:_files'
)

_arguments -s -S $arguments
