#compdef abrt
# Documentation: https://man.archlinux.org/search?q=abrt
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    {-a,--auth}'[Authenticate and show all problems on this machine.]'
    {-v,--version}'[Show program\\(cqs version number and exit.]'
    {-h,--help}'[Show help message.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
