#compdef sslyze

local -a arguments

arguments=(
  '--version[show programs version number and exit]'
  '(- * :)'{-h,--help}'[show this help message and exit]'
  '--xml_out[writes the scan results as an XML document to the file]:file:_files'
  '--targets_in[reads the list of targets to scan from the file]:file:_files'
  '--timeout[sets the timeout value in seconds used for every socket connection]:seconds:'
  '--nb_retries[sets the number of retry attempts for failed connections]:retries:'
  '--https_tunnel[tunnels all traffic to the target server through an HTTP CONNECT proxy]:proxy:'
  '--starttls[performs StartTLS handshakes when connecting to the target server]:protocol:(smtp xmpp xmpp_server pop3 ftp imap ldap rdp postgres auto)'
  '--xmpp_to[optional setting for STARTTLS XMPP]:hostname:'
  '--sni[use Server Name Indication to specify the hostname]:hostname:'
  '--quiet[hide script standard outputs]'
  '--regular[regular HTTPS scan; shortcut for --sslv2 --sslv3 --tlsv1 --reneg --resum --certinfo --http_get --hide_rejected_ciphers --compression --heartbleed]'
  '--cert[client certificate chain filename]:file:_files'
  '--key[client private key filename]:file:_files'
  '--keyform[client private key format]:format:(DER PEM)'
  '--pass[client private key passphrase]:passphrase:'
  '--hsts[checks support for HTTP Strict Transport Security]'
  '--certinfo[verifies the validity of the server certificate]'
  '--ca_file[local Certificate Authority file (in PEM format)]:file:_files'
  '--chrome_sha1[determines if the server will be affected by Google Chrome SHA-1 deprecation]'
  '--heartbleed[tests the server for the OpenSSL Heartbleed vulnerability]'
  '--reneg[tests the server for client-initiated renegotiation support]'
  '--resum[tests the server for session resumption support]'
  '--resum_rate[performs 100 session resumptions with the server]'
  '--compression[tests the server for Zlib compression support]'
  '--sslv2[lists the SSL 2.0 cipher suites supported by the server]'
  '--sslv3[lists the SSL 3.0 cipher suites supported by the server]'
  '--tlsv1[lists the TLS 1.0 cipher suites supported by the server]'
  '--tlsv1_1[lists the TLS 1.1 cipher suites supported by the server]'
  '--tlsv1_2[lists the TLS 1.2 cipher suites supported by the server]'
  '--http_get[for each cipher suite, sends an HTTP GET request]'
  '--hide_rejected_ciphers[hide rejected cipher suites from the output]'
  '*:filename:_files'
)

_arguments -s -S $arguments
