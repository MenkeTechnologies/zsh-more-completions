#compdef mmv mcp mln
# Zsh completion for mmv/mcp/mln (mass move/copy/link files)
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-h[Show help]' \
  '-d[Delete matched source files]' \
  '-v[Verbose, show each rename]' \
  '-n[No-execute, dry run]' \
  '-a[Append to existing target files]' \
  '1:from pattern:_files' \
  '2:to pattern:' && ret=0
return ret
