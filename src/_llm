#compdef llm

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a commands=(
      'prompt:execute a prompt'
      'chat:start an interactive chat'
      'keys:manage API keys'
      'logs:browse logged prompts and responses'
      'models:manage models'
      'plugins:manage plugins'
      'aliases:manage model aliases'
      'templates:manage templates'
      'embed:generate embeddings'
      'embed-models:manage embedding models'
      'embed-multi:embed multiple strings at once'
      'similar:find similar items'
      'collections:manage collections'
      'install:install a plugin'
      'uninstall:uninstall a plugin'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  args)
    case "$words[1]" in
      prompt)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-m --model)'{-m,--model}'[model to use]:model' \
          '(-s --system)'{-s,--system}'[system prompt]:prompt' \
          '(-t --template)'{-t,--template}'[template to use]:template' \
          '(-p --param)'{-p,--param}'[set parameter]:key value' \
          '(-o --option)'{-o,--option}'[set model option]:key value' \
          '--no-log[do not log to database]' \
          '--log[force logging to database]' \
          '(-n --no-stream)'{-n,--no-stream}'[do not stream output]' \
          '(-c --continue)'{-c,--continue}'[continue last conversation]' \
          '--cid[continue specified conversation]:id' \
          '--key[API key]:key' \
          '1:prompt text' && ret=0
        ;;
      chat)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-m --model)'{-m,--model}'[model to use]:model' \
          '(-s --system)'{-s,--system}'[system prompt]:prompt' \
          '(-t --template)'{-t,--template}'[template to use]:template' \
          '(-o --option)'{-o,--option}'[set model option]:key value' \
          '--no-log[do not log to database]' \
          '--cid[continue specified conversation]:id' \
          '--key[API key]:key' && ret=0
        ;;
      keys)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(set get path)' && ret=0
        ;;
      models)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(list default)' \
          '--options[show model options]' && ret=0
        ;;
      logs)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-n --count)'{-n,--count}'[number of logs]:count' \
          '(-m --model)'{-m,--model}'[filter by model]:model' \
          '(-q --query)'{-q,--query}'[search query]:query' \
          '--json[output as JSON]' \
          '--cid[filter by conversation ID]:id' \
          '(-t --truncate)'{-t,--truncate}'[truncate output]' && ret=0
        ;;
      templates)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(list show edit path)' && ret=0
        ;;
      aliases)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(list set remove path)' && ret=0
        ;;
      install)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:package name' && ret=0
        ;;
      uninstall)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:package name' && ret=0
        ;;
      embed)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-m --model)'{-m,--model}'[embedding model]:model' \
          '(-i --input)'{-i,--input}'[input file]:file:_files' \
          '--store[store in collection]' \
          '(-c --collection)'{-c,--collection}'[collection name]:collection' \
          '--key[API key]:key' \
          '1:content' && ret=0
        ;;
    esac
    ;;
esac

return ret
