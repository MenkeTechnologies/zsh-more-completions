#compdef sd2raw
# Documentation: https://man.archlinux.org/search?q=sd2raw
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-c[display the call graph nesting level]'
  '-h[show this help message]'
  '-p[set password to open the file]'
  '-v[show version information]'
  '*:filename:_files'
)

_arguments -s -S $arguments
