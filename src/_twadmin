#compdef twadmin


local -a arguments

arguments=(
    {-m,--create-cfgfile}'[Mode selector.]'
    {-v,--verbose}'[Verbose output mode. Mutually exclusive with (-s).]'
    {-s,--silent,--quiet}'[Silent output mode. Mutually exclusive with (-v).]'
    {-c,--cfgfile}'[Specify the destination of the encoded (and optionally signed) configuration …]'
    {-S,--site-keyfile}'[Use the specified site key file to encode and sign the new configuration file.]'
    {-Q,--site-passphrase}'[Specifies passphrase to be used with site key for configuration file encoding…]'
    {-e,--no-encryption}'[Do not sign the configuration file being stored.]'
    '--print-cfgfile[Mode selector.]'
    '--create-polfile[Mode selector.]'
    {-p,--polfile}'[Specify the destination of the encoded (and optionally signed) policy file.]'
    '--print-polfile[Mode selector.]'
    '--remove-encryption[Mode selector.]'
    {-L,--local-keyfile}'[Specify the local keyfile to use to verify database files and reports.]'
    {-P,--local-passphrase}'[Specify the passphrase to use when verifying with the old local keyfile.]'
    '--encrypt[Mode selector.]'
    '--examine[Mode selector.]'
    '--generate-keys[Mode selector.]'
    '--key-size[Specify the key size (1024 or 2048 bits) when generating keys.]'
    '--change-passphrases[Mode selector.]'
    '--local-passphrase-old[specify passphrase to decrypt old local keyfile]:passphrase:'
    '-K[specify key size (1024 or 2048 bits)]:size:(1024 2048)'
    '--site-passphrase-old[specify passphrase to decrypt old site keyfile]:passphrase:'
    '*:filename:_files'
)
_arguments -s -S $arguments
