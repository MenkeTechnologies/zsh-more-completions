#compdef img_cat
# Documentation: https://man.archlinux.org/search?q=img_cat
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-i[the format of the image file (use i list for supported types)]'
  '-b[the size (in bytes) of the device sectors]'
  '-s[the sector number to start at]'
  '-e[the sector number to stop at]'
  '-v[verbose output to stderr]'
  '-V[Print version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
