#compdef SplitForks
# Documentation: https://man.archlinux.org/search?q=SplitForks
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-s,--}'[strip resource fork from source after splitting]'
  {-v,--}'[verbose mode]'
  {-u,--}'[show usage]'
  '*:filename:_files'
)

_arguments -s -S $arguments
