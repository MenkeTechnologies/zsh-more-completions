#compdef thin_generate_metadata
# Documentation: https://man.archlinux.org/search?q=thin_generate_metadata
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--data-block-size[data block size]:size:'
  '--nr-data-blocks[number of data blocks]:count:'
  '--nr-thins[number of thin devices]:count:'
  '--blocks-per-thin[blocks per thin device]:count:'
  '--run-lengths[use run length encoding]'
  {-o,--output}'[output device or file]:file:_files'
  '*:filename:_files'
)

_arguments -s -S $arguments
