#compdef textlint

local -a arguments

arguments=(
  {-h,--help}'[show help.]'
  {-c,--config}'[use configuration from this file or sharable config.]:file:_files'
  '--ignore-path[specify path to a file containing patterns that describes files to ignore.]:file:_files'
  '--init[create the config file if not existed. - default: false]'
  '--fix[automatically fix problems]'
  '--dry-run[enable dry-run mode for --fix. Only show result, dont change the file.]'
  '--debug[outputs debugging information]'
  {-v,--version}'[outputs the version number.]'
  '--stdin[lint text provided on <STDIN>. - default: false]'
  '--stdin-filename[specify filename to process STDIN as]:filename:'
  {-o,--output-file}'[enable report to be written to a file.]:file:_files'
  {-f,--format}'[use a specific output format.]:format:'
  '--no-color[disable color in piped output.]'
  '--quiet[report errors only. - default: false]'
  '--no-textlintrc[disable .textlintrc]'
  '--plugin[set plugin package name]:plugin:'
  '--rule[set rule package name]:rule:'
  '--preset[set preset package name and load rules from preset package.]:preset:'
  '--rulesdir[use additional rules from this directory]:directory:_directories'
  '--cache[only check changed files - default: false]'
  '--cache-location[path to the cache file or directory]:path:_files'
  '--experimental[enable experimental flag.Some feature use on experimental.]'
  '--rules-base-directory[set module base directory.]:directory:_directories'
  '--parallel[lint files in parallel]'
  '--max-concurrency[maxConcurrency for --parallel]:number:'
  '*:filename:_files'
)

_arguments -s -S $arguments
