#compdef inotifywait

local -a events
events=(
  'access' 'modify' 'attrib' 'close_write' 'close_nowrite' 'close'
  'open' 'moved_to' 'moved_from' 'move' 'create' 'delete'
  'delete_self' 'move_self' 'unmount'
)

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  {-@,--fromfile}'[read filenames from file]:file:_files' \
  {-m,--monitor}'[keep listening for events forever]' \
  {-d,--daemon}'[run as daemon]' \
  {-o,--outfile}'[output events to file]:file:_files' \
  {-s,--syslog}'[send errors to syslog]' \
  {-r,--recursive}'[watch directories recursively]' \
  {-q,--quiet}'[print less output]' \
  '--exclude[exclude files matching pattern]:pattern:' \
  '--excludei[exclude files matching pattern (case insensitive)]:pattern:' \
  '--include[include only files matching pattern]:pattern:' \
  '--includei[include only files matching pattern (case insensitive)]:pattern:' \
  {-t,--timeout}'[timeout in seconds]:seconds:' \
  '*'{-e,--event}'[listen for specific event]:event:('"${events[*]}"')' \
  '--format[specify output format]:format:' \
  '--no-newline[do not print newline after event]' \
  '--timefmt[specify time format]:format:' \
  {-c,--csv}'[output in CSV format]' \
  '--no-dereference[do not follow symlinks]' \
  '*:file or directory:_files'
