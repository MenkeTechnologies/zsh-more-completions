#compdef grpc_cli

# Zsh completion for grpc_cli - gRPC command-line client

_grpc_cli_commands() {
  local -a commands=(
    'ls:list services or methods'
    'call:call a method'
    'type:show type information'
    'parse:parse message'
    'totext:convert to text format'
    'tojson:convert to JSON format'
    'help:show help'
  )
  _describe -t commands 'grpc_cli command' commands
}

_grpc_cli_call() {
  _arguments \
    '--metadata=[request metadata (key\:value)]:key\:value:' \
    '--proto_path=[path to proto files]:path:_directories' \
    '--protofiles=[proto file]:file:_files' \
    '--infile=[input file]:file:_files' \
    '--outfile=[output file]:file:_files' \
    '--binary_input[input is binary]' \
    '--binary_output[output is binary]' \
    '--json_input[input is JSON]' \
    '--json_output[output is JSON]' \
    '--timeout=[timeout in seconds]:seconds:' \
    '--channel_creds_type=[channel credentials type]:type:(ssl insecure)' \
    '--ssl_target=[SSL target name override]:override:' \
    '--ssl_client_cert=[SSL client certificate file]:file:_files' \
    '--ssl_client_key=[SSL client key file]:file:_files' \
    '--ssl_server_cert=[SSL server certificate file]:file:_files' \
    '--help[show help]' \
    '1:server address:' \
    '2:method:'
}

_grpc_cli() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '--help[show help]' \
    '1:command:_grpc_cli_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        ls)
          _arguments \
            '--l[long listing format]' \
            '--help[show help]' \
            '1:server address:'
          ;;
        call)
          _grpc_cli_call
          ;;
        type)
          _arguments \
            '--help[show help]' \
            '1:server address:' \
            '2:type name:'
          ;;
        *)
          _arguments '--help[show help]'
          ;;
      esac
      ;;
  esac
}

_grpc_cli "$@"
