#compdef bdemount

local -a arguments

arguments=(
  '-h[show this help]'
  '-k[specify the full volume encryption key and tweak key]:key:'
  '-o[specify the volume offset in bytes]:offset:'
  '-p[specify the password/passphrase]:password:'
  '-r[specify the recovery password/passphrase]:recovery password:'
  '-s[specify the path of the file containing the startup key]:key file:_files'
  '-v[verbose output to stderr]'
  '-V[print version]'
  '-X[extended options to pass to sub system]:options:'
  '*:filename:_files'
)

_arguments -s -S $arguments
