#compdef micromamba

# Zsh completion for micromamba - fast, statically-linked conda package manager

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'activate:Activate an environment'
  'deactivate:Deactivate current environment'
  'install:Install a list of packages'
  'update:Update packages'
  'remove:Remove a list of packages'
  'create:Create a new environment'
  'list:List installed packages'
  'clean:Clean package caches'
  'config:Configure micromamba'
  'info:Show general information about the micromamba installation'
  'init:Initialize shell for micromamba'
  'env:Manage environments'
  'run:Run a command in environment'
  'search:Find packages available in a channel'
  'shell:Generate shell initialization script'
  'self-update:Update micromamba to the latest version'
  'repoquery:Advanced query of packages and dependencies'
  'package:Build or extract packages'
  'help:Print help'
)

_arguments -s -S \
  '(-r --root-prefix)'{-r,--root-prefix}'[micromamba root directory]:dir:_files -/' \
  '(-p --prefix)'{-p,--prefix}'[path to the conda prefix]:path:_files -/' \
  '(-n --name)'{-n,--name}'[name of the environment]:name:' \
  '(-c --channel)'{-c,--channel}'[channels to use]:channel:' \
  '--no-channel-priority[disable channel priority]' \
  '--strict-channel-priority[enable strict channel priority]' \
  '-y[disable prompt]' \
  '--yes[disable prompt]' \
  '--json[report output as JSON]' \
  '--log-level[set log level]:level:(trace debug info warning error critical off)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      install|update|remove)
        _arguments \
          '(-n --name)'{-n,--name}'[name of the environment]:name:' \
          '(-p --prefix)'{-p,--prefix}'[path to the conda prefix]:path:_files -/' \
          '(-c --channel)'{-c,--channel}'[channels to use]:channel:' \
          '--freeze-installed[do not update installed packages]' \
          '--dry-run[only display what would have been done]' \
          '*:package:' && ret=0
        ;;
      create)
        _arguments \
          '(-n --name)'{-n,--name}'[name of the environment]:name:' \
          '(-p --prefix)'{-p,--prefix}'[path to the conda prefix]:path:_files -/' \
          '-f[environment definition file]:file:_files' \
          '--file[environment definition file]:file:_files' \
          '*:package:' && ret=0
        ;;
      shell)
        _arguments ':shell:(bash zsh fish xonsh cmd.exe)' && ret=0
        ;;
    esac
    ;;
esac

return ret
