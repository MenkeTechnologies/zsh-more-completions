#compdef file

# Zsh completion for file - determine file type

local -a arguments

arguments=(
  '(- *)--help[display help and exit]'
  {-v,--version}'[output version information and exit]'
  {-b,--brief}'[do not prepend filenames to output lines]'
  {-c,--checking-printout}'[print the parsed form of the magic file]'
  {-C,--compile}'[compile file specified by -m into magic.mgc]'
  '-d[apply the default system tests]'
  {-D,--debug}'[print debugging messages]'
  '-E[on filesystem errors, issue an error message and exit]'
  {-e,--exclude}'[exclude test from the list of tests]:test:(apptype ascii cdf compress csv elf encoding json soft tar text tokens)'
  '--exclude-quiet[like --exclude, but ignore unknown tests]:test:(apptype ascii cdf compress csv elf encoding json soft tar text tokens)'
  '--extension[output a slash-separated list of valid extensions]'
  {-f,--files-from}'[read filenames to be examined from file]:file:_files'
  {-F,--separator}'[use string as separator instead of colon]:separator string'
  {-h,--no-dereference}"[don't follow symlinks (default)]"
  '-i[do not further classify regular files (BSD)]'
  {-I,--mime}'[output MIME type strings (--mime-type and --mime-encoding)]'
  '--mime-type[output the MIME type]'
  '--mime-encoding[output the MIME encoding]'
  '--apple[output the Apple CREATOR/TYPE]'
  {-k,--keep-going}"[don't stop at the first match]"
  {-l,--list}'[list magic strength]'
  {-L,--dereference}'[follow symlinks]'
  {-m,--magic-file}'[use specified magic number files]:magic files:_files'
  '-M[like -m but also apply default tests after]:magic files:_files'
  {-n,--no-buffer}'[do not buffer output]'
  {-N,--no-pad}'[do not pad output]'
  {-0,--print0}'[terminate filenames with ASCII NUL]'
  {-p,--preserve-date}'[preserve access times on files]'
  {-P,--parameter}'[set file engine parameter limits]:parameter (name=value):(bytes elf_notes elf_phnum elf_shnum encoding indir name regex)'
  {-r,--raw}"[don't translate unprintable chars to \\ooo]"
  {-s,--special-files}'[treat special (block/char devices) files as ordinary]'
  {-S,--no-sandbox}'[disable system call sandboxing]'
  {-z,--uncompress}'[try to look inside compressed files]'
  {-Z,--uncompress-noreport}'[only print the contents of compressed files]'
  '*:file:_files'
)

_arguments -s -S $arguments
