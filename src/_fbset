#compdef fbset

local -a arguments

arguments=(
    '(- * :)'{-h,--help}'[display this usage information]'
    '--test[do not change, just test whether the mode is valid]'
    {-s,--show}'[display video mode settings]'
    {-i,--info}'[display all frame buffer information]'
    {-v,--verbose}'[verbose mode]'
    {-V,--version}'[print version information]'
    {-x,--xfree86}'[XFree86 compatibility mode]'
    {-a,--all}'[change all virtual consoles on this device]'
    '-fb[processed frame buffer device]:device:_files'
    '-db[video mode database file]:file:_files'
    '-xres[horizontal resolution (in pixels)]:pixels:'
    '-yres[vertical resolution (in pixels)]:pixels:'
    '-vxres[virtual horizontal resolution (in pixels)]:pixels:'
    '-vyres[virtual vertical resolution (in pixels)]:pixels:'
    '-depth[display depth (in bits per pixel)]:depth:'
    '-nonstd[select nonstandard video mode]:mode:'
    {-g,--geometry}'[.. : set all geometry parameters at once]'
    '-match[set virtual vertical resolution by virtual resolution]'
    '-pixclock[pixel clock (in picoseconds)]:picoseconds:'
    '-left[left margin (in pixels)]:pixels:'
    '-right[right margin (in pixels)]:pixels:'
    '-upper[upper margin (in pixel lines)]:lines:'
    '-lower[lower margin (in pixel lines)]:lines:'
    '-hslen[horizontal sync length (in pixels)]:pixels:'
    '-vslen[vertical sync length (in pixel lines)]:lines:'
    {-t,--timings}'[.. : set all timing parameters at once]'
    '-accel[hardware text acceleration enable]:bool:(false true)'
    '-hsync[horizontal sync polarity]:polarity:(low high)'
    '-vsync[vertical sync polarity]:polarity:(low high)'
    '-csync[composite sync polarity]:polarity:(low high)'
    '-gsync[synch on green]:bool:(false true)'
    '-extsync[external sync enable]:bool:(false true)'
    '-sync[custom (driver specific) sync value]:value:'
    '-bcast[broadcast enable]:bool:(false true)'
    '-laced[interlace enable]:bool:(false true)'
    '-double[doublescan enable]:bool:(false true)'
    '-rgba[recommended length of color entries]:rgba:'
    '-grayscale[grayscale enable]:bool:(false true)'
    '-move[move the visible part]:direction:(left right up down)'
    '-step[step increment (in pixels or pixel lines)]:step:'
    '*:filename:_files'
)

_arguments -s -S $arguments
