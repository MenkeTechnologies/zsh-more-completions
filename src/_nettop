#compdef nettop

local -a arguments

arguments=(
  '-m[set the mode]:mode:'
  '-n[enable address to name resolution]'
  '-p[select a particular process for display]:pid:'
  '-c[be gentle on the CPU - draw less often]'
  '-d[enable delta mode]'
  '-x[display numbers instead of human readable suffixes]'
  '-P[show per-process summaries only, excluding connection details]'
  '-s[set the delay between updates in seconds]:seconds:'
  '-t[set interface type]:type:'
  '-l[use logging mode and display N samples]:samples:'
  '-L[use logging mode in CSV format and display N samples]:samples:'
  '-j[include columns named in the parameter list]:columns:'
  '-J[include only the columns named in the parameter list]:columns:'
  '-k[exclude columns named in the parameter list]:columns:'
  '-h[display help message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
