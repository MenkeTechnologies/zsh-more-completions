#compdef nfanon
# Documentation: https://raw.githubusercontent.com/phaag/nfdump/master/man/nfanon.1
# Reference accessed: 2026-05-30
# nfanon — anonymize IP addresses in nfdump flow files using CryptoPAn.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)-h[print help and exit]' \
  '-r+[path to flow file(s) to anonymize (single file or directory)]:path:_files' \
  '-w+[output file (defaults to overwriting source)]:file:_files' \
  '-K+[encryption key (32-char string OR 64-char hex starting with 0x)]:key:' \
  '-v+[verbose level (0 disables activity spinner)]:level:' \
  '-W+[worker thread count (default: online CPU cores)]:N:' \
  && ret=0

return ret
