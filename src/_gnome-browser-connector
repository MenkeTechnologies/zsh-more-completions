#compdef gnome-browser-connector
# Documentation: https://man.archlinux.org/search?q=gnome-browser-connector
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[show help options]'
  '--help-all[show all help options]'
  '--help-gapplication[show GApplication options]'
  {-c,--connector}'[run as browser messaging host]'
  '*:filename:_files'
)

_arguments -s -S $arguments
