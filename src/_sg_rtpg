#compdef sg_rtpg
# Documentation: https://man.archlinux.org/search?q=sg_rtpg
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {--decode,-d}'[decode status and asym. access state]'
  {--extended,-e}'[use extended header parameter data format]'
  {--help,-h}'[print out usage message]'
  {--hex,-H}'[print out response in hex]'
  {--raw,-r}'[output response in binary to stdout]'
  {--verbose,-v}'[increase verbosity]'
  {--version,-V}'[print version string and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
