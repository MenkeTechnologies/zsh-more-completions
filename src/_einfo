#compdef einfo
# Documentation: https://man.archlinux.org/search?q=einfo
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[help message]'
  '-q[dont print short meta info summary]'
  '-v[verbose (error)]'
  '-vv[verbose (warnings)]'
  '-vvv[verbose (info)]'
  '-d[debug mode (implies -vvv)]'
  '-p[linear print book (normal reading)]'
  '-pp[print the whole book]'
  '-t[id> prints the tour <tour id>]'
  '*:filename:_files'
)

_arguments -s -S $arguments
