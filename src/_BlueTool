#compdef BlueTool
# Documentation: https://man.archlinux.org/search?q=BlueTool
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[this message.]'
  '-f[read commands from file at startup.]'
  '-F[runs the default script for a given sequence.]'
  '-c[execute commands from string at startup.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
