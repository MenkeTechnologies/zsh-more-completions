#compdef atuin

# Zsh completion for atuin (shell history tool)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'history:Manipulate shell history'
      'import:Import shell history from other tools'
      'stats:Calculate statistics for history'
      'search:Interactively search through shell history'
      'sync:Sync history with the configured server'
      'login:Login to the configured server'
      'logout:Log out'
      'register:Register with the configured server'
      'key:Print the encryption key'
      'status:Show sync status'
      'account:Manage your account'
      'kv:Manage the key-value store'
      'store:Manage the local store'
      'dotfiles:Manage dotfiles with Atuin'
      'default-config:Print the default configuration'
      'server:Start an atuin server'
      'init:Output shell setup'
      'info:Print atuin environment info'
      'doctor:Check atuin setup and configuration'
      'gen-completions:Generate shell completions'
    )
    _describe -t commands 'atuin command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      history)
        local -a subcmds=(
          'start:Begins a new command in the history'
          'end:Finishes a new command in the history'
          'list:List all items in history'
          'last:Get the last command ran'
          'prune:Delete history entries matching the query'
          'init-store:Init the local store'
        )
        _describe -t subcmds 'history subcommand' subcmds && ret=0
        ;;
      import)
        local -a sources=(
          'auto:Import from the best available source'
          'zsh:Import from zsh history'
          'zsh-hist-db:Import from zsh-histdb'
          'bash:Import from bash history'
          'resh:Import from RESH history'
          'fish:Import from fish history'
          'nu:Import from Nushell history'
          'nu-hist-db:Import from Nushell history DB'
        )
        _describe -t sources 'import source' sources && ret=0
        ;;
      stats)
        _arguments -s -S \
          '-c+[How many top commands to show]:count' \
          '--count=[How many top commands to show]:count' \
          '-p+[Period to calculate stats for]:period' \
          '--period=[Period to calculate stats for]:period' \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
      search)
        _arguments -s -S \
          '-c+[Filter by exit code]:code' \
          '--exit=[Filter by exit code]:code' \
          '-e+[Exclude exit code]:code' \
          '--exclude-exit=[Exclude exit code]:code' \
          '--exclude-cwd=[Exclude directory]:dir:_directories' \
          '--cwd=[Filter by directory]:dir:_directories' \
          '--before=[Only include results from before this date]:date' \
          '--after=[Only include results from after this date]:date' \
          '--limit=[How many entries to return]:limit' \
          '--offset=[Offset from the start]:offset' \
          '-i[Open interactive search UI]' \
          '--interactive[Open interactive search UI]' \
          '--filter-mode=[How to filter results]:mode:(global host session directory workspace)' \
          '--search-mode=[Which search mode to use]:mode:(prefix full-text fuzzy regex)' \
          '--inline-height=[Set the maximum number of lines for inline mode]:lines' \
          '--human[Use human-readable formatting for time]' \
          '--cmd-only[Show only the text of the command]' \
          '--delete[Delete matches]' \
          '--delete-it-all[Delete everything]' \
          '-r[Reverse the order of results]' \
          '--reverse[Reverse the order of results]' \
          '--format=[Available output formats]:format:(auto json)' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:query' && ret=0
        ;;
      sync)
        _arguments -s -S \
          '-f[Force re-sync everything]' \
          '--force[Force re-sync everything]' \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
      server)
        local -a subcmds=(
          'start:Start the server'
          'default-config:Print the default config'
        )
        _describe -t subcmds 'server subcommand' subcmds && ret=0
        ;;
      init)
        local -a shells=(
          'zsh:Generate zsh init'
          'bash:Generate bash init'
          'fish:Generate fish init'
          'nu:Generate nushell init'
          'xonsh:Generate xonsh init'
        )
        _describe -t shells 'shell' shells && ret=0
        ;;
      account)
        local -a subcmds=(
          'login:Login to your account'
          'register:Register a new account'
          'logout:Log out of your account'
          'delete:Delete your account'
          'change-password:Change your password'
        )
        _describe -t subcmds 'account subcommand' subcmds && ret=0
        ;;
      kv)
        local -a subcmds=(
          'set:Set a key-value pair'
          'get:Get the value for a key'
          'list:List all key-value pairs'
        )
        _describe -t subcmds 'kv subcommand' subcmds && ret=0
        ;;
      store)
        local -a subcmds=(
          'status:Show the status of the store'
          'rebuild:Rebuild the store'
          'rekey:Re-encrypt the store'
          'purge:Purge the store'
          'verify:Verify the store'
        )
        _describe -t subcmds 'store subcommand' subcmds && ret=0
        ;;
      gen-completions)
        _arguments -s -S \
          '-s+[Set the shell]:shell:(zsh bash fish nu)' \
          '--shell=[Set the shell]:shell:(zsh bash fish nu)' \
          '-o+[Set the output directory]:dir:_directories' \
          '--out-dir=[Set the output directory]:dir:_directories' \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
