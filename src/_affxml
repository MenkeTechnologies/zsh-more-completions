#compdef affxml
# Documentation: https://man.archlinux.org/search?q=affxml
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-V[just print the version number and exit]'
  '-x[dont include the infile filename in output.]'
  '-j[just print information about segname]'
  '-s[output stats for the file data (may a long time)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
