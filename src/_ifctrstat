#compdef ifctrstat
# Documentation: https://man.archlinux.org/search?q=ifctrstat
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[this help]'
  {-V,--version}'[show this programs version]'
  {-L,--list}'[list available counters]'
  {-n,--no-label}'[print value without counter label]'
  '*:filename:_files'
)

_arguments -s -S $arguments
