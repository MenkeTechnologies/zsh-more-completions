#compdef atk6-passive_discovery6
# Documentation: https://man.archlinux.org/search?q=atk6-passive_discovery6
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-D[do also dump destination addresses (does not work with -m)]'
  '-s[do only print the addresses, no other output]'
  '-m[the maximum number of hops a target which is dumped may be away.]'
  '-R[exchange the defined prefix with the link local prefix]'
  '*:filename:_files'
)

_arguments -s -S $arguments
