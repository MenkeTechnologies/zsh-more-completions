#compdef bbox
# Documentation: https://man.archlinux.org/search?q=bbox
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-l[loose bounding box (bbox is expanded by 1 point)]'
  '-r[resolution of picture in dpi]:dpi:'
  '-V[version information]'
  '-h[this help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
