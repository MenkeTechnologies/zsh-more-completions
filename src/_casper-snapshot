#compdef casper-snapshot

local -a arguments

arguments=(
  {-c,--cow}'[specifies the copy on write directory (default: /cow)]:directory:_files -/'
  {-d,--device}'[specifies the output snapshot device (default: none)]:device:_files'
  {-o,--output}'[specifies the output image file]:file:_files'
  {-r,--resync-string}'[internally used to resync previous made snapshots]:string:'
  {-t,--type}'[specifies the snapshot type]:type:(squashfs ext2 cpio)'
  '*:filename:_files'
)

_arguments -s -S $arguments
