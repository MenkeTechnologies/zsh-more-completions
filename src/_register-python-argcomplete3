#compdef register-python-argcomplete3

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  '--no-defaults[when no matches are generated, do not fallback to readline defaults]'
  '--complete-arguments[arguments for completion]'
  {-s,--shell}'[shell type (bash or tcsh)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
