#compdef bchscheme

local -a arguments

arguments=(
  '--library[set the library search path]:path:'
  '--band[specify the initial band to be loaded]:filename:_files'
  '--fasl[perform a cold load using specified file]:filename:_files'
  '--heap[size of the heap in 1024-word blocks]:size:'
  '--constant[size of constant space in 1024-word blocks]:size:'
  '--stack[size of the stack in 1024-word blocks]:size:'
  '--option-summary[causes Scheme to write option values to standard error.]'
  '--help[causes Scheme to report the available command line options.]'
  '--version[causes Scheme to report versions and copyrights, then exit.]'
  {--batch-mode,--quiet,--silent}'[suppress the startup report of versions and copyrights]'
  '--emacs[Scheme is running as a subprocess of GNU Emacs]'
  '--interactive[force interactive mode]'
  '--nocore[do not generate a core dump under any circumstances]'
  '--macosx-application[specifies that Scheme is running as a Mac OS X application.]'
  '--args[pass remaining arguments to Scheme]'
  '--edit[causes Edwin to start immediately after Scheme.]'
  '--eval[evaluate expression]:expression:'
  '--load[load file]:file:_files'
  '--no-init-file[inhibits automatic loading of the ~/.scheme.init file.]'
  '--no-suspend-file[inhibits automatic saving of bands to ~/scheme_suspend.]'
  '--suspend-file[save a band to ~/scheme_suspend on signal reception]'
  '*:filename:_files'
)

_arguments -s -S $arguments
