#compdef pandoc

# Zsh completion for pandoc

_pandoc() {
  local -a input_formats output_formats

  # Dynamically fetch formats if pandoc is available, otherwise use static list
  if (( $+commands[pandoc] )); then
    input_formats=( ${(f)"$(pandoc --list-input-formats 2>/dev/null)"} )
    output_formats=( ${(f)"$(pandoc --list-output-formats 2>/dev/null)"} )
  fi

  if (( ! $#input_formats )); then
    input_formats=(
      asciidoc biblatex bibtex bits commonmark commonmark_x creole csljson csv
      djot docbook docx dokuwiki endnotexml epub fb2 gfm haddock html ipynb
      jats jira json latex man markdown markdown_github markdown_mmd
      markdown_phpextra markdown_strict mdoc mediawiki muse native odt opml
      org pod pptx ris rst rtf t2t textile tikiwiki tsv twiki typst vimwiki
      xlsx xml
    )
  fi

  if (( ! $#output_formats )); then
    output_formats=(
      ansi asciidoc asciidoc_legacy asciidoctor bbcode bbcode_fluxbb
      bbcode_hubzilla bbcode_phpbb bbcode_steam bbcode_xenforo beamer biblatex
      bibtex chunkedhtml commonmark commonmark_x context csljson djot docbook
      docbook4 docbook5 docx dokuwiki dzslides epub epub2 epub3 fb2 gfm haddock
      html html4 html5 icml ipynb jats jats_archiving jats_articleauthoring
      jats_publishing jira json latex man markdown markdown_github markdown_mmd
      markdown_phpextra markdown_strict markua mediawiki ms muse native odt
      opendocument opml org pdf plain pptx revealjs rst rtf s5 slideous slidy
      tei texinfo textile typst vimdoc xml xwiki zimwiki
    )
  fi

  local -a all_formats
  all_formats=( $input_formats $output_formats )
  # deduplicate
  all_formats=( ${(u)all_formats} )

  _arguments -s -S \
    {-f,-r,--from=,--read=}'[specify input format]:input format:($input_formats)' \
    {-t,-w,--to=,--write=}'[specify output format]:output format:($output_formats)' \
    {-o,--output=}'[write output to file instead of stdout]:output file:_files' \
    '--data-dir=[specify the user data directory]:data directory:_directories' \
    {-d,--defaults=}'[specify a defaults file with option settings]:defaults file:_files' \
    '--shift-heading-level-by=[shift heading levels by integer]:level shift:' \
    '--base-header-level=[specify base header level]:level:' \
    '--indented-code-classes=[specify classes for indented code blocks]:classes:' \
    {-F,--filter=}'[specify an executable to use as a filter]:filter program:_files -g "*(*)"' \
    '*'{-L,--lua-filter=}'[specify a Lua script to use as a filter]:Lua filter:_files -g "*.lua"' \
    {-p,--preserve-tabs}'[preserve tabs instead of converting to spaces]' \
    '--tab-stop=[specify number of spaces per tab]:number of spaces:' \
    '--track-changes=[specify how to handle track changes in docx]:track changes:(accept reject all)' \
    '--file-scope[parse each input file individually before combining]' \
    '--extract-media=[extract media from a document to a directory]:media directory:_directories' \
    {-s,--standalone}'[produce output with an appropriate header and footer]' \
    '--template=[use specified template file]:template file:_files' \
    '*'{-M,--metadata=}'[set a metadata value]:key\=value:' \
    '*--metadata-file=[read metadata from a YAML file]:metadata file:_files -g "*.{yaml,yml}"' \
    '*'{-V,--variable=}'[set a template variable]:key\=value:' \
    '--variable-json=[set a template variable to a JSON value]:key\=JSON:' \
    {-D,--print-default-template=}'[print the system default template for a format]:format:($all_formats)' \
    '--print-default-data-file=[print a system default data file]:file name:' \
    '--print-highlight-style=[print a JSON version of a highlighting style]:style:' \
    '--dpi=[specify DPI for image conversion]:DPI value:' \
    '--eol=[specify line ending style]:line endings:(crlf lf native)' \
    '--wrap=[determine how text is wrapped in output]:wrap mode:(auto none preserve)' \
    '--columns=[specify length of lines in characters]:column width:' \
    '--strip-comments[strip HTML comments in source]' \
    {--toc,--table-of-contents}'[include an automatically generated table of contents]' \
    '--toc-depth=[specify the number of section levels to include in TOC]:depth:' \
    {--lof,--list-of-figures}'[include a list of figures]' \
    {--lot,--list-of-tables}'[include a list of tables]' \
    '--no-highlight[disables syntax highlighting]' \
    '--highlight-style=[specify the coloring style for highlighted code]:style:' \
    '--syntax-definition=[load a KDE XML syntax definition file]:syntax file:_files -g "*.xml"' \
    '--syntax-highlighting=[set syntax highlighting mode]:mode:(none default idiomatic)' \
    '*'{-H,--include-in-header=}'[include contents of file at end of the header]:header file:_files' \
    '*'{-B,--include-before-body=}'[include contents of file at beginning of the body]:body prefix file:_files' \
    '*'{-A,--include-after-body=}'[include contents of file at end of the body]:body suffix file:_files' \
    '--resource-path=[list of paths to search for images and other resources]:search path:_dir_list' \
    '--request-header=[set the request header for HTTP requests]:NAME\:VALUE:' \
    '--no-check-certificate[disable certificate verification for HTTPS requests]' \
    '--self-contained[produce a standalone HTML file with no external dependencies (deprecated)]' \
    '--embed-resources[embed resources in the document]' \
    '--link-images[link to images rather than embedding them]' \
    '--html-q-tags[use <q> tags for quotes in HTML]' \
    '--ascii[use only ASCII characters in output]' \
    '--reference-links[use reference-style links in markdown and reStructuredText]' \
    '--reference-location=[specify where footnotes and references are placed]:location:(block section document)' \
    '--figure-caption-position=[position of figure captions]:position:(above below)' \
    '--table-caption-position=[position of table captions]:position:(above below)' \
    '--markdown-headings=[specify heading style for markdown output]:style:(setext atx)' \
    '--list-tables[use list tables in RST output]' \
    '--top-level-division=[specify type for top-level headings]:division type:(default section chapter part)' \
    {-N,--number-sections}'[number section headings]' \
    '--number-offset=[offset for section headings (implies -N)]:offsets:' \
    '--listings[use the listings package for LaTeX code blocks]' \
    {-i,--incremental}'[make list items in slide shows display incrementally]' \
    '--slide-level=[specify heading level that creates slides]:slide level:' \
    '--section-divs[wrap sections in <section> tags using header identifiers]' \
    '--default-image-extension=[specify default extension for images]:extension:' \
    '--email-obfuscation=[method for obfuscating email addresses in HTML]:method:(none javascript references)' \
    '--id-prefix=[specify a prefix to add to all identifiers]:prefix:' \
    {-T,--title-prefix=}'[specify a prefix for the HTML title]:title prefix:' \
    '*'{-c,--css=}'[link to a CSS stylesheet]:stylesheet URL:' \
    '--reference-doc=[use specified file as a style reference]:reference document:_files' \
    '--epub-subdirectory=[specify subdirectory in EPUB container]:subdirectory:' \
    '--epub-cover-image=[use specified image as the EPUB cover]:cover image:_files -g "*.{png,jpg,jpeg,gif,svg}"' \
    '--epub-title-page[include an EPUB title page]' \
    '--epub-metadata=[look up EPUB metadata in specified file]:metadata file:_files -g "*.xml"' \
    '*--epub-embed-font=[embed specified font in the EPUB]:font file:_files -g "*.{ttf,otf,woff,woff2}"' \
    '--epub-chapter-level=[specify heading level at which to split EPUB into chapters]:chapter level:' \
    '--split-level=[specify heading level at which to split chunked output]:split level:' \
    '--chunk-template=[specify path template for chunked output]:path template:' \
    '--ipynb-output=[specify how to handle Jupyter notebook output]:output mode:(all none best)' \
    '--pdf-engine=[use specified engine when producing PDF output]:PDF engine:(pdflatex lualatex xelatex latexmk tectonic wkhtmltopdf weasyprint prince typst context pdfroff)' \
    '*--pdf-engine-opt=[pass option to the PDF engine]:engine option:' \
    '-C[process citations using citeproc]' \
    '--citeproc[process citations using citeproc]' \
    '*--bibliography=[set the bibliography field in metadata]:bibliography file:_files -g "*.{bib,bibtex,copac,json,yaml,enl,xml,wos,medline,mods,ris,nbib}"' \
    '--csl=[set the CSL file for citation formatting]:CSL file:_files -g "*.csl"' \
    '--citation-abbreviations=[set the citation-abbreviations field in metadata]:abbreviations file:_files -g "*.json"' \
    '--natbib[use natbib for citations in LaTeX output]' \
    '--biblatex[use biblatex for citations in LaTeX output]' \
    '--mathml[convert TeX math to MathML]' \
    '--webtex=[convert TeX formulas to <img> tags using a web service]:URL:' \
    '--mathjax=[use MathJax to display TeX math in HTML output]:URL:' \
    '--katex=[use KaTeX to display TeX math in HTML output]:URL:' \
    '--gladtex[enclose TeX math in <eq> tags in HTML output for gladTeX processing]' \
    '--abbreviations=[specify a file of abbreviations]:abbreviations file:_files' \
    '--trace[enable tracing for debugging]' \
    '--dump-args[print information about command-line arguments to stdout then exit]' \
    '--ignore-args[ignore command-line arguments (for use in wrapper scripts)]' \
    '--verbose[give verbose debugging output]' \
    '--quiet[suppress warning messages]' \
    '--fail-if-warnings[exit with error status if there are any warnings]' \
    '--log=[write log messages to specified file]:log file:_files' \
    '--sandbox[run in sandbox mode, restricting IO operations]' \
    '--bash-completion[generate a bash completion script]' \
    '--list-input-formats[list supported input formats, one per line]' \
    '--list-output-formats[list supported output formats, one per line]' \
    '--list-extensions=[list supported extensions for a format]:format:($all_formats)' \
    '--list-highlight-languages[list supported languages for syntax highlighting]' \
    '--list-highlight-styles[list supported styles for syntax highlighting]' \
    '(- *)'{-v,--version}'[print version]' \
    '(- *)'{-h,--help}'[show usage message]' \
    '*:input file:_files'
}

_pandoc "$@"
