#compdef nghttp

local -a arguments

arguments=(
  {-v,--verbose}'[print debug information such as reception and transmission of frames]'
  {-n,--null-out}'[discard downloaded data]'
  {-O,--remote-name}'[save download data in the current directory]'
  {-t,--timeout}'[timeout each request after <DURATION>. Set 0 to disable]'
  {-w,--window-bits}'[sets the stream level initial window size to 2**<N>-1.]'
  {-W,--connection-window-bits}'[sets the connection level initial window size to 2**<N>-1]'
  {-a,--get-assets}'[download assets such as stylesheets, images and scripts]'
  {-s,--stat}'[print statistics.]'
  {-H,--header}'[add a header to the requests. Example: -H:method: PUT]'
  '--trailer[add a trailer header to the requests]'
  '--cert[use the specified client certificate file]:file:_files'
  '--key[use the client private key file]:file:_files'
  {-d,--data}'[post FILE to server]:file:_files'
  {-m,--multiply}'[request each URI N times]:count:'
  {-u,--upgrade}'[perform HTTP Upgrade for HTTP/2]'
  {-p,--weight}'[set weight of given URI]:weight:'
  {-M,--peer-max-concurrent-streams}'[set SETTINGS_MAX_CONCURRENT_STREAMS value]:num:'
  {-c,--header-table-size}'[specify decoder header table size]:size:'
  '--encoder-header-table-size[specify encoder header table size]:size:'
  {-b,--padding}'[add at most <N> bytes to a frame payload as padding.]'
  {-r,--har}'[output HTTP transactions <PATH> in HAR format. If -]'
  '--color[force colored log output.]'
  '--continuation[send large header to test CONTINUATION.]'
  '--no-content-length[dont send content-length header field.]'
  '--no-dep[dont send dependency based priority hint to server.]'
  '--hexdump[display the incoming traffic in hexadecimal]'
  '--no-push[disable server push.]'
  '--max-concurrent-streams[the number of concurrent pushed streams this client accepts]:num:'
  '--expect-continue[perform an Expect/Continue handshake]'
  {-y,--no-verify-peer}'[suppress warning on server certificate verification]'
  '--version[display version information and exit.]'
  '(- * :)'{-h,--help}'[display this help and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
