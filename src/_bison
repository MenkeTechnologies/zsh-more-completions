#compdef bison

# Completion for GNU Bison parser generator

_bison_report_items() {
  local -a items
  items=(
    'state:describe the states'
    'itemset:complete the core item sets with their closure'
    'lookahead:explicitly associate lookahead tokens to items'
    'look-ahead:explicitly associate look-ahead tokens to items'
    'solved:describe shift/reduce conflicts solving'
    'counterexample:generate counterexamples for ambiguities'
    'cex:short for counterexample'
    'all:include all the above information'
    'none:disable the report'
  )
  _values -s , 'report item' $items
}

_bison_warnings() {
  local -a categories
  categories=(
    'midrule-values:unset or unused midrule values'
    'yacc:incompatibilities with POSIX Yacc'
    'conflicts-sr:shift/reduce conflicts'
    'conflicts-rr:reduce/reduce conflicts'
    'deprecated:deprecated constructs'
    'precedence:useless precedence and associativity'
    'other:all other warnings'
    'all:all the warnings except error'
    'no-midrule-values:disable midrule-values warnings'
    'no-yacc:disable yacc warnings'
    'no-conflicts-sr:disable shift/reduce conflict warnings'
    'no-conflicts-rr:disable reduce/reduce conflict warnings'
    'no-deprecated:disable deprecated warnings'
    'no-precedence:disable precedence warnings'
    'no-other:disable other warnings'
    'none:disable all warnings'
    'error:treat warnings as errors'
    'no-error:do not treat warnings as errors'
  )
  _values -s , 'warning category' $categories
}

_bison_features() {
  local -a features
  features=(
    'caret:show caret errors'
    'diagnostics-show-option:show option to disable diagnostic'
    'fixit:apply suggested fixits'
    'syntax-only:do not generate any file'
    'all:all of the above'
    'none:disable all features'
  )
  _values -s , 'feature' $features
}

_bison_languages() {
  local -a langs
  langs=(c c++ d java)
  _wanted languages expl 'output language' compadd -a langs
}

local arguments

arguments=(
  '(- *)'{-h,--help}'[display help and exit]'
  '(- *)'{-V,--version}'[output version information and exit]'
  '(- *)--print-localedir[output directory containing locale-dependent data and exit]'
  '(- *)--print-datadir[output directory containing skeletons and XSLT and exit]'

  # Operation modes
  {-y,--yacc}'[emulate POSIX Yacc]'
  {-W+,--warnings=}'[report warnings falling in CATEGORY]:warning category:_bison_warnings'
  {-f+,--feature=}'[activate miscellaneous features]:feature:_bison_features'

  # Parser
  {-L+,--language=}'[specify the output programming language]:language:_bison_languages'
  {-S+,--skeleton=}'[specify the skeleton to use]:skeleton file:_files'
  {-t,--debug}'[instrument the parser for tracing; same as -Dparse.trace]'
  '--locations[enable location support]'
  {-D+,--define=}'[similar to %define NAME "VALUE"]:name=value:'
  {-F+,--force-define=}'[override %define NAME "VALUE"]:name=value:'
  {-p+,--name-prefix=}'[prepend PREFIX to the external symbols (deprecated)]:prefix:'
  {-l,--no-lines}'[do not generate #line directives]'
  {-n,--no-parser}'[generate the tables only]'
  {-k,--token-table}'[include a table of token names]'

  # Output
  '--defines=-[also produce a header file]::header file:_files -g "*.h(-.)"'
  '-d[produce a header file (POSIX Yacc)]'
  {-r+,--report=}'[produce details on the automaton]:report items:_bison_report_items'
  '--report-file=[write report to FILE]:report file:_files'
  {-v,--verbose}'[same as --report=state]'
  {-b+,--file-prefix=}'[specify a PREFIX for output files]:prefix:'
  {-o+,--output=}'[leave output to FILE]:output file:_files'
  {-g,--graph}'=-[also output a graph of the automaton]::graph file:_files -g "*.gv(-.)"'
  {-x,--xml}'=-[also output an XML report of the automaton]::xml file:_files -g "*.xml(-.)"'
  '--color=-[colorize the output]::when:(always never auto)'
  '--style=[specify the CSS FILE for colorizer diagnostics]:css file:_files -g "*.css(-.)"'
  '-Werror=[treat warnings as errors]:category:'
  '--update[apply fixes to the source grammar file in place]'

  '*:grammar file:_files -g "*.{y,yy,ypp,y++}(-.)"'
)

_arguments -s -S : $arguments
