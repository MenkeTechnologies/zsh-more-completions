#compdef abrt-action-trim-files
# Documentation: https://man.archlinux.org/search?q=abrt-action-trim-files
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-v,--verbose}'[be verbose]'
  '-d[delete whole problem directories]'
  '-f[delete files inside this directory]'
  '-p[preserve this directory]'
  '*:filename:_files'
)

_arguments -s -S $arguments
