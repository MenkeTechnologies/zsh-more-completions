#compdef spa-acp-tool
# Documentation: https://man.archlinux.org/search?q=spa-acp-tool
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[show this help]'
  {-v,--verbose}'[be verbose]'
  {-c,--card}'[card number]'
  {-p,--properties}'[extra properties:]'
  '*:filename:_files'
)

_arguments -s -S $arguments
