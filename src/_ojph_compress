#compdef ojph_compress

local -a arguments

arguments=(
    '-i[Input file]:input file:_files -g "*.{ppm,pgm,raw,yuv,png,tif,tiff,bmp}"'
    '-o[Output file]:output file:_files -g "*.{j2c,jph,j2k}"'
    '-num_decomps=[Number of decomposition levels]:levels'
    '-qstep=[Quantization step size]:step size'
    '-reversible=[Use reversible transform]:(true false)'
    '-colour_trans=[Use colour transform]:(true false)'
    '-dims=[Image dimensions {x,y}]:dimensions'
    '-num_comps=[Number of components]:components'
    '-signed=[Signed samples]:(true false)'
    '-bit_depth=[Bit depth of components]:bit depth'
    '-downsamp=[Downsampling factor {x,y}]:factor'
    '-comp_downsamp=[Component downsampling {x,y}]:factor'
    '-tile_size=[Tile size {x,y}]:size'
    '-tile_offset=[Tile offset {x,y}]:offset'
    '-image_offset=[Image offset {x,y}]:offset'
    '-block_size=[Code block size {x,y}]:size'
    '-precints=[Precinct size {x,y}]:size'
    '-prog_order=[Progression order]:(LRCP RLCP RPCL PCRL CPRL)'
    '-num_threads=[Number of threads]:threads'
    '-profile=[Profile]:(PROFILE0 PROFILE1 BROADCAST CINEMA2K CINEMA4K CINEMA2S CINEMA4S CINEMASS IMF)'
    '-tlm_marker[Include TLM marker]'
)

_arguments -s -S $arguments
