#compdef findbugs-csr
# Documentation: https://man.archlinux.org/search?q=findbugs-csr
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-cloud[id of the cloud to use]'
  '-recent[maximum age in hours for an issue to be recent]'
  '-cloudSummary[write a cloud summary to thie file]'
  '*:filename:_files'
)

_arguments -s -S $arguments
