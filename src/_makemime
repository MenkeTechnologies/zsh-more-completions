#compdef makemime
# Documentation: https://man.archlinux.org/search?q=makemime
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-o[output. Default: stdout]'
  '-a[add header(s). Examples:]'
  '-c[content type. Default: application/octet-stream]'
  '-C[charset. Default: us-ascii]'
  '*:filename:_files'
)

_arguments -s -S $arguments
