#compdef bluetoothctl
# Documentation: https://man.archlinux.org/search?q=bluetoothctl
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--agent[agent handler: <capability>]'
  '--timeout[in seconds for non-interactive mode]'
  '--version[version]'
  '--help[display help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
