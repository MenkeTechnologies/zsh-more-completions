#compdef mysql_install_db

local -a arguments

arguments=(
  '--auth-root-authentication-method[chooses the authentication method for the created root user]'
  '--auth-root-socket-user[used with --auth-root-authentication-method=socket]'
  '--basedir[the path to the MariaDB installation directory.]'
  '--builddir[if using --srcdir with out-of-directory builds, specify the build directory]'
  '--cross-bootstrap[for internal use. Used when building the MariaDB system tables]'
  '--datadir[the path to the MariaDB data directory.]'
  '--defaults-extra-file[read this file after the global files are read.]'
  '--defaults-file[only read default options from the given file name.]'
  '--defaults-group-suffix[in addition to the given groups, read also groups with this suffix]'
  '--force[causes mysql_install_db to run even if DNS does not work]'
  '--help[display this help and exit.]'
  '--ldata[the path to the MariaDB data directory. Same as --datadir]'
  '--no-defaults[dont read default options from any option file.]'
  '--rpm[for internal use. This option is used by RPM files during the install process]'
  '--skip-auth-anonymous-user[do not install an unprivileged anonymous user.]'
  '--skip-name-resolve[use IP addresses rather than hostnames when creating grant table entries]'
  '--srcdir[the path to the MariaDB source directory]'
  '--user[the login username to use for running mysqld]'
  '*:filename:_files'
)

_arguments -s -S $arguments
