#compdef automationmodetool

local -a subcommands

subcommands=(
    'enable-automationmode:Enable automation mode (unattended execution)'
    'disable-automationmode:Disable automation mode'
    'status:Show current automation mode status'
)

_arguments -s -S \
    '1:subcommand:->subcmd' && return

case $state in
    subcmd)
        _describe 'automationmodetool subcommand' subcommands
        ;;
esac
