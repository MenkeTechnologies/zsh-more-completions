#compdef fzf-tmux
# Documentation: https://man.archlinux.org/search?q=fzf-tmux
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-u[split above (up)]:height:'
  '-d[split below (down)]:height:'
  '-l[split left]:width:'
  '-r[split right]:width:'
  '*:filename:_files'
)

_arguments -s -S $arguments
