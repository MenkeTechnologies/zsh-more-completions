#compdef libtool glibtool

# Zsh completion for GNU Libtool
# Based on GNU libtool 2.5

local -a modes
modes=(
  'clean:remove files from the build directory'
  'compile:compile a source file into a libtool object'
  'execute:automatically set library path, then run a program'
  'finish:complete the installation of libtool libraries'
  'install:install libraries or executables'
  'link:create a library or an executable'
  'uninstall:remove libraries from an installed directory'
)

local -a warning_categories
warning_categories=(
  'all:show all warnings'
  'none:turn off all the warnings'
  'error:warnings are treated as fatal errors'
)

_arguments -s -S \
  '(- *)'{-h,--help,--help-all}'[print short, long, or detailed help message]' \
  '(- *)--version[print version information]' \
  '(- *)--config[show all configuration variables]' \
  '(- *)--features[display basic configuration information and exit]' \
  '--debug[enable verbose shell tracing]' \
  {-n,--dry-run}'[display commands without modifying any files]' \
  '--finish[use operation --mode=finish]' \
  '--mode=[use operation mode MODE]:mode:_describe -t modes "operation mode" modes' \
  '--no-finish[do not update shared library cache]' \
  '(--no-quiet --no-silent)'{--quiet,--silent}'[do not print informational messages]' \
  '(--quiet --silent)'{--no-quiet,--no-silent}'[print default informational messages]' \
  '--no-warnings[equivalent to -Wnone]' \
  '--preserve-dup-deps[do not remove duplicate dependency libraries]' \
  '--reorder-cache=[reorder shared library cache for preferred DIRS]:directories:_files -/' \
  '--tag=[use configuration variables from tag TAG]:tag:(CC CXX F77 FC GCJ GO RC)' \
  {-v,--verbose}'[print more informational messages than default]' \
  {-W,--warnings=}'[report the warnings falling in CATEGORY]:warning category:_describe -t warnings "warning category" warning_categories' \
  '*:file:_files'
