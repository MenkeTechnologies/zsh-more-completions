#compdef uniq guniq

local -a arguments

arguments=(
  '(-c --count)'{-c,--count}'[prefix lines by the number of occurrences]'
  '(-d --repeated -D --all-repeated)'{-d,--repeated}'[only print duplicate lines, one for each group]'
  '(-d --repeated -D --all-repeated)-D[print all duplicate lines]'
  '(-d --repeated -D)--all-repeated=-[like -D, but allow separating groups with an empty line]:method:(none prepend separate)'
  '(-f --skip-fields)'{-f+,--skip-fields=}'[avoid comparing the first N fields]:number of fields'
  '--group=-[show all items, separating groups with an empty line]:method:(separate prepend append both)'
  '(-i --ignore-case)'{-i,--ignore-case}'[ignore differences in case when comparing]'
  '(-s --skip-chars)'{-s+,--skip-chars=}'[avoid comparing the first N characters]:number of characters'
  '(-u --unique)'{-u,--unique}'[only print unique lines]'
  '(-z --zero-terminated)'{-z,--zero-terminated}'[line delimiter is NUL, not newline]'
  '(-w --check-chars)'{-w+,--check-chars=}'[compare no more than N characters in lines]:number of characters'
  '(- *)--help[display this help and exit]'
  '(- *)--version[output version information and exit]'
  '1:input file:_files'
  '2:output file:_files'
)

_arguments -s -S $arguments
