#compdef lf

# Zsh completion for lf - terminal file manager

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,-help}'[show help]' \
  '(- *)'{-v,-version}'[show version]' \
  '-command=[execute command on startup]:command:' \
  '-config=[set path to config file]:config file:_files' \
  '-cpuprofile=[write cpu profile to file]:file:_files' \
  '-doc[show documentation]' \
  '-last-dir-path=[set file to write last dir on exit]:file:_files' \
  '-log=[set log file path]:file:_files' \
  '-memprofile=[write memory profile to file]:file:_files' \
  '-print-last-dir[print last dir to stdout on exit]' \
  '-print-selection[print selected files to stdout on exit]' \
  '-remote=[send remote command to running lf instance]:command:' \
  '-selection-path=[set file to write selection on exit]:file:_files' \
  '-server[start server (automatically done as needed)]' \
  '-single[start a client without a server]' \
  '*:directory:_files -/' && ret=0

return ret
