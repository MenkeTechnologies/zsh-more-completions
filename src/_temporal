#compdef temporal

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '--address=[server address]:address' \
  {-n,--namespace}'=[namespace]:namespace' \
  '--tls-cert-path=[TLS cert path]:cert:_files' \
  '--tls-key-path=[TLS key path]:key:_files' \
  '--tls-ca-path=[TLS CA path]:ca:_files' \
  '--codec-endpoint=[codec endpoint]:endpoint' \
  '--color=[color mode]:color:(auto always never)' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'workflow:manage workflows'
      'schedule:manage schedules'
      'batch:manage batch operations'
      'activity:manage activities'
      'task-queue:manage task queues'
      'server:run Temporal server'
      'operator:manage Temporal server'
      'env:manage environments'
      'completion:generate shell completion'
    )
    _describe -t commands 'temporal command' commands && ret=0
    ;;
  args)
    case $words[1] in
      workflow)
        _arguments -s -S -C \
          '1:subcommand:->wf_cmds' \
          '*::wf_arg:->wf_args' && ret=0
        case $state in
          wf_cmds)
            local -a wf_commands=(
              'start:start a workflow'
              'execute:start and wait for workflow'
              'describe:describe a workflow'
              'list:list workflows'
              'count:count workflows'
              'signal:signal a workflow'
              'query:query a workflow'
              'cancel:cancel a workflow'
              'terminate:terminate a workflow'
              'reset:reset a workflow'
              'delete:delete a workflow'
              'trace:trace a workflow'
              'update:update a workflow'
            )
            _describe -t commands 'workflow command' wf_commands && ret=0
            ;;
          wf_args)
            _arguments -s -S \
              {-w,--workflow-id}'=[workflow ID]:workflow id' \
              {-r,--run-id}'=[run ID]:run id' \
              '--task-queue=[task queue]:task queue' \
              '--type=[workflow type]:type' \
              '--input=[input JSON]:input' \
              '--search-attribute=[search attribute]:key=value' \
              '--memo=[memo]:key=value' \
              '--execution-timeout=[execution timeout]:timeout' \
              '--run-timeout=[run timeout]:timeout' \
              '--task-timeout=[task timeout]:timeout' \
              '--id-reuse-policy=[ID reuse policy]:policy:(AllowDuplicate AllowDuplicateFailedOnly RejectDuplicate TerminateIfRunning)' \
              '--reason=[reason]:reason' \
              '--query=[query]:query' \
              '--limit=[limit]:limit' \
              && ret=0
            ;;
        esac
        ;;
      schedule)
        _arguments -s -S -C \
          '1:subcommand:(create update toggle trigger backfill describe list delete)' \
          && ret=0
        ;;
      batch)
        _arguments -s -S -C \
          '1:subcommand:(describe list terminate)' \
          && ret=0
        ;;
      activity)
        _arguments -s -S -C \
          '1:subcommand:(complete fail)' \
          && ret=0
        ;;
      task-queue)
        _arguments -s -S -C \
          '1:subcommand:(describe list-partition update-build-ids get-build-ids)' \
          && ret=0
        ;;
      server)
        _arguments -s -S \
          '1:subcommand:(start-dev)' \
          '--db-filename=[database file]:file:_files' \
          '--port=[port]:port' \
          '--http-port=[HTTP port]:port' \
          '--ui-port=[UI port]:port' \
          '--headless[disable UI]' \
          '--ip=[IP address]:ip' \
          '--log-format=[log format]:format:(json pretty)' \
          '--log-level=[log level]:level:(debug info warn error)' \
          && ret=0
        ;;
      operator)
        _arguments -s -S -C \
          '1:subcommand:(cluster namespace search-attribute)' \
          && ret=0
        ;;
      env)
        _arguments -s -S -C \
          '1:subcommand:(get set delete list)' \
          && ret=0
        ;;
      completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
