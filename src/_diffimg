local -a arguments

arguments=(
    '-h[Show help message]'
    '--help[Show help message]'
    '-o[Output difference image]:output file:_files -g "*.{png,jpg,jpeg,bmp,tiff,gif}"'
    '--output=[Output difference image]:output file:_files -g "*.{png,jpg,jpeg,bmp,tiff,gif}"'
    '-r[Ratio mode - output a ratio of difference]'
    '--ratio[Ratio mode - output a ratio of difference]'
    '-t[Threshold for comparison]:threshold'
    '--threshold=[Threshold for comparison]:threshold'
    '1:first image:_files -g "*.{png,jpg,jpeg,bmp,tiff,gif,webp}"'
    '2:second image:_files -g "*.{png,jpg,jpeg,bmp,tiff,gif,webp}"'
)

_arguments -s -S $arguments
