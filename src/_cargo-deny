#compdef cargo-deny

_cargo-deny() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a global_opts
    global_opts=(
        {-L,--log-level}'[Set the log level]:level:(off error warn info debug trace)'
        '--all-features[Activate all available features]'
        '--no-default-features[Do not activate default features]'
        '--features[Comma-separated list of features to activate]:features:'
        '--manifest-path[Path to Cargo.toml]:path:_files -g "*.toml"'
        '--workspace[Check entire workspace]'
        '*--exclude[Exclude specific crates]:crate:'
        '--exclude-dev[Exclude dev dependencies]'
        '--color[Control color output]:color:(auto always never)'
        {-h,--help}'[Print help information]'
        {-V,--version}'[Print version information]'
    )

    _arguments -C \
        $global_opts \
        '(-): :->command' \
        '(-)*:: :->option-or-argument' && ret=0

    case $state in
        (command)
            local -a commands
            commands=(
                'check:Check dependencies against configured lints'
                'fetch:Fetch advisories from advisory databases'
                'init:Initialize a deny.toml configuration file'
                'list:List information about dependencies'
            )
            _describe -t commands 'cargo-deny command' commands && ret=0
            ;;
        (option-or-argument)
            curcontext=${curcontext%:*:*}:cargo-deny-$words[1]:
            case $words[1] in
                (check)
                    _arguments -s -S \
                        $global_opts \
                        {-c,--config}'[Path to deny.toml config file]:config:_files -g "*.toml"' \
                        {-g,--graph}'[Path to the dependency graph output]:path:_files' \
                        '--output-format[Format of the output]:format:(human json sarif)' \
                        '--audit-compatible-output[Output compatible with cargo audit]' \
                        '--disable-fetch[Disable fetching of advisory databases]' \
                        '--feature-depth[Specify the depth of feature resolution]:depth:' \
                        '--targets[One or more targets to filter]:target:' \
                        '--show-stats[Show statistics about the checks]' \
                        '*:check:(advisories licenses bans sources)' && ret=0
                    ;;
                (fetch)
                    _arguments -s -S \
                        $global_opts \
                        {-c,--config}'[Path to deny.toml config file]:config:_files -g "*.toml"' && ret=0
                    ;;
                (init)
                    _arguments -s -S \
                        $global_opts \
                        {-c,--config}'[Path to create deny.toml]:config:_files -g "*.toml"' && ret=0
                    ;;
                (list)
                    _arguments -s -S \
                        $global_opts \
                        {-c,--config}'[Path to deny.toml config file]:config:_files -g "*.toml"' \
                        {-f,--format}'[Output format]:format:(human json tsv)' \
                        {-l,--layout}'[Layout of the output]:layout:(crate license)' \
                        {-t,--threshold}'[Confidence threshold for license detection]:threshold:' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_cargo-deny "$@"
