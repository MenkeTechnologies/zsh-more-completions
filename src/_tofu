#compdef tofu

# Zsh completion for OpenTofu (Terraform-compatible)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:prepare your working directory'
  'validate:validate the configuration files'
  'plan:show changes required by the current configuration'
  'apply:create or update infrastructure'
  'destroy:destroy previously-created infrastructure'
  'console:try OpenTofu expressions at an interactive console'
  'fmt:reformat your configuration in the standard style'
  'force-unlock:release a stuck lock on the current workspace'
  'get:install or upgrade remote modules'
  'graph:generate a Graphviz graph of the steps'
  'import:associate existing infrastructure with a resource'
  'login:obtain and save credentials for a remote host'
  'logout:remove locally-stored credentials for a remote host'
  'metadata:metadata related commands'
  'output:show output values from your root module'
  'providers:show the providers required for this configuration'
  'refresh:update the state to match remote systems'
  'show:show a human-readable output from a state or plan file'
  'state:advanced state management'
  'taint:mark a resource instance as not fully functional'
  'test:execute integration tests'
  'untaint:remove the taint marker from a resource instance'
  'version:show the current OpenTofu version'
  'workspace:workspace management'
)

_arguments -s -S \
  '-chdir[switch to a different working directory]:dir:_files -/' \
  '-help[show help]' \
  '-version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'tofu command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (plan|apply)
        _arguments \
          '-auto-approve[skip interactive approval]' \
          '-backup[path to backup the existing state file]:file:_files' \
          '-compact-warnings[show warnings in compact form]' \
          '-destroy[select destroy planning mode]' \
          '-detailed-exitcode[return detailed exit codes]' \
          '-input[ask for input for variables]:bool:(true false)' \
          '-json[produce JSON output]' \
          '-lock[lock the state file]:bool:(true false)' \
          '-lock-timeout[duration to retry a state lock]:duration:' \
          '-no-color[disable color output]' \
          '-out[write a plan file]:file:_files' \
          '-parallelism[limit the number of concurrent operations]:n:' \
          '-refresh[update state prior to checking for differences]:bool:(true false)' \
          '-refresh-only[select the refresh only planning mode]' \
          '-replace[force replacement of a resource]:resource:' \
          '-state[path to the state file]:file:_files' \
          '-target[resource to target]:resource:' \
          '-var[set a variable]:key\=value:' \
          '-var-file[set variables from a file]:file:_files -g "*.tfvars *.tfvars.json"' \
          '*:config directory:_files -/' && ret=0
        ;;
      (init)
        _arguments \
          '-backend[configure the backend]:bool:(true false)' \
          '-backend-config[backend configuration]:key\=value or file:_files' \
          '-force-copy[suppress prompts for copying state data]' \
          '-from-module[copy module into target directory]:source:' \
          '-get[download modules]:bool:(true false)' \
          '-input[ask for input]:bool:(true false)' \
          '-lock[lock state]:bool:(true false)' \
          '-lock-timeout[state lock timeout]:duration:' \
          '-migrate-state[reconfigure backend and attempt to migrate state]' \
          '-no-color[disable color output]' \
          '-plugin-dir[directory containing plugin binaries]:dir:_files -/' \
          '-reconfigure[reconfigure backend ignoring saved configuration]' \
          '-upgrade[upgrade modules and plugins]' \
          '*:config directory:_files -/' && ret=0
        ;;
      (fmt)
        _arguments \
          '-check[check formatting without rewriting]' \
          '-diff[display diffs]' \
          '-list[list files with formatting differences]:bool:(true false)' \
          '-no-color[disable color output]' \
          '-recursive[process directories recursively]' \
          '-write[write result to source file]:bool:(true false)' \
          '*:file or directory:_files' && ret=0
        ;;
      (workspace)
        local -a ws_cmds=('delete:delete a workspace' 'list:list workspaces' 'new:create a workspace' 'select:select a workspace' 'show:show current workspace')
        _arguments '1:workspace command:((${(j: :)${ws_cmds// /\\:}}))' '*:args:' && ret=0
        ;;
      (state)
        local -a state_cmds=('list:list resources' 'mv:move an item' 'pull:pull current state' 'push:update remote state' 'replace-provider:replace provider' 'rm:remove instances' 'show:show a resource')
        _arguments '1:state command:((${(j: :)${state_cmds// /\\:}}))' '*:args:' && ret=0
        ;;
      (destroy)
        _arguments \
          '-auto-approve[skip approval]' \
          '-lock[lock state]:bool:(true false)' \
          '-no-color[disable color output]' \
          '-parallelism[concurrent operations]:n:' \
          '-target[target resource]:resource:' \
          '-var[set a variable]:key\=value:' \
          '-var-file[set variables from file]:file:_files -g "*.tfvars *.tfvars.json"' && ret=0
        ;;
      (output)
        _arguments \
          '-json[produce JSON output]' \
          '-raw[print raw string value]' \
          '-no-color[disable color output]' \
          '-state[state file]:file:_files' \
          '1:output name:' && ret=0
        ;;
      (import)
        _arguments \
          '-config[config directory]:dir:_files -/' \
          '-input[ask for input]:bool:(true false)' \
          '-lock[lock state]:bool:(true false)' \
          '-no-color[disable color output]' \
          '-var[set a variable]:key\=value:' \
          '-var-file[set variables from file]:file:_files -g "*.tfvars *.tfvars.json"' \
          '1:address:' '2:id:' && ret=0
        ;;
    esac
    ;;
esac

return ret
