#compdef ren

# Zsh completion for ren (batch rename tool)

_arguments -s -S \
  '(-d --dry-run)'{-d,--dry-run}'[show what would be renamed]' \
  '(-f --force)'{-f,--force}'[force overwrite]' \
  '(-i --interactive)'{-i,--interactive}'[confirm before each rename]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-n --no-act)'{-n,--no-act}'[do not perform renames]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:pattern:' \
  '2:replacement:' \
  '*:file:_files' && return 0
