#compdef aix2john
# Documentation: https://man.archlinux.org/search?q=aix2john
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[show this help message and exit]'
  '-s[use this option if "lpa_options = std_hash=true" is activated]'
  '-f[specify the AIX shadow file filename to read (usually]'
  '*:filename:_files'
)

_arguments -s -S $arguments
