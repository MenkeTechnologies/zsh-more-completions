#compdef fcping

local -a arguments

arguments=(
  '-f[Flood ping]'
  '-q[Quiet! just print summary]'
  '-x[Hex dump of responses]'
  '-i[wait interval seconds between each ping]:interval:'
  '-c[stop after sending count pings]:count:'
  '-h[HBA identifier (eth, MAC, WWPN, or FC-ID)]:hba:'
  '-s[byte-length of ping request payload (max 2108)]:size:'
  '-F[destination port ID]:port-id:'
  '-P[destination world-wide port name]:wwpn:'
  '-N[destination world-wide node name]:wwnn:'
  '*:filename:_files'
)

_arguments -s -S $arguments
