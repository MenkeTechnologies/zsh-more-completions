#compdef nektos

# nektos/act - run GitHub Actions locally (alternative binary name)
# The main binary is 'act' which is handled by _act completion

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*:args' && ret=0

return ret
