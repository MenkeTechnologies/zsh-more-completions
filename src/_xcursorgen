#compdef xcursorgen
# Documentation: https://man.archlinux.org/search?q=xcursorgen
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-V,--version}'[display the version number and exit]'
  {-p,--prefix}'[find cursor images in <dir>]'
  '*:filename:_files'
)

_arguments -s -S $arguments
