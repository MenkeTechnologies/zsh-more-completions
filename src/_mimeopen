#compdef mimeopen

local -a arguments

arguments=(
  {-a,--ask}'[do not execute the default application but ask which application to]'
  {-d,--ask-default}'[let the user choose a new default program for given files.]'
  {-n,--no-ask}'[dont ask the user which program to use. Choose the default program]'
  {-M,--magic-only}'[do not check for extensions, globs or inode type, only look at the content of the file]'
  '--database[...]'
  {-D,--debug}'[print debug information about how the mimetype was determined.]'
  '(- * :)'{-h,--help}'[display help and exit]'
  {-u,--usage}'[print a help message and exits.]'
  {-v,--version}'[print the version of the program and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
