#compdef jqp

# Zsh completion for jqp - jq playground

local -a themes
themes=(
  abap algol algol_nu arduino autumn borland bw colorful dracula emacs
  friendly fruity github gruvbox igor lovelace manni monokai murphy
  native nord paraiso-dark paraiso-light pastie perldoc pygments
  rainbow_dash rrt solarized-dark solarized-dark256 solarized-light
  swapoff tango trac vim vs vulcan xcode-dark xcode
)

local -a arguments

arguments=(
  {-f,--file}'[path to input JSON file]:input file:_files'
  {-t,--theme}'[set color theme]:theme:($themes)'
)

_arguments -s -S $arguments
