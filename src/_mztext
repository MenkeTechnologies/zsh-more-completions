#compdef mztext

local -a arguments

arguments=(
  {-o,--output}'[output file (defaults to standard output)]'
  {-c,--command-marker}'[command marker (defaults to "@")]'
  '--run[run the command string on a single preprocessed input file]'
  {--help,-h}'[show this help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
