#compdef so

# Zsh completion for so (StackOverflow CLI)

_arguments -s -S \
  '(-s --search-engine)'{-s,--search-engine}'[search engine to use]:engine:(duckduckgo google stackexchange)' \
  '(-l --limit)'{-l,--limit}'[number of results to show]:number:' \
  '(-t --type)'{-t,--type}'[search type]:type:(answers questions)' \
  '(-e --site)'{-e,--site}'[StackExchange site to search]:site:' \
  '--lucky[go to the first result]' \
  '(-q --query)'{-q,--query}'[query string]:query:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:query:' && return 0
