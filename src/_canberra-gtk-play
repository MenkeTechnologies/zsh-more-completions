#compdef canberra-gtk-play

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  '--help-all[show all help options]'
  '--help-gtk[show GTK+ Options]'
  {-v,--version}'[display version number and quit]'
  {-i,--id}'[event sound identifier]:id:'
  {-f,--file}'[play file]:file:_files'
  {-d,--description}'[event sound description]:description:'
  {-c,--cache-control}'[cache control]:mode:(permanent volatile never)'
  {-l,--loop}'[loop how many times (default: 1)]:count:'
  {-V,--volume}'[a floating point dB value for the sample volume (ex: 0.0)]:volume:'
  '--property[an arbitrary property]:property:'
  '--display[X display to use]:display:'
  '*:filename:_files'
)

_arguments -s -S $arguments
