#compdef ksflatten
# Documentation: https://man.archlinux.org/search?q=ksflatten
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    {-c,--config}'[The name of the input kickstart file.]':INFILE
    {-o,--output}'[Write the flattened kickstart file to OUTFILE, or stdout if no filename is gi]':OUTFILE
    '*:filename:_files'
)
_arguments -s -S $arguments
