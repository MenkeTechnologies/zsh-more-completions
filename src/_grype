#compdef grype

# Zsh completion for Grype - vulnerability scanner for container images and filesystems

local curcontext="$curcontext" state line ret=1

_grype_commands() {
  local -a commands=(
    'completion:generate a shell completion script'
    'db:vulnerability database operations'
    'help:help about any command'
    'version:show version information'
  )
  _describe -t commands 'grype command' commands
}

_grype_db() {
  local -a db_commands=(
    'check:check if the vulnerability database is up to date'
    'delete:delete the vulnerability database'
    'diff:diff two vulnerability databases'
    'import:import a vulnerability database archive'
    'list:list available vulnerability databases'
    'status:display the current status of the vulnerability database'
    'update:update the vulnerability database'
    'search:search the vulnerability database'
  )
  _describe -t db-commands 'db command' db_commands
}

_grype_scan() {
  _arguments -s -S \
    '(-o --output)'{-o,--output}'[report output format]:format:(table cyclonedx cyclonedx-json json sarif template)' \
    '--file[write output to file]:file:_files' \
    '--scope[selection of layers to analyze]:scope:(squashed all-layers)' \
    '--add-cpes-if-none[generate CPEs for packages with no CPE data]' \
    '--by-cve[orient results by CVE instead of vulnerability ID]' \
    '--config[application config file]:file:_files' \
    '--distro[distro to match against]:distro' \
    '--exclude[exclude paths from being scanned]:glob' \
    '(-f --fail-on)'{-f,--fail-on}'[set vulnerability severity that will fail the scan]:severity:(negligible low medium high critical)' \
    '--name[set the name of the target being analyzed]:name' \
    '--only-fixed[ignore matches for vulnerabilities that are not fixed]' \
    '--only-notfixed[ignore matches for vulnerabilities that are fixed]' \
    '--platform[an optional platform specifier]:platform:(linux/amd64 linux/arm64 linux/arm/v7)' \
    '(-q --quiet)'{-q,--quiet}'[suppress all output except for the vulnerability list]' \
    '(-s --show-suppressed)'{-s,--show-suppressed}'[show suppressed/ignored vulnerabilities]' \
    '(-t --template)'{-t,--template}'[specify the path to a Go template file]:file:_files' \
    '(-v --verbose)'{-v,--verbose}'[increase verbosity (-v = info, -vv = debug)]' \
    '--vex[specify one or more VEX documents]:file:_files' \
    '1:source:(dir\: registry\: sbom\: purl\:)' && ret=0
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '--version[show version]' \
  '--config[application config file]:file:_files' \
  '(-o --output)'{-o,--output}'[report output format]:format:(table cyclonedx cyclonedx-json json sarif template)' \
  '--file[write output to file]:file:_files' \
  '--scope[selection of layers to analyze]:scope:(squashed all-layers)' \
  '(-f --fail-on)'{-f,--fail-on}'[set vulnerability severity that will fail]:severity:(negligible low medium high critical)' \
  '--add-cpes-if-none[generate CPEs for packages with no CPE data]' \
  '--by-cve[orient results by CVE instead of vulnerability ID]' \
  '--distro[distro to match against]:distro' \
  '--exclude[exclude paths from being scanned]:glob' \
  '--name[set the name of the target being analyzed]:name' \
  '--only-fixed[ignore matches for vulnerabilities that are not fixed]' \
  '--only-notfixed[ignore matches for vulnerabilities that are fixed]' \
  '--platform[an optional platform specifier]:platform' \
  '--show-suppressed[show suppressed/ignored vulnerabilities]' \
  '--template[specify the path to a Go template file]:file:_files' \
  '--vex[specify one or more VEX documents]:file:_files' \
  '1: :_grype_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      db)
        _arguments -C \
          '1: :_grype_db' \
          '*:: :->db_args' && ret=0
        case $state in
          db_args)
            case $words[1] in
              import)
                _arguments '1:archive file:_files' && ret=0
                ;;
              diff)
                _arguments '1:database 1:_files' '2:database 2:_files' && ret=0
                ;;
              update|check|delete|status|list)
                _arguments && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish)' && ret=0
        ;;
      version)
        _arguments \
          '(-o --output)'{-o,--output}'[output format]:format:(text json)' && ret=0
        ;;
      *)
        _grype_scan
        ;;
    esac
    ;;
esac

return ret
