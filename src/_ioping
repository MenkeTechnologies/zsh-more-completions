#compdef ioping

# Zsh completion for ioping - disk I/O latency tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c+[stop after count requests]:count:' \
  '-i+[interval between requests]:interval:' \
  '-s+[request size]:size:' \
  '-S+[working set size]:disk size:' \
  '-w+[stop after deadline]:deadline:' \
  '-q[quiet mode]' \
  '-R[rate mode (seek rate test)]' \
  '-W[write mode]' \
  '-B[batch mode]' \
  '-C[use cached I/O]' \
  '-D[use direct I/O]' \
  '-L[use sequential operations]' \
  '-A[use asynchronous I/O]' \
  '-Y[use data sync I/O]' \
  '-p+[period for reporting]:period:' \
  '-P+[number of parallel requests]:parallel:' \
  '-h[show help]' \
  '-v[show version]' \
  '1:file or device:_files' && ret=0

return ret
