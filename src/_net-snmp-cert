#compdef net-snmp-cert

local -a arguments

arguments=(
  {-V,--version}'[print version string and exit]'
  {-D,--debug}'[set debug level]'
  {-F,--force}'[overwrite existing output files]'
  {-I,--nointeractive}'[non-interactive run]'
  {-Q,--noverbose}'[suppress verbose output]'
  {-C,--cfgdir}'[configuration dir]:dir:'
  {-T,--tlsdir}'[root for cert storage]:dir:'
  {-f,--cfgfile}'[config file]:file:_files'
  {-i,--identity}'[identity to use from config]'
  {-t,--tag}'[application tag (default snmp)]:tag:'
  {-a,--with-ca}'[CA certificate used to sign request]'
  {-A,--ca}'[output CA certificate]'
  {-r,--csr}'[certificate signing request]'
  {-x,--from-crt}'[certificate for current operation]'
  {-X,--crt}'[output certificate]'
  {-y,--install}'[install result in local repository]'
  {-e,--email}'[email name]:email:'
  {-h,--host}'[host name or IP address]:host:'
  {-d,--days}'[number of days certificate is valid]:days:'
  {-n,--cn}'[common name (CN)]:name:'
  {-o,--org}'[organization name]:name:'
  {-u,--unit}'[organizational unit name]:name:'
  {-c,--country}'[country code (e.g., US)]:code:'
  {-p,--province}'[province/state name]:name:'
  {-l,--locality}'[locality name (e.g., town)]:name:'
  {-s,--san}'[subject alternative name]:san:'
  '--brief[brief output]'
  '--text[text description]'
  '--subject[subject description]'
  '--subject_hash[hash of subject for indexing]'
  '--issuer[issuer description]'
  '--issuer_hash[hash of issuer for indexing]'
  '--fingerprint[SHA1 digest of DER]'
  '--serial[serial number]'
  '--modulus[modulus of the public key]'
  '--dates[start and end dates]'
  '--purpose[allowed uses]'
  '*:filename:_files'
)

_arguments -s -S $arguments
