#compdef gamemoded


local -a arguments

arguments=(
    {-r,--request}'[toggle gamemode for process]:PID:'
    {-s,--status}'[query the status of gamemode for process]:PID:'
    {-d,--daemonize}'[Run the daemon as a separate process (daemonize it).]'
    {-l,--log-to-syslog}'[Log to syslog.]'
    {-h,--help}'[Print help text.]'
    {-t,--test}'[Run diagnostic tests on the current installation.]'
    {-v,--version}'[Print the version.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
