#compdef wakeonlan
# Documentation: https://man.archlinux.org/search?q=wakeonlan
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[this information]'
  '-v[displays the script version]'
  '-i[set the destination IP address]'
  '-p[set the destination port]'
  '-f[uses file as a source of hardware addresses]'
  '*:filename:_files'
)

_arguments -s -S $arguments
