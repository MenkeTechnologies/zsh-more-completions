#compdef mm2gv
# Documentation: https://man.archlinux.org/search?q=mm2gv
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-u[make graph undirected]'
  '-v[assign len to edges]'
  '-c[assign color and wt to edges]'
  '-l[add label]'
  '-o[output file]'
  '*:filename:_files'
)

_arguments -s -S $arguments
