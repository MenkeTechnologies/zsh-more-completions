#compdef uname

# Zsh completion for uname (display system information)
# Supports both BSD (macOS/FreeBSD) and GNU coreutils versions

local curcontext="$curcontext" ret=1

if [[ "$OSTYPE" == linux* ]]; then
  # GNU coreutils uname
  _arguments -s -S \
    '(-a --all)'{-a,--all}'[print all information in the following order]' \
    '(-s --kernel-name)'{-s,--kernel-name}'[print the kernel name]' \
    '(-n --nodename)'{-n,--nodename}'[print the network node hostname]' \
    '(-r --kernel-release)'{-r,--kernel-release}'[print the kernel release]' \
    '(-v --kernel-version)'{-v,--kernel-version}'[print the kernel version]' \
    '(-m --machine)'{-m,--machine}'[print the machine hardware name]' \
    '(-p --processor)'{-p,--processor}'[print the processor type (non-portable)]' \
    '(-i --hardware-platform)'{-i,--hardware-platform}'[print the hardware platform (non-portable)]' \
    '(-o --operating-system)'{-o,--operating-system}'[print the operating system]' \
    '(- *)--help[display help and exit]' \
    '(- *)--version[output version information and exit]' && ret=0
else
  # BSD uname (macOS/FreeBSD)
  _arguments -s -S \
    '-a[print all information (behaves as -mnrsv)]' \
    '-m[print the machine hardware platform type]' \
    '-n[print the network node hostname]' \
    '-o[print the operating system (synonym for -s)]' \
    '-p[print the machine processor architecture type]' \
    '-r[print the operating system release level]' \
    '-s[print the operating system name]' \
    '-v[print the operating system version]' && ret=0
fi

return ret
