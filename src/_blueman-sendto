#compdef blueman-sendto

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-d,--device}'[send files to this device]'
  '--dest[same as --device]'
  {-s,--source}'[source adapter. Takes address or adapters name eg.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
