#compdef diesel

# Zsh completion for diesel - Rust ORM CLI tool

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'setup:create the database and run migrations'
  'database:manage the database'
  'migration:manage migrations'
  'print-schema:print table definitions for database schema'
  'completions:generate shell completions'
  'help:print help for subcommands'
)

_arguments -s -S \
  '1:subcommand:->subcmd' \
  '*::args:->args' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--database-url[specify the database URL]:url:' \
  '--config-file[path to diesel.toml]:file:_files -g "*.toml"' \
  '--locked-schema[require that the schema file is up to date]' \
  '--migration-dir[path to migrations directory]:directory:_files -/' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'diesel subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (setup)
        _arguments \
          '--database-url[database URL]:url:' \
          '--migration-dir[migrations directory]:directory:_files -/' \
          '--config-file[path to diesel.toml]:file:_files -g "*.toml"' && ret=0
        ;;
      (database)
        local -a db_commands=(
          'setup:create and set up the database'
          'reset:drop and recreate the database'
          'drop:drop the database'
        )
        _arguments \
          '1:database command:->db_subcmd' \
          '--database-url[database URL]:url:' \
          '--migration-dir[migrations directory]:directory:_files -/' && ret=0
        case $state in
          (db_subcmd) _describe -t commands 'database command' db_commands && ret=0 ;;
        esac
        ;;
      (migration)
        local -a mig_commands=(
          'run:run pending migrations'
          'revert:revert the latest migration'
          'redo:revert and re-run the latest migration'
          'list:list all available migrations'
          'pending:list pending migrations'
          'generate:create a new empty migration'
        )
        _arguments \
          '1:migration command:->mig_subcmd' \
          '*::mig_args:->mig_args' \
          '--database-url[database URL]:url:' \
          '--migration-dir[migrations directory]:directory:_files -/' && ret=0
        case $state in
          (mig_subcmd) _describe -t commands 'migration command' mig_commands && ret=0 ;;
          (mig_args)
            case ${line[1]} in
              (generate)
                _arguments '1:migration name:' && ret=0
                ;;
              (revert|redo)
                _arguments \
                  '-n[number of migrations to revert]:count:' \
                  '--all[revert all migrations]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      (print-schema)
        _arguments \
          '--database-url[database URL]:url:' \
          '--schema[schema name]:schema:' \
          '-o[only include these tables]:tables:' \
          '--only-tables[only include these tables]:tables:' \
          '-e[exclude these tables]:tables:' \
          '--except-tables[exclude these tables]:tables:' \
          '--with-docs[include documentation comments]' \
          '--column-sorting[column sort order]:order:(ordinal_position name)' \
          '--patch-file[patch file to apply]:file:_files' \
          '--import-types[extra types to import]:types:' && ret=0
        ;;
    esac
    ;;
esac

return ret
