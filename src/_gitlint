#compdef gitlint

# Zsh completion for gitlint - git commit message linter

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'lint:lint a commit message'
  'install-hook:install gitlint as a commit-msg hook'
  'uninstall-hook:uninstall gitlint commit-msg hook'
  'generate-config:generate a sample gitlint config file'
  'run-hook:run the gitlint commit-msg hook'
)

_arguments -s -S \
  '1:command:->command' \
  '(-C --config)'{-C,--config}'[path to config file]:file:_files' \
  '(-c --commit)'{-c,--commit}'[lint a specific commit]:commit hash' \
  '--commits[lint a range of commits]:commit range' \
  '--msg-filename[path to commit message file]:file:_files' \
  '--ignore[comma-separated list of rules to ignore]:rules' \
  '--contrib[comma-separated list of contrib rules to enable]:rules' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(-e --extra-path)'{-e,--extra-path}'[path to directory with extra user rules]:path:_directories' \
  '--target[target git repository]:dir:_directories' \
  '(-s --staged)'{-s,--staged}'[lint staged commit message]' \
  '--fail-without-commits[fail if no commits found]' \
  '(-q --silent)'{-q,--silent}'[silent mode]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'gitlint command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (lint)
        _arguments -s -S \
          '(-C --config)'{-C,--config}'[path to config file]:file:_files' \
          '--msg-filename[path to commit message file]:file:_files' \
          '--ignore[comma-separated list of rules to ignore]:rules' \
          '--contrib[comma-separated list of contrib rules]:rules' \
          '(-d --debug)'{-d,--debug}'[enable debug output]' \
          '(-e --extra-path)'{-e,--extra-path}'[path to extra user rules]:path:_directories' \
          '--target[target git repository]:dir:_directories' \
          '(-s --staged)'{-s,--staged}'[lint staged commit message]' \
          '(-c --commit)'{-c,--commit}'[lint a specific commit]:commit hash' \
          '--commits[lint a range of commits]:commit range' \
          '(-q --silent)'{-q,--silent}'[silent mode]' \
          '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (install-hook|uninstall-hook)
        _arguments -s -S \
          '--target[target git repository]:dir:_directories' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (generate-config)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (run-hook)
        _arguments -s -S \
          '--msg-filename[path to commit message file]:file:_files' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
