#compdef unlzop
# Documentation: https://man.archlinux.org/search?q=unlzop
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-c[write to stdout]'
  '-f[force]'
  '-U[delete input files]'
  '-t[test integrity]'
  '-v[verbose]'
  '-F[dont verify checksum]'
  '*:filename:_files'
)

_arguments -s -S $arguments
