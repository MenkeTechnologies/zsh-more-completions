#compdef csvsql

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-d+[delimiting character]:delimiter' \
  '--delimiter=[delimiting character]:delimiter' \
  '-t[specify that input is tab-delimited]' \
  '--tabs[specify that input is tab-delimited]' \
  '-q+[quoting character]:character' \
  '--quotechar=[quoting character]:character' \
  '-u+[double quote style]:style:(0 1 2 3)' \
  '--doublequote=[double quote style]:style:(0 1 2 3)' \
  '-H[no header row]' \
  '--no-header-row[no header row]' \
  '-K+[skip lines]:number' \
  '--skip-lines=[skip lines]:number' \
  '-e+[encoding]:encoding' \
  '--encoding=[encoding]:encoding' \
  '-S[ignore header case when sorting]' \
  '-l[insert line numbers]' \
  '--linenumbers[insert line numbers]' \
  '--zero[use zero-based line numbers]' \
  '--no-inference[disable type inference]' \
  '-i+[database dialect]:dialect:(access firebird mssql mysql oracle postgresql sqlite sybase)' \
  '--dialect=[database dialect]:dialect:(access firebird mssql mysql oracle postgresql sqlite sybase)' \
  '--db=[database connection string]:connection string' \
  '-f+[SQL file]:SQL file:_files -g "*.sql"' \
  '--query=[SQL query]:query' \
  '--insert[insert data into table]' \
  '--prefix=[add expression before insert]:prefix' \
  '--before-insert=[SQL to execute before insert]:SQL' \
  '--after-insert=[SQL to execute after insert]:SQL' \
  '--tables=[table names]:table names' \
  '--no-constraints[disable length limits and null checks]' \
  '--unique-constraint=[columns for unique constraint]:columns' \
  '--no-create[skip table creation]' \
  '--create-if-not-exists[use CREATE TABLE IF NOT EXISTS]' \
  '--overwrite[drop table before creating]' \
  '--db-schema=[database schema]:schema' \
  '-y+[sniff limit]:limit' \
  '--snifflimit=[sniff limit]:limit' \
  '-I[disable type inference]' \
  '--chunk-size=[chunk size for insert]:size' \
  '*:CSV file:_files -g "*.csv"' && ret=0

return ret
