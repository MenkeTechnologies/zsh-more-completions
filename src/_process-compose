#compdef process-compose

# Zsh completion for process-compose - Process orchestrator

_process-compose_commands() {
  local -a commands=(
    'up:start all or specific processes'
    'down:stop all running processes'
    'restart:restart a running process'
    'start:start a stopped process'
    'stop:stop a running process'
    'attach:attach to a running process'
    'info:show process info'
    'list:list running processes'
    'logs:show process logs'
    'port:show process port'
    'project:manage projects'
    'config:show configuration'
    'help:show help for a command'
    'version:show version information'
  )
  _describe -t commands 'process-compose command' commands
}

_process-compose_up() {
  _arguments \
    '(-f --config)'{-f,--config}'[specify config file]:file:_files' \
    '(-p --port)'{-p,--port}'[specify port]:port:' \
    '(-t --tui)'{-t,--tui}'[enable or disable TUI]:enable:(true false)' \
    '(-L --log-file)'{-L,--log-file}'[specify log file]:file:_files' \
    '--ordered-shutdown[shut down processes in reverse order]' \
    '--no-server[disable HTTP server]' \
    '--hide-disabled[hide disabled processes in TUI]' \
    '--env[specify env file]:file:_files' \
    '--ref-rate[TUI refresh rate in ms]:milliseconds:' \
    '--detached[run in detached mode]' \
    '--read-only[run in read-only mode]' \
    '--namespace[specify namespace]:namespace:' \
    '--unix-socket[specify unix socket path]:path:_files' \
    '--disable-dotenv[disable .env file loading]' \
    '--log-level[set log level]:level:(trace debug info warn error fatal panic)' \
    '--log-length[set max log length]:length:' \
    '--is-strict[enable strict mode]' \
    '--sort-column[sort by column]:column:(name status age ns)' \
    '--sort-ascending[sort in ascending order]' \
    '--theme[specify TUI theme]:theme:' \
    '--reverse-log[reverse log order]' \
    '*:process:'
}

_process-compose_logs() {
  _arguments \
    '(-f --follow)'{-f,--follow}'[follow log output]' \
    '(-t --tail)'{-t,--tail}'[number of lines to show]:lines:' \
    '(-p --process)'{-p,--process}'[process name]:process:'
}

_process-compose() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '--help[show help]' \
    '--version[show version]' \
    '1:command:_process-compose_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        up)
          _process-compose_up
          ;;
        logs)
          _process-compose_logs
          ;;
        restart|start|stop)
          _arguments '*:process name:'
          ;;
        *)
          _arguments '--help[show help]'
          ;;
      esac
      ;;
  esac
}

_process-compose "$@"
