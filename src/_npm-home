#compdef npm-home
# Documentation: https://man.archlinux.org/search?q=npm-home
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {--github,-g}'[open the GitHub repo of the package]'
  {--yarn,-y}'[open the Yarn homepage of the package]'
  '*:filename:_files'
)

_arguments -s -S $arguments
