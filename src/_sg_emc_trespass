#compdef sg_emc_trespass
# Documentation: https://man.archlinux.org/search?q=sg_emc_trespass
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-d[output debug]'
  '-hr[Set Honor Reservation bit]'
  '-s[send Short Trespass Command page (default: long)]'
  '-V[print version string then exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
