#compdef libguestfs-test-tool

local -a arguments

arguments=(
  '--help[display usage]'
  '--qemudir[specify QEMU source directory]'
  '--qemu[specify QEMU binary]'
  {--timeout,-t}'[set launch timeout (default: 600 seconds)]:seconds:'
  {--version,-V}'[display libguestfs version and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
