#compdef fsck
# Documentation: https://man.archlinux.org/search?q=fsck
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '-p[Automatic repair (no questions)]'
    '-n[Make no changes to the filesystem]'
    '-y[Assume "yes" to all questions]'
    '-c[Check for bad blocks and add them to the badblock list]'
    '-f[Force checking even if filesystem is marked clean]'
    '-v[Be verbose]'
    '-b[Use alternative superblock]:superblock:'
    '-B[Force blocksize when looking for superblock]:blocksize:'
    '-j[Set location of the external journal]:journal:_files'
    '-l[Add to badblocks list]:file:_files'
    '-L[Set badblocks list]:file:_files'
    '-z[Create an undo file]:file:_files'
    '*:filename:_files'
)

_arguments -s -S $arguments
