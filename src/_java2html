#compdef java2html

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[print help and exit]'
  '--detailed-help[print help, including all details and hidden options]'
  {-V,--version}'[print version and exit]'
  {-i,--input}'[input file (default=stdin)]'
  {-o,--output}'[output file (default=stdout)]'
  {-s,--src-lang}'[source language (use --lang-list to get the complete list)]'
  '--lang-list[list all the supported language and associated language definition file]'
  '--outlang-list[list all the supported output language and associated definition file]'
  {-f,--out-format}'[output format (use --outlang-list to get the complete list)]'
  {-d,--doc}'[create an output file that can be used as a standalone document]'
  '--no-doc[cancel the --doc option even if it is implied by other options]'
  {-c,--css}'[the external style sheet filename, implies --doc]'
  {-T,--title}'[give a title to the output document, implies --doc]'
  {-t,--tab}'[specify tab length.  (default=`8)]'
  {-H,--header}'[file to insert as header]'
  {-F,--footer}'[file to insert as footer]'
  '--style-file[specify the file containing format options]'
  '--style-css-file[specify the file containing format options (in CSS syntax)]'
  '--style-defaults[specify the file containing defaults for format options]'
  '--outlang-def[output language definition file]'
  '--outlang-map[output language map file]'
  '--data-dir[directory where language definition files and output files are searched for]'
  '--output-dir[output directory]'
  '--lang-def[language definition file]'
  '--lang-map[language map file  (default=`lang.map)]'
  '--show-lang-elements[prints the language elements that are defined in the language definition file]'
  '--infer-lang[force to infer source script language]'
  {-n,--line-number}'[number all output lines, using the specified padding]'
  '--line-number-ref[number all output lines and generate an anchor for each line]'
  '--line-range[generate only the lines in the specified range]'
  '--range-separator[the optional separator to be printed among ranges of lines]'
  '--range-context[number of (context) lines generated even if not in range]'
  '--regex-range[generate only the lines within the specified regular expression range]'
  '--gen-references[generate references]'
  '--ctags-file[specify the file generated by ctags that will be used for references]'
  '--ctags[how to run the ctags command]'
  '--tag-relative[use relative paths for tag entries]'
  {-v,--verbose}'[verbose mode on]'
  {-q,--quiet}'[print no progress information]'
  '--binary-output[write output files in binary mode]'
  '--statistics[print some statistics (i.e., elapsed time)]'
  '--gen-version[put source-highlight version in the generated output file]'
  '--check-lang[only check the correctness of a language definition file]'
  '--check-outlang[only check the correctness of an output language definition file]'
  '--failsafe[if no language definition is found for the input, use a failsafe one]'
  {-g,--debug-langdef}'[debug a language definition]'
  '--show-regex[show the regular expression automaton]'
  '*:filename:_files'
)

_arguments -s -S $arguments
