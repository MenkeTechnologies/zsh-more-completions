#compdef thumbpdf

local -a arguments

arguments=(
  '--help[print usage]'
  '--version[print version number]'
  '--gscmd[call of ghostscript (gs)]'
  '--antialias[anti-aliasing level, 0=disable, 4=max (default 4)]:level:'
  '--device[Ghostscript device for thumbnails (default png)]:device:'
  '--resolution[thumbnail resolution (default 9)]:dpi:'
  '--compress[thumbnail compress level, 0-10 (default 10)]:level:'
  '--modes[output mode]:mode:(pdftex pdfmark dvips ps2pdf)'
  '--password[password for encrypted pdf file]:password:'
  '*:filename:_files'
)

_arguments -s -S $arguments
