#compdef ibclearcounters
# Documentation: https://man.archlinux.org/search?q=ibclearcounters
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '-C[use specified CA]:ca name'
    '-P[use specified port]:port number'
    '-t[set timeout in milliseconds]:timeout'
    '*:filename:_files'
)
_arguments -s -S $arguments
