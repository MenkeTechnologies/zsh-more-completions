#compdef vivid
# Documentation: https://man.archlinux.org/search?q=vivid
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-m,--color-mode}'[type of ANSI colors to be used \[default: 24-bit\]  \[possible values:]'
  {-d,--database}'[path to filetypes database (filetypes.yml)]'
  {-h,--help}'[prints help information]'
  {-V,--version}'[prints version information]'
  '*:filename:_files'
)

_arguments -s -S $arguments
