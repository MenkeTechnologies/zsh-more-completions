#compdef lou_translate
# Documentation: https://man.archlinux.org/search?q=lou_translate
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    {-h,--help}'[display this help and exit.]'
    {-v,--version}'[display version information and exit.]'
    {-f,--forward}'[forward translation using the given table.]'
    {-b,--backward}'[backward translation using the given table If neither -f nor -b are specified]'
    '*:filename:_files'
)
_arguments -s -S $arguments
