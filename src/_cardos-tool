#compdef cardos-tool

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[print this help message]'
  {-i,--info}'[print information about this card]'
  {-f,--format}'[format this card erasing all content]'
  {-s,--startkey}'[specify startkey for format]:startkey:'
  {-S,--change-startkey}'[change Startkey with given APDU command]:apdu:'
  {-r,--reader}'[uses reader number \[0\]]:reader:'
  {-c,--card-driver}'[forces the use of driver \[auto-detect\]]:driver:'
  {-w,--wait}'[wait for a card to be inserted]'
  {-v,--verbose}'[verbose operation. Use several times to enable debug output.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
