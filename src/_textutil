#compdef textutil

local -a arguments

arguments=(
  '-help[show this message and exit]'
  '-info[display information about each file]'
  '-convert[convert each input file to format]:format:(txt rtf rtfd html doc docx wordml odt webarchive)'
  '-cat[concatenate input files into one output file]:format:(txt rtf rtfd html doc docx wordml odt webarchive)'
  '-extension[alternate extension for all output files]:extension:'
  '-output[alternate file name for first output file]:file:_files'
  '-stdin[read from stdin instead of files]'
  '-stdout[send first output file to stdout]'
  '-encoding[encoding used for plain text or html output files]:encoding:'
  '-inputencoding[encoding used to interpret plain text input files]:encoding:'
  '-format[force input files to be interpreted in this format]:format:(txt rtf rtfd html doc docx wordml odt webarchive)'
  '-font[specify font used for converting plain to rich text]:font:'
  '-fontsize[specify font size for converting plain to rich text]:size:'
  '-noload[do not load subsidiary resources for html files]'
  '-nostore[do not write out subsidiary resources for html files]'
  '-baseurl[base URL for subsidiary resources in html files]:url:'
  '-timeout[time in seconds to wait for html resources to load]:seconds:'
  '-textsizemultiplier[factor to apply to font sizes in html files]:factor:'
  '-excludedelements[HTML elements to exclude]:elements:'
  '-prefixspaces[number of spaces to indent nested html output]:spaces:'
  '-strip[do not copy metadata attributes to output files]'
  '-title[title metadata attribute for output files]:title:'
  '-author[author metadata attribute for output files]:author:'
  '-subject[subject metadata attribute for output files]:subject:'
  '-keywords[keywords metadata attribute for output files]:keywords:'
  '-comment[comment metadata attribute for output files]:comment:'
  '-editor[last editor metadata attribute for output files]:editor:'
  '-company[company metadata attribute for output files]:company:'
  '-creationtime[creation time metadata attribute for output files]:time:'
  '-modificationtime[modification time metadata attribute for output files]:time:'
  '*:filename:_files'
)

_arguments -s -S $arguments
