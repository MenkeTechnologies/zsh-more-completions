#compdef dyff

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a commands=(
      'between:compare two files'
      'last-applied:compare resource with last-applied'
      'yaml:convert input to YAML'
      'json:convert input to JSON'
      'version:show version'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  args)
    case "$words[1]" in
      between)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-o --output)'{-o,--output}'[output style]:style:(human brief github gitea)' \
          '--color[force color output]' \
          '--no-color[disable color output]' \
          '--truecolor[use 24-bit colors]' \
          '--omit-header[omit file header]' \
          '--ignore-order-changes[ignore order changes in lists]' \
          '--detect-kubernetes[detect Kubernetes resources]' \
          '--exclude-regexp[exclude paths matching regexp]:regexp' \
          '--filter[filter paths]:path' \
          '--set-exit-code[set exit code on diff]' \
          '--swap[swap from and to]' \
          '1:from file:_files -g "*.{yml,yaml,json}"' \
          '2:to file:_files -g "*.{yml,yaml,json}"' && ret=0
        ;;
      last-applied)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-o --output)'{-o,--output}'[output style]:style:(human brief github gitea)' \
          '1:file:_files -g "*.{yml,yaml,json}"' && ret=0
        ;;
      yaml)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--plain[use plain YAML style]' \
          '--restructure[restructure output]' \
          '1:file:_files -g "*.{yml,yaml,json}"' && ret=0
        ;;
      json)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:file:_files -g "*.{yml,yaml,json}"' && ret=0
        ;;
    esac
    ;;
esac

return ret
