#compdef podselect
# Documentation: https://man.archlinux.org/search?q=podselect
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-help[print a brief help message and exit.]'
  '-man[print the manual page and exit.]'
  '-section[specify a section to include in the output. See "SECTION]'
  '*:filename:_files'
)

_arguments -s -S $arguments
