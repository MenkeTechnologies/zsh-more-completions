#compdef zcomet

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'load:load a plugin'
  'fpath:add a directory to fpath'
  'snippet:source a snippet'
  'trigger:set up a trigger to lazy-load a plugin'
  'compinit:initialize completions'
  'compile:compile zsh scripts'
  'self-update:update zcomet itself'
  'update:update plugins and snippets'
  'list:list loaded plugins'
  'unload:unload a plugin'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'zcomet command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (load)
        _arguments '1:plugin (user/repo)' && ret=0
        ;;
      (fpath)
        _arguments '1:path:_directories' && ret=0
        ;;
      (snippet)
        _arguments '1:URL or file:_files' && ret=0
        ;;
      (trigger)
        _arguments \
          '1:trigger name' \
          '2:plugin (user/repo)' && ret=0
        ;;
      (unload)
        _arguments '1:plugin name' && ret=0
        ;;
    esac
    ;;
esac

return ret
