#compdef darwinup
# Documentation: https://man.archlinux.org/search?q=darwinup
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-d[disable helpful automation]'
  '-f[force operation to succeed at all costs]'
  '-n[dry run]'
  '-p[operate on roots under DIR (default: /)]'
  '-r[gracefully restart when finished]'
  '-v[verbose (use -vv for extra verbosity)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
