#compdef backdoor-factory

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-f,--file}'[file to backdoor]:file:_files'
  {-s,--shell}'[payloads available for use. Use show to see options]:shell:'
  {-H,--hostip}'[IP of the C2 for reverse connections]:host:'
  {-P,--port}'[the port to connect back to for reverse shells]:port:'
  {-J,--cave_jumping}'[use code cave jumping]'
  {-a,--add_new_section}'[add a new section for the shellcode]'
  {-U,--user_shellcode}'[user-supplied shellcode]:shellcode:'
  {-c,--cave}'[find code caves that can be used]'
  {-l,--shell_length}'[shell length]:length:'
  {-o,--output-file}'[the backdoor output file]:file:_files'
  {-n,--section}'[new section name (less than seven characters)]:name:'
  {-d,--directory}'[location of files to backdoor]:directory:_files -/'
  {-w,--change_access}'[change the section that houses the codecave]'
  {-i,--injector}'[turn the backdoor factory into hunt and inject mode]'
  {-u,--suffix}'[suffix on the original file for injector]:suffix:'
  {-D,--delete_original}'[delete the original file]'
  {-O,--disk_offset}'[disk offset]:offset:'
  {-S,--support_check}'[determine if the file is supported by BDF]'
  {-M,--cave-miner}'[help determine smallest shellcode]'
  {-q,--no_banner}'[suppress the banner]'
  {-v,--verbose}'[debug information output]'
  {-T,--image-type}'[binary type to process]:type:(ALL x86 x64)'
  {-Z,--zero_cert}'[overwrite the pointer to the PE certificate table]'
  {-R,--runas_admin}'[check PE binaries for admin privileges (experimental)]'
  {-L,--patch_dll}'[do not patch DLLs]'
  {-F,--fat_priority}'[fat binary priority]:priority:'
  {-B,--beacon}'[set beacon interval for payloads that support it]:interval:'
  {-m,--patch-method}'[patching method for PE files]:method:(manual automatic)'
  {-b,--user_malware}'[user-supplied binary]:binary:_files'
  {-X,--xp_mode}'[enable XP legacy machine support]'
  {-A,--idt_in_cave}'[put Import Directory Table in cave (experimental)]'
  {-C,--code_sign}'[sign PE binaries with codesigning cert]'
  {-p,--preprocess}'[execute preprocessing scripts]'
  '*:filename:_files'
)

_arguments -s -S $arguments
