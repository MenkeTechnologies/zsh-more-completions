#compdef ucfq
# Documentation: https://man.archlinux.org/search?q=ucfq
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--help[this message.]'
  '--debug[turn on debugging mode.]'
  '--verbose[make the script more verbose.]'
  '--with-colons[A compact, machine readable version of the output.]'
  '--state-dir[set the state directory instead of the default]:path:_directories'
  '*:filename:_files'
)

_arguments -s -S $arguments
