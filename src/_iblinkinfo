#compdef iblinkinfo


local -a arguments

arguments=(
    {--outstanding_smps,-o}'[specify the number of outstanding SMPs to issue during the scan]':val
    {-y,--m_key}'[use the specified M_key for requests.]':key
    '-e[show send and receive errors (timeouts and others).]'
    {-v,--verbose}'[increase the application verbosity level.]'
    {--down,-d}'[Print only nodes which have a port in the "Down" state.]'
    {--line,-l}'[Print all information for each link on one line.]'
    {--additional,-p}'[Print additional port settings (<LifeTime>,<HoqLife>,<VLStallCount>).]'
    '--switches-only[Show only switches in output.]'
    '--cas-only[Show only CAs in output. Partial Scan flags.]'
    {--port-guid,-G}'[specify port GUID for partial scan]:port guid'
    {-D,--Direct}'[use direct route addressing]'
    {--switch,-S}'[specify switch GUID for partial scan]:switch guid'
    {--all,-a}'[Print all nodes found in a partial fabric scan.]'
    {--hops,-n}'[Specify the number of hops away from a specified node to scan.]':hops
    '--load-cache[Load and use the cached ibnetdiscover data stored in the specified filename.]:filename'
    '--diff[Load cached ibnetdiscover data and do a diff comparison to current network]:filename'
    '--diffcheck[Specify what diff checks should be done in the --diff option above.]:key(s)'
    '--filterdownports[Filter downports indicated in a ibnetdiscover cache.]:filename'
    {-C,--Ca}'[use specified CA]:ca name'
    {-P,--Port}'[use specified port]:port number'
    {--config,-z}'[use specified config file]:config file:_files'
    '--node-name-map[specify node name map file]:filename:_files'
    {-t,--timeout}'[set timeout in milliseconds]:timeout'
    {-h,--help}'[show help]'
    {-V,--version}'[show version]'
    '*:filename:_files'
)
_arguments -s -S $arguments
