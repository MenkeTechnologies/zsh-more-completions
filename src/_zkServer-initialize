#compdef zkServer-initialize
# Documentation: https://man.archlinux.org/search?q=zkServer-initialize
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[display this message]'
  '--help[display this message]'
  '--configfile[/local/etc/zookeeper/zoo.cfg         ZooKeeper config file]'
  '--myid[set the myid to be used, if any (1-255)]'
  '--force[force creation of the data/txnlog dirs]'
  '*:filename:_files'
)

_arguments -s -S $arguments
