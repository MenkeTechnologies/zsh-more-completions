#compdef infokey
# Documentation: https://man.archlinux.org/search?q=infokey
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--output[output to FILE instead of $HOME/.info]'
  '--help[display this help and exit.]'
  '--version[display version information and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
