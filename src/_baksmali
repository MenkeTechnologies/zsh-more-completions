#compdef baksmali
# Documentation: https://man.archlinux.org/search?q=baksmali
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {--help,-h,-\?}'[show usage information]'
  {--version,-v}'[Print the version of baksmali and then exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
