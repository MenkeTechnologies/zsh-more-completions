#compdef systemd-dissect


local -a arguments

arguments=(
    {--read-only,-r}'[Operate in read-only mode.]'
    '--fsck[Turn off automatic file system checking.]:no'
    '--mkdir[If combined with --mount the directory to mount the OS image to is created if]'
    '--discard[Takes one of "disabled", "loop", "all", "crypto".]'
    {--root-hash,--root-hash-sig,--verity-data}'[Configure various aspects of Verity data integrity for the OS image.]'
    '--image[switch, and be used as root file system for system service using the RootImag]'
    {--mount,-m}''
    '-R[switch (for recursive operation), so that the OS image and all nested partiti]'
    '-M[.]'
    {--copy-from,-x}''
    {--copy-to,-a}''
    '--json[.]:MODE'
    {-h,--help}''
    '--version[.]'
    '--add[fsck(8) command, in automatic fixing mode.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
