#compdef alertmanager

local -a arguments

arguments=(
  '--config.file[configuration file path]:file:_files'
  '--storage.path[base path for data storage]:path:_directories'
  '--data.retention[data retention period]:duration:'
  '--data.maintenance-interval[maintenance interval for data]:interval:'
  '--alerts.gc-interval[alert garbage collection interval]:interval:'
  '--web.listen-address[address to listen on for web interface]:address:'
  '--web.external-url[external URL for this Alertmanager]:url:'
  '--web.route-prefix[prefix for the internal routes]:prefix:'
  '--web.get-concurrency[maximum GET request concurrency]:number:'
  '--web.timeout[timeout for HTTP requests]:duration:'
  '--cluster.listen-address[cluster listen address]:address:'
  '--cluster.advertise-address[cluster advertise address]:address:'
  '*--cluster.peer[initial peer address]:address:'
  '--cluster.peer-timeout[peer timeout]:duration:'
  '--cluster.gossip-interval[gossip interval]:duration:'
  '--cluster.pushpull-interval[push/pull interval]:duration:'
  '--cluster.tcp-timeout[TCP timeout]:duration:'
  '--cluster.probe-timeout[probe timeout]:duration:'
  '--cluster.probe-interval[probe interval]:duration:'
  '--cluster.settle-timeout[settle timeout]:duration:'
  '--cluster.reconnect-interval[reconnect interval]:duration:'
  '--cluster.reconnect-timeout[reconnect timeout]:duration:'
  '--log.level[log filtering level]:level:(debug info warn error)'
  '--log.format[log format]:format:(logfmt json)'
  '(- *)--version[print version information]'
)

_arguments -s -S $arguments
