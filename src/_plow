#compdef plow
# Zsh completion for plow - HTTP benchmarking tool
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-c --concurrency)'{-c,--concurrency}'[number of concurrent connections]:number:' \
  '(-d --duration)'{-d,--duration}'[duration of test]:duration:' \
  '(-n --requests)'{-n,--requests}'[total number of requests]:number:' \
  '--body[request body]:body string:' \
  '--body-file[read request body from file]:file:_files' \
  '(-T --content-type)'{-T,--content-type}'[content type header]:content type:' \
  '*'{-H,--header}'[custom HTTP header]:header:' \
  '(-m --method)'{-m,--method}'[HTTP method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
  '--timeout[request timeout]:duration:' \
  '--host[host header]:host:' \
  '--cert[TLS certificate file]:file:_files' \
  '--key[TLS private key file]:file:_files' \
  '(-k --insecure)'{-k,--insecure}'[skip TLS verification]' \
  '--http2[use HTTP/2]' \
  '--listen[listen address for real-time report]:address:' \
  '--seconds[use seconds as time unit]' \
  '--no-print[suppress result output]' \
  '--json[output results as JSON]' \
  '(- *)--version[show version]' \
  '(- *)--help[show help information]' \
  '1:url:' && ret=0
return ret
