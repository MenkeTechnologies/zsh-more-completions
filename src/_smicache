#compdef smicache
# Documentation: https://man.archlinux.org/search?q=smicache
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-V[show version and license information]'
  '-h[show usage information]'
  '-d[use dir as the caching directory]'
  '-p[use prefix as the URL prefix for fetching modules]'
  '*:filename:_files'
)

_arguments -s -S $arguments
