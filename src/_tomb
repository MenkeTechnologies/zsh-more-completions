#compdef tomb

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-s[size in MB for dig/resize]:size in MB' \
  '-k[key file]:key file:_files' \
  '-g[use GPG encryption]' \
  '-r[GPG recipient]:recipient' \
  '-o[mount options]:mount options' \
  '-f[force operation]' \
  '1:command:->commands' \
  '*:file:_files' && ret=0

case "$state" in
  commands)
    local -a cmds=(
      'dig:create a new tomb file'
      'forge:create a new key file'
      'lock:lock a tomb with a key'
      'open:open an existing tomb'
      'close:close an open tomb'
      'slam:force close all open tombs'
      'list:list open tombs'
      'index:index contents of open tombs'
      'search:search indexed tomb contents'
      'resize:resize a tomb'
      'passwd:change key password'
      'setkey:change tomb key'
      'engrave:engrave key to QR code'
      'bury:steganographically hide a key'
      'exhume:extract a key hidden with bury'
    )
    _describe -t commands 'tomb command' cmds && ret=0
    ;;
esac
return ret
