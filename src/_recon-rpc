#compdef recon-rpc
# Documentation: https://man.archlinux.org/search?q=recon-rpc
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  '-t[set RPC server type]'
  '-a[set RPC server bind address]'
  '-p[set RPC server port]'
  '*:filename:_files'
)

_arguments -s -S $arguments
