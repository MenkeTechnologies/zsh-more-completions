#compdef security
# Documentation: https://man.archlinux.org/search?q=security
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-i[run in interactive mode.]'
  '-l[run /usr/bin/leaks -nocontext before exiting.]'
  '-p[set the prompt to "prompt" (implies -i).]'
  '-q[be less verbose.]'
  '-v[be more verbose about whats going on.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
