#compdef elfctl
# Documentation: https://man.archlinux.org/search?q=elfctl
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-l[list known control features.]'
  '-i[ignore unknown features.]'
  '-e[+-=\]feature,list      Edit features from a comma separated list.]'
  {-h,--help}'[print a usage message and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
