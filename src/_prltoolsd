#compdef prltoolsd

local -a arguments

arguments=(
  '-h[This help]'
  '-V[Version]'
  '-f[Run in foreground]'
  '-v[Verbose output]'
  '-p[Path to PID file, default: /var/run/prltoolsd.pid]'
  '-r[Dynamic resolution update time (in milliseconds) \[100, 1000\], default: 250]'
  '-T[Disable time synchronization]'
  '-c[path to configuration file (deprecated)]:config file:_files'
  '*:filename:_files'
)

_arguments -s -S $arguments
