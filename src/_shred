#compdef shred

# Completion for shred - overwrite a file to hide its contents
# GNU coreutils

local arguments

arguments=(
  {-f,--force}'[change permissions to allow writing if necessary]'
  {-n,--iterations}'=[overwrite N times instead of the default (3)]:number of iterations'
  '--random-source=[get random bytes from FILE]:random source:_files'
  {-s,--size}'=[shred this many bytes (suffixes K, M, G accepted)]:size'
  '-u[deallocate and remove file after overwriting]'
  '--remove=-[like -u but give control on HOW to delete]::removal method:((unlink\:"use standard unlink call" wipe\:"obfuscate bytes in the name first" wipesync\:"obfuscate and sync each byte to device"))'
  {-v,--verbose}'[show details of data and metadata operations performed]'
  {-x,--exact}'[do not round file sizes up to the next full block]'
  {-z,--zero}'[add a final overwrite with zeros to hide shredding]'
  '--help[display help and exit]'
  '--version[output version information and exit]'
  '*:file:_files'
)

_arguments -s -S $arguments
