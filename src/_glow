#compdef glow

# Zsh completion for glow (markdown renderer for the terminal)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-a --all)'{-a,--all}'[show all files including hidden]' \
  '(-s --style)'{-s,--style}'[style name or JSON file]:style:(auto dark light notty dracula)' \
  '(-w --width)'{-w,--width}'[word-wrap at specified width]:width' \
  '(-p --pager)'{-p,--pager}'[display output in pager]' \
  '(-l --local)'{-l,--local}'[show local files only (no stash)]' \
  '--config[path to config file]:config file:_files' \
  '--mouse[enable mouse wheel]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:markdown file or URL:_files -g "*.md(|x)(N)"' \
  && ret=0

return ret
