#compdef mwawZip
# Documentation: https://man.archlinux.org/search?q=mwawZip
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[print this help]'
  '-x[do not zip a BinHex, an OLE2 or a Zip file]'
  '-v[output mwawZip version]'
  '-D[only zip the file containing a resource fork or finder information.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
