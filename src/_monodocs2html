#compdef monodocs2html

local -a arguments

arguments=(
  '--default-template[writes the default XSLT to stdout.]'
  '--ext[the file EXTENSION to use for created files]'
  '--force-update[always generate new files]'
  {-o,--out}'[the DIRECTORY to place the generated files]'
  '--template[an XSLT FILE to use to generate the created files.]'
  '--with-profile[the .NET PROFILE to generate documentation for.]'
  '--with-version[the assembly VERSION to generate documentation for.]'
  '-h[show this message and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
