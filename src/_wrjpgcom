#compdef wrjpgcom
# Documentation: https://man.archlinux.org/search?q=wrjpgcom
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-replace[delete any existing comments]'
  '-comment[" Insert comment with given text]'
  '-cfile[read comment from named file]'
  '*:filename:_files'
)

_arguments -s -S $arguments
