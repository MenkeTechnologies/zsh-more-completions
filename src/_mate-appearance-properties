#compdef mate-appearance-properties
# Documentation: https://man.archlinux.org/search?q=mate-appearance-properties
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  '--help-all[show all help options]'
  '--help-gtk[show GTK+ Options]'
  {-i,--install-theme}'[specify the filename of a theme to install]'
  {-p,--show-page}'[specify the name of the page to show (theme|background|fonts|interface)]'
  '--display[X display to use]'
  '*:filename:_files'
)

_arguments -s -S $arguments
