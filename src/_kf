#compdef kf

local -a arguments

arguments=(
  {-p,--port}'[port to connect to]'
  {-l,--login}'[remote login name]'
  {-c,--ccache}'[remote cred cache]'
  {-F,--forwardable}'[forward forwardable credentials]'
  {-G,--no-forwardable}'[dont forward forwardable credentials]'
  '*:filename:_files'
)

_arguments -s -S $arguments
