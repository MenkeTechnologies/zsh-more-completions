#compdef exim_msgdate


local -a arguments

arguments=(
    {-u,--unix}'[output timestamps in Unix format (seconds since 1970-01-01)]'
    {--GMT,--UTC,-z,--zulu}'[use UTC time zone]'
    {-l,--local}'[use local time zone]'
    '--help'
    '--man'
    '--debug'
    {--base,--base36,--base62}'[set message ID base encoding]'
    '--pid'
    '--localhost_number'
    '--C'
    '--dexim_path'
    '*:filename:_files'
)
_arguments -s -S $arguments
