#compdef grub2-setpassword
# Documentation: https://man.archlinux.org/search?q=grub2-setpassword
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[print this message and exit]'
  {-v,--version}'[print the version information and exit]'
  {-o,--output}'[_path <DIRECTORY> put user.cfg in a user-selected directory]'
  '*:filename:_files'
)

_arguments -s -S $arguments
