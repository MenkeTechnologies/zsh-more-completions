#compdef cct

local -a arguments

arguments=(
  '-c[specify input columns for (up to) 4 input parameters]:columns:'
  '-d[specify number of decimals in output]:decimals:'
  '-I[do the inverse transformation]'
  '-o[specify output file name]:file:_files'
  '-t[provide a fixed t value for all input data (e.g. -t 0)]:value:'
  '-z[provide a fixed z value for all input data (e.g. -z 0)]:value:'
  '-s[skip n first lines of an infile]:n:'
  '-v[verbose: Provide non-essential informational output.]'
  '--output[alias for -o]'
  '--columns[alias for -c]'
  '--decimals[alias for -d]'
  '--height[alias for -z]'
  '--time[alias for -t]'
  '--verbose[alias for -v]'
  '--inverse[alias for -I]'
  '--skip-lines[alias for -s]'
  '--help[alias for -h]'
  '--version[print version number]'
  '*:filename:_files'
)

_arguments -s -S $arguments
