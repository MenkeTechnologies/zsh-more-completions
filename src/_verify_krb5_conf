#compdef verify_krb5_conf
# Documentation: https://man.archlinux.org/search?q=verify_krb5_conf
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--dumpconfig[show the parsed config files]'
  '--warn-mit-syntax[the parsed config files]'
  '--version[print version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
