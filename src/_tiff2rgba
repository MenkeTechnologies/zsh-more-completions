#compdef tiff2rgba
# Documentation: https://man.archlinux.org/search?q=tiff2rgba
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-r[rows/strip]'
  '-b[by block rather than as a whole image)]'
  '-n[t emit alpha component.]'
  '-8[bigTIFF file instead of ClassicTIFF]'
  '*:filename:_files'
)

_arguments -s -S $arguments
