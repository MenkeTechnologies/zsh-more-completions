#compdef grub2-mkimage
# Documentation: https://man.archlinux.org/search?q=grub2-mkimage
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-c,--config}'[embed FILE as an early config]'
  {-C,--compression}'[)]'
  {-d,--directory}'[use images and modules under DIR]'
  {-k,--pubkey}'[embed FILE as public key for signature checking]'
  {-m,--memdisk}'[embed FILE as a memdisk image]'
  {-n,--note}'[add]'
  {-o,--output}'[output a generated image to FILE \[default=stdout\]]'
  {-O,--format}'[generate an image in FORMAT]'
  {-p,--prefix}'[set prefix directory]'
  {-v,--verbose}'[print verbose messages.]'
  '--usage[give a short usage message]'
  {-V,--version}'[print program version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
