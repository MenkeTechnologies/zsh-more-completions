#compdef turbostat
# Documentation: https://man.archlinux.org/search?q=turbostat
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--add[add a counter]'
  '--cpu[cpu-set limit output to summary plus cpu-set:]'
  '--quiet[skip decoding system configuration header]'
  '--interval[override default 5-second measurement interval]'
  '--help[print this help message]'
  '--list[list column headers only]'
  '--out[create or truncate "file" for all output]'
  '--version[print version information]'
  '*:filename:_files'
)

_arguments -s -S $arguments
