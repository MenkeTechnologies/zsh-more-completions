#compdef py3rsa-keygen
# Documentation: https://man.archlinux.org/search?q=py3rsa-keygen
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    {-h,--help}'[show help message and exit.]'
    '--pubout[output filename for the public key.]:PUBOUT'
    {-o,--out}'[output filename for the private key.]'
    '--form[key format of the private and public keys - default PEM]:FORM'
    '*:filename:_files'
)
_arguments -s -S $arguments
