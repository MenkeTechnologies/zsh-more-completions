#compdef py3rsa-keygen


local -a arguments

arguments=(
    {-h,--help}'[show help message and exit.]'
    '--pubout[output filename for the public key.]:PUBOUT'
    {-o,--out}'[output filename for the private key.]'
    '--form[key format of the private and public keys - default PEM AUTHOR ,py3rsa-keygen…]:FORM'
    '*:filename:_files'
)
_arguments -s -S $arguments
