#compdef signal-cli

_signal-cli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a global_opts
    global_opts=(
        {-u,--username}'[Specify your phone number]:phone number:'
        '--config[Set the config directory]:config dir:_directories'
        {-o,--output}'[Set the output format]:format:(json plain-text)'
        '--service-environment[Set the service environment]:environment:(live staging)'
        '--trust-new-identities[Set the trust policy for new identities]:policy:(on-first-use always never)'
        {-v,--verbose}'[Enable verbose output]'
        {-h,--help}'[Print help information]'
        '--version[Print version information]'
    )

    _arguments -C \
        $global_opts \
        '(-): :->command' \
        '(-)*:: :->option-or-argument' && ret=0

    case $state in
        (command)
            local -a commands
            commands=(
                'daemon:Run as a daemon'
                'jsonRpc:Run JSON-RPC server'
                'link:Link to an existing device'
                'register:Register a new account'
                'verify:Verify a registration code'
                'unregister:Unregister from Signal'
                'send:Send a message'
                'receive:Receive messages'
                'getUserStatus:Check if users are registered on Signal'
                'joinGroup:Join a group via invite link'
                'quitGroup:Leave a group'
                'listGroups:List all groups'
                'updateGroup:Update group settings'
                'listContacts:List contacts'
                'listIdentities:List known identity keys'
                'trust:Trust an identity key'
                'updateAccount:Update account settings'
                'updateConfiguration:Update Signal configuration'
                'updateProfile:Update your profile'
                'removePin:Remove registration lock PIN'
                'setPin:Set registration lock PIN'
                'block:Block a contact or group'
                'unblock:Unblock a contact or group'
                'sendContacts:Send contacts to linked devices'
                'sendSyncRequest:Send a sync request'
                'uploadStickerPack:Upload a sticker pack'
                'listStickerPacks:List installed sticker packs'
                'addStickerPack:Add a sticker pack'
                'version:Print the version'
            )
            _describe -t commands 'signal-cli command' commands && ret=0
            ;;
        (option-or-argument)
            curcontext=${curcontext%:*:*}:signal-cli-$words[1]:
            case $words[1] in
                (send)
                    _arguments -s -S \
                        $global_opts \
                        {-m,--message}'[Message to send]:message:' \
                        '*'{-a,--attachment}'[Attachment file to send]:file:_files' \
                        '*--mention[Mention a user in the message]:mention:' \
                        '--quote-timestamp[Timestamp of message to quote]:timestamp:' \
                        '--quote-author[Author of the quoted message]:author:' \
                        '--quote-message[Text of the quoted message]:message:' \
                        '*--quote-mention[Mention in the quoted message]:mention:' \
                        '--preview-url[URL for link preview]:url:' \
                        '--preview-title[Title for link preview]:title:' \
                        '--preview-image[Image for link preview]:image:_files' \
                        '--sticker[Sticker to send]:sticker:' \
                        '--story-timestamp[Timestamp of story to reply to]:timestamp:' \
                        '--story-author[Author of the story to reply to]:author:' \
                        '--edit-timestamp[Timestamp of message to edit]:timestamp:' \
                        {-e,--end-session}'[End the session with the recipient]' \
                        '--notify-self[Send a notification to self]' \
                        {-g,--group-id}'[Send to a group]:group ID:' \
                        '--note-to-self[Send a note to self]' \
                        '*:recipient:' && ret=0
                    ;;
                (receive)
                    _arguments -s -S \
                        $global_opts \
                        '--timeout[Timeout in seconds]:seconds:' \
                        '--max-messages[Maximum messages to receive]:count:' && ret=0
                    ;;
                (register)
                    _arguments -s -S \
                        $global_opts \
                        '--voice[Use voice call for verification]' \
                        '--captcha[Captcha token]:token:' && ret=0
                    ;;
                (verify)
                    _arguments -s -S \
                        $global_opts \
                        '--pin[Registration lock PIN]:pin:' \
                        ':verification code:' && ret=0
                    ;;
                (updateGroup)
                    _arguments -s -S \
                        $global_opts \
                        {-g,--group-id}'[Group ID]:group ID:' \
                        {-n,--name}'[Group name]:name:' \
                        '--description[Group description]:description:' \
                        '*'{-a,--avatar}'[Group avatar]:file:_files' \
                        '*--member[Add a member]:member:' \
                        '*--remove-member[Remove a member]:member:' \
                        '*--admin[Make a member an admin]:member:' \
                        '*--remove-admin[Remove admin from a member]:member:' \
                        '--link[Group invite link setting]:setting:(enabled enabled-with-approval disabled)' \
                        '--set-permission-add-member[Who can add members]:permission:(every-member only-admins)' \
                        '--set-permission-edit-details[Who can edit details]:permission:(every-member only-admins)' \
                        '--set-permission-send-messages[Who can send messages]:permission:(every-member only-admins)' \
                        '--expiration[Message expiration timer in seconds]:seconds:' && ret=0
                    ;;
                (updateProfile)
                    _arguments -s -S \
                        $global_opts \
                        '--given-name[First name]:name:' \
                        '--family-name[Last name]:name:' \
                        '--about[About text]:about:' \
                        '--about-emoji[About emoji]:emoji:' \
                        '--avatar[Profile avatar]:file:_files' \
                        '--remove-avatar[Remove profile avatar]' && ret=0
                    ;;
                (trust)
                    _arguments -s -S \
                        $global_opts \
                        '--verified-safety-number[Safety number to verify]:safety number:' \
                        '--trust-all-known-keys[Trust all known keys]' \
                        ':recipient:' && ret=0
                    ;;
                (block|unblock)
                    _arguments -s -S \
                        $global_opts \
                        {-g,--group-id}'[Group ID to block/unblock]:group ID:' \
                        '*:recipient:' && ret=0
                    ;;
                (setPin)
                    _arguments -s -S \
                        $global_opts \
                        ':pin:' && ret=0
                    ;;
                (daemon|jsonRpc|link|unregister|listGroups|listContacts|listIdentities|getUserStatus|joinGroup|quitGroup|updateAccount|updateConfiguration|removePin|sendContacts|sendSyncRequest|uploadStickerPack|listStickerPacks|addStickerPack|version)
                    _arguments -s -S $global_opts && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_signal-cli "$@"
