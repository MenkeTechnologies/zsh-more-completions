#compdef hyperfine

# Zsh completion for hyperfine - A command-line benchmarking tool

_hyperfine() {
  local -a arguments

  arguments=(
    '(-w --warmup)'{-w,--warmup}'[perform NUM warmup runs before the actual benchmark]:num runs:'
    '(-m --min-runs)'{-m,--min-runs}'[perform at least NUM runs for each command (default\: 10)]:num runs:'
    '(-M --max-runs)'{-M,--max-runs}'[perform at most NUM runs for each command]:num runs:'
    '(-r --runs)'{-r,--runs}'[perform exactly NUM runs for each command]:num runs:'
    '(-s --setup)'{-s,--setup}'[execute CMD before each set of timing runs]:cmd:_cmdstring'
    '--reference[the reference command for relative comparison of results]:cmd:_cmdstring'
    '--reference-name[give a meaningful name to the reference command]:name:'
    '*'{-p,--prepare}'[execute CMD before each timing run]:cmd:_cmdstring'
    '*'{-C,--conclude}'[execute CMD after each timing run]:cmd:_cmdstring'
    '(-c --cleanup)'{-c,--cleanup}'[execute CMD after all benchmarking runs for each command]:cmd:_cmdstring'
    '(-P --parameter-scan)'{-P,--parameter-scan}'[perform benchmark runs for each value in range MIN..MAX]:var: :min: :max:'
    '(-D --parameter-step-size)'{-D,--parameter-step-size}'[traverse the range MIN..MAX in steps of DELTA]:delta:'
    '*'{-L,--parameter-list}'[perform benchmark runs for each value in comma-separated list]:var: :values:'
    '(-S --shell)'{-S,--shell}'[set the shell to use for executing benchmarked commands]:shell:_command_names'
    '-N[an alias for --shell=none]'
    '(-i --ignore-failure)'{-i,--ignore-failure}'[ignore non-zero exit codes of the benchmarked programs]::mode:'
    '--style[set output style type (default\: auto)]:type:(auto basic full nocolor color none)'
    '--sort[specify the sort order of the speed comparison summary]:method:(auto command mean-time)'
    '(-u --time-unit)'{-u,--time-unit}'[set the time unit to be used]:unit:(microsecond millisecond second)'
    '--export-asciidoc[export timing summary as an AsciiDoc table]:file:_files'
    '--export-csv[export timing summary as CSV]:file:_files'
    '--export-json[export timing summary and individual runs as JSON]:file:_files'
    '--export-markdown[export timing summary as a Markdown table]:file:_files'
    '--export-orgmode[export timing summary as an Emacs org-mode table]:file:_files'
    '--show-output[print stdout and stderr of the benchmark]'
    '*--output[control where the output of the benchmark is redirected]:where:_hyperfine_output'
    '*--input[control where the input of the benchmark comes from]:where:_hyperfine_input'
    '*'{-n,--command-name}'[give a meaningful name to a command]:name:'
    '(- *)'{-h,--help}'[print help]'
    '(- *)'{-V,--version}'[print version]'
    '*:command:_cmdstring'
  )

  _arguments -s -S $arguments
}

_hyperfine_output() {
  local -a output_options
  output_options=(
    'null:redirect output to /dev/null (default)'
    'pipe:feed the output through a pipe before discarding it'
    'inherit:do not redirect the output at all'
  )
  _alternative \
    'options:output option:compadd -V options null pipe inherit' \
    'files:output file:_files'
}

_hyperfine_input() {
  local -a input_options
  input_options=(
    'null:read from /dev/null (default)'
  )
  _alternative \
    'options:input option:compadd -V options null' \
    'files:input file:_files'
}

_hyperfine "$@"
