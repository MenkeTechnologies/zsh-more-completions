#compdef hyperfine

local arguments

arguments=(
  {-w,--warmup}'[perform NUM warmup runs before the actual benchmark]:num runs:'
  {-m,--min-runs}'[perform at least NUM runs for each command (default: 10)]:num runs:'
  {-M,--max-runs}'[perform at most NUM runs for each command]:num runs:'
  {-r,--runs}'[perform exactly NUM runs for each command]:num runs:'
  {-s,--setup}'[execute CMD before each set of timing runs]:cmd:'
  '--reference[the reference command for relative comparison of results]:cmd:'
  '--reference-name[give a meaningful name to the reference command]:name:'
  {-p,--prepare}'[execute CMD before each timing run]:cmd:'
  {-C,--conclude}'[execute CMD after each timing run]:cmd:'
  {-c,--cleanup}'[execute CMD after all benchmarking runs for each command]:cmd:'
  {-P,--parameter-scan}'[perform benchmark runs for each value in range MIN..MAX]:var: :min: :max:'
  {-D,--parameter-step-size}'[traverse the range MIN..MAX in steps of DELTA]:delta:'
  {-L,--parameter-list}'[perform benchmark runs for each value in comma-separated list]:var: :values:'
  {-S,--shell}'[set the shell to use for executing benchmarked commands]:shell:_command_names'
  '-N[an alias for --shell=none]'
  {-i,--ignore-failure}'[ignore non-zero exit codes of the benchmarked programs]::mode:(all-non-zero)'
  '--style[set output style type (default: auto)]:type:(auto basic full nocolor color none)'
  '--sort[specify the sort order of the speed comparison summary]:method:(auto command mean-time)'
  {-u,--time-unit}'[set the time unit to be used]:unit:(microsecond millisecond second)'
  '--export-asciidoc[export timing summary as an AsciiDoc table]:file:_files'
  '--export-csv[export timing summary as CSV]:file:_files'
  '--export-json[export timing summary and individual runs as JSON]:file:_files'
  '--export-markdown[export timing summary as a Markdown table]:file:_files'
  '--export-orgmode[export timing summary as an Emacs org-mode table]:file:_files'
  '--show-output[print stdout and stderr of the benchmark]'
  '--output[control where the output of the benchmark is redirected]:where:(null pipe inherit)'
  '--input[control where the input of the benchmark comes from]:where:(null)'
  {-n,--command-name}'[give a meaningful name to a command]:name:'
  {-h,--help}'[print help]'
  {-V,--version}'[print version]'
  '*:command:'
)

_arguments -s $arguments
