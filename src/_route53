#compdef route53

local -a arguments

arguments=(
    '--help[Show help]'
    '--version[Show version]'
    '1:command:(ls get create delete change)'
    '*:: :->args'
)

_arguments -s -S $arguments && return

case "$state" in
    args)
        case ${words[1]} in
            ls)
                _arguments \
                    '--type[Record type]:type:(A AAAA CNAME MX NS PTR SOA SRV TXT)' \
                    '*:hosted zone ID:'
                ;;
            get)
                _arguments '*:hosted zone ID:'
                ;;
            create)
                _arguments \
                    '--name[Domain name]:domain name' \
                    '--type[Record type]:type:(A AAAA CNAME MX NS PTR SOA SRV TXT)' \
                    '--value[Record value]:value' \
                    '--ttl[TTL in seconds]:ttl' \
                    '*:hosted zone ID:'
                ;;
            delete)
                _arguments \
                    '--name[Domain name]:domain name' \
                    '--type[Record type]:type:(A AAAA CNAME MX NS PTR SOA SRV TXT)' \
                    '*:hosted zone ID:'
                ;;
            *)
                _default
                ;;
        esac
        ;;
esac
