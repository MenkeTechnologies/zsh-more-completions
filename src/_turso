#compdef turso

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a cmds=(
      'auth:manage authentication'
      'contact:contact Turso support'
      'db:manage databases'
      'dev:start a local development server'
      'group:manage database groups'
      'org:manage organizations'
      'plan:manage subscription plan'
      'quickstart:get started with Turso'
      'relax:sometimes you need a break'
      'update:update the Turso CLI'
      'version:show version'
    )
    _describe -t commands 'turso command' cmds && ret=0
    ;;
  args)
    case "${words[1]}" in
      db)
        local -a db_cmds=(
          'create:create a database'
          'destroy:destroy a database'
          'list:list databases'
          'show:show database details'
          'shell:open a database shell'
          'tokens:manage database tokens'
          'inspect:inspect database'
          'replicate:replicate database to a location'
          'update:update database configuration'
        )
        _describe -t commands 'turso db command' db_cmds && ret=0
        ;;
      auth)
        local -a auth_cmds=(
          'login:log in to Turso'
          'logout:log out of Turso'
          'signup:sign up for Turso'
          'token:show authentication token'
          'whoami:show current user'
        )
        _describe -t commands 'turso auth command' auth_cmds && ret=0
        ;;
      group)
        local -a group_cmds=(
          'create:create a group'
          'destroy:destroy a group'
          'list:list groups'
          'locations:manage group locations'
          'update:update group configuration'
        )
        _describe -t commands 'turso group command' group_cmds && ret=0
        ;;
    esac
    ;;
esac
return ret
