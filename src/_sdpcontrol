#compdef sdpcontrol
# Documentation: https://man.archlinux.org/search?q=sdpcontrol
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-a[address to connect to]'
  '-c[path to the control socket (default is /var/run/sdp)]'
  '-h[display usage and quit]'
  '-l[connect to the local SDP server via control socket]'
  '*:filename:_files'
)

_arguments -s -S $arguments
