#compdef ath3kfw
# Documentation: https://man.archlinux.org/search?q=ath3kfw
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-D[enable debugging]'
  '-d[device to operate upon]'
  '-f[firmware path, if not default]'
  '-I[enable informational output]'
  '*:filename:_files'
)

_arguments -s -S $arguments
