#compdef lgroupadd
# Documentation: https://man.archlinux.org/search?q=lgroupadd
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-i,--interactive}'[prompt for all information]'
  {-g,--gid}'[gid for new group]'
  {-r,--reserved}'[create a system group]'
  '--usage[display brief usage message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
