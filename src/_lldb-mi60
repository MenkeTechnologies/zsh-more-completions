#compdef lldb-mi60
# Documentation: https://man.archlinux.org/search?q=lldb-mi60
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[prints out usage information for the MI debugger]'
  '--version[prints out GNU (gdb) version information. Exit the MI Driver]'
  '--versionLong[prints out MI Driver version information. Exit the MI Driver]'
  '--interpreter[this option is kept for backward compatibility. This executable always run in MI mode]'
  {-s,--source}'[tells the debugger to read in and execute lldb commands from file]:file:_files'
  '--executable[use the MI Driver in MI mode for the debugging the specified executable.]'
  '--log[use this argument to tell the MI Driver to update its log]'
  '--log-dir[use this argument to specify the directory the MI Driver]'
  '*:filename:_files'
)

_arguments -s -S $arguments
