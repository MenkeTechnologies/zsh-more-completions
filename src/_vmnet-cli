#compdef vmnet-cli
# Documentation: https://man.archlinux.org/search?q=vmnet-cli
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {--configure,-c}'[configure virtual network]'
  '--start[start virtual network]'
  '--stop[stop virtual network]'
  '--status[show virtual network status]'
  '(- * :)'{--help,-h}'[display help]'
  '--version[display version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
