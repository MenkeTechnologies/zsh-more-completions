#compdef vmnet-cli

local -a arguments

arguments=(
  {--configure,-c}'[configure virtual network]'
  '--start[start virtual network]'
  '--stop[stop virtual network]'
  '--status[show virtual network status]'
  '(- * :)'{--help,-h}'[display help]'
  '--version[display version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
