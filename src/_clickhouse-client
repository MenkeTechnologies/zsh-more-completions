#compdef clickhouse-client

_arguments -s -S \
  {-h,--host}'[server hostname]:host:_hosts' \
  '--port[server port]:port:' \
  {-u,--user}'[username]:user:' \
  '--password[password]:password:' \
  {-d,--database}'[database name]:database:' \
  {-q,--query}'[query to execute]:query:' \
  {-m,--multiquery}'[allow multiple queries separated by semicolons]' \
  {-n,--multiline}'[allow multiline queries]' \
  {-f,--format}'[output format]:format:(TabSeparated CSV JSONEachRow JSON Pretty PrettyCompact PrettyNoEscapes Vertical TSV TSVWithNames TSVWithNamesAndTypes CSVWithNames JSONCompact JSONCompactEachRow Null XML Markdown MySQLWire)' \
  '--time[print execution time to stderr]' \
  '--stacktrace[print stack traces on exceptions]' \
  '--config-file[config file path]:file:_files' \
  '--secure[use TLS connection]' \
  '--history_file[history file path]:file:_files' \
  '--param_name[set named parameter]:value:' \
  '--server_logs_file[server logs file]:file:_files' \
  '--pager[pager command]:command:_command_names' \
  '--progress[show progress bar]:mode:(tty)' \
  '--echo[echo queries before execution]' \
  '--max_client_network_bandwidth[max client network bandwidth]:bytes:' \
  '--compression[enable compression]:bool:(true false)' \
  '--max_memory_usage[max memory usage]:bytes:' \
  '--help[show help]' \
  '--version[show version]' \
  '-V[show version]' \
  '--max_parser_depth[max parser depth]:depth:' \
  '--send_logs_level[server log level]:level:(none fatal error warning information debug trace)' \
  '--testmode[enable test mode]' \
  '*:file:_files'
