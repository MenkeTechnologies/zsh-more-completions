#compdef netscsid

local -a arguments

arguments=(
    '--scanbus[scan SCSI bus]'
    '--devices[show available devices]'
    '--version[print version information and exit]'
    '-v[increment the level of general verbosity]'
    '-V[increment the SCSI command transport verbose level]'
    '--debug[enable debug mode]'
    {--silent,-s}'[do not print status report for failed SCSI commands]'
    '--force[force to continue on some errors]'
    '--immed[set the SCSI IMMED flag in certain commands]'
    '--dummy[go through recording steps without actually writing]'
    '--sao[set SAO (Session At Once) writing mode]'
    '--tao[set TAO (Track At Once) writing mode]'
    '--raw[set RAW writing mode]'
    '--raw96r[set RAW writing mode with 96 bytes of raw P-W subchannel data]'
    '--raw96p[set RAW writing mode with 96 bytes of packed P-W subchannel data]'
    '--raw16[set RAW writing mode with 16 bytes of P-Q subchannel data]'
    '--clone[set clone writing mode]'
    '--multi[allow multi session CDs to be made]'
    '--msinfo[retrieve and print multi session info]'
    '--toc[retrieve and print table of content or PMA of a CD]'
    '--atip[retrieve and print ATIP info]'
    '--fix[fixate the disk]'
    '--nofix[do not fixate the disk after writing]'
    '--waiti[wait for input on stdin before opening device]'
    '--load[load the media and exit]'
    '--lock[load the media, lock the door and exit]'
    '--eject[eject disk after doing the work]'
    '--format[format a CD-RW/DVD-RW/DVD+RW disc]'
    '--checkdrive[check if the drive is supported]'
    '--setdropts[set driver specific options]'
    '--prcap[print drive capabilities]'
    '--inq[do an inquiry for the drive and exit]'
    '--reset[try to reset the SCSI bus]'
    '--abort[try to send an abort sequence to the drive]'
    '--overburn[allow writing more than the official size of a medium]'
    '--ignsize[ignore the known size of the medium]'
    '--useinfo[use *.inf files to overwrite audio options]'
    '--audio[write subsequent tracks in audio mode]'
    '--data[write subsequent tracks in data mode]'
    '--packet[set packet writing mode]'
    '--noclose[do not close the current track]'
    '--text[write CD-Text information from file]'
    '--pad[pad tracks]'
    '--swab[assume audio data is byte-swapped]'
    '--mode2[write subsequent tracks in CD-ROM mode 2 format]'
    '--xa[write subsequent tracks in CD-ROM XA mode 2 format]'
    '--xa1[write subsequent tracks in CD-ROM XA mode 1 format]'
    '--xa2[write subsequent tracks in CD-ROM XA mode 2 format]'
    '--xamix[write subsequent tracks in mixed mode]'
    '--cdi[set the TOC type for the disk to CDI]'
    '--isosize[use ISO-9660 file system size as the track size]'
    '--nopad[do not pad]'
    '--shorttrack[allow short tracks]'
    '--noshorttrack[re-enforce Red Book track length standard]'
    '--preemp[set pre-emphasis for subsequent audio tracks]'
    '--nopreemp[unset pre-emphasis for subsequent audio tracks]'
    '--copy[set copy permitted for subsequent audio tracks]'
    '--nocopy[set copy not permitted for subsequent audio tracks]'
    '--scms[set SCMS for subsequent audio tracks]'
    '*:filename:_files'
)
_arguments -s -S $arguments
