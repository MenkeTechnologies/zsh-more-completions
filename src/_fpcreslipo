#compdef fpcreslipo
# Documentation: https://man.archlinux.org/search?q=fpcreslipo
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {--help,-h}'[-\? Show this screen.]'
  {--version,-V}'[show program version.]'
  {--verbose,-v}'[be verbose.]'
  {--output,-o}'[set the output file name.]'
  {--endian,-e}'[set shared file endianess (big, little)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
