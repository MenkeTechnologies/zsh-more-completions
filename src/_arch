#compdef arch
# Documentation: https://man.archlinux.org/search?q=arch
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-c[clear out all environment variables before running prog.]'
  '-d[delete the given environment variable before running prog.]'
  '-e[add the given environment variable/value before running prog.]'
  '-h[print usage message and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
