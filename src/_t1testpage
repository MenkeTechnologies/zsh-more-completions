#compdef t1testpage
# Documentation: https://man.archlinux.org/search?q=t1testpage
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-g,--glyph}'[limit output to one or more GLYPHs.]:glyph:'
  {-s,--smoke}'[print smoke proofs, one character per page.]'
  {-o,--output}'[write output to FILE instead of standard out.]:file:_files'
  '(- * :)'{-h,--help}'[print this message and exit.]'
  '--version[print version number and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
