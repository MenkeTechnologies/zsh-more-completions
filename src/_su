#compdef su

local -a arguments

if [[ "$OSTYPE" == darwin* ]]; then
  # macOS / BSD su
  arguments=(
    '-f[if invoked shell is csh, prevent it from reading .cshrc]'
    '-l[simulate a full login]'
    '-m[leave the environment unmodified]'
    '-[simulate a full login (same as -l)]'
    '1:user:_users'
    '*::arguments: _normal'
  )
else
  # GNU/Linux su (util-linux)
  arguments=(
    {-m,-p,--preserve-environment}'[do not reset environment variables]'
    {-g,--group=}'[specify the primary group]:group:_groups'
    {-G,--supp-group=}'[specify a supplemental group]:group:_groups'
    '-[simulate a full login (same as -l)]'
    {-l,--login}'[start the shell as a login shell]'
    {-c,--command=}'[pass a single command to the shell with -c]:command:_command_names -e'
    '--session-command=[pass a single command to the shell with -c and do not create a new session]:command:_command_names -e'
    {-f,--fast}'[pass -f to the shell (for csh or tcsh)]'
    {-s,--shell=}'[run the specified shell instead of the default]:shell:_shells'
    {-P,--pty}'[create a new pseudo-terminal]'
    {-w,--whitelist-environment=}'[do not reset specified variables]:variable list:'
    '(- * :)'{-h,--help}'[display help message and exit]'
    '(- * :)'{-V,--version}'[display version information and exit]'
    '1:user:_users'
    '*::arguments: _normal'
  )
fi

_arguments -s -S $arguments
