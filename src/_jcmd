#compdef jcmd
# Documentation: https://man.archlinux.org/search?q=jcmd
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-f[read and execute commands from the file]'
  '-l[list JVM processes on the local machine]'
  '-h[this help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
