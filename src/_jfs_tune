#compdef jfs_tune
# Documentation: https://man.archlinux.org/search?q=jfs_tune
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-J[set external journal options.]'
  '-l[display superblock]'
  '-L[set volume label.]'
  '-U[set UUID.]'
  '-V[print version information only.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
