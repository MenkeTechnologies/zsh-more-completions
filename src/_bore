#compdef bore

# Zsh completion for bore - TCP tunnel tool

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'local:start a local proxy to the remote server'
      'server:start the remote proxy server'
      'help:show help for a subcommand'
    )
    _describe -t commands 'bore command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (local)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          {-l,--local-host}'[local host to expose]:host:_hosts' \
          {-p,--port}'[optional port on the remote server]:port:' \
          {-s,--secret}'[optional secret for authentication]:secret:' \
          {-t,--to}'[address of the remote server]:server:_hosts' \
          '1:local port:' \
          && ret=0
        ;;
      (server)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--min-port[minimum accepted TCP port number]:port:' \
          '--secret[optional secret for authentication]:secret:' \
          '1:port:' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
