#compdef vmwgfxctrl
# Documentation: https://man.archlinux.org/search?q=vmwgfxctrl
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--help[out the help screen]'
  '--print-topology[out the currently set topology]'
  '--set-topology[+x+y  (WxH+x+y repeated for each screen)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
