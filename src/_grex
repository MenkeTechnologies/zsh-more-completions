#compdef grex

# Zsh completion for grex (regex generator from test cases)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-d --digits)'{-d,--digits}'[convert digits to \d]' \
  '(-D --non-digits)'{-D,--non-digits}'[convert non-digits to \D]' \
  '(-s --spaces)'{-s,--spaces}'[convert whitespace to \s]' \
  '(-S --non-spaces)'{-S,--non-spaces}'[convert non-whitespace to \S]' \
  '(-w --words)'{-w,--words}'[convert word chars to \w]' \
  '(-W --non-words)'{-W,--non-words}'[convert non-word chars to \W]' \
  '(-r --repetitions)'{-r,--repetitions}'[detect repetitions]' \
  '(-e --escape)'{-e,--escape}'[escape special regex characters]' \
  '--with-surrogates[include surrogates]' \
  '(-i --ignore-case)'{-i,--ignore-case}'[produce case-insensitive regex]' \
  '(-g --capture-groups)'{-g,--capture-groups}'[use capturing groups instead of non-capturing]' \
  '(-x --verbose)'{-x,--verbose}'[produce verbose regex with comments]' \
  '--colorize[colorize output]' \
  '(-f --file)'{-f,--file}'[read test cases from file]:input file:_files' \
  '--min-repetitions[minimum repetitions for quantifier]:count' \
  '--min-substring-length[minimum substring length for extraction]:length' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:test case strings' && ret=0

return ret
