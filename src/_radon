#compdef radon

# Zsh completion for radon (Python code metrics)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'cc:compute Cyclomatic Complexity'
  'raw:compute raw metrics'
  'mi:compute Maintainability Index'
  'hal:compute Halstead metrics'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'radon command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (cc)
        _arguments \
          '(-s --show-complexity)'{-s,--show-complexity}'[show complexity ranking]' \
          '(-a --average)'{-a,--average}'[compute average complexity]' \
          '(-n --min)'{-n,--min}'[minimum complexity to show]:rank:(A B C D E F)' \
          '(-x --max)'{-x,--max}'[maximum complexity to show]:rank:(A B C D E F)' \
          '(-e --exclude)'{-e,--exclude}'[exclude files]:pattern:' \
          '(-i --ignore)'{-i,--ignore}'[ignore directories]:dirs:' \
          '(-j --json)'{-j,--json}'[output as JSON]' \
          '--xml[output as XML]' \
          '--md[output as Markdown]' \
          '--no-assert[exclude assert statements]' \
          '--total-average[show total average]' \
          '--order[sort order]:order:(SCORE LINES ALPHA)' \
          '*:path:_files -g "*.py"' && ret=0
        ;;
      (raw)
        _arguments \
          '(-s --summary)'{-s,--summary}'[show summary]' \
          '(-j --json)'{-j,--json}'[output as JSON]' \
          '(-e --exclude)'{-e,--exclude}'[exclude files]:pattern:' \
          '(-i --ignore)'{-i,--ignore}'[ignore directories]:dirs:' \
          '*:path:_files -g "*.py"' && ret=0
        ;;
      (mi)
        _arguments \
          '(-m --multi)'{-m,--multi}'[count multiline strings as comments]' \
          '(-s --show)'{-s,--show}'[show actual MI value]' \
          '(-j --json)'{-j,--json}'[output as JSON]' \
          '(-e --exclude)'{-e,--exclude}'[exclude files]:pattern:' \
          '(-i --ignore)'{-i,--ignore}'[ignore directories]:dirs:' \
          '--min[min MI grade to display]:grade:(A B C)' \
          '--max[max MI grade to display]:grade:(A B C)' \
          '--sort[sort by MI value]' \
          '*:path:_files -g "*.py"' && ret=0
        ;;
      (hal)
        _arguments \
          '(-j --json)'{-j,--json}'[output as JSON]' \
          '(-e --exclude)'{-e,--exclude}'[exclude files]:pattern:' \
          '(-i --ignore)'{-i,--ignore}'[ignore directories]:dirs:' \
          '-f[show functions]:pattern:' \
          '*:path:_files -g "*.py"' && ret=0
        ;;
    esac
    ;;
esac

return ret
