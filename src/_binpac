#compdef binpac
# Documentation: https://man.archlinux.org/search?q=binpac
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-d[use given directory for compiler output]:directory:_files -/'
  '-D[enable debugging output]'
  '-q[stay quiet]'
  '-h[show command line help]'
  '-I[include directory in input file search path]:directory:_files -/'
  '*:filename:_files'
)

_arguments -s -S $arguments
