#compdef sort gsort

# Zsh completion for sort (GNU coreutils and BSD)

_sort() {
  local -a common_args gnu_only bsd_only

  common_args=(
    # Ordering options
    {-b,--ignore-leading-blanks}'[ignore leading blanks when finding sort keys]'
    {-d,--dictionary-order}'[consider only blanks and alphanumeric characters]'
    {-f,--ignore-case}'[fold lower case to upper case characters]'
    {-g,--general-numeric-sort}'[compare according to general numerical value]'
    {-i,--ignore-nonprinting}'[consider only printable characters]'
    {-M,--month-sort}'[compare month abbreviations: (unknown) < JAN < ... < DEC]'
    {-h,--human-numeric-sort}'[compare human readable numbers (e.g., 2K 1G)]'
    {-n,--numeric-sort}'[compare according to string numerical value]'
    {-R,--random-sort}'[shuffle, but group identical keys]'
    '--random-source=[get random bytes from FILE]:file:_files'
    {-r,--reverse}'[reverse the result of comparisons]'
    '--sort=[sort according to WORD]:word:(general-numeric human-numeric month numeric random version)'
    {-V,--version-sort}'[natural sort of (version) numbers within text]'

    # Other options
    '--batch-size=[merge at most NMERGE inputs at once]:number'
    {-c,--check}'[check for sorted input; do not sort]'
    {-C,--check=quiet,--check=silent}'[like -c, but do not report first bad line]'
    '--compress-program=[compress temporaries with PROG]:program:_command_names -e'
    '--debug[annotate the part of the line used to sort]'
    '--files0-from=[read input from NUL-terminated file names in F]:file:_files'
    '*'{-k,--key=}'[sort via a key; KEYDEF gives location and type]:key definition'
    {-m,--merge}'[merge already sorted files; do not sort]'
    {-o,--output=}'[write result to FILE instead of standard output]:output file:_files'
    '-s[stabilize sort by disabling last-resort comparison]'
    {-S,--buffer-size=}'[use SIZE for main memory buffer]:size'
    {-t,--field-separator=}'[use SEP instead of non-blank to blank transition]:separator'
    {-T,--temporary-directory=}'[use DIR for temporaries, not $TMPDIR or /tmp]:directory:_directories'
    '--parallel=[change the number of concurrent sorts]:number'
    {-u,--unique}'[output only the first of lines with equal keys]'
    {-z,--zero-terminated}'[line delimiter is NUL, not newline]'
    '--help[display help and exit]'
    '--version[output version information and exit]'
    '*:file:_files'
  )

  # GNU-specific: --stable as a long option
  gnu_only=(
    '--stable[stabilize sort by disabling last-resort comparison]'
  )

  # BSD-specific sort algorithm selection options
  bsd_only=(
    '--heapsort[use heapsort algorithm]'
    '--mergesort[use mergesort algorithm]'
    '--radixsort[use radixsort algorithm]'
    '--qsort[use quicksort algorithm]'
    '--mmap[try to use file memory mapping system call]'
  )

  case "$OSTYPE" in
    darwin*|freebsd*|openbsd*|netbsd*)
      _arguments -s -S $common_args $bsd_only
      ;;
    *)
      _arguments -s -S $common_args $gnu_only
      ;;
  esac
}

_sort "$@"
