#compdef gnome-thumbnail-font
# Documentation: https://man.archlinux.org/search?q=gnome-thumbnail-font
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  {-t,--text}'[text to thumbnail (default: Aa)]'
  {-s,--size}'[thumbnail size (default: 128)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
