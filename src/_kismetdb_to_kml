#compdef kismetdb_to_kml
# Documentation: https://man.archlinux.org/search?q=kismetdb_to_kml
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-i,--in}'[input kismetdb file]'
  {-o,--out}'[output KML file]'
  {-f,--force}'[force writing to the target file, even if it exists.]'
  {-v,--verbose}'[verbose output]'
  {-s,--skip-clean}'[dont clean (sql vacuum) input database]'
  {-e,--exclude}'[lon,dist Exclude records within dist *meters* of the lat,lon]'
  '--basic-location[use basic average location information instead of computing a more complex track]'
  '*:filename:_files'
)

_arguments -s -S $arguments
