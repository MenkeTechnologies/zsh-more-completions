#compdef zstreamdump
# Documentation: https://man.archlinux.org/search?q=zstreamdump
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-v,--}'[enable verbose output]'
  {-C,--}'[checksum verification]'
  {-d,--}'[contents of blocks modified, implies verbose]'
  '*:filename:_files'
)

_arguments -s -S $arguments
