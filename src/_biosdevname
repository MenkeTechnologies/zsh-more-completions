#compdef biosdevname

local -a arguments

arguments=(
  {-i,--interface}'[treat args as ethernet devs]'
  {-d,--debug}'[enable debugging]'
  {-p,--policy}'[naming policy]:policy:(physical all_ethN)'
  {-P,--prefix}'[string use for embedded NICs (default=em)]:prefix:'
  {-s,--smbios}'[require SMBIOS x.y or greater]:version:'
  {-x,--nopirq}'[dont use PIR table for slot numbers]'
  {-v,--version}'[show biosdevname version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
