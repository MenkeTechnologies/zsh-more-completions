#compdef lsipc

local arguments

arguments=(
  '(-q -s -Q -S -M)'{-m,--shmems}'[write information about active System V shared memory segments]'
  '(-q -s -Q -S -m)'{-M,--posix-shmems}'[write information about active POSIX shared memory segments]'
  '(-m -s -M -S -Q)'{-q,--queues}'[write information about active System V message queues]'
  '(-m -s -M -S -q)'{-Q,--posix-mqueues}'[write information about active POSIX message queues]'
  '(-m -q -M -Q -S)'{-s,--semaphores}'[write information about active System V semaphore sets]'
  '(-m -q -M -Q -s)'{-S,--posix-semaphores}'[write information about active POSIX named semaphores]'
  {-g,--global}'[show system-wide usage and limits of IPC resources]'
  {-i,--id}'[show full details on a single System V resource identified by id]:id'
  {-N,--name}'[show full details on a single POSIX resource identified by name]:name'
  '--noheadings[do not print a header line]'
  '--notruncate[do not truncate output]'
  '--time-format[display dates in specified format]:format:(short full iso)'
  {-b,--bytes}'[print size in bytes rather than in human readable format]'
  {-c,--creator}'[show creator and owner]'
  {-e,--export}'[produce output in the form of key="value" pairs]'
  {-J,--json}'[use the JSON output format]'
  {-n,--newline}'[display each piece of information on a separate line]'
  {-l,--list}'[use list output format]'
  {-o,--output}'[define the columns to output]:list'
  {-P,--numeric-perms}'[print numeric permissions]'
  {-r,--raw}'[use raw output format]'
  {-t,--time}'[show attach, detach and change times]'
  {-y,--shell}'[use column names that can be used as shell variable identifiers]'
  '(- * :)'{-h,--help}'[display help text and exit]'
  '(- * :)'{-V,--version}'[display version information and exit]'
)

_arguments -s $arguments
