#compdef procs

# Zsh completion for procs (modern ps replacement in Rust)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-a --and)'{-a,--and}'[AND logic for multi-keyword]' \
  '(-o --or)'{-o,--or}'[OR logic for multi-keyword]' \
  '(-d --nand)'{-d,--nand}'[NAND logic for multi-keyword]' \
  '(-r --nor)'{-r,--nor}'[NOR logic for multi-keyword]' \
  '(-l --list)'{-l,--list}'[show list of fields]' \
  '--thread[show thread information]' \
  '(-t --tree)'{-t,--tree}'[tree view]' \
  '(-w --watch)'{-w,--watch}'[watch mode with default interval]' \
  '(-W --watch-interval)'{-W,--watch-interval}'[watch mode with custom interval]:interval (seconds)' \
  '(-i --insert)'{-i,--insert}'[insert column to output]:column' \
  '--only[only show specified columns]:columns' \
  '(-s --sortd)'{-s,--sortd}'[sort column in descending order]:column' \
  '(-S --sorta)'{-S,--sorta}'[sort column in ascending order]:column' \
  '(-c --color)'{-c,--color}'[color mode]:color:(auto always disable)' \
  '--theme[theme]:theme' \
  '(-p --pager)'{-p,--pager}'[pager mode]:pager:(auto always disable)' \
  '--interval[interval for watch mode]:interval (milliseconds)' \
  '--completion[generate shell completion]:shell:(zsh bash fish powershell elvish)' \
  '--config[path to config file]:config file:_files' \
  '--no-header[do not show header]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:keyword' && ret=0

return ret
