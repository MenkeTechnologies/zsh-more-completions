#compdef bdeinfo

local -a arguments

arguments=(
  '-h[show this help]'
  '-k[the full volume encryption key and tweak key]:key:'
  '-o[specify the volume offset in bytes]:offset:'
  '-p[specify the password/passphrase]:password:'
  '-r[specify the recovery password]:recovery password:'
  '-s[specify the file containing the startup key]:key file:_files'
  '-v[verbose output to stderr]'
  '-V[print version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
