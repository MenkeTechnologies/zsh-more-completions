#compdef py3rsa-decrypt


local -a arguments

arguments=(
    {-h,--help}'[show help message and exit.]'
    {-i,--input}'[name of the file to decrypt. read from stdin if not specified.]'
    {-o,--output}'[name of the file to write the decrypted file to.]'
    '--keyform[key format of the private key - default PEM]:KEYFORM'
    '*:filename:_files'
)
_arguments -s -S $arguments
