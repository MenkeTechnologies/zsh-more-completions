#compdef abrt-action-save-package-data
# Documentation: https://man.archlinux.org/search?q=abrt-action-save-package-data
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-v,--verbose}'[be verbose]'
  '-d[problem directory]'
  '-c[configuration file]'
  '*:filename:_files'
)

_arguments -s -S $arguments
