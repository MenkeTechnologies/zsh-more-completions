#compdef helmfile

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  {-f,--file}'=[helmfile path]:file:_files' \
  {-e,--environment}'=[environment]:environment' \
  {-l,--selector}'=[label selector]:selector' \
  '*--state-values-set=[set state values]:key=value' \
  {-i,--interactive}'[interactive mode]' \
  {-n,--namespace}'=[namespace]:namespace' \
  '--color[force color output]' \
  '--no-color[disable color output]' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '--allow-no-matching-release[allow no matching release]' \
  '--debug[enable debug output]' \
  {-q,--quiet}'[quiet mode]' \
  '--kube-context=[Kubernetes context]:context' \
  '--concurrency=[max parallel operations]:concurrency' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'apply:apply changes'
      'sync:sync releases'
      'diff:show diff'
      'template:template releases'
      'lint:lint charts'
      'repos:sync chart repos'
      'deps:update chart dependencies'
      'status:show release status'
      'destroy:destroy releases'
      'test:test releases'
      'build:build state'
      'list:list releases'
      'fetch:fetch charts'
      'write-values:write values files'
      'state:manage state'
    )
    _describe -t commands 'helmfile command' commands && ret=0
    ;;
  args)
    case $words[1] in
      apply|sync|diff|template|lint|destroy|test)
        _arguments -s -S \
          '--set=[set values]:key=value' \
          '*--values=[values file]:values:_files' \
          '--args=[pass args to helm]:args' \
          '--skip-deps[skip chart deps]' \
          '--skip-crds[skip CRDs]' \
          '--include-crds[include CRDs]' \
          '--skip-needs[skip needs]' \
          '--include-needs[include needs]' \
          && ret=0
        ;;
      status|list|build)
        _arguments -s -S \
          '--output=[output format]:format:(json)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
