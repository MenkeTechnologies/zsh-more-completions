#compdef ibclearerrors
# Documentation: https://man.archlinux.org/search?q=ibclearerrors
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    {-N,--nocolor}'[disable color output]'
    '-C[use specified CA]:ca name'
    '-P[use specified port]:port number'
    '-t[set timeout in milliseconds]:timeout'
    '*:filename:_files'
)
_arguments -s -S $arguments
