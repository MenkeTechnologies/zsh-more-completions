#compdef smbdiagnose
# Documentation: https://man.archlinux.org/search?q=smbdiagnose
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[show help]'
  '-f[output directory (default is ~/Desktop)]:directory:_directories'
  '-s[collect sysdiagnose. Default is not to collect sysdiagnose]'
  '*:filename:_files'
)

_arguments -s -S $arguments
