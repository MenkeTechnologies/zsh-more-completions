#compdef ccze

local -a arguments

arguments=(
    {-a,--argument}'[add arguments to plugin]:args:'
    {-A,--raw-ansi}'[Generate raw ANSI output]'
    {-c,--color}'[set the color of KEY to COLOR]:key=color:'
    {-C,--convert-date}'[Convert UNIX timestamps to readable format]'
    {-F,--rcfile}'[read configuration from FILE]:file:_files'
    {-h,--html}'[Generate HTML output]'
    {-l,--list-plugins}'[List available plugins]'
    {-m,--mode}'[change the output mode]:mode:'
    {-o,--options}'[toggle some options]:options:'
    {-p,--plugin}'[load plugin]:plugin:'
    {-r,--remove-facility}'[remove syslog-ng facility from start of lines]'
    '--usage[Give a short usage message]'
    {-V,--version}'[Print program version]'
    '*:filename:_files'
)

_arguments -s -S $arguments
