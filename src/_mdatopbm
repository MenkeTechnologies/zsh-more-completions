#compdef mdatopbm
# Documentation: https://man.archlinux.org/search?q=mdatopbm
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-a[Output an ASCII pbm file]'
  '-d[Double height (to compensate for the PCW aspect ratio)]'
  '-i[Invert colours]'
  '*:filename:_files'
)

_arguments -s -S $arguments
