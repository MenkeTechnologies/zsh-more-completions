#compdef mpeg2enc

local -a arguments

arguments=(
  {-v,--verbose}'[verbosity level]:num: '
  {-f,--format}'[output format]:fmt: '
  {-x,--display-hsize}'[display horizontal size]:pixels: '
  {-y,--display-vsize}'[display vertical size]:pixels: '
  {-a,--aspect}'[aspect ratio code]:num: '
  {-F,--frame-rate}'[frame rate code]:num: '
  {-b,--video-bitrate}'[video bitrate in kbps]:num: '
  {-t,--target-video-bitrate}'[target video bitrate]'
  {-B,--nonvideo-bitrate}'[non-video bitrate in kbps]:num: '
  {-q,--quantisation}'[quantisation level]:num: '
  {-A,--ratecontroller}'[rate controller (0 or 1)]:num: '
  {-o,--output}'[output file path]:pathname:_files'
  {-T,--target-still-size}'[target still size in KB]:size: '
  {-I,--interlace-mode}'[interlace mode]:num: '
  {-r,--motion-search-radius}'[motion search radius]:num: '
  '-4[reduction factor for 4x4 subsampled motion compensation]:num: '
  '-2[reduction factor for 2x2 subsampled motion compensation]:num: '
  {-g,--min-gop-size}'[minimum GOP size]:num: '
  {-G,--max-gop-size}'[maximum GOP size]:num: '
  {-c,--closed-gop}'[closed GOP]'
  {-P,--force-b-b-p}'[force B-B-P frame pattern]'
  {-Q,--quantisation-reduction}'[quantisation reduction]:num: '
  {-X,--quant-reduction-max-var}'[quantisation reduction max variance]:num: '
  {-V,--video-buffer}'[video buffer size in KB]:num: '
  {-n,--video-norm}'[video norm]:norm:(n p s)'
  {-S,--sequence-length}'[sequence length in MB]:num: '
  {-p,--3-2-pulldown}'[enable 3-2 pulldown]'
  {-D,--intra_dc_prec}'[intra DC precision (8-11)]:precision: '
  {-N,--reduce-hf}'[reduce high frequency]:num: '
  {-H,--keep-hf}'[keep high frequency]'
  {-s,--sequence-header-every-gop}'[sequence header every GOP]'
  {-d,--no-dummy-svcd-SOF}'[no dummy SVCD SOF]'
  {-z,--playback-field-order}'[playback field order]:order:(b t)'
  {-M,--multi-thread}'[number of threads]:num: '
  {-C,--correct-svcd-hds}'[correct SVCD HDS]'
  '--no-constraints[deactivate constraints for maximum video resolution and sample rate]'
  '--no-altscan-mpeg2[deactivate use of alternate block pattern for MPEG-2]'
  '--dualprime-mpeg2[turn on use of dual-prime motion compensation]'
  {-K,--custom-quant-matrices}'[custom quantisation matrices]:type:(kvcd tmpgenc default hi-res help)'
  {-E,--unit-coeff-elim}'[unit coefficient elimination]:num: '
  {-R,--b-per-refframe}'[B frames per reference frame]:num:(0 1 2)'
  {-u,--cbr}'[constant bitrate]'
  '--chapters[chapter markers]:chapters: '
  '(- * :)--help[display help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
