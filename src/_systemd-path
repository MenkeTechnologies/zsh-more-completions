#compdef systemd-path
# Documentation: https://man.archlinux.org/search?q=systemd-path
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help]'
  '--version[show package version]'
  '--suffix[suffix to append to paths]'
  '*:filename:_files'
)

_arguments -s -S $arguments
