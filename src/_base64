#compdef base64 gbase64

# Completion for base64 (BSD and GNU coreutils)

local arguments

if _pick_variant gnu='Free Soft' unix --version 2>/dev/null; then
  # GNU coreutils base64
  arguments=(
    '(- *)'{-d,--decode}'[decode data]'
    {-i,--ignore-garbage}'[when decoding, ignore non-alphabet characters]'
    {-w+,--wrap=}'[wrap encoded lines after COLS characters (default 76, 0 to disable)]:columns'
    '(- *)--help[display help and exit]'
    '(- *)--version[output version information and exit]'
    '*:file:_files'
  )
else
  # BSD base64 (macOS)
  arguments=(
    '(- *)'{-h,--help}'[display help message]'
    {-D,-d,--decode}'[decode input]'
    {-b+,--break=}'[break encoded string into num character lines]:line length'
    {-i+,--input=}'[input file (default stdin)]:input file:_files'
    {-o+,--output=}'[output file (default stdout)]:output file:_files'
    '*:file:_files'
  )
fi

_arguments -s -S $arguments
