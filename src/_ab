#compdef ab

# Zsh completion for ab (Apache HTTP server benchmarking tool)

_ab() {
    local -a arguments

    arguments=(
        '-A[add Basic WWW Authentication (colon-separated user:password)]:auth-username\:password:'
        '-b[size of TCP send/receive buffer, in bytes]:windowsize:'
        '-B[address to bind to when making outgoing connections]:local-address:'
        '-c[number of multiple requests to make at a time]:concurrency:'
        '*-C[add cookie (repeatable, e.g. name=value)]:cookie-name=value:'
        '-d[do not show percentiles served table]'
        '-e[output CSV file with percentages served]:csv file:_files'
        '-E[specify client certificate chain and private key (PEM)]:certfile:_files'
        '-f[specify SSL/TLS protocol]:protocol:(SSL2 SSL3 TLS1 TLS1.1 TLS1.2 TLS1.3 ALL)'
        '-g[output collected data to gnuplot format file]:gnuplot file:_files'
        '-h[display usage information]'
        '*-H[add arbitrary header line (repeatable)]:custom-header:'
        '-i[use HEAD instead of GET]'
        '-I[disable TLS Server Name Indication (SNI) extension]'
        '-k[use HTTP KeepAlive feature]'
        '-l[accept variable document length (use for dynamic pages)]'
        '-m[custom HTTP method for the requests]:method:(GET HEAD POST PUT DELETE PATCH OPTIONS TRACE CONNECT)'
        '-n[number of requests to perform]:requests:'
        '-p[file containing data to POST (remember to set -T)]:POST file:_files'
        '-P[add Basic Proxy Authentication (colon-separated user:password)]:proxy-auth-username\:password:'
        '-q[do not show progress when doing more than 150 requests]'
        '-r[do not exit on socket receive errors]'
        '-s[seconds to max wait for each response (default 30)]:timeout:'
        '-S[do not show confidence estimators and warnings]'
        '-t[seconds to max to spend on benchmarking (implies -n 50000)]:timelimit:'
        '-T[content-type header for POST/PUT data]:content-type:(application/x-www-form-urlencoded text/plain application/json multipart/form-data application/xml text/html)'
        '-u[file containing data to PUT (remember to set -T)]:PUT file:_files'
        '-v[verbosity level for troubleshooting info]:verbosity:'
        '-V[print version number and exit]'
        '-w[print out results in HTML tables]'
        '-x[string to insert as table attributes]:table-attributes:'
        '-X[proxy server and port number to use]:proxy\:port:'
        '-y[string to insert as tr attributes]:tr-attributes:'
        '-z[string to insert as td or th attributes]:td-attributes:'
        '-Z[specify SSL/TLS cipher suite (see openssl ciphers)]:ciphersuite:'
        ':URL:_urls'
    )

    _arguments -s $arguments
}

_ab "$@"
