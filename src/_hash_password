#compdef hash_password

local -a arguments

arguments=(
  {-e,--environment-var}'[use value of the specified environment variable]:variable:'
  '(- * :)'{-h,--help}'[display this help message]'
  {-i,--input}'[input is a file (or - for stdin) to read the password from]:file:_files'
  {-p,--plain}'[argument is the plain text password]'
  {-r,--logrounds}'[number of hash rounds (default: 10).]'
  '*:filename:_files'
)

_arguments -s -S $arguments
