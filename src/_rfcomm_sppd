#compdef rfcomm_sppd
# Documentation: https://man.archlinux.org/search?q=rfcomm_sppd
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-a[peer address (required in client mode)]'
  '-b[run in background]'
  '-c[RFCOMM channel to connect to or listen on]'
  '-t[use slave pseudo tty (required in background mode)]'
  '-S[server mode]'
  '-h[display this message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
