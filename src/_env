#compdef env

local -a arguments

arguments=(
  {-i,--ignore-environment}'[start with an empty environment]'
  '(-0 --null)'{-0,--null}'[end each output line with NUL, not newline]'
  '*'{-u+,--unset=}'[remove variable from the environment]:variable:_parameters -g "*export*"'
  {-C+,--chdir=}'[change working directory to DIR]:directory:_directories'
  {-P+,--altpath=}'[search specified directories to locate the utility]:alternate path:_dir_list'
  '-S+[split string into separate arguments]:string'
  {-v,--verbose}'[print verbose information for each step of processing]'
  '(- *)--help[display help and exit]'
  '(- *)--version[output version information and exit]'
  '*::command: _command_names -e'
)

_arguments -s -S $arguments
