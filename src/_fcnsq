#compdef fcnsq
# Documentation: https://man.archlinux.org/search?q=fcnsq
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--gpn[<port id>]'
  '--gnn[<port id>]'
  '--gspn[id>]'
  '--gsnn[wide node name>]'
  '--quiet[|-q print minimal results on success, and no error messages]'
  '*:filename:_files'
)

_arguments -s -S $arguments
