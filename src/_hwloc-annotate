#compdef hwloc-annotate
# Documentation: https://man.archlinux.org/search?q=hwloc-annotate
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--ci[clear existing infos]'
  '--ri[replace or remove existing infos with same name (annotation must be info)]'
  '--cu[clear existing userdata]'
  '*:filename:_files'
)

_arguments -s -S $arguments
