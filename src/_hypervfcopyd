#compdef hypervfcopyd
# Documentation: https://man.archlinux.org/search?q=hypervfcopyd
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-n,--no-daemon}'[stay in foreground, dont daemonize]'
  '(- * :)'{-h,--help}'[print this help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
