#compdef timetrap

# Zsh completion for timetrap - simple time tracking (Ruby)

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'archive:archive entries'
      'backend:show backend info'
      'configure:edit configuration'
      'display:display entries'
      'd:display entries'
      'edit:edit an entry'
      'in:start an entry'
      'start:start an entry'
      'kill:delete a timesheet'
      'list:list timesheets'
      'l:list timesheets'
      'now:show current entry'
      'out:stop current entry'
      'stop:stop current entry'
      'resume:resume last entry'
      'sheet:switch to a timesheet'
      's:switch to a timesheet'
      'switch:switch to a timesheet'
      'today:display today entries'
      'yesterday:display yesterday entries'
      'week:display this week entries'
      'month:display this month entries'
    )
    _describe -t commands 'timetrap command' commands && ret=0
    ;;
  args)
    case ${line[1]} in
      in|start)
        _arguments -s \
          '--at[set start time]:time' \
          '*:note' && ret=0
        ;;
      out|stop)
        _arguments -s \
          '--at[set stop time]:time' && ret=0
        ;;
      display|d)
        _arguments -s \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '(-s --start)'{-s,--start}'[start date]:date' \
          '(-e --end)'{-e,--end}'[end date]:date' \
          '(-f --format)'{-f,--format}'[output format]:format:(text csv ical factor json ids)' \
          '(-g --grep)'{-g,--grep}'[filter by pattern]:pattern' \
          '--ids[show entry ids]' && ret=0
        ;;
      edit)
        _arguments -s \
          '--id[entry id]:id' \
          '--start[set start time]:time' \
          '--end[set end time]:time' \
          '--append[append to note]:note' \
          '--move[move to sheet]:sheet' && ret=0
        ;;
      kill)
        _arguments -s \
          '--id[entry id]:id' && ret=0
        ;;
      sheet|s|switch)
        _arguments ':sheet name' && ret=0
        ;;
      list|l)
        _arguments -s \
          '(-s --simple)'{-s,--simple}'[simple output]' && ret=0
        ;;
      archive)
        _arguments -s \
          '(-s --start)'{-s,--start}'[start date]:date' \
          '(-e --end)'{-e,--end}'[end date]:date' \
          '--grep[filter by pattern]:pattern' && ret=0
        ;;
    esac
    ;;
esac

return ret
