#compdef psql

# Zsh completion for psql - PostgreSQL interactive terminal

local ret=1

# Helper function to list PostgreSQL databases
(( $+functions[_psql_databases] )) || _psql_databases() {
  local -a dbs
  dbs=( ${(f)"$(psql -AtXq -c 'SELECT datname FROM pg_database WHERE datallowconn ORDER BY datname' template1 2>/dev/null)"} )
  if (( $#dbs )); then
    _describe -t databases 'database' dbs
  else
    _message -e databases 'database name'
  fi
}

# Helper function to list PostgreSQL users
(( $+functions[_psql_users] )) || _psql_users() {
  local -a users
  users=( ${(f)"$(psql -AtXq -c 'SELECT usename FROM pg_user ORDER BY usename' template1 2>/dev/null)"} )
  if (( $#users )); then
    _describe -t users 'database user' users
  else
    _users
  fi
}

_arguments -s -S \
  '(- *)'{-\?,--help}'=-[show help, then exit]::topic:(options commands variables)' \
  + '(general)' \
    {-c+,--command=}'[run only single command (SQL or internal) and exit]:command string' \
    {-d+,--dbname=}'[database name to connect to]:database:_psql_databases' \
    {-f+,--file=}'[execute commands from file, then exit]:file:_files' \
    {-l,--list}'[list available databases, then exit]' \
    {-v+,--set=,--variable=}'[set psql variable NAME to VALUE]:variable assignment (NAME=VALUE)' \
    '(- *)'{-V,--version}'[output version information, then exit]' \
    {-X,--no-psqlrc}'[do not read startup file (~/.psqlrc)]' \
    {-1,--single-transaction}'[execute as a single transaction (if non-interactive)]' \
  + '(input-output)' \
    {-a,--echo-all}'[echo all input from script]' \
    {-b,--echo-errors}'[echo failed commands]' \
    {-e,--echo-queries}'[echo commands sent to server]' \
    {-E,--echo-hidden}'[display queries that internal commands generate]' \
    {-L+,--log-file=}'[send session log to file]:log file:_files' \
    {-n,--no-readline}'[disable enhanced command line editing (readline)]' \
    {-o+,--output=}'[send query results to file (or |pipe)]:output:_files' \
    {-q,--quiet}'[run quietly (no messages, only query output)]' \
    {-s,--single-step}'[single-step mode (confirm each query)]' \
    {-S,--single-line}'[single-line mode (end of line terminates SQL command)]' \
  + '(output-format)' \
    {-A,--no-align}'[unaligned table output mode]' \
    '--csv[CSV (Comma-Separated Values) table output mode]' \
    {-F+,--field-separator=}'[field separator for unaligned output]:separator ["|"]' \
    {-H,--html}'[HTML table output mode]' \
    {-P+,--pset=}'[set printing option VAR to ARG]:VAR=ARG' \
    {-R+,--record-separator=}'[record separator for unaligned output]:separator' \
    {-t,--tuples-only}'[print rows only]' \
    {-T+,--table-attr=}'[set HTML table tag attributes]:attributes (e.g. width, border)' \
    {-x,--expanded}'[turn on expanded table output]' \
    {-z,--field-separator-zero}'[set field separator for unaligned output to zero byte]' \
    {-0,--record-separator-zero}'[set record separator for unaligned output to zero byte]' \
  + '(connection)' \
    {-h+,--host=}'[database server host or socket directory]:hostname:_hosts' \
    {-p+,--port=}'[database server port]:port [5432]' \
    {-U+,--username=}'[database user name]:username:_psql_users' \
    {-w,--no-password}'[never prompt for password]' \
    {-W,--password}'[force password prompt]' \
  + '(operands)' \
    '1:database:_psql_databases' \
    '2:username:_psql_users' \
  && ret=0

return ret
