#compdef quicktype

# Zsh completion for quicktype (generate types from JSON/schema)

_arguments -s -S \
  '(-o --out)'{-o,--out}'[output filename]:file:_files' \
  '(-t --top-level)'{-t,--top-level}'[name for the top level type]:name:' \
  '(-l --lang)'{-l,--lang}'[target language]:language:(ruby javascript flow typescript kotlin elm swift rust dart python cs go java scala json-schema pike haskell cpp crystal)' \
  '(-s --src-lang)'{-s,--src-lang}'[source language]:source:(json schema graphql postman typescript)' \
  '--src[source file or URL]:source:_files' \
  '--src-urls[source URLs file]:file:_files' \
  '--no-maps[use objects/classes instead of maps]' \
  '--no-enums[do not infer enums]' \
  '--no-uuids[do not detect UUID strings]' \
  '--no-date-times[do not detect date-time strings]' \
  '--no-integer-strings[do not detect integer strings]' \
  '--no-boolean-strings[do not detect boolean strings]' \
  '--no-combine-classes[do not combine similar classes]' \
  '--no-ignore-json-refs[treat $ref as a reference]' \
  '--graphql-schema[GraphQL schema file]:file:_files' \
  '--graphql-introspect[GraphQL endpoint URL]:url:_urls' \
  '--http-method[HTTP method for fetching]:method:(GET POST)' \
  '--http-header[HTTP header]:header:' \
  '--alphabetize-properties[alphabetize properties]' \
  '--all-properties-optional[make all properties optional]' \
  '--quiet[suppress output]' \
  '--debug[debug output]:debug:(print-graph print-reconstitution print-gather-names print-transformations print-schema-resolving print-times)' \
  '--telemetry[enable telemetry]:value:(enable disable)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:input:_files' && return 0
