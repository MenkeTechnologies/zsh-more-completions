#compdef osinfo-query
# Documentation: https://man.archlinux.org/search?q=osinfo-query
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  {-s,--sort}'[sort column]'
  {-f,--fields}'[display fields]'
  '*:filename:_files'
)

_arguments -s -S $arguments
