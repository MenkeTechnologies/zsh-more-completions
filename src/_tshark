#compdef tshark

# Zsh completion for tshark (Wireshark network protocol analyzer - terminal version)

_tshark_interfaces() {
  local -a interfaces
  interfaces=(${(f)"$(tshark -D 2>/dev/null | sed 's/^[0-9]*\. //')"})
  _describe -t interfaces 'capture interface' interfaces
}

_tshark_link_types() {
  local -a ltypes
  ltypes=(${(f)"$(tshark -L 2>/dev/null | sed -n 's/^  \([A-Z0-9_]*\) (\(.*\))/\1:\2/p')"})
  _describe -t link-types 'link-layer type' ltypes
}

_tshark_file_types() {
  local -a ftypes
  ftypes=(${(f)"$(tshark -F 2>/dev/null | sed -n 's/^  \([a-z0-9_]*\) - \(.*\)/\1:\2/p')"})
  if (( ${#ftypes} == 0 )); then
    ftypes=(
      'pcap:Wireshark/tcpdump/... - pcap'
      'pcapng:Wireshark/... - pcapng'
      'k12text:K12 text file'
      'netmon1:Microsoft NetMon 1.x'
      'netmon2:Microsoft NetMon 2.x'
      'ngsniffer:Sniffer (DOS)'
      'ngwsniffer_1_1:NetXray, Sniffer (Windows) 1.1'
      'ngwsniffer_2_0:Sniffer (Windows) 2.00x'
      'niobserver:Network Instruments Observer'
      'nokiapcap:Nokia tcpdump - pcap'
      'nsecpcap:Wireshark - nanosecond libpcap'
      'rf5:Tektronix K12xx 32-bit .rf5 format'
      'visuals:Visual Networks traffic capture'
    )
  fi
  _describe -t file-types 'output file type' ftypes
}

_tshark_time_formats() {
  local -a formats
  formats=(
    'a:absolute (local time)'
    'ad:absolute with date (local time)'
    'adoy:absolute with date using day of year'
    'd:delta (since previous packet)'
    'dd:delta displayed (since previous displayed packet)'
    'e:epoch (seconds since 1970-01-01)'
    'r:relative (to first packet)'
    'u:absolute (UTC)'
    'ud:absolute with date (UTC)'
    'udoy:absolute with date using day of year (UTC)'
  )
  _describe -t time-formats 'timestamp format' formats
}

_tshark_output_formats() {
  local -a formats
  formats=(
    'text:plain text (default)'
    'fields:specified fields (-e)'
    'json:JSON format'
    'jsonraw:JSON raw format'
    'ek:Elasticsearch bulk format'
    'pdml:PDML XML format'
    'ps:PostScript format'
    'psml:PSML XML format'
    'tabs:tab-separated values'
  )
  _describe -t output-formats 'output format' formats
}

_tshark_seconds_formats() {
  local -a formats
  formats=(
    's:seconds (default)'
    'hms:hours\:minutes\:seconds'
  )
  _describe -t seconds-formats 'seconds format' formats
}

_arguments -s -S \
