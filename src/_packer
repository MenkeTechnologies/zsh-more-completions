#compdef packer

# Zsh completion for HashiCorp Packer

local curcontext="$curcontext" state line ret=1

local -a packer_commands
packer_commands=(
  'build:build image(s) from template'
  'console:creates a console for testing variable interpolation'
  'fix:fixes templates from old versions of Packer'
  'fmt:rewrites HCL2 config files to canonical format'
  'hcl2_upgrade:transform a JSON template into an HCL2 configuration'
  'init:install missing plugins or upgrade plugins'
  'inspect:see components of a template'
  'plugins:interact with Packer plugins and catalog'
  'validate:check that a template is valid'
  'version:prints the Packer version'
)

_arguments -s -S \
  '-autocomplete-install[install shell autocompletion]' \
  '-autocomplete-uninstall[uninstall shell autocompletion]' \
  '-help[show help]' \
  '-h[show help]' \
  '-version[show version]' \
  '-v[show version]' \
  '1:command:_describe -t commands command packer_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      build)
        _arguments -s -S \
          '-color=[disable color output]:bool:(true false)' \
          '-debug[debug mode enabled for builds]' \
          '-except=[run all builds except these]:builder name:' \
          '-force[force a build to continue if artifacts exist]' \
          '-machine-readable[produce machine-readable output]' \
          '-on-error=[if the build fails, take this action]:action:(abort ask cleanup run-cleanup-provisioner)' \
          '-only=[build only the specified builds]:builder name:' \
          '-parallel-builds=[limit the number of builds to run in parallel]:number:' \
          '-timestamp-ui[prefix output with RFC3339 timestamp]' \
          '-var=[set a variable in the Packer template]:key=value:' \
          '-var-file=[JSON or HCL2 file with user variables]:var file:_files -g "*.{json,hcl,pkrvars.hcl,auto.pkrvars.hcl}"' \
          '-warn-on-undeclared-var[display a warning for undeclared variables]' \
          '1:template:_files -g "*.{json,pkr.hcl}"' && ret=0
        ;;
      validate)
        _arguments -s -S \
          '-evaluate-datasources[evaluate data sources during validation]' \
          '-except=[validate all builds except these]:builder name:' \
          '-machine-readable[produce machine-readable output]' \
          '-no-warn-undeclared-var[suppress warnings about undeclared variables]' \
          '-only=[validate only the specified builds]:builder name:' \
          '-syntax-only[only check syntax]' \
          '-var=[set a variable in the Packer template]:key=value:' \
          '-var-file=[JSON or HCL2 file with user variables]:var file:_files -g "*.{json,hcl,pkrvars.hcl,auto.pkrvars.hcl}"' \
          '1:template:_files -g "*.{json,pkr.hcl}"' && ret=0
        ;;
      inspect)
        _arguments -s -S \
          '-machine-readable[produce machine-readable output]' \
          '1:template:_files -g "*.{json,pkr.hcl}"' && ret=0
        ;;
      console)
        _arguments -s -S \
          '-var=[set a variable in the Packer template]:key=value:' \
          '-var-file=[JSON or HCL2 file with user variables]:var file:_files -g "*.{json,hcl,pkrvars.hcl,auto.pkrvars.hcl}"' \
          '1:template:_files -g "*.{json,pkr.hcl}"' && ret=0
        ;;
      fix)
        _arguments -s -S \
          '-validate[if true, the fixed template will be validated]:bool:(true false)' \
          '1:template:_files -g "*.json"' && ret=0
        ;;
      fmt)
        _arguments -s -S \
          '-check[check if input is formatted]' \
          '-diff[display diff of formatting changes]' \
          '-recursive[process files in subdirectories]' \
          '-write=[write result to source file]:bool:(true false)' \
          '1:path:_files -g "*.{pkr.hcl,pkrvars.hcl}"' && ret=0
        ;;
      hcl2_upgrade)
        _arguments -s -S \
          '-output-file=[set output file name]:output file:_files' \
          '-with-annotations[add annotation comments to the output]' \
          '1:template:_files -g "*.json"' && ret=0
        ;;
      init)
        _arguments -s -S \
          '-upgrade[upgrade already-installed plugins to latest]' \
          '-force[force installation even if already installed]' \
          '1:config directory:_files -/' && ret=0
        ;;
      plugins)
        local -a plugins_commands
        plugins_commands=(
          'install:install the latest version of a plugin'
          'installed:list all installed Packer plugins'
          'remove:remove an installed Packer plugin'
          'required:list plugins required by a template'
        )
        _arguments -s -S \
          '1:plugins command:_describe -t commands command plugins_commands' \
          '*::plugins args:->plugins_args' && ret=0
        case "$state" in
          plugins_args)
            case "${line[1]}" in
              install)
                _arguments -s -S \
                  '-force[force reinstallation]' \
                  '-path=[install from a local binary]:binary:_files' \
                  '1:plugin source:' && ret=0
                ;;
              remove)
                _arguments -s -S \
                  '1:plugin name:' && ret=0
                ;;
              required)
                _arguments -s -S \
                  '1:template:_files -g "*.{json,pkr.hcl}"' && ret=0
                ;;
              installed)
                ret=0
                ;;
              *)
                _default && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
