#compdef mcphub

# Zsh completion for mcphub (MCP server registry and hub)

local -a commands
commands=(
  'list:List available MCP servers'
  'install:Install an MCP server'
  'update:Update installed servers'
  'search:Search the hub'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[Print help message]' \
  '1: :_describe -t commands "command" commands' \
  '*:: :->args'
