#compdef kitty

# Zsh completion for kitty (GPU-accelerated terminal emulator)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--class=[set the class part of the WM_CLASS window property]:class:' \
  '--name=[set the name part of the WM_CLASS window property]:name:' \
  '--title=[set the OS window title]:title:' \
  '-T=[set the OS window title]:title:' \
  '--config=[specify a path to the configuration file]:config file:_files' \
  '-c=[specify a path to the configuration file]:config file:_files' \
  '--override=[override individual configuration options]:option=value:' \
  '-o=[override individual configuration options]:option=value:' \
  '--directory=[set the working directory for the kitty process]:directory:_directories' \
  '-d=[set the working directory for the kitty process]:directory:_directories' \
  '--detach[detach from the controlling terminal]' \
  '--session=[path to a file containing the startup session]:session file:_files' \
  '--hold[remain open after child process exits]' \
  '--single-instance[if specified only a single instance of kitty will run]' \
  '-1[if specified only a single instance of kitty will run]' \
  '--instance-group=[used in combination with single-instance]:group name:' \
  '--wait-for-single-instance-window-close[wait for single instance window to close]' \
  '--listen-on=[listen on a socket for control messages]:socket address:' \
  '--start-as=[set the initial window state]:state:(normal fullscreen maximized minimized)' \
  '--watcher=[path to a Python file for custom event handling]:watcher:_files' \
  '-w=[path to a Python file for custom event handling]:watcher:_files' \
  '--version[show version]' \
  '-v[show version]' \
  '--dump-theme[dump the default theme]' \
  '--debug-gl[debug OpenGL]' \
  '--debug-keyboard[print out key events as they are received]' \
  '--debug-rendering[print out rendering commands]' \
  '--debug-font-fallback[print debug information for font fallback selection]' \
  '--help[show help]' \
  '-h[show help]' \
  '1:kitten or command:->subcmd' \
  '*::args:->args' && ret=0

case "$state" in
  subcmd)
    local -a kittens
    kittens=(
      '+kitten:run a kitten'
      '+list-fonts:list available fonts'
      '+runpy:run a Python script'
      '+launch:launch a program in a new kitty window'
      '+edit-config:edit the kitty configuration file'
      '+open:open a URL'
      '+complete:output shell completion code'
      '@ls:list all windows'
      '@send-text:send arbitrary text to specified windows'
      '@set-colors:set terminal colors'
      '@close-window:close the specified windows'
      '@close-tab:close the specified tabs'
      '@new-window:open a new window'
      '@focus-window:focus the specified window'
      '@focus-tab:focus the specified tab'
      '@launch:run an arbitrary process in a new window/tab'
      '@set-tab-title:set the tab title'
      '@set-window-title:set the window title'
      '@get-text:get text from the specified window'
      '@set-font-size:set the font size'
      '@resize-window:resize the specified window'
      '@resize-os-window:resize the OS window'
      '@scroll-window:scroll the specified window'
      '@signal-child:send a signal to the child process'
      '@set-window-logo:set the window logo'
      '@action:run a kitty action'
      '@env:change environment variables in running kitty'
      '@select-window:select a window visually'
      '@detach-window:detach a window'
      '@detach-tab:detach a tab'
      '@set-background-opacity:set background opacity'
      '@create-marker:create a marker'
      '@remove-marker:remove a marker'
      '@goto-layout:switch to the specified layout'
      '@kitten:run a kitten'
      '@disable-ligatures:control ligature rendering'
      '@set-spacing:set window padding and margins'
    )
    _describe -t commands 'kitty command' kittens && ret=0
    ;;
  args)
    case "${line[1]}" in
      +kitten)
        local -a kitten_names
        kitten_names=(
          'icat:display images in the terminal'
          'diff:a fast side-by-side diff tool'
          'clipboard:copy/paste to the clipboard'
          'unicode_input:input unicode characters'
          'hints:select and act on text matching a regex'
          'themes:change the kitty color theme'
          'ssh:SSH with kitty features'
          'transfer:transfer files'
          'ask:ask the user for input'
          'broadcast:broadcast input to all windows'
          'show_key:show pressed key details'
          'panel:draw a GPU accelerated panel on your desktop'
          'query_terminal:query the terminal for information'
          'show_error:show an error message'
          'resize_window:resize the active window'
          'hyperlinked_grep:search with clickable results'
        )
        _describe -t kittens 'kitten' kitten_names && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
