#compdef sips

local -a arguments

arguments=(
  {-g,--getProperty}'[get value of property from image]:property:'
  {-X,--extractTag}'[extract tag from image]:tagFile:'
  {-v,--verify}'[verify the image]'
  {-x,--extractProfile}'[extract ICC profile from image]'
  {-s,--setProperty}'[set property to value]:property value:'
  {-d,--deleteProperty}'[delete property from image]:property:'
  '--deleteTag[delete tag from image]:tag:'
  '--copyTag[copy tag to destination tag]:srcTag dstTag:'
  '--loadTag[load tag from file]:tagFile:'
  '--repair[repair the image]'
  {-e,--embedProfile}'[embed ICC profile in image]:profile:'
  {-E,--embedProfileIfNone}'[embed ICC profile only if none exists]:profile:'
  {-m,--matchTo}'[match image to ICC profile]:profile:'
  {-M,--matchToWithIntent}'[match image to ICC profile with rendering intent]:profile intent:'
  '--deleteColorManagementProperties[delete color management properties]'
  {-r,--rotate}'[rotate image by degrees]:degrees:'
  {-f,--flip}'[flip image]:orientation:(horizontal vertical)'
  {-c,--cropToHeightWidth}'[crop image to height and width]:pixelsH pixelsW:'
  {-p,--padToHeightWidth}'[pad image to height and width]:pixelsH pixelsW:'
  '--padColor[set pad color]:color:'
  {-z,--resampleHeightWidth}'[resample image to height and width]:pixelsH pixelsW:'
  '--resampleWidth[resample image to width]:pixelsW:'
  '--resampleHeight[resample image to height]:pixelsH:'
  {-Z,--resampleHeightWidthMax}'[resample image so height and width are not greater than value]:pixelsWH:'
  {-i,--addIcon}'[add icon to image]'
  {-o,--optimizeColorForSharing}'[optimize color for sharing]'
  '*:filename:_files'
)

_arguments -s -S $arguments
