#compdef jiv
# Documentation: https://man.archlinux.org/search?q=jiv
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--help[print this help information and exit.]'
  '--version[print version information and exit.]'
  '--loop[loop indefinitely through images.]'
  '--wait[advance to next image after N seconds.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
