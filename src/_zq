#compdef zq

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-f --format)'{-f,--format}'[output format]:format:(text csv json lake parquet table tsv vng zeek zjson zng zson)' \
  '-z[ZSON output shorthand]' \
  '-j[JSON output shorthand]' \
  '-i[input format]:format:(auto csv json line parquet tsv vng zeek zjson zng zson)' \
  '(-c --color)'{-c,--color}'[color output]:when:(auto always never)' \
  '--split-size[split output into files of size]:size' \
  '-raw[raw output]' \
  '-I[include file]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:file:_files' && ret=0
return ret
