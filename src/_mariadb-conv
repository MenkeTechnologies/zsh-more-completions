#compdef mariadb-conv
# Documentation: https://man.archlinux.org/search?q=mariadb-conv
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '--from:name'
    '-f:name'
    '--to:name'
    '-t:name'
    '--continue'
    '-c'
    '--delimiter:name'
    '*:filename:_files'
)
_arguments -s -S $arguments
