#compdef whalebrew

local curcontext="$curcontext" state line ret=1

_whalebrew_commands() {
  local -a commands=(
    'install:Install a Docker image as a command'
    'list:List installed commands'
    'uninstall:Uninstall a command'
    'version:Show version'
    'edit:Edit a command'
    'search:Search for available commands'
  )
  _describe -t commands 'whalebrew command' commands
}

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:_whalebrew_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      install)
        _arguments -s -S \
          '(-n --name)'{-n,--name}'[custom command name]:name' \
          '(-f --force)'{-f,--force}'[force install]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:image' && ret=0
        ;;
      uninstall)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:command' && ret=0
        ;;
      edit)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:command' && ret=0
        ;;
      search)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:query' && ret=0
        ;;
    esac
    ;;
esac

return ret
