#compdef goreleaser

# Zsh completion for goreleaser - release automation for Go

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:generates a .goreleaser.yaml file'
  'check:check if config is valid'
  'build:build the binaries only'
  'release:release the current project'
  'healthcheck:check if needed tools are installed'
  'completion:generate shell completion'
  'jsonschema:output goreleaser JSON schema'
)

_arguments -s -S \
  '1:command:->command' \
  '--debug[enable debug mode]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'goreleaser command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (release)
        _arguments -s -S \
          '--clean[remove the dist directory before building]' \
          '--snapshot[generate an unversioned snapshot release]' \
          '*--skip[skip steps]:step:(announce aur before chocolatey docker homebrew ko nfpm nix publish sbom scoop sign snapcraft validate winget)' \
          '--timeout[timeout for the release process]:timeout' \
          '(-p --parallelism)'{-p,--parallelism}'[number of parallel tasks]:number' \
          '(-f --config)'{-f,--config}'[config file]:file:_files' \
          '--release-notes[load release notes from file]:file:_files' \
          '--release-notes-tmpl[load release notes from template]:file:_files' \
          '--release-header[release header template]:file:_files' \
          '--release-footer[release footer template]:file:_files' \
          '--auto-snapshot[automatically create snapshot if on dirty tag]' \
          '--fail-fast[exit on first error]' \
          '--debug[enable debug mode]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (build)
        _arguments -s -S \
          '--clean[remove the dist directory before building]' \
          '--snapshot[generate an unversioned snapshot build]' \
          '--single-target[build only for current GOOS/GOARCH]' \
          '--output[copy the binary to the path after build]:path:_files' \
          '--timeout[timeout for the build process]:timeout' \
          '(-p --parallelism)'{-p,--parallelism}'[number of parallel tasks]:number' \
          '(-f --config)'{-f,--config}'[config file]:file:_files' \
          '*--id[build only specified ids]:id' \
          '--debug[enable debug mode]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (check)
        _arguments -s -S \
          '(-f --config)'{-f,--config}'[config file]:file:_files' \
          '--deprecated[force print deprecation messages]' \
          '--debug[enable debug mode]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (init)
        _arguments -s -S \
          '(-f --config)'{-f,--config}'[config file to create]:file:_files' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      (*)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
