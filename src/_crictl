#compdef crictl

# Zsh completion for crictl (CRI CLI for Kubernetes container runtimes)

_crictl() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a global_opts
    global_opts=(
        {-c,--config}'[Location of the client config file]:file:_files'
        {-D,--debug}'[Enable debug mode]'
        {-i,--image-endpoint}'[Endpoint of CRI image manager service]:endpoint'
        {-r,--runtime-endpoint}'[Endpoint of CRI container runtime service]:endpoint'
        {-t,--timeout}'[Timeout of connecting to the server]:timeout'
        '(- *)'{-h,--help}'[Show help]'
        '(- *)'{-v,--version}'[Print the version]'
        '--enable-tracing[Enable OpenTelemetry tracing]'
        '--tracing-endpoint[Address of the OpenTelemetry collector]:endpoint'
        '--tracing-sampling-rate-per-million[Tracing sampling rate per million]:rate'
        '--profile-cpu[Write CPU profile to file]:file:_files'
        '--profile-mem[Write memory profile to file]:file:_files'
    )

    _arguments -C \
        $global_opts \
        '(-): :->command' \
        '(-)*:: :->option-or-argument' && ret=0

    case $state in
        (command)
            local -a commands
            commands=(
                'attach:Attach to a running container'
                'create:Create a new container'
                'exec:Run a command in a running container'
                'version:Display runtime version information'
                'images:List images'
                'inspect:Display the status of one or more containers'
                'inspecti:Return the status of one or more images'
                'imagefsinfo:Return image filesystem info'
                'inspectp:Display the status of one or more pods'
                'logs:Fetch the logs of a container'
                'port-forward:Forward local port to a pod'
                'ps:List containers'
                'pull:Pull an image from a registry'
                'run:Run a new container inside a sandbox'
                'runp:Run a new pod'
                'rm:Remove one or more containers'
                'rmi:Remove one or more images'
                'rmp:Remove one or more pods'
                'pods:List pods'
                'start:Start one or more created containers'
                'info:Display information of the container runtime'
                'stop:Stop one or more running containers'
                'stopp:Stop one or more running pods'
                'update:Update one or more running containers'
                'config:Get, set, and list crictl client configuration options'
                'stats:List container(s) resource usage statistics'
                'statsp:List pod resource usage statistics'
                'completion:Output shell completion code'
                'checkpoint:Checkpoint one or more running containers'
                'events:Stream the events of containers'
                'metricsp:List pod metrics'
                'metricdescs:List metric descriptors'
                'runtime-config:Get the runtime configuration'
                'update-runtime-config:Update the runtime configuration'
                'help:Shows a list of commands or help for one command'
            )
            _describe -t commands 'command' commands && ret=0
            ;;
        (option-or-argument)
            curcontext=${curcontext%:*:*}:crictl-$words[1]:
            case $words[1] in
                (ps)
                    _arguments -s \
                        {-a,--all}'[Show all containers]' \
                        '--id[Filter by container id]:id' \
                        '--label[Filter by key=value label]:label' \
                        '--last[Only show the most recently created n containers]:n' \
                        '--latest[Show the most recently created container]' \
                        '--name[Filter by container name]:name' \
                        '--no-trunc[Show output without truncating]' \
                        {-o,--output}'[Output format]:format:(json yaml table go)' \
                        '--pod[Filter by pod id]:id' \
                        {-q,--quiet}'[Only show container ids]' \
                        {-s,--state}'[Filter by container state]:state:(created running exited unknown)' \
                        '--image[Filter by image name]:image' \
                        && ret=0
                    ;;
                (pods)
                    _arguments -s \
                        '--id[Filter by pod id]:id' \
                        '--label[Filter by key=value label]:label' \
                        '--last[Only show the most recently created n pods]:n' \
                        '--latest[Show the most recently created pod]' \
                        '--name[Filter by pod name]:name' \
                        '--namespace[Filter by pod namespace]:namespace' \
                        '--no-trunc[Show output without truncating]' \
                        {-o,--output}'[Output format]:format:(json yaml table go)' \
                        {-q,--quiet}'[Only show pod ids]' \
                        {-s,--state}'[Filter by pod state]:state:(ready notready)' \
                        && ret=0
                    ;;
                (images|image|img)
                    _arguments -s \
                        '--digests[Show digests]' \
                        '--no-trunc[Show output without truncating]' \
                        {-o,--output}'[Output format]:format:(json yaml table go)' \
                        {-q,--quiet}'[Only show image ids]' \
                        '--pinned[Filter by pinned/unpinned images]:value:(true false)' \
                        '*:image name:' \
                        && ret=0
                    ;;
                (inspect)
                    _arguments -s \
                        {-o,--output}'[Output format]:format:(json yaml table go)' \
                        {-q,--quiet}'[Do not show verbose information]' \
                        '--template[Go template for output]:template' \
                        '*:container id:' \
                        && ret=0
                    ;;
                (inspecti)
                    _arguments -s \
                        {-o,--output}'[Output format]:format:(json yaml table go)' \
                        {-q,--quiet}'[Do not show verbose information]' \
                        '--template[Go template for output]:template' \
                        '*:image id:' \
                        && ret=0
                    ;;
                (inspectp)
                    _arguments -s \
                        {-o,--output}'[Output format]:format:(json yaml table go)' \
                        {-q,--quiet}'[Do not show verbose information]' \
                        '--template[Go template for output]:template' \
                        '*:pod id:' \
                        && ret=0
                    ;;
                (logs)
                    _arguments -s \
                        {-f,--follow}'[Follow log output]' \
                        '--previous[Show previously terminated container log]' \
                        '--since[Show logs since relative timestamp]:time' \
                        '--tail[Number of lines to show from the end of the logs]:lines' \
                        '--timestamps[Show timestamps on each line]' \
                        '--limited-bytes[Limit bytes of logs to return]:bytes' \
                        '*:container id:' \
                        && ret=0
                    ;;
                (exec)
                    _arguments -s \
                        {-i,--interactive}'[Keep STDIN open]' \
                        {-t,--tty}'[Allocate a pseudo-TTY]' \
                        '--timeout[Timeout in seconds]:seconds' \
                        '*:container id and command:' \
                        && ret=0
                    ;;
                (attach)
                    _arguments -s \
                        '--stdin[Keep STDIN open]' \
                        '--tty[Allocate a pseudo-TTY]' \
                        '--transport[Transport protocol]:transport:(websocket)' \
                        '*:container id:' \
                        && ret=0
                    ;;
                (create)
                    _arguments -s \
                        '--no-pull[Do not pull image before create]' \
                        '--with-pull[Pull image before create]' \
                        '1:pod id:' \
                        '2:container config:_files -g "*.{json,yaml}"' \
                        '3:pod config:_files -g "*.{json,yaml}"' \
                        && ret=0
                    ;;
                (run)
                    _arguments -s \
                        '--no-pull[Do not pull image before run]' \
                        '--with-pull[Pull image before run]' \
                        '--runtime[Runtime handler]:runtime' \
                        '1:container config:_files -g "*.{json,yaml}"' \
                        '2:pod config:_files -g "*.{json,yaml}"' \
                        && ret=0
                    ;;
                (runp)
                    _arguments -s \
                        '--runtime[Runtime handler]:runtime' \
                        '1:pod config:_files -g "*.{json,yaml}"' \
                        && ret=0
                    ;;
                (pull)
                    _arguments -s \
                        '--auth[Use auth string for accessing the registry]:auth' \
                        '--creds[Use credentials (USERNAME\:PASSWORD) for accessing the registry]:credentials' \
                        '--pod-config[Config file for the pod sandbox]:file:_files -g "*.{json,yaml}"' \
                        '--annotation[Annotations to add to the pulled image]:key=value' \
                        '*:image name:' \
                        && ret=0
                    ;;
                (rm)
                    _arguments -s \
                        {-a,--all}'[Remove all containers]' \
                        {-f,--force}'[Force removal of the container]' \
                        '*:container id:' \
                        && ret=0
                    ;;
                (rmi)
                    _arguments -s \
                        {-a,--all}'[Remove all images]' \
                        {-q,--prune}'[Remove all unused images]' \
                        '*:image id or name:' \
                        && ret=0
                    ;;
                (rmp)
                    _arguments -s \
                        {-a,--all}'[Remove all pods]' \
                        {-f,--force}'[Force removal of the pod]' \
                        '*:pod id:' \
                        && ret=0
                    ;;
                (stop)
                    _arguments -s \
                        {-a,--all}'[Stop all containers]' \
                        '--timeout[Timeout in seconds to stop the container]:seconds' \
                        '*:container id:' \
                        && ret=0
                    ;;
                (stopp)
                    _arguments -s \
                        {-a,--all}'[Stop all pods]' \
                        '*:pod id:' \
                        && ret=0
                    ;;
                (start)
                    _arguments -s \
                        '*:container id:' \
                        && ret=0
                    ;;
                (update)
                    _arguments -s \
                        '--cpu-period[CPU CFS period to be used for hardcapping]:period' \
                        '--cpu-quota[CPU CFS hardcap limit]:quota' \
                        '--cpu-share[CPU shares (relative weight)]:shares' \
                        '--cpuset-cpus[CPU(s) to use]:cpus' \
                        '--cpuset-mems[Memory node(s) to use]:mems' \
                        '--memory[Memory limit in bytes]:limit' \
                        '*:container id:' \
                        && ret=0
                    ;;
                (stats)
                    _arguments -s \
                        {-a,--all}'[Show all containers]' \
                        '--id[Filter by container id]:id' \
                        '--label[Filter by key=value label]:label' \
                        {-o,--output}'[Output format]:format:(json yaml table go)' \
                        '--pod[Filter by pod id]:id' \
                        {-s,--seconds}'[Sample duration for CPU usage]:seconds' \
                        '*:container id:' \
                        && ret=0
                    ;;
                (statsp)
                    _arguments -s \
                        {-o,--output}'[Output format]:format:(json yaml table go)' \
                        '--label[Filter by key=value label]:label' \
                        '*:pod id:' \
                        && ret=0
                    ;;
                (config)
                    _arguments -s \
                        '--get[Get value of a config option]:key' \
                        '--set[Set option (key=value)]:key=value' \
                        '--list[List all options]' \
                        && ret=0
                    ;;
                (port-forward)
                    _arguments -s \
                        '*:pod-id and port:' \
                        && ret=0
                    ;;
                (completion)
                    _arguments -s \
                        '1:shell:(bash zsh fish powershell)' \
                        && ret=0
                    ;;
                (checkpoint)
                    _arguments -s \
                        '--export[Location of tar archive for checkpoint image]:file:_files' \
                        '*:container id:' \
                        && ret=0
                    ;;
                (events|event)
                    _arguments -s \
                        {-o,--output}'[Output format]:format:(json yaml go)' \
                        && ret=0
                    ;;
                (version)
                    _arguments -s \
                        '*:arguments:' \
                        && ret=0
                    ;;
                (*)
                    _arguments -s \
                        '*:arguments:' \
                        && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_crictl "$@"
