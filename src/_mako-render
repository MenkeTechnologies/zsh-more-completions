#compdef mako-render
# Documentation: https://man.archlinux.org/search?q=mako-render
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  '--var[variable (can be used multiple times, use name=value)]'
  '--template-dir[directory to use for template lookup (multiple]'
  '*:filename:_files'
)

_arguments -s -S $arguments
