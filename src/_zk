#compdef zk

# Zsh completion for zk - a plain text note-taking assistant

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'init:Create a notebook in the given directory'
  'new:Create a new note in the given notebook directory'
  'list:List notes matching the given criteria'
  'edit:Edit notes matching the given criteria'
  'index:Index the notes to be searchable'
  'link:Insert a link to a note'
  'tag:Manage the note tags'
  'graph:Produce a graph of the notes'
  'config:Edit the notebook configuration'
  'notebook:Manage notebooks'
  'cd:Print the notebook path to use with the shell'
  'help:Print help'
)

_arguments -s -S \
  '--notebook-dir[use this notebook directory]:dir:_files -/' \
  '--working-dir[run as if zk was started in given directory]:dir:_files -/' \
  '--no-input[never prompt or ask for confirmation]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      new)
        _arguments \
          '(-t --title)'{-t,--title}'[note title]:title:' \
          '--date[set creation date of the note]:date:' \
          '--group[assignment to a config group]:group:' \
          '--template[custom template for the note]:template:_files' \
          '--extra[add custom variable to the template]:key=value:' \
          '--print-path[print the path of the created note]' \
          '--dry-run[do not create the note on the file system]' \
          ':directory:_files -/' && ret=0
        ;;
      list|edit)
        _arguments \
          '(-q --quiet)'{-q,--quiet}'[do not print notes]' \
          '(-e --exact-match)'{-e,--exact-match}'[filter notes with exact match instead of fuzzy search]' \
          '(-t --tag)'{-t,--tag}'[filter by tag]:tag:' \
          '(-m --mention)'{-m,--mention}'[filter notes mentioning a path]:path:_files' \
          '(-M --mentioned-by)'{-M,--mentioned-by}'[filter notes mentioned by given path]:path:_files' \
          '(-l --link-to)'{-l,--link-to}'[filter notes having a link to path]:path:_files' \
          '(-L --no-link-to)'{-L,--no-link-to}'[filter notes having no link to path]:path:_files' \
          '(-n --limit)'{-n,--limit}'[limit results]:N:' \
          '--sort[sort results by]:field:(created modified path word-count random)' \
          '--format[output format]:format:(path oneline short medium full json jsonl)' \
          '--delimiter[output delimiter]:delimiter:' \
          '--delimiter0[use NUL as output delimiter]' \
          '--no-header[disable pretty output header]' \
          '*:filter expression:' && ret=0
        ;;
    esac
    ;;
esac

return ret
