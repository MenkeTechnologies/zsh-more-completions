#compdef pacote
# Documentation: https://man.archlinux.org/search?q=pacote
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--long[print an object from resolve, including integrity and spec.]'
  '--json[print result objects as JSON rather than nodes default.]'
  {--help,-h}'[print this helpful text.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
