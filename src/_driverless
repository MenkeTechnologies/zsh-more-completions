#compdef driverless
# Documentation: https://man.archlinux.org/search?q=driverless
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[show help]'
  '--help[show help]'
  '--version[show this usage message.]'
  '-d[delete or directory]'
  {-v,--debug}'[debug/verbose mode.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
