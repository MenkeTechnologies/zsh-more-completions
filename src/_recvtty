#compdef recvtty
# Documentation: https://man.archlinux.org/search?q=recvtty
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {--mode,-m}'[mode of operation (single or null) (default: "single")]'
  '--pid-file[path to write daemon process ID to]:file:_files'
  {--help,-h}'[show help]'
  {--version,-v}'[print the version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
