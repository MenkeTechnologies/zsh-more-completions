#compdef rm

# Zsh completion for rm - remove files and directories
# Supports both GNU coreutils and BSD/macOS variants

local -a arguments

if [[ "$OSTYPE" == darwin* || "$OSTYPE" == freebsd* ]]; then
  # BSD/macOS variant
  arguments=(
    '-d[attempt to remove directories as well as other types of files]'
    '(-i)-f[do not prompt for confirmation, ignore nonexistent files]'
    '(-f)-i[prompt for confirmation before each removal]'
    '-I[prompt once before removing more than three files or recursing]'
    '-P[this flag has no effect (kept for backward compatibility)]'
    '-R[remove file hierarchies recursively (implies -d)]'
    '-r[equivalent to -R]'
    '-v[be verbose, show files as they are removed]'
    '-W[attempt to undelete named files (union filesystem whiteouts)]'
    '-x[do not cross mount points when removing a hierarchy]'
    '*:file:_files'
  )
else
  # GNU coreutils variant
  arguments=(
    '(-i -I)-f[ignore nonexistent files and arguments, never prompt]'
    {-f,--force}'[ignore nonexistent files and arguments, never prompt]'
    '(-f -I)-i[prompt before every removal]'
    '(-f -i)-I[prompt once before removing more than three files or recursing]'
    '--interactive=-[prompt according to WHEN]::when:(never once always)'
    '--one-file-system[when removing a hierarchy recursively, skip any directory on a different file system]'
    '--no-preserve-root[do not treat / specially]'
    "--preserve-root=-[do not remove / (default)]::scope:(all)"
    {-r,-R,--recursive}'[remove directories and their contents recursively]'
    {-d,--dir}'[remove empty directories]'
    {-v,--verbose}'[explain what is being done]'
    '--help[display help and exit]'
    '--version[output version information and exit]'
    '*:file:_files'
  )
fi

_arguments -s -S $arguments
