#compdef gtf

local -a arguments

arguments=(
  '(-v --verbose)'{-v,--verbose}'[enable verbose printouts (traces each step of the computation)]'
  '(-f --fbmode)'{-f,--fbmode}'[output an fbset(8)-style mode description]'
  '(-x --xorgmode)'{-x,--xorgmode}'[output an Xorg-style mode description (this is the default)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
