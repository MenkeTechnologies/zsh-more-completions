#compdef t1binary

local -a arguments

arguments=(
  {-l,--block-length}'[set max output block length.]:length:'
  {-o,--output}'[write output to FILE.]:file:_files'
  '(- * :)'{-h,--help}'[print this message and exit.]'
  '--version[print version number and warranty and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
