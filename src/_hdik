#compdef hdik
# Documentation: https://man.archlinux.org/search?q=hdik
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-shadow[shadow option]'
  '-nomount[do not mount the image after attach]'
  '-drivekey[<value>]'
  '-encryption[+hmacsha1-key>]'
  '*:filename:_files'
)

_arguments -s -S $arguments
