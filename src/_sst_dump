#compdef sst_dump

local -a arguments

arguments=(
  '--file[path to SST file or directory containing SST files]'
  '--command[check: Iterate over entries in files but dont print anything except if an error is encounterd (default command)]'
  '--output_hex[output keys and values in hex format]'
  '--from[key to start reading from when executing check|scan]'
  '--to[key to stop reading at when executing check|scan]'
  '--prefix[returns all keys with this prefix when executing check|scan]'
  '--read_num[number of entries to read]:num'
  '--verify_checksum[verify file checksum]'
  '--input_key_hex[input keys are in hex format]'
  '--show_properties[show table properties]'
  '--set_block_size[set block size for reading]:block size'
  '--compression_types[compression types to test]:comma-separated list'
  '--parse_internal_key[parse an internal key in hex]:hex key'
  '*:filename:_files'
)

_arguments -s -S $arguments
