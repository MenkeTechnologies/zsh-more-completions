#compdef l3sys-query

local -a arguments

arguments=(
  '--exclude[exclude entries from directory listing]:pattern:'
  {-h,--help}'[prints this message and exits]'
  '--ignore-case[ignore case when sorting directory listing]'
  {-p,--pattern}'[treat (x)args as a Lua pattern]'
  {-r,--recursive}'[activates recursive directory listing]'
  '--reverse[reversing sorting order]'
  '--sort[method used to sort directory listing]:method:(name date)'
  '--type[select just the directories or files in a listing]:type:(d f)'
  {-v,--version}'[prints version information and exits]'
  '*:filename:_files'
)

_arguments -s -S $arguments
