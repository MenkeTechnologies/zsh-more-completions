#compdef fourcc2pixfmt
# Documentation: https://man.archlinux.org/search?q=fourcc2pixfmt
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-l[list the pixel format for each fourcc]'
  '-L[list the fourccs for each pixel format]'
  '-p[given a pixel format, print the list of associated fourccs (one per line)]'
  '-h[print this help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
