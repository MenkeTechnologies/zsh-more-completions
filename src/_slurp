#compdef slurp

# Zsh completion for slurp - Wayland region selector

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-d[display dimensions of selection]' \
  '-b[set background color]:color:' \
  '-c[set border color]:color:' \
  '-s[set selection color]:color:' \
  '-B[set border color of boxes]:color:' \
  '-w[set border weight]:weight:' \
  '-f[set format string]:format:' \
  '-p[select a single pixel]' \
  '-o[select only predefined output regions]' \
  '-r[require ratio]:width\:height:' \
  '-a[set aspect ratio]:width\:height:' \
  && return 0
