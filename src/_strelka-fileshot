#compdef strelka-fileshot
# Documentation: https://man.archlinux.org/search?q=strelka-fileshot
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-c[path to fileshot conf (default "/etc/strelka/fileshot.yaml")]'
  '-cpu[enables cpu profiling]'
  '-heap[enables heap profiling]'
  '*:filename:_files'
)

_arguments -s -S $arguments
