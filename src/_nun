#compdef nun
# Documentation: https://man.archlinux.org/search?q=nun
# Reference accessed: 2026-05-16

# Zsh completion for nun (ni uninstall)

_arguments -S -A "-*" \
  '(- *)'{-h,--help}'[display help]' \
  '(-v --version)'{-v,--version}'[display version]' \
  '(-C --directory)'{-C,--directory}'[change directory]:directory:_files -/' \
  '(-g --global)'{-g,--global}'[uninstall global packages]' \
  '*:package: '
