#compdef cupstestppd
# Documentation: https://man.archlinux.org/search?q=cupstestppd
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-I[filters,none,profiles}]'
  '-R[set alternate root.]'
  '-W[none,constraints,defaults,duplex,filters,profiles,sizes,translations}]'
  '-q[run silently.]'
  '-r[use relaxed open mode.]'
  '-v[be verbose.]'
  '-vv[be very verbose.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
