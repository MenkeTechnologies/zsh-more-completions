#compdef report-gtk

local -a arguments

arguments=(
  {-v,--verbose}'[be verbose]'
  '-g[alternate GUI file]'
  '-p[add program names to log]'
  {-d,--delete}'[remove PROBLEM_DIR after reporting]'
  {-e,--event}'[run only these events]'
  {-x,--expert}'[expert mode]'
  '*:filename:_files'
)

_arguments -s -S $arguments
