#compdef arduino-builder

local -a arguments

arguments=(
    '-compile[Compiles the sketch]'
    '-dump-prefs[Dumps build preferences]'
    '-preprocess[Preprocesses the sketch]'
    '-build-path[Specify build path]:build path:_directories'
    '-build-cache[Specify build cache path]:cache path:_directories'
    '-hardware[Specify hardware folders]:hardware path:_directories'
    '-tools[Specify tools folders]:tools path:_directories'
    '-libraries[Specify libraries folders]:libraries path:_directories'
    '-built-in-libraries[Specify built-in libraries path]:path:_directories'
    '-fqbn[Fully qualified board name]:fqbn'
    '-ide-version[IDE version number]:version'
    '-core-api-version[Core API version]:version'
    '-warnings[Warning level]:level:(none default more all)'
    '-verbose[Verbose output]'
    '-debug-level[Debug level]:level'
    '-logger[Logger type]:logger:(human machine)'
    '-vid-pid[VID/PID to use]:vid_pid'
    '-jobs[Number of parallel jobs]:jobs'
    '*:sketch path:_files'
)

_arguments -s -S $arguments
