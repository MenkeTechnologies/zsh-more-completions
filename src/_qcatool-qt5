#compdef qcatool-qt5

local -a arguments

arguments=(
  '--noprompt[do not prompt for input]'
  '--ordered[order certificate chain]'
  '--debug[enable debug output]'
  '--log-file[log to specified file]:file:_files'
  '--log-level[set log level]:level: '
  '--nobundle[do not use certificate bundles]'
  '*:filename:_files'
)

_arguments -s -S $arguments
