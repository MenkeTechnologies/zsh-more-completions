#compdef fdtoverlay
# Documentation: https://man.archlinux.org/search?q=fdtoverlay
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-i,--input}'[input base DT blob]:file:_files'
  {-o,--output}'[output DT blob]:file:_files'
  {-v,--verbose}'[verbose messages]'
  {-h,--help}'[print this help and exit]'
  {-V,--version}'[print version and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
