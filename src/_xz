#compdef xz unxz xzcat lzma unlzma lzcat

local arguments

arguments=(
  # Operation mode
  '(-d --decompress -t --test -l --list -z --compress)'{-z,--compress}'[force compression]'
  '(-z --compress -t --test -l --list -d --decompress)'{-d,--decompress}'[force decompression]'
  '(-z --compress -d --decompress -l --list -t --test)'{-t,--test}'[test compressed file integrity]'
  '(-z --compress -d --decompress -t --test -l --list)'{-l,--list}'[list information about .xz files]'

  # Operation modifiers
  {-k,--keep}'[keep (don'\''t delete) input files]'
  {-f,--force}'[force overwrite of output file and (de)compress links]'
  {-c,--stdout}'[write to standard output and don'\''t delete input files]'
  '--no-sync[don'\''t synchronize output file to storage device before removing input]'
  '--single-stream[decompress only the first stream, silently ignore remaining data]'
  '--no-sparse[do not create sparse files when decompressing]'
  {-S+,--suffix=}'[use specified suffix on compressed files]:suffix'
  '--files=-[read filenames to process from file]::file:_files'
  '--files0=-[like --files but use null character as terminator]::file:_files'

  # File format and compression options
  {-F+,--format=}'[file format to encode or decode]:format:(auto xz lzma lzip raw)'
  {-C+,--check=}'[integrity check type]:check type:(none crc32 crc64 sha256)'
  '--ignore-check[don'\''t verify the integrity check when decompressing]'
  '-0[set compression preset level 0 (fastest)]'
  '-1[set compression preset level 1]'
  '-2[set compression preset level 2]'
  '-3[set compression preset level 3]'
  '-4[set compression preset level 4]'
  '-5[set compression preset level 5]'
  '-6[set compression preset level 6 (default)]'
  '-7[set compression preset level 7]'
  '-8[set compression preset level 8]'
  '-9[set compression preset level 9 (slowest, best compression)]'
  {-e,--extreme}'[try to improve compression ratio by using more CPU time]'
  {-T+,--threads=}'[use at most NUM threads (0=auto)]:number of threads'
  '--block-size=[start a new .xz block after every SIZE bytes of input]:block size'
  '--block-list=[start a new .xz block after given intervals of uncompressed data]:block list'
  '--flush-timeout=[flush pending data if more than NUM milliseconds since last flush]:timeout (ms)'
  '--memlimit-compress=[set memory usage limit for compression]:memory limit'
  '--memlimit-decompress=[set memory usage limit for decompression]:memory limit'
  '--memlimit-mt-decompress=[set memory usage limit for threaded decompression]:memory limit'
  {-M+,--memlimit=}'[set memory usage limit for all operations]:memory limit'
  '--no-adjust[give error instead of adjusting settings if memory limit exceeded]'

  # Custom filter chain options
  '--filters=[set filter chain using liblzma filter string syntax]:filter string'
  '--filters1=[set additional filter chain 1]:filter string'
  '--filters2=[set additional filter chain 2]:filter string'
  '--filters3=[set additional filter chain 3]:filter string'
  '--filters4=[set additional filter chain 4]:filter string'
  '--filters5=[set additional filter chain 5]:filter string'
  '--filters6=[set additional filter chain 6]:filter string'
  '--filters7=[set additional filter chain 7]:filter string'
  '--filters8=[set additional filter chain 8]:filter string'
  '--filters9=[set additional filter chain 9]:filter string'
  '--filters-help[display information about liblzma filter string syntax and exit]'

  # Filter options
  '--lzma1=-[LZMA1 filter with options]:options'
  '--lzma2=-[LZMA2 filter with options]:options'
  '--x86=-[x86 BCJ filter (32-bit and 64-bit)]:options'
  '--arm=-[ARM BCJ filter]:options'
  '--armthumb=-[ARM-Thumb BCJ filter]:options'
  '--arm64=-[ARM64 BCJ filter]:options'
  '--powerpc=-[PowerPC BCJ filter (big endian only)]:options'
  '--ia64=-[IA-64 (Itanium) BCJ filter]:options'
  '--sparc=-[SPARC BCJ filter]:options'
  '--riscv=-[RISC-V BCJ filter]:options'
  '--delta=-[Delta filter]:options'

  # Other options
  {-q,--quiet}'[suppress warnings; specify twice to suppress errors too]'
  {-v,--verbose}'[be verbose; specify twice for even more verbose]'
  {-Q,--no-warn}'[make warnings not affect the exit status]'
  '--robot[use machine-parsable messages (useful for scripts)]'
  '--info-memory[display the total amount of RAM and active memory usage limits, and exit]'
  '(- *)'{-h,--help}'[display short help and exit]'
  '(- *)'{-H,--long-help}'[display long help (lists also the advanced options) and exit]'
  '(- *)'{-V,--version}'[display the version number and exit]'

  '*:file:_files'
)

_arguments -s -S $arguments
