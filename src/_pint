#compdef pint

# Zsh completion for pint - Prometheus rule linter/validator

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'lint:lint Prometheus rules'
  'ci:run checks on git changes'
  'watch:continuously lint Prometheus rules'
  'config:manage pint configuration'
  'version:print version information'
)

_arguments -s -S \
  '1:subcommand:->subcmd' \
  '*::args:->args' \
  '--no-color[disable colored output]' \
  '(-l --log-level)'{-l,--log-level}'[set log level]:level:(debug info warn error fatal)' \
  '(-c --config)'{-c,--config}'[path to config file]:file:_files -g "*.hcl"' \
  '--no-discovery[disable online Prometheus checks]' \
  '--offline[deprecated: use --no-discovery]' \
  '(-w --workers)'{-w,--workers}'[number of worker threads]:count:' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'pint subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (lint)
        _arguments \
          '--min-severity[minimum severity to report]:severity:(info warning bug fatal)' \
          '--output[output format]:format:(console text json)' \
          '*:rule files:_files -g "*.yml *.yaml *.rules"' && ret=0
        ;;
      (ci)
        _arguments \
          '--base-branch[base branch for comparison]:branch:' \
          '--require-owner[require rule owner comments]' \
          '--min-severity[minimum severity to report]:severity:(info warning bug fatal)' \
          '--output[output format]:format:(console text json)' && ret=0
        ;;
      (watch)
        _arguments \
          '--listen[address to listen on]:address:' \
          '--pidfile[path to PID file]:file:_files' \
          '--max-problems[max number of problems to report]:count:' \
          '--min-severity[minimum severity to report]:severity:(info warning bug fatal)' \
          '*:rule files:_files -g "*.yml *.yaml *.rules"' && ret=0
        ;;
    esac
    ;;
esac

return ret
