#compdef rstart
# Documentation: https://man.archlinux.org/search?q=rstart
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-c[run command in the specified context]'
  '-g[interpret command as a generic command]'
  '-l[run command as the specified user]'
  '-v[enable verbose output]'
  '*:filename:_files'
)

_arguments -s -S $arguments
