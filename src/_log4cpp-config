#compdef log4cpp-config

local -a arguments

arguments=(
  '--prefix[show or set the install prefix]'
  '--exec-prefix[show or set the exec prefix]'
  '--exec_prefix[show the exec prefix]'
  '--eprefix[show the exec prefix]'
  '--version[show the version]'
  {--cflags,-I}'[show compiler flags]'
  {--libs,-L}'[show linker flags]'
  '--package[show the package name]'
  '--bindir[show the bindir]'
  '--sbindir[show the sbindir]'
  '--libexecdir[show the libexecdir]'
  '--datadir[show the datadir]'
  '--sysconfdir[show the sysconfdir]'
  '--sharedstatedir[show the sharedstatedir]'
  '--localstatedir[show the localstatedir]'
  '--libdir[show the libdir]'
  '--infodir[show the infodir]'
  '--mandir[show the mandir]'
  '--target[show the target]'
  '--host[show the host]'
  '--build[show the build]'
  '--pkgdatadir[show the package data directory]'
  '--pkglibdir[show the package library directory]'
  '--pkgincludedir[show the package include directory]'
  '--template-version[print template version]'
  '--help[display help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
