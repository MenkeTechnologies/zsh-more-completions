local -a arguments

arguments=(
    {-M,--modprobe}'[Specify the path to the modprobe program.]':modprobe_program
    {-c,--counters}'[Include the current values of all packet and byte counters in the output.]'
    {-V,--version}'[Print version information and exit.]'
