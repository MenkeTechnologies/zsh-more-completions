#compdef docusaurus

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:start the development server'
  'build:build website for production'
  'swizzle:wrap or eject a theme component'
  'deploy:deploy website to GitHub pages'
  'clear:remove build artifacts'
  'serve:serve website locally from build directory'
  'write-translations:extract required translations'
  'write-heading-ids:generate heading IDs'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'docusaurus command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (start)
        _arguments -s -S \
          '--port=[development server port]:port' \
          '--host=[development server host]:host' \
          '--hot-only[do not fall back to page reload]' \
          '--no-open[do not open browser]' \
          '--config=[path to config file]:config:_files' \
          '--locale=[locale to use]:locale' \
          '--poll[use polling for file watching]' \
          '--no-minify[disable minification of bundles]' \
          '1:site directory:_directories' && ret=0
        ;;
      (build)
        _arguments -s -S \
          '--bundle-analyzer[visualize size of webpack output]' \
          '--out-dir=[output directory]:directory:_directories' \
          '--config=[path to config file]:config:_files' \
          '--locale=[locale to build]:locale' \
          '--no-minify[disable minification]' \
          '1:site directory:_directories' && ret=0
        ;;
      (serve)
        _arguments -s -S \
          '--port=[serve port]:port' \
          '--host=[serve host]:host' \
          '--build[build site before serving]' \
          '--dir=[build output directory]:directory:_directories' \
          '--config=[path to config file]:config:_files' \
          '--no-open[do not open browser]' \
          '1:site directory:_directories' && ret=0
        ;;
      (swizzle)
        _arguments -s -S \
          '--wrap[wrap with a component]' \
          '--eject[eject the component]' \
          '--danger[allow swizzling unsafe components]' \
          '--typescript[use TypeScript variant]' \
          '--javascript[use JavaScript variant]' \
          '--config=[path to config file]:config:_files' \
          '1:theme name' \
          '2:component name' && ret=0
        ;;
      (deploy)
        _arguments -s -S \
          '--locale=[locale to deploy]:locale' \
          '--config=[path to config file]:config:_files' \
          '--out-dir=[output directory]:directory:_directories' \
          '--skip-build[skip building before deploying]' \
          '1:site directory:_directories' && ret=0
        ;;
      (clear)
        _arguments '1:site directory:_directories' && ret=0
        ;;
      (write-translations)
        _arguments -s -S \
          '--locale=[locale to write]:locale' \
          '--override[override existing translations]' \
          '--config=[path to config file]:config:_files' \
          '--messagePrefix=[message prefix]:prefix' \
          '1:site directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
