#compdef size

local -a arguments

arguments=(
  {-A,--format}'[select SysV output style]'
  {-B,--format}'[select Berkeley output style (default)]'
  '-o[display numbers in octal]'
  '-d[display numbers in decimal]'
  '-x[display numbers in hex]'
  {-t,--totals}'[display the total sizes (Berkeley only)]'
  '--common[display total size for *COM* syms]'
  '--target[set the binary file format]'
  '(- * :)'{-h,--help}'[display this information]'
  {-v,--version}'[display the programs version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
