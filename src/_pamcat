#compdef pamcat


local -a arguments

arguments=(
    '--listfile[read list of input files from specified file]:file:_files'
    {--topbottom,--tb}'[Combine images vertically, top to bottom.]'
    {--leftright,--lr}'[Combine images horizontally, left to right.]'
    '--jleft[ Left-justify images in a top-bottom concatenation.]'
    '--jright[ Right-justify images in a top-bottom concatenation.]'
    '--jtop[ Top-justify images in a left-right concatenation.]'
    '--jbottom[ Bottom-justify images in a left-right concatenation.]'
    '--jcenter[ Center images (valid for both left-right and top-bottom concatenations).]'
    '--white[Make all padding white.]'
    '--black[Make all padding black.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
