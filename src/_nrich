#compdef nrich

# Zsh completion for nrich - quickly analyze IPs and get open ports, vulnerabilities, and CVEs

_arguments -s -S \
  '(-o --output)'{-o,--output}'[output format]:format:(text json csv)' \
  '(-c --config)'{-c,--config}'[config file]:file:_files' \
  '(-a --api-key)'{-a,--api-key}'[Shodan API key]:key:' \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  ':file or IP:_files'
