#compdef kswitch
# Documentation: https://man.archlinux.org/search?q=kswitch
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-t,--type}'[type of credential cache]'
  {-c,--cache}'[name of credential cache]'
  {-p,--principal}'[name of principal]'
  {-i,--interactive}'[interactive selection]'
  '*:filename:_files'
)

_arguments -s -S $arguments
