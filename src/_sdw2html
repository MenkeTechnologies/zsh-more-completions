#compdef sdw2html
# Documentation: https://man.archlinux.org/search?q=sdw2html
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[show this help message]'
  '-p[set password to open the file]'
  '-v[show version information]'
  '*:filename:_files'
)

_arguments -s -S $arguments
