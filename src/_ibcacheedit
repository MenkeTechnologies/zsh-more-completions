#compdef ibcacheedit


local -a arguments

arguments=(
    '--switchguid[Specify a switchguid that should be changed.]:BEFOREGUID:AFTERGUID'
    '--caguid[Specify a caguid that should be changed.]:BEFOREGUID:AFTERGUID'
    '--sysimgguid[Specify a sysimgguid that should be changed.]:BEFOREGUID:AFTERGUID'
    '--portguid[Specify a portguid that should be changed. The nodeguid of the port (e. g.]:NODEGUID:BEFOREGUID:AFTERGUID'
    '--cache[specify cache file]:cache file:_files'
    {-h,--help}'[show help]'
    {-V,--version}'[show version]'
    '*:filename:_files'
)
_arguments -s -S $arguments
