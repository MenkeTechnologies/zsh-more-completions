#compdef tqdm

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[print this help and exit]'
  {-v,--version}'[print version and exit]'
  '--desc[prefix for the progressbar]:str:'
  '--total[total number of expected iterations]:int:'
  '--leave[keep all traces of the progressbar upon termination]'
  '--ncols[width of the entire output message]:int:'
  '--mininterval[minimum progress display update interval in seconds]:float:'
  '--maxinterval[maximum progress display update interval in seconds]:float:'
  '--miniters[minimum progress display update interval in iterations]:int:'
  '--ascii[use ASCII characters to fill the meter]'
  '--disable[disable the entire progressbar]'
  '--unit[string used to define the unit of each iteration]:str:'
  '--unit_scale[scale the unit automatically]'
  '--dynamic_ncols[allow dynamic resizing of ncols]'
  '--smoothing[exponential moving average smoothing factor]:float:'
  '--bar_format[custom bar format string]:str:'
  '--initial[initial counter value]:int:'
  '--position[line offset for printing]:int:'
  '--postfix[additional stats to display at end of bar]:dict:'
  '--unit_divisor[unit divisor]:float:'
  '--write_bytes[write bytes instead of unicode]'
  '--delim[delimiting character]:char:'
  '--buf_size[buffer size]:int:'
  '--bytes[use bytes for size counter]'
  '--manpath[directory for man page installation]:str:'
  '--log[log level (CRITICAL, ERROR, WARN, INFO, DEBUG)]:str:'
  '*:filename:_files'
)

_arguments -s -S $arguments
