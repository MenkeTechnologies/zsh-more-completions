#compdef pgrep

_pgrep() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a common_opts
    common_opts=(
        {-d+,--delimiter=}'[specify output delimiter]:delimiter:'
        {-l,--list-name}'[list PID and process name]'
        {-a,--list-full}'[list PID and full command line]'
        {-v,--inverse}'[negate the matching, list non-matching processes]'
        {-w,--lightweight}'[list all TID (lightweight processes)]'
        {-c,--count}'[display count of matching processes]'
        {-f,--full}'[match against full argument lists, not just process name]'
        {-g+,--pgroup=}'[match listed process group IDs]:process group:_sequence _pgids'
        {-G+,--group=}'[match real group IDs]:group:_sequence _groups'
        {-i,--ignore-case}'[match case insensitively]'
        {-n,--newest}'[select only the most recently started process]'
        {-o,--oldest}'[select only the least recently started process]'
        {-O+,--older=}'[select processes older than given seconds]:seconds:'
        {-P+,--parent=}'[match only child processes of the given parent]:parent pid:_sequence _pids'
        {-s+,--session=}'[match session IDs]:session id:_sequence _pids'
        {-t+,--terminal=}'[match by controlling terminal]:terminal:_sequence _ttys'
        {-u+,--euid=}'[match by effective user IDs]:effective user:_sequence _users'
        {-U+,--uid=}'[match by real user IDs]:real user:_sequence _users'
        {-x,--exact}'[match exactly with the command name]'
        {-F+,--pidfile=}'[read PIDs from file]:pid file:_files'
        {-L,--logpidfile}'[fail if PID file is not locked]'
        {-r,--runstates=}'[match runstates]:state:(D I R S T t W X Z)'
        {-q,--quiet}'[do not write anything to standard output]'
        '--cgroup=[match by cgroup v2 names]:cgroup name:'
        '--ns=[match the processes that belong to the same namespace as the given PID]:pid:_pids'
        '--nslist=[list of namespaces to consider for --ns]:namespace:_values -s , namespace cgroup ipc mnt net pid time user uts'
        '(- *)'{-h,--help}'[display help and exit]'
        '(- *)'{-V,--version}'[output version information and exit]'
    )

    _arguments -s \
        $common_opts \
        '*:process name pattern:_process_names -a' && ret=0

    return ret
}

_pgrep "$@"
