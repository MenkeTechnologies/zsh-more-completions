#compdef ubertooth-debug
# Documentation: https://man.archlinux.org/search?q=ubertooth-debug
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[help message]'
  '-r[read the contents of CC2400 register(s)]:registers:'
  '-U[set ubertooth device to use]:0-7:'
  '-v[verbosity (default=1)]:0-2:'
  '*:filename:_files'
)

_arguments -s -S $arguments
