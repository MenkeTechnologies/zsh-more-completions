#compdef themole

local -a arguments

arguments=(
  '-u[the url which contains a sqli vulnerability.]:url:'
  '-n[the string which is printed on good queries.]:string:'
  '-t[the amount of threads to run. Defaults to 4.]:threads:'
  '-e[use ENCODING to decode data retrieved from the server.]:encoding:'
  '-p[sets the GET vulnerable param(URL must be provided).]:param:'
  '*:filename:_files'
)

_arguments -s -S $arguments
