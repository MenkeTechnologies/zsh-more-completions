#compdef jsonnet

# Zsh completion for jsonnet (data templating language)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-e --exec)'{-e,--exec}'[treat argument as code]' \
  '(-J --jpath)'{-J,--jpath}'[specify library search path]:path:_files -/' \
  '(-o --output-file)'{-o,--output-file}'[write output to file]:file:_files' \
  '(-m --multi)'{-m,--multi}'[write multiple output files to directory]:dir:_files -/' \
  '(-y --yaml-stream)'{-y,--yaml-stream}'[output as YAML stream]' \
  '(-S --string)'{-S,--string}'[expect string as output]' \
  '--tla-str[top-level argument string]:var\=val:' \
  '--tla-code[top-level argument code]:var\=code:' \
  '--tla-str-file[top-level argument from string file]:var\=file:' \
  '--tla-code-file[top-level argument from code file]:var\=file:' \
  '--ext-str[external variable string]:var\=val:' \
  '--ext-code[external variable code]:var\=code:' \
  '--ext-str-file[external variable from string file]:var\=file:' \
  '--ext-code-file[external variable from code file]:var\=file:' \
  '--max-stack[stack size limit]:size:' \
  '--max-trace[max stack trace on error]:size:' \
  '--create-output-dirs[create output directories]' \
  '1:jsonnet file:_files -g "*.jsonnet *.libsonnet"' && return 0
