#compdef update-shells
# Documentation: https://man.archlinux.org/search?q=update-shells
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--no-act[do not move the actual update into place]'
  '--verbose[be more verbose]'
  '--root[operate on the given chroot, defaults to /]'
  '*:filename:_files'
)

_arguments -s -S $arguments
