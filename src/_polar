#compdef polar

# Zsh completion for polar (Polar.sh CLI)

local -a commands
commands=(
  'login:Authenticate the CLI with your Polar account'
  'logout:Remove local authentication credentials'
  'listen:Tunnel webhook events to a local server'
  'init:Initialize a new Polar project or boilerplate'
  'help:Display help information'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[Display help information]' \
  '(- *)'{-v,--version}'[Show the current version]' \
  '1: :_describe -t commands "command" commands' \
  '*:: :->args'

case $words[1] in
  listen)
    _arguments \
      '1:URL:_urls'
    ;;
esac
