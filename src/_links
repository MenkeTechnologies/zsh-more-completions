#compdef links

local -a arguments

arguments=(
  '-help[prints this help screen]'
  '-version[prints the links version number and exit.]'
  '-lookup[does name lookup, like command "host".]'
  '-g[run in graphics mode.]'
  '-no-g[run in text mode (overrides previous -g).]'
  '-driver[graphics driver name]:driver:'
  '-mode[graphics mode]:mode:'
  '-display[set Xwindow display.]'
  '-force-html[treat files with unknown type as html rather than text.]'
  '-source[write unformatted data stream to stdout.]'
  '-dump[write formatted document to stdout.]'
  '-width[for dump, format document to this screen width]:width:'
  '-codepage[for dump, convert output to specified character set]:codepage:'
  '-anonymous[restrict links so that it can run on an anonymous account.]'
  '-no-connect[run links as a separate instance instead of connecting to an existing one]'
  '-download-dir[default download directory.]'
  '-language[set user interface language.]'
  '-max-connections[maximum number of concurrent connections.]'
  '-max-connections-to-host[maximum number of concurrent connection to a given host.]'
  '-retries[number of retries.]'
  '-receive-timeout[timeout on receive.]'
  '-unrestartable-receive-timeout[timeout on non restartable connections.]'
  '-timeout-when-trying-multiple-addresses[timeout for connection when trying multiple addresses.]'
  '-bind-address[bind to specified IP address]:address:'
  '-bind-address-ipv6[bind to specified IPv6 address]:address:'
  '-no-libevent[dont use libevent library.]'
  '-no-openmp[dont use OpenMP.]'
  '-async-dns[use asynchronous DNS resolver]:toggle:(0 1)'
  '-download-utime[set utime on downloaded files]:toggle:(0 1)'
  '-format-cache-size[number of formatted document pages cached.]'
  '-memory-cache-size[cache memory in bytes.]'
  '-image-cache-size[image cache in bytes.]'
  '-font-cache-size[font cache in bytes.]'
  '-aggressive-cache[enable aggressive caching]:toggle:(0 1)'
  '-address-preference[set address preference]:preference:(0 1 2 3 4)'
  '-http-proxy[host and port number of the HTTP proxy, or blank.]'
  '-ftp-proxy[host and port number of the FTP proxy, or blank.]'
  '-https-proxy[host and port number of the HTTPS proxy, or blank.]'
  '-socks-proxy[socks proxy (user@host:port)]:proxy:'
  '-append-text-to-dns-lookups[append text to dns lookups]:text:'
  '-no-proxy-domains[domains to bypass proxy]:domains:'
  '-only-proxies[only use proxies for all connections]:toggle:(0 1)'
  '-ssl.certificates[verify SSL certificates]:level:(0 1 2)'
  '-ssl.builtin-certificates[use builtin SSL certificates]:toggle:(0 1)'
  '-ssl.client-cert-key[SSL client certificate key file]:filename:_files'
  '-ssl.client-cert-crt[SSL client certificate file]:filename:_files'
  '-ssl.client-cert-password[SSL client certificate password]:text:'
  '-http-bugs.http10[use HTTP/1.0]:toggle:(0 1)'
  '-http-bugs.allow-blacklist[allow blacklisting]:toggle:(0 1)'
  '-http-bugs.bug-302-redirect[302 redirect workaround]:toggle:(0 1)'
  '-http-bugs.bug-post-no-keepalive[no keepalive after POST]:toggle:(0 1)'
  '-http-bugs.bug-no-accept-charset[no accept-charset]:toggle:(0 1)'
  '-http-bugs.no-compression[disable compression]:toggle:(0 1)'
  '-http-bugs.retry-internal-errors[retry internal errors]:toggle:(0 1)'
  '-http.fake-firefox[fake Firefox identity]:toggle:(0 1)'
  '-http.do-not-track[send do-not-track header]:toggle:(0 1)'
  '-http.referer[referer policy]:level:(0 1 2 3 4)'
  '-http.fake-referer[fake referer string]:string:'
  '-http.fake-user-agent[fake user agent string]:string:'
  '-http.extra-header[extra HTTP header]:string:'
  '-ftp.anonymous-password[anonymous FTP password]:string:'
  '-ftp.use-passive[use passive FTP]:toggle:(0 1)'
  '-ftp.use-eprt-epsv[use EPRT/EPSV]:toggle:(0 1)'
  '-ftp.fast[fast FTP mode]:toggle:(0 1)'
  '-ftp.set-iptos[set IP TOS]:toggle:(0 1)'
  '-smb.allow-hyperlinks-to-smb[allow hyperlinks to SMB]:toggle:(0 1)'
  '-menu-font-size[size of font in menu.]'
  '-menu-background-color[set menu background color in graphics mode, RRGGBB are hex.]'
  '-menu-foreground-color[set menu foreground color in graphics mode.]'
  '-scroll-bar-area-color[set color of scroll bar area.]'
  '-scroll-bar-bar-color[set color of scroll bar.]'
  '-scroll-bar-frame-color[set color of scroll bar frame.]'
  '-bookmarks-file[file to store bookmarks.]'
  '-bookmarks-codepage[character set of bookmarks file.]'
  '-save-url-history[save URL history]:toggle:(0 1)'
  '-display-red-gamma[red gamma of display.]'
  '-display-green-gamma[green gamma of display.]'
  '-display-blue-gamma[blue gamma of display.]'
  '-user-gamma[additional gamma.]'
  '-bfu-aspect[display aspect ration.]'
  '-dither-letters[dither letters]:toggle:(0 1)'
  '-dither-images[dither images]:toggle:(0 1)'
  '-display-optimize[display optimization level]:level:(0 1 2)'
  '-gamma-correction[gamma correction level]:level:(0 1 2)'
  '-overwrite-instead-of-scroll[overwrite instead of scroll]:toggle:(0 1)'
  '-html-assume-codepage[if server didnt specify document charset, assume this one]:codepage:'
)

_arguments -s -S $arguments
