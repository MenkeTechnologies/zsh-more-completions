#compdef brakeman

local -a arguments

arguments=(
  {-n,--no-threads}'[run checks sequentially]'
  {-p,--path}'[specify path to Rails application]'
  {-q,--quiet}'[suppress informational messages]'
  {-z,--exit-on-warn}'[exit code is non-zero if warnings found (Default)]'
  '--ensure-latest[fail when Brakeman is outdated]'
  {-3,--rails3}'[force Rails 3 mode]'
  {-4,--rails4}'[force Rails 4 mode]'
  {-5,--rails5}'[force Rails 5 mode]'
  {-6,--rails6}'[force Rails 6 mode]'
  {-A,--run-all-checks}'[run all default and optional checks]'
  {-a,--assume-all-routes}'[assume all controller methods are actions (Default)]'
  {-e,--escape-html}'[escape HTML by default]'
  '--faster[faster, but less accurate scan]'
  '--ignore-model-output[consider model attributes XSS-safe]'
  '--ignore-protected[consider models with attr_protected safe]'
  '--interprocedural[process method calls to known methods]'
  '--no-branching[disable flow sensitivity on conditionals]'
  '--branch-limit[limit depth of values in branches (-1 for no limit)]'
  '--parser-timeout[set parse timeout (Default: 10)]'
  {-r,--report-direct}'[only report direct use of untrusted data]'
  '-s[set methods as safe for unescaped output in views]:methods:'
  '--safe-methods[set methods as safe for unescaped output]:methods:'
  '--url-safe-methods[set methods as safe for URL generation]:methods:'
  '--skip-files[skip processing of these files/directories]:paths:'
  '--only-files[process only these files/directories]:paths:'
  '--skip-libs[skip processing lib directory]'
  '--add-libs-path[additional lib paths to process]:paths:'
  '--add-engines-path[additional engine paths to process]:paths:'
  {-E,--enable}'[1,Check2,etc Enable the specified checks]'
  {-t,--test}'[1,Check2,etc Only run the specified checks]'
  {-x,--except}'[1,Check2,etc Skip the specified checks]'
  '--add-checks-path[additional checks paths]:paths:'
  {-d,--debug}'[lots of output]'
  {-f,--format}'[specify output formats. Default is text]'
  '--css-file[specify CSS to use for HTML output]'
  {-i,--ignore-config}'[use configuration to ignore warnings]'
  {-I,--interactive-ignore}'[interactively ignore warnings]'
  {-l,--combine-locations}'[combine warning locations (Default)]'
  {-m,--routes}'[report controller information]'
  '--message-limit[limit message length in HTML report]'
  '--table-width[limit table width in text report]'
  {-o,--output}'[specify files for output. Defaults to stdout. Multiple -os allowed]'
  '--absolute-paths[output absolute file paths in reports]'
  '--github-repo[output links to GitHub in reports]:user/repo:'
  {-w,--confidence-level}'[set minimal confidence level (1 - 3)]'
  '--compare[compare the results of a previous Brakeman scan (only JSON is supported)]'
  {-c,--config-file}'[use specified configuration file]'
  {-C,--create-config}'[output configuration file based on options]'
  '--allow-check-paths-in-config[allow loading checks from configuration file (Unsafe)]'
  {-k,--checks}'[list all available vulnerability checks]'
  '--optional-checks[list optional checks]'
  {-v,--version}'[show Brakeman version]'
  '--force-scan[scan application even if rails is not detected]'
  '(- * :)'{-h,--help}'[display this message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
