#compdef tsql

local -a arguments

arguments=(
  '-a[specify application name]:name:'
  '-S[specify server entry in freetds.conf to connect]:server:'
  '-H[specify hostname to connect]:hostname:_hosts'
  '-p[specify port to connect to]:port:'
  '-U[specify username to use]:username:'
  '-P[specify password to use]:password:'
  '-D[specify database name to use]:database:'
  '-I[specify old configuration file (called interface) to use]:file:_files'
  '-J[specify character set to use]:charset:'
  '-v[verbose mode]'
  '-o[output options (f=no footer, h=no header, t=no separator)]:options:'
  '*:filename:_files'
)

_arguments -s -S $arguments
