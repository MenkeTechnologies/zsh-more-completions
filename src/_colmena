#compdef colmena

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'apply:apply configurations to remote machines'
  'apply-local:apply configurations to the local machine'
  'build:build configurations without applying'
  'upload-keys:upload secrets to remote machines'
  'exec:execute a command on remote machines'
  'repl:start an interactive Nix REPL'
  'nix-info:show Nix information for the configuration'
  'eval:evaluate an expression'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-f --config)'{-f,--config}'=[path to hive.nix or flake]:config:_files' \
  '--show-trace[show Nix evaluation trace on error]' \
  '--impure[allow impure expressions]' \
  '--nix-option=[set a Nix option]:option' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'colmena command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (apply)
        _arguments -s -S \
          '--on=[select nodes to apply to]:nodes' \
          '--parallel=[number of hosts to build in parallel]:count' \
          '--keep-result[keep build results]' \
          '--verbose[verbose output]' \
          '--no-keys[do not upload keys]' \
          '--reboot[reboot after activation]' \
          '--no-substitute[do not use binary caches]' \
          '--force-replace-unknown-profiles[force replace unknown profiles]' \
          '--evaluator=[evaluation strategy]:evaluator:(chunked streaming)' \
          '--eval-node-limit=[max nodes to evaluate at once]:limit' \
          '--no-build-on-target[do not build on target nodes]' \
          '--build-on-target[build on target nodes]' \
          '1:goal:(switch boot test dry-activate push keys)' && ret=0
        ;;
      (apply-local)
        _arguments -s -S \
          '--sudo[escalate with sudo]' \
          '--verbose[verbose output]' \
          '--no-substitute[do not use binary caches]' \
          '--node=[name of the local node]:node' \
          '1:goal:(switch boot test dry-activate)' && ret=0
        ;;
      (build)
        _arguments -s -S \
          '--on=[select nodes to build]:nodes' \
          '--parallel=[number of hosts to build in parallel]:count' \
          '--keep-result[keep build results]' \
          '--verbose[verbose output]' \
          '--no-substitute[do not use binary caches]' \
          '--evaluator=[evaluation strategy]:evaluator:(chunked streaming)' \
          '--eval-node-limit=[max nodes to evaluate at once]:limit' && ret=0
        ;;
      (exec)
        _arguments -s -S \
          '--on=[select nodes]:nodes' \
          '--parallel=[number of hosts in parallel]:count' \
          '--verbose[verbose output]' \
          '*:command' && ret=0
        ;;
      (upload-keys)
        _arguments -s -S \
          '--on=[select nodes]:nodes' \
          '--parallel=[number of hosts in parallel]:count' && ret=0
        ;;
    esac
    ;;
esac

return ret
