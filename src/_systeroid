#compdef systeroid

# Zsh completion for systeroid (sysctl TUI)

_arguments -s -S \
  '(-a --all)'{-a,--all}'[display all sysctl parameters]' \
  '(-T --tree)'{-T,--tree}'[display parameters as tree]' \
  '(-J --json)'{-J,--json}'[output as JSON]' \
  '(-D --docs)'{-D,--docs}'[show documentation for parameters]' \
  '(-E --explain)'{-E,--explain}'[explain parameter descriptions]' \
  '(-d --deprecated)'{-d,--deprecated}'[include deprecated parameters]' \
  '(-p --pattern)'{-p,--pattern}'[pattern to match]:pattern:' \
  '(-q --quiet)'{-q,--quiet}'[do not print key name]' \
  '(-w --write)'{-w,--write}'[write mode]' \
  '(-n --no-pager)'{-n,--no-pager}'[do not use a pager]' \
  '--no-color[disable color output]' \
  '--tui[launch the TUI]' \
  '--kernel-docs[path to kernel documentation]:path:_files -/' \
  '(-c --config)'{-c,--config}'[config file]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:parameter=value:' && return 0
