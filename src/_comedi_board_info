#compdef comedi_board_info
# Documentation: https://man.archlinux.org/search?q=comedi_board_info
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-n[number of channels for async command (default 1)]'
  '-F[probing sampling rate for async command (default 1Ghz)]'
  '-v[verbose output]'
  '-h[this help screen]'
  '*:filename:_files'
)

_arguments -s -S $arguments
