#compdef ubertooth-util

local -a arguments

arguments=(
  '-v[firmware revision number]'
  '-V[compile info]'
  '-I[identify ubertooth device by flashing all LEDs]'
  '-d[get/set all LEDs]:bool:(0 1)'
  '-l[get/set USR LED]:bool:(0 1)'
  '-S[stop current operation]'
  '-r[reset]'
  '-U[set ubertooth device to use]:0-7:'
  '-N[total number of Uberteeth and exit]'
  '-a[get/set power amplifier level]:level:'
  '-c[get/set channel in MHz]:channel:'
  '-C[get/set channel]:channel:'
  '-q[start LED spectrum analyzer]:rssi-threshold:'
  '-t[continuous transmit test]'
  '-z[set squelch level]:level:'
  '-e[set repeater mode]'
  '-m[get range test result]'
  '-n[initiate range test]'
  '-f[enter flash programming (DFU) mode]'
  '-i[enter in-System Programming (ISP) mode]'
  '-b[get hardware board id number]'
  '-p[get microcontroller Part ID]'
  '-s[get microcontroller serial number]'
  '*:filename:_files'
)

_arguments -s -S $arguments
