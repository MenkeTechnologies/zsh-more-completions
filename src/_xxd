#compdef xxd

local -a arguments

arguments=(
    '-a[toggle autoskip: A single * replaces nul-lines. Default off.]'
    '-b[binary digit dump (incompatible with -ps,-i,-r). Default hex.]'
    '-c[format octets per line. Default 16 (-i: 12, -ps: 30)]:cols:'
    '-E[show characters in EBCDIC. Default ASCII.]'
    '-e[little-endian dump (incompatible with -ps,-i,-r).]'
    '-g[number of octets per group in normal output. Default 2 (-e: 4)]:bytes:'
    '-h[print this summary.]'
    '-i[output in C include file style.]'
    '-l[stop after len octets]:len:'
    '-o[add offset to the displayed file position]:offset:'
    '-ps[output in postscript plain hexdump style.]'
    '-r[reverse operation: convert (or patch) hexdump into binary.]'
    '-s[start at seek bytes absolute (or +: relative) infile offset]:seek:'
    '-u[use upper case hex letters.]'
    '-v[show version: "xxd V1.10 27oct98 by Juergen Weigert".]'
    '*:filename:_files'
)

_arguments -s -S $arguments
