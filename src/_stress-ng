#compdef stress-ng

# Zsh completion for stress-ng (advanced system stress tester)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)--version[show version information]' \
  '--cpu[start N CPU stress workers]:workers:' \
  '--cpu-load[load CPU by percentage]:percent (0-100):' \
  '--cpu-method[specify CPU stress method]:method:(all ackermann bitops callfunc cdouble cfloat clongdouble correlate crc16 decimal32 decimal64 decimal128 dither div8 div16 div32 div64 double euler explog factorial fibonacci fft float float32 float64 float80 float128 fnv1a gamma gcd gray hamming hanoi hyperbolic idct int128 int64 int32 int16 int8 int128float int128double int128longdouble int128decimal32 int128decimal64 int128decimal128 int64float int64double int64longdouble int32float int32double int32longdouble jenkin jmp ln2 longdouble loop matrixprod nsqrt omega parity phi pi pjw prime psi queens rand rand48 rgb sieve stats sqrt trig union zeta)' \
  '--io[start N IO stress workers]:workers:' \
  '--vm[start N VM stress workers]:workers:' \
  '--vm-bytes[allocate N bytes per VM worker]:bytes:' \
  '--vm-method[specify VM stress method]:method:(all flip galpat-0 galpat-1 gray incdec inc-nybble rand-set rand-sum read64 ror swap move-inv modulo-x prime-0 prime-1 prime-gray-0 prime-gray-1 prime-incdec walk-0d walk-1d walk-0a walk-1a write64 zero-one)' \
  '--hdd[start N HDD stress workers]:workers:' \
  '--hdd-bytes[write N bytes per HDD worker]:bytes:' \
  '--sock[start N socket stress workers]:workers:' \
  {-t,--timeout}'[timeout after N seconds]:duration:' \
  '--metrics[print pseudo-anonymized metrics]' \
  '--metrics-brief[print brief metrics summary]' \
  '--times[show run time summary at end]' \
  {-v,--verbose}'[verbose output]' \
  {-q,--quiet}'[quiet output]' \
  '--log-file[log messages to file]:file:_files' \
  '--yaml[output results to YAML file]:file:_files' \
  '--class[specify stressor class]:class:(cpu cpu-cache device filesystem interrupt io memory network os pipe scheduler security vm)' \
  '--sequential[run stressors sequentially]:count:' \
  '--all[run all stressors]:count:' \
  '--parallel[run stressors in parallel]:count:' \
  '--random[start N random stressors]:count:' \
  '--taskset[set CPU affinity]:CPU list:' \
  '--temp-path[specify path for temporary files]:path:_files -/' \
  '--job[run stressors defined in job file]:file:_files' \
  '--seed[set random seed]:seed:' \
  '--backoff[wait N microseconds between stressor start]:microseconds:' \
  '--dry-run[do not run stressors, just parse options]' \
  '--aggressive[enable aggressive mode for all stressors]' \
  '--maximize[maximize stressor settings where possible]' \
  '--minimize[minimize stressor settings where possible]' \
  '--keep-name[keep stress-ng process name in child processes]'
