#compdef dnsrecon

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-d,--domain}'[target domain.]'
  {-n,--name_server}'[domain server to use]:ns_server'
  {-r,--range}'[IP range for reverse lookup brute force in formats]'
  {-D,--dictionary}'[dictionary file of subdomain and hostnames to use for brute force]:file:_files'
  '-f[filter out of brute force domain lookup records that resolve to wildcard]'
  {-t,--type}'[type of enumeration to perform.]:type'
  '-a[perform AXFR with standard enumeration.]'
  '-s[perform a reverse lookup of IPv4 ranges in the SPF record.]'
  '-g[perform Google enumeration with standard enumeration.]'
  '-b[perform Bing enumeration with standard enumeration.]'
  '-k[perform crt.sh enumeration with standard enumeration.]'
  '-w[perform deep whois record analysis and reverse lookup of IP ranges.]'
  '-z[performs a DNSSEC zone walk with standard enumeration.]'
  '--threads[number of threads to use in reverse lookups and forward brute force]:num'
  '--lifetime[time to wait for a server to respond to a query.]:seconds'
  '--db[SQLite 3 file to save found records.]:file:_files'
  {-x,--xml}'[XML file to save found records.]:file:_files'
  {-c,--csv}'[comma separated value file.]:file:_files'
  {-j,--json}'[JSON file.]:file:_files'
  '--iw[continue brute forcing a domain even if a wildcard is detected]'
  '-v[enable verbose]'
  '*:filename:_files'
)

_arguments -s -S $arguments
