#compdef crontab

local -a arguments

if [[ "$OSTYPE" == darwin* ]]; then
  # macOS crontab (Vixie Cron)
  arguments=(
    '-u[specify the user whose crontab is to be used]:user:_users'
    '(-l -r)-e[edit the current crontab]'
    '(-e -r)-l[display the current crontab on standard output]'
    '(-e -l)-r[remove the current crontab]'
    '1::crontab file:_files'
  )
else
  # Linux crontab (Vixie/ISC Cron or cronie)
  arguments=(
    '-u[specify the user whose crontab is to be used]:user:_users'
    '(-l -r)-e[edit the current crontab]'
    '(-e -r)-l[display the current crontab on standard output]'
    '(-e -l)-r[remove the current crontab]'
    '-i[prompt before deleting users crontab (use with -r)]'
    '-n[set host in cluster to run users crontabs]:hostname:_hosts'
    '-c[get host in cluster to run users crontabs]'
    '-s[append current SELinux security context string as MLS_LEVEL]'
    '-T[test whether crontab file is valid]:crontab file:_files'
    '-V[print version and exit]'
    '1::crontab file:_files'
  )
fi

_arguments -s -S $arguments
