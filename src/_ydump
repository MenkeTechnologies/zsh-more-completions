#compdef ydump

local -a arguments

arguments=(
  '-o[output file]'
  '-std[convert tuples and variants into standard JSON]'
  '-c[compact output (default: pretty-printed)]'
  '-s[streaming mode: read and write a sequence of JSON values]'
  '-u[a single JSON record is expected]'
  '-sort[sort object fields (default: preserve field order)]'
  '-ob[output as Biniou format]'
  '-version[print version of yojson and ydump and exit]'
  '-help[display this list of options]'
  '--help[display this list of options]'
  '*:filename:_files'
)

_arguments -s -S $arguments
