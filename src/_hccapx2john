#compdef hccapx2john
# Documentation: https://man.archlinux.org/search?q=hccapx2john
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[show this help message and exit]'
  '-nc[AP nonce correction to be used, 0 to disable, default 8]'
  '--no-mp[disable message_pair BE/LE/nc detection]'
  '*:filename:_files'
)

_arguments -s -S $arguments
