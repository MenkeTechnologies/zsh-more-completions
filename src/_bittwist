#compdef bittwist

local -a arguments

arguments=(
  '-d[print a list of network interfaces available]'
  '-v[print timestamp for each packet]'
  '-vv[print timestamp and hex data for each packet]'
  '-i[send pcap-file(s) through interface]:interface:'
  '-s[packet length to send]:length:'
  '-l[send pcap-file(s) for loop times]:loops:'
  '-c[send up to count packets]:count:'
  '-m[set interval multiplier speed]:speed:'
  '-r[limit the sending rate in Mbps]:rate:'
  '-p[set interval to sleep in seconds]:seconds:'
  '-h[print version information and usage]'
  '*:filename:_files'
)

_arguments -s -S $arguments
