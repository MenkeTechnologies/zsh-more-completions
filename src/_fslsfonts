#compdef fslsfonts
# Documentation: https://man.archlinux.org/search?q=fslsfonts
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-l[give long info about each font]'
  '-m[give character min and max bounds]'
  '-C[force columns]'
  '-1[force single column]'
  '-u[keep output unsorted]'
  '-w[maximum width for multiple columns]'
  '-n[number of columns if multi column]'
  '-server[font server to contact]'
  '-version[print command version and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
