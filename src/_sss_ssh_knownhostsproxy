#compdef sss_ssh_knownhostsproxy
# Documentation: https://man.archlinux.org/search?q=sss_ssh_knownhostsproxy
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-p,--port}'[the port to use to connect to the host]'
  {-d,--domain}'[the SSSD domain to use]'
  '--usage[display brief usage message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
