#compdef dart

local -a arguments

arguments=(
  '--enable-asserts[enable assert statements.]'
  {--help,-h}'[display this message (add -v or --verbose for all options)]'
  '--package-root[the path to the package root directory]:path:_files -/'
  '--packages[where to find a package spec file.]:file:_files'
  '--observe[enable the observation port on specified address and port]'
  '--enable-vm-service[enable the VM service on specified address and port]'
  '--pause-isolates-on-exit[pause isolates on exit]'
  '--pause-isolates-on-unhandled-exceptions[pause isolates on unhandled exceptions]'
  '--warn-on-pause-with-no-debugger[warn on pause with no debugger attached]'
  '--snapshot-kind[specify the snapshot kind to generate]:kind'
  '--snapshot[generate a snapshot of the loaded Dart script]:file:_files'
  '--version[print the VM version.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
