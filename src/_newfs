#compdef newfs

local -a arguments

arguments=(
  '-E[erase previous disk content]'
  '-J[enable journaling via gjournal]'
  '-L[add volume label to superblock]:label:'
  '-N[do not create file system, just print out parameters]'
  '-O[file system format: 1 => UFS1, 2 => UFS2]:format:'
  '-R[regression test, suppress random factors]'
  '-S[sector size]:size:'
  '-T[disk type]'
  '-U[enable soft updates]'
  '-a[maximum contiguous blocks]:blocks:'
  '-b[block size]:size:'
  '-c[cylinders per cylinder group]:cylinders:'
  '-d[maximum extent size]:size:'
  '-e[maximum blocks per file in a cylinder group]:blocks:'
  '-f[fragment size]:size:'
  '-g[average file size]:size:'
  '-h[average files per directory]:files:'
  '-i[number of bytes per inode]:bytes:'
  '-j[enable soft updates journaling]'
  '-k[space to hold for metadata blocks]:space:'
  '-l[enable multilabel MAC]'
  '-n[do not create .snap directory]'
  '-m[minimum free space percentage]:percent:'
  '-o[optimization preference]:preference:(space time)'
  '-p[partition name (a..h)]:partition:'
  '-r[reserved sectors at the end of device]:sectors:'
  '-s[file system size in sectors]:sectors:'
  '-t[enable TRIM]'
  '*:filename:_files'
)

_arguments -s -S $arguments
