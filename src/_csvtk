#compdef csvtk

# Zsh completion for csvtk (CSV/TSV toolkit)

local curcontext="$curcontext" state line ret=1

_csvtk_global_flags() {
  _arguments -s \
    '(-t --tabs)'{-t,--tabs}'[use tabs as delimiter]' \
    '(-d --delimiter)'{-d,--delimiter}'[field delimiter]:char' \
    '(-D --out-delimiter)'{-D,--out-delimiter}'[output field delimiter]:char' \
    '(-E --ignore-empty-rows)'{-E,--ignore-empty-rows}'[ignore empty rows]' \
    '(-H --no-header-row)'{-H,--no-header-row}'[input has no header row]' \
    '(-j --threads)'{-j,--threads}'[number of threads]:number' \
    '(-l --lazy-quotes)'{-l,--lazy-quotes}'[allow lazy quotes]' \
    '(-T --out-tabs)'{-T,--out-tabs}'[use tabs for output delimiter]' \
    '(-C --comment-char)'{-C,--comment-char}'[comment character]:char' \
    '(-U --delete-header)'{-U,--delete-header}'[delete header row]' \
    '(-I --ignore-illegal-row)'{-I,--ignore-illegal-row}'[ignore illegal rows]' \
    '--infile-list[file with list of input files]:file:_files' \
    '(-n --line-number)'{-n,--line-number}'[print line number]' \
    '(- *)'{-h,--help}'[show help]' \
    '*:input files:_files'
}

_csvtk() {
  local -a commands=(
    'headers:print header row'
    'head:print first N rows'
    'cat:concatenate CSV/TSV files'
    'sample:sampling by proportion'
    'cut:select columns'
    'uniq:unique rows'
    'freq:frequency of selected fields'
    'inter:intersection of multiple files'
    'grep:grep rows by column value'
    'filter:filter rows by values of selected fields'
    'filter2:filter rows by awk-like expressions'
    'join:join files by selected fields'
    'split:split CSV/TSV into multiple files'
    'splitxlsx:split XLSX sheet into multiple sheets'
    'collapse:collapse one field with selected fields as keys'
    'mutate:create new column from selected fields'
    'mutate2:create new column by awk-like expressions'
    'gather:gather columns into key-value pairs'
    'spread:spread a key-value pair across multiple columns'
    'sort:sort by selected fields'
    'plot:plot data'
    'pretty:convert CSV to readable aligned table'
    'csv2tab:convert CSV to tab-delimited'
    'tab2csv:convert tab-delimited to CSV'
    'csv2md:convert CSV to markdown table'
    'csv2rst:convert CSV to reStructuredText table'
    'csv2json:convert CSV to JSON format'
    'space2tab:convert space-delimited to tab-delimited'
    'transpose:transpose CSV data'
    'version:print version'
    'rename:rename column names'
    'rename2:rename column names by regular expression'
    'replace:replace data of selected fields by regular expression'
    'round:round float to n decimal places'
    'fold:fold multiple values of a field'
    'unfold:unfold a field with multiple values'
    'ncol:print number of columns'
    'nrow:print number of rows'
    'corr:calculate Pearson correlation between columns'
    'watch:monitor and online statistics'
    'fix:fix CSV/TSV with different numbers of columns'
    'del-header:delete header row'
    'add-header:add header row'
    'summary:summary statistics'
    'fix-quotes:fix malformed CSV with wrong quotes'
    'comb:compute combinations of items at every row'
    'sep:separate column into multiple columns'
    'genautocomplete:generate shell autocompletion script'
  )

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1:command:->command' \
    '*::args:->args' && ret=0

  case $state in
    command)
      _describe -t commands 'csvtk command' commands && ret=0
      ;;
    args)
      _csvtk_global_flags && ret=0
      ;;
  esac

  return ret
}

_csvtk "$@"
