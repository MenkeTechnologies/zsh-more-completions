#compdef qwen

# Zsh completion for Qwen Code CLI (Alibaba agentic coding tool)

local -a commands
commands=(
  'init:Analyze directory and create QWEN.md'
  'auth:Update API key or switch to Qwen OAuth'
  'model:Switch between different Qwen models'
  'clear:Reset chat history'
  'compact:Summarize history to save tokens'
  'settings:Configure language, theme, and preferences'
  'summary:Generate a high-level project summary'
  'resume:Resume a previous chat session'
  'stats:Display performance statistics'
  'exit:Exit the CLI'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[Show help message]' \
  '(- *)--version[Display version]' \
  '-p[Execute a single prompt]:prompt:' \
  '--source=[Specify model source]:source:(bailian)' \
  '1: :_describe -t commands "command" commands' \
  '*:: :->args'
