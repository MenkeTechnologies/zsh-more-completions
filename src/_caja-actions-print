#compdef caja-actions-print
# Documentation: https://man.archlinux.org/search?q=caja-actions-print
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  '--help-all[show all help options]'
  '--help-misc[miscellaneous options]'
  {-i,--id}'[the identifiant of the menu or the action to be printed]'
  {-f,--format}'[an export format \[Desktop1\]]'
  '*:filename:_files'
)

_arguments -s -S $arguments
