#compdef mongod

local -a arguments

arguments=(
  # General options
  '(- *)'{-h,--help}'[Show usage information]'
  '--version[Show version information]'
  {-f,--config}'[Configuration file specifying additional options]:config file:_files'
  '*'{-v,--verbose}'[Be more verbose (include multiple times for more verbosity)]'
  '--quiet[Quieter output]'

  # Network options
  '--port[Specify port number (default 27017)]:port'
  '--bind_ip[Comma separated list of IP addresses to listen on]:ip addresses'
  '--bind_ip_all[Bind to all IP addresses]'
  '--ipv6[Enable IPv6 support]'
  '--listenBacklog[Set socket listen backlog size]:backlog size'
  '--maxConns[Max number of simultaneous connections]:max connections'

  # Logging options
  '--logpath[Log file to send output to instead of stdout]:log file:_files'
  '--syslog[Log to system syslog facility instead of file or stdout]'
  '--syslogFacility[Syslog facility used for mongodb syslog messages]:facility'
  '--logappend[Append to logpath instead of overwriting]'
  '--logRotate[Set the log rotation behavior]:behavior:(rename reopen)'
  '--timeStampFormat[Desired format for timestamps in log messages]:format:(iso8601-utc iso8601-local)'

  # Process management
  '--pidfilepath[Full path to pidfile]:pid file:_files'
  '--timeZoneInfo[Full path to time zone info directory]:directory:_directories'
  '--nounixsocket[Disable listening on UNIX domain sockets]'
  '--unixSocketPrefix[Alternative directory for UNIX domain sockets]:directory:_directories'
  '--filePermissions[Permissions to set on UNIX domain socket file]:permissions'
  '--fork[Fork server process (background)]'

  # Security options
  '--keyFile[Private key for cluster authentication]:key file:_files'
  '--noauth[Run without security]'
  '--auth[Run with security]'
  '--transitionToAuth[For rolling access control upgrade]'
  '--clusterAuthMode[Authentication mode used for cluster authentication]:mode:(keyFile sendKeyFile sendX509 x509)'
  '*--setParameter[Set a configurable parameter]:parameter'
  '--clusterIpSourceAllowlist[Network CIDR specification of permitted origin for cluster authentication]:cidr'

  # TLS options (modern, replaces deprecated SSL options)
  '--tlsMode[Set the TLS operation mode]:mode:(disabled allowTLS preferTLS requireTLS)'
  '--tlsCertificateKeyFile[PEM file for TLS]:pem file:_files'
  '--tlsCertificateKeyFilePassword[Password for TLS PEM file]:password'
  '--tlsClusterFile[Key file for internal TLS authentication]:cluster file:_files'
  '--tlsClusterPassword[Internal authentication key file password]:password'
  '--tlsCAFile[Certificate authority file for TLS]:ca file:_files'
  '--tlsClusterCAFile[CA file for verifying cluster TLS peer certificates]:ca file:_files'
  '--tlsCRLFile[Certificate revocation list file for TLS]:crl file:_files'
  '--tlsDisabledProtocols[Comma separated list of TLS protocols to disable]:protocols'
  '--tlsAllowConnectionsWithoutCertificates[Allow client connections without presenting a certificate]'
  '--tlsAllowInvalidHostnames[Allow server certificates to provide non-matching hostnames]'
  '--tlsAllowInvalidCertificates[Allow connections to servers with invalid certificates]'
  '--tlsFIPSMode[Activate FIPS 140-2 mode at startup]'
  '--tlsLogVersions[Log TLS versions on connection]'

  # Deprecated SSL options (kept for backward compatibility)
  '--sslOnNormalPorts[Use SSL on configured ports (deprecated)]'
  '--sslMode[Set the SSL operation mode (deprecated, use --tlsMode)]:mode:(disabled allowSSL preferSSL requireSSL)'
  '--sslPEMKeyFile[PEM file for SSL (deprecated)]:pem file:_files'
  '--sslPEMKeyPassword[PEM file password (deprecated)]:password'
  '--sslClusterFile[Key file for internal SSL authentication (deprecated)]:file:_files'
  '--sslClusterPassword[Internal authentication key file password (deprecated)]:password'
  '--sslCAFile[Certificate authority file for SSL (deprecated)]:ca file:_files'
  '--sslCRLFile[Certificate revocation list file for SSL (deprecated)]:crl file:_files'
  '--sslDisabledProtocols[TLS protocols to disable (deprecated)]:protocols'
  '--sslWeakCertificateValidation[Allow client to connect without presenting a certificate (deprecated)]'
  '--sslAllowConnectionsWithoutCertificates[Allow connections without certificates (deprecated)]'
  '--sslAllowInvalidHostnames[Allow non-matching hostnames (deprecated)]'
  '--sslAllowInvalidCertificates[Allow invalid certificates (deprecated)]'
  '--sslFIPSMode[Activate FIPS 140-2 mode (deprecated)]'

  # Profiling options
  '--slowms[Value of slow for profile and console log (default 100)]:milliseconds'
  '--slowOpSampleRate[Fraction of slow ops to include in the profile and console log]:rate'
  '--profile[Profiling level: 0=off 1=slow 2=all]:level:(0 1 2)'

  # Storage options
  '--storageEngine[Storage engine to use]:engine:(wiredTiger)'
  '--dbpath[Directory for datafiles (default /data/db)]:directory:_directories'
  '--directoryperdb[Each database will be stored in a separate directory]'
  '--syncdelay[Seconds between disk syncs (0=never, default 60)]:seconds'
  '--upgrade[Upgrade db if needed]'
  '--repair[Run repair on all dbs]'
  '--repairpath[Root directory for repair files]:directory:_directories'
  '--journal[Enable journaling]'
  '--nojournal[Disable journaling]'
  '--journalCommitInterval[How often to group/batch commit (ms)]:interval'
  '--oplogMinRetentionHours[Minimum number of hours to preserve in the oplog]:hours'

  # WiredTiger options
  '--wiredTigerCacheSizeGB[Maximum amount of memory to allocate for cache]:size in GB'
  '--wiredTigerJournalCompressor[Compressor for journal data]:compressor:(none snappy zlib zstd)'
  '--wiredTigerDirectoryForIndexes[Put indexes and data in different directories]'
  '--wiredTigerCollectionBlockCompressor[Block compressor for collection data]:compressor:(none snappy zlib zstd)'
  '--wiredTigerIndexPrefixCompression[Use prefix compression on row-store leaf pages]'
  '--wiredTigerMaxCacheOverflowSizeGB[Maximum cache overflow file size]:size in GB'
  '--wiredTigerEngineConfigString[WiredTiger storage engine custom config]:config'
  '--wiredTigerCollectionConfigString[WiredTiger collection config]:config'
  '--wiredTigerIndexConfigString[WiredTiger index config]:config'

  # Replication options
  '--replSet[Replica set name and optional seed list]:setname'
  '--oplogSize[Size to use (in MB) for replication op log]:size in MB'
  '--enableMajorityReadConcern[Enable majority read concern]'

  # Sharding options
  '--configsvr[Declare this is a config db of a cluster]'
  '--shardsvr[Declare this is a shard db of a cluster]'
  '--clusterRole[Server role in a sharded cluster]:role:(configsvr shardsvr)'

  # Diagnostic options
  '--cpu[Periodically show CPU and iowait utilization]'
  '--sysinfo[Print some diagnostic system information]'
  '--shutdown[Kill a running server (for init scripts)]'
  '--networkMessageCompressors[Comma-separated list of compressors for network messages]:compressors'

  # Audit options
  '--auditDestination[Destination for audit logs]:destination:(syslog console file)'
  '--auditFilter[Filter to limit type of operations to audit]:filter'
  '--auditFormat[Format of the audit log output]:format:(JSON BSON)'
  '--auditPath[Path for the audit log file]:audit file:_files'

  # LDAP options
  '--ldapServers[LDAP server hostname or IP]:servers'
  '--ldapQueryUser[LDAP user used for queries]:user'
  '--ldapQueryPassword[Password for LDAP query user]:password'
  '--ldapBindWithOSDefaults[Use OS default credentials for LDAP bind]'
  '--ldapBindMethod[Method to authenticate to LDAP server]:method:(simple sasl)'
  '--ldapBindSASLMechanisms[SASL mechanisms for LDAP binding]:mechanisms'
  '--ldapTransportSecurity[Transport layer security for LDAP]:security:(none tls)'
  '--ldapTimeoutMS[Timeout in ms for LDAP operations]:timeout'
  '--ldapUserToDNMapping[Mapping of usernames to LDAP DNs]:mapping'
  '--ldapAuthzQueryTemplate[LDAP query template for authorization]:template'

  # Free Monitoring (deprecated in newer versions)
  '--enableFreeMonitoring[Enable free cloud monitoring]:state:(on off runtime)'

  '*:filename:_files'
)

_arguments -s -S $arguments
