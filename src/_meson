#compdef meson

# Zsh completion for meson build system
# Covers all subcommands with up-to-date options

_meson() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a commands
  commands=(
    'setup:configure the project'
    'configure:change project options'
    'compile:build the project'
    'test:run tests'
    'install:install the project'
    'dist:generate release archive'
    'introspect:introspect project'
    'init:create a new project'
    'env2mfile:convert environment to a cross or native file'
    'wrap:wrap tools'
    'subprojects:manage subprojects'
    'rewrite:modify the project definition'
    'devenv:run commands in developer environment'
    'reprotest:test if project builds reproducibly'
    'format:format meson source files'
    'fmt:format meson source files'
    'help:print help of a subcommand'
  )

  _arguments -C \
    '(- * :)'{-h,--help}'[show this help message and exit]' \
    '1:command:->cmds' \
    '*::arg:->args'

  case $state in
    cmds)
      _describe 'meson command' commands
      ;;
    args)
      local -a setup_configure_common=(
        '(-h --help)'{-h,--help}'[show help]'
        '--prefix=[installation prefix]:path:_directories'
        '--bindir=[executable directory]:path:_directories'
        '--datadir=[data file directory]:path:_directories'
        '--includedir=[header file directory]:path:_directories'
        '--infodir=[info page directory]:path:_directories'
        '--libdir=[library directory]:path:_directories'
        '--licensedir=[licenses directory]:path:_directories'
        '--libexecdir=[library executable directory]:path:_directories'
        '--localedir=[locale data directory]:path:_directories'
        '--localstatedir=[localstate data directory]:path:_directories'
        '--mandir=[manual page directory]:path:_directories'
        '--sbindir=[system executable directory]:path:_directories'
        '--sharedstatedir=[arch-independent data directory]:path:_directories'
        '--sysconfdir=[sysconf data directory]:path:_directories'
        '--auto-features=[override value of all auto features]:mode:(enabled disabled auto)'
        '--backend=[backend to use]:backend:(ninja vs vs2010 vs2012 vs2013 vs2015 vs2017 vs2019 vs2022 vs2026 xcode none)'
        '--genvslite=[generate VS lite solution]:version:(vs2022 vs2026)'
        '--buildtype=[build type to use]:type:(plain debug debugoptimized release minsize custom)'
        '--debug[enable debug symbols and other info]'
        '--default-library=[default library type]:type:(shared static both)'
        '--default-both-libraries=[default both_libraries type]:type:(shared static auto)'
        '--errorlogs[print logs for failing tests]'
        '--install-umask=[default umask for installed files]:umask:'
        '--layout=[build directory layout]:layout:(mirror flat)'
        '--namingscheme=[naming scheme for build dirs]:scheme:(platform classic)'
        '--optimization=[optimization level]:level:(plain 0 g 1 2 3 s)'
        '--prefer-static[prefer static linking]'
        '--stdsplit[split stdout and stderr in test logs]'
        '--strip[strip targets on install]'
        '--unity=[unity build]:mode:(on off subprojects)'
        '--unity-size=[number of sources per unity file]:size:'
        '--warnlevel=[compiler warning level]:level:(0 1 2 3 everything)'
        '--werror[treat warnings as errors]'
        '--wrap-mode=[wrap mode]:mode:(default nofallback nodownload forcefallback nopromote)'
        '--force-fallback-for=[force fallback for specified subprojects]:subprojects:'
        '--vsenv[activate Visual Studio environment]'
        '--pkg-config-path=[extra paths for pkg-config]:path:_directories'
        '--build.pkg-config-path=[extra pkg-config paths for build machine]:path:_directories'
        '--cmake-prefix-path=[extra paths for cmake]:path:_directories'
        '--build.cmake-prefix-path=[extra cmake paths for build machine]:path:_directories'
        '*-D[set option]:option:'
        '--native-file=[native compilation file]:file:_files'
        '--cross-file=[cross compilation file]:file:_files'
        '-v[verbose output]'
        '--fatal-meson-warnings[make meson warnings fatal]'
        '--clearcache[clear cached state]'
      )

      case $words[1] in
        setup)
          _arguments \
            $setup_configure_common \
            '--reconfigure[reconfigure existing build directory]' \
            '--wipe[wipe build directory and reconfigure]' \
            '1:build directory:_directories' \
            '2:source directory:_directories'
          ;;
        configure)
          _arguments \
            $setup_configure_common \
            '--no-pager[do not use pager for output]' \
            '-U[unset specified options]:option:' \
            '1:build directory:_directories'
          ;;
        compile)
          _arguments \
            '(-h --help)'{-h,--help}'[show help]' \
            '--clean[clean the build directory]' \
            '-C[directory to cd into before running]:directory:_directories' \
            {-j,--jobs}'=[number of parallel worker jobs]:jobs:' \
            {-l,--load-average}'=[system load average to try to maintain]:load:' \
            '(-v --verbose)'{-v,--verbose}'[show more verbose output]' \
            '--ninja-args=[arguments to pass to ninja]:args:' \
            '--vs-args=[arguments to pass to msbuild]:args:' \
            '--xcode-args=[arguments to pass to xcodebuild]:args:' \
            '*:target:'
          ;;
        test)
          _arguments \
            '(-h --help)'{-h,--help}'[show help]' \
            '--maxfail=[number of failures before aborting (0 to disable)]:count:' \
            '--repeat=[number of times to run the tests]:count:' \
            '--no-rebuild[do not rebuild before running tests]' \
            '--gdb[run test under gdb]' \
            '--gdb-path=[path to gdb binary]:path:_files' \
            '(-i --interactive)'{-i,--interactive}'[run tests with interactive input/output]' \
            '--list[list available tests]' \
            '--wrapper=[wrapper to run tests with (e.g. Valgrind)]:wrapper:_command_names' \
            '-C[directory to cd into before running]:directory:_directories' \
            '--suite=[only run tests belonging to given suite]:suite:' \
            '--no-suite=[do not run tests belonging to given suite]:suite:' \
            '--no-stdsplit[do not split stderr and stdout in test logs]' \
            '--print-errorlogs[print logs for failing tests]' \
            '--benchmark[run benchmarks instead of tests]' \
            '--logbase=[base name for log file]:name:' \
            {-j,--num-processes}'=[number of parallel test processes]:jobs:' \
            '(-v --verbose)'{-v,--verbose}'[do not redirect stdout and stderr]' \
            '(-q --quiet)'{-q,--quiet}'[produce less output to the terminal]' \
            {-t,--timeout-multiplier}'=[multiply test timeout by factor]:factor:' \
            '--setup=[which test setup to use]:setup:' \
            '--test-args=[arguments to pass to the specified test(s)]:args:' \
            '--max-lines=[maximum number of lines to show from a long test log]:lines:' \
            '--slice=[split tests into slices (SLICE/NUM_SLICES)]:slice:' \
            '*:test name:'
          ;;
        install)
          _arguments \
            '(-h --help)'{-h,--help}'[show help]' \
            '-C[directory to cd into before running]:directory:_directories' \
            '--no-rebuild[do not rebuild before installing]' \
            '--only-changed[only overwrite files that are older than the copied file]' \
            '(-q --quiet)'{-q,--quiet}'[do not print every installed file]' \
            '--destdir=[set or override DESTDIR environment]:directory:_directories' \
            '(-n --dry-run)'{-n,--dry-run}'[do not actually install, just print logs]' \
            '--skip-subprojects=-[do not install files from given subprojects]::subprojects:' \
            '--tags=[install only targets having one of the given tags]:tags:' \
            '--strip[strip targets even if strip option was not set during configure]'
          ;;
        dist)
          _arguments \
            '(-h --help)'{-h,--help}'[show help]' \
            '-C[directory to cd into before running]:directory:_directories' \
            '--allow-dirty[allow even when repository contains uncommitted changes]' \
            '--formats=[comma-separated list of archive types to create]:formats:(xztar bztar gztar zip)' \
            '--include-subprojects[include source code of subprojects used for the build]' \
            '--no-tests[do not build and test generated packages]'
          ;;
        introspect)
          _arguments \
            '(-h --help)'{-h,--help}'[show help]' \
            '--ast[dump the AST of the meson file]' \
            '--benchmarks[list all benchmarks]' \
            '--buildoptions[list all build options]' \
            '--buildsystem-files[list files that make up the build system]' \
            '--compilers[list used compilers]' \
            '--dependencies[list external dependencies]' \
            '--scan-dependencies[scan for dependencies used in meson.build]' \
            '--installed[list all installed files and directories]' \
            '--install-plan[list all installed files with details]' \
            '--machines[info about host, build, and target machines]' \
            '--projectinfo[information about projects]' \
            '--targets[list top level targets]' \
            '--tests[list all unit tests]' \
            '--backend=[backend to use for --buildoptions introspection]:backend:(ninja none vs vs2010 vs2012 vs2013 vs2015 vs2017 vs2019 vs2022 vs2026 xcode)' \
            '(-a --all)'{-a,--all}'[print all available information]' \
            '(-i --indent)'{-i,--indent}'[enable pretty printed JSON]' \
            '(-f --force-object-output)'{-f,--force-object-output}'[always use the new JSON format for multiple entries]' \
            '*:build directory:_directories'
          ;;
        init)
          _arguments \
            '(-h --help)'{-h,--help}'[show help]' \
            '-C[directory to cd into before running]:directory:_directories' \
            {-n,--name}'=[project name]:name:' \
            {-e,--executable}'=[executable name]:name:' \
            {-d,--deps}'=[dependencies, comma-separated]:deps:' \
            {-l,--language}'=[project language]:language:(c cpp cs cuda d fortran java objc objcpp rust vala)' \
            {-b,--build}'[build after generation]' \
            '--builddir=[directory for build]:directory:_directories' \
            {-f,--force}'[force overwrite of existing files and directories]' \
            '--type=[project type]:type:(executable library)' \
            '--version=[project version]:version:' \
            '*:source file:_files'
          ;;
        wrap)
          local -a wrap_cmds
          wrap_cmds=(
            'list:show all available projects'
            'search:search the db by name'
            'install:install the specified project'
            'update:update wrap files from WrapDB'
            'info:show available versions of a project'
            'status:show installed and available versions'
            'promote:bring a subsubproject up to the master project'
            'update-db:update list of projects available in WrapDB'
          )
          _describe 'wrap command' wrap_cmds
          ;;
        subprojects)
          local -a sub_cmds
          sub_cmds=(
            'update:update all subprojects from wrap files'
            'checkout:checkout a branch (git only)'
            'download:ensure subprojects are fetched'
            'foreach:execute a command in each subproject directory'
            'purge:remove all wrap-based subproject artifacts'
            'packagefiles:manage the packagefiles overlay'
          )
          _describe 'subprojects command' sub_cmds
          ;;
        rewrite)
          _arguments \
            '(-h --help)'{-h,--help}'[show help]' \
            {-s,--sourcedir}'=[path to source directory]:directory:_directories' \
            '(-V --verbose)'{-V,--verbose}'[enable verbose output]' \
            '(-S --skip-errors)'{-S,--skip-errors}'[skip errors instead of aborting]' \
            '1:rewrite command:(target tgt kwargs default-options def command cmd)'
          ;;
        devenv)
          _arguments \
            '(-h --help)'{-h,--help}'[show help]' \
            '-C[path to build directory]:directory:_directories' \
            '(--workdir -w)'{--workdir,-w}'=[directory to cd into before running]:directory:_directories' \
            '--dump=-[only print required environment, optionally to a file]::file:_files' \
            '--dump-format=[format used with --dump]:format:(sh export vscode)' \
            '*:command:_command_names'
          ;;
        env2mfile)
          _arguments \
            '(-h --help)'{-h,--help}'[show help]' \
            '--debarch=[dpkg architecture to generate]:arch:' \
            '--gccsuffix=[particular gcc version suffix]:suffix:' \
            '-o[output file or directory]:file:_files' \
            '--cross[generate a cross compilation file]' \
            '--native[generate a native compilation file]' \
            '--android[generate cross files for Android toolchains]' \
            '--use-for-build[use _FOR_BUILD envvars]' \
            '--system=[define system for cross compilation]:system:' \
            '--subsystem=[define subsystem for cross compilation]:subsystem:' \
            '--kernel=[define kernel for cross compilation]:kernel:' \
            '--cpu=[define cpu for cross compilation]:cpu:' \
            '--cpu-family=[define cpu family for cross compilation]:cpu_family:' \
            '--endian=[define endianness for cross compilation]:endian:(big little)'
          ;;
        reprotest)
          _arguments \
            '(-h --help)'{-h,--help}'[show help]' \
            '--intermediaries[check intermediate files]' \
            '*:meson args:'
          ;;
        format|fmt)
          _arguments \
            '(-h --help)'{-h,--help}'[show help]' \
            '(-q --check-only -d --check-diff -i --inplace)'{-q,--check-only}'[exit with 1 if files would be modified]' \
            '(-q --check-only -d --check-diff -i --inplace)'{-d,--check-diff}'[exit with 1 and show diff if files would be modified]' \
            '(-q --check-only -d --check-diff -i --inplace)'{-i,--inplace}'[format files in-place]' \
            '(-r --recursive)'{-r,--recursive}'[recurse into subdirectories]' \
            {-c,--configuration}'=[read configuration from file]:file:_files' \
            '(-e --editor-config)'{-e,--editor-config}'[try to read configuration from .editorconfig]' \
            {-o,--output}'=[output file]:file:_files' \
            '--source-file-path=[path to use when reading from stdin]:path:_files' \
            '*:source file:_files'
          ;;
        help)
          _describe 'meson command' commands
          ;;
        *)
          _files
          ;;
      esac
      ;;
  esac
}

_meson "$@"
