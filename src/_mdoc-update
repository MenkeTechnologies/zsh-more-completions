#compdef mdoc-update

local -a arguments

arguments=(
  '--delete[delete removed members from the XML files.]'
  '--exceptions[document potential exceptions that members can throw]'
  '-f[specify a FLAG to alter behavior. See later -f*]'
  '--fignore-missing-types[do not report an error if a --type=TYPE type]'
  '--fno-assembly-versions[do not generate //AssemblyVersion elements.]'
  {-i,--import}'[import documentation from FILE.]'
  {-L,--lib}'[check for assembly references in DIRECTORY.]'
  '--library[ignored for compatibility with update-ecma-xml.]'
  {-o,--out}'[root DIRECTORY to generate/update documentation.]'
  '-r[search for dependent assemblies in the directory containing the assembly]'
  '--since[manually specify the assembly VERSION that new members were added in]'
  '--type[only update documentation for TYPE.]'
  '--dropns[when processing assembly ASSEMBLY, strip off the specified prefix]'
  '--ntypes[if the new assembly is switching to magic types, use this option]'
  '--preserve[do not delete members that dont exist in the new assembly]'
  '--api-style[denotes the API style. Currently, only classic is supported]'
  {--fx,--frameworks}'[configuration XML file that points to framework directories]'
  '--use-docid[add DocId to the list of type and member attributes]'
  '-h[show this message and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
