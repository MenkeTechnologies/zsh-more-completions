#compdef yq

# Zsh completion for yq - YAML/JSON/XML processor (mikefarah/yq)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-C,--colors}'[force print with colors]' \
  {-M,--no-colors}'[force print without colors]' \
  {-e,--exit-status}'[set exit status for no matches]' \
  '--expression[force expression as argument]:expression:' \
  '--from-file[load expression from file]:file:_files' \
  {-f,--front-matter}'[process front matter]:handler:(extract process)' \
  '--header-preprocess[recalculate header count on split]' \
  {-I,--indent}'[sets indent level]:indent:' \
  {-i,--inplace}'[update the file inplace]' \
  {-p,--input-format}'[input format]:format:(yaml json props csv tsv xml toml lua)' \
  {-o,--output-format}'[output format]:format:(yaml json props csv tsv xml toml lua)' \
  {-N,--no-doc}'[do not print document separators]' \
  {-n,--null-input}'[do not read input]' \
  {-P,--prettyPrint}'[pretty print output]' \
  '--split-exp[split output based on expression]:expression:' \
  {-s,--split-exp-file}'[split output into files]:expression:' \
  '--unwrapScalar[unwrap scalar values]' \
  '--no-unwrapScalar[do not unwrap scalar values]' \
  '--verbose[verbose mode]' \
  '--xml-attribute-prefix[prefix for XML attributes]:prefix:' \
  '--xml-content-name[name for XML content]:name:' \
  '--xml-strict-mode[strict XML parsing]' \
  '--xml-skip-directives[skip XML directives]' \
  '--xml-skip-proc-inst[skip XML processing instructions]' \
  '--xml-raw-token[output raw XML tokens]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'eval:evaluate expression (default)'
      'eval-all:evaluate expression against all documents'
      'completion:generate shell completion'
      'help:show help'
    )
    _describe -t commands 'command' commands && ret=0
    _files && ret=0
    ;;
  (args)
    case $line[1] in
      (eval|eval-all)
        _arguments \
          '*:file:_files' \
          && ret=0
        ;;
      (completion)
        _arguments \
          '1:shell:(bash fish powershell zsh)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
