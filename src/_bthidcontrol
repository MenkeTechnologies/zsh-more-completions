#compdef bthidcontrol
# Documentation: https://man.archlinux.org/search?q=bthidcontrol
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-a[specify bdaddr]'
  '-c[specify path to the bthidd config file]'
  '-H[specify path to the bthidd HIDs file]'
  '-h[display usage and quit]'
  '-v[be verbose]'
  '*:filename:_files'
)

_arguments -s -S $arguments
