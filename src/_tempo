#compdef tempo

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,-help}'[show help]' \
  '(- *)-version[show version]' \
  '-config.file=[YAML config file]:config file:_files' \
  '-config.expand-env[expand environment variables in config]' \
  '-target=[module to run]:target:(all distributor ingester querier query-frontend compactor metrics-generator)' \
  '-server.http-listen-address=[HTTP server listen address]:address' \
  '-server.http-listen-port=[HTTP server listen port]:port' \
  '-server.grpc-listen-address=[gRPC server listen address]:address' \
  '-server.grpc-listen-port=[gRPC server listen port]:port' \
  '-log.level=[log level]:level:(debug info warn error)' \
  '-log.format=[log format]:format:(logfmt json)' \
  '-mem-ballast-size-mbs=[size of memory ballast in MBs]:size' \
  '-print-config[dump the whole config]' \
  '-storage.trace.backend=[storage backend]:backend:(local gcs s3 azure)' \
  '-storage.trace.local.path=[local storage path]:directory:_directories' \
  '-storage.trace.s3.bucket=[S3 bucket name]:bucket' \
  '-storage.trace.s3.endpoint=[S3 endpoint]:endpoint' \
  '-storage.trace.gcs.bucket=[GCS bucket name]:bucket' && ret=0

return ret
