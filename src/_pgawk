#compdef pgawk

local -a arguments

arguments=(
  {-f,--file}'[read program source from file]:file:_files'
  {-F,--field-separator}'[set field separator]:separator'
  {-v,--assign}'[assign a variable value]:var=val'
  {-b,--characters-as-bytes}'[treat all input data as single-byte characters]'
  {-c,--traditional}'[run in compatibility mode]'
  {-C,--copyright}'[print short version of copyright information]'
  {-d,--dump-variables}'[dump global variables to file]:file:_files'
  {-e,--source}'[use program text as source]:program-text'
  {-E,--exec}'[execute program from file]:file:_files'
  {-g,--gen-pot}'[scan and parse the AWK program and generate a GNU .pot file]'
  '(- * :)'{-h,--help}'[print this help message and exit]'
  {-L,--lint}'[provide warnings about dubious constructs]'
  {-n,--non-decimal-data}'[recognize octal and hexadecimal values in input data]'
  {-N,--use-lc-numeric}'[use locale decimal point character for parsing input data]'
  {-O,--optimize}'[enable optimization of the internal representation]'
  {-p,--profile}'[output profiling data to file]:file:_files'
  {-P,--posix}'[operate in strict POSIX mode]'
  {-r,--re-interval}'[enable interval expressions in regular expressions]'
  {-S,--sandbox}'[run in sandbox mode, disabling system function]'
  {-t,--lint-old}'[provide warnings about non-portable constructs]'
  {-V,--version}'[print version information and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
