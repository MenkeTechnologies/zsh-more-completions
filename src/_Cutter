#compdef Cutter
# Documentation: https://man.archlinux.org/search?q=Cutter
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[displays this help.]'
  {-v,--version}'[displays version information.]'
  {-A,--anal}'[automatically open file and optionally start]'
  '-i[run script file]'
  '--pythonhome[PYTHONHOME to use for Jupyter]'
  '*:filename:_files'
)

_arguments -s -S $arguments
