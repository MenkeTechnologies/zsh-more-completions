#compdef gnome-session-selector
# Documentation: https://man.archlinux.org/search?q=gnome-session-selector
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  '--help-all[show all help options]'
  '--help-gtk[show GTK+ Options]'
  '--action[what to do with session selection (save|load|print)]'
  '--display[X display to use]'
  '*:filename:_files'
)

_arguments -s -S $arguments
