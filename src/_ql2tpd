#compdef ql2tpd
# Documentation: https://man.archlinux.org/search?q=ql2tpd
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '--config[specify configuration file path (default \\\[lq\]/etc/ql2tpd/ql2tpd. toml\\\[rq\]).]:string'
    '--verbose[toggle verbose log output]'
    '*:filename:_files'
)
_arguments -s -S $arguments
