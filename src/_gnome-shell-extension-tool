#compdef gnome-shell-extension-tool
# Documentation: https://man.archlinux.org/search?q=gnome-shell-extension-tool
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-d,--disable-extension}'[disable a GNOME Shell extension]'
  {-e,--enable-extension}'[enable a GNOME Shell extension]'
  {-c,--create-extension}'[create a new GNOME Shell extension]'
  {-r,--reload-extension}'[reload a GNOME Shell extension]'
  '*:filename:_files'
)

_arguments -s -S $arguments
