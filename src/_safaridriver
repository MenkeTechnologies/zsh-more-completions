#compdef safaridriver

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[prints out this usage information.]'
  {-p,--port}'[port number the driver should use]:port'
  '--enable[apply configuration changes for WebDriver testing]'
  '--w3c[use the standards-compliant W3C WebDriver protocol (default).]'
  '--legacy[use the legacy Selenium WebDriver protocol.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
