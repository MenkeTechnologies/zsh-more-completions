#compdef etc1tool
# Documentation: https://man.archlinux.org/search?q=etc1tool
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--help[print this usage information.]'
  '--encode[create an ETC1 file from a PNG file.]'
  '--encodeNoHeader[a raw ETC1 data file (without a header) from a PNG file.]'
  '--decode[create a PNG file from an ETC1 file.]'
  '--showDifference[write difference between original and encoded]'
  '*:filename:_files'
)

_arguments -s -S $arguments
