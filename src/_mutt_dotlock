#compdef mutt_dotlock
# Documentation: https://man.archlinux.org/search?q=mutt_dotlock
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-t[try]'
  '-f[force]'
  '-u[unlock]'
  '-d[unlink]'
  '-p[privileged]'
  '-r[retry locking]'
  '*:filename:_files'
)

_arguments -s -S $arguments
