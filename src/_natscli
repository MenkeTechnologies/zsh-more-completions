#compdef nats

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'pub:publish a message to a subject'
  'sub:subscribe to a subject'
  'request:send a request to a subject'
  'reply:listen for requests on a subject'
  'bench:benchmark NATS'
  'server:manage NATS servers'
  'stream:manage JetStream streams'
  'consumer:manage JetStream consumers'
  'kv:manage JetStream key-value stores'
  'object:manage JetStream object stores'
  'account:manage accounts'
  'context:manage nats contexts'
  'events:show account events'
  'errors:show NATS error codes'
  'latency:perform latency testing'
  'rtt:compute round-trip time'
  'cheat:cheatsheets for NATS CLI'
  'backup:backup JetStream configuration'
  'restore:restore JetStream configuration'
  'governor:manage concurrency governor'
  'micro:interact with micro services'
  'schema:schema tools'
  'auth:NATS decentralized auth'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-s --server)'{-s,--server}'=[NATS server URLs]:server url' \
  '--user=[username]:username' \
  '--password=[password]:password' \
  '--creds=[user credentials file]:creds file:_files' \
  '--nkey=[user NKey]:nkey file:_files' \
  '--tlscert=[TLS public certificate]:cert file:_files' \
  '--tlskey=[TLS private key]:key file:_files' \
  '--tlsca=[TLS certificate authority chain]:ca file:_files' \
  '--timeout=[connection timeout]:timeout' \
  '--context=[configuration context]:context' \
  '--js-domain=[JetStream domain]:domain' \
  '--js-api-prefix=[JetStream API prefix]:prefix' \
  '--js-event-prefix=[JetStream event prefix]:prefix' \
  '--trace[enable protocol trace]' \
  '--no-context[do not use context]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'nats command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (pub)
        _arguments -s -S \
          '--count=[publish N messages]:count' \
          '--sleep=[sleep between messages]:duration' \
          '--header=[add headers]:header (Key\:Value)' \
          '--reply=[set reply subject]:subject' \
          '1:subject' \
          '2:body' && ret=0
        ;;
      (sub)
        _arguments -s -S \
          '--raw[show raw message]' \
          '--count=[quit after N messages]:count' \
          '--queue=[queue group name]:group' \
          '--inbox[subscribe to a generated inbox]' \
          '--headers-only[show only headers]' \
          '--dump=[dump messages to directory]:directory:_directories' \
          '1:subject' && ret=0
        ;;
      (request)
        _arguments -s -S \
          '--count=[send N requests]:count' \
          '--header=[add headers]:header (Key\:Value)' \
          '--raw[show raw response]' \
          '--timeout=[request timeout]:timeout' \
          '1:subject' \
          '2:body' && ret=0
        ;;
      (stream)
        local -a stream_cmds=(
          'add:create a new stream'
          'edit:edit an existing stream'
          'info:show stream information'
          'ls:list known streams'
          'rm:remove a stream'
          'purge:purge a stream of all data'
          'get:retrieve a specific message'
          'rmm:securely remove a message'
          'view:view messages in a stream'
          'copy:create a new stream based on source'
          'seal:seal a stream preventing further modification'
          'cluster:manage stream clustering'
          'find:find streams matching certain criteria'
          'report:report on stream statistics'
          'backup:backup stream configuration and data'
          'restore:restore a stream from backup'
          'template:manage stream templates'
        )
        _arguments \
          '1:subcommand:_describe -t stream-commands "stream command" stream_cmds' \
          '*:args' && ret=0
        ;;
      (consumer)
        local -a consumer_cmds=(
          'add:create a new consumer'
          'edit:edit an existing consumer'
          'info:show consumer information'
          'ls:list known consumers'
          'rm:remove a consumer'
          'next:request messages from pull consumer'
          'sub:subscribe to push consumer'
          'copy:copy a consumer'
          'report:report on consumer statistics'
        )
        _arguments \
          '1:subcommand:_describe -t consumer-commands "consumer command" consumer_cmds' \
          '*:args' && ret=0
        ;;
      (kv)
        local -a kv_cmds=(
          'add:add a new KV store'
          'put:put a value for a key'
          'get:get a value for a key'
          'del:delete a key'
          'purge:purge all values for a key'
          'create:create a key'
          'history:show the history for a key'
          'status:show the status of a KV store'
          'watch:watch for changes on a KV store'
          'ls:list KV store contents'
          'rm:remove a KV store'
          'compact:compact a KV store'
        )
        _arguments \
          '1:subcommand:_describe -t kv-commands "kv command" kv_cmds' \
          '*:args' && ret=0
        ;;
      (context)
        local -a ctx_cmds=(
          'save:save or update a context'
          'select:select the default context'
          'ls:list known contexts'
          'rm:remove a context'
          'show:show a context'
          'edit:edit a context'
          'validate:validate all contexts'
        )
        _arguments \
          '1:subcommand:_describe -t ctx-commands "context command" ctx_cmds' \
          '*:args' && ret=0
        ;;
      (server)
        local -a server_cmds=(
          'info:show server information'
          'list:list known servers'
          'ping:ping all servers'
          'report:report on server statistics'
          'request:request data from servers'
          'raft:manage RAFT clustering'
          'passwd:manage server passwords'
          'check:health check NATS servers'
          'generate:generate server config'
          'mapping:manage subject mappings'
        )
        _arguments \
          '1:subcommand:_describe -t server-commands "server command" server_cmds' \
          '*:args' && ret=0
        ;;
    esac
    ;;
esac

return ret
