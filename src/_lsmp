#compdef lsmp
# Documentation: https://man.archlinux.org/search?q=lsmp
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-p[print all mach ports for process id <pid>.]'
  '-a[print all mach ports for all processeses.]'
  '-v[print verbose details for kernel objects.]'
  '-j[save output as JSON to <path>.]'
  '-h[print this help.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
