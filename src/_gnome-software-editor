#compdef gnome-software-editor
# Documentation: https://man.archlinux.org/search?q=gnome-software-editor
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  '--verbose[use verbose logging]'
  '*:filename:_files'
)

_arguments -s -S $arguments
