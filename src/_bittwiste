#compdef bittwiste

local -a arguments

arguments=(
  '-I[input pcap based trace file]:file:_files'
  '-O[output trace file]:file:_files'
  '-L[copy up to the specified layer and discard the rest]:layer:'
  '-X[append payload in hex digits to the end of each packet]:hex:'
  '-C[disable checksum correction]'
  '-M[replace the linktype stored in the pcap file header]:linktype:'
  '-D[delete the specified byte offset from each packet]:offset:'
  '-R[save only the specified range of packets]:range:'
  '-S[save only packets within the specified timeframe]:timeframe:'
  '-T[edit only the specified header]:header:'
  '-h[print version information and usage]'
  '*:filename:_files'
)

_arguments -s -S $arguments
