#compdef git-sizer

# Zsh completion for git sizer (compute repository size metrics)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-v --verbose)'{-v,--verbose}'[report all statistics]' \
  '--no-progress[suppress progress output]' \
  '--json[output in JSON format]' \
  '--json-version[set JSON output version]:version:(1 2)' \
  '--threshold[minimum level of concern to report]:level:(informational notable large none)' \
  '--names[how to display names]:mode:(none hash print)' \
  '--branches[process branches]' \
  '--tags[process tags]' \
  '--remotes[process remotes]' \
  '--refgroup[add a reference group pattern]:pattern:' \
  '--include[include refs matching pattern]:pattern:' \
  '--exclude[exclude refs matching pattern]:pattern:' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
