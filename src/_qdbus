#compdef qdbus
# Documentation: https://man.archlinux.org/search?q=qdbus
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--system[connect to the system bus]'
  '--address[connect to the given bus]'
  '--literal[print replies literally]'
  '*:filename:_files'
)

_arguments -s -S $arguments
