#compdef texluac
# Documentation: https://man.archlinux.org/search?q=texluac
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-l[list (use -l -l for full listing)]'
  '-o[output to file name (default is "texluac.out")]'
  '-p[parse only]'
  '-s[strip debug information]'
  '-v[show version information]'
  '*:filename:_files'
)

_arguments -s -S $arguments
