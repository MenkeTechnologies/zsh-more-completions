#compdef copier

# Zsh completion for copier - project template tool

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'copy:copy a template to a destination'
  'recopy:recopy a template to a destination'
  'update:update a project from its template'
  'worker:internal worker subcommand'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*:option:->options' && ret=0

case $state in
  (command)
    _describe -t commands 'copier command' subcommands && ret=0
    ;;
  (options)
    case ${line[1]} in
      (copy)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-a --answers-file)'{-a,--answers-file}'[path to answers file]:answers file:_files' \
          '--cleanup-on-error[cleanup on error]' \
          '--no-cleanup-on-error[do not cleanup on error]' \
          '--conflict[how to handle file conflicts]:conflict:(inline rej)' \
          '*'{-d,--data}'[data key=value pair]:key=value:' \
          '--data-file[path to data file]:data file:_files' \
          '--defaults[use default answers]' \
          '*--exclude[exclude pattern]:pattern:' \
          '--overwrite[overwrite existing files]' \
          '--no-overwrite[do not overwrite existing files]' \
          '--pretend[do not write any files]' \
          '(-q --quiet)'{-q,--quiet}'[suppress output]' \
          '*--skip-if-exists[skip existing files matching pattern]:pattern:' \
          '--trust[trust the template]' \
          '--vcs-ref[VCS reference]:ref:' \
          '--UNSAFE[allow running unsafe templates]' \
          '1:template source:_files -/' \
          '2:destination:_files -/' && ret=0
        ;;
      (recopy)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-a --answers-file)'{-a,--answers-file}'[path to answers file]:answers file:_files' \
          '--conflict[how to handle file conflicts]:conflict:(inline rej)' \
          '*'{-d,--data}'[data key=value pair]:key=value:' \
          '--data-file[path to data file]:data file:_files' \
          '--defaults[use default answers]' \
          '*--exclude[exclude pattern]:pattern:' \
          '--overwrite[overwrite existing files]' \
          '--no-overwrite[do not overwrite existing files]' \
          '--pretend[do not write any files]' \
          '(-q --quiet)'{-q,--quiet}'[suppress output]' \
          '*--skip-if-exists[skip existing files matching pattern]:pattern:' \
          '--trust[trust the template]' \
          '--vcs-ref[VCS reference]:ref:' \
          '--UNSAFE[allow running unsafe templates]' \
          '1:destination:_files -/' && ret=0
        ;;
      (update)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-a --answers-file)'{-a,--answers-file}'[path to answers file]:answers file:_files' \
          '--conflict[how to handle file conflicts]:conflict:(inline rej)' \
          '--context-lines[number of context lines for conflict markers]:lines:' \
          '*'{-d,--data}'[data key=value pair]:key=value:' \
          '--data-file[path to data file]:data file:_files' \
          '--defaults[use default answers]' \
          '*--exclude[exclude pattern]:pattern:' \
          '--overwrite[overwrite existing files]' \
          '--pretend[do not write any files]' \
          '(-q --quiet)'{-q,--quiet}'[suppress output]' \
          '*--skip-if-exists[skip existing files matching pattern]:pattern:' \
          '--trust[trust the template]' \
          '--vcs-ref[VCS reference]:ref:' \
          '--UNSAFE[allow running unsafe templates]' \
          '1:destination:_files -/' && ret=0
        ;;
      (*)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
