#compdef pdftk

# Zsh completion for pdftk - PDF toolkit

local curcontext="$curcontext" state line ret=1

local -a operations=(
  'cat:concatenate pages from input PDFs to create a new PDF'
  'shuffle:interleave pages from input PDFs to create a new PDF'
  'burst:split a single input PDF document into individual pages'
  'rotate:rotate specified pages in the PDF'
  'generate_fdf:generate FDF file suitable for fill_form'
  'fill_form:fill PDF form fields using FDF or XFDF data'
  'background:apply a PDF watermark to the background of each page'
  'multibackground:apply PDF watermarks to background'
  'stamp:apply a PDF watermark to the foreground of each page'
  'multistamp:apply PDF watermarks to foreground'
  'dump_data:read PDF document info and print to stdout'
  'dump_data_utf8:same as dump_data but output in UTF-8 encoding'
  'dump_data_fields:read PDF form field data'
  'dump_data_fields_utf8:read PDF form field data in UTF-8'
  'dump_data_annots:read PDF annotation data'
  'update_info:update PDF document info with data from stdin'
  'update_info_utf8:update PDF document info in UTF-8'
  'attach_files:attach files to PDF'
  'unpack_files:unpack files attached to PDF'
)

_arguments -s -S \
  '*:input PDF or operation:->input_or_op' && ret=0

case $state in
  input_or_op)
    _alternative \
      'files:PDF file:_files -g "*.pdf"' \
      'operations:operation:((${(j: :)${operations// /\\:}}))' \
      && ret=0
    ;;
esac

return ret
