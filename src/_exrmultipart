#compdef exrmultipart
# Documentation: https://man.archlinux.org/search?q=exrmultipart
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-override[0/1\] 0-do not override conflicting shared attributes \[default\]]'
  '-view[(after specifying -i) assign following inputs to view name]'
  '*:filename:_files'
)

_arguments -s -S $arguments
