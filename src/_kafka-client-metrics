#compdef kafka-client-metrics

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--command-config[Property file with configs to pass to Admin Client]:file:_files'
    '--alter[Alter client metrics configuration]'
    '--delete[Delete client metrics configuration]'
    '--describe[Describe client metrics configuration]'
    '--list[List client metrics configurations]'
    '--name[Name of the client metrics subscription]:name:'
    '--metrics[Comma-separated list of metric prefixes]:metrics:'
    '--interval[Push interval in milliseconds]:ms:'
    '--match[Client match patterns]:pattern:'
)

_arguments -s -S $arguments
