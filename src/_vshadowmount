#compdef vshadowmount
# Documentation: https://man.archlinux.org/search?q=vshadowmount
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[shows this help]'
  '-o[specify the volume offset in bytes]'
  '-v[verbose output to stderr, while vshadowmount will remain running in]'
  '-V[print version]'
  '-X[extended options to pass to sub system]'
  '*:filename:_files'
)

_arguments -s -S $arguments
