#compdef watchdog
# Documentation: https://man.archlinux.org/search?q=watchdog
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-T[reboot after N seconds if not reset (default 60)]'
  '-t[reset every N seconds (default 30)]'
  '-F[run in foreground]'
  '*:filename:_files'
)

_arguments -s -S $arguments
