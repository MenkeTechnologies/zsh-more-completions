#compdef rsync

# Zsh completion for rsync 3.4.x
# Comprehensive options based on rsync --help output

local -a arguments

arguments=(
  '*'{-v,--verbose}'[increase verbosity]'
  '--info=[fine-grained informational verbosity]:flags'
  '--debug=[fine-grained debug verbosity]:flags'
  '--stderr=[change stderr output mode]:mode:(e a c)'
  {-q,--quiet}'[suppress non-error messages]'
  '--no-motd[suppress daemon-mode MOTD]'
  {-c,--checksum}'[skip based on checksum, not mod-time & size]'
  {-a,--archive}'[archive mode; equals -rlptgoD (no -A,-X,-U,-N,-H)]'
  '--no-OPTION[turn off an implied OPTION (e.g. --no-D)]'
  {-r,--recursive}'[recurse into directories]'
  {-R,--relative}'[use relative path names]'
  '--no-implied-dirs[do not send implied dirs with --relative]'
  {-b,--backup}'[make backups (see --suffix & --backup-dir)]'
  '--backup-dir=[make backups into hierarchy based in DIR]:directory:_directories'
  '--suffix=[set backup suffix]:suffix'
  {-u,--update}'[skip files that are newer on the receiver]'
  '--inplace[update destination files in-place]'
  '--append[append data onto shorter files]'
  '--append-verify[like --append, but with old data in file checksum]'
  {-d,--dirs}'[transfer directories without recursing]'
  '--old-dirs[works like --dirs when talking to old rsync]'
  '--mkpath[create destination'\''s missing path components]'
  {-l,--links}'[copy symlinks as symlinks]'
  {-L,--copy-links}'[transform symlink into referent file/dir]'
  '--copy-unsafe-links[only "unsafe" symlinks are transformed]'
  '--safe-links[ignore symlinks that point outside the source tree]'
  '--munge-links[munge symlinks to make them safe and unusable]'
  {-k,--copy-dirlinks}'[transform symlink to a dir into referent dir]'
  {-K,--keep-dirlinks}'[treat symlinked dir on receiver as dir]'
  {-H,--hard-links}'[preserve hard links]'
  {-p,--perms}'[preserve permissions]'
  '--fileflags[preserve file-flags (aka chflags)]'
  {-E,--executability}'[preserve the file'\''s executability]'
  '--chmod=[affect file and/or directory permissions]:permissions'
  {-A,--acls}'[preserve ACLs (implies --perms)]'
  {-X,--xattrs}'[preserve extended attributes]'
  {-o,--owner}'[preserve owner (super-user only)]'
  {-g,--group}'[preserve group]'
  '--devices[preserve device files (super-user only)]'
  '--copy-devices[copy device contents as a regular file]'
  '--write-devices[write to devices as files (implies --inplace)]'
  '--specials[preserve special files]'
  '-D[same as --devices --specials]'
  {-t,--times}'[preserve modification times]'
  {-U,--atimes}'[preserve access (use) times]'
  '--open-noatime[avoid changing the atime on opened files]'
  {-N,--crtimes}'[preserve create times (newness)]'
  {-O,--omit-dir-times}'[omit directories from --times]'
  {-J,--omit-link-times}'[omit symlinks from --times]'
  '--super[receiver attempts super-user activities]'
  '--fake-super[store/recover privileged attrs using xattrs]'
  {-S,--sparse}'[turn sequences of nulls into sparse blocks]'
  '--preallocate[allocate dest files before writing them]'
  {-n,--dry-run}'[perform a trial run with no changes made]'
  {-W,--whole-file}'[copy files whole (without delta-xfer algorithm)]'
  '--checksum-choice=[choose the checksum algorithm]:algorithm:(xxh128 xxh3 xxh64 md5 md4 sha1 none)'
  '--cc=[choose the checksum algorithm (alias for --checksum-choice)]:algorithm:(xxh128 xxh3 xxh64 md5 md4 sha1 none)'
  {-x,--one-file-system}'[do not cross filesystem boundaries]'
  {-B,--block-size=}'[force a fixed checksum block-size]:block size'
  {-e,--rsh=}'[specify the remote shell to use]:command:_command_names'
  '--rsync-path=[specify the rsync to run on the remote machine]:path:_files'
  '--existing[skip creating new files on receiver]'
  '--ignore-existing[skip updating files that already exist on receiver]'
  '--remove-source-files[sender removes synchronized files (non-dirs)]'
  '--del[an alias for --delete-during]'
  '--delete[delete extraneous files from destination dirs]'
  '--delete-before[receiver deletes before transfer, not during]'
  '--delete-during[receiver deletes during the transfer]'
  '--delete-delay[find deletions during, delete after]'
  '--delete-after[receiver deletes after transfer, not during]'
  '--delete-excluded[also delete excluded files from destination dirs]'
  '--ignore-missing-args[ignore missing source args without error]'
  '--delete-missing-args[delete missing source args from destination]'
  '--ignore-errors[delete even if there are I/O errors]'
  '--force-delete[force deletion of directories even if not empty]'
  '--force-change[affect user-/system-immutable files/dirs]'
  '--force-uchange[affect user-immutable files/dirs]'
  '--force-schange[affect system-immutable files/dirs]'
  '--max-delete=[do not delete more than NUM files]:number'
  '--max-size=[do not transfer any file larger than SIZE]:size'
  '--min-size=[do not transfer any file smaller than SIZE]:size'
  '--max-alloc=[change a limit relating to memory alloc]:size'
  '--partial[keep partially transferred files]'
  '--partial-dir=[put a partially transferred file into DIR]:directory:_directories'
  '--delay-updates[put all updated files into place at transfer'\''s end]'
  {-m,--prune-empty-dirs}'[prune empty directory chains from the file-list]'
  '--numeric-ids[do not map uid/gid values by user/group name]'
  '--usermap=[custom username mapping]:mapping'
  '--groupmap=[custom groupname mapping]:mapping'
  '--chown=[simple username/groupname mapping]:user\:group'
  '--timeout=[set I/O timeout in seconds]:seconds'
  '--contimeout=[set daemon connection timeout in seconds]:seconds'
  {-I,--ignore-times}'[do not skip files that match in size and mod-time]'
  '--size-only[skip files that match in size]'
  {-\@,--modify-window=}'[set the accuracy for mod-time comparisons]:number'
  {-T,--temp-dir=}'[create temporary files in directory DIR]:directory:_directories'
  '*'{-y,--fuzzy}'[find similar file for basis if no dest file]'
  '--compare-dest=[also compare destination files relative to DIR]:directory:_directories'
  '--copy-dest=[like --compare-dest and include copies of unchanged files]:directory:_directories'
  '--link-dest=[hardlink to files in DIR when unchanged]:directory:_directories'
  {-z,--compress}'[compress file data during the transfer]'
  '--compress-choice=[choose the compression algorithm]:algorithm:(zstd lz4 zlibx zlib none)'
  '--zc=[choose the compression algorithm (alias for --compress-choice)]:algorithm:(zstd lz4 zlibx zlib none)'
  '--compress-level=[explicitly set compression level]:level'
  '--zl=[explicitly set compression level (alias)]:level'
  '--skip-compress=[skip compressing files with a suffix in LIST]:list'
  {-C,--cvs-exclude}'[auto-ignore files the same way CVS does]'
  '*'{-f,--filter=}'[add a file-filtering RULE]:rule'
  '-F[same as --filter='\''dir-merge /.rsync-filter'\'']'
  '*--exclude=[exclude files matching PATTERN]:pattern'
  '--exclude-from=[read exclude patterns from FILE]:file:_files'
  '*--include=[do not exclude files matching PATTERN]:pattern'
  '--include-from=[read include patterns from FILE]:file:_files'
  '--files-from=[read list of source-file names from FILE]:file:_files'
  {-0,--from0}'[all *-from/filter files are delimited by 0s]'
  '--old-args[disable the modern arg-protection idiom]'
  {-s,--secluded-args}'[use the protocol to safely send the args]'
  '--trust-sender[trust the remote sender'\''s file list]'
  '--copy-as=[specify user and optional group for the copy]:user\:\[group\]'
  '--address=[bind address for outgoing socket to daemon]:address'
  '--port=[specify double-colon alternate port number]:port'
  '--sockopts=[specify custom TCP options]:options'
  '--blocking-io[use blocking I/O for the remote shell]'
  '--outbuf=[set output buffering to None, Line, or Block]:mode:((N\:None L\:Line B\:Block))'
  '--stats[give some file-transfer stats]'
  {-8,--8-bit-output}'[leave high-bit chars unescaped in output]'
  {-h,--human-readable}'[output numbers in a human-readable format]'
  '--progress[show progress during transfer]'
  '-P[same as --partial --progress]'
  {-i,--itemize-changes}'[output a change-summary for all updates]'
  {-M,--remote-option=}'[send OPTION to the remote side only]:option'
  '--out-format=[output updates using the specified FORMAT]:format'
  '--log-file=[log what we'\''re doing to the specified FILE]:file:_files'
  '--log-file-format=[log updates using the specified FMT]:format'
  '--password-file=[read daemon-access password from FILE]:file:_files'
  '--early-input=[use FILE for daemon'\''s early exec input]:file:_files'
  '--list-only[list the files instead of copying them]'
  '--bwlimit=[limit socket I/O bandwidth]:rate (KBytes per second)'
  '--stop-after=[stop rsync after MINS minutes have elapsed]:minutes'
  '--stop-at=[stop rsync at the specified point in time]:time (y-m-dTh\:m)'
  '--fsync[fsync every written file]'
  '--write-batch=[write a batched update to FILE]:file:_files'
  '--only-write-batch=[like --write-batch but without updating dest]:file:_files'
  '--read-batch=[read a batched update from FILE]:file:_files'
  '--protocol=[force an older protocol version to be used]:number'
  '--iconv=[request charset conversion of filenames]:conversion spec'
  '--checksum-seed=[set block/file checksum seed]:number'
  {-4,--ipv4}'[prefer IPv4]'
  {-6,--ipv6}'[prefer IPv6]'
  {-V,--version}'[print version number]'
  '--help[show help]'
  '*:file:_files'
)

_arguments -s -S $arguments
