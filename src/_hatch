#compdef hatch

# Zsh completion for hatch - modern Python project manager

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'build:Build a project'
  'clean:Remove build artifacts'
  'config:Manage the config file'
  'dep:Manage environment dependencies'
  'env:Manage environments'
  'fmt:Format and lint source code'
  'new:Create or initialize a project'
  'project:View project information'
  'publish:Publish build artifacts'
  'run:Run commands within project environments'
  'shell:Enter a shell within an environment'
  'status:Show information about the current project'
  'test:Run tests'
  'version:View or set the version of your project'
  'help:Show help'
)

_arguments -s -S \
  '(-e --env)'{-e,--env}'[the name of the environment to use]:env:' \
  '(-p --project)'{-p,--project}'[the name of the project to work on]:project:' \
  '--color[enable color output]:mode:(auto always never)' \
  '--no-color[disable color output]' \
  '--interactive[allow prompting of non-critical user input]' \
  '--no-interactive[disable all prompting of non-critical user input]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity (can be repeated)]' \
  '(-q --quiet)'{-q,--quiet}'[decrease verbosity (can be repeated)]' \
  '--show-warnings[always show deprecation warnings]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      build)
        _arguments \
          '(-c --clean)'{-c,--clean}'[remove build artifacts before building]' \
          '(-t --target)'{-t,--target}'[the target to build]:target:(wheel sdist)' \
          '*:target:' && ret=0
        ;;
      env)
        local -a env_cmds=(
          'create:Create an environment'
          'find:Locate an environment'
          'prune:Remove all environments'
          'remove:Remove an environment'
          'run:Run a command within an environment'
          'show:Show available environments'
        )
        _describe -t env_cmds 'env command' env_cmds && ret=0
        ;;
      version)
        _arguments ':version:' && ret=0
        ;;
      run)
        _arguments \
          '(-e --env)'{-e,--env}'[the name of the environment to use]:env:' \
          '--ignore-compat[ignore environment compatibility and use first available]' \
          '*:command:' && ret=0
        ;;
    esac
    ;;
esac

return ret
