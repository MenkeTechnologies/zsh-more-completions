#compdef newfs_msdos

local -a arguments

arguments=(
  '-N[do not create file system, just print out parameters]'
  '-B[get bootstrap from file]:file:_files'
  '-F[FAT type (12, 16, or 32)]:type:(12 16 32)'
  '-I[volume ID]:id:'
  '-O[OEM string]:string:'
  '-S[bytes per sector]:bytes:'
  '-P[physical bytes per sector]:bytes:'
  '-a[sectors per FAT]:sectors:'
  '-b[block size]:size:'
  '-c[sectors per cluster]:sectors:'
  '-e[root directory entries]:entries:'
  '-f[standard format]:format:'
  '-h[drive heads]:heads:'
  '-i[file system info sector]:sector:'
  '-k[backup boot sector]:sector:'
  '-m[media descriptor]:descriptor:'
  '-n[number of FATs]:count:'
  '-o[hidden sectors]:sectors:'
  '-r[reserved sectors]:sectors:'
  '-s[file system size in sectors]:sectors:'
  '-u[sectors per track]:sectors:'
  '-v[volume name]:name:'
  '*:filename:_files'
)

_arguments -s -S $arguments
