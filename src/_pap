#compdef pap
# Documentation: https://man.archlinux.org/search?q=pap
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-A[printer Appletalk address]'
  '-c[take cuts (lie about wait time)]'
  '-d[enable debug]'
  '-e[send stdout to stderr]'
  '-E[dont wait for EOF from printer]'
  '-p[printer name]'
  '-s[put current printer status in statusfile]'
  '-w[wait for printer status = waiting]'
  '-W[wait for printer status = idle]'
  '*:filename:_files'
)

_arguments -s -S $arguments
