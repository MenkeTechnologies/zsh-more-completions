#compdef delta

# Zsh completion for delta - a viewer for git and diff output
# https://github.com/dandavison/delta

_delta_style_options() {
  _message 'style string (e.g. "red bold ul", "syntax #002800", "omit", "raw")'
}

_delta() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -s -S \
    '--blame-code-style[style for the code section of git blame lines]:style:_delta_style_options' \
    '--blame-format[format string for git blame commit metadata]:format:' \
    '--blame-palette[background colors for git blame lines (space-separated)]:colors:' \
    '--blame-separator-format[separator between blame format and code section]:format:' \
    '--blame-separator-style[style for the blame separator]:style:_delta_style_options' \
    '--blame-timestamp-format[format of git blame timestamp in raw git output]:format:' \
    '--blame-timestamp-output-format[strftime format string for blame timestamp output]:format:' \
    '--color-only[do not alter input structurally, only apply colors and highlighting]' \
    '--config[load config file at specified path instead of ~/.gitconfig]:path:_files' \
    '--commit-decoration-style[decoration style for commit hash line]:style:_delta_style_options' \
    '--commit-regex[regex to identify commit lines when parsing git output]:regex:' \
    '--commit-style[style for the commit hash line]:style:_delta_style_options' \
    '(--light)--dark[use default colors for a dark terminal background]' \
    '--default-language[default language for syntax highlighting]:language:' \
    '--detect-dark-light[detect terminal dark/light mode]:mode:(auto always never)' \
    '(-@ --diff-args)'{-@,--diff-args}'[extra arguments to pass to git diff]:args:' \
    '--diff-highlight[emulate diff-highlight]' \
    '--diff-so-fancy[emulate diff-so-fancy]' \
    '--diff-stat-align-width[width for file paths in diff stat section]:width:' \
    '--features[names of delta features to activate (space-separated)]:features:' \
    '--file-added-label[text to display before an added file path]:label:' \
    '--file-copied-label[text to display before a copied file path]:label:' \
    '--file-decoration-style[decoration style for file headers]:style:_delta_style_options' \
    '--file-modified-label[text to display before a modified file path]:label:' \
    '--file-removed-label[text to display before a removed file path]:label:' \
    '--file-renamed-label[text to display before a renamed file path]:label:' \
    '--file-style[style for file headers]:style:_delta_style_options' \
    '--file-transformation[sed-style command to transform file paths for display]:command:' \
    '--generate-completion[print completion file for the given shell]:shell:(bash elvish fish powershell zsh)' \
    '--grep-context-line-style[style for non-matching lines of grep output]:style:_delta_style_options' \
    '--grep-file-style[style for file paths in grep output]:style:_delta_style_options' \
    '--grep-header-decoration-style[decoration style for grep headers]:style:_delta_style_options' \
    '--grep-header-file-style[style for file path part of grep header]:style:_delta_style_options' \
    '--grep-line-number-style[style for line numbers in grep output]:style:_delta_style_options' \
    '--grep-match-line-style[style for matching lines of grep output]:style:_delta_style_options' \
    '--grep-match-word-style[style for matching substrings in grep output]:style:_delta_style_options' \
    '--grep-output-type[grep output format]:type:(ripgrep classic)' \
    '--grep-separator-symbol[separator symbol for grep output]:symbol:' \
    '--hunk-header-decoration-style[decoration style for hunk headers]:style:_delta_style_options' \
    '--hunk-header-file-style[style for file paths in hunk headers]:style:_delta_style_options' \
    '--hunk-header-line-number-style[style for line numbers in hunk headers]:style:_delta_style_options' \
    '--hunk-header-style[style for hunk headers]:style:_delta_style_options' \
    '--hunk-label[text to display before a hunk header]:label:' \
    '--hyperlinks[render commit hashes, file names, and line numbers as hyperlinks]' \
    '--hyperlinks-commit-link-format[format string for commit hyperlinks]:format:' \
    '--hyperlinks-file-link-format[format string for file hyperlinks]:format:' \
    '--inline-hint-style[style for short inline hint text]:style:_delta_style_options' \
    '--inspect-raw-lines[whether to examine ANSI color escape sequences in raw lines]:mode:(true false)' \
    '--keep-plus-minus-markers[prefix added/removed lines with +/- characters]' \
    '(--dark)--light[use default colors for a light terminal background]' \
    '--line-buffer-size[size of internal line buffer]:size:' \
    '--line-fill-method[line-fill method in side-by-side mode]:method:(ansi spaces)' \
    '(-n --line-numbers)'{-n,--line-numbers}'[display line numbers next to the diff]' \
    '--line-numbers-left-format[format string for the left column of line numbers]:format:' \
    '--line-numbers-left-style[style for the left column of line numbers]:style:_delta_style_options' \
    '--line-numbers-minus-style[style for line numbers in minus (old) lines]:style:_delta_style_options' \
    '--line-numbers-plus-style[style for line numbers in plus (new) lines]:style:_delta_style_options' \
    '--line-numbers-right-format[format string for the right column of line numbers]:format:' \
    '--line-numbers-right-style[style for the right column of line numbers]:style:_delta_style_options' \
    '--line-numbers-zero-style[style for line numbers in unchanged lines]:style:_delta_style_options' \
    '--list-languages[list supported languages and associated file extensions]' \
    '--list-syntax-themes[list available syntax-highlighting color themes]' \
    '--map-styles[map input styles to output styles]:styles map:' \
    '--max-line-distance[maximum line pair distance for within-line diff (0.0-1.0)]:distance:' \
    '--max-line-length[truncate lines longer than this (0 to disable)]:length:' \
    '--max-syntax-highlighting-length[stop syntax highlighting after this many characters]:length:' \
    '--merge-conflict-begin-symbol[string marking beginning of merge conflict region]:symbol:' \
    '--merge-conflict-end-symbol[string marking end of merge conflict region]:symbol:' \
    '--merge-conflict-ours-diff-header-decoration-style[decoration style for ours diff header]:style:_delta_style_options' \
    '--merge-conflict-ours-diff-header-style[style for ours diff header]:style:_delta_style_options' \
    '--merge-conflict-theirs-diff-header-decoration-style[decoration style for theirs diff header]:style:_delta_style_options' \
    '--merge-conflict-theirs-diff-header-style[style for theirs diff header]:style:_delta_style_options' \
    '--minus-empty-line-marker-style[style for removed empty line markers]:style:_delta_style_options' \
    '--minus-emph-style[style for emphasized sections of removed lines]:style:_delta_style_options' \
    '--minus-non-emph-style[style for non-emphasized sections of removed lines]:style:_delta_style_options' \
    '--minus-style[style for removed lines]:style:_delta_style_options' \
    '--navigate[activate diff navigation keybindings]' \
    '--navigate-regex[regex defining navigation stop points]:regex:' \
    '--no-gitconfig[do not read any settings from git config]' \
    '--pager[pager program to use]:pager:_command_names' \
    '--paging[whether to use a pager for output]:mode:(auto always never)' \
    '--parse-ansi[display ANSI color escape sequences in human-readable form]' \
    '--plus-emph-style[style for emphasized sections of added lines]:style:_delta_style_options' \
    '--plus-empty-line-marker-style[style for added empty line markers]:style:_delta_style_options' \
    '--plus-non-emph-style[style for non-emphasized sections of added lines]:style:_delta_style_options' \
    '--plus-style[style for added lines]:style:_delta_style_options' \
    '--raw[do not alter the input in any way]' \
    '--relative-paths[output file paths relative to current directory]' \
    '--right-arrow[text to display with a changed file path]:symbol:' \
    '--show-colors[show available named colors]' \
    '--show-config[display active values for all delta options]' \
    '--show-syntax-themes[show example diff for available syntax-highlighting themes]' \
    '--show-themes[show example diff for available delta themes]' \
    '(-s --side-by-side)'{-s,--side-by-side}'[display diffs in side-by-side layout]' \
    '--syntax-theme[syntax-highlighting theme to use]:theme:' \
    '--tabs[number of spaces to replace tab characters with]:width:' \
    '--true-color[whether to emit 24-bit true color RGB codes]:mode:(auto always never)' \
    '--whitespace-error-style[style for whitespace errors]:style:_delta_style_options' \
    '(-w --width)'{-w,--width}'[width of underline/overline decorations]:width:' \
    '--word-diff-regex[regex defining a word for within-line diff algorithm]:regex:' \
    '--wrap-left-symbol[end-of-line symbol for left-aligned wrapped content]:symbol:' \
    '--wrap-max-lines[maximum number of times a line should be wrapped]:lines:' \
    '--wrap-right-percent[threshold percentage for right-aligning wrapped content]:percent:' \
    '--wrap-right-prefix-symbol[symbol displayed before right-aligned wrapped content]:symbol:' \
    '--wrap-right-symbol[end-of-line symbol for right-aligned wrapped content]:symbol:' \
    '--zero-style[style for unchanged lines]:style:_delta_style_options' \
    '--24-bit-color[deprecated: use --true-color]:mode:(auto always never)' \
    '(-h --help)'{-h,--help}'[print help information]' \
    '(-V --version)'{-V,--version}'[print version information]' \
    '::first file:_files' \
    '::second file:_files'
}

_delta "$@"
