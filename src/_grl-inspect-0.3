#compdef grl-inspect-0.3
# Documentation: https://man.archlinux.org/search?q=grl-inspect-0.3
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  '--help-all[show all help options]'
  '--help-grl[show Grilo Options]'
  {-d,--delay}'[wait some seconds before showing results (default 1 second)]'
  {-c,--config}'[configuration file to send to sources]'
  {-k,--keys}'[list available metadata keys in the system]'
  {-V,--version}'[print version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
