#compdef update-secureboot-policy
# Documentation: https://man.archlinux.org/search?q=update-secureboot-policy
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--enable[prompt to enable Secure Boot validation.]'
  '--disable[prompt to disable Secure Boot validation (default).]'
  '--help[this help text.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
