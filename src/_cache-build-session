#compdef cache-build-session
# Documentation: https://man.archlinux.org/search?q=cache-build-session
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--help[display available options]'
  '--help-list[display list of available options]'
  '--version[display the version of this program]'
  '--prefix-map-cmake[infer source and build prefixes from a CMake build directory]:directory:_files -/'
  '-v[verbose output]'
  '*:filename:_files'
)

_arguments -s -S $arguments
