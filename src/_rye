#compdef rye

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'add:add a dependency'
      'build:build the project'
      'config:manage configuration'
      'fetch:fetch a Python interpreter'
      'fmt:format code'
      'init:initialize a new project'
      'install:install a global tool'
      'lint:lint code'
      'lock:update the lockfile'
      'make-req:generate requirements file'
      'pin:pin a Python version'
      'publish:publish the project'
      'remove:remove a dependency'
      'run:run a command'
      'show:show project info'
      'sync:sync the environment'
      'test:run tests'
      'toolchain:manage Python toolchains'
      'tools:manage global tools'
      'self:manage rye itself'
      'version:show or set version'
    )
    _describe -t commands 'rye command' commands && ret=0
    ;;
  args)
    case $words[1] in
      add)
        _arguments -s -S \
          '--dev[add as dev dependency]' \
          '--optional=[optional dependency group]:group' \
          '--pin=[pin strategy]:strategy:(equal tilde-equal greater-equal)' \
          '--git=[git URL]:url' \
          '--url=[package URL]:url' \
          '--path=[local path]:path:_files' \
          '*--features=[features to enable]:features' \
          '--pre[allow pre-releases]' \
          '1:package' \
          && ret=0
        ;;
      init)
        _arguments -s -S \
          '--name=[project name]:name' \
          '--min-py=[minimum Python version]:version' \
          '--py=[Python version]:version' \
          '--lib[create a library project]' \
          '--script[create a script project]' \
          '--build-system=[build system]:build system:(hatchling setuptools flit pdm-backend maturin)' \
          '1:path:_directories' \
          && ret=0
        ;;
      run)
        _arguments -s -S \
          '*:command' \
          && ret=0
        ;;
      pin)
        _arguments -s -S \
          '1:python version' \
          && ret=0
        ;;
      remove)
        _arguments -s -S \
          '--dev[remove from dev dependencies]' \
          '1:package' \
          && ret=0
        ;;
      sync)
        _arguments -s -S \
          '--no-dev[skip dev dependencies]' \
          '--no-lock[skip locking]' \
          '--force[force sync]' \
          && ret=0
        ;;
      publish)
        _arguments -s -S \
          '--repository=[repository name]:repository' \
          '--repository-url=[repository URL]:url' \
          '--token=[upload token]:token' \
          '--yes[skip confirmation]' \
          && ret=0
        ;;
      fetch)
        _arguments -s -S \
          '1:python version' \
          && ret=0
        ;;
      toolchain)
        _arguments -s -S -C \
          '1:subcommand:(fetch list register remove)' \
          && ret=0
        ;;
      tools)
        _arguments -s -S -C \
          '1:subcommand:(install uninstall list)' \
          && ret=0
        ;;
      self)
        _arguments -s -S -C \
          '1:subcommand:(update uninstall completion)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
