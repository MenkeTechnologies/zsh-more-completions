#compdef pkgx

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--sync[sync package metadata]' \
  '--update[update pkgx]' \
  '--verbosity=[set verbosity level]:level:(quiet normal verbose debug)' \
  '--silent[suppress all output]' \
  '(-q --quiet)'{-q,--quiet}'[suppress non-essential output]' \
  '*:command or package' && ret=0

return ret
