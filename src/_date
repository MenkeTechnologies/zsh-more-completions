#compdef date

# Zsh completion for date - display or set date and time
# Supports both BSD/macOS and GNU/Linux (coreutils) variants

local -a iso_formats
iso_formats=(
  'date:show date only (default)'
  'hours:show date and hours'
  'minutes:show date, hours, and minutes'
  'seconds:show date, hours, minutes, and seconds'
  'ns:show date and time with nanoseconds'
)

_date_iso_format() {
  _describe -t iso-formats 'ISO 8601 precision' iso_formats
}

local arguments

arguments=(
  # BSD/macOS options
  '-f[parse new_date using specified input format (strptime)]:input format:'
  '-j[do not try to set the date (parse-only mode)]'
  '-n[obsolete, accepted and ignored for compatibility]'
  '-R[output in RFC 2822 format]'
  '-r[display last modification time of file, or date from epoch seconds]:file or seconds:'
  '-u[display or set date in UTC]'
  '-z[change to specified timezone before printing]:output timezone:'
  '*-v[adjust date/time value (e.g., +1d, -2m, +3H)]:adjustment ([+|-]val[ymwdHMS]):'
  '-I-[output in ISO 8601 format]::precision:_date_iso_format'

  # GNU/Linux (coreutils) options
  '(-d --date)'{-d,--date}'[display time described by string, not now]:date string:'
  '--debug[annotate the parsed date and warn about questionable usage]'
  '(-f --file)'{-f,--file}'[parse dates from file, one per line]:date file:_files'
  '(-I --iso-8601)'{-I-,--iso-8601=}'[output in ISO 8601 format]::precision:_date_iso_format'
  '(-R --rfc-email)'{-R,--rfc-email}'[output in RFC 5322 format]'
  '--rfc-3339=[output in RFC 3339 format]:precision:(date seconds ns)'
  '(-r --reference)'{-r,--reference}'[display last modification time of file]:file:_files'
  '(-s --set)'{-s,--set}'[set time described by string]:date string:'
  '(-u --utc --universal)'{-u,--utc,--universal}'[print or set Coordinated Universal Time (UTC)]'
  '--resolution[output the available resolution of timestamps]'
  '(- *)--help[display help and exit]'
  '(- *)--version[output version information and exit]'

  ':output format or date setting:'
)

_arguments -s -S $arguments
