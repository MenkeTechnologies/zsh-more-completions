#compdef cctiff

local -a arguments

arguments=(
  '-v[verbose.]'
  '-c[combine linearisation curves into one transform.]'
  '-p[use slow precise correction.]'
  '-k[check fast result against precise, and report.]'
  '-r[override the default CLUT resolution]:resolution:'
  '-t[choose output encoding from 1..n]:encoding:'
  '-f[set output format]:format:(Tiff Jpeg)'
  '-q[set JPEG quality 1..100 (default 80)]:quality:'
  '-a[read and Write planes > 4 as alpha planes]'
  '-I[ignore any file or profile colorspace mismatches]'
  '-D[dont append or set the output TIFF or JPEG description]'
  '-N[output uncompressed TIFF (default LZW)]'
  '-e[embed a profile in the destination TIFF or JPEG file]:profile:_files'
  '-i[rendering intent]:intent:(p r a)'
  '-o[lookup order]:order:(n r)'
  '-d[calibration direction]:direction:(f b)'
  '*:filename:_files'
)

_arguments -s -S $arguments
