#compdef kotlinc-js

local -a arguments

arguments=(
  '-api-version[allow using declarations only from the specified version]:version:'
  '-help[print a synopsis of standard options]'
  '-ir-output-dir[destination directory for IR backend output]:directory:_directories'
  '-ir-output-name[base name of the output file for IR backend]:name:'
  '-ir-produce-js[generate a .js file using the IR backend]'
  '-ir-produce-klib-dir[generate an unpacked klib into the directory]:directory:_directories'
  '-ir-produce-klib-file[generate a packed klib into a file]:file:_files'
  '-language-version[provide source compatibility with the specified version]:version:'
  '-libraries[paths to Kotlin libraries with .meta.js and .kjsm files]:libraries:_files'
  '-main[define whether the main function should be called]:call:(call noCall)'
  '-meta-info[generate metadata]'
  '-module-kind[kind of the JS module generated]:kind:(plain amd commonjs umd es)'
  '-no-stdlib[do not automatically include the default Kotlin/JS stdlib]'
  '-nowarn[generate no warnings]'
  '-opt-in[enable usages of API that requires opt-in]:annotation:'
  '-output[destination .js file]:js file:_files -g "*.js"'
  '-output-postfix[add the content of the specified file to the end of output]:file:_files'
  '-output-prefix[add the content of the specified file to the beginning of output]:file:_files'
  '-progressive[enable progressive compiler mode]'
  '-source-map[generate source map]'
  '-source-map-base-dirs[base directories for calculating relative paths in source map]:dirs:_directories'
  '-source-map-embed-sources[embed source files into the source map]:mode:(always never inlining)'
  '-source-map-prefix[add the specified prefix to paths in the source map]:prefix:'
  '-target[generate JS files for specific ECMA version]:version:(v5)'
  '-verbose[enable verbose logging output]'
  '-version[display compiler version]'
  '-W[report a warning on any compiler option]'
  '-Werror[report an error on any compiler warning]'
  '-X[print a synopsis of advanced options]'
  '*:source files:_files -g "*.kt"'
)

_arguments -s -S $arguments
