#compdef jbgtopbm85
# Documentation: https://man.archlinux.org/search?q=jbgtopbm85
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-x[maximum number of pixels per line for which memory]'
  '-y[interrupt decoder after this number of lines]'
  '-B[input buffer size]'
  '*:filename:_files'
)

_arguments -s -S $arguments
