#compdef wpctl

_wpctl_set_volume() {
  _arguments \
    '--pid[filter by PID]:pid:_pids' \
    ':ID:' \
    ':volume:'
}

_wpctl_set_mute() {
  _arguments \
    ':ID:' \
    ':mute state:(1 0 toggle)'
}

_wpctl_clear_default() {
  _arguments \
    '--type[specify type]:type:(source sink)'
}

_wpctl() {
  local -a commands
  commands=(
    'status:show current status'
    'inspect:inspect an object'
    'set-default:set default sink or source'
    'set-volume:set volume of a node'
    'set-mute:set mute state of a node'
    'set-profile:set profile of a device'
    'get-volume:get volume of a node'
    'clear-default:clear default sink or source'
  )

  _arguments \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '1:command:->command' \
    '*::arguments:->arguments'

  case "$state" in
    command)
      _describe -t commands 'wpctl command' commands
      ;;
    arguments)
      case "$words[1]" in
        set-volume) _wpctl_set_volume ;;
        set-mute) _wpctl_set_mute ;;
        clear-default) _wpctl_clear_default ;;
        inspect|set-default|get-volume) _arguments ':ID:' ;;
        set-profile) _arguments ':ID:' ':profile index:' ;;
      esac
      ;;
  esac
}

_wpctl "$@"
