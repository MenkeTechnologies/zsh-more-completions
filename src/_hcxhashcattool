#compdef hcxhashcattool
# Documentation: https://man.archlinux.org/search?q=hcxhashcattool
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-p[input hashcat potfile]'
  '-P[output PMK file (PMK:ESSID:PSK)]'
  '-h[show this help]'
  '-v[show version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
