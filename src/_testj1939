#compdef testj1939
# Documentation: https://man.archlinux.org/search?q=testj1939
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-v[print relevant API calls]'
  '-s[initial send of LEN bytes dummy data]'
  '-r[receive (and print) data]'
  '-e[echo incoming packets back]'
  '-c[issue connect()]'
  '-p[set priority to PRIO]'
  '-n[emit 64bit NAMEs in output]'
  '-w[return after TIME (default 1) seconds]'
  '*:filename:_files'
)

_arguments -s -S $arguments
