#compdef t1asm

local -a arguments

arguments=(
  {-a,--pfa}'[output font in ASCII (PFA) format.]'
  {-b,--pfb}'[output font in binary (PFB) format. This is the default.]'
  {-l,--block-length}'[set max block length for PFB output.]:length:'
  {-l,--line-length}'[set max encrypted line length for PFA output.]:length:'
  {-o,--output}'[write output to FILE.]:file:_files'
  '(- * :)'{-h,--help}'[print this message and exit.]'
  '--version[print version number and warranty and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
