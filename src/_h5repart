#compdef h5repart
# Documentation: https://man.archlinux.org/search?q=h5repart
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-v[produce verbose output]'
  '-V[print a version number and exit]'
  '-b[the I/O block size, defaults to 1kB]'
  '-m[the destination member size or 1GB]'
  '-family[_to_sec2 Change file driver from family to sec2]'
  '*:filename:_files'
)

_arguments -s -S $arguments
