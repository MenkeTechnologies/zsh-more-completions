#compdef catman

local -a arguments

arguments=(
  {-C,--config-file}'[use this user configuration file]:file:_files'
  {-d,--debug}'[emit debugging messages]'
  {-M,--manpath}'[set search path for manual pages]:path:_files -/'
  '--usage[give a short usage message]'
  {-V,--version}'[print program version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
