#compdef fbtest
# Documentation: https://man.archlinux.org/search?q=fbtest
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-f[the frame buffer device (default /dev/fb0)]:device:_files'
  '-C[the virtual console device (default /dev/tty1)]:device:_files'
  '*:filename:_files'
)

_arguments -s -S $arguments
