#compdef scl
# Documentation: https://man.archlinux.org/search?q=scl
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-l,--list}'[list installed Software Collections or packages]'
  '(- * :)'{-h,--help}'[display this help and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
