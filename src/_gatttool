#compdef gatttool

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  '--help-all[show all help options]'
  '--help-gatt[show all GATT commands]'
  '--help-params[show all Primary Services/Characteristics arguments]'
  '--help-char-read-write[show all Characteristics Value/Descriptor Read/Write arguments]'
  {-i,--adapter}'[specify local adapter interface]'
  {-b,--device}'[specify remote Bluetooth address]'
  {-t,--addr-type}'[set LE address type (public or random)]:type:(public random)'
  {-m,--mtu}'[specify the MTU size]'
  {-p,--psm}'[specify the PSM for GATT/ATT over BR/EDR]'
  {-l,--sec-level}'[set security level]:level:(low medium high)'
  {-I,--interactive}'[use interactive mode]'
  '*:filename:_files'
)

_arguments -s -S $arguments
