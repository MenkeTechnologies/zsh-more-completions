#compdef ubertooth-dfu

local -a arguments

arguments=(
  '-u[upload - read firmware from device]'
  '-d[download - write DFU file to device]'
  '-r[reset ubertooth after other operations complete]'
  '-s[add DFU suffix to binary firmware file]'
  '-U[set ubertooth device to use]:device:(0 1 2 3 4 5 6 7)'
  '*:filename:_files'
)

_arguments -s -S $arguments
