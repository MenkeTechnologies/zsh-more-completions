#compdef paccache

local -a arguments

arguments=(
  {-d,--dryrun}'[perform a dry run, only finding candidate packages.]'
  {-m,--move}'[move candidate packages to "dir".]'
  {-r,--remove}'[remove candidate packages.]'
  '--min-atime[keep packages with an atime not older than specified]:time'
  '--min-mtime[keep packages with an mtime not older than specified]:time'
  {-a,--arch}'[scan for "arch" (default: all architectures).]'
  {-c,--cachedir}'[scan "dir" for packages. can be used more than once.]'
  {-f,--force}'[apply force to mv(1) and rm(1) operations.]'
  '(- * :)'{-h,--help}'[display this help message and exit.]'
  {-i,--ignore}'[ignore "pkgs", comma-separated]:packages'
  {-k,--keep}'[keep "num" of each package in the cache (default: 3).]'
  '--nocolor[remove color from output.]'
  {-q,--quiet}'[minimize output]'
  {-u,--uninstalled}'[target uninstalled packages.]'
  {-v,--verbose}'[increase verbosity. specify up to 3 times.]'
  {-z,--null}'[use null delimiters for candidate names (only with -v and -vv)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
