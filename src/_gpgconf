#compdef gpgconf

# Zsh completion for gpgconf (GnuPG configuration utility)

_gpgconf_components() {
  local -a components
  components=(${(f)"$(gpgconf --list-components 2>/dev/null | while IFS=: read -r name desc _; do
    [[ -n $name ]] && print -- "${name}:${desc}"
  done)"})
  _describe -t components 'component' components
}

_arguments -s -S \
  '(- *)'{-h,--help}'[display help and exit]' \
  '(- *)--version[display version and exit]' \
  '--list-components[list all components]' \
  '--check-programs[check all programs]' \
  '--list-options[list options for a component]:component:_gpgconf_components' \
  '--change-options[change options for a component]:component:_gpgconf_components' \
  '--check-options[check options for a component]:component:_gpgconf_components' \
  '--apply-defaults[apply global default values]' \
  '--apply-profile[update configuration files using specified profile]:profile file:_files' \
  {-L,--list-dirs}'[get the configuration directories for gpgconf]' \
  '--list-config[list global configuration file]' \
  '--check-config[check global configuration file]' \
  '--query-swdb[query the software version database]' \
  {-R,--reload}'[reload all or a given component]:component:_gpgconf_components' \
  '--launch[launch a given component]:component:_gpgconf_components' \
  {-K,--kill}'[kill a given component]:component:_gpgconf_components' \
  {-V,--show-versions}'[show versions of all installed components]' \
  {-X,--show-configs}'[show configuration details of all components]' \
  {-o,--output}'[use as output file]:output file:_files' \
  {-v,--verbose}'[verbose]' \
  {-q,--quiet}'[quiet]' \
  {-n,--dry-run}'[do not make any changes]' \
  {-r,--runtime}'[activate changes at runtime, if possible]' \
  '--status-fd[write status info to this file descriptor]:file descriptor' \
  '*:filename:_files'
