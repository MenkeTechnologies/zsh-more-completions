#compdef gh-dash

# Zsh completion for gh-dash (GitHub dashboard TUI)

_arguments -s -S \
  '(-c --config)'{-c,--config}'[config file]:file:_files -g "*.yml *.yaml"' \
  '--debug[enable debug logging]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' && return 0
