#compdef netsniff-ng

local -a arguments

arguments=(
  {-i,-d,--dev,--in}'[input source as netdev, pcap or pcap stdin]'
  {-o,--out}'[output sink as netdev, pcap, directory, trafgen, or stdout]'
  {-C,--fanout-group}'[join packet fanout group]:id:'
  {-K,--fanout-type}'[apply fanout discipline]:type:(hash lb cpu rnd roll qm)'
  {-L,--fanout-opts}'[additional fanout options]:opts:'
  {-f,--filter}'[use BPF filter from bpfc file/stdin or tcpdump-like expression]:filter:'
  {-t,--type}'[filter for packet type]:type:(host broadcast multicast others outgoing)'
  {-F,--interval}'[dump interval if -o is a directory]:interval:'
  {-R,--rfraw}'[capture or inject raw 802.11 frames]'
  {-n,--num}'[number of packets until exit (def: 0)]:num:'
  {-P,--prefix}'[prefix for pcaps stored in directory]:name:'
  {-T,--magic}'[pcap magic number/pcap format to store]:magic:'
  {-w,--cooked}'[use Linux cooked header instead of link header]'
  {-D,--dump-pcap-types}'[dump pcap types and magic numbers and quit]'
  {-B,--dump-bpf}'[dump generated BPF assembly]'
  {-r,--rand}'[randomize packet forwarding order]'
  {-M,--no-promisc}'[no promiscuous mode for netdev]'
  {-A,--no-sock-mem}'[dont tune core socket memory]'
  {-N,--no-hwtimestamp}'[disable hardware time stamping]'
  {-m,--mmap}'[mmap pcap file I/O]'
  {-G,--sg}'[scatter/gather pcap file I/O]'
  {-c,--clrw}'[use slower read/write I/O]'
  {-S,--ring-size}'[specify ring size]:size:'
  {-k,--kernel-pull}'[kernel pull from user interval in us]:us:'
  {-J,--jumbo-support}'[support 64KB Super Jumbo Frames]'
  {-b,--bind-cpu}'[bind to specific CPU]:cpu:'
  {-u,--user}'[drop privileges and change to userid]:userid:'
  {-g,--group}'[drop privileges and change to groupid]:groupid:'
  {-H,--prio-high}'[make this high priority process]'
  {-Q,--notouch-irq}'[do not touch IRQ CPU affinity of NIC]'
  {-s,--silent}'[do not print captured packets]'
  {-q,--less}'[print less-verbose packet information]'
  {-X,--hex}'[print packet data in hex format]'
  {-l,--ascii}'[print human-readable packet data]'
  {-U,--update}'[update GeoIP databases]'
  {-V,--verbose}'[be more verbose]'
  {-v,--version}'[show version and exit]'
  '(- * :)'{-h,--help}'[show help and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
