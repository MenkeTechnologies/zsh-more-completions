#compdef xcmsdb
# Documentation: https://man.archlinux.org/search?q=xcmsdb
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-display[.scrn\] display to use]'
  '-format[32 | 16 | 8 \] property format]'
  '-query[query Screen Color Characterization Data]'
  '-remove[remove Screen Color Characterization Data]'
  '-version[print program version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
