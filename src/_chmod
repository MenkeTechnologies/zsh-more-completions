#compdef chmod

# Zsh completion for chmod - change file modes or Access Control Lists
# Supports both GNU coreutils and BSD/macOS variants

_chmod_modes() {
  if [[ -prefix [0-7] ]]; then
    _message 'octal mode (e.g., 755, 644)'
    return
  fi

  local -a specs
  specs=(
    'u+r:add read for owner'
    'u+w:add write for owner'
    'u+x:add execute for owner'
    'u-r:remove read for owner'
    'u-w:remove write for owner'
    'u-x:remove execute for owner'
    'g+r:add read for group'
    'g+w:add write for group'
    'g+x:add execute for group'
    'g-r:remove read for group'
    'g-w:remove write for group'
    'g-x:remove execute for group'
    'o+r:add read for others'
    'o+w:add write for others'
    'o+x:add execute for others'
    'o-r:remove read for others'
    'o-w:remove write for others'
    'o-x:remove execute for others'
    'a+r:add read for all'
    'a+w:add write for all'
    'a+x:add execute for all'
    'a-r:remove read for all'
    'a-w:remove write for all'
    'a-x:remove execute for all'
    'u+s:set SUID'
    'g+s:set SGID'
    '+t:set sticky bit'
    '755:rwxr-xr-x'
    '750:rwxr-x---'
    '700:rwx------'
    '644:rw-r--r--'
    '600:rw-------'
    '444:r--r--r--'
    '777:rwxrwxrwx'
    '400:r--------'
  )
  _describe -t modes 'file mode' specs
}

local -a arguments

if [[ "$OSTYPE" == darwin* || "$OSTYPE" == freebsd* ]]; then
  # BSD/macOS variant
  arguments=(
    '-f[do not display diagnostic messages on failure]'
    '-H[follow symbolic links on the command line (with -R)]'
    '-h[change the mode of the symbolic link itself]'
    '-L[follow all symbolic links (with -R)]'
    '-P[do not follow symbolic links (with -R, default)]'
    '-R[change files and directories recursively]'
    '-v[be verbose, show filenames as mode is modified]'
    '-a[ACL entry to add]:ACL entry: '
    '+a[ACL entry to add]:ACL entry: '
    '=a[rewrite ACL entries]:ACL entry: '
    '-E[read ACL information from stdin]'
    '-C[return false if ACL is not canonical]'
    '-N[remove all ACL entries]'
    '-i[remove inherited ACL entries]'
    '1:mode:_chmod_modes'
    '*:file:_files'
  )
else
  # GNU coreutils variant
  arguments=(
    {-c,--changes}'[report only when a change is made]'
    {-f,--silent,--quiet}'[suppress most error messages]'
    {-v,--verbose}'[output a diagnostic for every file processed]'
    '--no-preserve-root[do not treat / specially (the default)]'
    '--preserve-root[fail to operate recursively on /]'
    '--reference=[use specified file mode instead of MODE values]:reference file:_files'
    {-R,--recursive}'[change files and directories recursively]'
    '--help[display help and exit]'
    '--version[output version information and exit]'
    '1:mode:_chmod_modes'
    '*:file:_files'
  )
fi

_arguments -s -S $arguments
