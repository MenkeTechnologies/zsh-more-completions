#compdef choom
# Documentation: https://man.archlinux.org/search?q=choom
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-n,--adjust}'[specify the adjust score value]'
  {-p,--pid}'[process ID]'
  '(- * :)'{-h,--help}'[display this help]'
  {-V,--version}'[display version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
