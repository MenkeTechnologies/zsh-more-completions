#compdef xmake

# Zsh completion for xmake - cross-platform build tool

local curcontext="$curcontext" state line ret=1

local -a global_opts=(
  '(-h --help)'{-h,--help}'[show help information]'
  '(-V --version)'{-V,--version}'[show version]'
  '(-v --verbose)'{-v,--verbose}'[show verbose output]'
  '(-D --diagnosis)'{-D,--diagnosis}'[enable diagnosis info]'
  '(-q --quiet)'{-q,--quiet}'[quiet operation]'
  '(-y --yes)'{-y,--yes}'[input yes by default]'
  '(-F --file)'{-F,--file}'[read a given xmake.lua]:file:_files'
  '(-P --project)'{-P,--project}'[change to the given project directory]:dir:_files -/'
)

local -a subcommands=(
  'build:build targets'
  'b:build targets'
  'run:run the project target'
  'r:run the project target'
  'install:install the project binary files'
  'i:install the project binary files'
  'uninstall:uninstall the project binary files'
  'clean:remove all binary and temporary files'
  'c:remove all binary and temporary files'
  'config:configure the project'
  'f:configure the project'
  'create:create a new project'
  'global:configure the global options'
  'g:configure the global options'
  'package:package target'
  'p:package target'
  'update:update and uninstall the xmake program'
  'require:install and update required packages'
  'repo:manage package repositories'
  'env:set the envirnoment and execute command'
  'lua:run the lua script'
  'check:check the project sourcefile info'
  'project:generate the project file'
  'plugin:manage plugins'
  'show:show the given project information'
  'watch:watch the project and rebuild it'
  'service:start remote or distributed build service'
  'format:format the current project'
  'doxygen:generate doxygen document'
)

_arguments -s -S \
  $global_opts \
  '1:subcommand:->subcmd' \
  '*::args:->args' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'xmake subcommand' subcommands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (build|b)
        _arguments -s -S \
          $global_opts \
          '(-j --jobs)'{-j,--jobs}'[set the number of parallel compilation jobs]:n:' \
          '(-v --verbose)'{-v,--verbose}'[show verbose output]' \
          '(-D --diagnosis)'{-D,--diagnosis}'[enable diagnosis info]' \
          '(-w --warning)'{-w,--warning}'[enable warnings output]' \
          '--rebuild[rebuild]' \
          '--dry-run[dry run, do not actually build]' \
          '--all[build all targets]' \
          '(-g --group)'{-g,--group}'[build targets of the given group]:group name:' \
          '(-t --target)'{-t,--target}'[build the given target]:target name:' && ret=0
        ;;
      (run|r)
        _arguments -s -S \
          $global_opts \
          '(-d --debug)'{-d,--debug}'[run with debug mode]' \
          '(-w --workdir)'{-w,--workdir}'[set the working directory]:dir:_files -/' \
          '--detach[run program in background]' && ret=0
        ;;
      (config|f)
        _arguments -s -S \
          $global_opts \
          '(-p --plat)'{-p,--plat}'[compile for the given platform]:platform:(linux windows macosx android iphoneos watchos cross)' \
          '(-a --arch)'{-a,--arch}'[compile for the given architecture]:arch:(x86_64 i386 arm64 armv7 armv7s arm64-v8a armeabi-v7a)' \
          '(-m --mode)'{-m,--mode}'[compile for the given mode]:mode:(debug release releasedbg minsizerel)' \
          '--toolchain[set the toolchain name]:toolchain name:' \
          '(-k --kind)'{-k,--kind}'[compile the given target kind]:kind:(static shared binary)' \
          '--buildir[set the build directory]:dir:_files -/' \
          '(-o --output)'{-o,--output}'[set the output directory]:dir:_files -/' \
          '--ndk[set the Android NDK directory]:dir:_files -/' \
          '--sdk[set the SDK directory]:dir:_files -/' \
          '--cc[set the C compiler]:compiler:' \
          '--cxx[set the C++ compiler]:compiler:' \
          '--ld[set the linker]:linker:' \
          '--ar[set the static library archiver]:archiver:' \
          '--host[set the current host environment]' \
          '--clean[clean cached configure]' \
          '--check[recheck configure]' \
          '--menu[configure project with a menu-driven user interface]' && ret=0
        ;;
      (create)
        _arguments -s -S \
          $global_opts \
          '(-l --language)'{-l,--language}'[the project language]:language:(c c++ objc objc++ rust go d swift)' \
          '(-t --template)'{-t,--template}'[select the project template]:template:(console static shared qt vsxmake)' \
          '(-P --project)'{-P,--project}'[create in given directory]:dir:_files -/' && ret=0
        ;;
      (install|i)
        _arguments -s -S \
          $global_opts \
          '(-o --installdir)'{-o,--installdir}'[set the install directory]:dir:_files -/' \
          '--admin[try to request administrator permissions to install]' && ret=0
        ;;
      (require)
        _arguments -s -S \
          $global_opts \
          '--force[force to reinstall all packages]' \
          '--shallow[only install shallow packages]' \
          '--extra[set the extra package info]:options:' \
          '*:package name:' && ret=0
        ;;
      (clean|c)
        _arguments -s -S \
          $global_opts \
          '--all[clean all targets and their dependencies]' && ret=0
        ;;
      (global|g)
        _arguments -s -S \
          $global_opts \
          '--menu[configure with a menu-driven interface]' \
          '--clean[clean cached global configure]' \
          '--check[recheck global configure]' && ret=0
        ;;
      (package|p)
        _arguments -s -S \
          $global_opts \
          '(-f --format)'{-f,--format}'[set the package format]:format:(local remote)' \
          '(-o --outputdir)'{-o,--outputdir}'[set the output directory]:dir:_files -/' && ret=0
        ;;
      (*)
        _arguments -s -S $global_opts && ret=0
        ;;
    esac
    ;;
esac

return ret
