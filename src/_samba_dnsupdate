#compdef samba_dnsupdate

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  '--verbose[enable verbose output]'
  '--use-samba-tool[use samba-tool to make updates over RPC]'
  '--use-nsupdate[use nsupdate command to make updates over DNS]'
  '--all-names[update all DNS names]'
  '--all-interfaces[update all network interfaces]'
  '--current-ip[IP address to update DNS to match]:ip'
  '--rpc-server-ip[IP address of server to use with samba-tool]:ip'
  '--use-file[use a file rather than real DNS calls]:file:_files'
  '--update-list[add DNS names from the given file]:file:_files'
  '--update-cache[cache database of already registered records]:file:_files'
  '--fail-immediately[exit on first failure]'
  '--no-credentials[dont try and get credentials]'
  '--no-substitutions[dont try to expand variables in update-list file]'
  {-s,--configfile}'[configuration file]'
  {-d,--debuglevel}'[debug level]'
  '--option[set smb.conf option from command line]'
  '--realm[set the realm name]'
  {-V,--version}'[display version number]'
  '*:filename:_files'
)

_arguments -s -S $arguments
