#compdef skhd

# Zsh completion for skhd - simple hotkey daemon for macOS

_arguments -s -S \
  '-V[output version information]' \
  '-P[profile collected hotkeys]' \
  '-v[output verbose mode]' \
  '-r[reload configuration file]' \
  '-o[observe sent events only (no capture)]' \
  '-h[output help information]' \
  '-c[path to configuration file]:config file:_files' \
  '-k[synthesize a keypress (hex/key) from observer mode]:keycode:' \
  '-t[set text to type]:text:' && return 0
