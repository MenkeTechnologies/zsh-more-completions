#compdef cacaclock
# Documentation: https://man.archlinux.org/search?q=cacaclock
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[this help]'
  {-v,--version}'[version of the program]'
  {-f,--font}'[use FONT for time display]:font:'
  {-d,--dateformat}'[use FORMAT as strftime argument (default %R:%S)]:format:'
  '*:filename:_files'
)

_arguments -s -S $arguments
