#compdef lavrec

local -a arguments

arguments=(
  {-f,--format}'[format AVI/Quicktime]'
  {-i,--input}'[input source or 1-10:norm see manpage]'
  {-d,--decimation}'[decimation (either 1,2,4 or two digit number)]'
  {-g,--geometry}'[X-style geometry string (part of 768/720x576/480)]'
  {-q,--quality}'[quality in percent]'
  {-t,--time}'[capture time (default: unlimited - Ctrl-C to stop)]'
  {-S,--single-frame}'[single frame capture mode]'
  {-T,--time-lapse}'[time lapse, capture only every <num>th frame]'
  {-w,--wait}'[wait for user confirmation to start]'
  {-B,--batch}'[batch mode for recording non-interactively]'
  {-a,--audio-bitsize}'[audio size, 0 for no audio, 8 or 16]'
  {-r,--audio-bitrate}'[audio rate in Hz]'
  {-s,--stereo}'[stereo (default: mono)]'
  {-l,--audio-volume}'[recording level in percent, -1 for mixers not touched]'
  {-m,--mute}'[mute audio output during recording]'
  {-R,--audio-source}'[set recording source: (l)ine, (m)icro, (c)d]'
  {-c,--synchronization}'[level of corrections for synchronization]'
  {-n,--mjpeg-buffers}'[number of MJPEG buffers (default: 64)]'
  {-b,--mjpeg-buffer-size}'[size of MJPEG buffers in Kb (default: 256)]'
  {-C,--channel}'[when using a TV tuner, channel list/number]'
  {-F,--frequency}'[when using a TV tuner, frequency in KHz]'
  {-U,--use-read}'[use read instead of mmap for recording]'
  '--software-encoding[use software JPEG-encoding (for BTTV-capture)]'
  '--num-procs[number of encoding processes (default: 1)]'
  '--max-file-size[maximum size per file (in MB)]'
  '--max-file-frames[maximum number of frames per file]'
  '--file-flush[flush capture file to disk every num frames]'
  {-v,--verbose}'[verbose level (default: 0)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
