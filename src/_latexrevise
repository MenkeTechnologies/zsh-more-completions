#compdef latexrevise

local -a arguments

arguments=(
  {-a,--accept}'[run in ACCEPT mode (delete all blocks marked by \DIFdelbegin)]'
  {-d,--decline}'[run in DECLINE mode (delete all blocks marked by \DIFaddbegin)]'
  {-s,--simplify}'[run in SIMPLIFY mode (keep all \DIFaddbegin, \DIFaddend)]'
  {-c,--comment}'[remove \cmd{...} marking explicit comments]:command:'
  {-e,--comment-environment}'[remove explicit annotation environments from the text]:environment:'
  {-m,--markup}'[remove the markup command but leave its argument]:command:'
  {-n,--markup-environment}'[remove \begin{envir} and \end{envir} commands]:environment:'
  {-q,--no-warnings}'[do not warn users about \DIDadd{..} or \DIFdel statements]'
  {-V,--verbose}'[verbose output]'
  '*:filename:_files'
)

_arguments -s -S $arguments
