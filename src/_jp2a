#compdef jp2a

# Zsh completion for jp2a - JPEG to ASCII converter

_arguments \
  '--help[show help message]' \
  '--version[show version]' \
  '--width[set output width]:width:' \
  '--height[set output height]:height:' \
  '--size[set output size]:WxH:' \
  '--chars[set character ramp]:characters:' \
  '--colors[enable color output]' \
  '--color-depth[set color depth]:depth:(4 8 24)' \
  '--background[set background mode]:mode:(light dark)' \
  '--border[draw border around image]' \
  '--clear[clear screen before output]' \
  '--fill[use fill characters]' \
  '--flipx[flip image horizontally]' \
  '--flipy[flip image vertically]' \
  '--grayscale[convert to grayscale]' \
  '--html[output as HTML]' \
  '--html-fill[set HTML fill mode]' \
  '--html-fontsize[set HTML font size]:size:' \
  '--html-no-bold[disable bold in HTML output]' \
  '--html-raw[output raw HTML]' \
  '--html-title[set HTML title]:title:' \
  '--invert[invert image]' \
  '--output[write output to file]:output file:_files' \
  '--red[set red weight]:weight:' \
  '--green[set green weight]:weight:' \
  '--blue[set blue weight]:weight:' \
  '--term-fit[fit to terminal size]' \
  '--term-height[fit to terminal height]' \
  '--term-width[fit to terminal width]' \
  '--verbose[verbose output]' \
  '*:image file:_files -g "*.{jpg,jpeg,png,gif,bmp,tif,tiff}"'
