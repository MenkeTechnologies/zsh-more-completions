#compdef afida
# Documentation: https://man.archlinux.org/search?q=afida
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-o[display results selected by bit flags.]'
  '-t[suppress output for distortions below THRESHOLD.]'
  '-l[set channel layout. If specified once, applies to both files.]'
  '-d[delay of TEST_FILE compared to REFERENCE_FILE in frames.]'
  '-h[print this help message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
