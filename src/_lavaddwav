#compdef lavaddwav
# Documentation: https://man.archlinux.org/search?q=lavaddwav
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-m[maximum size per file \[2044 MB\]]'
  '-l[list mode (input files are text lists of AVI//QT and WAV files)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
