#compdef cksfv
# Zsh completion for cksfv
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  {-c,--check}'[check SFV file]:SFV file:_files -g "*.sfv(-.)"' \
  {-i,--ignore-case}'[ignore case in filenames]' \
  {-q,--quiet}'[quiet mode]' \
  {-v,--verbose}'[verbose mode]' \
  '-g[generate SFV to stdout]' \
  '-f[output SFV to file]:file:_files' \
  '-C[change to directory before checking]:directory:_directories' \
  '-r[recursive mode]' \
  '--help[display help]' \
  '*:file:_files' && ret=0
return ret
