#compdef genDDNSkey

local -a arguments

arguments=(
  '(-f --key-file)'{-f,--key-file}'[includable key is written to this file]:filename:_files'
  '(-n --key-name)'{-n,--key-name}'[name of the key (default: DHCP_UPDATER)]:name'
  '(-d --key-dir)'{-d,--key-dir}'[public / private key directory]:directory:_directories'
  '(-r --random)'{-r,--random}'[random device to use (default: /dev/random)]:device:_files'
  '--force[overwrite an existing key file]'
  '--help[print usage info]'
  '*:filename:_files'
)

_arguments -s -S $arguments
