#compdef slack-term
# Documentation: https://man.archlinux.org/search?q=slack-term
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-config[path to config file]:config:_files'
  '-token[slack token]:token:'
  '-debug[enable debug mode]'
  '(- * :)'{-help,-h}'[show help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
