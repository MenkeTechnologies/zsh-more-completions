#compdef muffet

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-b --buffer-size)'{-b,--buffer-size}'[HTTP response buffer size]:size' \
  '(-c --max-connections)'{-c,--max-connections}'[max number of connections]:count' \
  '--max-connections-per-host[max connections per host]:count' \
  '--max-redirections[max number of redirections]:count' \
  '(-t --timeout)'{-t,--timeout}'[request timeout]:seconds' \
  '--rate-limit[rate limit per second]:rate' \
  '--max-response-body-size[max response body size]:size' \
  '*'{-H,--header}'[custom header]:header' \
  '--accepted-status-codes[accepted status codes]:codes' \
  '*'{-e,--excluded-pattern}'[excluded URL pattern]:pattern' \
  '--included-pattern[included URL pattern]:pattern' \
  '--follow-robots-txt[follow robots.txt]' \
  '--follow-sitemap-xml[follow sitemap.xml]' \
  '--skip-tls-verification[skip TLS verification]' \
  '--one-page-only[check only the given page]' \
  '--json[output in JSON format]' \
  '--color[color output]:when:(auto always never)' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:url' && ret=0
return ret
