#compdef ccguess
# Documentation: https://man.archlinux.org/search?q=ccguess
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[print this help message and exit]'
  {-V,--version}'[print version info and exit]'
  {-L,--license}'[print license info and exit]'
  {-K,--key}'[specify approximate key]:key:'
  {-d,--depth}'[try up to this many changes to key (default: 5)]:depth:'
  {-c,--continue}'[keep trying more keys after first match]'
  {-n,--non-printable}'[allow non-printable characters in keys]'
  {-t,--chartable}'[characters to use in passwords (default: printable)]:chartable:'
  '*:filename:_files'
)

_arguments -s -S $arguments
