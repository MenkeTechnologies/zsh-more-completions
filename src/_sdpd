#compdef sdpd
# Documentation: https://man.archlinux.org/search?q=sdpd
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-c[specify control socket name (default /var/run/sdp)]'
  '-d[do not detach (run in foreground)]'
  '-g[specify group]'
  '-h[display usage and exit]'
  '-u[specify user]'
  '*:filename:_files'
)

_arguments -s -S $arguments
