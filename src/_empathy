#compdef empathy
# Documentation: https://man.archlinux.org/search?q=empathy
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--help-all[show all help options]'
  '--help-gtk[show GTK+ Options]'
  {-n,--no-connect}'[dont connect on startup]'
  {-h,--start-hidden}'[dont display the contact list or any other dialogs on startup]'
  {-p,--show-preferences}'[show the preferences dialog]'
  {-v,--version}'[show version information]'
  '--display[X display to use]'
  '*:filename:_files'
)

_arguments -s -S $arguments
