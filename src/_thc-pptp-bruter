#compdef thc-pptp-bruter
# Documentation: https://man.archlinux.org/search?q=thc-pptp-bruter
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-v[verbose output / Debug output]'
  '-W[disable windows hack \[default: enabled\]]'
  '-u[user \[default: administrator\]]:user:'
  '-w[wordlist file \[default: stdin\]]:file:_files'
  '-p[PPTP port \[default: 1723\]]:port:'
  '-n[number of parallel tries \[default: 5\]]:number:'
  '-l[limit to n passwords / sec \[default: 100\]]:limit:'
  '*:filename:_files'
)

_arguments -s -S $arguments
