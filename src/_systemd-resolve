#compdef systemd-resolve resolvectl

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help]'
  '--version[show package version]'
  '-4[resolve IPv4 addresses only]'
  '-6[resolve IPv6 addresses only]'
  {-i+,--interface=}'[look on specified interface]:interface:_net_interfaces'
  {-p+,--protocol=}'[look via specified protocol]:protocol:(dns llmnr llmnr-ipv4 llmnr-ipv6 mdns mdns-ipv4 mdns-ipv6)'
  {-t+,--type=}'[query RR with DNS type]:type:(A AAAA ANY CNAME DNAME HINFO MX NS PTR SOA SRV SSHFP TLSA TXT)'
  {-c+,--class=}'[query RR with DNS class]:class:(IN ANY)'
  '--service[resolve service (SRV)]'
  '--service-address=[resolve address for services]:boolean:(true false)'
  '--service-txt=[resolve TXT records for services]:boolean:(true false)'
  '--cname=[follow CNAME/DNAME redirects]:boolean:(true false)'
  '--validate=[apply DNSSEC validation]:boolean:(true false)'
  '--synthesize=[resolve select domains locally]:boolean:(true false)'
  '--cache=[use local DNS cache]:boolean:(true false)'
  '--zone=[answer from local LLMNR/mDNS records]:boolean:(true false)'
  '--trust-anchor=[answer from local DNSSEC trust anchors]:boolean:(true false)'
  '--network=[answer via network requests]:boolean:(true false)'
  '--search=[use search domains for single-label names]:boolean:(true false)'
  '--raw=[dump answer records as binary data]:format:(payload packet)'
  '--legend=[print column headers and meta information]:boolean:(true false)'
  '--stale-data=[allow use of expired resource records]:boolean:(true false)'
  '--relax-single-label=[relax routing rules for single-label names]:boolean:(true false)'
  '--no-ask-password[do not query user for authentication]'
  '--json=[output as JSON]:mode:(short pretty off)'
  '-j[output as JSON (shortcut for --json=pretty on tty)]'
  '--no-pager[do not pipe output into a pager]'
  '*:domain or address:_hosts'
)

_arguments -s -S $arguments
