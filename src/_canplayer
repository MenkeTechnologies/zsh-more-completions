#compdef canplayer

local -a arguments

arguments=(
  '-I[input file (default stdin)]:file:_files'
  '-l[process input file num times]:num:'
  '-t[ignore timestamps: send frames immediately]'
  '-g[gap in milliseconds (default: 1 ms)]:gap:'
  '-s[skip gaps in timestamps > s seconds]:seconds:'
  '-x[disable local loopback of sent CAN frames]'
  '-v[verbose: print sent CAN frames]'
  '*:filename:_files'
)

_arguments -s -S $arguments
