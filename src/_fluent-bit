#compdef fluent-bit

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config}'=[configuration file]:config file:_files' \
  '(-d --daemon)'{-d,--daemon}'[run in background mode]' \
  '(-D --dry-run)'{-D,--dry-run}'[dry run]' \
  '(-f --flush)'{-f,--flush}'=[set flush time in seconds]:seconds' \
  '(-F --filter)'{-F,--filter}'=[set a filter]:filter:(grep modify record_modifier lua kubernetes throttle nest parser geoip2 rewrite_tag)' \
  '(-i --input)'{-i,--input}'=[set an input]:input:(cpu mem thermal disk proc net serial stdin tail forward mqtt head dummy random syslog exec kmsg collectd statsd opentelemetry)' \
  '(-m --match)'{-m,--match}'=[set a match (output/filter)]:match pattern' \
  '(-o --output)'{-o,--output}'=[set an output]:output:(stdout file forward http es influxdb datadog splunk cloudwatch_logs s3 kafka prometheus_exporter loki stackdriver azure_blob null counter flowcounter)' \
  '(-p --prop)'{-p,--prop}'=[set property (key=value)]:property' \
  '(-e --plugin)'{-e,--plugin}'=[load external plugin]:plugin file:_files' \
  '(-l --log_file)'{-l,--log_file}'=[write log to a file]:log file:_files' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-R --parser)'{-R,--parser}'=[specify an additional parser file]:parser file:_files' \
  '(-s --coro_stack_size)'{-s,--coro_stack_size}'=[set coroutine stack size in bytes]:bytes' \
  '(-S --sosreport)'{-S,--sosreport}'[support report for offline analysis]' \
  '(-T --sp-task)'{-T,--sp-task}'=[define a stream processor task]:task' \
  '--hot-reload[enable hot reload]' \
  '--enable-chunk-trace[enable chunk tracing]' \
  '-v[increase logging verbosity]' \
  '--verbose[increase logging verbosity]' \
  '--workdir=[set working directory]:directory:_directories' \
  '--storage_path=[set storage path]:directory:_directories' \
  '--plugin=[load external plugin]:plugin file:_files' && ret=0

return ret
