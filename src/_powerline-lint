#compdef powerline-lint
# Documentation: https://man.archlinux.org/search?q=powerline-lint
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-p,--config-path}'[paths where configuration should be checked, in order.]'
  {-d,--debug}'[display additional information. Used for debugging]'
  '*:filename:_files'
)

_arguments -s -S $arguments
