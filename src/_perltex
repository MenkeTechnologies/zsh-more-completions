#compdef perltex
# Documentation: https://man.archlinux.org/search?q=perltex
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--help[display basic usage information.]'
  '--latex[specify a program to use instead of latex. For example]'
  '--permit[permit particular Perl operations to be performed. The --permit]'
  '--makesty[generate a LaTeX style file called noperltex.sty. Replacing the]'
  '*:filename:_files'
)

_arguments -s -S $arguments
