#compdef vue-init
# Documentation: https://man.archlinux.org/search?q=vue-init
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-c,--clone}'[use git clone]'
  '--offline[use cached template]'
  {-h,--help}'[output usage information]'
  '*:filename:_files'
)

_arguments -s -S $arguments
