#compdef mev
# Documentation: https://man.archlinux.org/search?q=mev
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-C[choose virtual console (beware of it)]'
  '-d[choose the default mask]'
  '-e[choose the eventMask]'
  '-E[emacs-mode]'
  '-i[accept commands from stdin]'
  '-f[fit drag events inside the screen]'
  '-m[minimum modifier mask]'
  '-M[maximum modifier mask]'
  '-p[show pointer while dragging]'
  '-u[user-mode (default)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
