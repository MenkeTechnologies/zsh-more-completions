#compdef unidecode
# Documentation: https://man.archlinux.org/search?q=unidecode
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-e,--encoding}'[specify an encoding (default is UTF-8)]'
  '-c[transliterate TEXT instead of FILE]'
  '*:filename:_files'
)

_arguments -s -S $arguments
