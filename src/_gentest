#compdef gentest

local -a arguments

arguments=(
  '--smb2[use SMB2 protocol]'
  '--seed[seed to use for randomizer]:seed:'
  '--num-ops[number of operations]:num:'
  '--oplocks[use oplocks]'
  '--showall[display all operations]'
  '--analyse[do backtrack analysis]'
  '--analysealways[analysis always]'
  '--analysecontinuous[analysis continuous]'
  '--ignore[ignore from file]:file:_files'
  '--preset[use preset seeds]'
  '--fast[use fast reconnect]'
  '--unclist[UNC list file]:file:_files'
  '--seedsfile[seed file]:file:_files'
  {-U,--user}'[set the network username]:user:'
  '--maskindexing[mask out the indexed file attrib]'
  '--noeas[dont use extended attributes]'
  '--noacls[dont use ACLs]'
  '--skip-cleanup[dont delete files at start]'
  '--valid[generate only valid fields]'
  '--usage[display brief usage message]'
  {-d,--debuglevel}'[set debug level]:level:'
  '--debug-stderr[send debug output to STDERR]'
  {-s,--configfile}'[use alternative configuration]:file:_files'
  '--option[set smb.conf option from command line]:option=value:'
  {-l,--log-basename}'[basename for log/debug files]:basename:'
  '--leak-report[enable talloc leak reporting on exit]'
  '--leak-report-full[enable full talloc leak reporting]'
  {-R,--name-resolve}'[use these name resolution services]:order:'
  {-O,--socket-options}'[socket options to use]'
  {-n,--netbiosname}'[primary netbios name]'
  {-S,--signing}'[set the client signing state]:state:(on off required)'
  {-W,--workgroup}'[set the workgroup name]'
  '--realm[set the realm name]'
  {-i,--scope}'[use this Netbios scope]'
  {-m,--maxprotocol}'[set max protocol level]'
  {-N,--no-pass}'[dont ask for a password]'
  '--password[password]:password:'
  {-A,--authentication-file}'[get the credentials from a file]:file:_files'
  {-P,--machine-pass}'[use stored machine account password]'
  '--simple-bind-dn[DN to use for a simple bind]'
  {-k,--kerberos}'[use Kerberos, -k \[yes|no\]]'
  '--krb5-ccache[credentials cache location for Kerberos]:ccache:'
  '--sign[sign connection to prevent modification]'
  {-e,--encrypt}'[encrypt connection for privacy]'
  {-V,--version}'[print version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
