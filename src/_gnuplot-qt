#compdef gnuplot-qt

local -a arguments

arguments=(
  {-V,--version}'[show version information]'
  '(- * :)'{-h,--help}'[show help information]'
  {-p,--persist}'[do not close plot windows after script ends]'
  {-d,--default-settings}'[do not read settings from ~/.gnuplot]'
  '-c[execute script file with arguments]:script:_files'
  '-e[execute command string]:command:'
  '*:filename:_files'
)

_arguments -s -S $arguments
