#compdef checkov

local -a _checkov_frameworks
_checkov_frameworks=(
  cloudformation terraform terraform_plan kubernetes serverless arm
  dockerfile secrets github_configuration gitlab_configuration
  bitbucket_configuration github_actions gitlab_ci bitbucket_pipelines
  circleci_pipelines argo_workflows openapi helm kustomize
  sca_package sca_image ansible bicep
)

_arguments -s -S \
  {-h,--help}'[show help]' \
  {-v,--version}'[show version]' \
  {-d,--directory}'[directory to scan]:dir:_directories' \
  {-f,--file}'[file to scan]:file:_files' \
  '--skip-check[skip specific checks]:check IDs:' \
  '--check[run specific checks]:check IDs:' \
  '--framework[specify framework]:framework:('"${_checkov_frameworks[*]}"')' \
  {-o,--output}'[output format]:format:(cli json junitxml csv sarif github_failed_only cyclonedx)' \
  '--output-file-path[output file directory]:dir:_directories' \
  '--repo-id[repository ID]:id:' \
  '--branch[branch name]:name:' \
  {-s,--soft-fail}'[return 0 exit code on findings]' \
  '--soft-fail-on[soft fail for specific checks]:check IDs:' \
  '--hard-fail-on[hard fail for specific checks]:check IDs:' \
  '--bc-api-key[Bridgecrew API key]:key:' \
  '--config-file[config file path]:file:_files' \
  '--external-checks-dir[external checks directory]:dir:_directories' \
  '--external-checks-git[external checks git URL]:url:' \
  '--list[list all available checks]' \
  '--skip-framework[skip specific frameworks]:framework:('"${_checkov_frameworks[*]}"')' \
  '--compact[compact output]' \
  '--quiet[suppress output]' \
  '--download-external-modules[download external modules]' \
  '--evaluate-variables[evaluate variables]' \
  '--var-file[variable file]:file:_files' \
  '--min-cve-severity[minimum CVE severity]:severity:(low medium high critical)' \
  '--skip-cve-package[skip CVE for package]:package:' \
  '--ca-certificate[CA certificate file]:file:_files' \
  '--no-guide[disable guide]' \
  '--skip-suppressions[skip suppressions]' \
  '--include-all-checkov-policies[include all checkov policies]' \
  '--create-config[create config file]:file:_files' \
  '--show-config[show config]' \
  '--skip-path[skip path]:path:_files' \
  '--baseline[baseline file]:file:_files' \
  '--use-enforcement-rules[use enforcement rules]' \
  '--prisma-api-url[Prisma Cloud API URL]:url:' \
  '--policy-metadata-filter[policy metadata filter]:filter:'
