#compdef systemd-cgtop

local arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help]'
  '--version[show package version]'
  '(-t -c -m -i)'{-p,--order=path}'[order by control group path name]'
  '(-p -c -m -i)'{-t,--order=tasks}'[order by number of tasks/processes]'
  '(-p -t -m -i)'{-c,--order=cpu}'[order by CPU load (default)]'
  '(-p -t -c -i)'{-m,--order=memory}'[order by memory usage]'
  '(-p -t -c -m)'{-i,--order=io}'[order by IO load]'
  {-b,--batch}'[run in batch mode, accepting no input]'
  {-r,--raw}'[provide raw (not human-readable) numbers]'
  '--cpu=[show CPU usage as percentage or time]:mode:(percentage time)'
  '-P[count only userspace processes instead of all tasks]'
  '-k[count userspace processes and kernel threads instead of all tasks]'
  '--recursive=[include processes of child control groups]:boolean:(true false)'
  {-n+,--iterations=}'[run for N iterations before exiting]:iterations'
  '-1[shortcut for --iterations=1]'
  {-d+,--delay=}'[delay between updates]:delay (seconds)'
  '--depth=[maximum control group tree traversal depth]:depth'
  {-M,--machine=}'[show container]:machine'
  '*::control group path:_directories'
)

_arguments -s $arguments
