#compdef cut gcut

# Zsh completion for cut (GNU coreutils and BSD)

_cut() {
  local -a args

  args=(
    '(-c -f -b --bytes)'{-b,--bytes=}'[select only these bytes]:byte list'
    '(-b -f -c --characters)'{-c,--characters=}'[select only these characters]:character list'
    '(-b -c -f --fields)'{-f,--fields=}'[select only these fields]:field list'
    '(-w)-d+[use specified delimiter instead of TAB]:delimiter'
    '(-w)--delimiter=[use specified delimiter instead of TAB]:delimiter'
    '-n[do not split multi-byte characters]'
    '-w[use whitespace (spaces and tabs) as the delimiter]'
    '--complement[complement the set of selected bytes, characters or fields]'
    {-s,--only-delimited}'[do not print lines not containing delimiters]'
    '--output-delimiter=[use STRING as the output delimiter]:string'
    {-z,--zero-terminated}'[line delimiter is NUL, not newline]'
    '(- *)--help[display help and exit]'
    '(- *)--version[output version information and exit]'
    '*:file:_files'
  )

  _arguments -s -S $args
}

_cut "$@"
