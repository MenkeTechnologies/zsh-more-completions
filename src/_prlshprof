#compdef prlshprof
# Documentation: https://man.archlinux.org/search?q=prlshprof
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[This help]'
  '-l[Logging level \[0, 3\], default 2]'
  '-v[Verbose logging, set log level to 3]'
  '*:filename:_files'
)

_arguments -s -S $arguments
