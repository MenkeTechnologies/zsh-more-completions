#compdef ldns-dpa

local -a arguments

arguments=(
  '-c[count occurrences of matching expressions]'
  '-f[filter occurrences of matching expressions]'
  '-h[show this help]'
  '-p[show percentage of -u and -c values of the total]'
  '-of[write pcap packets that match the -f flag to file]'
  '-ofh[write pcap packets that match the -f flag to file]'
  '-s[show possible match names, operators, and values]'
  '-sf[print packets that match -f filter]'
  '-u[count all occurrences of matchname]'
  '-ua[Show average value of every -u matchname]'
  '-uac[Show average count of every -u matchname]'
  '-um[only show -u results that occured more than number times]'
  '-v[be more verbose]'
  '-notip[dump pcap packets that were not recognized as IP]'
  '-baddns[dump mangled dns packets to file]'
  '-version[Show the version and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
