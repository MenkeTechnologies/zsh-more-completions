#compdef nnn
# Documentation: https://man.archlinux.org/search?q=nnn
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-b[bookmark key to open]'
  '-C[disable directory color]'
  '-e[use exiftool instead of mediainfo]'
  '-i[start in navigate-as-you-type mode]'
  '-l[start in light mode]'
  '-p[copy selection to file (stdout if -)]'
  '-S[start in disk usage analyser mode]'
  '-v[show program version]'
  '-h[show this help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
