#compdef pango-view

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  '--help-all[show all help options]'
  '--help-cairo[options understood by the cairo backend]'
  '--no-auto-dir[no layout direction according to contents]'
  '--backend[Pango backend to use for rendering (default: cairo)]:backend:(cairo xft ft2)'
  '--background[set the background color]:color'
  {-q,--no-display}'[do not display (just write to file or whatever)]'
  '--dpi[set the resolution]'
  '--align[text alignment]:alignment:(left center right)'
  '--ellipsize[ellipsization mode]:mode:(start middle end)'
  '--font[set the font description]'
  '--foreground[set the text color]:color'
  '--gravity[base gravity for glyph rotation]:gravity:(south east north west auto)'
  '--gravity-hint[gravity hint]:hint:(natural strong line)'
  '--header[display the options in the output]'
  '--height[height in points (positive) or number of lines (negative) for ellipsizing]:height'
  '--hinting[hinting style]:style:(none auto full)'
  '--indent[width in points to indent paragraphs]'
  '--justify[align paragraph lines to be justified]'
  '--language[language to use for font selection]:language'
  '--margin[set the margin on the output in pixels]:pixels'
  '--markup[interpret text as Pango markup]'
  {-o,--output}'[save rendered image to output file]'
  '--pixels[use pixel units instead of points (sets dpi to 72)]'
  '--rtl[set base direction to right-to-left]'
  '--rotate[angle at which to rotate results]'
  {-n,--runs}'[run Pango layout engine this many times]'
  '--single-par[enable single-paragraph mode]'
  {-t,--text}'[text to display (instead of a file)]'
  '--version[show version numbers]'
  '--waterfall[create a waterfall display]'
  {-w,--width}'[width in points to which to wrap lines or ellipsize]'
  '--wrap[text wrapping mode (needs a width to be set)]:mode:(word char word-char)'
  '*:filename:_files'
)

_arguments -s -S $arguments
