#compdef amazon-ssm-agent
# Documentation: https://man.archlinux.org/search?q=amazon-ssm-agent
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-clear[clear registration]'
  '-code[activation code]'
  '-fingerprint[enable ingerprint]'
  '-i[instance id]'
  '-id[activation ID]'
  '-r[instance region]'
  '-region[AWS region]'
  '-register[register agent]'
  '-similarityThreshold[(default 40)]'
  '-y[answer yes to prompts]'
  '*:filename:_files'
)

_arguments -s -S $arguments
