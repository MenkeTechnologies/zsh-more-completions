#compdef meshctl
# Documentation: https://man.archlinux.org/search?q=meshctl
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--config[local mesh config JSON files from <directory>]'
  '--timeout[in seconds for non-interactive mode]'
  '--version[version]'
  '--help[display help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
