#compdef mdcat

# Zsh completion for mdcat - cat for Markdown

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--no-colour[disable all colours and other styles]' \
  '(-c --no-colour --ansi)'{-c,--ansi}'[force ANSI style output]' \
  '--columns=[set maximum number of columns to use]:columns:' \
  '(-l --local)'{-l,--local}'[do not load remote resources]' \
  '--fail[fail on broken links]' \
  '-p[paginate output with a pager]' \
  '--detect-terminal[detect terminal capabilities]' \
  '*:markdown file:_files -g "*.(md|markdown|mkd|mdown)"' && ret=0

return ret
