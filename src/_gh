#compdef gh

# Zsh completion for GitHub CLI (gh)
# Updated with all commands and subcommands as of gh 2.x

local -a _gh_global_flags

_gh_global_flags=(
  '(- *)'{-h,--help}'[show help for command]'
  '--version[show gh version]'
)

_gh_repo_flag=(
  {-R,--repo}'[select another repository using the \[HOST/\]OWNER/REPO format]:repo:'
)

_gh_json_flags=(
  '--json[output JSON with specified fields]:fields:'
  {-q,--jq}'[filter JSON output using a jq expression]:expression:'
  {-t,--template}'[format JSON output using a Go template]:template:'
)

