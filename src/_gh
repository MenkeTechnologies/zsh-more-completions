_gh() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    $_gh_global_flags \
    '1:command:->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'gh command' _gh_commands
      ;;
    args)
      case $line[1] in
        auth)
          _arguments -C \
            $_gh_global_flags \
            '1:subcommand:->subcmd' \
            '*::arg:->subargs'
          case $state in
            subcmd) _describe -t commands 'auth command' _gh_auth_commands ;;
            subargs)
              case $line[1] in
                login)
                  _arguments \
                    $_gh_global_flags \
                    {-p,--git-protocol}'[the protocol to use for git operations]:protocol:(ssh https)' \
                    {-h,--hostname}'[the hostname of the GitHub instance to authenticate with]:hostname:' \
                    {-s,--scopes}'[additional authentication scopes to request]:scopes:' \
                    {-w,--web}'[open a browser to authenticate]' \
                    '--with-token[read token from standard input]' \
                    '--insecure-storage[save authentication credentials in plain text]' \
                    '--skip-ssh-key[skip generating a new SSH key]'
                  ;;
                logout)
                  _arguments \
                    $_gh_global_flags \
                    {-h,--hostname}'[the hostname of the GitHub instance]:hostname:' \
                    {-u,--user}'[the account to log out of]:user:'
                  ;;
                refresh)
                  _arguments \
                    $_gh_global_flags \
                    {-h,--hostname}'[the GitHub host to refresh credentials for]:hostname:' \
                    {-s,--scopes}'[additional authentication scopes for gh to have]:scopes:' \
                    '--remove-scopes[authentication scopes to remove from gh]:scopes:' \
                    '--insecure-storage[save authentication credentials in plain text]'
                  ;;
                setup-git)
                  _arguments \
                    $_gh_global_flags \
                    {-h,--hostname}'[the hostname to configure git for]:hostname:' \
                    '--force[force setup even if the host is not known]'
                  ;;
                status)
                  _arguments \
                    $_gh_global_flags \
                    {-h,--hostname}'[check a specific hostname]:hostname:' \
                    {-t,--show-token}'[display the auth token]'
                  ;;
                switch)
                  _arguments \
                    $_gh_global_flags \
                    {-h,--hostname}'[the hostname of the GitHub instance]:hostname:' \
                    {-u,--user}'[the account to switch to]:user:'
                  ;;
                token)
                  _arguments \
                    $_gh_global_flags \
                    {-h,--hostname}'[the hostname of the GitHub instance]:hostname:' \
                    {-u,--user}'[the account to print the token for]:user:'
                  ;;
              esac
              ;;
          esac
          ;;
        browse)
          _arguments \
            $_gh_global_flags \
            $_gh_repo_flag \
            {-a,--actions}'[open repository actions]' \
            '--blame[open blame view for a file]' \
            {-b,--branch}'[select another branch]:branch:' \
            {-c,--commit}'[select another commit by SHA]:commit sha:' \
            {-n,--no-browser}'[print destination URL instead of opening the browser]' \
            {-p,--projects}'[open repository projects]' \
            {-r,--releases}'[open repository releases]' \
            {-s,--settings}'[open repository settings]' \
            {-w,--wiki}'[open repository wiki]' \
            '*:path:_files'
          ;;
        codespace|cs)
          _arguments -C \
            $_gh_global_flags \
            '1:subcommand:->subcmd' \
            '*::arg:->subargs'
          case $state in
            subcmd) _describe -t commands 'codespace command' _gh_codespace_commands ;;
            subargs)
              case $line[1] in
                create)
                  _arguments \
                    $_gh_global_flags \
                    $_gh_repo_flag \
                    {-b,--branch}'[repository branch]:branch:' \
                    '--default-permissions[do not prompt to accept additional permissions]' \
                    '--devcontainer-path[path to the devcontainer.json file]:path:_files' \
                    {-d,--display-name}'[display name for the codespace]:name:' \
                    '--idle-timeout[allowed inactivity before codespace is stopped]:duration:' \
                    {-l,--location}'[location to create the codespace]:location:' \
                    {-m,--machine}'[hardware specifications for the VM]:machine:' \
                    '--retention-period[allowed time after shutting down before the codespace is deleted]:period:' \
                    {-s,--status}'[show status of post-create command and dotfiles]' \
                    {-w,--web}'[create codespace from browser]'
                  ;;
                list|ls)
                  _arguments \
                    $_gh_global_flags \
                    $_gh_repo_flag \
                    $_gh_json_flags \
                    {-o,--org}'[the login handle of the organization]:org:' \
                    {-u,--user}'[the username to list codespaces for]:user:' \
                    {-L,--limit}'[maximum number of codespaces to list]:limit:' \
                    {-w,--web}'[list codespaces in the web browser]'
                  ;;
                delete)
                  _arguments \
                    $_gh_global_flags \
                    $_gh_repo_flag \
                    '--all[delete all codespaces]' \
                    {-c,--codespace}'[name of the codespace]:codespace:' \
                    '--days[delete codespaces older than N days]:days:' \
                    {-f,--force}'[skip confirmation for codespaces that contain unsaved changes]' \
                    {-o,--org}'[the login handle of the organization]:org:' \
                    {-u,--user}'[the username to delete codespaces for]:user:'
                  ;;
                stop)
                  _arguments \
                    $_gh_global_flags \
                    $_gh_repo_flag \
                    {-c,--codespace}'[name of the codespace]:codespace:' \
                    {-o,--org}'[the login handle of the organization]:org:' \
                    {-u,--user}'[the username to stop codespace for]:user:'
                  ;;
                *)
                  _arguments \
                    $_gh_global_flags \
                    {-c,--codespace}'[name of the codespace]:codespace:'
                  ;;
              esac
              ;;
          esac
          ;;
        gist)
          _arguments -C \
            $_gh_global_flags \
            '1:subcommand:->subcmd' \
            '*::arg:->subargs'
          case $state in
            subcmd) _describe -t commands 'gist command' _gh_gist_commands ;;
            subargs)
              case $line[1] in
                create)
                  _arguments \
                    $_gh_global_flags \
                    {-d,--desc}'[a description for this gist]:description:' \
                    {-f,--filename}'[provide a filename to be used when reading from stdin]:filename:' \
                    {-p,--public}'[list the gist publicly (default: secret)]' \
                    {-w,--web}'[open the web browser with created gist]' \
                    '*:files:_files'
                  ;;
                edit)
                  _arguments \
                    $_gh_global_flags \
                    {-a,--add}'[add a new file to the gist]:filename:' \
                    {-d,--desc}'[a new description for this gist]:description:' \
                    {-f,--filename}'[select a file to edit]:filename:' \
                    {-r,--remove}'[remove a file from the gist]:filename:' \
                    ':gist ID or URL:'
                  ;;
                list)
                  _arguments \
                    $_gh_global_flags \
                    {-L,--limit}'[maximum number of gists to fetch]:limit:' \
                    '--public[show only public gists]' \
                    '--secret[show only secret gists]'
                  ;;
                view)
                  _arguments \
                    $_gh_global_flags \
                    {-f,--filename}'[display a single file from the gist]:filename:' \
                    '--files[list file names from the gist]' \
                    {-r,--raw}'[print raw instead of rendered gist contents]' \
                    {-w,--web}'[open gist in the browser]' \
                    ':gist ID or URL:'
                  ;;
                clone)
                  _arguments \
                    $_gh_global_flags \
                    ':gist ID or URL:' \
                    ':directory:_directories'
                  ;;
                delete)
                  _arguments \
                    $_gh_global_flags \
                    ':gist ID or URL:'
                  ;;
                rename)
                  _arguments \
                    $_gh_global_flags \
                    ':gist ID or URL:' \
                    ':old filename:' \
                    ':new filename:'
                  ;;
              esac
              ;;
          esac
          ;;
        gpg-key)
          _arguments -C \
            $_gh_global_flags \
            '1:subcommand:->subcmd' \
            '*::arg:->subargs'
          case $state in
            subcmd) _describe -t commands 'gpg-key command' _gh_gpg_key_commands ;;
            subargs)
              case $line[1] in
                add)
                  _arguments \
                    $_gh_global_flags \
                    '--title[title for the new key]:title:' \
                    ':key file:_files'
                  ;;
                delete)
                  _arguments \
                    $_gh_global_flags \
                    '--confirm[skip the confirmation prompt]' \
                    ':key ID:'
                  ;;
              esac
              ;;
          esac
          ;;
        issue)
          _arguments -C \
            $_gh_global_flags \
            $_gh_repo_flag \
            '1:subcommand:->subcmd' \
            '*::arg:->subargs'
          case $state in
            subcmd) _describe -t commands 'issue command' _gh_issue_commands ;;
            subargs)
              case $line[1] in
                create)
                  _arguments \
                    $_gh_global_flags \
                    $_gh_repo_flag \
                    {-t,--title}'[supply a title]:title:' \
                    {-b,--body}'[supply a body]:body:' \
                    {-F,--body-file}'[read body text from file]:file:_files' \
                    {-a,--assignee}'[assign people by their login]:assignee:' \
                    {-l,--label}'[add labels by name]:label:' \
                    {-p,--project}'[add the issue to projects by name]:project:' \
                    {-m,--milestone}'[add the issue to a milestone by name]:milestone:' \
                    {-w,--web}'[open the browser to create an issue]' \
                    {-e,--editor}'[skip prompts and open the text editor]' \
                    '--template[template name or path to use as the body]:template:_files' \
                    '--recover[recover input from a failed run of create]:file:_files'
                  ;;
                list)
                  _arguments \
                    $_gh_global_flags \
                    $_gh_repo_flag \
                    $_gh_json_flags \
                    {-s,--state}'[filter by state]:state:(open closed all)' \
                    {-l,--label}'[filter by label]:label:' \
                    {-a,--assignee}'[filter by assignee]:assignee:' \
                    '--author[filter by author]:author:' \
                    '--mention[filter by mention]:mention:' \
                    {-m,--milestone}'[filter by milestone]:milestone:' \
                    {-S,--search}'[search issues with query]:query:' \
                    {-L,--limit}'[maximum number of issues to fetch]:limit:' \
                    {-w,--web}'[list issues in the web browser]' \
                    '--app[filter by GitHub App author]:app:'
                  ;;
                view)
                  _arguments \
                    $_gh_global_flags \
                    $_gh_repo_flag \
                    $_gh_json_flags \
                    {-c,--comments}'[view issue comments]' \
                    {-w,--web}'[open an issue in the browser]' \
                    ':issue number or URL:'
                  ;;
                close)
                  _arguments \
                    $_gh_global_flags \
                    $_gh_repo_flag \
                    {-c,--comment}'[leave a closing comment]:comment:' \
                    {-r,--reason}'[reason for closing]:reason:(completed "not planned")' \
                    ':issue number or URL:'
                  ;;
                reopen)
                  _arguments \
                    $_gh_global_flags \
                    $_gh_repo_flag \
                    {-c,--comment}'[leave a reopening comment]:comment:' \
                    ':issue number or URL:'
                  ;;
                edit)
                  _arguments \
                    $_gh_global_flags \
                    $_gh_repo_flag \
                    '--add-assignee[add assigned users by their login]:assignee:' \
                    '--add-label[add labels by name]:label:' \
                    '--add-project[add the issue to projects by name]:project:' \
                    {-b,--body}'[set the new body]:body:' \
                    {-F,--body-file}'[read body text from file]:file:_files' \
                    {-m,--milestone}'[edit the milestone the issue belongs to]:milestone:' \
                    '--remove-assignee[remove assigned users by their login]:assignee:' \
                    '--remove-label[remove labels by name]:label:' \
                    '--remove-project[remove the issue from projects by name]:project:' \
                    {-t,--title}'[set the new title]:title:' \
                    ':issue number or URL:'
                  ;;
                comment)
                  _arguments \
                    $_gh_global_flags \
                    $_gh_repo_flag \
                    {-b,--body}'[the comment body]:body:' \
                    {-F,--body-file}'[read body text from file]:file:_files' \
                    {-e,--editor}'[skip prompts and open the text editor]' \
                    {-w,--web}'[open the web browser to write the comment]' \
                    ':issue number or URL:'
                  ;;
                delete)
                  _arguments \
                    $_gh_global_flags \
                    $_gh_repo_flag \
                    '--confirm[skip the confirmation prompt]' \
                    ':issue number or URL:'
                  ;;
                lock)
                  _arguments \
                    $_gh_global_flags \
                    $_gh_repo_flag \
                    {-r,--reason}'[reason for locking]:reason:(off-topic resolved spam too\ heated)' \
                    ':issue number or URL:'
                  ;;
                develop)
                  _arguments \
                    $_gh_global_flags \
                    $_gh_repo_flag \
                    {-b,--base}'[name of the base branch]:branch:' \
                    '--checkout[checkout the branch after creating it]' \
                    {-l,--list}'[list linked branches for the issue]' \
                    {-n,--name}'[name of the branch to create]:branch:' \
                    ':issue number or URL:'
                  ;;
                pin)
                  _arguments $_gh_global_flags $_gh_repo_flag ':issue number or URL:'
                  ;;
                unpin)
                  _arguments $_gh_global_flags $_gh_repo_flag ':issue number or URL:'
                  ;;
                unlock)
                  _arguments $_gh_global_flags $_gh_repo_flag ':issue number or URL:'
                  ;;
                transfer)
                  _arguments \
                    $_gh_global_flags \
                    $_gh_repo_flag \
                    ':issue number or URL:' \
                    ':destination repo:'
                  ;;
                status)
                  _arguments $_gh_global_flags $_gh_repo_flag $_gh_json_flags
                  ;;
              esac
              ;;
          esac
          ;;
        org)
          _arguments -C \
            $_gh_global_flags \
            '1:subcommand:->subcmd' \
            '*::arg:->subargs'
          case $state in
            subcmd) _describe -t commands 'org command' _gh_org_commands ;;
            subargs)
              case $line[1] in
                list)
                  _arguments \
                    $_gh_global_flags \
                    {-L,--limit}'[maximum number of organizations to list]:limit:'
                  ;;
              esac
              ;;
          esac
          ;;
        pr)
          _arguments -C \
            $_gh_global_flags \
            $_gh_repo_flag \
            '1:subcommand:->subcmd' \
            '*::arg:->subargs'
          case $state in
            subcmd) _describe -t commands 'pr command' _gh_pr_commands ;;
            subargs)
              case $line[1] in
                create)
                  _arguments \
                    $_gh_global_flags \
                    $_gh_repo_flag \
                    {-t,--title}'[supply a title for the pull request]:title:' \
                    {-b,--body}'[supply a body for the pull request]:body:' \
                    {-F,--body-file}'[read body text from file]:file:_files' \
                    {-B,--base}'[the branch into which you want your code merged]:branch:' \
                    {-H,--head}'[the branch that contains commits for your pull request]:branch:' \
                    {-d,--draft}'[mark pull request as a draft]' \
                    {-f,--fill}'[use commits info for title and body]' \
                    '--fill-verbose[use commits info for title and body including full commit bodies]' \
                    '--fill-first[use first commit info for title and body]' \
                    {-l,--label}'[add labels by name]:label:' \
                    {-a,--assignee}'[assign people by their login]:assignee:' \
                    '--reviewer[request reviews from people or teams]:reviewer:' \
                    {-m,--milestone}'[add the pull request to a milestone by name]:milestone:' \
                    {-p,--project}'[add the pull request to projects by name]:project:' \
                    {-w,--web}'[open the web browser to create a pull request]' \
                    {-e,--editor}'[skip prompts and open the text editor]' \
                    '--no-maintainer-edit[disable maintainer ability to modify pull request]' \
                    '--recover[recover input from a failed run of create]:file:_files' \
                    '--template[template file to use as starting body text]:file:_files'
                  ;;
                list)
                  _arguments \
                    $_gh_global_flags \
