#compdef cygdb
# Documentation: https://man.archlinux.org/search?q=cygdb
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  '--gdb-executable[gdb executable to use \[default: gdb\]]'
  {-v,--verbose}'[verbose mode. Multiple -v options increase the]'
  '*:filename:_files'
)

_arguments -s -S $arguments
