#compdef obxprop
# Documentation: https://man.archlinux.org/search?q=obxprop
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--help[display this help and exit]'
  '--display[connect to this X display]'
  '--id[show the properties for this window]'
  '--root[show the properties for the root window]'
  '*:filename:_files'
)

_arguments -s -S $arguments
