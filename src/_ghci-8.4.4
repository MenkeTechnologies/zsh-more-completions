#compdef ghci-8.4.4
# Documentation: https://man.archlinux.org/search?q=ghci-8.4.4
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-i[Search for imported modules in the directory <dir>.]:dir:'
  '-H32m[increase GHCs default heap size to 32m]'
  '-cpp[enable CPP processing of source files]'
  '*:filename:_files'
)

_arguments -s -S $arguments
