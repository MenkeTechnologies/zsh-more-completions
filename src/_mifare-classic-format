#compdef mifare-classic-format
# Documentation: https://man.archlinux.org/search?q=mifare-classic-format
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-f[fast format (only erase MAD)]'
  '-y[do not ask for confirmation (dangerous)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
