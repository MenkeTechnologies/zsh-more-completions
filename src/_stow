#compdef stow

# Zsh completion for stow - manage farms of symbolic links

_arguments -s -S \
  '(-d --dir)'{-d,--dir}'[set stow dir]:dir:_files -/' \
  '(-t --target)'{-t,--target}'[set target dir]:dir:_files -/' \
  '(-S --stow)'{-S,--stow}'[stow packages]:package:_files -/' \
  '(-D --delete)'{-D,--delete}'[unstow packages]:package:_files -/' \
  '(-R --restow)'{-R,--restow}'[restow packages (delete then stow)]:package:_files -/' \
  '--ignore[ignore files/folders matching regex]:regex:' \
  '--defer[defer stowing the given package]:package:' \
  '--override[override stowing the given package]:package:' \
  '--adopt[move existing files from target dir into the stow dir]' \
  '--no-folding[disable folding of newly stowed directories]' \
  '(-n --no --simulate)'{-n,--simulate}'[do not actually make any changes]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity (up to level 5)]' \
  '-vvvvv[maximum verbosity]' \
  '(-p --compat)'{-p,--compat}'[use legacy conflict resolution algorithm]' \
  '(-V --version)'{-V,--version}'[show version number]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:package:_files -/'
