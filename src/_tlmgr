#compdef tlmgr

local -a arguments

arguments=(
  '--repository[specify the package repository]:url:'
  '--gui[start the graphical user interface]'
  '--gui-lang[set GUI language]:lang:'
  '--debug-translation[report untranslated strings in GUI mode]'
  '--machine-readable[write machine-readable output instead of human-readable]'
  '--no-execute-actions[suppress execution of post-install actions]'
  '--package-logfile[specify package log file]:file:_files'
  '--pause[wait for user input before exiting]'
  '--persistent-downloads[use persistent HTTP connections (default)]'
  '--no-persistent-downloads[do not use persistent HTTP connections]'
  '--pin-file[change the pinning file location]:file:_files'
  '--usermode[activate user mode for this run]'
  '--usertree[specify tree directory for user mode]:directory:_directories'
  '--verify-repo[set verification level (none, main, all)]:level:(none main all)'
  '--backupdir[specify backup directory]:directory:_directories'
  '--all[apply to all packages]'
  '--clean[prune backup directory of old backups]:count:'
  '--dry-run[show actions without performing them]'
  '--use-svn[use svn status output instead of file listing]'
  '--local[dump the local TLPDB]'
  '--remote[dump the remote TLPDB]'
  '--json[output in JSON format]'
  '--dest[specify output file]:file:_files'
  '--localcfg[specify local config additions]:file:_files'
  '--rebuild-sys[run necessary programs after config changes]'
  '--list[list packages or files]'
  '--only-installed[only show installed packages]'
  '--only-remote[only list packages from the remote repository]'
  '--data[specify data items to output]:items:'
  '--file[use a local file instead of fetching from repository]:file:_files'
  '--force[force the operation]'
  '--no-depends[do not install/remove dependencies]'
  '--no-depends-at-all[do not install/remove any dependencies including binary ones]'
  '--reinstall[reinstall a package even if already installed]'
  '--with-doc[include documentation]'
  '--with-src[include source files]'
  '--w32mode[set Windows mode (user or admin)]:mode:(user admin)'
  '--fileassocmode[set file association mode (0, 1, or 2)]:mode:(0 1 2)'
  '--backup[make backups before updating]'
  '--global[search the installation medium database]'
  '--word[restrict search to full words]'
  '--self[update tlmgr itself]'
  '--exclude[exclude package from update]:package:'
  '--no-auto-remove[do not auto-remove packages]'
  '--no-auto-install[do not auto-install new packages]'
  '--reinstall-forcibly-removed[reinstall packages that were forcibly removed]'
  '*:filename:_files'
)

_arguments -s -S $arguments
