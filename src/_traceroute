#compdef traceroute

# Zsh completion for traceroute - print the route packets take to a network host

_traceroute() {
  local -a args
  local variant

  _pick_variant variant gnu='linux' unix --version 2>/dev/null

  case $variant in
    gnu)
      # Linux iproute2/traceroute
      args=(
        '-4[use IPv4]'
        '-6[use IPv6]'
        {-A,--as-path-lookups}'[perform AS path lookups in routing registries]'
        '--back[guess the number of hops in the backward path]'
        {-d,--debug}'[enable socket level debugging]'
        {-D,--dccp}'[use DCCP requests for tracerouting]'
        {-e,--extensions}'[show ICMP extensions (if present), including MPLS]'
        {-f,--first}'[start from the specified TTL hop instead of 1]:first_ttl'
        {-F,--do-not-fragment}'[do not fragment packets]'
        '--fwmark[set firewall mark for outgoing packets]:mark'
        '-g[specify a loose source route gateway (8 max)]:gateway:_hosts'
        {-I,--icmp}'[use ICMP ECHO for tracerouting]'
        {-i,--interface}'[specify network interface to operate with]:interface:_net_interfaces'
        {-l,--flowlabel}'[use specified flow_label for IPv6 packets]:flow_label'
        {-m,--max-hops}'[set the max number of hops (max TTL)]:max_ttl'
        {-M,--module}'[use specified module (builtin or external) for tracerouting]:module'
        '--mtu[discover MTU along the path being traced]'
        '-n[do not resolve IP addresses to their domain names]'
        {-N,--sim-queries}'[set the number of probes to be tried simultaneously]:number'
        {-O,--options}'[use module-specific option]:option'
        {-p,--port}'[set the destination port to use]:port'
        {-P,--protocol}'[use raw packet of specified protocol for tracerouting]:protocol'
        {-q,--queries}'[set the number of probes per each hop]:nqueries'
        '-r[bypass normal routing and send directly to attached network host]'
        {-s,--source}'[use specified source address for outgoing packets]:source:_hosts'
        '--sport[use specified source port for outgoing packets]:port'
        {-t,--tos}'[set the TOS (IPv4) or TC (IPv6) value for probe packets]:tos'
        {-T,--tcp}'[use TCP SYN for tracerouting (default port 80)]'
        {-U,--udp}'[use UDP to particular port for tracerouting (default port 53)]'
        '-UL[use UDPLITE for tracerouting]'
        {-V,--version}'[print version info and exit]'
        {-w,--wait}'[set time in seconds to wait for response to a probe]:seconds'
        {-z,--sendwait}'[minimal time interval between probes in ms (default 0)]:milliseconds'
        '(- *)--help[display help and exit]'
        '1:host:_hosts'
        '2::packet length (bytes)'
      )
      ;;
    *)
      # BSD/macOS traceroute
      args=(
        '-a[turn on AS# lookups for each hop encountered]'
        '-A[turn on AS# lookups and use given server]:as_server'
        '-d[enable socket level debugging]'
        '-D[print differences between transmitted and quoted packets]'
        '-e[firewall evasion mode (fixed destination ports)]'
        '-E[detect ECN bleaching]'
        '-f[set the initial time-to-live used in first outgoing probe packet]:first_ttl'
        '-F[set the "don'\''t fragment" bit]'
        '-g[specify a loose source route gateway (8 max)]:gateway:_hosts'
        '-i[specify network interface for source IP address]:interface:_net_interfaces'
        '-I[use ICMP ECHO instead of UDP datagrams]'
        '-M[set the initial time-to-live value used in outgoing probe packets]:first_ttl'
        '-m[set the max time-to-live (max number of hops)]:max_ttl'
        '-n[print hop addresses numerically rather than symbolically]'
        '-N[perform NAPT detection]'
        '-P[send packets of specified IP protocol]:protocol:(UDP TCP GRE ICMP)'
        '-p[set the base port number used in probes]:port'
        '-q[set the number of probes per TTL]:nqueries'
        '-r[bypass normal routing and send directly to attached network host]'
        '-s[use specified source address in outgoing probe packets]:source:_hosts'
        '-S[print summary of unanswered probes for each hop]'
        '-t[set the type-of-service in probe packets (0-255)]:tos'
        '-v[verbose output (list received ICMP packets other than TIME_EXCEEDED)]'
        '-w[set time in seconds to wait for a response (default 5)]:seconds'
        '-x[toggle IP checksums]'
        '-z[set time in milliseconds to pause between probes (default 0)]:milliseconds'
        '1:host:_hosts'
        '2::packet size (bytes)'
      )
      ;;
  esac

  _arguments -s -S : $args
}

_traceroute "$@"
