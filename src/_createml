#compdef createml

local -a subcommands

subcommands=(
    'image-classifier:Train an image classifier model'
    'text-classifier:Train a text classifier model'
    'tabular-classifier:Train a tabular classifier model'
    'tabular-regressor:Train a tabular regressor model'
    'object-detector:Train an object detection model'
    'sound-classifier:Train a sound classifier model'
    'activity-classifier:Train an activity classifier model'
    'word-tagger:Train a word tagger model'
    'style-transfer:Train a style transfer model'
    'recommendation:Train a recommendation model'
    'hand-pose-classifier:Train a hand pose classifier model'
    'body-pose-classifier:Train a body pose classifier model'
    'hand-action-classifier:Train a hand action classifier model'
    'body-action-classifier:Train a body action classifier model'
)

_arguments -s -S \
    '--help[Show help information]' \
    '--version[Show version]' \
    '1:subcommand:->subcmd' \
    '*:: :->args' && return

case $state in
    subcmd)
        _describe 'createml subcommand' subcommands
        ;;
    args)
        _arguments \
            '--training-data[Training data directory or file]:training data:_files' \
            '--validation-data[Validation data directory or file]:validation data:_files' \
            '--testing-data[Testing data directory or file]:testing data:_files' \
            '--output[Output model path]:output path:_files' \
            '--max-iterations[Maximum training iterations]:iterations' \
            '--augmentation[Data augmentation options]:augmentation:(crop rotation blur noise)' \
            '--scenario[Training scenario]:scenario' \
            '--seed[Random seed]:seed' \
            '--algorithm[Algorithm to use]:algorithm' \
            '--feature-columns[Feature columns]:columns' \
            '--target-column[Target column]:column' \
            '--help[Show help information]'
        ;;
esac
