#compdef strip

local arguments

arguments=(
  '-u[save all undefined symbols]'
  '-r[save all symbols referenced dynamically]'
  '-s+[save global symbols listed in file]:symbol file:_files'
  '-R+[remove global symbols listed in file]:symbol file:_files'
  '-i[ignore symbols in -s/-R files not found in input (normally an error)]'
  '-d+[save debugging entries for source files listed in file]:source list file:_files'
  '-A[save all global absolute symbols and Objective-C class symbols]'
  '-n[save all N_SECT global symbols]'
  '-S[remove debugging symbol table entries]'
  '-X[remove local symbols whose names begin with L]'
  '-T[remove Swift symbols from the Mach-O symbol table]'
  '-N[remove all nlist symbols and the string table from dynamic binaries]'
  '-x[remove all local symbols (keep only globals)]'
  '-c[remove section contents of a dynamic library (create stub library)]'
  '-D[set archive SYMDEF to reasonable defaults (deterministic)]'
  '-o+[write stripped output to specified file]:output file:_files'
  '-v[verbose: print arguments passed to tools run by strip]'
  '-no_uuid[remove any LC_UUID load commands]'
  '-no_split_info[remove the LC_SEGMENT_SPLIT_INFO load command and its payload]'
  '-no_atom_info[remove the LC_ATOM_INFO load command and its payload]'
  '-no_code_signature_warning[do not warn when code signature would be invalid in output]'
  '*-arch[specify architecture to operate on in universal file]:architecture:(x86_64 arm64 arm64e i386 all)'
  '(-I --input-target)'{-I,--input-target}'[assume input file is in specified format]:format:'
  '(-O --output-target)'{-O,--output-target}'[create output file in specified format]:format:'
  '(-F --target)'{-F,--target}'[set both input and output format]:format:'
  '(-p --preserve-dates)'{-p,--preserve-dates}'[copy modified/access timestamps to the output]'
  '--enable-deterministic-archives[produce deterministic output when stripping archives]'
  '--disable-deterministic-archives[disable deterministic behavior]'
  '--remove-section=[remove specified section from the output]:section:'
  '--remove-relocations=[remove relocations from specified section]:section:'
  '(-s --strip-all)--strip-all[remove all symbol and relocation information]'
  '(-g -S -d --strip-debug)'{-g,--strip-debug}'[remove all debugging symbols and sections]'
  '--strip-dwo[remove all DWO sections]'
  '--strip-unneeded[remove all symbols not needed by relocations]'
  '--only-keep-debug[strip everything but the debug information]'
  '(-M --merge-notes)'{-M,--merge-notes}'[remove redundant entries in note sections]'
  '--no-merge-notes[do not attempt to remove redundant notes]'
  '(-N --strip-symbol)'{-N,--strip-symbol}'=[do not copy specified symbol]:symbol:'
  '(-K --keep-symbol)'{-K,--keep-symbol}'=[do not strip specified symbol]:symbol:'
  '--keep-file-symbols[do not strip file symbol(s)]'
  '(-w --wildcard)'{-w,--wildcard}'[permit wildcards in symbol comparison]'
  '(--discard-all)--discard-all[remove all non-global symbols]'
  '(--discard-locals)--discard-locals[remove any compiler-generated symbols]'
  '--info[list object formats and architectures supported]'
  '(- * :)'{-h,--help}'[display help information]'
  '(-V --version)'{-V,--version}'[display version information]'
  '*:file:_files'
)

_arguments -s $arguments
