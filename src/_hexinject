#compdef hexinject

local -a arguments

arguments=(
  '-s[sniff mode]'
  '-p[inject mode]'
  '-r[raw mode (instead of the default hexadecimal mode)]'
  '-f[custom pcap filter]'
  '-i[network device to use]'
  '-F[pcap file to use as device (sniff mode only)]'
  '-c[number of packets to capture]'
  '-t[sleep time in microseconds (default 100)]'
  '-I[list all available network devices]'
  '-C[enable automatic packet checksum]'
  '-S[enable automatic packet size fields]'
  '-P[enable promiscuous mode]'
  '-M[set the wireless interface in monitor mode]'
  '-h[show help screen]'
  '*:filename:_files'
)

_arguments -s -S $arguments
