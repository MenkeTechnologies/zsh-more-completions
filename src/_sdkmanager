#compdef sdkmanager

local -a arguments

arguments=(
  '--sdk_root[use the specified SDK root instead of the SDK]:sdk root path:_directories'
  '--channel[include packages in channels up to channelId]:channel id'
  '--include_obsolete[with --list, show obsolete packages in the package listing]'
  '--no_https[force all connections to use http rather than https]'
  '--proxy[connect via a proxy of the given type]:proxy type:(http socks)'
  '--proxy_host[IP or DNS address of the proxy to use]:IP or DNS address'
  '--proxy_port[proxy port to connect to]:port'
  '--verbose[enable verbose output]'
  '*:filename:_files'
)

_arguments -s -S $arguments
