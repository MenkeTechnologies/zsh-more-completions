#compdef trash-rm

# Zsh completion for trash-rm (trash-cli) - remove individual files from trash

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--version[show version]' \
  '--verbose[print more information]' \
  '--trash-dir[specify trash directory]:directory:_files -/' \
  '*:trashed file pattern:' && return 0
