#compdef sg_verify

local -a arguments

arguments=(
  {--16,-S}'[use VERIFY(16) (def: use VERIFY(10) )]'
  '--bpc[max blocks per verify command (def: 128)]'
  '--count[count of blocks to verify (def: 1)]'
  {--dpo,-d}'[disable page out (cache retention priority)]'
  '--ebytchk[sets BYTCHK value, either 1, 2 or 3 (def: 0)]'
  '--group[set group number field (def: 0)]'
  {--help,-h}'[print out usage message]'
  '--in[input from file (def: stdin)]:file:_files'
  '--lba[logical block address to start verify (def: 0)]'
  '--ndo[number of bytes placed in data-out buffer]'
  {--quiet,-q}'[suppress miscompare report to stderr, still]'
  {--readonly,-r}'[open DEVICE read-only (def: open it read-write)]'
  {--verbose,-v}'[increase verbosity]'
  {--version,-V}'[print version string and exit]'
  '--vrprotect[VRP set vrprotect field to VRP (def: 0)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
