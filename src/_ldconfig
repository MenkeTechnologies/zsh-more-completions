#compdef ldconfig

local arguments

arguments=(
  {-c,--format}'[use cache format (old, new, or compat)]:format:(old new compat)'
  '-C[use specified cache file instead of /etc/ld.so.cache]:cache file:_files'
  '-f[use specified configuration file instead of /etc/ld.so.conf]:config file:_files'
  {-i,--ignore-aux-cache}'[ignore auxiliary cache file]'
  '-l[manually link individual libraries]'
  '-n[only process directories specified on the command line]'
  '-N[do not rebuild the cache]'
  {-p,--print-cache}'[print the lists of directories and candidate libraries stored in the current cache]'
  '-r[change to and use specified directory as root directory]:root directory:_directories'
  {-v,--verbose}'[generate verbose messages]'
  '-X[do not update symbolic links]'
  '(- *)'{-V,--version}'[display program version]'
  '(- *)--help[display help information]'
  '(- *)--usage[give a short usage message]'
  '*:directory:_directories'
)

_arguments -s $arguments
