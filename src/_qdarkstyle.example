#compdef qdarkstyle.example

local -a arguments

arguments=(
  {-h,--help}'[show this help message and exit]'
  '--palette[select palette]:palette:(dark light none)'
  '--qt_from[select Qt binding]:binding:(pyqt5 pyqt pyside2 pyside qtpy pyqtgraph qt.py)'
  '--test[auto close window after 2s.]'
  '--screenshots[generate screenshots on images folder.]'
  '--offscreen[do not try to show the screen (running on server).]'
  '--reset[reset GUI settings (position, size) then opens.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
