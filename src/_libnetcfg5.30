#compdef libnetcfg5.30
# Documentation: https://man.archlinux.org/search?q=libnetcfg5.30
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-c[the configuration]'
  '-d[defaults from the old config (implies -c, non-interactive)]'
  '-i[a specific file as the old config file]'
  '-o[a specific file as the new config file]'
  '-h[this help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
