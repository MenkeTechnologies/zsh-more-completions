#compdef logcli

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'query:run a LogQL query'
  'instant-query:run an instant LogQL query'
  'labels:find values for a label'
  'series:run a series query'
  'detected-fields:run a detected fields query'
  'detected-labels:run a detected labels query'
  'stats:run a stats query'
  'volume:run a volume query'
  'fmt:format a LogQL query'
)

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--addr=[server address]:address' \
  '--username=[basic auth username]:username' \
  '--password=[basic auth password]:password' \
  '--bearer-token=[bearer token]:token' \
  '--bearer-token-file=[bearer token file]:file:_files' \
  '--ca-cert=[TLS CA cert path]:cert:_files' \
  '--tls-skip-verify[skip TLS verification]' \
  '--cert=[TLS client cert path]:cert:_files' \
  '--key=[TLS client key path]:key:_files' \
  '--org-id=[org ID for multi-tenancy]:org id' \
  '(-q --quiet)'{-q,--quiet}'[suppress query metadata]' \
  '--proxy-url=[proxy URL]:url' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'logcli command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (query)
        _arguments -s -S \
          '--limit=[limit on number of entries to return]:limit' \
          '--since=[lookback window]:duration' \
          '--from=[start looking at time]:time' \
          '--to=[stop looking at time]:time' \
          '--step=[query resolution step width]:duration' \
          '--interval=[query interval]:duration' \
          '--batch=[query batch size]:size' \
          '--forward[scan forwards through logs]' \
          '--no-labels[do not print any labels]' \
          '--exclude-label=[exclude labels by name]:labels' \
          '--include-label=[include only specified labels]:labels' \
          '--labels-length=[max label line length]:length' \
          '--store-config=[store query config]:file:_files' \
          '--colored-output[colorize output]' \
          '(-o --output)'{-o,--output}'=[output mode]:mode:(default raw jsonl)' \
          '(-t --tail)'{-t,--tail}'[tail the logs]' \
          '--delay-for=[delay queries by duration]:duration' \
          '--part-path-prefix=[path prefix for partitions]:prefix' \
          '1:LogQL query' && ret=0
        ;;
      (instant-query)
        _arguments -s -S \
          '--limit=[limit on number of entries]:limit' \
          '--now=[time for instant query]:time' \
          '(-o --output)'{-o,--output}'=[output mode]:mode:(default raw jsonl)' \
          '1:LogQL query' && ret=0
        ;;
      (labels)
        _arguments -s -S \
          '--since=[lookback window]:duration' \
          '--from=[start time]:time' \
          '--to=[end time]:time' \
          '1:label name' && ret=0
        ;;
      (series)
        _arguments -s -S \
          '--since=[lookback window]:duration' \
          '--from=[start time]:time' \
          '--to=[end time]:time' \
          '--match=[series selector]:selector' && ret=0
        ;;
    esac
    ;;
esac

return ret
