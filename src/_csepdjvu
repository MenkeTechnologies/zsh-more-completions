#compdef csepdjvu
# Documentation: https://man.archlinux.org/search?q=csepdjvu
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-v,-vv}'[select verbosity level.]'
  '-d[set resolution to <n> dpi (default: 300).]'
  '-t[restricts text information to lines only.]'
  '-q[select quality for background (default: 72+11+10+10)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
