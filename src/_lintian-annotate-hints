#compdef lintian-annotate-hints
# Documentation: https://man.archlinux.org/search?q=lintian-annotate-hints
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    {-a,--annotate}'[Read from standard input or any files specified on the command line and searc]'
    {-h,--help}'[Display usage information and exit.]'
    '--include-dir[Use dir as an additional \\*(L"Lintian root\\*(R".]:dir'
    '--profile[Use the severities from the vendor profile prof when displaying tags.]:prof'
    '*:filename:_files'
)
_arguments -s -S $arguments
