#compdef arturo

local -a arguments

arguments=(
    '-e[evaluate given code]:code'
    '--evaluate[evaluate given code]:code'
    '-c[compile script]:output file:_files'
    '--compile[compile script]:output file:_files'
    '-r[run in REPL mode]'
    '--repl[run in REPL mode]'
    '-p[run package manager]'
    '--package[run package manager]'
    '-u[update Arturo to latest version]'
    '--update[update Arturo to latest version]'
    '-m[show available modules]'
    '--modules[show available modules]'
    '-v[show version]'
    '--version[show version]'
    '-h[show help]'
    '--help[show help]'
    '--no-color[disable colored output]'
    '--debug[run in debug mode]'
    '--verbose[verbose output]'
    '*:Arturo script:_files -g "*.art"'
)

_arguments -s -S $arguments
