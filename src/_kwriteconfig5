#compdef kwriteconfig5
# Documentation: https://man.archlinux.org/search?q=kwriteconfig5
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[displays this help.]'
  '--file[use <file> instead of global config]'
  '--group[group to look in. Use repeatedly for nested groups.]'
  '--key[key to look for]'
  '--type[type of variable. Use "bool" for a boolean, otherwise it is treated as a string]:type:'
  '*:filename:_files'
)

_arguments -s -S $arguments
