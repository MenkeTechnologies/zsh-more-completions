#compdef pn2pdf

local -a arguments

arguments=(
  {-b,--batch}'[process the commands in FILE]'
  {-k,--keep}'[keep temporary files]'
  {-f,--force}'[force the rendering of all pictures]'
  {-t,--test}'[create]'
  {-d,--delete}'[delete]'
  '(- * :)'{-h,--help}'[display this help and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
