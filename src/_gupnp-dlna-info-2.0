#compdef gupnp-dlna-info-2.0
# Documentation: https://man.archlinux.org/search?q=gupnp-dlna-info-2.0
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  {-t,--timeout}'[specify timeout (in seconds, defaults to 10)]'
  {-a,--async}'[run asynchronously]'
  {-r,--relaxed}'[enable Relaxed mode]'
  {-e,--extended}'[enable extended mode]'
  '*:filename:_files'
)

_arguments -s -S $arguments
