#compdef econftool
# Documentation: https://man.archlinux.org/search?q=econftool
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-f,--full}'[copy the original configuration file to /etc]'
  '--use-home[only has an effect if the user is root]'
  {-y,--yes}'[assumes yes for all prompts and runs non-interactively]'
  '*:filename:_files'
)

_arguments -s -S $arguments
