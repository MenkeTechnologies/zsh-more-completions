#compdef hostnamectl

# zsh completions for 'hostnamectl'

_hostnamectl_commands() {
  local -a commands
  commands=(
    'status:show system hostname and related information'
    'hostname:get or set the system hostname'
    'icon-name:get or set the system icon name'
    'chassis:get or set the system chassis type'
    'deployment:get or set the deployment environment'
    'location:get or set the system location string'
  )
  _describe -t commands 'hostnamectl command' commands
}

_hostnamectl_chassis_types() {
  local -a types
  types=(
    'desktop' 'laptop' 'convertible' 'server' 'tablet'
    'handset' 'watch' 'embedded' 'vm' 'container'
  )
  _describe -t types 'chassis type' types
}

_hostnamectl() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -s \
    '(- *)'{-h,--help}'[show help message and exit]' \
    '(- *)--version[show package version]' \
    '--no-ask-password[do not query the user for authentication]' \
    {-H+,--host=}'[execute the operation on a remote host]:user@host:_hosts' \
    {-M+,--machine=}'[execute operation on a local container]:machine name' \
    '--transient[only set transient hostname]' \
    '--static[only set static hostname]' \
    '--pretty[only set pretty hostname]' \
    '--json=[format output as JSON]:mode:(short pretty off)' \
    '-j[JSON output (pretty on tty, short otherwise)]' \
    '(-): :_hostnamectl_commands' \
    '(-)*:: :->args'

  case $state in
    args)
      case ${line[1]} in
        status)
          _arguments \
            '--json=[format output as JSON]:mode:(short pretty off)' \
            '-j[JSON output (pretty on tty, short otherwise)]'
          ;;
        hostname)
          _arguments \
            '--static[only show or set static hostname]' \
            '--transient[only show or set transient hostname]' \
            '--pretty[only show or set pretty hostname]' \
            ':new hostname'
          ;;
        icon-name)
          _arguments ':icon name'
          ;;
        chassis)
          _arguments ':chassis type:_hostnamectl_chassis_types'
          ;;
        deployment)
          _arguments ':environment'
          ;;
        location)
          _arguments ':location'
          ;;
      esac
      ;;
  esac
}

_hostnamectl "$@"
