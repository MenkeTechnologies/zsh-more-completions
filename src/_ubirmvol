#compdef ubirmvol
# Documentation: https://man.archlinux.org/search?q=ubirmvol
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-n,--vol}'[_id=<volume id> volume ID to remove]'
  {-N,--name}'[name> volume name to remove]'
  '-h[-\?, --help print help message]'
  {-V,--version}'[print program version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
