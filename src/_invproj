#compdef proj

local -a arguments

arguments=(
    '-b[binary coordinate data input and output]'
    '-d[specify number of decimals in output]:n'
    '-i[select binary input only]'
    '-I[specify inverse projection]'
    '-o[select binary output only]'
    '-e[error string to output on detection of error]:string'
    '-E[copy input coordinates to output line]'
    '-lp[list all projection identifiers]'
    '-lP[expanded description of all projections]'
    '-le[list all available ellipsoids]'
    '-lu[list all available distance units]'
    '-r[reverse expected input order to latitude-longitude]'
    '-s[reverse output order to latitude-longitude]'
    '-S[estimate meridional and parallel scale factors]'
    '-m[scale cartesian data by mult parameter]:mult'
    '-f[printf format string for output values]:format'
    '-v[list cartographic control parameters]'
    '-V[expanded annotated listing of projection characteristics]'
    '-w[suppress degree-minute-second fields]'
    '*:filename:_files'
)
_arguments -s -S $arguments
