#compdef ps4pdf
# Documentation: https://man.archlinux.org/search?q=ps4pdf
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--Xps2pdf[passes OPT to ps2pdf.]'
  '--crop[pdfcrop on ps2pdf output.]'
  '--lualatex[the luatex engine for .dvi and .pdf]'
  '--xelatex[the xetex engine for .xdv and .pdf]'
  '*:filename:_files'
)

_arguments -s -S $arguments
