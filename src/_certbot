#compdef certbot

_certbot() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a subcommands
  subcommands=(
    'certonly:obtain or renew a certificate, but do not install it'
    'install:install a previously obtained certificate in a server'
    'renew:renew all previously obtained certificates that are near expiry'
    'revoke:revoke a certificate'
    'delete:delete a certificate'
    'register:create an ACME account'
    'unregister:deactivate an ACME account'
    'update_account:update an ACME account'
    'show_account:display account details'
    'certificates:display information about certificates configured on the system'
    'enhance:add security enhancements to existing configurations'
    'rollback:rollback server configuration changes made during install or enhance'
    'everything:obtain, install, and renew certificates (default)'
    'reconfigure:update a renewed certificates configuration'
  )

  local -a plugin_opts
  plugin_opts=(
    '--standalone[run a standalone webserver for authentication]'
    '--nginx[use the Nginx plugin for authentication and installation]'
    '--apache[use the Apache plugin for authentication and installation]'
    '--webroot[place files in a server'\''s webroot folder for authentication]'
    '--manual[obtain certificates interactively, or using shell script hooks]'
    '--dns-cloudflare[obtain certificates using a DNS TXT record (Cloudflare)]'
    '--dns-digitalocean[obtain certificates using a DNS TXT record (DigitalOcean)]'
    '--dns-dnsimple[obtain certificates using a DNS TXT record (DNSimple)]'
    '--dns-dnsmadeeasy[obtain certificates using a DNS TXT record (DNS Made Easy)]'
    '--dns-gehirn[obtain certificates using a DNS TXT record (Gehirn)]'
    '--dns-google[obtain certificates using a DNS TXT record (Google)]'
    '--dns-linode[obtain certificates using a DNS TXT record (Linode)]'
    '--dns-luadns[obtain certificates using a DNS TXT record (LuaDNS)]'
    '--dns-nsone[obtain certificates using a DNS TXT record (NS1)]'
    '--dns-ovh[obtain certificates using a DNS TXT record (OVH)]'
    '--dns-rfc2136[obtain certificates using a DNS TXT record (RFC 2136)]'
    '--dns-route53[obtain certificates using a DNS TXT record (Route 53)]'
    '--dns-sakuracloud[obtain certificates using a DNS TXT record (Sakura Cloud)]'
  )

  local -a arguments
  arguments=(
    '1:subcommand:->subcmd'
    '*-d+[domain name(s) to obtain a certificate for]:domain:'
    '*--domains+[domain name(s) to obtain a certificate for]:domain:'
    $plugin_opts
    # Authentication and certificate options
    '--authenticator[authenticator plugin name]:plugin:'
    '--installer[installer plugin name]:plugin:'
    {-a,--agree-tos}'[agree to the ACME server'\''s Subscriber Agreement]'
    {-m,--email}'[email address for important account notifications]:email:'
    '--register-unsafely-without-email[create account with no email address]'
    '--no-eff-email[do not share email address with EFF]'
    '--eff-email[share email address with EFF]'
    # Testing and staging
    '--test-cert[obtain a test certificate from a staging server]'
    '--staging[use the staging server to obtain test certificates]'
    '--dry-run[test "renew" or "certonly" without saving any certificates to disk]'
    '--debug[show tracebacks in case of errors]'
    '--debug-challenges[after setting up challenges, wait for user input before submitting to CA]'
    # Certificate options
    '--cert-name[certificate name to apply]:name:'
    '--cert-path[path to the certificate for install and revoke]:path:_files'
    '--key-path[path to the private key for install and revoke]:path:_files'
    '--fullchain-path[accompanying path to a full certificate chain]:path:_files'
    '--chain-path[accompanying path to a certificate chain]:path:_files'
    # Key options
    '--rsa-key-size[size of the RSA key]:size:(2048 3072 4096)'
    '--key-type[type of generated private key]:type:(rsa ecdsa)'
    '--elliptic-curve[the SECG elliptic curve name to use]:curve:(secp256r1 secp384r1 secp521r1)'
    '--must-staple[add the OCSP Must Staple extension to the certificate]'
    '--reuse-key[when renewing, use the same private key as the existing certificate]'
    '--new-key[when renewing or replacing a certificate, generate a new private key]'
    '--no-reuse-key[when renewing, do not reuse the private key]'
    # Configuration and directories
    '--config-dir[configuration directory]:dir:_directories'
    '--work-dir[working directory]:dir:_directories'
    '--logs-dir[logs directory]:dir:_directories'
    '--max-log-backups[specifies the maximum number of backup logs to keep]:number:'
    # Server and protocol
    '--server[ACME Directory Resource URI]:uri:'
    '--preferred-challenges[a sorted, comma delimited list of the preferred challenge to use]:challenges:'
    '--preferred-chain[set the preferred certificate chain]:chain:'
    '--issuance-timeout[timeout in seconds for issuance of a certificate]:seconds:'
    # Renewal and behavior
    {-n,--non-interactive}'[run without ever asking for user input]'
    '--force-interactive[force Certbot to be interactive even if it detects it'\''s not being run in a terminal]'
    '--keep-until-expiring[if the requested certificate matches an existing certificate, always keep the existing one until it is due for renewal]'
    '--keep[alias for --keep-until-expiring]'
    '--expand[if an existing certificate covers some subset of the requested names, always expand and replace it]'
    '--renew-by-default[if a certificate already exists for the requested domains, renew it]'
    '--renew-with-new-domains[if a certificate already exists, renew it and include the additional names]'
    '--force-renewal[force renewal of the certificate even if it is not yet due]'
    '--allow-subset-of-names[when performing domain validation, do not consider it a failure if authorizations can not be obtained for a strict subset of the requested domains]'
    '--no-autorenew[disable auto renewal of certificates]'
    '--break-my-certs[be willing to replace or renew valid certificates with invalid (testing/staging) certificates]'
    # Web server and security enhancements
    '--redirect[automatically redirect all HTTP traffic to HTTPS for the newly authenticated vhost]'
    '--no-redirect[do not automatically redirect HTTP traffic to HTTPS]'
    '--staple-ocsp[enables OCSP Stapling]'
    '--no-staple-ocsp[disables OCSP Stapling]'
    '--strict-permissions[require that all configuration files are owned by the current user]'
    '--uir[add the Content-Security-Policy: upgrade-insecure-requests header to every HTTP response]'
    '--no-uir[do not add the Content-Security-Policy header]'
    '--hsts[add the Strict-Transport-Security header to every HTTP response]'
    '--no-hsts[do not add the Strict-Transport-Security header]'
    # Hooks
    '--pre-hook[command to run in a shell before obtaining any certificates]:command:'
    '--post-hook[command to run in a shell after attempting to obtain/renew certificates]:command:'
    '--deploy-hook[command to run in a shell after successfully deploying a certificate]:command:'
    '--renew-hook[alias for --deploy-hook]:command:'
    '--disable-hook-validation[disable the hook commands validation]'
    '--no-directory-hooks[disable running executables found in Certbot'\''s hook directories during renewal]'
    # Webroot options
    {-w,--webroot-path}'[public_html / webroot path]:path:_directories'
    '--webroot-map[JSON dictionary mapping domains to webroot paths]:json:'
    # Apache options
    '--apache-server-root[full path to the Apache server root directory]:path:_directories'
    '--apache-vhost-root[full path to the Apache virtual host configuration root]:path:_directories'
    '--apache-logs-root[full path to the Apache logs root]:path:_directories'
    '--apache-challenge-location[path to the .well-known/acme-challenge directory]:path:_directories'
    '--apache-ctl[full path to the apache ctl script]:path:_files'
    '--apache-enmod[full path to the apache a2enmod script]:path:_files'
    '--apache-dismod[full path to the apache a2dismod script]:path:_files'
    '--apache-le-vhost-ext[SSL vhost configuration extension]:extension:'
    # Nginx options
    '--nginx-server-root[Nginx server root directory]:path:_directories'
    '--nginx-ctl[path to the nginx binary used for managing the Nginx configuration]:path:_files'
    '--nginx-sleep-seconds[number of seconds to wait for Nginx configuration changes to apply]:seconds:'
    # Manual options
    '--manual-auth-hook[path or command to execute for the authentication script]:command:'
    '--manual-cleanup-hook[path or command to execute for the cleanup script]:command:'
    # Output and logging
    {-q,--quiet}'[silence all output except errors]'
    '(- * :)'{-h,--help}'[print this help message and exit]'
    '--version[print the version number]'
    '--no-verify-ssl[disable verification of the ACME server'\''s certificate]'
    '--user-agent[set a custom user agent string]:string:'
    '--user-agent-comment[set a custom user agent comment]:string:'
    '--preconfigured-renewal[use the renewal parameters provided by the installer]'
    '--reason[specify reason for revoking certificate]:reason:(unspecified keycompromise affiliationchanged superseded cessationofoperation)'
    '--delete-after-revoke[delete certificates after revoking them]'
    '--no-delete-after-revoke[do not delete certificates after revoking them]'
    '--eab-kid[key identifier for External Account Binding]:kid:'
    '--eab-hmac-key[HMAC key for External Account Binding]:key:'
    '*:domain:'
  )

  _arguments -s -S $arguments

  case $state in
    subcmd)
      _describe -t subcommands 'certbot subcommand' subcommands
      ;;
  esac
}

_certbot "$@"
