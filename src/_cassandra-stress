#compdef cassandra-stress

local -a subcommands
subcommands=(
    'write:Insert data'
    'read:Read data'
    'mixed:Interleave read and write'
    'counter_write:Insert counter data'
    'counter_read:Read counter data'
    'user:Run user-defined profile'
    'help:Show help'
    'print:Print cluster info'
    'legacy:Legacy stress mode'
)

_arguments -C \
    '1:subcommand:->subcmd' \
    '*:: :->args'

case $state in
    subcmd)
        _describe -t subcommands 'cassandra-stress subcommand' subcommands
        ;;
    args)
        _arguments \
            '-node[Cassandra nodes to connect to]:nodes' \
            '-port[Port options]:port spec' \
            '-transport[Transport options]:transport' \
            '-rate[Rate limiting]:rate spec' \
            '-mode[Connection mode]:mode' \
            '-schema[Schema options]:schema' \
            '-col[Column details]:column spec' \
            '-pop[Population distribution]:pop spec' \
            '-log[Logging options]:log spec' \
            '-errors[Error handling]:error spec' \
            '-tokenrange[Token range]:range' \
            'n[Number of operations]:count' \
            'duration[Duration of test]:duration' \
            'cl[Consistency level]:level:(ONE QUORUM ALL LOCAL_QUORUM EACH_QUORUM LOCAL_ONE ANY TWO THREE)' \
            '*:profile file:_files -g "*.yaml"'
        ;;
esac
