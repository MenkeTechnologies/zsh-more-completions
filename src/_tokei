#compdef tokei

# Zsh completion for tokei - a code statistics tool
# https://github.com/XAMPPRocky/tokei

_tokei() {
  local -a arguments

  arguments=(
    {-c,--columns}'[set strict column width for terminal output]:width'
    {-C,--compact}'[do not print statistics about embedded languages]'
    '*'{-e,--exclude}'[ignore all files and directories matching the pattern]:pattern'
    {-f,--files}'[print out statistics on individual files]'
    '(- *)'{-h,--help}'[print help information]'
    '--hidden[count hidden files and directories]'
    {-i,--input}'[give statistics from a previous tokei run (file path or "stdin")]:file:_files'
    {-l,--languages}'[print out supported languages and their extensions]'
    '--no-ignore[don'\''t respect ignore files (.gitignore, .ignore, etc.)]'
    '--no-ignore-parent[don'\''t respect ignore files in parent directories]'
    '--no-ignore-dot[don'\''t respect .ignore and .tokeignore files]'
    '--no-ignore-vcs[don'\''t respect VCS ignore files (.gitignore, .hgignore, etc.)]'
    {-n,--num-format}'[format of printed numbers]:format:(plain commas dots underscores)'
    {-o,--output}'[output Tokei in a specific format]:format:(cbor json yaml)'
    {-r,--rsort}'[reverse sort languages based on column]:column:(files lines blanks code comments)'
    {-s,--sort}'[sort languages based on column]:column:(files lines blanks code comments)'
    '--streaming[print records as simple lines or JSON for batch processing]:format:(simple json)'
    {-t,--types}'[filter output by language type, comma-separated (e.g. Rust,Markdown)]:types'
    '*'{-v,--verbose}'[set log output level (1: unknown extensions, 2: reserved, 3: file trace)]'
    {-V,--version}'[print version information]'
    '*:path:_files -/'
  )

  _arguments -s -S $arguments
}

_tokei "$@"
