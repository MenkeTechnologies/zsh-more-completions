#compdef mysql_config

local -a arguments

arguments=(
  '--cflags[print compiler flags]'
  '--cxxflags[print C++ compiler flags]'
  '--include[print include path]'
  '--libs[print library linking flags]'
  '--libs_r[print reentrant library linking flags]'
  '--plugindir[print plugin directory path]'
  '--socket[print default socket path]'
  '--port[print default port number]'
  '--version[print version]'
  '--variable=[print value of a variable]:variable: '
  '*:filename:_files'
)

_arguments -s -S $arguments
