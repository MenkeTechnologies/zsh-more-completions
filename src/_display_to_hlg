#compdef display_to_hlg

local -a arguments

arguments=(
  {-m,--max_nits}'[maximum nits]:nits'
  {-s,--surround_nits}'[surround nits]:nits'
  '--preserve_saturation[preserve saturation (0..1)]:value'
  {-h,--help}'[prints this help message. All options are shown above.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
