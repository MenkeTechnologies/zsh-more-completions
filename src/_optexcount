#compdef optexcount
# Documentation: https://man.archlinux.org/search?q=optexcount
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-v,--verbose}'[activate verbose mode]'
  {-s,--set-verbchar}'[set implicit inline verbatim character]'
  '--version[show programs version number and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
