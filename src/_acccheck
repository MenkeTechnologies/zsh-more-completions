#compdef acccheck
# Documentation: https://man.archlinux.org/search?q=acccheck
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-t[host IP address\]]'
  '-T[containing target ip address(es)\]]'
  '-p[password\]]'
  '-P[containing passwords\]]'
  '-u[user\]]'
  '-U[containing usernames\]]'
  '-v[mode\]]'
  '*:filename:_files'
)

_arguments -s -S $arguments
