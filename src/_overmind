#compdef overmind

_overmind_start() {
  _arguments \
    {-f,--procfile}'[specify Procfile]:file:_files' \
    {-p,--port}'[specify port]:port:' \
    {-l,--processes}'[specify processes to run]:processes:' \
    {-r,--root}'[specify root directory]:dir:_directories' \
    {-t,--title}'[specify tmux session title]:title:' \
    {-N,--no-port}'[do not assign port numbers]' \
    '--tmux-config[specify tmux config file]:file:_files' \
    '--formation[specify formation]:formation:' \
    '--auto-restart[specify auto-restart behavior]:behavior:' \
    '--colors[specify colors for processes]:colors:' \
    '--socket[specify socket path]:socket:_files' \
    '--network[specify network type]:network:(tcp unix)' \
    '--can-die[specify processes that can die]:processes:' \
    '--any-can-die[allow any process to die]' \
    '--stop-signals[specify stop signals for processes]:signals:' \
    '--idle-timeout[specify idle timeout]:seconds:' \
    {-D,--daemonize}'[run in background]'
}

_overmind_run() {
  _arguments \
    {-f,--procfile}'[specify Procfile]:file:_files' \
    '--socket[specify socket path]:socket:_files' \
    '--network[specify network type]:network:(tcp unix)' \
    '*::command:_command_names'
}

_overmind() {
  local -a commands
  commands=(
    'start:start processes'
    'restart:restart a process'
    'stop:stop a process'
    'connect:connect to a process'
    'quit:quit overmind'
    'run:run a command in the process environment'
    'echo:echo process output'
    'kill:kill overmind and all processes'
    'help:show help'
  )

  _arguments \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '1:command:->command' \
    '*::arguments:->arguments'

  case "$state" in
    command)
      _describe -t commands 'overmind command' commands
      ;;
    arguments)
      case "$words[1]" in
        start) _overmind_start ;;
        run) _overmind_run ;;
        restart|stop|connect|echo) _arguments ':process name:' ;;
      esac
      ;;
  esac
}

_overmind "$@"
