#compdef pamixer
# Zsh completion for pamixer - PulseAudio/PipeWire command line mixer
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '--get-volume[get current volume]' \
  '--get-mute[get current mute state]' \
  '--set-volume[set volume to N]:volume (0-100):' \
  '(-i --increase)'{-i,--increase}'[increase volume by N]:amount:' \
  '(-d --decrease)'{-d,--decrease}'[decrease volume by N]:amount:' \
  '(-t --toggle-mute)'{-t,--toggle-mute}'[toggle mute]' \
  '(-m --mute)'{-m,--mute}'[mute]' \
  '(-u --unmute)'{-u,--unmute}'[unmute]' \
  '--default-source[use default source instead of sink]' \
  '--sink[select sink by name]:sink name:' \
  '--source[select source by name]:source name:' \
  '--list-sinks[list available sinks]' \
  '--list-sources[list available sources]' \
  '--allow-boost[allow volume above 100%]' \
  '--gamma[set gamma for volume mapping]:gamma float:' \
  '--set-limit[set volume limit]:limit (0-100):' \
  '(- *)--help[show help information]' \
  '(- *)--version[show version]' && ret=0
return ret
