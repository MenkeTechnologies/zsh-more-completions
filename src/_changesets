#compdef changeset

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add:add a new changeset'
  'version:apply the changeset versions'
  'publish:publish changed packages'
  'status:get the status of changesets'
  'init:initialize changesets in the project'
  'pre:enter or exit pre mode'
  'tag:tag all packages'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'changeset command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (add)
        _arguments -s -S \
          '--empty[create an empty changeset]' \
          '--open[open created changeset in editor]' && ret=0
        ;;
      (version)
        _arguments -s -S \
          '--ignore=[skip a package from being published]:package' \
          '--snapshot=[create a snapshot release]:tag' \
          '--no-changelog[skip writing changelogs]' && ret=0
        ;;
      (publish)
        _arguments -s -S \
          '--otp=[one-time password for npm]:otp' \
          '--tag=[publish to a specific dist-tag]:tag' \
          '--no-git-tag[skip git tagging]' \
          '--snapshot[publish a snapshot release]' && ret=0
        ;;
      (status)
        _arguments -s -S \
          '--since=[show status since ref]:ref' \
          '--verbose[show verbose status]' \
          '--output=[write to file]:file:_files' && ret=0
        ;;
      (pre)
        _arguments -s -S \
          '1:mode:(enter exit)' \
          '2:tag:(alpha beta rc next canary dev)' && ret=0
        ;;
    esac
    ;;
esac

return ret
