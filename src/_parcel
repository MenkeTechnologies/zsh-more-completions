#compdef parcel

_parcel_log_levels=(none error warn info verbose)

_parcel() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a _parcel_cmds
  _parcel_cmds=(
    'serve:start a development server'
    'watch:watch and rebuild on changes'
    'build:build for production'
  )

  _arguments -C \
    '--help[show help]' \
    '--version[show version]' \
    '1:command:->cmds' \
    '*::arg:->args'

  case "$state" in
    cmds)
      _describe -t commands 'parcel command' _parcel_cmds
      ;;
    args)
      local -a common_args
      common_args=(
        '--dist-dir[output directory]:dir:_directories'
        '--public-url[public URL prefix]:url:'
        '--no-cache[disable caching]'
        '--cache-dir[cache directory]:dir:_directories'
        '--no-source-maps[disable source maps]'
        '--no-autoinstall[disable auto install]'
        '--target[target to build]:target:'
        '--log-level[log level]:level:('"${_parcel_log_levels[*]}"')'
        '--profile[enable build profiling]'
        '--detailed-report[print detailed build report]'
        '*:entry files:_files'
      )

      case $line[1] in
        serve)
          _arguments \
            '--port[dev server port]:port:' \
            '--host[dev server host]:host:_hosts' \
            '--open[open in browser]:browser:' \
            '--https[enable HTTPS]' \
            '--cert[SSL certificate file]:file:_files' \
            '--key[SSL key file]:file:_files' \
            '--no-hmr[disable hot module replacement]' \
            '--hmr-port[HMR port]:port:' \
            '--hmr-hostname[HMR hostname]:hostname:_hosts' \
            '--lazy[lazy build]' \
            {-V,--version}'[show version]' \
            {-h,--help}'[show help]' \
            $common_args
          ;;
        watch)
          _arguments \
            $common_args
          ;;
        build)
          _arguments \
            '--no-optimize[disable optimization]' \
            '--no-scope-hoist[disable scope hoisting]' \
            '--no-content-hash[disable content hashing]' \
            $common_args
          ;;
      esac
      ;;
  esac
}

_parcel "$@"
