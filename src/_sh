#compdef sh

local -a arguments

arguments=(
  '--debug[turn on shell debugging]'
  '--debugger[arrange for the debugger profile to be executed]'
  '--dump-po-strings[equivalent to -D, but output in GNU gettext po file format]'
  '--dump-strings[equivalent to -D]'
  '--help[display a usage message and exit]'
  '--init-file[execute commands from file instead of ~/.bashrc]:file:_files'
  '--login[make this shell act as if directly invoked by login]'
  '--noediting[do not use the GNU readline library for input]'
  '--noprofile[do not load the system-wide or personal startup files]'
  '--norc[do not read the ~/.bashrc initialization file]'
  '--posix[change behavior to match the POSIX standard]'
  '--rcfile[execute commands from file instead of ~/.bashrc]:file:_files'
  '--restricted[make the shell a restricted shell]'
  '--verbose[print shell input lines as they are read]'
  '--version[show version information and exit]'
  '-c[read and execute commands from the first non-option argument]:command:'
  '-i[force the shell to run interactively]'
  '-l[make the shell act as if invoked as a login shell]'
  '-r[make the shell a restricted shell]'
  '-s[read commands from standard input]'
  '-D[print all double-quoted strings preceded by $]'
  '*:filename:_files'
)

_arguments -s -S $arguments
