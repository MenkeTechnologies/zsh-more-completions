#compdef datasette

# Zsh completion for datasette - explore and publish SQLite databases

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'serve:serve one or more SQLite database files with a web UI'
  'inspect:generate JSON summary of database files'
  'publish:publish database files to a hosting provider'
  'package:package database files into a Docker container'
  'install:install plugins and dependencies'
  'uninstall:uninstall plugins'
  'plugins:list installed plugins'
  'create-token:create a signed API token'
)

_arguments -s -S \
  '1:subcommand:->subcmd' \
  '*::args:->args' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'datasette subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (serve)
        _arguments \
          '(-i --immutable)'{-i,--immutable}'[database files to open in immutable mode]:db file:_files -g "*.db *.sqlite *.sqlite3"' \
          '(-h --host)'{-h,--host}'[host for server]:host:' \
          '(-p --port)'{-p,--port}'[port for server]:port:' \
          '--cors[enable CORS headers]' \
          '--inspect-file[path to inspect data]:file:_files -g "*.json"' \
          '-m[path to metadata]:file:_files -g "*.json *.yaml *.yml"' \
          '--template-dir[path to custom templates]:directory:_files -/' \
          '--plugins-dir[path to plugins directory]:directory:_files -/' \
          '--static[static files directory]:mount\:dir:' \
          '--memory[create an in-memory database]' \
          '--config[deprecated: use --setting instead]:setting:' \
          '--setting[configure a setting]:key value:' \
          '--secret[secret for signing tokens]:secret:' \
          '--root[output URL to root user]' \
          '--get[GET a path instead of serving]:path:' \
          '--token[API token]:token:' \
          '--version-note[extra note to show on /-/versions]:note:' \
          '--help-settings[show available settings]' \
          '--pdb[launch debugger on error]' \
          '--open[open browser to datasette]' \
          '--create[create databases if they do not exist]' \
          '--crossdb[enable cross-database queries]' \
          '--nolock[skip locking SQLite databases]' \
          '--ssl-keyfile[SSL key file]:file:_files' \
          '--ssl-certfile[SSL certificate file]:file:_files' \
          '--internal[path to internal database]:file:_files' \
          '*:database files:_files -g "*.db *.sqlite *.sqlite3"' && ret=0
        ;;
      (inspect)
        _arguments \
          '--inspect-file[save output to file]:file:_files -g "*.json"' \
          '*:database files:_files -g "*.db *.sqlite *.sqlite3"' && ret=0
        ;;
      (publish)
        _arguments \
          '1:provider:(cloudrun heroku vercel fly)' \
          '*:database files:_files -g "*.db *.sqlite *.sqlite3"' && ret=0
        ;;
      (package)
        _arguments \
          '-t[tag for Docker image]:tag:' \
          '*:database files:_files -g "*.db *.sqlite *.sqlite3"' && ret=0
        ;;
      (install)
        _arguments '*:package name:' && ret=0
        ;;
      (uninstall)
        _arguments \
          '-y[skip confirmation]' \
          '*:package name:' && ret=0
        ;;
      (plugins)
        _arguments '--all[show all plugins including built-in]' && ret=0
        ;;
      (create-token)
        _arguments \
          '--secret[secret for signing]:secret:' \
          '-e[token expiry]:duration:' \
          '-a[actor ID]:id:' && ret=0
        ;;
    esac
    ;;
esac

return ret
