#compdef mate-calculator

local -a arguments

arguments=(
  {-v,--version}'[show release version]'
  '-h[-\?, --help Show help options]'
  '--help-all[show all help options]'
  '--help-gtk[show GTK+ options]'
  {-s,--solve}'[solve the given equation]'
  '*:filename:_files'
)

_arguments -s -S $arguments
