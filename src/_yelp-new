#compdef yelp-new
# Documentation: https://man.archlinux.org/search?q=yelp-new
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--stub[create a .page.stub file instead of a .page file]'
  '--tmpl[copy an installed template to a local template]'
  '*:filename:_files'
)

_arguments -s -S $arguments
