#compdef qhelpgenerator
# Documentation: https://man.archlinux.org/search?q=qhelpgenerator
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-o[generates a Qt compressed help file]'
  '-c[checks whether all links in HTML files are valid]'
  '-s[suppresses status messages]'
  '-v[displays the version of the tool]'
  '*:filename:_files'
)

_arguments -s -S $arguments
