#compdef outguess
# Documentation: https://man.archlinux.org/search?q=outguess
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-p[parameter passed to destination data handler]'
  '-r[retrieve message from data]'
  '-x[number of key derivations to be tried]'
  '-m[mark pixels that have been modified]'
  '-t[collect statistic information]'
  '-F[turns statistical steganalysis foiling on/off.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
