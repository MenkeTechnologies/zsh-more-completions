#compdef jupyter-kernel
# Documentation: https://man.archlinux.org/search?q=jupyter-kernel
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--debug[set log level to logging.DEBUG (maximize logging output)]'
  '--kernel[(KernelApp.kernel_name)]'
  '--ip[(KernelManager.ip)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
