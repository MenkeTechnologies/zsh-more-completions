#compdef mutagen-inspect
# Documentation: https://man.archlinux.org/search?q=mutagen-inspect
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  '--no-flac[compatibility; does nothing.]'
  '--no-mp3[3 Compatibility; does nothing.]'
  '--no-apev2[2 Compatibility; does nothing.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
