#compdef httpx

local -a arguments

arguments=(
  {-m,--method}'[request method]:method:(GET POST PUT PATCH DELETE HEAD OPTIONS)'
  {-p,--params}'[query parameters to include in the request]:key=value:'
  {-c,--content}'[byte content to include in the request body]:content:'
  {-d,--data}'[form data to include in the request body]:key=value:'
  {-f,--files}'[form files to include in the request body]:name=filename:_files'
  {-j,--json}'[JSON data to include in the request body]:data:'
  {-h,--headers}'[include additional HTTP headers in the request]:key=value:'
  '--cookies[cookies to include in the request]:key=value:'
  '--auth[username and password for authentication]:user:pass:'
  '--proxy[send the request via a proxy]:URL:'
  '--timeout[timeout value to use for network operations]:seconds:'
  '--follow-redirects[automatically follow redirects.]'
  '--no-verify[disable SSL verification.]'
  '--http2[send the request using HTTP/2]'
  '--download[save the response content as a file]'
  {-v,--verbose}'[verbose output, show request as well as response]'
  '--help[show this message and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
