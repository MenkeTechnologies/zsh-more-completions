#compdef jsonpointer

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-f,--pointer-file}'[file containing a JSON pointer expression]'
  '--indent[indent output by n spaces]'
  {-v,--version}'[show programs version number and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
