#compdef bladeRF-cli

local -a arguments

arguments=(
  {-d,--device}'[use the specified bladeRF device]:device:'
  {-f,--flash-firmware}'[write the provided FX3 firmware file to flash]:file:_files'
  {-l,--load-fpga}'[load the provided FPGA bitstream]:file:_files'
  {-L,--flash-fpga}'[write the provided FPGA image to flash]:file:_files'
  {-p,--probe}'[probe for devices, print results, then exit]'
  {-e,--exec}'[execute the specified interactive mode command]:command:'
  {-s,--script}'[run provided script]:script:_files'
  {-i,--interactive}'[enter interactive mode]'
  '--lib-version[print libbladeRF version and exit]'
  {-v,--verbosity}'[set the libbladeRF verbosity level]:level:'
  '--version[print CLI version and exit]'
  '(- * :)'{-h,--help}'[show this help text]'
  '--help-interactive[print help information for all interactive commands]'
  '*:filename:_files'
)

_arguments -s -S $arguments
