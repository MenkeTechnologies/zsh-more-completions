#compdef imv

# Zsh completion for imv - Image viewer for Wayland and X11

_arguments \
  '-h[show help message]' \
  '-b[set background color]:color:' \
  '-c[execute command at startup]:command:' \
  '-d[set slideshow delay in seconds]:seconds:' \
  '-e[set overlay font]:font:' \
  '-f[start in fullscreen mode]' \
  '-l[list open files at exit]' \
  '-n[start at image]:image path or index:' \
  '-r[load directories recursively]' \
  '-s[set scaling mode]:mode:(none shrink full crop)' \
  '-t[start in slideshow mode]' \
  '-u[set upscaling method]:method:(nearest linear)' \
  '-v[show version]' \
  '-w[set window title]:title:' \
  '-x[disable looping]' \
  '*:image file:_files'
