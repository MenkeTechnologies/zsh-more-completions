#compdef compsize
# Documentation: https://man.archlinux.org/search?q=compsize
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    {-b,--bytes}'[Show raw byte counts rather than human-friendly sizes.]'
    '--reflink'
    {-x,--one-file-system}'[Skip files and directories on different file systems. SIGNALS.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
