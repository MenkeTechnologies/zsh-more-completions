#compdef ziptorrent
# Documentation: https://man.archlinux.org/search?q=ziptorrent
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[display this help message]'
  '-n[dont actually change archives, just print what would be done]'
  '-V[display version number]'
  '-v[verbose]'
  '*:filename:_files'
)

_arguments -s -S $arguments
