#compdef setup-pulseaudio
# Documentation: https://man.archlinux.org/search?q=setup-pulseaudio
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--enable[enables PulseAudio]'
  '--disable[disables PulseAudio]'
  '--auto[automatically enables/disables PulseAudio based on configuration]'
  '--status[shows activation state (disabled or enabled) for PulseAudio]'
  '*:filename:_files'
)

_arguments -s -S $arguments
