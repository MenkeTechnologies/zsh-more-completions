#compdef duckdb

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,-help}'[show help]' \
  '(- *)--version[show version]' \
  '-ascii[set output mode to ascii]' \
  '-bail[stop after hitting an error]' \
  '-batch[force batch I/O]' \
  '-box[set output mode to box]' \
  '-column[set output mode to column]' \
  '-cmd[run command before reading stdin]:command' \
  '-c[run command string]:command' \
  '-csv[set output mode to csv]' \
  '-echo[print commands before execution]' \
  '-init[read/process named file]:file:_files' \
  '-header[turn headers on]' \
  '-noheader[turn headers off]' \
  '-html[set output mode to html]' \
  '-interactive[force interactive I/O]' \
  '-json[set output mode to json]' \
  '-line[set output mode to line]' \
  '-list[set output mode to list]' \
  '-markdown[set output mode to markdown]' \
  '-newline[set output row separator]:separator' \
  '-nofollow[refuse to open symbolic links]' \
  '-no-stdin[exit after processing options]' \
  '-nullvalue[set text string for NULL values]:text' \
  '-readonly[open the database read-only]' \
  '-separator[set output column separator]:separator' \
  '-s[run command string]:command' \
  '-stats[print memory stats before each finalize]' \
  '-table[set output mode to table]' \
  '-tabs[set output mode to tabs]' \
  '-unsigned[allow loading unsigned extensions]' \
  '1:database file:_files -g "*.{db,duckdb,parquet,csv,json}"' && ret=0

return ret
