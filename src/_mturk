#compdef mturk

local -a arguments

arguments=(
    '--help[Show help]'
    '--version[Show version]'
    '1:command:->cmds'
    '*:: :->args'
)

local -a commands
commands=(
    'create-hit:Create a new HIT'
    'create-hit-type:Create a new HIT type'
    'create-hit-with-hit-type:Create HIT with existing type'
    'list-hits:List HITs'
    'get-hit:Get HIT details'
    'delete-hit:Delete a HIT'
    'update-hit-review-status:Update HIT review status'
    'list-assignments-for-hit:List assignments for HIT'
    'get-assignment:Get assignment details'
    'approve-assignment:Approve an assignment'
    'reject-assignment:Reject an assignment'
    'list-workers-with-qualification-type:List qualified workers'
    'create-qualification-type:Create a qualification type'
    'list-qualification-types:List qualification types'
    'get-qualification-type:Get qualification type details'
    'get-account-balance:Get account balance'
    'send-bonus:Send bonus to worker'
    'notify-workers:Notify workers'
    'create-worker-block:Block a worker'
    'delete-worker-block:Unblock a worker'
    'list-worker-blocks:List blocked workers'
)

_arguments -s -S $arguments && return

case "$state" in
    cmds)
        _describe -t commands 'mturk commands' commands
        ;;
    args)
        _arguments \
            '--profile[AWS profile]:profile' \
            '--region[AWS region]:region' \
            '--output[Output format]:format:(json text table)' \
            '*:argument:'
        ;;
esac
