#compdef radare2

local -a arguments

arguments=(
  '-0[print \x00 after init and every command]'
  '-2[close stderr file descriptor (silent warning messages)]'
  '-a[set asm.arch]:arch: '
  '-A[run aaa command to analyze all referenced code]'
  '-b[set asm.bits]:bits: '
  '-B[set base address for PIE binaries]:address: '
  '-c[execute radare command]:command: '
  '-C[file is host:port]:host\:port: '
  '-d[debug the executable file or running process pid]'
  '-D[enable debug mode (e cfg.debug=true)]'
  '-e[evaluate config var]:key=value: '
  '-f[block size = file size]'
  '-F[force to use that rbin plugin]:plugin: '
  {-h,-hh}'[show help message, -hh for long]'
  '-H[display variable]:variable: '
  '-i[run script file]:file:_files'
  '-I[run script file before the file is opened]:file:_files'
  '-k[set asm.os]:os:(linux macos w32 netbsd)'
  '-l[load plugin file]:file:_files'
  '-L[list supported IO plugins]'
  '-m[map file at given address (loadaddr)]:address: '
  '-M[do not demangle symbol names]'
  {-n,-nn}'[do not load RBin info (-nn only load bin structures)]'
  '-N[do not load user settings and scripts]'
  '-q[quiet mode (no prompt) and quit after -i]'
  '-Q[quiet mode (no prompt) and quit faster (quickLeak=true)]'
  '-p[use project, list if no arg, load if no file]:project: '
  '-P[apply rapatch file and quit]:file:_files'
  '-r[specify rarun2 profile to load]:profile:_files'
  '-R[specify custom rarun2 directive]:directive: '
  '-s[initial seek]:address: '
  '-S[start r2 in sandbox mode]'
  '-t[load rabin2 info in thread]'
  '-u[set bin.filter=false to get raw sym/sec/cls names]'
  {-v,-V}'[show radare2 version (-V show lib versions)]'
  '-w[open file in write mode]'
  '-x[open without exec-flag (asm.emu will not work), See io.exec]'
  '-X[same as -e bin.usextr=false (useful for dyldcache)]'
  {-z,-zz}'[do not load strings or load them even in raw]'
  '*:filename:_files'
)

_arguments -s -S $arguments
