#compdef dgawk

local -a arguments

arguments=(
  {-f,--file}'[read program source from file]:file:_files'
  {-F,--field-separator}'[set field separator]:separator'
  {-v,--assign}'[assign a variable value]:var=val'
  {-b,--characters-as-bytes}'[treat all input data as single-byte characters]'
  {-c,--traditional}'[run in compatibility mode]'
  {-C,--copyright}'[print short version of GNU copyright information]'
  {-d,--dump-variables}'[dump sorted list of global variables]:file:_files'
  {-e,--source}'[use program-text as program source]:program-text'
  {-E,--exec}'[like -f but exit after end of file]:file:_files'
  {-g,--gen-pot}'[scan and parse AWK program, generate a GNU .pot file]'
  '(- * :)'{-h,--help}'[print this help message and exit]'
  {-L,--lint}'[provide warnings about dubious constructs]'
  {-n,--non-decimal-data}'[recognize octal and hex values in input data]'
  {-N,--use-lc-numeric}'[force use of locale decimal point character]'
  {-O,--optimize}'[enable program optimizations]'
  {-p,--profile}'[send profiling data to file]:file:_files'
  {-P,--posix}'[operate in strict POSIX mode]'
  {-r,--re-interval}'[enable interval expressions in regex]'
  {-R,--command}'[read debugger commands from file]:file:_files'
  {-S,--sandbox}'[run in sandbox mode]'
  {-t,--lint-old}'[provide warnings about non-portable constructs]'
  {-V,--version}'[print version information and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
