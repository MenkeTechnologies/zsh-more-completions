#compdef y4mtopnm
# Documentation: https://man.archlinux.org/search?q=y4mtopnm
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-P[produce PAM output instead of PPM/PGM]'
  '-D[de-interleave fields into two PNM images]'
  '-f[flatten multiplane frames/fields in raw composite grayscale images]'
  '-v[verbosity (0,1,2) \[1\]]'
  '-h[print this help message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
