#compdef unicharset_extractor
# Documentation: https://man.archlinux.org/search?q=unicharset_extractor
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--norm[_mode  Normalization mode: 1=Combine graphemes, 2=Split graphemes, 3=Pure unicode  (type:int default:1)]'
  '--output[_unicharset  Output file path  (type:string default:unicharset)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
