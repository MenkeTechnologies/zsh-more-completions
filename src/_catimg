#compdef catimg
# Documentation: https://man.archlinux.org/search?q=catimg
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[Displays this message]'
  '-w[terminal width]:width:'
  '-l[number of loops for GIF files]:loops:'
  '-r[resolution (1 or 2)]:resolution:(1 2)'
  '-c[Convert colors to a restricted palette]'
  '*:filename:_files'
)

_arguments -s -S $arguments
