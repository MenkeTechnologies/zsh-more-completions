#compdef search
# Documentation: https://man.archlinux.org/search?q=search
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-c,--case-sensitive}'[enable case-sensitive search]'
  {-s,--show-filenames-only}'[show filenames only, not matching lines]'
  '*:filename:_files'
)

_arguments -s -S $arguments
