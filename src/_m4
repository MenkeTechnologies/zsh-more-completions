#compdef m4 gm4

# Completion for GNU M4 macro processor

_m4_debug_flags() {
  local -a flags
  flags=(
    'a:show actual arguments'
    'c:show before collect, after collect and after call'
    'e:show expansion'
    'f:say current input file name'
    'i:show changes in input files'
    'l:say current input line number'
    'p:show results of path searches'
    'q:quote values as necessary, with a or e flag'
    't:trace for all macro calls, not only traced'
    'x:add a unique macro call id, useful with c flag'
    'V:shorthand for all of the above flags'
  )
  _values -s '' 'debug flag' $flags
}

local -a arguments

arguments=(
  '(- *)--help[display help and exit]'
  '(- *)--version[output version information and exit]'

  # Operation modes
  {-E,--fatal-warnings}'[once: warnings become errors, twice: stop execution after first warning]'
  {-e,-i,--interactive}'[unbuffer output, ignore interrupts]'
  {-P,--prefix-builtins}'[force a m4_ prefix to all builtins]'
  {-Q,--quiet,--silent}'[suppress some warnings for builtins]'
  '--warn-macro-sequence=-[warn if macro definition matches REGEXP]::regexp:'

  # Preprocessor features
  '*'{-D+,--define=}'[define NAME as having VALUE, or empty]:name\=value:'
  '*'{-I+,--include=}'[append DIRECTORY to include path]:directory:_directories'
  {-s,--synclines}'[generate #line NUM "FILE" lines]'
  '*'{-U+,--undefine=}'[undefine NAME]:name:'

  # Limits control
  {-g,--gnu}'[override -G to re-enable GNU extensions]'
  {-G,--traditional}'[suppress all GNU extensions]'
  {-H+,--hashsize=}'[set symbol lookup hash table size]:prime number:'
  {-L+,--nesting-limit=}'[change artificial nesting limit, 0 for unlimited]:limit:'

  # Frozen state files
  {-F+,--freeze-state=}'[produce a frozen state on FILE at end]:state file:_files'
  {-R+,--reload-state=}'[reload a frozen state from FILE at start]:state file:_files'

  # Debugging
  {-d+,--debug=}'[set debug level (no FLAGS implies aeq)]:debug flags:_m4_debug_flags'
  {-o+,--error-output=}'[redirect debug and trace output to FILE]:debug file:_files'
  '--debugfile=-[redirect debug and trace output to FILE]::debug file:_files'
  {-l+,--arglength=}'[restrict macro tracing size]:length:'
  '*'{-t+,--trace=}'[trace NAME when it is defined]:macro name:'

  '*:input file:_files'
)

_arguments -s -S : $arguments
