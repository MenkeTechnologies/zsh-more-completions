#compdef mkbom
# Documentation: https://man.archlinux.org/search?q=mkbom
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[print full usage]'
  '-s[create a path-only bom]'
  '-i[a file listing in lsbom(8) format used to create the bom file]'
  '*:filename:_files'
)

_arguments -s -S $arguments
