#compdef smp_conf_phy_event
# Documentation: https://man.archlinux.org/search?q=smp_conf_phy_event
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {--clear,-C}'[clear all peak value detectors for this phy]'
  {--enumerate,-e}'[enumerate phy event source names, ignore]'
  '--expected[EX set expected expander change count to EX]'
  '--file[read PES, THR pairs from FILE]:file'
  {--help,-h}'[print out usage message]'
  {--hex,-H}'[print response in hexadecimal]'
  '--interface[PARAMS specify or override interface]'
  '--pes[PES...|-P PES,PES... comma separated list of Phy]'
  '--phy[phy identifier (def: 0)]:id'
  {--raw,-r}'[output response in binary]'
  '--sa[SAS_ADDR SAS address of SMP target (use leading]'
  '--thres[THR...|-T THR,THR... comma separated list of peak]'
  {--verbose,-v}'[increase verbosity]'
  {--version,-V}'[print version string and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
