#compdef errinfo
# Documentation: https://man.archlinux.org/search?q=errinfo
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-c[# counts - aggregate style]'
  '-p[71 # examine PID 871 only]'
  '-n[# examine processes with the name "ssh" only]'
  '-cn[# examine "ssh" using counts]'
  '*:filename:_files'
)

_arguments -s -S $arguments
