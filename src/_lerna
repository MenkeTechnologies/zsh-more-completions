#compdef lerna

_lerna() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a _lerna_cmds
  _lerna_cmds=(
    'init:initialize a lerna repo'
    'bootstrap:link local packages and install dependencies'
    'publish:publish packages'
    'version:bump version of packages'
    'run:run an npm script in each package'
    'exec:execute a command in each package'
    'clean:remove node_modules from all packages'
    'diff:diff all packages or a single package since last release'
    'ls:list local packages'
    'list:list local packages'
    'changed:list packages that have changed since last release'
    'import:import a package into the monorepo'
    'info:print local environment information'
    'create:create a new lerna-managed package'
    'add:add a dependency to matched packages'
    'link:symlink together all packages'
    'repair:attempt to repair the lerna configuration'
  )

  local -a global_args
  global_args=(
    '--help[show help]'
    '--version[show version]'
    '--loglevel[log level]:level:(silly verbose info success warn error)'
    '--concurrency[max parallel processes]:number:'
    '--reject-cycles[fail if dependency cycle is detected]'
    '--no-progress[disable progress bars]'
    '--no-sort[do not topologically sort packages]'
    '--max-buffer[max buffer length for subprocesses]:bytes:'
  )

  _arguments -C \
    $global_args \
    '1:command:->cmds' \
    '*::arg:->args'

  case "$state" in
    cmds)
      _describe -t commands 'lerna command' _lerna_cmds
      ;;
    args)
      local -a scope_args
      scope_args=(
        '--scope[restrict to packages matching glob]:glob:'
        '--ignore[ignore packages matching glob]:glob:'
        '--since[restrict to packages changed since ref]:ref:'
        '--include-dependencies[include transitive dependencies]'
      )

      case $line[1] in
        init)
          _arguments \
            '--independent[use independent versioning]' \
            '--exact[use exact versions]' \
            $global_args
          ;;
        bootstrap)
          _arguments \
            '--hoist[hoist common dependencies]' \
            '--strict[fail on warnings]' \
            '--nohoist[do not hoist matching glob]:glob:' \
            '--no-ci[use npm install instead of npm ci]' \
            '--force-local[force local sibling links]' \
            $scope_args \
            $global_args
          ;;
        publish)
          _arguments \
            '--canary[publish canary release]' \
            '--contents[subdirectory to publish]:dir:_directories' \
            '--dist-tag[npm dist-tag]:tag:' \
            '--force-publish[force publish all packages]' \
            '--git-head[explicit SHA to set as gitHead]:sha:' \
            '--graph-type[dependency graph type]:type:(all dependencies)' \
            '--no-git-tag-version[do not commit or tag version changes]' \
            '--no-push[do not push to remote]' \
            '--preid[prerelease identifier]:id:' \
            '--pre-dist-tag[npm dist-tag for prerelease]:tag:' \
            '--registry[npm registry URL]:url:' \
            '--tag-version-prefix[tag version prefix]:prefix:' \
            '--temp-tag[use temporary tag for publishing]' \
            '--yes[skip confirmation prompts]' \
            '--conventional-commits[use conventional commits]' \
            $global_args
          ;;
        version)
          _arguments \
            '--allow-branch[allowed branches for versioning]:glob:' \
            '--amend[amend the previous commit]' \
            '--conventional-commits[use conventional commits]' \
            '--conventional-graduate[graduate prerelease packages]' \
            '--conventional-prerelease[create prerelease versions]' \
            '--changelog-preset[changelog preset]:name:' \
            '--create-release[create release on platform]:platform:(github gitlab)' \
            '--exact[save exact versions]' \
            '--force-publish[force publish all packages]' \
            '--git-remote[git remote name]:remote:' \
            '--ignore-changes[ignore changes matching glob]:glob:' \
            '--include-merged-tags[include merged tags]' \
            '--message[custom commit message]:message:' \
            '--no-changelog[do not generate changelog]' \
            '--no-commit-hooks[disable commit hooks]' \
            '--no-git-tag-version[do not commit or tag]' \
            '--no-granular-pathspec[do not use granular pathspec]' \
            '--no-push[do not push to remote]' \
            '--no-private[exclude private packages]' \
            '--preid[prerelease identifier]:id:' \
            '--sign-git-commit[sign git commits]' \
            '--sign-git-tag[sign git tags]' \
            '--tag-version-prefix[tag version prefix]:prefix:' \
            '--yes[skip confirmation prompts]' \
            '--bump[version bump]:bump:(major minor patch premajor preminor prepatch prerelease)' \
            $global_args
          ;;
        run)
          _arguments \
            '--stream[stream output]' \
            '--parallel[run in parallel]' \
            '--no-bail[continue on failure]' \
            '--no-prefix[do not prefix output]' \
            '--profile[generate performance profile]' \
            '--profile-location[profile output directory]:dir:_directories' \
            '--sort[topologically sort packages]' \
            '--no-sort[do not sort packages]' \
            $scope_args \
            $global_args \
            '1:script:'
          ;;
        exec)
          _arguments \
            '--stream[stream output]' \
            '--parallel[run in parallel]' \
            '--no-bail[continue on failure]' \
            $scope_args \
            $global_args \
            '*:command:'
          ;;
        clean)
          _arguments \
            '--yes[skip confirmation]' \
            '--scope[restrict to packages matching glob]:glob:' \
            '--ignore[ignore packages matching glob]:glob:' \
            $global_args
          ;;
        diff)
          _arguments \
            $global_args \
            '1:package:'
          ;;
        ls|list)
          _arguments \
            '--json[output as JSON]' \
            '--ndjson[output as newline-delimited JSON]' \
            '--all[include private packages]' \
            '--long[show extended information]' \
            '--parseable[show parseable output]' \
            '--toposort[topologically sort]' \
            '--graph[show dependency graph]' \
            $scope_args \
            '--include-dependents[include dependents]' \
            $global_args
          ;;
        changed)
          _arguments \
            '--json[output as JSON]' \
            '--ndjson[output as newline-delimited JSON]' \
            '--all[include private packages]' \
            '--long[show extended information]' \
            '--parseable[show parseable output]' \
            '--toposort[topologically sort]' \
            '--graph[show dependency graph]' \
            $scope_args \
            '--include-dependents[include dependents]' \
            $global_args
          ;;
        import)
          _arguments \
            $global_args \
            '1:directory:_directories'
          ;;
        info)
          _arguments $global_args
          ;;
        create)
          _arguments \
            $global_args \
            '1:package name:'
          ;;
        add)
          _arguments \
            $scope_args \
            $global_args \
            '1:package:'
          ;;
        link)
          _arguments $global_args
          ;;
        repair)
          _arguments $global_args
          ;;
      esac
      ;;
  esac
}

_lerna "$@"
