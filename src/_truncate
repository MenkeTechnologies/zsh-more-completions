#compdef truncate

# Completion for truncate (shrink or extend the size of a file)

local arguments

arguments=(
  '(- *)--help[display help information and exit]'
  '(- *)--version[output version information and exit]'

  {-c,--no-create}'[do not create any files]'
  {-o,--io-blocks}'[treat SIZE as number of IO blocks instead of bytes]'
  {-r+,--reference=}'[base size on reference file]:reference file:_files'
  {-s+,--size=}'[set or adjust the file size by SIZE bytes (+/-/</>/%/ prefixes supported)]:size'

  '*:file:_files'
)

_arguments -s -S $arguments
