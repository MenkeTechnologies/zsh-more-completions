                    '--exec-arg[new arguments for the exec credential plugin]:arg:' \
                    '--exec-env[key=value environment values for the exec credential plugin]:env:' \
                    '--password[password for the user entry]:password:' \
                    '--token[token for the user entry]:token:' \
                    '--username[username for the user entry]:username:' \
                    ':user:'
                  ;;
                set)
                  _arguments ':property path:' ':value:'
                  ;;
                unset)
                  _arguments ':property path:'
                  ;;
                rename-context)
                  _arguments ':old context:' ':new context:'
                  ;;
                delete-cluster|delete-context|delete-user)
                  _arguments ':name:'
                  ;;
                get-contexts)
                  _arguments \
                    $_kubectl_output_flag \
                    '--no-headers[do not print headers]' \
                    ':context:'
