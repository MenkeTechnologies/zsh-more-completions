#compdef kubectl

# Zsh completion for kubectl (Kubernetes CLI)
# Updated with all commands, subcommands, and flags

local -a _kubectl_resource_types

_kubectl_resource_types=(
  pods po services svc deployments deploy replicasets rs statefulsets sts
  daemonsets ds jobs cronjobs cj configmaps cm secrets serviceaccounts sa
  namespaces ns nodes no persistentvolumes pv persistentvolumeclaims pvc
  ingresses ing networkpolicies netpol roles rolebindings clusterroles
  clusterrolebindings endpoints ep events ev limitranges limits
  resourcequotas quota horizontalpodautoscalers hpa poddisruptionbudgets pdb
  priorityclasses pc storageclasses sc volumeattachments
  customresourcedefinitions crd csidrivers csinodes csistoragecapacities
  mutatingwebhookconfigurations validatingwebhookconfigurations
  leases controllerrevisions replicationcontrollers rc podtemplates
  validatingadmissionpolicies validatingadmissionpolicybindings
)

_kubectl_global_flags=(
  '--kubeconfig[path to the kubeconfig file]:file:_files'
  '--context[the name of the kubeconfig context to use]:context:'
  {-n,--namespace}'[if present, the namespace scope for this CLI request]:namespace:'
  '--cluster[the name of the kubeconfig cluster to use]:cluster:'
  '--user[the name of the kubeconfig user to use]:user:'
  '--as[username to impersonate for the operation]:user:'
  '--as-group[group to impersonate for the operation]:group:'
  '--as-uid[UID to impersonate for the operation]:uid:'
  '--cache-dir[default cache directory]:dir:_directories'
  '--certificate-authority[path to a cert file for the certificate authority]:file:_files'
  '--client-certificate[path to a client certificate file]:file:_files'
  '--client-key[path to a client key file]:file:_files'
  '--insecure-skip-tls-verify[skip TLS certificate verification]'
  '--match-server-version[require server version to match client version]'
  '--request-timeout[the length of time to wait before giving up on a single server request]:timeout:'
  {-s,--server}'[the address and port of the Kubernetes API server]:server:'
  '--tls-server-name[server name to use for server certificate validation]:name:'
  '--token[bearer token for authentication to the API server]:token:'
  {-v,--v}'[number for the log level verbosity]:level:'
  '--warnings-as-errors[treat warnings received from the server as errors]'
)

_kubectl_output_flag=(
  {-o,--output}'[output format]:format:(json yaml wide name custom-columns custom-columns-file go-template go-template-file jsonpath jsonpath-as-json jsonpath-file template templatefile)'
)

_kubectl_dry_run_flag=(
  '--dry-run[strategy for dry run]:strategy:(none client server)'
)

_kubectl_selector_flag=(
  {-l,--selector}'[selector (label query) to filter on]:selector:'
)

_kubectl_field_selector_flag=(
  '--field-selector[selector (field query) to filter on]:selector:'
)

_kubectl_filename_flags=(
  {-f,--filename}'[filename, directory, or URL to files]:file:_files'
  {-k,--kustomize}'[process a kustomization directory]:dir:_directories'
  {-R,--recursive}'[process the directory used in -f recursively]'
)

_kubectl_commands=(
  # Basic Commands (Beginner)
  'create:create a resource from a file or from stdin'
  'expose:take a replication controller, service, deployment or pod and expose it as a new Kubernetes service'
  'run:run a particular image on the cluster'
  'set:set specific features on objects'
  # Basic Commands (Intermediate)
  'explain:get documentation for a resource'
  'get:display one or many resources'
  'edit:edit a resource on the server'
  'delete:delete resources by file names, stdin, resources and names, or by resources and label selector'
  # Deploy Commands
  'rollout:manage the rollout of a resource'
  'scale:set a new size for a deployment, replica set, or replication controller'
  'autoscale:auto-scale a deployment, replica set, stateful set, or replication controller'
  # Cluster Management Commands
  'certificate:modify certificate resources'
  'cluster-info:display cluster information'
  'top:display resource (CPU/memory) usage'
  'cordon:mark node as unschedulable'
  'uncordon:mark node as schedulable'
  'drain:drain node in preparation for maintenance'
  'taint:update the taints on one or more nodes'
  # Troubleshooting and Debugging Commands
  'describe:show details of a specific resource or group of resources'
  'logs:print the logs for a container in a pod'
  'attach:attach to a running container'
  'exec:execute a command in a container'
  'port-forward:forward one or more local ports to a pod'
  'proxy:run a proxy to the Kubernetes API server'
  'cp:copy files and directories to and from containers'
  'auth:inspect authorization'
  'debug:create debugging sessions for troubleshooting workloads and nodes'
  'events:list events'
  # Advanced Commands
  'diff:diff the live version against a would-be applied version'
  'apply:apply a configuration to a resource by file name or stdin'
  'patch:update fields of a resource'
  'replace:replace a resource by file name or stdin'
  'wait:wait for a specific condition on one or many resources'
  'kustomize:build a kustomization target from a directory or URL'
  # Settings Commands
  'label:update the labels on a resource'
  'annotate:update the annotations on a resource'
  'completion:output shell completion code for the specified shell'
  # Other Commands
  'alpha:commands for features in alpha'
  'api-resources:print the supported API resources on the server'
  'api-versions:print the supported API versions on the server'
  'config:modify kubeconfig files'
  'plugin:provides utilities for interacting with plugins'
  'version:print the client and server version information'
)

_kubectl_config_commands=(
  'current-context:display the current-context'
  'delete-cluster:delete the specified cluster from the kubeconfig'
  'delete-context:delete the specified context from the kubeconfig'
  'delete-user:delete the specified user from the kubeconfig'
  'get-clusters:display clusters defined in the kubeconfig'
  'get-contexts:describe one or many contexts'
  'get-users:display users defined in the kubeconfig'
  'rename-context:rename a context from the kubeconfig file'
  'set:set an individual value in a kubeconfig file'
  'set-cluster:set a cluster entry in kubeconfig'
  'set-context:set a context entry in kubeconfig'
  'set-credentials:set a user entry in kubeconfig'
  'unset:unset an individual value in a kubeconfig file'
  'use-context:set the current-context in a kubeconfig file'
  'view:display merged kubeconfig settings or a specified kubeconfig file'
)

_kubectl_rollout_commands=(
  'history:view rollout history'
  'pause:mark the provided resource as paused'
  'restart:restart a resource'
  'resume:resume a paused resource'
  'status:show the status of the rollout'
  'undo:undo a previous rollout'
)

_kubectl_top_commands=(
  'node:display resource (CPU/memory) usage of nodes'
  'pod:display resource (CPU/memory) usage of pods'
)

_kubectl_create_subcommands=(
  'clusterrole:create a cluster role'
  'clusterrolebinding:create a cluster role binding for a particular cluster role'
  'configmap:create a config map from a local file, directory or literal value'
  'cronjob:create a cron job with the specified name'
  'deployment:create a deployment with the specified name'
  'ingress:create an ingress with the specified name'
  'job:create a job with the specified name'
  'namespace:create a namespace with the specified name'
  'poddisruptionbudget:create a pod disruption budget with the specified name'
  'priorityclass:create a priority class with the specified name'
  'quota:create a resource quota with the specified name'
  'role:create a role with single rule'
  'rolebinding:create a role binding for a particular role or cluster role'
  'secret:create a secret using specified subcommand'
  'service:create a service using a specified subcommand'
  'serviceaccount:create a service account with the specified name'
  'token:request a service account token'
)

_kubectl_set_subcommands=(
  'env:update environment variables on a pod template'
  'image:update the image of a pod template'
  'resources:update resource requests/limits on objects with pod templates'
  'selector:set the selector on a resource'
  'serviceaccount:update the service account of a resource'
  'subject:update the user, group, or service account in a role binding or cluster role binding'
)

_kubectl_auth_subcommands=(
  'can-i:check whether an action is allowed'
  'reconcile:reconciles rules for RBAC role, role binding, cluster role, and cluster role binding objects'
  'whoami:experimental - check self subject attributes'
)

_kubectl_certificate_subcommands=(
  'approve:approve a certificate signing request'
  'deny:deny a certificate signing request'
)

_kubectl() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    $_kubectl_global_flags \
    '1:command:->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'kubectl command' _kubectl_commands
      ;;
    args)
      case $line[1] in
        get)
          _arguments \
            $_kubectl_global_flags \
            $_kubectl_output_flag \
            $_kubectl_selector_flag \
            $_kubectl_field_selector_flag \
            $_kubectl_filename_flags \
            {-A,--all-namespaces}'[list the requested objects across all namespaces]' \
            {-w,--watch}'[watch for changes after listing/getting]' \
            '--watch-only[watch for changes to the requested objects without listing/getting first]' \
            '--show-labels[show all labels as the last column]' \
            '--show-kind[list the resource type for the requested objects]' \
            '--show-managed-fields[show managed fields in the output]' \
            '--sort-by[sort list types using this field specification]:field:' \
            '--no-headers[do not print headers]' \
            '--chunk-size[return large lists in chunks rather than all at once]:size:' \
            '--ignore-not-found[treat "resource not found" as a successful retrieval]' \
            '--subresource[specify subresource to get]:subresource:(status scale)' \
            '--template[template string or path to template file]:template:_files' \
            '--allow-missing-template-keys[ignore errors in templates when a field or key is missing]' \
            '--server-print[output in the server-preferred format]' \
            '--raw[raw URI to request from the server]:uri:' \
            '*:resource type:($(_kubectl_resource_types))'
          ;;
        apply)
          _arguments \
            $_kubectl_global_flags \
            $_kubectl_output_flag \
            $_kubectl_selector_flag \
            $_kubectl_filename_flags \
            $_kubectl_dry_run_flag \
            '--all[select all resources in the namespace of the specified resource types]' \
            '--cascade[strategy for cascade deletion]:strategy:(background orphan foreground)' \
            '--field-manager[name of the manager used to track field ownership]:manager:' \
            '--force[if true, immediately remove resources from API and bypass graceful deletion]' \
            '--force-conflicts[if true, server-side apply will force the changes against conflicts]' \
            '--grace-period[period of time in seconds given to the resource to terminate gracefully]:seconds:' \
            '--openapi-patch[try to use openapi to calculate diff]' \
            '--overwrite[automatically resolve conflicts between the modified and live configuration]' \
            '--prune[automatically delete resource objects that do not appear in the configs]' \
            '--prune-allowlist[overrides the default allowlist with the specified object]:group/version/kind:' \
            '--server-side[submit server-side apply request]' \
            '--show-managed-fields[show managed fields in the output]' \
            '--validate[validation mode]:mode:(strict warn ignore true false)' \
            '--wait[wait for resources to be gone before returning]'
          ;;
        delete)
          _arguments \
            $_kubectl_global_flags \
            $_kubectl_output_flag \
            $_kubectl_selector_flag \
            $_kubectl_field_selector_flag \
            $_kubectl_filename_flags \
            $_kubectl_dry_run_flag \
            '--all[delete all resources in the namespace]' \
            {-A,--all-namespaces}'[delete across all namespaces]' \
            '--cascade[strategy for cascade deletion]:strategy:(background orphan foreground)' \
            '--force[if true, immediately remove resources from API]' \
            '--grace-period[period of time in seconds given to the resource to terminate gracefully]:seconds:' \
            '--ignore-not-found[treat "resource not found" as a successful delete]' \
            '--now[if true, resources are signaled for immediate shutdown]' \
            '--raw[raw URI to DELETE to the server]:uri:' \
            '--timeout[the length of time to wait before giving up on a delete]:duration:' \
            '--wait[if true, wait for resources to be gone before returning]' \
            '*:resource type:($(_kubectl_resource_types))'
          ;;
        describe)
          _arguments \
            $_kubectl_global_flags \
            $_kubectl_selector_flag \
            $_kubectl_filename_flags \
            {-A,--all-namespaces}'[describe across all namespaces]' \
            '--chunk-size[return large lists in chunks rather than all at once]:size:' \
            '--show-events[show events related to the described object]' \
            ':resource type:($(_kubectl_resource_types))' \
            ':resource name:'
          ;;
        logs)
          _arguments \
            $_kubectl_global_flags \
            $_kubectl_selector_flag \
            {-f,--follow}'[specify if the logs should be streamed]' \
            '--tail[lines of recent log file to display]:lines:' \
            '--since[only return logs newer than a relative duration]:duration:' \
            '--since-time[only return logs after a specific date (RFC3339)]:time:' \
            {-c,--container}'[print the logs of this container]:container:' \
            '--all-containers[get all containers'\'' logs in the pod]' \
            {-p,--previous}'[print the logs for the previous instance of the container]' \
            '--timestamps[include timestamps on each line in the log output]' \
            '--prefix[prefix each log line with the log source (pod name and container name)]' \
            '--ignore-errors[if watching / following pod logs, allow for any errors that occur to be non-fatal]' \
            '--insecure-skip-tls-verify-backend[skip verifying the identity of the kubelet when connecting]' \
            '--limit-bytes[maximum bytes of logs to return]:bytes:' \
            '--max-log-requests[specify maximum number of concurrent logs to follow when using a selector]:count:' \
            '--pod-running-timeout[the length of time to wait until at least one pod is running]:duration:' \
            ':pod name:'
          ;;
        exec)
          _arguments \
            $_kubectl_global_flags \
            $_kubectl_filename_flags \
            {-i,--stdin}'[pass stdin to the container]' \
            {-t,--tty}'[stdin is a TTY]' \
            {-c,--container}'[container name]:container:' \
            '-q[only print output from the remote session]' \
            '--pod-running-timeout[the length of time to wait until at least one pod is running]:duration:' \
            ':pod name:' \
            '(--)--[command separator]' \
            '*:command:'
          ;;
        run)
          _arguments \
            $_kubectl_global_flags \
            $_kubectl_output_flag \
            $_kubectl_dry_run_flag \
            '--image[the image for the container to run]:image:' \
            '--port[the port that this container exposes]:port:' \
            '--env[environment variables to set in the container]:env:' \
            '--labels[comma separated labels to apply to the pod]:labels:' \
            '--restart[the restart policy for this pod]:policy:(Always OnFailure Never)' \
            '--rm[if true, delete the pod after it exits]' \
            {-i,--stdin}'[keep stdin open on the container]' \
            {-t,--tty}'[allocate a TTY for the container]' \
            '--attach[wait for the pod to start running and then attach]' \
            '--command[use extra arguments as the command field instead of the default]' \
            '--expose[create a ClusterIP service associated with the pod]' \
            '--grace-period[period of time in seconds to wait before killing the pod]:seconds:' \
            '--hostport[the host port mapping for the container port]:hostport:' \
            '--image-pull-policy[the image pull policy for the container]:policy:(Always IfNotPresent Never)' \
            '--leave-stdin-open[leave stdin open after the first attach completes]' \
            '--limits[the resource requirement limits for this container]:limits:' \
            '--override-type[the method used to override the generated object]:type:(json merge strategic)' \
            '--overrides[an inline JSON override for the generated object]:json:' \
            '--pod-running-timeout[the length of time to wait until at least one pod is running]:duration:' \
            '--privileged[give extended privileges to this container]' \
            '--quiet[suppress prompt messages]' \
            '--requests[the resource requirement requests for this container]:requests:' \
            '--serviceaccount[service account name to use]:sa:' \
            '--annotations[annotations to apply to the pod]:annotations:' \
            ':name:'
          ;;
        create)
          _arguments -C \
            $_kubectl_global_flags \
            $_kubectl_output_flag \
            $_kubectl_filename_flags \
            $_kubectl_selector_flag \
            $_kubectl_dry_run_flag \
            '--edit[edit the API resource before creating]' \
            '--field-manager[name of the manager used to track field ownership]:manager:' \
            '--raw[raw URI to POST to the server]:uri:' \
            '--save-config[save the config of the current object in its annotation]' \
            '--show-managed-fields[show managed fields in the output]' \
            '--validate[validation mode]:mode:(strict warn ignore true false)' \
            '--windows-line-endings[use Windows line-endings]' \
            '1:subcommand:->subcmd' \
            '*::arg:->subargs'
          case $state in
            subcmd) _describe -t commands 'create subcommand' _kubectl_create_subcommands ;;
            subargs)
              case $line[1] in
                configmap)
                  _arguments \
                    $_kubectl_global_flags \
                    $_kubectl_output_flag \
                    $_kubectl_dry_run_flag \
                    '--from-file[key files can be specified using their file path]:file:_files' \
                    '--from-literal[specify a key and literal value to insert in config map]:key=value:' \
                    '--from-env-file[specify the path to a file to read lines of key=val pairs]:file:_files' \
                    '--append-hash[append a hash of the configmap to its name]' \
                    ':name:'
                  ;;
                secret)
                  _arguments \
                    $_kubectl_global_flags \
                    '1:type:(docker-registry generic tls)'
                  ;;
                deployment)
                  _arguments \
                    $_kubectl_global_flags \
                    $_kubectl_output_flag \
                    $_kubectl_dry_run_flag \
                    '--image[image names to run]:image:' \
                    '--replicas[number of replicas to create]:replicas:' \
                    '--port[the port that this container exposes]:port:' \
                    ':name:'
                  ;;
                namespace)
                  _arguments \
                    $_kubectl_global_flags \
                    $_kubectl_output_flag \
                    $_kubectl_dry_run_flag \
                    ':name:'
                  ;;
                service)
                  _arguments \
                    $_kubectl_global_flags \
                    '1:type:(clusterip externalname loadbalancer nodeport)'
                  ;;
                job)
                  _arguments \
                    $_kubectl_global_flags \
                    $_kubectl_output_flag \
                    $_kubectl_dry_run_flag \
                    '--from[the name of the resource to create a job from]:resource:' \
                    '--image[image name to run]:image:' \
                    ':name:'
                  ;;
                cronjob)
                  _arguments \
                    $_kubectl_global_flags \
                    $_kubectl_output_flag \
                    $_kubectl_dry_run_flag \
                    '--image[image name to run]:image:' \
                    '--schedule[a schedule in the Cron format]:schedule:' \
                    '--restart[job restart policy]:policy:(Always OnFailure Never)' \
                    ':name:'
                  ;;
                token)
                  _arguments \
                    $_kubectl_global_flags \
                    '--audience[audience of the requested token]:audience:' \
                    '--bound-object-kind[kind of an object to bind the token to]:kind:(Node Pod Secret)' \
                    '--bound-object-name[name of an object to bind the token to]:name:' \
                    '--bound-object-uid[UID of an object to bind the token to]:uid:' \
                    '--duration[requested lifetime of the token]:duration:' \
                    ':service account:'
                  ;;
              esac
              ;;
          esac
          ;;
        expose)
          _arguments \
            $_kubectl_global_flags \
            $_kubectl_output_flag \
            $_kubectl_selector_flag \
            $_kubectl_filename_flags \
            $_kubectl_dry_run_flag \
            '--cluster-ip[clusterIP to be assigned to the service]:clusterIP:' \
            '--external-ip[additional external IP address to accept for the service]:ip:' \
            '--load-balancer-ip[IP to assign to the LoadBalancer]:ip:' \
            '--name[the name for the newly created object]:name:' \
            '--overrides[an inline JSON override for the generated object]:json:' \
            '--port[the port that the service should serve on]:port:' \
            '--protocol[the network protocol for the service]:protocol:(TCP UDP SCTP)' \
            '--session-affinity[set the session affinity for the service]:affinity:(None ClientIP)' \
            '--target-port[name or number for the port on the container]:port:' \
            '--type[type for this service]:type:(ClusterIP NodePort LoadBalancer ExternalName)' \
            '*:resource:'
          ;;
        edit)
          _arguments \
            $_kubectl_global_flags \
            $_kubectl_output_flag \
            $_kubectl_filename_flags \
            $_kubectl_selector_flag \
            {-A,--all-namespaces}'[edit across all namespaces]' \
            '--field-manager[name of the manager used to track field ownership]:manager:' \
            '--save-config[save the config of the current object in its annotation]' \
            '--show-managed-fields[show managed fields in the output]' \
            '--subresource[specify subresource to edit]:subresource:(status scale)' \
            '--validate[validation mode]:mode:(strict warn ignore true false)' \
            '--windows-line-endings[use Windows line-endings]' \
            '*:resource type:($(_kubectl_resource_types))'
          ;;
        scale)
          _arguments \
            $_kubectl_global_flags \
            $_kubectl_output_flag \
            $_kubectl_filename_flags \
            $_kubectl_selector_flag \
            $_kubectl_dry_run_flag \
            '--all[select all resources in the namespace of the specified resource types]' \
            '--current-replicas[precondition for current size]:count:' \
            '--replicas[the new desired number of replicas]:count:' \
            '--resource-version[precondition for resource version]:version:' \
            '--timeout[the length of time to wait before giving up on a scale operation]:duration:' \
            '*:resource:'
          ;;
        autoscale)
          _arguments \
            $_kubectl_global_flags \
            $_kubectl_output_flag \
            $_kubectl_filename_flags \
            $_kubectl_dry_run_flag \
            '--cpu-percent[the target average CPU utilization]:percent:' \
            '--max[the upper limit for the number of pods]:max:' \
            '--min[the lower limit for the number of pods]:min:' \
            '--name[the name for the newly created HPA]:name:' \
            '*:resource:'
          ;;
        rollout)
          _arguments -C \
            $_kubectl_global_flags \
            '1:subcommand:->subcmd' \
            '*::arg:->subargs'
          case $state in
            subcmd) _describe -t commands 'rollout command' _kubectl_rollout_commands ;;
            subargs)
              case $line[1] in
                history)
                  _arguments \
                    $_kubectl_global_flags \
                    $_kubectl_output_flag \
                    $_kubectl_filename_flags \
                    $_kubectl_selector_flag \
                    '--revision[see the details of a specific revision]:revision:' \
                    '*:resource:'
                  ;;
                pause|resume)
                  _arguments \
                    $_kubectl_global_flags \
                    $_kubectl_output_flag \
                    $_kubectl_filename_flags \
                    $_kubectl_selector_flag \
                    '--field-manager[name of the manager used to track field ownership]:manager:' \
                    '*:resource:'
                  ;;
                restart)
                  _arguments \
                    $_kubectl_global_flags \
                    $_kubectl_output_flag \
                    $_kubectl_filename_flags \
                    $_kubectl_selector_flag \
                    '--field-manager[name of the manager used to track field ownership]:manager:' \
                    '*:resource:'
                  ;;
                status)
                  _arguments \
                    $_kubectl_global_flags \
                    $_kubectl_filename_flags \
                    $_kubectl_selector_flag \
                    '--revision[pin the status display to a specific revision]:revision:' \
                    '--timeout[the length of time to wait before ending watch]:duration:' \
                    {-w,--watch}'[watch the status of the rollout until it is done]' \
                    '*:resource:'
                  ;;
                undo)
                  _arguments \
                    $_kubectl_global_flags \
                    $_kubectl_output_flag \
                    $_kubectl_filename_flags \
                    $_kubectl_selector_flag \
                    $_kubectl_dry_run_flag \
                    '--to-revision[the revision to rollback to]:revision:' \
                    '*:resource:'
                  ;;
              esac
              ;;
          esac
          ;;
        top)
          _arguments -C \
            $_kubectl_global_flags \
            '1:subcommand:->subcmd' \
            '*::arg:->subargs'
          case $state in
            subcmd) _describe -t commands 'top command' _kubectl_top_commands ;;
            subargs)
              case $line[1] in
                pod)
                  _arguments \
                    $_kubectl_global_flags \
                    $_kubectl_selector_flag \
                    '--containers[show metrics for all containers]' \
                    '--no-headers[do not print headers]' \
                    '--sort-by[sort by cpu or memory]:field:(cpu memory)' \
                    '--sum[print the sum of the resource usage]' \
                    '--use-protocol-buffers[enables using protocol-buffers to access Metrics API]' \
                    {-A,--all-namespaces}'[list across all namespaces]' \
                    ':pod name:'
                  ;;
                node)
                  _arguments \
                    $_kubectl_global_flags \
                    $_kubectl_selector_flag \
                    '--no-headers[do not print headers]' \
                    '--sort-by[sort by cpu or memory]:field:(cpu memory)' \
                    '--show-capacity[show the capacity of the node]' \
                    '--use-protocol-buffers[enables using protocol-buffers to access Metrics API]' \
                    ':node name:'
                  ;;
              esac
              ;;
          esac
          ;;
        config)
          _arguments -C \
            $_kubectl_global_flags \
            '1:subcommand:->subcmd' \
            '*::arg:->subargs'
          case $state in
            subcmd) _describe -t commands 'config command' _kubectl_config_commands ;;
            subargs)
              case $line[1] in
                use-context)
                  _arguments ':context:'
