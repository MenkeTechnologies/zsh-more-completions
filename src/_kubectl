        annotate)
          _arguments \
            $_kubectl_global_flags \
            $_kubectl_output_flag \
            $_kubectl_selector_flag \
            $_kubectl_filename_flags \
            $_kubectl_dry_run_flag \
            '--all[select all resources in the namespace]' \
            {-A,--all-namespaces}'[annotate across all namespaces]' \
