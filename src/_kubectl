            '--custom[path to a JSON or YAML file containing a partial container spec]:file:_files' \
            '--env[environment variables to set in the container]:env:' \
            '--image[container image to use for debug container]:image:' \
            '--image-pull-policy[the image pull policy for the debug container]:policy:(Always IfNotPresent Never)' \
            {-i,--stdin}'[keep stdin open on the container]' \
