            '--skip-wait-for-delete-timeout[skip waiting for pods whose deletion timestamp is less than N seconds]:seconds:' \
            '--timeout[the length of time to wait before giving up]:duration:' \
            ':node name:'
          ;;
        taint)
          _arguments \
            $_kubectl_global_flags \
            $_kubectl_output_flag \
            $_kubectl_selector_flag \
            $_kubectl_dry_run_flag \
