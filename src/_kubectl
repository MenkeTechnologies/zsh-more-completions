              ;;
          esac
          ;;
        port-forward)
          _arguments \
            $_kubectl_global_flags \
            '--address[addresses to listen on]:address:' \
            '--pod-running-timeout[the length of time to wait until at least one pod is running]:duration:' \
            ':resource:' \
            '*:port (local\:remote):'
          ;;
        diff)
          _arguments \
            $_kubectl_global_flags \
            $_kubectl_selector_flag \
            $_kubectl_filename_flags \
