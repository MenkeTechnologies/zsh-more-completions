#compdef fusermount-glusterfs
# Documentation: https://man.archlinux.org/search?q=fusermount-glusterfs
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[print help]'
  '-V[print version]'
  '-o[opt...\] mount options]'
  '-u[unmount]'
  '-q[quiet]'
  '-z[lazy unmount]'
  '*:filename:_files'
)

_arguments -s -S $arguments
