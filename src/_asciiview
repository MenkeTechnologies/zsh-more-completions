#compdef asciiview

local -a arguments

arguments=(
    '-driver[Display driver]:driver:(curses slang x11 stdout stderr)'
    '-width[Width]:width:'
    '-height[Height]:height:'
    '-brightness[Brightness]:brightness:'
    '-contrast[Contrast]:contrast:'
    '-gamma[Gamma]:gamma:'
    '-dimmul[Dithering multiplier]:value:'
    '-bold[Use bold characters]'
    '-dim[Use dim characters]'
    '-reverse[Use reverse video]'
    '-normal[Normal output]'
    '-inversion[Inversion type]:type:'
    '-dither[Dithering mode]:mode:(none error_distribution)'
    '-random[Random dithering]:value:'
    '-help[Show help]'
    '*:image file:_files -g "*.{png,jpg,jpeg,gif,bmp,pnm,pgm,ppm,tga,pcx}"'
)

_arguments -s -S $arguments
