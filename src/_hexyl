#compdef hexyl

local -a arguments

arguments=(
  {-n,--length}'[only read N bytes from the input]:bytes:'
  {-c,--bytes}'[an alias for -n/--length]'
  {-s,--skip}'[skip the first N bytes of the input]:bytes:'
  '--block-size[sets the size of the `block` unit to SIZE.]'
  {-v,--no-squeezing}'[display all input data without squeezing identical lines]'
  '--color[when to use colors]:when:(always auto never)'
  '--border[border style]:style:(unicode ascii none)'
  {-o,--display-offset}'[add N bytes to the displayed file position]:offset:'
  {-h,--help}'[prints help information]'
  {-V,--version}'[prints version information]'
  '*:filename:_files'
)

_arguments -s -S $arguments
