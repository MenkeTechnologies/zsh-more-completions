#compdef pipx

# Zsh completion for pipx - install/run Python applications in isolated environments

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'install:install a package'
  'inject:install packages into an existing virtual environment'
  'upgrade:upgrade a package'
  'upgrade-all:upgrade all packages'
  'uninstall:uninstall a package'
  'uninstall-all:uninstall all packages'
  'reinstall:reinstall a package'
  'reinstall-all:reinstall all packages'
  'list:list installed packages'
  'run:run an app in a temporary virtual environment'
  'ensurepath:ensure pipx paths are on PATH'
  'environment:print pipx environment variables'
  'completions:print shell completions'
)

_arguments -s -S \
  '1:command:->command' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'pipx command' commands && ret=0
    ;;
  (args)
    local -a installed_packages
    installed_packages=("${(@f)$(pipx list --short 2>/dev/null | awk '{print $1}')}")

    case $words[1] in
      (install)
        _arguments -s -S \
          '--include-deps[include apps of dependent packages]' \
          '--force[modify existing virtual environment]' \
          '--suffix[optional suffix for virtual environment]:suffix' \
          '--python[python interpreter to use]:python:_command_names' \
          '--pip-args[extra arguments to pass to pip]:args' \
          '--preinstall[packages to install before the main package]:package' \
          '--system-site-packages[give access to system site-packages]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:package' && ret=0
        ;;
      (inject)
        _arguments -s -S \
          '--include-apps[add apps from injected packages]' \
          '--include-deps[include apps of dependent packages]' \
          '--pip-args[extra arguments to pass to pip]:args' \
          '--force[modify existing virtual environment]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:package:compadd -a installed_packages' \
          '*:dependencies' && ret=0
        ;;
      (upgrade)
        _arguments -s -S \
          '--include-injected[upgrade injected packages too]' \
          '--force[modify existing virtual environment]' \
          '--pip-args[extra arguments to pass to pip]:args' \
          '--python[python interpreter to use]:python:_command_names' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:package:compadd -a installed_packages' && ret=0
        ;;
      (upgrade-all)
        _arguments -s -S \
          '--include-injected[upgrade injected packages too]' \
          '--force[modify existing virtual environment]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (uninstall)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:package:compadd -a installed_packages' && ret=0
        ;;
      (reinstall)
        _arguments -s -S \
          '--python[python interpreter to use]:python:_command_names' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:package:compadd -a installed_packages' && ret=0
        ;;
      (list)
        _arguments -s -S \
          '--include-injected[show injected packages]' \
          '--json[output as JSON]' \
          '--short[output in short format]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (run)
        _arguments -s -S \
          '--no-cache[do not reuse cached virtual environment]' \
          '--pip-args[extra arguments to pass to pip]:args' \
          '--spec[pip installation spec]:spec' \
          '--python[python interpreter to use]:python:_command_names' \
          '--system-site-packages[give access to system site-packages]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:package' \
          '*:arguments' && ret=0
        ;;
      (completions)
        _arguments '1:shell:(bash zsh fish)' && ret=0
        ;;
      (*)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
