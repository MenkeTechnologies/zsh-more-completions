#compdef lvchange

local -a arguments

arguments=(
  {-p,--permission}'[set access permission]:permission:(rw r)'
  {-r,--readahead}'[set read ahead sectors]:readahead:(auto none)'
  {-k,--setactivationskip}'[set activation skip flag]:flag:(y n)'
  {-Z,--zero}'[set zeroing of new blocks]:flag:(y n)'
  {-M,--persistent}'[set persistent device number]:flag:(y n)'
  '--addtag[add a tag to the LV]:tag:'
  '--deltag[delete a tag from the LV]:tag:'
  '--alloc[set allocation policy]:policy:(anywhere contiguous cling inherit normal)'
  '--detachprofile[detach metadata profile]'
  '--metadataprofile[set metadata profile]:profile:'
  '--profile[set configuration profile]:profile:'
  '--errorwhenfull[error when thin pool is full]:flag:(y n)'
  '--discards[set thin pool discards behavior]:behavior:(ignore nopassdown passdown)'
  '--cachemode[set cache mode]:mode:(passthrough writeback writethrough)'
  '--cachepolicy[set cache policy]:policy:'
  '--cachesettings[set cache settings]:settings:'
  '--minrecoveryrate[set minimum recovery rate]:rate:'
  '--maxrecoveryrate[set maximum recovery rate]:rate:'
  '--writebehind[set maximum outstanding writes behind]:number:'
  '--writemostly[mark device as write-mostly]:PV:'
  '*:filename:_files'
)

_arguments -s -S $arguments
