local -a arguments

arguments=(
  '-i[input cowpatty hashfile]'
  '-w[output passwordlist file]'
  '-W[output pmk:password file]'
  '-p[output pmk file]'
  '-s[print pmks to stdout]'
  '-h[this help file]'
  '*:filename:_files'
