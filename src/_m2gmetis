#compdef m2gmetis
# Documentation: https://man.archlinux.org/search?q=m2gmetis
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-gtype[specifies the graph that will be generated.]'
  '-ncommon[\[applies when gtype=dual\]]'
  '-dbglvl[selects the dbglvl.]'
  '-help[prints this message.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
