#compdef kbuildsycoca5
# Documentation: https://man.archlinux.org/search?q=kbuildsycoca5
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[displays this help.]'
  {-v,--version}'[displays version information.]'
  '--author[show author information.]'
  '--license[show license information.]'
  '--desktopfile[the base file name of the desktop entry for this application]:name:'
  '--nosignal[do not signal applications to update (deprecated]'
  '--noincremental[disable incremental update, re-read everything]'
  '--checkstamps[check file timestamps (deprecated, no longer]'
  '--nocheckfiles[disable checking files (deprecated, no longer]'
  '--global[create global database]'
  '--menutest[perform menu generation test run only]'
  '--track[track menu id for debug purposes]'
  '--testmode[switch QStandardPaths to test mode, for unit tests]'
  '*:filename:_files'
)

_arguments -s -S $arguments
