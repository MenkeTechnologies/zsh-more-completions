#compdef arp

# Zsh completion for arp (supports both Linux and macOS/BSD variants)

_arp() {
    local curcontext="$curcontext" state line ret=1

    if [[ "$OSTYPE" == darwin* || "$OSTYPE" == freebsd* || "$OSTYPE" == openbsd* ]]; then
        # macOS / BSD variant
        _arguments -s -S \
            '-a[display all current ARP entries]' \
            '-d[delete an entry for the specified host]:hostname:_hosts' \
            '-f[read entries from file]:filename:_files' \
            '-i[limit operation scope to specified interface]:interface:_net_interfaces' \
            '-l[show link-layer reachability information]' \
            '-n[show addresses numerically, do not resolve names]' \
            '-s[create an ARP entry]:hostname:_hosts' \
            '-S[create an ARP entry, deleting any existing entry first]:hostname:_hosts' \
            '-x[show extended link-layer reachability information]' \
            '*:hostname:_hosts' \
            && ret=0
    else
        # Linux variant
        _arguments -s -S \
            '(- *)'{-h,--help}'[display help information]' \
            {-V,--version}'[display version information]' \
            '-a[display entries in BSD style]' \
            '-e[display entries in Linux style (default)]' \
            '-H[specify hardware address type]:type:(ether arcnet pronet ax25 netrom)' \
            {-s,--set}'[create a new ARP entry]:hostname:_hosts' \
            {-d,--delete}'[delete a specified entry]:hostname:_hosts' \
            {-v,--verbose}'[be verbose]' \
            {-n,--numeric}'[do not resolve names]' \
            {-i,--device}'[specify network interface]:interface:_net_interfaces' \
            {-D,--use-device}'[read hardware address from given device]' \
            {-A,-p,--protocol}'[specify protocol family]:family:(inet inet6)' \
            {-f,--file}'[read new entries from file or from /etc/ethers]:filename:_files' \
            '*:hostname:_hosts' \
            && ret=0
    fi

    return ret
}

_arp "$@"
