#compdef modprobe

# zsh completions for 'modprobe'

_modprobe() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a modules
    _modprobe_modules() {
        if [[ -d /lib/modules/$(uname -r) ]]; then
            modules=(${${(f)"$(find /lib/modules/$(uname -r) -name '*.ko' -o -name '*.ko.zst' -o -name '*.ko.xz' -o -name '*.ko.gz' 2>/dev/null)"}:t:r:r})
            _describe -t modules 'kernel module' modules
        fi
    }

    _arguments -s -S \
        {-a,--all}'[insert all module names on the command line]' \
        {-b,--use-blacklist}'[apply blacklist commands to module names]' \
        {-C,--config}'[use specified config directory instead of default]:config directory:_directories' \
        {-c,--show-config}'[print out effective configuration and exit]' \
        {-d,--dirname}'[use directory as filesystem root for /lib/modules]:root directory:_directories' \
        {-D,--show-depends}'[list module dependencies in insmod format and exit]' \
        '--first-time[fail if module already inserted or removed]' \
        {-f,--force}'[force module insertion or removal (strip versioning)]' \
        '--force-vermagic[ignore module version magic string]' \
        '--force-modversion[ignore module symbol version hashes]' \
        {-i,--ignore-install}'[ignore install commands in configuration]' \
        {-i,--ignore-remove}'[ignore remove commands in configuration]' \
        {-n,--dry-run}'[do not execute operations, just print out]' \
        {-q,--quiet}'[suppress error messages for missing modules]' \
        {-R,--resolve-alias}'[display all module names matching an alias and exit]' \
        {-r,--remove}'[remove modules instead of inserting]' \
        '--remove-holders[also remove dependent modules (reverse dependencies)]' \
        {-S,--set-version}'[use specified kernel version instead of uname -r]:kernel version:' \
        {-s,--syslog}'[route error messages through syslog instead of stderr]' \
        '--show-modversions[display module versioning information and exit]' \
        '--show-exports[list symbols exported by the module and exit]' \
        '--dump-modversions[same as --show-modversions]' \
        {-v,--verbose}'[display detailed status messages]' \
        {-w,--wait}'[retry module removal if busy, up to timeout]:timeout (ms):' \
        {-V,--version}'[show program version]' \
        '(- *)'{-h,--help}'[show help message]' \
        '*:module:_modprobe_modules' && ret=0

    return ret
}

_modprobe "$@"
