#compdef devdump
# Documentation: https://man.archlinux.org/search?q=devdump
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-help,-h}'[print this help]'
  '-version[print version info and exit]'
  '-i[filename to read ISO-9660 image from]'
  '*:filename:_files'
)

_arguments -s -S $arguments
