#compdef expr

# Zsh completion for expr

_expr() {
    local -a arguments

    # Detect GNU vs BSD expr
    if expr --help &>/dev/null 2>&1; then
        # GNU coreutils expr
        arguments=(
            '(- *)--help[display help and exit]'
            '(- *)--version[output version information and exit]'
            '*:expression token: _alternative
                "operators:operator:(+ - \* / %% \: match substr index length)"
                "files:file:_files"'
        )
    else
        # BSD expr (macOS) - no long options, POSIX-compliant
        arguments=(
            '*:expression token: _alternative
                "operators:operator:(+ - \* / %% \: \| \& = \> \>= \< \<= \!=)"
                "files:file:_files"'
        )
    fi

    _arguments -s -S $arguments
}

_expr "$@"
