#compdef trdsql

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-id[input delimiter]:delimiter' \
  '-ih[input has header]' \
  '-is[skip header lines]:lines' \
  '-ir[input format]:format:(CSV LTSV JSON TBLN)' \
  '-od[output delimiter]:delimiter' \
  '-oh[output header]' \
  '-oaq[output all quoted]' \
  '-of[output format]:format:(CSV LTSV JSON JSONL TBLN RAW MD AT VF YAML)' \
  '-ilr[input limit rows]:rows' \
  '-out[output file]:file:_files' \
  '-a[analyze table structure]' \
  '-A[analyze full table structure]' \
  '-q[query]:query' \
  '*:file:_files' && ret=0
return ret
