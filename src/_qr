#compdef qr

local -a arguments

arguments=(
    '(- * :)--version[show programs version number and exit]'
    '(- * :)'{-h,--help}'[show this help message and exit]'
  '--factory[full python path to the image factory class]:class: '
  '--optimize[optimize the data by looking for chunks of at least this size]:size: '
  '--error-correction[the error correction level to use]:level:(L M Q H)'
  '*:filename:_files'
)

_arguments -s -S $arguments
