#compdef upterm

# Zsh completion for upterm - secure terminal sharing

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'host:host a terminal session'
      'session:manage sessions'
      'upgrade:upgrade upterm'
      'version:show version'
    )
    _describe -t commands 'upterm command' commands && ret=0
    ;;
  args)
    case ${line[1]} in
      host)
        _arguments -s \
          '--server[server URL]:url' \
          '--force-command[force command]:command' \
          '--private-key[private key file]:file:_files' \
          '--authorized-key[authorized key file]:file:_files' \
          '--known-hosts[known hosts file]:file:_files' \
          '--read-only[read-only session]' \
          '(-a --accept)'{-a,--accept}'[accept SSH public key]:public key' \
          '--github-user[authorized GitHub user]:user' \
          '*:command:_command_names' && ret=0
        ;;
      session)
        local -a session_cmds=(
          'list:list sessions'
          'info:show session info'
          'current:show current session'
        )
        _describe -t commands 'session command' session_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
