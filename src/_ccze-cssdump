#compdef ccze-cssdump
# Documentation: https://man.archlinux.org/search?q=ccze-cssdump
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-F,--rcfile}'[read configuration from FILE]:file:_files'
  {-l,--load}'[load default configuration files]'
  '--usage[give a short usage message]'
  {-V,--version}'[print program version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
