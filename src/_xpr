#compdef xpr

local -a arguments

arguments=(
  '-append[append output to file]:file:_files'
  '-noff[do not send formfeed]'
  '-output[specify output file]:file:_files'
  '-compact[use compact format]'
  '-device[specify printer device]:device:(ln03 la100 ps lw pp ljet pjet pjetxl)'
  '-dump[dump window image]'
  '-gamma[set gamma correction]:value:'
  '-gray[set number of gray levels]:levels:(2 3 4)'
  '-height[set output height]:inches:'
  '-width[set output width]:inches:'
  '-header[set page header]:string:'
  '-trailer[set page trailer]:string:'
  '-landscape[print in landscape orientation]'
  '-portrait[print in portrait orientation]'
  '-left[left margin]:inches:'
  '-top[top margin]:inches:'
  '-noposition[do not position output]'
  '-nosixopt[do not use sixel optimization]'
  '-plane[select bit plane]:plane:'
  '-psfig[produce PSfig-compatible output]'
  '-render[use rendering algorithm]:type:'
  '-report[report statistics]'
  '-rv[reverse video]'
  '-scale[set scale factor]:factor:'
  '-slide[produce output for slides]'
  '-split[split output into pages]:pages:'
  '*:filename:_files'
)

_arguments -s -S $arguments
