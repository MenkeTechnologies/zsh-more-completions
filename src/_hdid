#compdef hdid

local -a arguments

arguments=(
  '-readonly[force read-only]'
  '-kernel[attempt to attach the image in-kernel]'
  '-mount[mount volumes?]'
  '-nomount[same as -mount suppressed]'
  '-mountpoint[mount at <path> instead of inside /Volumes]'
  '-mountroot[mount volumes on <path>/<volname>]'
  '-mountrandom[mount volumes on <path>/<random>]'
  '-encryption[method>]'
  '-stdinpass[read passphrase from stdin]'
  '-agentpass[use agent passphrase if cached]'
  '-recover[recover bad image with bad blocks]'
  '-imagekey[<value>]'
  '-drivekey[<value>]'
  '-shadow[shadow option]'
  '-insecurehttp[allow insecure HTTP]'
  '-cacert[| dir>]'
  '-plist[output plist format]'
  '-puppetstrings[machine-readable progress]'
  '-verbose[verbose output]'
  '-debug[enable debug output]'
  '-quiet[suppress non-error output]'
  '*:filename:_files'
)

_arguments -s -S $arguments
