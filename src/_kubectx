#compdef kubectx

# Zsh completion for kubectx (switch Kubernetes contexts)

local curcontext="$curcontext" state line ret=1

local -a contexts
contexts=(${(f)"$(kubectl config get-contexts -o name 2>/dev/null)"})

local -a commands
commands=(
  '-c:show current context'
  '-d:delete context'
  '-h:show help'
  '--help:show help'
  '-u:unset current context'
  '--unset:unset current context'
  '-:switch to previous context'
)

_arguments -s -S \
  '(-c --current)'{-c,--current}'[Show current context name]' \
  '(-d --delete)'{-d,--delete}'[Delete the specified context]:context:($contexts)' \
  '(-h --help)'{-h,--help}'[Show help message]' \
  '(-u --unset)'{-u,--unset}'[Unset the current context]' \
  '1:context:->ctx' && ret=0

case "$state" in
  ctx)
    _describe -t contexts 'kubernetes context' contexts && ret=0
    ;;
esac

return ret
