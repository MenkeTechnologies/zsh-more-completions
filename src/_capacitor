#compdef cap

local curcontext="$curcontext" state line ret=1

local -a platforms=(android ios)

local -a commands=(
  'add:add a native platform to your app'
  'copy:copy web assets to native platforms'
  'init:initialize Capacitor in your app'
  'ls:list installed Capacitor plugins'
  'open:open the native IDE for a platform'
  'run:run a native platform on device or emulator'
  'sync:copy web assets and update native plugins'
  'update:update native platforms and plugins'
  'migrate:migrate to the latest major version'
  'doctor:check your Capacitor project for common issues'
  'telemetry:manage telemetry settings'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'cap command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (add)
        _arguments '1:platform:(android ios)' && ret=0
        ;;
      (copy|update)
        _arguments -s -S \
          '--deployment[use deployment builds]' \
          '--inline-source-maps[use inline source maps]' \
          '1:platform:(android ios)' && ret=0
        ;;
      (sync)
        _arguments -s -S \
          '--deployment[use deployment builds]' \
          '--inline-source-maps[use inline source maps]' \
          '1:platform:(android ios)' && ret=0
        ;;
      (open)
        _arguments '1:platform:(android ios)' && ret=0
        ;;
      (run)
        _arguments -s -S \
          '--list[list available targets]' \
          '--target=[specify target device/emulator]:target' \
          '--no-sync[do not sync before running]' \
          '--flavor=[specify flavor (Android)]:flavor' \
          '--scheme=[specify scheme (iOS)]:scheme' \
          '--configuration=[specify configuration]:config:(Debug Release)' \
          '--forwardPorts=[forward ports]:ports' \
          '1:platform:(android ios)' && ret=0
        ;;
      (init)
        _arguments -s -S \
          '--web-dir=[web assets directory]:directory:_directories' \
          '1:app name' \
          '2:app package id' && ret=0
        ;;
    esac
    ;;
esac

return ret
