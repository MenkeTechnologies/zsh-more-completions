#compdef csvstat

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-d+[delimiting character]:delimiter' \
  '--delimiter=[delimiting character]:delimiter' \
  '-t[specify that input is tab-delimited]' \
  '--tabs[specify that input is tab-delimited]' \
  '-q+[quoting character]:character' \
  '--quotechar=[quoting character]:character' \
  '-u+[double quote style]:style:(0 1 2 3)' \
  '--doublequote=[double quote style]:style:(0 1 2 3)' \
  '-H[no header row]' \
  '--no-header-row[no header row]' \
  '-K+[skip lines]:number' \
  '--skip-lines=[skip lines]:number' \
  '-e+[encoding]:encoding' \
  '--encoding=[encoding]:encoding' \
  '-S[ignore header case when sorting]' \
  '-l[insert line numbers]' \
  '--linenumbers[insert line numbers]' \
  '--zero[use zero-based line numbers]' \
  '--no-inference[disable type inference]' \
  '-c+[columns to examine]:columns' \
  '--columns=[columns to examine]:columns' \
  '-n[display column names and indices]' \
  '--names[display column names and indices]' \
  '--csv[output as CSV]' \
  '--json[output as JSON]' \
  '-y+[sniff limit]:limit' \
  '--snifflimit=[sniff limit]:limit' \
  '-I[disable type inference]' \
  '--type[only print data type]' \
  '--nulls[only print nulls]' \
  '--non-nulls[only print non-nulls]' \
  '--unique[only print unique values]' \
  '--min[only print min]' \
  '--max[only print max]' \
  '--sum[only print sum]' \
  '--mean[only print mean]' \
  '--median[only print median]' \
  '--stdev[only print standard deviation]' \
  '--len[only print max string length]' \
  '--max-precision[only print max precision]' \
  '--freq[only print frequent values]' \
  '-f+[frequency count]:count' \
  '--freq-count=[frequency count]:count' \
  '--count[only print row count]' \
  '*:CSV file:_files -g "*.csv"' && ret=0

return ret
