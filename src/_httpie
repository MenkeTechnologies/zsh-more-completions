#compdef http https

# Zsh completion for HTTPie (http/https commands)
# Supports HTTPie 3.x options

local curcontext="$curcontext" state line
typeset -A opt_args

local -a output_options auth_options network_options ssl_options troubleshooting_options

# Output processing options
output_options=(
  '--pretty[control output processing]:pretty style:(all colors format none)'
  {-s,--style}'[output coloring style]:style:(auto abap algol algol_nu arduino autumn borland bw colorful default dracula emacs friendly friendly_grayscale fruity github-dark gruvbox-dark gruvbox-light igor inkpot lilypond lovelace manni material monokai murphy native nord nord-darker one-dark paraiso-dark paraiso-light pastie perldoc pie pie-dark rainbow_dash rrt sas solarized solarized-dark solarized-light staroffice stata stata-dark stata-light tango trac vim vs xcode zenburn)'
  '--response-charset[override the response encoding for terminal display]:encoding:(ascii utf-8 utf-16 latin-1 iso-8859-1)'
  '--response-mime[override the response mime type for coloring and formatting]:mime type'
  '--format-options[comma-separated list of format tweaking options]:format options'
  {-p,--print}'[control which parts of the exchange are printed]:output string:(H B h b m HB Hh Hb hb HBhb)'
  {-v,--verbose}'[print the whole request as well as the response (shortcut for --print=HBhb)]'
  '--all[by default, only the final response is shown; print intermediary requests/responses as well]'
  {-P,--history-print}'[the same as --print but applies only to intermediary requests/responses]:output string:(H B h b m HB Hh Hb hb HBhb)'
  {-S,--stream}'[always stream the response body by line]'
  {-o,--output}'[save output to FILE instead of stdout]:output file:_files'
  {-d,--download}'[download the body to a file and print the response headers]'
  {-c,--continue}'[resume an interrupted download (requires --output)]'
  {-q,--quiet}'[do not print to stdout or stderr (use -qq to suppress warnings too)]'
)

# Content type options
local -a content_options
content_options=(
  {-j,--json}'[data items from the command line are serialized as a JSON object (default for non-GET)]'
  {-f,--form}'[data items from the command line are serialized as form fields]'
  '--multipart[similar to --form, but forces multipart/form-data even without file fields]'
  '--boundary[specify a custom boundary string for multipart form data]:boundary string'
  '--raw[pass raw request data without extra processing]:raw data'
  {-x,--compress}'[content compressed with deflate algorithm; auto set Content-Encoding header]'
  '--chunked[enable streaming via chunked transfer encoding]'
)

# Authentication options
auth_options=(
  {-a,--auth}'[credentials for server authentication]:USER\:PASS or TOKEN'
  {-A,--auth-type}'[the authentication mechanism to use]:auth type:(basic digest bearer)'
  '--auth-plugin[specify the auth plugin to use]:plugin name'
)

# Network options
network_options=(
  '--offline[build the request and print it but do not actually send it]'
  '--proxy[string mapping protocol to the URL of the proxy]:proxy (protocol\:url)'
  {-F,--follow}'[follow 30x Location redirects]'
  '--max-redirects[maximum number of redirects (default 30)]:number'
  '--max-headers[maximum number of response headers to read (default 256)]:number'
  '--timeout[connection timeout of the request in seconds (default 30)]:seconds'
  '--check-status[exit with error status code if HTTP status is one of 3xx, 4xx, or 5xx]'
  '--path-as-is[bypass dot segment URL squashing]'
  '--interface[local interface to use for outgoing connections]:interface'
)

# SSL options
ssl_options=(
  '--verify[SSL certificate verification; set to "no" to skip]:verify:(yes no)'
  '--ssl[desired version of the SSL/TLS protocol]:ssl version:(ssl2.3 tls1 tls1.1 tls1.2 tls1.3)'
  '--ciphers[string specifying the SSL/TLS ciphers to use]:ciphers'
  '--cert[client-side SSL certificate file path]:certificate file:_files'
  '--cert-key[private key file path for the client-side SSL certificate]:key file:_files'
  '--cert-key-pass[passphrase for the client-side SSL certificate private key]:passphrase'
)

# Session options
local -a session_options
session_options=(
  '--session[create, or reuse and update a named session]:session name'
  '--session-read-only[create or read a named session without updating it]:session name'
)

# Troubleshooting options
troubleshooting_options=(
  '(- *)'{-h,--help}'[show help message and exit]'
  '(- *)--version[show version and exit]'
  '--traceback[print the exception traceback should one occur]'
  '--debug[print internal debug information]'
  '--default-scheme[the default scheme to use if not specified in the URL]:scheme:(http https)'
  '--sorted[sort the output of headers and JSON dict keys in alphabetical order]'
  '--unsorted[disables --sorted]'
  {-I,--ignore-stdin}'[do not attempt to read stdin]'
)

_arguments -s -S -C \
  $content_options \
  $output_options \
  $auth_options \
  $network_options \
  $ssl_options \
  $session_options \
  $troubleshooting_options \
  '1:URL:_urls' \
  '*:request item (key=value, key\:=json, key==param, key\:file, @file)'
