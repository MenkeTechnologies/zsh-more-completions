#compdef qemu-ga

local -a arguments

arguments=(
  {-m,--method}'[transport method]:method:(unix-listen virtio-serial isa-serial)'
  {-p,--path}'[device/socket path]:path:_files'
  {-l,--logfile}'[set logfile path, logs to stderr by default]:logfile:_files'
  {-f,--pidfile}'[specify pidfile (default is /var/run/qemu-ga.pid)]:pidfile:_files'
  {-F,--fsfreeze-hook}'[enable fsfreeze hook]:script:_files'
  {-t,--statedir}'[specify dir to store state information]:dir:_directories'
  {-v,--verbose}'[log extra debugging information]'
  {-V,--version}'[print version information and exit]'
  {-d,--daemonize}'[become a daemon]'
  {-b,--blacklist}'[comma-separated list of RPCs to disable]:rpcs: '
  {-D,--dump-conf}'[dump a qemu-ga config file based on current config]'
  '(- * :)'{-h,--help}'[display this help and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
