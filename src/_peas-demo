#compdef peas-demo
# Documentation: https://man.archlinux.org/search?q=peas-demo
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  '--help-all[show all help options]'
  '--help-gtk[show GTK+ Options]'
  {-b,--run-from-build-dir}'[run from build directory]'
  '--display[X display to use]'
  '*:filename:_files'
)

_arguments -s -S $arguments
