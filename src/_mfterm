#compdef mfterm
# Documentation: https://man.archlinux.org/search?q=mfterm
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--help[(-h) Show this help message.]'
  '--version[(-v) Display version information.]'
  '--tag[(-t) Load a tag from the specified file.]'
  '--keys[(-k) Load keys from the specified file.]'
  '--dict[(-d) Load dictionary from the specified file.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
