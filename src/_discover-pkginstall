#compdef discover-pkginstall
# Documentation: https://man.archlinux.org/search?q=discover-pkginstall
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-l[list packages]'
  '-v[be verbose]'
  '-n[only echo commands, do not run them]'
  '*:filename:_files'
)

_arguments -s -S $arguments
