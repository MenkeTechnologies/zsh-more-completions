#compdef kondo
# Zsh completion for kondo - Clean unneeded build artifacts
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-a --all)'{-a,--all}'[clean all projects without confirmation]' \
  '(-o --older)'{-o,--older}'[only clean projects older than specified days]:days:' \
  '(-d --default)'{-d,--default}'[set default command]:command:' \
  '--ignored[include ignored files]' \
  '(-f --follow-symlinks)'{-f,--follow-symlinks}'[follow symbolic links]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(- *)--help[show help information]' \
  '(- *)--version[show version]' \
  '*:directory:_directories' && ret=0
return ret
