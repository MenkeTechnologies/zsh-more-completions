#compdef column

# Zsh completion for column
# Supports both BSD (macOS) column and util-linux column

_column() {
    local -a arguments

    # Detect whether we have the util-linux version (has --help) or BSD version
    if column --help &>/dev/null 2>&1; then
        # util-linux version with long options
        arguments=(
            {-c,--columns}'[output is formatted for a display columns wide]:columns:'
            {-e,--table-empty-lines}'[do not ignore empty lines]'
            '(-L --table-empty-lines-after-header)'{-L,--table-empty-lines-after-header}'[print empty line after header]'
            {-J,--json}'[use JSON output format for table output]'
            {-l,--table-columns}'[specify number of columns in the input]:num:'
            {-n,--table-name}'[specify table name for JSON output]:name:'
            {-o,--output-separator}'[table output column separator]:separator:'
            {-O,--table-order}'[specify column order for output]:columns:'
            {-d,--table-noheadings}'[do not print header]'
            {-E,--table-noextreme}'[specify columns where is possible to use multi-line cells]:columns:'
            {-H,--table-hide}'[do not print specified columns]:columns:'
            {-N,--table-columns}'[specify column names]:names:'
            {-R,--table-right}'[right align text in specified columns]:columns:'
            {-r,--tree}'[specify column to use tree-like output]:column:'
            {-i,--tree-id}'[specify column with line ID for tree output]:column:'
            {-p,--tree-parent}'[specify column with parent ID for tree output]:column:'
            {-s,--separator}'[specify possible table delimiters]:separators:'
            {-t,--table}'[create a table]'
            {-W,--table-wrap}'[specify columns where is possible to wrap text]:columns:'
            {-x,--fillrows}'[fill rows before filling columns]'
            '(- *)'{-h,--help}'[display help and exit]'
            '(- *)'{-V,--version}'[output version information and exit]'
            '*:file:_files'
        )
    else
        # BSD version (macOS) with short options only
        arguments=(
            '-c[output is formatted for a display columns wide]:columns:'
            '-s[specify a set of characters to delimit columns for -t]:separator:'
            '-t[determine number of columns and create a table]'
            '-x[fill columns before filling rows]'
            '*:file:_files'
        )
    fi

    _arguments -s $arguments
}

_column "$@"
