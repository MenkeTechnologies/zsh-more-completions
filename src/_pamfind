#compdef pamfind
# Documentation: https://man.archlinux.org/search?q=pamfind
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '--target[This specifies the tuple value to find.]'
    '--color[This is the color to find, assuming the image is a color visual image.]:color'
    '--machine[This makes the output more convenient for a machine to use, while less conv]'
    '*:filename:_files'
)
_arguments -s -S $arguments
