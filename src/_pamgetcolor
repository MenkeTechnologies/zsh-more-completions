#compdef pamgetcolor


local -a arguments

arguments=(
    '--format[This specifies the format in which to output the colors.]'
    '--radius[sets the radius of the regions.]'
    '--infile[This specifies the Netpbm file to analyze.]'
    '--linear[This tells pamgetcolor to work with the intensity-linear variation of Netpbm …]'
    '*:filename:_files'
)
_arguments -s -S $arguments
