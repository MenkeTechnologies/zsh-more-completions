#compdef neofetch

# Zsh completion for neofetch (system information tool)

_neofetch() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -s -S \
        '(- *)--help[show help message]' \
        '(- *)--version[show version]' \
        '--config=[specify a config file]:config file:_files' \
        '--print_config[print the default config file]' \
        '--stdout[turn off all colors and disables image backend]' \
        '--loop[redisplay every X seconds]' \
        '--json[display output in JSON format]' \
        '--off[disable all ASCII/image output]' \
        '--bold=[toggle bold text]:bold:(on off)' \
        '--underline=[toggle underline text]:underline:(on off)' \
        '--underline_char=[character to use for underline]:character:' \
        '--separator=[change default separator]:separator:' \
        '--color_blocks=[toggle color blocks]:color blocks:(on off)' \
        '--block_range=[range of colors to print]:range:' \
        '--block_width=[width of color blocks in spaces]:width:' \
        '--block_height=[height of color blocks]:height:' \
        '--bar_char=[characters to use for bar display]:characters:' \
        '--bar_border=[toggle bar border]:bar border:(on off)' \
        '--bar_length=[length of bars]:length:' \
        '--bar_colors=[colors for bars]:colors:' \
        '--cpu_brand=[toggle CPU brand in output]:cpu brand:(on off)' \
        '--cpu_cores=[type of CPU core count to display]:cores:(logical physical off)' \
        '--cpu_speed=[toggle CPU speed]:cpu speed:(on off)' \
        '--cpu_temp=[toggle CPU temperature]:cpu temp:(C F off)' \
        '--distro_shorthand=[shorten the output of distro]:shorthand:(on off tiny)' \
        '--gpu_brand=[toggle GPU brand]:gpu brand:(on off)' \
        '--gpu_type=[which GPU to display]:gpu type:(all dedicated integrated)' \
        '--kernel_shorthand=[shorten the output of kernel]:shorthand:(on off)' \
        '--memory_percent=[toggle memory percentage]:memory percent:(on off)' \
        '--memory_unit=[memory output unit]:unit:(kib mib gib)' \
        '--os_arch=[toggle OS architecture]:os arch:(on off)' \
        '--package_managers=[toggle package manager names]:package managers:(on off)' \
        '--shell_path=[toggle shell path]:shell path:(on off)' \
        '--shell_version=[toggle shell version]:shell version:(on off)' \
        '--speed_shorthand=[toggle speed shorthand]:shorthand:(on off)' \
        '--speed_type=[type of CPU speed to display]:speed type:(current min max bios scaling_current scaling_min scaling_max)' \
        '--uptime_shorthand=[shorten uptime output]:shorthand:(on off tiny)' \
        '--refresh_rate=[toggle refresh rate]:refresh rate:(on off)' \
        '--de_version=[toggle DE version]:de version:(on off)' \
        '--disk_show=[which disks to display]:disk:_files -/' \
        '--disk_subtitle=[type of disk subtitle]:subtitle:(mount name dir none)' \
        '--ip_host=[URL to query for public IP]:host:' \
        '--song_format=[format to display song information]:format:' \
        '--song_shorthand=[toggle song shorthand]:shorthand:(on off)' \
        '--gtk_shorthand=[toggle GTK shorthand]:shorthand:(on off)' \
        '--colors=[change text colors]:colors:' \
        '--ascii=[set when to display ASCII art]:ascii:' \
        '--ascii_distro=[which distro ASCII art to display]:distro:' \
        '--ascii_colors=[colors of ASCII art]:colors:' \
        '--ascii_bold=[toggle bold ASCII art]:bold:(on off)' \
        '--image=[image source]:image:(auto ascii wallpaper off)' \
        '--backend=[which image backend to use]:backend:(ascii caca catimg chafa jp2a kitty pixterm sixel tycat w3m iterm2 pot viu termpix ueberzug)' \
        '--source=[image source path]:source:_files' \
        '--gap=[gap between image and text]:gap:' \
        '--clean[remove all cached files]' \
        '*--disable=[disable an info line]:info line:' \
        '--title_fqdn=[toggle FQDN in title]:fqdn:(on off)'
}

_neofetch "$@"
