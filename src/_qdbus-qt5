#compdef qdbus-qt5
# Documentation: https://man.archlinux.org/search?q=qdbus-qt5
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--system[connect to the system bus]'
  '--bus[connect to a custom bus]'
  '--literal[print replies literally]'
  '*:filename:_files'
)

_arguments -s -S $arguments
