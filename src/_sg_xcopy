#compdef sg_xcopy

local -a arguments

arguments=(
  '--help[print out this usage message then exit]'
  '--on_dst[send XCOPY command to the output file/device]'
  '--on_src[send XCOPY command to the input file/device]'
  '--verbose[same action as verbose=1]'
  '--version[print version information then exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
