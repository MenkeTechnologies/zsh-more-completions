#compdef paperconfig
# Documentation: https://man.archlinux.org/search?q=paperconfig
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[print this help and exit]'
  {-p,--paper}'[specify the paper to use]'
  '--force[force paper configuration]'
  '*:filename:_files'
)

_arguments -s -S $arguments
