#compdef prettypacket
# Documentation: https://man.archlinux.org/search?q=prettypacket
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-x[print example packet, to see its structure]'
  '-d[dump example packet as hexstring]'
  '-h[this help screen]'
  '*:filename:_files'
)

_arguments -s -S $arguments
