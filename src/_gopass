#compdef gopass

# Zsh completion for gopass - the slightly more awesome standard unix password manager

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'ag:Search for secrets matching a query'
  'audit:Scan the store for weak, old or compromised secrets'
  'cat:Print the raw content of a secret'
  'clone:Clone a store from a git repository'
  'config:Edit configuration'
  'copy:Copy secrets from one location to another'
  'create:Create a new secret'
  'delete:Remove one or many secrets from the store'
  'edit:Edit an existing secret'
  'env:Run a subprocess with the selected secret exported as env vars'
  'find:Search for secrets files containing the search string'
  'fsck:Check store integrity'
  'generate:Generate a new password'
  'git:Run any git command inside a password store'
  'grep:Search for secrets content'
  'history:Show the history of a secret'
  'init:Initialize new password storage'
  'insert:Insert a new secret'
  'link:Create a symlink in the store'
  'list:List existing secrets'
  'merge:Merge multiple stores into one'
  'mounts:Mount and unmount sub-stores'
  'move:Move a secret from one location to another'
  'otp:Display and generate OTP codes'
  'process:Process a template'
  'recipients:List and edit recipient keys'
  'setup:Setup a new store'
  'show:Display the contents of a secret'
  'sum:Compute checksum of a secret'
  'sync:Sync all local stores with their remotes'
  'templates:List templates'
  'unclip:Clear the clipboard'
  'update:Check for updates'
  'version:Display version'
  'help:Show help'
)

_arguments -s -S \
  '--yes[automatically answer all questions with yes]' \
  '--clip[copy result to clipboard]' \
  '-c[copy result to clipboard]' \
  '--password[only show the password]' \
  '--qr[print QR code to terminal]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      show|cat|edit|delete|copy|move|history|otp)
        _arguments \
          '-c[copy result to clipboard]' \
          '--clip[copy result to clipboard]' \
          '--qr[print QR code]' \
          '--force[overwrite existing entry]' \
          '-f[overwrite existing entry]' \
          '*:secret:' && ret=0
        ;;
      generate)
        _arguments \
          '-c[copy result to clipboard]' \
          '--clip[copy result to clipboard]' \
          '--symbols[include symbols in password]' \
          '--no-symbols[exclude symbols from password]' \
          '--memorable[generate memorable password]' \
          '--xkcd[generate XKCD-style password]' \
          '--strict[require strict character class rules]' \
          '-f[force overwrite of existing secret]' \
          '--force[force overwrite of existing secret]' \
          ':secret:' \
          ':length:' && ret=0
        ;;
      recipients)
        local -a recipients_cmds=(
          'add:Add a new recipient'
          'remove:Remove a recipient'
          'print:Print recipients'
          'update:Re-encrypt secrets for updated recipients list'
        )
        _describe -t recipients_cmds 'recipients command' recipients_cmds && ret=0
        ;;
      mounts)
        local -a mounts_cmds=(
          'add:Add a new mounted store'
          'remove:Remove a mounted store'
          'list:Print all mounted stores'
        )
        _describe -t mounts_cmds 'mounts command' mounts_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
