#compdef spix
# Documentation: https://man.archlinux.org/search?q=spix
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-n,--dry-run}'[print the commands that would be executed, but do not execute]'
  '--version[show version and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
