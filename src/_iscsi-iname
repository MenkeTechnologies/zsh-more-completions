#compdef iscsi-iname
# Documentation: https://man.archlinux.org/search?q=iscsi-iname
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-p[/--prefix <prefix>          -- set IQN prefix \[iqn.1994-05.com.redhat\]]'
  '-g[/--generate-iname-prefix    -- generate the InitiatorName= prefix]'
  '*:filename:_files'
)

_arguments -s -S $arguments
