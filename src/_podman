          '--retry-delay[delay between retries]:duration' \
          '--rm[remove intermediate containers]' \
          '--runtime[OCI runtime]:runtime:_files' \
          '--secret[expose secret]:id=src' \
          '--security-opt[security options]:option' \
          '--shm-size[size of /dev/shm]:size' \
          '--sign-by[GPG key to sign]:key' \
          '--skip-unused-stages[skip unused stages]' \
          '--squash[squash layers]' \
          '--squash-all[squash all layers]' \
          '--ssh[SSH agent socket or keys]:ssh' \
          '(-t --tag)'{-t,--tag}'[tag the image]:tag' \
          '--target[target build stage]:stage' \
          '--timestamp[set created timestamp]:timestamp' \
          '--tls-verify[require HTTPS and verify certs]' \
          '--ulimit[ulimit options]:ulimit' \
          '--unsetenv[unset env vars]:var' \
          '--userns[user namespace mode]:mode' \
          '--uts[UTS namespace]:ns' \
          '(-v --volume)'{-v,--volume}'[bind mount a volume]:volume:_directories' \
          '1:context:_directories' && ret=0
        ;;
      logs)
        _arguments -s -S \
          '--color[output with color]' \
          '(-f --follow)'{-f,--follow}'[follow log output]' \
          '(-l --latest)'{-l,--latest}'[act on latest container]' \
          '(-n --names)'{-n,--names}'[output the container name in the log]' \
          '--since[show logs since timestamp]:timestamp' \
          '(-t --timestamps)'{-t,--timestamps}'[show timestamps]' \
          '--tail[number of lines to show from end]:lines' \
          '--until[show logs until timestamp]:timestamp' \
          '*:container:' && ret=0
        ;;
      stop)
        _arguments -s -S \
          '(-a --all)'{-a,--all}'[stop all running containers]' \
          '--cidfile[read container ID from file]:file:_files' \
          '(-l --latest)'{-l,--latest}'[act on latest container]' \
          '(-t --time)'{-t,--time}'[seconds to wait before killing]:seconds' \
          '*:container:' && ret=0
        ;;
      rm)
        _arguments -s -S \
          '(-a --all)'{-a,--all}'[remove all containers]' \
          '--cidfile[read container ID from file]:file:_files' \
          '--depend[remove dependencies]' \
          '(-f --force)'{-f,--force}'[force removal]' \
          '(-l --latest)'{-l,--latest}'[act on latest container]' \
          '(-t --time)'{-t,--time}'[seconds to wait before killing]:seconds' \
          '(-v --volumes)'{-v,--volumes}'[remove anonymous volumes]' \
          '*:container:' && ret=0
        ;;
      rmi)
        _arguments -s -S \
          '(-a --all)'{-a,--all}'[remove all images]' \
          '(-f --force)'{-f,--force}'[force removal]' \
          '--no-prune[do not remove untagged parents]' \
          '*:image:' && ret=0
        ;;
      inspect)
        _arguments -s -S \
          '(-f --format)'{-f,--format}'[Go template format]:format' \
          '(-l --latest)'{-l,--latest}'[act on latest container]' \
          '(-s --size)'{-s,--size}'[display total file sizes]' \
          '--type[type of object]:type:(container image volume network pod)' \
          '*:object:' && ret=0
        ;;
      login)
        _arguments -s -S \
          '--authfile[authentication file]:file:_files' \
          '--cert-dir[certificates directory]:dir:_directories' \
          '--get-login[print current login user]' \
          '(-p --password)'{-p,--password}'[password]:password' \
          '--password-stdin[read password from stdin]' \
          '--tls-verify[require HTTPS and verify certs]' \
          '(-u --username)'{-u,--username}'[username]:username' \
          '1:registry:' && ret=0
        ;;
      logout)
        _arguments -s -S \
          '(-a --all)'{-a,--all}'[remove all authentications]' \
          '--authfile[authentication file]:file:_files' \
          '1:registry:' && ret=0
        ;;
      search)
        _arguments -s -S \
          '--authfile[authentication file]:file:_files' \
          '--compatible[list is compatible with docker search]' \
          '(-f --filter)'{-f,--filter}'[filter output]:filter' \
          '--format[Go template format]:format' \
          '--limit[limit number of results]:limit' \
          '--list-tags[list tags for the image]' \
          '--no-trunc[do not truncate output]' \
          '--tls-verify[require HTTPS and verify certs]' \
          '1:term:' && ret=0
        ;;
      compose)
        local -a compose_commands=(
          'down:stop and remove containers'
          'up:create and start containers'
        )
        _describe -t compose-commands 'compose command' compose_commands
        ;;
      generate)
        local -a generate_commands=(
          'kube:generate Kubernetes YAML from containers/pods'
          'spec:generate a specgen JSON struct'
          'systemd:generate systemd unit files'
        )
        _describe -t generate-commands 'generate command' generate_commands
        ;;
      kube|play)
        local -a kube_commands=(
          'apply:apply Kubernetes YAML to containers'
          'down:remove resources from YAML'
          'generate:generate Kubernetes YAML from containers'
          'play:create containers from Kubernetes YAML'
        )
        _describe -t kube-commands 'kube command' kube_commands
        ;;
      manifest)
        local -a manifest_commands=(
          'add:add images to a manifest list'
          'annotate:add or update information'
          'create:create a manifest list'
          'exists:check if a manifest list exists'
          'inspect:display a manifest list'
          'push:push a manifest list'
          'rm:remove manifest lists'
          'remove:remove an entry from a manifest list'
        )
        _describe -t manifest-commands 'manifest command' manifest_commands
        ;;
    esac
    ;;
esac

return ret
