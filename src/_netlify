#compdef netlify ntl

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:build on your local machine'
  'completion:generate shell completion script'
  'deploy:create a new deploy from the contents of a folder'
  'dev:local dev server'
  'env:control environment variables'
  'functions:manage netlify functions'
  'init:configure continuous deployment for a new or existing site'
  'integration:manage Netlify integrations'
  'link:link a local repo or project folder to an existing site'
  'login:login to your Netlify account'
  'logs:stream logs'
  'open:open settings for the site linked to the current folder'
  'recipes:create and modify files in a project using pre-defined recipes'
  'serve:build the site for production and serve locally'
  'sites:handle various site operations'
  'status:print status info'
  'switch:switch your active Netlify account'
  'unlink:unlink a local folder from a Netlify site'
  'watch:watch for site deploy to finish'
  'blobs:manage Netlify Blobs'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--debug[print debugging information]' \
  '--httpProxy=[proxy server address]:proxy url' \
  '--httpProxyCertificateFilename=[certificate file to use with proxy]:cert file:_files' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'netlify command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (deploy)
        _arguments -s -S \
          '(-d --dir)'{-d,--dir}'=[specify a folder to deploy]:directory:_directories' \
          '(-f --functions)'{-f,--functions}'=[specify a functions folder to deploy]:directory:_directories' \
          '(-p --prod)'{-p,--prod}'[deploy to production]' \
          '--alias=[specifies the alias for deployment]:alias' \
          '--branch=[serves the same functionality as --alias]:branch' \
          '(-o --open)'{-o,--open}'[open site after deploy]' \
          '(-m --message)'{-m,--message}'=[a short message to include in the deploy log]:message' \
          '(-s --site)'{-s,--site}'=[a site name or ID]:site' \
          '--json[output as JSON]' \
          '--timeout=[timeout to wait for deployment]:timeout' \
          '--trigger[trigger a new build of your site]' \
          '--build[run build command before deploying]' \
          '--context=[build context]:context:(production deploy-preview branch-deploy dev)' \
          '--skip-functions-cache[ignore any functions cache]' && ret=0
        ;;
      (dev)
        _arguments -s -S \
          '(-c --command)'{-c,--command}'=[command to run]:command' \
          '(-p --port)'{-p,--port}'=[port of netlify dev]:port' \
          '--targetPort=[port of target dev server]:port' \
          '--framework=[framework to use]:framework' \
          '(-d --dir)'{-d,--dir}'=[dir with static files]:directory:_directories' \
          '(-f --functions)'{-f,--functions}'=[specify a functions folder]:directory:_directories' \
          '(-o --offline)'{-o,--offline}'[disables any features requiring network access]' \
          '(-l --live)'{-l,--live}'[start a public live session]' \
          '--no-open[do not open browser]' \
          '(-e --edgeInspect)'{-e,--edgeInspect}'=[enable Edge Functions debugging]:address' \
          '--geo=[force geo mock]:mode:(mock cache update)' && ret=0
        ;;
      (env)
        local -a env_cmds=(
          'get:get value of an env variable'
          'import:import and set env variables from .env file'
          'list:list environment variables'
          'set:set value of env variable'
          'unset:unset an environment variable'
          'clone:clone env variables from one site to another'
        )
        _arguments \
          '1:subcommand:_describe -t env-commands "env command" env_cmds' \
          '*:args' && ret=0
        ;;
      (functions)
        local -a func_cmds=(
          'build:build functions locally'
          'create:create a new function'
          'invoke:trigger a function while in netlify dev'
          'list:list functions'
          'serve:serve functions locally'
        )
        _arguments \
          '1:subcommand:_describe -t func-commands "functions command" func_cmds' \
          '*:args' && ret=0
        ;;
      (sites)
        local -a sites_cmds=(
          'create:create an empty site'
          'create-template:create a site from a starter template'
          'delete:delete a site'
          'list:list all sites'
        )
        _arguments \
          '1:subcommand:_describe -t sites-commands "sites command" sites_cmds' \
          '*:args' && ret=0
        ;;
      (open)
        local -a open_cmds=(
          'admin:opens the admin UI for the site'
          'site:opens the site URL in browser'
        )
        _arguments \
          '1:subcommand:_describe -t open-commands "open command" open_cmds' && ret=0
        ;;
      (logs)
        local -a logs_cmds=(
          'deploy:stream deploy logs'
          'function:stream function logs'
        )
        _arguments \
          '1:subcommand:_describe -t logs-commands "logs command" logs_cmds' && ret=0
        ;;
    esac
    ;;
esac

return ret
