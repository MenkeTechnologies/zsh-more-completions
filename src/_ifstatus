#compdef ifplugstatus ifstatus
# Documentation: https://man.archlinux.org/search?q=ifplugstatus
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    {-a,--auto}'[Enable interface automatically before querying (default: off).]'
    {-h,--help}'[Show help.]'
    {-q,--quiet}'[Decrease verbosity by one.]'
    {-v,--verbose}'[Increase verbosity by one. See option -q.]'
    {-V,--version}'[show version]'
    '*:filename:_files'
)
_arguments -s -S $arguments
