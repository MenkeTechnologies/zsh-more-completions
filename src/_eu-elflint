#compdef eu-elflint
# Documentation: https://man.archlinux.org/search?q=eu-elflint
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-d,--debuginfo}'[binary is a separate debuginfo file]'
  '--gnu-ld[binary has been created with GNU ld and is]'
  {-q,--quiet}'[do not print anything if successful]'
  '--strict[be extremely strict, flag level 2 features.]'
  '--usage[give a short usage message]'
  {-V,--version}'[print program version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
