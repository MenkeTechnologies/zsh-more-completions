#compdef exiftool

# Zsh completion for ExifTool (https://exiftool.org/)

_exiftool() {
    local -a arguments

    arguments=(
        # Input/output options
        '-tagsFromFile[copy tags from specified file]:source file:_files'
        {-b,--binary}'[output data in binary format]'
        {-c,--coordFormat}'[set format for GPS coordinates]:format string:'
        '--charset[specify encoding for tag values]:charset:(UTF8 Latin Latin2 Cyrillic Greek Turkish Hebrew Arabic Windows1252 MacRoman ShiftJIS)'
        '--config[specify configuration file]:config file:_files'
        '-csv[export/import tags in CSV format]'
        '--csvDelim[set CSV delimiter]:delimiter:'
        {-d,--dateFormat}'[set format for date/time values]:format string:'
        {-D,--decimal}'[show tag ID numbers in decimal]'
        '-e[do not generate composite tags (same as --composite)]'
        '--composite[generate composite tags (default)]'
        '-E[escape HTML entities in output]'
        '-ex[escape XML entities in output]'
        '-ec[escape C-style characters in output]'
        '-ee[extract information from embedded files]'
        '-ee2[extract information from embedded files including metadata]'
        '-ee3[extract information from embedded files including all data]'
        '*-ext[process files with specified extension]:extension:'
        '*--ext[exclude files with specified extension]:extension:'
        {-f,--forcePrint}'[force printing of all specified tags]'
        {-F,--fixBase}'[fix base offset for maker notes]'
        '--fast[increase speed for extracting information]'
        '--fast2[faster extraction, may miss some data]'
        '--fast3[even faster, skip all processing except reading]'
        '--fast4[fastest, skip all extra processing]'
        '--fast5[avoid extracting EXIF MakerNote information]'
        {-g,--groupHeadings}'[organize output by tag group]:group families (0-7):'
        {-G,--groupNames}'[print group name for each tag]:group families (0-7):'
        '-geotag[set GPS values from GPS track log]:track log file:_files'
        {-h,--htmlFormat}'[format output as HTML]'
        {-H,--hex}'[show tag ID numbers in hexadecimal]'
        '-htmlDump[generate HTML hex dump of JPEG image]:offset:'
        '*-if[conditionally process files]:condition expression:'
        '-if0[same as -if but no warning for false condition]:condition expression:'
        {-j,--json}'[export/import tags in JSON format]'
        '-json[export/import tags in JSON format]'
        {-k,--pause}'[pause before terminating]'
        {-l,--long}'[use long 2-line output format]'
        {-L,--latin}'[use Windows Latin1 encoding]'
        '--lang[set language for tag descriptions]:language:'
        '--listItem[extract specific item from a list]:index:'
        {-m,--ignoreMinorErrors}'[ignore minor errors and warnings]'
        {-n,--printConv}'[disable print conversion (read/write numerical values)]'
        {-o,--out}'[set output file or directory]:output:_files'
        '--overwrite_original[overwrite original file when writing]'
        '--overwrite_original_in_place[overwrite original file in place (preserving inode)]'
        {-p,--printFormat}'[set output format]:format string:'
        {-P,--preserve}'[preserve file modification date/time]'
        '--password[password for processing protected files]:password:'
        '--progress[show file progress count]'
        '--progress=[show file progress with format]:format:'
        {-q,--quiet}'[quiet processing (-q -q for very quiet)]'
        {-r,--recurse}'[recursively process subdirectories]'
        '-r.[recursively process subdirectories, following symlinks]'
        {-s,--short}'[short output format (-s -s for very short, -s -s -s for tag names only)]'
        {-S,--veryShort}'[very short output format (tag names on same line)]'
        '--sep[set separator for list items]:separator:'
        '--sort[sort output alphabetically]'
        '-struct[enable structured output of XMP lists and structures]'
        '--struct[disable structured output]'
        {-t,--tab}'[output in tab-delimited format]'
        {-T,--table}'[output in table format]'
        {-u,--unknown}'[extract unknown tags]'
        {-U,--unknown2}'[extract unknown tags and binary data]'
        {-v,--verbose}'[verbose messages (-v0 to -v5 for varying levels)]'
        {-w,--textOut}'[set output file name format]:format:'
        '-W[create output file for each tag]:format:'
        '-W![same as -W but overwrite existing files]:format:'
        '-W+[same as -W but append to existing files]:format:'
        {-wm,--writeMode}'[set write mode]:mode:(w c g)'
        '*-x[exclude specified tag]:tag name:'
        '-X[output in RDF/XML format]'
        {-z,--zip}'[read/write compressed information]'
        '-@[read file list or command-line arguments from file]:arg file:_files'

        # Processing control
        '--api[set ExifTool API option]:option=value:'
        '--common_args[define arguments common to all commands]'
        '--echo[echo text to stdout]:text:'
        '--echo1[echo text to stdout]:text:'
        '--echo2[echo text to stderr]:text:'
        '--echo3[echo text to file set by -w]:text:'
        '--echo4[echo text to file set by -W]:text:'
        '--efile[save names of files with errors]:error file:_files'
        '--efile![same as --efile but overwrite existing file]:error file:_files'
        '--efile+[same as --efile but append to existing file]:error file:_files'
        '--execute[execute command and start a new one]'
        '--execute+[execute and add next command number to output]'

        # Tag operations
        '--globalTimeShift[shift all date/time values]:shift amount:'
        '--restore_original[restore original file from backup _original]'
        '--delete_original[delete backup _original files]'
        '--delete_original![delete backup _original files without prompting]'
        '--stay_open[keep reading from -@ argfile]:bool:(True False 1 0)'
        '--userParam[set user-defined parameter]:param=value:'
        '--useMWG[use MWG composite tags for reading/writing]'

        # List options
        '-list[list all supported tags]'
        '-listw[list all writable tags]'
        '-listf[list supported file extensions]'
        '-listr[list recognized file extensions]'
        '-listwf[list writable file extensions]'
        '-listd[list deletable tag groups]'
        '-listg[list all tag groups]:family (0-7):'
        '-listx[list database in XML format]'

        # Version/help
        '(- *)--ver[display ExifTool version]'
        '(- *)'{-v,--version}'[display ExifTool version]'

        # Files
        '*:file:_files'
    )

    _arguments -s -S $arguments
}

_exiftool "$@"
