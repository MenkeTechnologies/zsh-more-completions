#compdef whois

# Zsh completion for whois
# Supports both BSD (macOS) whois and GNU/Debian whois

_whois() {
    local -a arguments

    if whois --help &>/dev/null 2>&1; then
        # GNU/Debian whois with long options
        arguments=(
            {-h,--host}'[connect to specified whois server]:host:_hosts'
            {-p,--port}'[connect to specified port]:port:'
            '-H[hide legal disclaimers]'
            '--verbose[explain what is being done]'
            '(- *)--help[display help and exit]'
            '(- *)--version[output version information and exit]'
            '-l[find the one level less specific match]'
            '-L[find all levels less specific matches]'
            '-m[find all one level more specific matches]'
            '-M[find all levels of more specific matches]'
            '-c[find the smallest match containing a mnt-irt attribute]'
            '-x[exact match]'
            '-b[return brief IP address ranges with abuse contact]'
            '-B[turn off object filtering (show email addresses)]'
            '-G[turn off grouping of associated objects]'
            '-d[return DNS reverse delegation objects too]'
            '-i[do an inverse look-up for specified attributes]:attribute:'
            '-T[only look for objects of specified type]:type:'
            '-K[only primary keys are returned]'
            '-r[turn off recursive look-ups for contact information]'
            '-R[force to show local copy of the domain object]'
            '-a[also search all the mirrored databases]'
            '-s[search the database mirrored from source]:source:'
            '-g[find updates from source from serial first to last]:source\:first-last:'
            '-t[request template for object of specified type]:type:'
            '-v[request verbose template for object of specified type]:type:'
            '-q[query specified server info]:info:(version sources)'
            '*:name:'
        )
    else
        # BSD whois (macOS)
        arguments=(
            '-a[use the American Registry for Internet Numbers (ARIN) database]'
            '-A[use the Asia/Pacific Network Information Center (APNIC) database]'
            '-b[use the Network Abuse Clearinghouse database]'
            '-c[equivalent to -h TLD.whois-servers.net]:TLD:'
            '-f[use the African Network Information Centre (AfriNIC) database]'
            '-g[use the US non-military federal government database]'
            '-h[use the specified host instead of the default]:host:_hosts'
            '-i[use the traditional Network Information Center (InterNIC) database]'
            '-I[use the Internet Assigned Numbers Authority (IANA) database]'
            '-k[use the National Internet Development Agency of Korea (KRNIC) database]'
            '-l[use the Latin American and Caribbean (LACNIC) database]'
            '-m[use the Route Arbiter Database (RADB)]'
            '-p[connect to the whois server on specified port]:port:'
            '-P[use the PeeringDB database of AS numbers]'
            '-Q[quick lookup; do not follow referrals to other whois servers]'
            '-r[use the RIPE database]'
            '-R[do a recursive lookup; follow referrals to other whois servers]'
            '-S[send query verbatim and print output verbatim]'
            '*:name:'
        )
    fi

    _arguments -s $arguments
}

_whois "$@"
