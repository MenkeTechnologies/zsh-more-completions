#compdef pkla-check-authorization
# Documentation: https://man.archlinux.org/search?q=pkla-check-authorization
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  {-p,--paths}'[use authorization top directories in ;-separated PATH]'
  '*:filename:_files'
)

_arguments -s -S $arguments
