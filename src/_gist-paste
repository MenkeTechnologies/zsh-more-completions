#compdef gist-paste

local -a arguments

arguments=(
  '--login[authenticate gist on this computer.]'
  {-f,--filename}'[set the filename and syntax type]:filename:'
  {-t,--type}'[sets the file extension and syntax type.]'
  {-p,--private}'[makes your gist private.]'
  '--no-private[make gist public]'
  {-d,--description}'[adds a description to your gist.]'
  {-s,--shorten}'[shorten the gist URL using git.io.]'
  {-u,--update}'[update an existing gist]:url-or-id:'
  {-a,--anonymous}'[create an anonymous gist.]'
  {-c,--copy}'[copy the resulting URL to the clipboard]'
  {-e,--embed}'[copy the embed code for the gist to the clipboard]'
  {-o,--open}'[open the resulting URL in a browser]'
  '--no-open[do not open the gist in a browser]'
  {-P,--paste}'[paste from the clipboard to gist]'
  {-R,--raw}'[display raw URL of the new gist]'
  {-l,--list}'[list all gists for user]'
  {-r,--read}'[read a gist and print out the contents]:filename:'
  '--delete[delete a gist]:url-or-id:'
  '(- * :)'{-h,--help}'[show this message.]'
  {-v,--version}'[print the version.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
