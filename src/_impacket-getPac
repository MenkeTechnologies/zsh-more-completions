#compdef impacket-getPac
# Documentation: https://man.archlinux.org/search?q=impacket-getPac
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[show this help message and exit]'
  '-targetUser[the target user to retrieve the PAC of]'
  '-debug[turn DEBUG output ON]'
  '-hashes[NTLM hashes, format is LMHASH:NTHASH]'
  '*:filename:_files'
)

_arguments -s -S $arguments
