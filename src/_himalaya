#compdef himalaya

# Zsh completion for himalaya - CLI email client

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'envelope:Manage envelopes'
  'flag:Manage flags'
  'message:Manage messages'
  'attachment:Manage attachments'
  'folder:Manage folders'
  'account:Manage accounts'
  'completion:Print shell completion script'
  'man:Print manual page'
  'help:Print help'
)

_arguments -s -S \
  '(-c --config)'{-c,--config}'[Override default configuration file path]:file:_files' \
  '(-a --account)'{-a,--account}'[Override default account]:account:' \
  '(-f --folder)'{-f,--folder}'[Override default folder]:folder:' \
  '--log[Minimum log level]:level:(off error warn info debug trace)' \
  '--no-keyring[Disable global keyring]' \
  '(-h --help)'{-h,--help}'[Print help]' \
  '(-V --version)'{-V,--version}'[Print version]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      envelope)
        local -a envelope_cmds=(
          'list:List envelopes'
          'watch:Watch envelopes'
          'get:Get an envelope'
        )
        _describe -t envelope_cmds 'envelope command' envelope_cmds && ret=0
        ;;
      message)
        local -a message_cmds=(
          'read:Read a message'
          'write:Write a new message'
          'reply:Reply to a message'
          'forward:Forward a message'
          'copy:Copy a message to a folder'
          'move:Move a message to a folder'
          'delete:Delete messages'
          'save:Save a raw message to a folder'
          'send:Send a raw message'
        )
        _describe -t message_cmds 'message command' message_cmds && ret=0
        ;;
      folder)
        local -a folder_cmds=(
          'list:List folders'
          'create:Create a folder'
          'delete:Delete a folder'
          'expunge:Expunge a folder'
          'purge:Purge a folder'
        )
        _describe -t folder_cmds 'folder command' folder_cmds && ret=0
        ;;
      account)
        local -a account_cmds=(
          'list:List accounts'
          'configure:Configure an account'
          'check-up:Check account up'
          'sync:Sync an account'
          'default:Set default account'
        )
        _describe -t account_cmds 'account command' account_cmds && ret=0
        ;;
      completion)
        _arguments ':shell:(bash elvish fish nushell powershell zsh)' && ret=0
        ;;
    esac
    ;;
esac

return ret
