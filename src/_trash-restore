#compdef trash-restore
# Zsh completion for trash-restore (trash-cli)
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '--trash-dir[Specify trash directory]:trash directory:_directories' \
  '--sort[Sort output]:sort order:(date path none)' \
  '(- *)--help[Show help message]' \
  '(- *)--version[Show version]' \
  '*:path pattern:_files' && ret=0
return ret
