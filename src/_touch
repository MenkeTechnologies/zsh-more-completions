#compdef touch

# Completion for touch - change file access and modification times
# Supports both BSD (macOS) and GNU coreutils options

local -a arguments

arguments=(
  '-A[adjust access and modification timestamps by specified value]:adjustment ([[-][[hh]mm]SS])'
  '-a[change only the access time]'
  {-c,--no-create}'[do not create any files]'
  {-d,--date}'[parse STRING and use it instead of current time]:date string'
  '-f[(ignored)]'
  {-h,--no-dereference}'[affect symbolic link itself instead of referenced file]'
  '-m[change only the modification time]'
  {-r,--reference}'[use specified file'\''s times instead of current time]:reference file:_files'
  '-t[use specified time instead of current time]:time ([[CC]YY]MMDDhhmm[.ss])'
  '--time=[specify which time to change]:time type:(access atime use modify mtime)'
  '--help[display help and exit]'
  '--version[output version information and exit]'
  '*:file:_files'
)

_arguments -s -S $arguments
