#compdef openssl2john
# Documentation: https://man.archlinux.org/search?q=openssl2john
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[show this help message and exit]'
  '-p[specify password]'
  '-a[specify algorithm]'
  '-c[specify cipher]'
  '-m[specify mode]'
  '*:filename:_files'
)

_arguments -s -S $arguments
