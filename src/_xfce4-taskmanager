#compdef xfce4-taskmanager

local -a arguments

arguments=(
  {-h,--help}'[show help options]'
  '--help-all[show all help options]'
  '--help-gtk[show GTK+ Options]'
  '--start-hidden[dont open a task manager window]'
  '--display[X display to use]'
  '*:filename:_files'
)

_arguments -s -S $arguments
