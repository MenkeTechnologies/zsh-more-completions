#compdef trietool-0.2
# Documentation: https://man.archlinux.org/search?q=trietool-0.2
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-p,--path}'[set trie directory to DIR \[default=.\]]'
  '(- * :)'{-h,--help}'[display this help and exit]'
  {-V,--version}'[output version information and exit]'
  {-e,--encoding}'[specify character encoding of LISTFILE]'
  {-e,--encoding}'[specify character encoding of LISTFILE]'
  '*:filename:_files'
)

_arguments -s -S $arguments
