#compdef kwalletd5
# Documentation: https://man.archlinux.org/search?q=kwalletd5
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[displays this help.]'
  {-v,--version}'[displays version information.]'
  '--author[show author information.]'
  '--license[show license information.]'
  '--desktopfile[the base file name of the desktop entry for this application]:name:'
  '*:filename:_files'
)

_arguments -s -S $arguments
