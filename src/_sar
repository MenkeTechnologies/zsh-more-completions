#compdef sar

local -a arguments

arguments=(
  '-A[equivalent to -bBdFHISvwWy -m ALL -n ALL -q ALL -r ALL -u ALL]'
  '-B[report paging statistics]'
  '-b[report I/O and transfer rate statistics]'
  '-C[display comments inserted by sadc]'
  '-D[use saYYYYMMDD format for daily data files]'
  '-d[report activity for each block device]'
  '-e[set ending time of report]:end time (hh\:mm[\:ss] or seconds):'
  '-F[display statistics for mounted filesystems]: :((MOUNT))'
  '-f[extract records from specified file]:data file:_files'
  '-H[report hugepages utilization statistics]'
  '-h[display in human-readable format (equivalent to --pretty --human)]'
  '-I[report interrupt statistics]: :(SUM ALL)'
  '-i[select data records at seconds interval]:interval (seconds):'
  '-j[display persistent device names]:naming type:((SID ID LABEL PATH UUID))'
  '-m[report power management statistics]:keywords:(CPU FAN FREQ IN TEMP USB ALL)'
  '-n[report network statistics]:keywords:(DEV EDEV NFS NFSD SOCK IP EIP ICMP EICMP TCP ETCP UDP SOCK6 IP6 EIP6 ICMP6 EICMP6 UDP6 FC SOFT ALL)'
  '-o[save readings in binary form to file]:output file:_files'
  '-P[report per-processor statistics]:CPU list or ALL:'
  '-p[pretty printing (same as --pretty)]'
  '-q[report queue length and pressure-stall statistics]: :(LOAD CPU IO MEM ALL)'
  '-r[report memory utilization statistics]: :(ALL)'
  '-S[report swap space utilization statistics]'
  '-s[set starting time of data]:start time (hh\:mm[\:ss] or seconds):'
  '-t[display timestamps in original local time]'
  '-u[report CPU utilization]: :(ALL)'
  '(- * :)'-V'[print version number and exit]'
  '-v[report status of inode, file and other kernel tables]'
  '-W[report swapping statistics]'
  '-w[report task creation and system switching activity]'
  '-x[display minimum and maximum values]'
  '-y[report TTY devices activity]'
  '-z[omit output for inactive devices]'
  '--dec[specify number of decimal places]:decimal places:((0 1 2))'
  '--dev[specify block devices]:device list:_sequence compadd - ${(f)"$(lsblk -dno NAME 2>/dev/null)"}'
  '--fs[specify filesystems]:filesystem list:_sequence _directories'
  '(- * :)--help[display help and exit]'
  '--human[print sizes in human-readable format]'
  '--iface[specify network interfaces]:interface list:_sequence _net_interfaces'
  '--int[specify interrupt names]:interrupt list:'
  '--pretty[make reports easier to read]'
  '--sadc[indicate which data collector is called by sar]'
  '1:interval (seconds):'
  '2:count:'
)

_arguments -s -S $arguments
