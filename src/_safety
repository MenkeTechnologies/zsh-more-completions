#compdef safety

# zsh completions for 'safety'

_safety() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a global_opts
  global_opts=(
    '(- *)'{-h,--help}'[show help message and exit]'
    '(- *)--version[show version and exit]'
    '--debug[enable debug mode]'
  )

  local -a subcommands
  subcommands=(
    'check:find vulnerabilities in a target file or environment'
    'scan:scan a project directory for vulnerabilities'
    'validate:validate a Safety policy file'
    'auth:authenticate with the Safety API'
    'configure:set up Safety configuration'
  )

  _arguments -s -S \
    $global_opts \
    '1: :->subcommand' \
    '*:: :->args' && return

  case $state in
    subcommand)
      _describe -t subcommands 'safety subcommand' subcommands
      ;;
    args)
      case $line[1] in
        check)
          _arguments -s -S \
            '(- *)'{-h,--help}'[show help message and exit]' \
            '*'{-r,--requirement}'[path to requirements file]:requirements file:_files' \
            '--key[Safety API key]:api key:' \
            '--db[path to a local vulnerability database]:database path:_directories' \
            '--stdin[read input from stdin]' \
            '--full-report[generate a full report]' \
            '--short-report[generate a short report]' \
            '--bare[output only the package names]' \
            '--cache[cache requests to the vulnerability database]' \
            '--output[output format]:format:(screen json bare text)' \
            '--continue-on-error[continue scanning even if there is an error]' \
            '--policy-file[path to a Safety policy file]:policy file:_files' \
            '--audit-and-monitor[create an audit event on Safety platform]' \
            '--project[project name on Safety platform]:project name:' \
            '--save-json[path to save JSON report]:output file:_files' \
            '--save-html[path to save HTML report]:output file:_files' \
            ;;
        scan)
          _arguments -s -S \
            '(- *)'{-h,--help}'[show help message and exit]' \
            '--target[target directory to scan]:directory:_directories' \
            '--output[output format]:format:(screen json text)' \
            '--policy-file[path to a Safety policy file]:policy file:_files' \
            '--save-as[path to save the scan report]:output file:_files' \
            ;;
        validate)
          _arguments -s -S \
            '(- *)'{-h,--help}'[show help message and exit]' \
            '*:policy file:_files' \
            ;;
        auth)
          _arguments -s -S \
            '(- *)'{-h,--help}'[show help message and exit]' \
            ;;
        configure)
          _arguments -s -S \
            '(- *)'{-h,--help}'[show help message and exit]' \
            ;;
      esac
      ;;
  esac
}

_safety "$@"
