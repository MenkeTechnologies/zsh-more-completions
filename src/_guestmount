#compdef guestmount

local -a arguments

arguments=(
  '(-a --add)'{-a,--add}'[add image]:image:_files'
  '(-c --connect)'{-c,--connect}'[specify libvirt URI for -d option]:uri'
  '--dir-cache-timeout[set readdir cache timeout (default 5 sec)]'
  '(-d --domain)'{-d,--domain}'[add disks from libvirt guest]:guest'
  '--echo-keys[dont turn off echo for passphrases]'
  '--fd[write to pipe FD when mountpoint is ready]:fd'
  '--format[force disk format for -a option]:format'
  '--fuse-help[display extra FUSE options]'
  '(-i --inspector)'{-i,--inspector}'[automatically mount filesystems]'
  '--help[display help message and exit]'
  '--keys-from-stdin[read passphrases from stdin]'
  '--live[connect to a live virtual machine]'
  '(-m --mount)'{-m,--mount}'[mount dev on mountpoint (if omitted, /)]:dev'
  '--no-fork[dont daemonize]'
  '(-n --no-sync)'{-n,--no-sync}'[dont autosync]'
  '(-o --option)'{-o,--option}'[pass extra option to FUSE]:option'
  '--pid-file[write PID to filename]:filename:_files'
  '(-r --ro)'{-r,--ro}'[mount read-only]'
  '--selinux[for backwards compat only, does nothing]'
  '(-v --verbose)'{-v,--verbose}'[verbose messages]'
  '(-V --version)'{-V,--version}'[display version and exit]'
  '(-w --rw)'{-w,--rw}'[mount read-write]'
  '(-x --trace)'{-x,--trace}'[trace guestfs API calls]'
  '*:filename:_files'
)

_arguments -s -S $arguments
