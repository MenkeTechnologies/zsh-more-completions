#compdef preconv
# Documentation: https://man.archlinux.org/search?q=preconv
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-d[show debugging messages]'
  '-D[specify default encoding]'
  '-e[specify input encoding]'
  '-h[print this message]'
  '-r[dont add .lf requests]'
  '-v[print version number]'
  '*:filename:_files'
)

_arguments -s -S $arguments
