#compdef vegeta

# Zsh completion for vegeta - HTTP load testing

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--cpus[number of CPUs to use]:cpus:' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'attack:send HTTP requests'
      'encode:encode results'
      'plot:plot results as HTML'
      'report:generate reports from results'
    )
    _describe -t commands 'vegeta command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (attack)
        _arguments \
          '-body[request body file]:file:_files' \
          '-cert[TLS client PEM encoded certificate file]:file:_files -g "*.pem"' \
          '-chunked[send body with chunked transfer encoding]' \
          '-connections[max open idle connections per target host]:number:' \
          '-dns-ttl[DNS TTL for cached lookups]:duration:' \
          '-duration[duration of the test]:duration:' \
          '-format[targets format]:format:(http json)' \
          '-header[request header]:header:' \
          '-http2[send HTTP/2 requests when supported]' \
          '-insecure[ignore invalid server TLS certificates]' \
          '-keepalive[use persistent connections]' \
          '-key[TLS client PEM encoded private key file]:file:_files -g "*.pem"' \
          '-laddr[local IP address]:address:' \
          '-lazy[read targets lazily]' \
          '-max-body[maximum body bytes to capture]:bytes:' \
          '-max-connections[maximum open connections per target host]:number:' \
          '-max-workers[maximum number of workers]:number:' \
          '-name[attack name]:name:' \
          '-output[output file]:file:_files' \
          '-proxy-header[proxy CONNECT header]:header:' \
          '-rate[rate of requests]:rate:' \
          '-redirects[number of redirects to follow]:number:' \
          '-resolvers[comma-separated list of custom DNS resolvers]:resolvers:' \
          '-root-certs[TLS root certificate files]:file:_files -g "*.pem"' \
          '-session-tickets[enable TLS session tickets]' \
          '-targets[targets file]:file:_files' \
          '-timeout[request timeout]:duration:' \
          '-unix-socket[use Unix socket]:socket:_files' \
          '-workers[initial number of workers]:number:' \
          && ret=0
        ;;
      (encode)
        _arguments \
          '-output[output file]:file:_files' \
          '-to[encoding format]:format:(csv gob json)' \
          && ret=0
        ;;
      (plot)
        _arguments \
          '-output[output file]:file:_files -g "*.html"' \
          '-threshold[threshold line]:value:' \
          '-title[plot title]:title:' \
          && ret=0
        ;;
      (report)
        _arguments \
          '-buckets[histogram buckets]:buckets:' \
          '-every[report interval]:duration:' \
          '-output[output file]:file:_files' \
          '-type[report type]:type:(text json hist hdrplot)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
