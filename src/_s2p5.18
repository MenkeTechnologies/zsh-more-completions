#compdef s2p5 s2p5.18
# Documentation: https://man.archlinux.org/search?q=s2p5
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '-a[open file specified in w command before input processing]'
    '-e[The editing commands defined by script are appended to the script.]:script'
    '-f[read editing commands from the specified script-file]:script-file'
)
_arguments -s -S $arguments
