#compdef blktrace

local -a arguments

arguments=(
  {-d,--dev}'[specified device to trace]:device:_files'
  '-r[path to mounted debugfs]:path:_files -/'
  '-o[output file(s) to send output to]:file:_files'
  '-D[directory to prepend to output file names]:directory:_files -/'
  '-w[stop after defined time, in seconds]:seconds:'
  '-a[trace specified actions]:actions:'
  '-A[trace mask as a single value]:mask:'
  '-b[buffer size in KiB (default 512)]:size:'
  '-n[number of sub buffers (default 4)]:count:'
  '-l[run in network listen mode (blktrace server)]'
  '-h[run in network client mode, connecting to the given host]:host:'
  '-p[port to use (default 8462)]:port:'
  '-s[tell the network client NOT to use sendfile()]'
  '-I[add devices found in devs file]:file:_files'
  '-v[program version info]'
  '-V[program version info]'
  '*:filename:_files'
)

_arguments -s -S $arguments
