#compdef browserslist

local -a arguments

arguments=(
    '--coverage[Show browser coverage]'
    '--json[Output as JSON]'
    '--mobile-to-desktop[Use mobile to desktop option]'
    '--ignore-unknown-versions[Ignore unknown versions]'
    '--config[Path to config]:file:_files'
    '--env[Environment from config]:env'
    '--stats[Path to custom usage stats]:file:_files -g "*.json"'
    '--update-db[Update caniuse-lite database]'
    '--help[Show help]'
    '--version[Show version]'
    '*:queries'
)

_arguments -s -S $arguments
