#compdef poetry

# Zsh completion for Poetry (Python packaging and dependency management)
# Covers Poetry 1.8.x / 2.x commands and options

_poetry() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    local -a commands
    commands=(
        'about:Shows information about Poetry'
        'add:Adds a new dependency to pyproject.toml'
        'build:Builds a package, as a tarball and a wheel by default'
        'cache:Interact with Poetry'\''s cache'
        'check:Validates the content of the pyproject.toml file'
        'config:Manages configuration settings'
        'env:Interact with Poetry'\''s project environments'
        'export:Exports the lock file to alternative formats'
        'help:Displays help for a command'
        'init:Creates a basic pyproject.toml file in the current directory'
        'install:Installs the project dependencies'
        'list:Lists commands'
        'lock:Locks the project dependencies'
        'new:Creates a new Python project at <path>'
        'publish:Publishes a package to a remote repository'
        'remove:Removes a package from the project dependencies'
        'run:Runs a command in the appropriate environment'
        'search:Searches for packages on remote repositories'
        'self:Interact with Poetry directly'
        'shell:Spawns a shell within the virtual environment'
        'show:Shows information about packages'
        'source:Manage repository sources for a project'
        'sync:Synchronize the environment with the locked packages and the specified groups'
        'update:Update the dependencies as according to the pyproject.toml file'
        'version:Shows the version of the project or bumps it when given a valid bump rule'
    )

    local -a global_flags
    global_flags=(
        '(-h --help)'{-h,--help}'[Display help information]'
        '(-q --quiet)'{-q,--quiet}'[Do not output any message]'
        '*'{-v,--verbose}'[Increase the verbosity of messages (-v, -vv, -vvv)]'
        '(-V --version)'{-V,--version}'[Display this application version]'
        '--ansi[Force ANSI output]'
        '--no-ansi[Disable ANSI output]'
        '(-n --no-interaction)'{-n,--no-interaction}'[Do not ask any interactive question]'
        '--no-plugins[Disables plugins]'
        '--no-cache[Disables Poetry source caches]'
        '(-C --directory)'{-C,--directory}'[The working directory for the Poetry command]:directory:_directories'
        '(-P --project)'{-P,--project}'[The project directory for the Poetry command]:directory:_directories'
    )

    _arguments -C \
        $global_flags \
        '1:command:->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'poetry command' commands
            ;;
        args)
            case $words[1] in
                about)
                    _arguments -s \
                        '(-h --help)'{-h,--help}'[Display help]'
                    ;;
                add)
                    _arguments -s \
                        '(-G --group)'{-G,--group}'[The group to add the dependency to]:group:' \
                        '(-e --editable)'{-e,--editable}'[Add vcs/path dependencies as editable]' \
                        '*--extras[Extras to activate for the dependency]:extras:' \
                        '--optional[Add as an optional dependency to a group]:group:' \
                        '--python[Python version constraint]:constraint:' \
                        '--platform[Platforms for which the dependency must be installed]:platform:(darwin linux win32)' \
                        '--source[Name of the source to use to install the package]:source:' \
                        '--allow-prereleases[Accept prereleases]' \
                        '--dry-run[Output the operations but do not execute anything]' \
                        '--lock[Do not perform install after updating the lock file]' \
                        '(-h --help)'{-h,--help}'[Display help]' \
                        '*:package:'
                    ;;
                build)
                    _arguments -s \
                        '(-f --format)'{-f,--format}'[Limit the format to either sdist or wheel]:format:(sdist wheel)' \
                        '--clean[Clean output directory before building]' \
                        '(-o --output)'{-o,--output}'[Set the output directory for built packages]:directory:_directories' \
                        '(-h --help)'{-h,--help}'[Display help]'
                    ;;
                cache)
                    local -a cache_commands
                    cache_commands=(
                        'clear:Clears a Poetry cache by name'
                        'list:List available caches'
                    )
                    _arguments -C \
                        '(-h --help)'{-h,--help}'[Display help]' \
                        '1:cache command:->cachecmd' \
                        '*::arg:->cacheargs'
                    case $state in
                        cachecmd)
                            _describe -t cache_commands 'cache command' cache_commands
                            ;;
                        cacheargs)
                            case $words[1] in
                                clear)
                                    _arguments -s \
                                        '--all[Clear all entries in the cache]' \
                                        '(-h --help)'{-h,--help}'[Display help]' \
                                        '1:cache name:'
                                    ;;
                                list)
                                    _arguments -s \
                                        '(-h --help)'{-h,--help}'[Display help]'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                check)
                    _arguments -s \
                        '--lock[Check that the lock file is up to date]' \
                        '(-h --help)'{-h,--help}'[Display help]'
                    ;;
                config)
                    _arguments -s \
                        '--list[List configuration settings]' \
                        '--unset[Unset configuration setting]' \
                        '--local[Set or get a repository-specific setting]' \
                        '(-h --help)'{-h,--help}'[Display help]' \
                        '1:key:(cache-dir experimental.system-git-client installer.max-workers installer.modern-installation installer.no-binary installer.parallel keyring.enabled repositories solver.lazy-wheel virtualenvs.create virtualenvs.in-project virtualenvs.options.always-copy virtualenvs.options.no-pip virtualenvs.options.no-setuptools virtualenvs.options.system-site-packages virtualenvs.path virtualenvs.prefer-active-python virtualenvs.prompt warnings.export http-basic pypi-token certificates)' \
                        '2:value:'
                    ;;
                env)
                    local -a env_commands
                    env_commands=(
                        'activate:Activates a virtual environment'
                        'deactivate:Deactivates the current virtual environment'
                        'info:Displays information about the currently activated virtual environment'
                        'list:Lists all virtualenvs associated with the current project'
                        'remove:Remove virtual environments associated with the project'
                        'use:Activates or creates a new virtualenv for the current project'
                    )
                    _arguments -C \
                        '(-h --help)'{-h,--help}'[Display help]' \
                        '1:env command:->envcmd' \
                        '*::arg:->envargs'
                    case $state in
                        envcmd)
                            _describe -t env_commands 'env command' env_commands
                            ;;
                        envargs)
                            case $words[1] in
                                info)
                                    _arguments -s \
                                        '(-p --path)'{-p,--path}'[Only display the environment path]' \
                                        '(-e --executable)'{-e,--executable}'[Only display the environment python executable]' \
                                        '(-h --help)'{-h,--help}'[Display help]'
                                    ;;
                                list)
                                    _arguments -s \
                                        '--full-path[Prepend the full path to the virtualenvs]' \
                                        '(-h --help)'{-h,--help}'[Display help]'
                                    ;;
                                remove)
                                    _arguments -s \
                                        '--all[Remove all managed virtualenvs for the project]' \
                                        '(-h --help)'{-h,--help}'[Display help]' \
                                        '*:python version:'
                                    ;;
                                use)
                                    _arguments -s \
                                        '(-h --help)'{-h,--help}'[Display help]' \
                                        '1:python version:'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                export)
                    _arguments -s \
                        '(-f --format)'{-f,--format}'[Format to export to]:format:(constraints.txt requirements.txt)' \
                        '(-o --output)'{-o,--output}'[The output file]:file:_files' \
                        '--without-hashes[Exclude hashes from the exported file]' \
                        '--without-urls[Exclude source repository urls from the exported file]' \
                        '--without-credentials[Exclude credentials from the exported file]' \
                        '*--extras[Extra sets of dependencies to include]:extras:' \
                        '*--with[The optional dependency groups to include]:group:' \
                        '*--without[The dependency groups to ignore]:group:' \
                        '--only[The only dependency groups to include]:group:' \
                        '--all-extras[Include all extra dependencies]' \
                        '(-h --help)'{-h,--help}'[Display help]'
                    ;;
                help)
                    _arguments -s \
                        '1:command:($commands)'
                    ;;
                init)
                    _arguments -s \
                        '--name[Name of the package]:name:' \
                        '--description[Description of the package]:description:' \
                        '--author[Author name of the package]:author:' \
                        '--python[Compatible Python versions]:constraint:' \
                        '--license[License of the package]:license:' \
                        '*--dependency[Package to require with an optional version constraint]:dependency:' \
                        '*--dev-dependency[Package to require for development]:dependency:' \
                        '(-h --help)'{-h,--help}'[Display help]'
                    ;;
                install)
                    _arguments -s \
                        '*--without[The dependency groups to ignore]:group:' \
                        '*--with[The optional dependency groups to include]:group:' \
                        '--only[The only dependency groups to include]:group:' \
                        '--no-root[Do not install the root package]' \
                        '--no-directory[Do not install any directory path dependencies]' \
                        '--dry-run[Output the operations but do not execute anything]' \
                        '*--extras[Extra sets of dependencies to install]:extras:' \
                        '(-E)*'{-E+}'[Extra sets of dependencies to install]:extras:' \
                        '--all-extras[Install all extra dependencies]' \
                        '--only-root[Only install the root project, excluding all dependencies]' \
                        '--sync[Synchronize the environment with the locked packages]' \
                        '--compile[Compile Python source files to bytecode]' \
                        '--all-groups[Install dependencies from all groups]' \
                        '(-h --help)'{-h,--help}'[Display help]'
                    ;;
                list)
                    _arguments -s \
                        '(-h --help)'{-h,--help}'[Display help]'
                    ;;
                lock)
                    _arguments -s \
                        '--no-update[Do not update locked versions, only refresh lock file]' \
                        '--check[Check that the lock file is up to date]' \
                        '--regenerate[Regenerate the lock file from scratch]' \
                        '(-h --help)'{-h,--help}'[Display help]'
                    ;;
                new)
                    _arguments -s \
                        '--name[Set the resulting package name]:name:' \
                        '--src[Use the src layout for the project]' \
                        '--readme[Specify the readme file format]:format:(md rst)' \
                        '--python[Compatible Python versions]:constraint:' \
                        '(-h --help)'{-h,--help}'[Display help]' \
                        '1:path:_directories'
                    ;;
                publish)
                    _arguments -s \
                        '(-r --repository)'{-r,--repository}'[The repository to register the package to]:repository:' \
                        '(-u --username)'{-u,--username}'[The username to access the repository]:username:' \
                        '(-p --password)'{-p,--password}'[The password to access the repository]:password:' \
                        '--cert[Certificate authority to access the repository]:cert:_files' \
                        '--client-cert[Client certificate to access the repository]:cert:_files' \
                        '--build[Build the package before publishing]' \
                        '--dry-run[Perform all actions except upload the package]' \
                        '--skip-existing[Ignore errors from files already existing in the repository]' \
                        '--dist-dir[Dist directory where built distributions are located]:directory:_directories' \
                        '(-h --help)'{-h,--help}'[Display help]'
                    ;;
                remove)
                    _arguments -s \
                        '(-G --group)'{-G,--group}'[The group to remove the dependency from]:group:' \
                        '--dry-run[Output the operations but do not execute anything]' \
                        '--lock[Do not perform install after removing the lock file]' \
                        '(-h --help)'{-h,--help}'[Display help]' \
                        '*:package:'
                    ;;
                run)
                    _arguments -s \
                        '(-h --help)'{-h,--help}'[Display help]' \
                        '1:command:_command_names' \
                        '*:arguments:_files'
                    ;;
                search)
                    _arguments -s \
                        '(-h --help)'{-h,--help}'[Display help]' \
                        '1:query:'
                    ;;
                self)
                    local -a self_commands
                    self_commands=(
                        'add:Add additional packages to Poetry'\''s runtime environment'
                        'install:Install locked packages required by this Poetry installation'
                        'lock:Lock the Poetry installation'\''s system requirements'
                        'remove:Remove additional packages from Poetry'\''s runtime environment'
                        'show:Show packages in Poetry'\''s runtime environment'
                        'update:Updates Poetry to the latest version'
                    )
                    _arguments -C \
                        '(-h --help)'{-h,--help}'[Display help]' \
                        '1:self command:->selfcmd' \
                        '*::arg:->selfargs'
                    case $state in
                        selfcmd)
                            _describe -t self_commands 'self command' self_commands
                            ;;
                        selfargs)
                            case $words[1] in
                                add)
                                    _arguments -s \
                                        '--dry-run[Output the operations but do not execute anything]' \
                                        '*--extras[Extras to activate for the dependency]:extras:' \
                                        '--editable[Add vcs/path dependencies as editable]' \
                                        '--source[Name of the source to use]:source:' \
                                        '--allow-prereleases[Accept prereleases]' \
                                        '(-h --help)'{-h,--help}'[Display help]' \
                                        '*:package:'
                                    ;;
                                install)
                                    _arguments -s \
                                        '--sync[Synchronize the environment]' \
                                        '--dry-run[Output the operations but do not execute anything]' \
                                        '(-h --help)'{-h,--help}'[Display help]'
                                    ;;
                                lock)
                                    _arguments -s \
                                        '--no-update[Do not update locked versions]' \
                                        '--check[Check that the lock file is up to date]' \
                                        '(-h --help)'{-h,--help}'[Display help]'
                                    ;;
                                remove)
                                    _arguments -s \
                                        '--dry-run[Output the operations but do not execute anything]' \
                                        '(-h --help)'{-h,--help}'[Display help]' \
                                        '*:package:'
                                    ;;
                                show)
                                    _arguments -s \
                                        '(-t --tree)'{-t,--tree}'[List the dependencies as a tree]' \
                                        '(-l --latest)'{-l,--latest}'[Show the latest version]' \
                                        '(-o --outdated)'{-o,--outdated}'[Show only outdated packages]' \
                                        '(-h --help)'{-h,--help}'[Display help]' \
                                        '1:package:'
                                    ;;
                                update)
                                    _arguments -s \
                                        '--preview[Allow preview versions]' \
                                        '--dry-run[Output the operations but do not execute anything]' \
                                        '(-h --help)'{-h,--help}'[Display help]'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                shell)
                    _arguments -s \
                        '(-h --help)'{-h,--help}'[Display help]'
                    ;;
                show)
                    _arguments -s \
                        '*--without[The dependency groups to ignore]:group:' \
                        '*--with[The optional dependency groups to include]:group:' \
                        '--only[The only dependency groups to include]:group:' \
                        '(-t --tree)'{-t,--tree}'[List the dependencies as a tree]' \
                        '(-l --latest)'{-l,--latest}'[Show the latest version]' \
                        '(-o --outdated)'{-o,--outdated}'[Show the latest version but only for packages that are outdated]' \
                        '(-a --all)'{-a,--all}'[Show all packages including development dependencies]' \
                        '--top-level[Show only top-level dependencies]' \
                        '--why[Show the reason a package is included in the lock file]' \
                        '(-h --help)'{-h,--help}'[Display help]' \
                        '1:package:'
                    ;;
                source)
                    local -a source_commands
                    source_commands=(
                        'add:Add a new source'
                        'remove:Remove a source'
                        'show:Show information about sources'
                    )
                    _arguments -C \
                        '(-h --help)'{-h,--help}'[Display help]' \
                        '1:source command:->sourcecmd' \
                        '*::arg:->sourceargs'
                    case $state in
                        sourcecmd)
                            _describe -t source_commands 'source command' source_commands
                            ;;
                        sourceargs)
                            case $words[1] in
                                add)
                                    _arguments -s \
                                        '--default[Set this source as the default]' \
                                        '--secondary[Set this source as secondary (deprecated)]' \
                                        '--supplemental[Set this source as supplemental]' \
                                        '--explicit[Set this source as explicit]' \
                                        '--priority[Set the priority of this source]:priority:(default primary supplemental explicit)' \
                                        '(-h --help)'{-h,--help}'[Display help]' \
                                        '1:name:' \
                                        '2:url:'
                                    ;;
                                remove)
                                    _arguments -s \
                                        '(-h --help)'{-h,--help}'[Display help]' \
                                        '1:name:'
                                    ;;
                                show)
                                    _arguments -s \
                                        '(-h --help)'{-h,--help}'[Display help]' \
                                        '1:name:'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                sync)
                    _arguments -s \
                        '*--without[The dependency groups to ignore]:group:' \
                        '*--with[The optional dependency groups to include]:group:' \
                        '--only[The only dependency groups to include]:group:' \
                        '--no-root[Do not install the root package]' \
                        '--no-directory[Do not install any directory path dependencies]' \
                        '--dry-run[Output the operations but do not execute anything]' \
                        '--all-extras[Install all extra dependencies]' \
                        '*--extras[Extra sets of dependencies to install]:extras:' \
                        '--all-groups[Install dependencies from all groups]' \
                        '(-h --help)'{-h,--help}'[Display help]'
                    ;;
                update)
                    _arguments -s \
                        '*--without[The dependency groups to ignore]:group:' \
                        '*--with[The optional dependency groups to include]:group:' \
                        '--only[The only dependency groups to include]:group:' \
                        '--dry-run[Output the operations but do not execute anything]' \
                        '--lock[Do not perform install after updating the lock file]' \
                        '(-h --help)'{-h,--help}'[Display help]' \
                        '*:package:'
                    ;;
                version)
                    _arguments -s \
                        '(-s --short)'{-s,--short}'[Output the version number only]' \
                        '--dry-run[Do not update pyproject.toml file]' \
                        '--next-phase[Increment the phase of the current version]' \
                        '(-h --help)'{-h,--help}'[Display help]' \
                        '1:version:(major minor patch premajor preminor prepatch prerelease)'
                    ;;
            esac
            ;;
    esac
}

_poetry "$@"
