#compdef qprofdiff
# Documentation: https://man.archlinux.org/search?q=qprofdiff
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-n[suppress unchanged items]'
  '-si[sort by difference in number of instances]'
  '-sg[sort by difference in max. generation]'
  '-sc[sort by difference in max. cost]'
  '*:filename:_files'
)

_arguments -s -S $arguments
