#compdef flake8

local -a arguments

arguments=(
  {-h,--help}'[show this help message and exit]'
  {-v,--verbose}'[print more information about what is happening in flake8]'
  '--output-file[redirect report to a file]:file:_files'
  '--append-config[provide extra config files to parse in addition to defaults]:file:_files'
  '--config[path to the config file that will be the authoritative config source]:file:_files'
  '--isolated[ignore all configuration files.]'
  '--version[show programs version number and exit]'
  {-q,--quiet}'[report only file names, or nothing. Repeatable]'
  '--count[print total number of errors and warnings to standard error]'
  '--diff[report changes only within line number ranges in the unified diff]'
  '--exclude[comma-separated list of files or directories to exclude]:patterns:'
  '--extend-exclude[comma-separated list of files or directories to add to excludes]:patterns:'
  '--filename[only check for filenames matching the given patterns]:patterns:'
  '--stdin-display-name[the name used when reporting errors from code on stdin]:name:'
  '--format[format errors according to the chosen formatter]:format:'
  '--hang-closing[hang closing bracket instead of matching indentation]'
  '--ignore[comma-separated list of errors and warnings to ignore]:codes:'
  '--extend-ignore[comma-separated list of errors and warnings to add to ignore list]:codes:'
  '--per-file-ignores[pairing of filenames and violation codes to ignore]:patterns:'
  '--max-line-length[maximum allowed line length (default: 79)]:length:'
  '--max-doc-length[maximum allowed doc line length]:length:'
  '--indent-size[number of spaces used for indentation (default: 4)]:size:'
  '--select[comma-separated list of errors and warnings to enable]:codes:'
  '--disable-noqa[disable the effect of "# noqa"]'
  '--show-source[show the source generate each error or warning.]'
  '--no-show-source[negate --show-source]'
  '--statistics[count errors and warnings.]'
  '--enable-extensions[enable plugins and extensions that are otherwise disabled]:extensions:'
  '--exit-zero[exit with status code "0" even if there are errors.]'
  '--install-hook[install a hook for version control]:type:(git mercurial)'
  {-j,--jobs}'[number of subprocesses to use to run checks in parallel]:jobs:'
  '--tee[write to stdout and output-file.]'
  '--benchmark[print benchmark information about this run of Flake8]'
  '--bug-report[print information necessary when preparing a bug report]'
  '--max-complexity[McCabe complexity threshold]:threshold:'
  '--builtins[define more built-ins, comma separated]:builtins:'
  '--doctests[also check syntax of the doctests]'
  '--include-in-doctest[run doctests only on these files]:files:'
  '--exclude-from-doctest[skip these files when running doctests]:files:'
  '*:filename:_files'
)

_arguments -s -S $arguments
