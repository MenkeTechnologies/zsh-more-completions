#compdef cbfstool


local -a arguments

arguments=(
    {-r,-b}'[Add a raw 64-bit integer value P add-master-header \[-r image,regions\] \\e.]'
    '-j[Add a legacy CBFS master header.]'
    {-o,-H,-B}'[Create a legacy ROM file with CBFS master header*.]'
    '-a[find a place for a file of that size]:size:'
    '-m[Extracts a file from ROM.]'
    {-u,-i}'[Write file into same-size \[or larger\] raw region.]'
    '-T[Output top-aligned memory address.]'
    '-d[Accept short data; fill downward/from top.]'
    '-F[Force action.]'
    '-g[Generate position and alignment arguments.]'
    '-U[Unprocessed; don\t decompress or make ELF.]'
    '-v[Provide verbose output.]'
    '-h[Display this help message.]'
    '--ext-win-base[base of extended decode window in host address space (x86 only)]:base:'
    '--ext-win-size[size of extended decode window in host address space (x86 only)]:size:'
    '*:filename:_files'
)
_arguments -s -S $arguments
