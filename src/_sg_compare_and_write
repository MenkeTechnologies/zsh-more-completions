#compdef sg_compare_and_write

local -a arguments

arguments=(
  {--dpo,-d}'[set the dpo bit in cdb (def: clear)]'
  {--fua,-f}'[set the fua bit in cdb (def: clear)]'
  {--fua_nv,-F}'[set the fua_nv bit in cdb (def: clear)]'
  '--group[GN is GROUP NUMBER to set in cdb (def: 0)]'
  {--help,-h}'[print out usage message]'
  '--in[file containing a compare buffer and write buffer]:file:_files'
  '--inw[file containing a write buffer]:file:_files'
  '--lba[LBA of the first block of the compare and write]'
  '--num[number of blocks to compare/write (def: 1)]'
  {--quiet,-q}'[suppress MISCOMPARE report to stderr]'
  '--timeout[timeout for the command (def: 60 secs)]'
  {--verbose,-v}'[increase verbosity (use -vv for more)]'
  {--version,-V}'[print version string then exit]'
  '--wrprotect[write protect information (def: 0)]'
  '--xferlen[number of bytes to transfer]'
  '*:filename:_files'
)

_arguments -s -S $arguments
