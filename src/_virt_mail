#compdef virt_mail
# Documentation: https://man.archlinux.org/search?q=virt_mail
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-m[(default, needs -l)]'
  '-m[(same as -m sendmail)]'
  '-m[mode or machine]'
  '-m[mode or machine]'
  '*:filename:_files'
)

_arguments -s -S $arguments
