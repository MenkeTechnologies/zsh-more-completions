#compdef syft

# Zsh completion for Syft - SBOM generator

local curcontext="$curcontext" state line ret=1

_syft_commands() {
  local -a commands=(
    'attest:generate an SBOM as an in-toto attestation for a container image'
    'cataloger:show available catalogers and configuration'
    'completion:generate a shell completion script'
    'convert:convert between SBOM formats'
    'help:help about any command'
    'login:log in to a registry'
    'packages:generate a package SBOM'
    'scan:generate an SBOM'
    'version:show version information'
  )
  _describe -t commands 'syft command' commands
}

_syft_output_formats() {
  local -a formats=(
    'syft-json'
    'syft-table'
    'syft-text'
    'cyclonedx-xml'
    'cyclonedx-json'
    'spdx-json'
    'spdx-tag-value'
    'github-json'
    'template'
  )
  _describe -t formats 'output format' formats
}

_syft_scan() {
  _arguments -s -S \
    '(-o --output)'{-o,--output}'[report output format]:format:_syft_output_formats' \
    '--file[write output to file]:file:_files' \
    '--from[specify the source providing the input]:source:(docker podman registry dir file)' \
    '--name[set the name of the target being analyzed]:name' \
    '--platform[an optional platform specifier]:platform:(linux/amd64 linux/arm64 linux/arm/v7)' \
    '--config[application config file]:file:_files' \
    '--exclude[exclude paths from being scanned using a glob]:glob' \
    '--catalogers[enable one or more package catalogers]:catalogers' \
    '--default-catalogers[set the base set of catalogers to use]:preset:(all image directory)' \
    '--select-catalogers[selection expression to filter catalogers]:expr' \
    '--source-name[set the source name]:name' \
    '--source-version[set the source version]:version' \
    '(-q --quiet)'{-q,--quiet}'[suppress all output except for SBOM]' \
    '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
    '--scope[selection of layers to analyze]:scope:(squashed all-layers)' \
    '1:source:' && ret=0
}

_syft_attest() {
  _arguments -s -S \
    '(-o --output)'{-o,--output}'[report output format]:format:_syft_output_formats' \
    '--key[path to the private key file]:file:_files' \
    '--platform[an optional platform specifier]:platform' \
    '--from[specify the source providing the input]:source:(docker podman registry)' \
    '--name[set the name of the target]:name' \
    '--exclude[exclude paths from scanning]:glob' \
    '--catalogers[enable one or more package catalogers]:catalogers' \
    '--scope[selection of layers to analyze]:scope:(squashed all-layers)' \
    '(-q --quiet)'{-q,--quiet}'[suppress all output except for SBOM]' \
    '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
    '1:image:' && ret=0
}

_syft_convert() {
  _arguments -s -S \
    '(-o --output)'{-o,--output}'[report output format]:format:_syft_output_formats' \
    '--file[write output to file]:file:_files' \
    '1:SBOM file:_files' && ret=0
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '--version[show version]' \
  '--config[application config file]:file:_files' \
  '(-o --output)'{-o,--output}'[report output format]:format:_syft_output_formats' \
  '--file[write output to file]:file:_files' \
  '--scope[selection of layers to analyze]:scope:(squashed all-layers)' \
  '--from[specify the source providing the input]:source:(docker podman registry dir file)' \
  '--platform[an optional platform specifier]:platform' \
  '--exclude[exclude paths from being scanned]:glob' \
  '--name[set the name of the target being analyzed]:name' \
  '--catalogers[enable one or more package catalogers]:catalogers' \
  '1: :_syft_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      scan|packages) _syft_scan ;;
      attest)        _syft_attest ;;
      convert)       _syft_convert ;;
      completion)
        _arguments '1:shell:(bash zsh fish)' && ret=0
        ;;
      version)
        _arguments \
          '(-o --output)'{-o,--output}'[output format]:format:(text json)' && ret=0
        ;;
      cataloger)
        _arguments \
          '--show-hidden[show hidden catalogers]' \
          '--show-default[show cataloger defaults]' \
          '1:search term:' && ret=0
        ;;
      login)
        _arguments \
          '(-u --username)'{-u,--username}'[registry username]:username' \
          '(-p --password)'{-p,--password}'[registry password]:password' \
          '--password-stdin[read password from stdin]' \
          '--tls-verify[require TLS and verify certificates]' \
          '1:server:' && ret=0
        ;;
    esac
    ;;
esac

return ret
