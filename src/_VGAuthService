#compdef VGAuthService
# Documentation: https://man.archlinux.org/search?q=VGAuthService
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-k[kill the running instance that was started as a daemon.]'
  '-s[run in daemon mode.]'
  '-b[run in background mode, using a pid lock file.]'
  '-h[display this help and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
