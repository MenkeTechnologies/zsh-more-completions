#compdef miranda
# Documentation: https://man.archlinux.org/search?q=miranda
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-s[file> Load previous host data from struct file]'
  '-l[file> Log user-supplied commands to log file]'
  '-i[specify the name of the interface to use (Linux only, requires root)]'
  '-u[disable show-uniq-hosts-only option]'
  '-d[enable debug mode]'
  '-v[enable verbose mode]'
  '-h[show help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
