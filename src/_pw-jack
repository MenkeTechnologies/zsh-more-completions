#compdef pw-jack
# Documentation: https://man.archlinux.org/search?q=pw-jack
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '-h[Show help.]'
    '-r[The name of the remote instance to connect to.]:NAME'
    '-v[Verbose operation.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
