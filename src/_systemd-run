#compdef systemd-run

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help text]'
  '--version[show package version]'
  '--no-pager[do not pipe output into a pager]'
  '--no-ask-password[do not prompt for password]'
  '--system[talk to the service manager of the system]'
  '--user[talk to the service manager of the calling user]'
  {-H,--host=}'[execute on remote host]:hostname:_hosts'
  {-M,--machine=}'[execute on local container]:machine name'
  {-C,--capsule=}'[execute on a capsule]:capsule name'
  '--scope[create a transient scope unit instead of service]'
  {-u,--unit=}'[use specified unit name]:unit name'
  {-p,--property=}'[set property on the scope or service unit]:property'
  '--description=[provide a description for the unit]:description'
  '--slice=[make the unit part of the specified slice]:slice'
  '--slice-inherit[inherit the slice of the systemd-run caller]'
  '--expand-environment=[expand environment variables in command arguments]:bool:(yes no)'
  {-r,--remain-after-exit}'[keep service around after process terminates]'
  '--send-sighup[send SIGHUP when terminating the scope or service]'
  '--service-type=[set the service type]:service type:(simple forking oneshot dbus notify idle exec)'
  '--uid=[run as specified system user]:user:_users'
  '--gid=[run as specified system group]:group:_groups'
  '--nice=[run with specified nice level]:nice level'
  '--working-directory=[run with specified working directory]:directory:_directories'
  {-d,--same-dir}'[use current working directory for the service]'
  '--root-directory=[run with specified root directory]:directory:_directories'
  {-R,--same-root-dir}'[use root directory of systemd-run as root directory]'
  {-E,--setenv=}'[set environment variable]:environment variable'
  {-t,--pty}'[connect stdin/stdout/stderr to the terminal via PTY]'
  {-T,--pty-late}'[like --pty but PTY communication begins after unit starts]'
  {-P,--pipe}'[inherit stdin/stdout/stderr of the transient service]'
  {-S,--shell}'[shortcut for an interactive shell in the current directory]'
  {-q,--quiet}'[suppress informational output while running]'
  {-v,--verbose}'[display unit log output while running]'
  {-G,--collect}'[unload the transient unit after it completed]'
  '--no-block[do not wait for the unit start operation to finish]'
  '--wait[synchronously wait for the transient service to terminate]'
  '--job-mode=[control how to deal with already queued jobs]:mode:(fail replace replace-irreversibly isolate ignore-dependencies ignore-requirements flush)'
  '--ignore-failure[treat non-success exit status as success]'
  '--background=[change terminal background color]:ansi color'
  '--json=[show output in JSON format]:mode:(off pretty short)'
  '--on-active=[run after specified delay]:timespan'
  '--on-boot=[run specified time after machine was booted]:timespan'
  '--on-startup=[run specified time after systemd activation]:timespan'
  '--on-unit-active=[run specified time after last activation]:timespan'
  '--on-unit-inactive=[run specified time after last deactivation]:timespan'
  '--on-calendar=[run on specified realtime calendar event]:calendar expression'
  '--on-clock-change[trigger when system clock jumps]'
  '--on-timezone-change[trigger when timezone changes]'
  '--path-property=[set property on the path unit]:property'
  '--socket-property=[set property on the socket unit]:property'
  '--timer-property=[set property on the timer unit]:property'
  '*:command:_command_names -e'
)

_arguments -s -S $arguments
