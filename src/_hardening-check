#compdef hardening-check

local -a arguments

arguments=(
  {--nopie,-p}'[do not require that the checked binaries be built as PIE]'
  {--nostackprotector,-s}'[do not require that the checked binaries be built with stack protector]'
  {--nofortify,-f}'[do not require that the checked binaries be built with Fortify]'
  {--norelro,-r}'[do not require that the checked binaries be built with RELRO]'
  {--nobindnow,-b}'[do not require that the checked binaries be built with BIND_NOW]'
  {--quiet,-q}'[only report failures.]'
  {--verbose,-v}'[report verbosely on failures.]'
  {--report-functions,-R}'[after the report, display all external functions needed by the binary]'
  {--find-libc-functions,-F}'[instead of the regular report, locate the libc for the first ELF binary]'
  {--color,-c}'[enable colorized status output.]'
  {--lintian,-l}'[switch reporting to lintian-check-parsable output.]'
  '--debug[enable debugging during processing]'
  '(- * :)'{--help,-h}'[display this help and exit]'
  {--man,-H}'[print the manual page and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
