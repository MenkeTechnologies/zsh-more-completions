#compdef jhat

local -a arguments

arguments=(
  '-J[pass flag directly to the runtime system]:flag:'
  '-stack[turn off tracking object allocation call stack.]'
  '-refs[turn off tracking of references to objects]'
  '-port[set the port for the HTTP server. Defaults to 7000]'
  '-exclude[specify a file that lists data members that should be excluded from the reachable objects query]:file:_files'
  '-baseline[specify a baseline object dump for comparison]:file:_files'
  '-debug[set debug level.]'
  '-version[report version number]'
  '(-)-h[print help and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
