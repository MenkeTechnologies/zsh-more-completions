#compdef tailscale

# Zsh completion for tailscale (mesh VPN)

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'bugreport:Print a shareable identifier to help diagnose issues'
  'cert:Get TLS certs'
  'completion:Shell tab-completion scripts'
  'configure:Configure the host to enable more Tailscale features'
  'debug:Run debug operations'
  'dns:Access DNS settings'
  'down:Disconnect from Tailscale'
  'drive:Share a directory with your tailnet'
  'exit-node:Show machines on your tailnet configured as exit nodes'
  'file:Send or receive files'
  'funnel:Turn on/off Funnel'
  'ip:Show Tailscale IP addresses'
  'licenses:Get open source license information'
  'lock:Manage tailnet lock'
  'login:Log in to a Tailscale account'
  'logout:Disconnect from Tailscale and expire current node key'
  'nc:Connect to a port on a host, connected to stdin/stdout'
  'netcheck:Print an analysis of local network conditions'
  'ping:Ping a host at the Tailscale layer, see how it routes'
  'serve:Serve content and local servers on your tailnet'
  'set:Change specified preferences'
  'ssh:SSH to a Tailscale machine'
  'status:Show state of tailscaled and its connections'
  'switch:Switches to a different Tailscale account'
  'up:Connect to Tailscale, logging in if needed'
  'update:Update Tailscale to the latest/different version'
  'version:Print Tailscale version'
  'web:Run a web server for controlling Tailscale'
  'whois:Show the machine and user associated with a Tailscale IP'
)

_arguments -C \
  '--socket=[Path to tailscaled socket]:path:_files' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'tailscale command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      up)
        _arguments \
          '--accept-dns[Accept DNS configuration from the admin panel]' \
          '--accept-risk=[Accept risk and skip confirmations for risk types]:risk:' \
          '--accept-routes[Accept routes advertised by other Tailscale nodes]' \
          '--advertise-connector[Advertise this node as an app connector]' \
          '--advertise-exit-node[Offer to be an exit node for outbound internet traffic]' \
          '--advertise-routes=[Routes to advertise to other nodes]:routes:' \
          '--advertise-tags=[ACL tags to request]:tags:' \
          '--auth-key=[Node authorization key]:key:' \
          '--exit-node=[Tailscale exit node IP or hostname to use]:node:' \
          '--exit-node-allow-lan-access[Allow direct access to local network when routing through an exit node]' \
          '--force-reauth[Force reauthentication]' \
          '--hostname=[Hostname to use instead of the one from the OS]:hostname:' \
          '--json[Output in JSON format]' \
          '--login-server=[Base URL of control server]:url:' \
          '--netfilter-mode=[Netfilter mode]:mode:(off nodivert on)' \
          '--operator=[Unix username to allow to operate on tailscaled]:user:' \
          '--qr[Show a QR code for the auth URL]' \
          '--reset[Reset unspecified settings to their default values]' \
          '--shields-up[Block incoming connections from other Tailscale nodes]' \
          '--snat-subnet-routes[Source NAT traffic to local routes]' \
          '--ssh[Run an SSH server, permitting access per tailnet admin SSH rules]' \
          '--stateful-filtering[Apply stateful filtering to forwarded packets]' \
          '--timeout=[Maximum amount of time to wait for tailscaled to enter running state]:duration:' && ret=0
        ;;
      down)
        _arguments \
          '--accept-risk=[Accept risk types]:risk:' && ret=0
        ;;
      set)
        _arguments \
          '--accept-dns=[Accept DNS configuration]:value:(true false)' \
          '--accept-risk=[Accept risk types]:risk:' \
          '--accept-routes=[Accept subnet routes]:value:(true false)' \
          '--advertise-connector=[Advertise as app connector]:value:(true false)' \
          '--advertise-exit-node=[Offer to be an exit node]:value:(true false)' \
          '--advertise-routes=[Routes to advertise]:routes:' \
          '--auto-update=[Auto-update preference]:value:(true false)' \
          '--exit-node=[Exit node IP or hostname]:node:' \
          '--exit-node-allow-lan-access=[Allow LAN access through exit node]:value:(true false)' \
          '--hostname=[Hostname override]:hostname:' \
          '--nickname=[Machine nickname]:nickname:' \
          '--operator=[Unix username for operator]:user:' \
          '--shields-up=[Block incoming connections]:value:(true false)' \
          '--ssh=[Run SSH server]:value:(true false)' \
          '--stateful-filtering=[Apply stateful filtering]:value:(true false)' \
          '--update-check=[Notify about available updates]:value:(true false)' \
          '--webclient=[Run web client]:value:(true false)' && ret=0
        ;;
      login)
        _arguments \
          '--accept-dns[Accept DNS configuration]' \
          '--accept-routes[Accept routes]' \
          '--advertise-connector[Advertise as app connector]' \
          '--advertise-exit-node[Offer to be an exit node]' \
          '--advertise-routes=[Routes to advertise]:routes:' \
          '--advertise-tags=[ACL tags to request]:tags:' \
          '--auth-key=[Node authorization key]:key:' \
          '--exit-node=[Exit node]:node:' \
          '--hostname=[Hostname override]:hostname:' \
          '--login-server=[Base URL of control server]:url:' \
          '--nickname=[Machine nickname]:nickname:' \
          '--operator=[Unix username for operator]:user:' \
          '--qr[Show QR code]' \
          '--shields-up[Block incoming connections]' \
          '--ssh[Run SSH server]' \
          '--timeout=[Timeout]:duration:' && ret=0
        ;;
      logout)
        _arguments && ret=0
        ;;
      status)
        _arguments \
          '--active[Show only active peers]' \
          '--browser[Open admin console in browser]' \
          '--json[Output in JSON format]' \
          '--peers[Show peers (default true)]' \
          '--self[Show self status (default true)]' && ret=0
        ;;
      ping)
        _arguments \
          {-c,--c}'=[Max number of pings to send]:count:' \
          '--icmp[Use ICMP Level ping]' \
          '--peerapi[Try hitting the peerapi HTTP handler]' \
          '--size=[Size of the ping message]:size:' \
          '--timeout=[Timeout before giving up on a ping]:duration:' \
          '--tsmp[Do a TSMP-level ping (through WireGuard but not TCP/UDP)]' \
          '--until-direct[Stop once a direct path is established]' \
          '--verbose[Verbose output]' \
          '1:host:' && ret=0
        ;;
      nc)
        _arguments \
          '1:hostname:' \
          '2:port:' && ret=0
        ;;
      ssh)
        _arguments \
          '*:host and args:' && ret=0
        ;;
      ip)
        _arguments \
          {-1,--1}'[Only print one IP address]' \
          {-4,--4}'[Only print IPv4 address]' \
          {-6,--6}'[Only print IPv6 address]' \
          '1:peer hostname:' && ret=0
        ;;
      netcheck)
        _arguments \
          '--every=[If non-zero, do regular net checks with this interval]:duration:' \
          '--verbose[Verbose output]' && ret=0
        ;;
      cert)
        _arguments \
          '--cert-file=[Output cert file path]:file:_files' \
          '--key-file=[Output key file path]:file:_files' \
          '--serve-demo[Serve a demo HTTPS server]' \
          '1:domain:' && ret=0
        ;;
      file)
        local -a file_cmds
        file_cmds=(
          'cp:Copy file(s) to a host'
          'get:Move files out of the Tailscale file inbox'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t file_cmds 'file subcommand' file_cmds && ret=0 ;;
          subargs)
            case "${line[1]}" in
              cp)
                _arguments \
                  '--name=[Alternate filename]:name:' \
                  '--targets[List available transfer targets]' \
                  '--verbose[Verbose output]' \
                  '*:files:_files' && ret=0
                ;;
              get)
                _arguments \
                  '--conflict=[Behavior on filename conflict]:behavior:(skip overwrite rename)' \
                  '--loop[Run in a loop, receiving files as they come in]' \
                  '--verbose[Verbose output]' \
                  '--wait=[Timeout for waiting for files]:duration:' \
                  '1:target directory:_directories' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      serve)
        _arguments \
          '--bg[Run as a background process]' \
          '--http=[Expose an HTTP server on the specified port]:port:' \
          '--https=[Expose an HTTPS server on the specified port]:port:' \
          '--set-path=[Serve on a specific path prefix]:path:' \
          '--tcp=[Expose a TCP forwarder on the specified port]:port:' \
          '--tls-terminated-tcp=[Expose a TLS-terminated TCP server]:port:' \
          '--yes[Accept all defaults]' \
          'off:Turn off serving' \
          'reset:Reset serve config' \
          'status:View current serve config' \
          '*:source:' && ret=0
        ;;
      funnel)
        _arguments \
          '--bg[Run as a background process]' \
          '--http=[Expose an HTTP server on the specified port]:port:' \
          '--https=[Expose an HTTPS server on the specified port]:port:' \
          '--set-path=[Serve on a specific path prefix]:path:' \
          '--tcp=[Expose a TCP forwarder on the specified port]:port:' \
          '--tls-terminated-tcp=[Expose a TLS-terminated TCP server]:port:' \
          '--yes[Accept all defaults]' \
          'off:Turn off Funnel' \
          'reset:Reset Funnel config' \
          'status:View current Funnel config' \
          '*:source:' && ret=0
        ;;
      lock)
        local -a lock_cmds
        lock_cmds=(
          'add:Add a tailnet lock trusted key'
          'disable:Disable tailnet lock for this tailnet'
          'disabling-secret:View the tailnet lock disabling secret'
          'init:Initialize tailnet lock for this tailnet'
          'local-disable:Disable tailnet lock for this node only'
          'log:List tailnet lock activity logs'
          'revoke-keys:Revoke tailnet lock keys'
          'sign:Sign a node key by a trusted signing key'
          'status:View the state of tailnet lock'
          'verify:Verify the tailnet lock signature of a node'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t lock_cmds 'lock subcommand' lock_cmds && ret=0 ;;
        esac
        ;;
      exit-node)
        local -a en_cmds
        en_cmds=(
          'list:Show exit nodes on your tailnet'
          'suggest:Suggest the best available exit node'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t en_cmds 'exit-node subcommand' en_cmds && ret=0 ;;
          subargs)
            case "${line[1]}" in
              list)
                _arguments \
                  '--filter=[Filter exit nodes]:filter:' \
                  '--json[Output in JSON format]' && ret=0
                ;;
              suggest)
                _arguments \
                  '--json[Output in JSON format]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      dns)
        local -a dns_cmds
        dns_cmds=(
          'query:Perform a DNS query'
          'status:View current DNS settings'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t dns_cmds 'dns subcommand' dns_cmds && ret=0 ;;
        esac
        ;;
      drive)
        local -a drive_cmds
        drive_cmds=(
          'share:Share a directory with your tailnet'
          'unshare:Unshare a directory from your tailnet'
          'rename:Rename a shared directory'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t drive_cmds 'drive subcommand' drive_cmds && ret=0 ;;
          subargs)
            case "${line[1]}" in
              share)
                _arguments \
                  '1:share name:' \
                  '2:path:_directories' && ret=0
                ;;
              unshare)
                _arguments '1:share name:' && ret=0
                ;;
              rename)
                _arguments \
                  '1:old name:' \
                  '2:new name:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      switch)
        _arguments \
          '--list[List available accounts]' \
          '1:account:' && ret=0
        ;;
      configure)
        local -a configure_cmds
        configure_cmds=(
          'kubeconfig:Configure a Kubernetes cluster kubeconfig to use a Tailscale API server proxy'
          'synology:Configure Synology to work with Tailscale'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t configure_cmds 'configure subcommand' configure_cmds && ret=0 ;;
        esac
        ;;
      update)
        _arguments \
          '--check[Check for updates only, do not install]' \
          '--dry-run[Print what would be done without doing it]' \
          '--track=[Track a specific release track]:track:(stable unstable)' \
          '--version=[Install a specific version]:version:' \
          '--yes[Skip confirmation prompt]' && ret=0
        ;;
      version)
        _arguments \
          '--daemon[Also print version of local tailscaled]' \
          '--json[Output in JSON format]' \
          '--upstream[Check for available update]' && ret=0
        ;;
      whois)
        _arguments \
          '--json[Output in JSON format]' \
          '1:ip or ip\:port:' && ret=0
        ;;
      bugreport)
        _arguments \
          '--diagnose[Run additional in-depth checks]' \
          '--record[Run and record a bugreport]' && ret=0
        ;;
      web)
        _arguments \
          '--cgi[Run as CGI script]' \
          '--dev[Run in development mode]' \
          '--listen=[Listen address]:address:' \
          '--prefix=[URL path prefix]:prefix:' && ret=0
        ;;
      debug)
        local -a debug_cmds
        debug_cmds=(
          'capture:Stream pcaps of packets traversing tailscaled'
          'daemon-goroutines:Print tailscaled goroutine stacks'
          'derp-map:Print the current DERP map'
          'doctor:Run the doctor to check for common problems'
          'local-creds:Print how to connect to local tailscaled'
          'metrics:Print tailscaled metrics'
          'netmap:Print the current netmap'
          'peer-endpoint-changes:Print changes to peer endpoints'
          'portmap:Debug portmap requests'
          'prefs:Print current prefs'
          'reload-config:Reload config'
          'set-expire-time:Set the expiry time for a node'
          'ts-logs:Stream tailscaled logs'
          'watch-ipn:Subscribe to IPN message bus'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t debug_cmds 'debug subcommand' debug_cmds && ret=0 ;;
        esac
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
