#compdef osqueryi

# Zsh completion for osqueryi (osquery interactive shell)

_arguments -s -S \
  '(- *)--help[show help message]' \
  '(- *)--version[show version information]' \
  '--json[set output mode to JSON]' \
  '--csv[set output mode to CSV]' \
  '--line[set output mode to line]' \
  '--list[set output mode to list]' \
  '--header[toggle column headers in output]' \
  '--separator[set output field separator]:separator:' \
  {-S,--socket}'[path to osqueryd socket]:socket path:_files' \
  '--connect[connect to remote host]:host:_hosts' \
  '--database_path[path to database file]:path:_files -/' \
  '--extensions_socket[path to extensions socket]:socket path:_files' \
  '--extensions_autoload[path to autoload extensions]:path:_files' \
  '--extensions_timeout[timeout for extension startup]:seconds:' \
  '--disable_extensions[disable extension loading]' \
  '--config_path[path to configuration file]:file:_files' \
  '--config_plugin[configuration plugin name]:plugin:' \
  '--logger_path[path for log files]:path:_files -/' \
  '--logger_plugin[logger plugin name]:plugin:' \
  '--disable_logging[disable logging]' \
  '--verbose[enable verbose informational messages]' \
  {-A,--enable_tables}'[comma-separated list of table names to enable]:tables:' \
  {-L,--list}'[list all available tables]' \
  '--planner[enable query planner output]' \
  '*:SQL file:_files -g "*.sql"'
