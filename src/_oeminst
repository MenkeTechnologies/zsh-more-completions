#compdef oeminst
# Documentation: https://man.archlinux.org/search?q=oeminst
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-v[verbose]'
  '-n[dont install, show where files would be installed]'
  '-c[dont install, save files to current directory]'
  '-S[specify the install scope u = user (def.), l = local system\]]'
  '*:filename:_files'
)

_arguments -s -S $arguments
