#compdef affdiskprint
# Documentation: https://man.archlinux.org/search?q=affdiskprint
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-x[verify the diskprint]'
  '-V[just print the version number and exit.]'
  '-h[print this help.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
