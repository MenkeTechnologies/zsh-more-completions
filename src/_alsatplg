#compdef alsatplg
# Documentation: https://man.archlinux.org/search?q=alsatplg
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[help]'
  {-c,--compile}'[compile file]'
  {-v,--verbose}'[set verbosity level (0...1)]'
  {-o,--output}'[set output file]'
  '*:filename:_files'
)

_arguments -s -S $arguments
