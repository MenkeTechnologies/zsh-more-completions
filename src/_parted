#compdef parted

# Zsh completion for GNU parted (partition editor)
# Covers parted 3.6+ options and commands

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a parted_commands=(
  'align-check:check partition alignment (TYPE N)'
  'disk_set:change a flag on the disk (FLAG STATE)'
  'disk_toggle:toggle the state of FLAG on the disk'
  'help:print general help or help on COMMAND'
  'mklabel:create a new disk label (LABEL-TYPE)'
  'mktable:create a new disk label (alias for mklabel)'
  'mkpart:create a new partition (PART-TYPE FS-TYPE START END)'
  'name:set the name of partition NUMBER to NAME'
  'print:display the partition table or partition'
  'quit:exit parted'
  'rescue:rescue a lost partition near START and END'
  'resizepart:resize partition NUMBER'
  'rm:delete partition NUMBER'
  'select:choose the device to edit (DEVICE)'
  'set:change a flag on partition NUMBER (NUMBER FLAG STATE)'
  'toggle:toggle the state of FLAG on partition NUMBER'
  'type:change type-id or type-uuid of partition NUMBER (LUKS2 only)'
  'unit:set the default unit to UNIT'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[display help message and exit]' \
  '(- *)'{-v,--version}'[display version information and exit]' \
  {-l,--list}'[list partition layout on all block devices]' \
  {-m,--machine}'[display machine-parseable output]' \
  {-j,--json}'[display JSON output]' \
  {-s,--script}'[never prompt for user intervention]' \
  {-f,--fix}'[automatically fix exceptions in script mode]' \
  {-a,--align}'[alignment type for new partitions]:alignment type:(none cylinder minimal optimal)' \
  '1:device:_files -g "*(-%)"' \
  '*:command:->commands' && ret=0

case "$state" in
  commands)
    _describe -t commands 'parted command' parted_commands && ret=0
    ;;
esac

return ret
