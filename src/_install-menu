#compdef install-menu
# Documentation: https://man.archlinux.org/search?q=install-menu
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[this message]'
  '--remove[remove the menu instead of generating it.]'
  {-v,--verbose}'[be verbose]'
  '*:filename:_files'
)

_arguments -s -S $arguments
