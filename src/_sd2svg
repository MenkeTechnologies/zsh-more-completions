#compdef sd2svg
# Documentation: https://man.archlinux.org/search?q=sd2svg
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[show this help message]'
  '-o[write ouput to OUTPUT]'
  '-N[output the number of sheets]'
  '-n[choose the page to convert (1: means first page)]'
  '-v[show version information]'
  '*:filename:_files'
)

_arguments -s -S $arguments
