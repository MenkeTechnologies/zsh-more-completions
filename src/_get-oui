#compdef get-oui
# Documentation: https://man.archlinux.org/search?q=get-oui
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[this usage message.]'
  '-f[specify the output OUI file. Default=ieee-oui.txt]'
  '-u[specify the URL to fetch the OUI data from.]'
  '-v[verbose progress messages.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
