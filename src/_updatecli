#compdef updatecli

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a cmds=(
      'apply:apply changes'
      'diff:show diff of changes'
      'manifest:manage manifests'
      'show:show configuration'
      'version:show version'
      'completion:generate shell completion'
    )
    _describe -t commands 'updatecli command' cmds && ret=0
    ;;
  args)
    case "${words[1]}" in
      apply|diff)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'[config file]:config file:_files' \
          '(-v --values)'{-v,--values}'[values file]:values file:_files' \
          '(-s --secrets)'{-s,--secrets}'[secrets file]:secrets file:_files' \
          '--disable-tls[disable TLS verification]' \
          '--clean[clean temporary files]' && ret=0
        ;;
      manifest)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'[config file]:config file:_files' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac
return ret
