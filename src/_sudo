#compdef sudo

local -a arguments

arguments=(
  {-A,--askpass}'[use a helper program for password prompting]'
  {-b,--background}'[run command in the background]'
  {-B,--bell}'[ring bell when prompting]'
  {-C,--close-from=}'[close all file descriptors >= num]:fd num:'
  {-D,--chdir=}'[change the working directory before running command]:directory:_directories'
  {-E,--preserve-env}'[preserve user environment when running command]'
  '--preserve-env=[preserve specific environment variables]:variable list:'
  {-e,--edit}'[edit files instead of running a command]'
  {-g,--group=}'[run command as the specified group name or ID]:group:_groups'
  {-H,--set-home}'[set HOME variable to target user'\''s home dir]'
  '(- * :)'{-h,--help}'[display help message and exit]'
  {-h,--host=}'[run command on host (if supported by plugin)]:host:_hosts'
  {-i,--login}'[run login shell as the target user]'
  {-K,--remove-timestamp}'[remove timestamp file completely]'
  {-k,--reset-timestamp}'[invalidate timestamp file]'
  {-l,--list}'[list user'\''s privileges or check a specific command]'
  {-n,--non-interactive}'[non-interactive mode, no prompts are used]'
  {-N,--no-update}'[do not update user'\''s timestamp]'
  {-P,--preserve-groups}'[preserve group vector instead of setting to target'\''s]'
  {-p,--prompt=}'[use the specified password prompt]:prompt:'
  {-R,--chroot=}'[change the root directory before running command]:directory:_directories'
  {-r,--role=}'[create SELinux security context with specified role]:role:'
  {-S,--stdin}'[read password from standard input]'
  {-s,--shell}'[run shell as the target user]'
  {-t,--type=}'[create SELinux security context with specified type]:type:'
  {-T,--command-timeout=}'[terminate command after the specified time limit]:timeout (seconds):'
  {-U,--other-user=}'[in list mode, display privileges for user]:user:_users'
  {-u,--user=}'[run command (or edit file) as specified user name or ID]:user:_users'
  '(- * :)'{-V,--version}'[display version information and exit]'
  {-v,--validate}'[update user'\''s timestamp without running a command]'
  '(-):command: _command_names -e'
  '*::arguments:_normal'
)

_arguments -s -S $arguments
