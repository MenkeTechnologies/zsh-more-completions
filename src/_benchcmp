#compdef benchcmp
# Documentation: https://man.archlinux.org/search?q=benchcmp
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-best[compare best times from old and new]'
  '-changed[show only benchmarks that have changed]'
  '-mag[sort benchmarks by magnitude of change]'
  '*:filename:_files'
)

_arguments -s -S $arguments
