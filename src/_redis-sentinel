#compdef redis-server redis-sentinel
# Documentation: https://man.archlinux.org/search?q=redis-server
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '--sentinel[Run in sentinel mode.]'
    '--test-memory[Run a memory check and exit.]:megabytes'
    '-h[Output this help and exit.]'
    '--help'
    '--version'
    '-v[Output version and exit.]'
    '--port[port]'
    '*:filename:_files'
)
_arguments -s -S $arguments
