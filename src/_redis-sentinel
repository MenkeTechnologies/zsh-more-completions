#compdef redis-server redis-sentinel


local -a arguments

arguments=(
    '--sentinel[Run in sentinel mode.]'
    '--test-memory[Run a memory check and exit.]:megabytes'
    '-h[Output this help and exit.]'
    '--help[.]'
    '--version[.]'
    '-v[Output version and exit.]'
    '--port[port EXAMPLES.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
