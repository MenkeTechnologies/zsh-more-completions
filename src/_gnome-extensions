#compdef gnome-extensions

local -a arguments

arguments=(
    {--quiet,-q}'[do not print error messages]'
    '--user[show user extensions]'
    '--system[show system extensions]'
    '--enabled[show enabled extensions]'
    '--disabled[show disabled extensions]'
    '--prefs[open preferences]'
    '--updates[show updates]'
    {-d,--details}'[show detailed information]'
    '--name[set extension name]:name:'
    '--description[set extension description]:description:'
    '--uuid[set extension UUID]:uuid:'
    '--template[set extension template]:template:_files'
    {-i,--interactive}'[use interactive mode]'
    '--extra-source[add extra source file]:source:_files'
    '--schema[set GSettings schema]:schema:'
    '--podir[set directory for translation files]:directory:_directories'
    '--gettext-domain[set gettext domain]:domain:'
    {-f,--force}'[force operation]'
    {-o,--out-dir}'[set output directory]:directory:_directories'
    '*:filename:_files'
)
_arguments -s -S $arguments
