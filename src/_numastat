#compdef numastat
# Documentation: https://man.archlinux.org/search?q=numastat
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-c[minimize column widths]'
  '-m[show meminfo-like system-wide memory usage]'
  '-n[show the numastat statistics info]'
  '-p[to show process info]'
  '-s[to sort data by total column or <node>]'
  '-v[make some reports more verbose]'
  '-V[show the /usr/bin/numastat code version]'
  '-z[skip rows and columns of zeros]'
  '*:filename:_files'
)

_arguments -s -S $arguments
