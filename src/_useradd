#compdef useradd

# Completion for useradd (shadow-utils)
# https://github.com/shadow-maint/shadow

_useradd() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a arguments

    arguments=(
        {-b,--base-dir}'[default base directory for the home directory]:base directory:_directories'
        '--btrfs-subvolume-home[use BTRFS subvolume for home directory]'
        {-c,--comment}'[GECOS field of the new account]:comment:'
        {-d,--home-dir}'[home directory of the new account]:home directory:_directories'
        {-D,--defaults}'[print or change default useradd configuration]'
        {-e,--expiredate}'[expiration date of the new account (YYYY-MM-DD)]:expiration date:'
        {-f,--inactive}'[password inactivity period of the new account]:inactive days:'
        {-F,--add-subids-for-system}'[add subordinate IDs for system users]'
        {-g,--gid}'[name or ID of the primary group of the new account]:primary group:_groups'
        {-G,--groups}'[list of supplementary groups of the new account]:supplementary groups:_sequence _groups'
        '(- * :)'{-h,--help}'[display help message and exit]'
        {-k,--skel}'[use this alternative skeleton directory]:skeleton directory:_directories'
        {-K,--key}'[override /etc/login.defs defaults (KEY=VALUE)]:key=value:'
        {-l,--no-log-init}'[do not add the user to the lastlog and faillog databases]'
        {-m,--create-home}'[create the user'\''s home directory]'
        {-M,--no-create-home}'[do not create the user'\''s home directory]'
        {-N,--no-user-group}'[do not create a group with the same name as the user]'
        {-o,--non-unique}'[allow creating users with duplicate (non-unique) UID]'
        {-p,--password}'[encrypted password of the new account]:encrypted password:'
        {-P,--prefix}'[directory prefix for etc files]:prefix directory:_directories'
        {-r,--system}'[create a system account]'
        {-R,--root}'[directory to chroot into]:chroot directory:_directories'
        {-s,--shell}'[login shell of the new account]:login shell:_files -g "*(*)"'
        {-u,--uid}'[user ID of the new account]:UID:'
        {-U,--user-group}'[create a group with the same name as the user]'
        {-Z,--selinux-user}'[use a specific SEUSER for the SELinux user mapping]:SELinux user:'
        '1:username:'
    )

    _arguments -s -S $arguments && ret=0
    return ret
}

_useradd "$@"
