#compdef age-keygen

# Zsh completion for age-keygen - generate age key pairs

_arguments -s -S \
  '(-o --output)'{-o,--output}'[write result to file (default: standard output)]:file:_files' \
  '-y[convert an identity file to a recipients file]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-h --help)'{-h,--help}'[print help]' \
  '*:file:_files'
