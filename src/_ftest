#compdef ftest

local -a arguments

arguments=(
  '-f[force operation]'
  '-c[configuration file]'
  '-v[verbose output]'
  '-d[0.25 = 250 ms>]'
  '-s[time, 1 = 1 s>]'
  '-e[method>]'
  '-t[type or time]'
  '-r[connection>]'
  '-F[connection>]'
  '-g[fragments number, es. 4|IP fragments size, es. 16b>]'
  '-p[segments number, es. 4|TCP segments size, es 6b>]'
  '-k[value, es. 60000>]'
  '-m[mode or machine]'
  '*:filename:_files'
)

_arguments -s -S $arguments
