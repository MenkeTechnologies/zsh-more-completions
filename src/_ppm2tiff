#compdef ppm2tiff
# Documentation: https://man.archlinux.org/search?q=ppm2tiff
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-r[make each strip have no more than the given number of rows]:rows'
  '-R[set x&y resolution (dpi)]:resolution'
  '-c[compression scheme (jpeg, lzw, deflate, packbits, g3, g4, none)]:scheme:(jpeg lzw deflate packbits g3 g4 none)'
  '*:filename:_files'
)

_arguments -s -S $arguments
