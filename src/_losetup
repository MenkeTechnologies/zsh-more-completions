#compdef losetup

local arguments

arguments=(
  {-a,--all}'[show the status of all loop devices]'
  {-d,--detach}'[detach the file or device associated with the specified loop device(s)]:loop device:_files -g "/dev/loop*"'
  {-D,--detach-all}'[detach all associated loop devices]'
  {-f,--find}'[find the first unused loop device]'
  {-c,--set-capacity}'[force the loop driver to reread the size of the file]:loop device:_files -g "/dev/loop*"'
  {-j,--associated}'[show the status of all loop devices associated with the given file]:file:_files'
  {-L,--nooverlap}'[check for conflicts between loop devices to avoid sharing]'
  {-o,--offset}'[the data start is moved offset bytes into the file]:offset (bytes)'
  '--loop-ref[set the reference string for the loop device]:string'
  '--sizelimit[device is limited to specified bytes of the file]:size (bytes)'
  {-b,--sector-size}'[set the logical sector size of the loop device in bytes]:size (bytes)'
  {-P,--partscan}'[force the kernel to scan the partition table on a newly created device]'
  {-r,--read-only}'[set up a read-only loop device]'
  '--direct-io[enable or disable direct I/O for the backing file]::on or off:(on off)'
  '--show[display the name of the assigned loop device (with -f)]'
  {-v,--verbose}'[verbose mode]'
  {-l,--list}'[print default columns for all or specified loop devices]'
  {-O,--output}'[specify the columns to be printed for --list output]:list'
  '--output-all[output all available columns]'
  {-n,--noheadings}'[do not print headings for --list output]'
  '--raw[use raw --list output format]'
  {-J,--json}'[use JSON format for --list output]'
  '--remove[remove specified loop device(s) completely]:loop device:_files -g "/dev/loop*"'
  '(- * :)'{-h,--help}'[display help text and exit]'
  '(- * :)'{-V,--version}'[display version information and exit]'
  '*:file:_files'
)

_arguments -s $arguments
