#compdef timg

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-g+[output geometry (WxH)]:geometry' \
  '--grid=[arrange images in columns]:columns' \
  '-p+[pixel style]:style:(quarter half kitty iterm2 sixel)' \
  '--pixelation=[pixel style]:style:(quarter half kitty iterm2 sixel)' \
  '-C[center image]' \
  '--center[center image]' \
  '-W[fit width]' \
  '--fit-width[fit width]' \
  '-U[upscale image]' \
  '--upscale[upscale image]' \
  '-b+[background color]:color' \
  '--background=[background color]:color' \
  '-B+[checkerboard background for transparency]:color' \
  '--auto-crop=[auto crop]:mode:(on off)' \
  '--rotate=[rotate image]:degrees:(0 90 180 270)' \
  '-t+[display duration for animations]:duration' \
  '--title[display filename as title]' \
  '-f+[frame count limit for animations]:frame count' \
  '--frames=[frame count limit for animations]:frame count' \
  '-a[play animations]' \
  '--loops=[loop count for animations]:loops' \
  '-c+[number of animation cycles]:cycles' \
  '-V[verbose output]' \
  '--verbose[verbose output]' \
  '--compress[use compression for protocols that support it]' \
  '--threads=[number of threads]:threads' \
  '-o+[output to file]:output file:_files' \
  '--output=[output to file]:output file:_files' \
  '--clear[clear screen before display]' \
  '*:file:_files' && ret=0

return ret
