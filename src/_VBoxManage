#compdef VBoxManage

local curcontext="$curcontext" state state_descr line
typeset -A opt_args

local -a subcommands
subcommands=(
    'list:list VMs, host info, etc.'
    'showvminfo:show VM configuration details'
    'registervm:register a VM'
    'unregistervm:unregister a VM'
    'createvm:create a new VM'
    'modifyvm:modify VM settings'
    'clonevm:clone a VM'
    'movevm:move a VM to a new location'
    'import:import an OVF/OVA appliance'
    'export:export VMs as OVF/OVA'
    'startvm:start a VM'
    'controlvm:control a running VM'
    'snapshot:manage VM snapshots'
    'closemedium:close a medium (disk/DVD/floppy)'
    'storageattach:attach a storage medium to a VM'
    'storagectl:manage storage controllers'
    'bandwidthctl:manage bandwidth groups'
    'showmediuminfo:show medium info'
    'createmedium:create a new disk image'
    'modifymedium:modify a medium'
    'clonemedium:clone a medium'
    'mediumproperty:manage medium properties'
    'encryptmedium:encrypt a medium'
    'checkmediumpwd:check medium encryption password'
    'convertfromraw:convert raw disk image to VDI'
    'setextradata:set extra data'
    'getextradata:get extra data'
    'setproperty:set global properties'
    'usbfilter:manage USB filters'
    'usbdevsource:manage USB device sources'
    'sharedfolder:manage shared folders'
    'guestproperty:manage guest properties'
    'guestcontrol:control guest OS'
    'metrics:manage performance metrics'
    'natnetwork:manage NAT networks'
    'hostonlyif:manage host-only interfaces'
    'hostonlynet:manage host-only networks'
    'dhcpserver:manage DHCP servers'
    'debugvm:debug a VM'
    'extpack:manage extension packs'
    'unattended:unattended guest OS install'
    'cloud:manage cloud instances'
    'cloudprofile:manage cloud profiles'
    'signova:sign an OVA'
    'modifynvram:modify NVRAM variables'
    'updatecheck:manage update checks'
)

_arguments -s -S \
    '--nologo[suppress logo output]' \
    '--settingspw=[specify settings password]:password' \
    '--settingspwfile=[specify settings password file]:file:_files' \
    '1:subcommand:->subcmd' \
    '*::arguments:->args'

case $state in
    subcmd)
        _describe -t subcommands 'VBoxManage subcommand' subcommands
        ;;
    args)
        case $words[1] in
            list)
                local -a list_opts
                list_opts=(
                    'vms' 'runningvms' 'ostypes' 'hostdvds' 'hostfloppies'
                    'intnets' 'bridgedifs' 'hostonlyifs' 'hostonlynets'
                    'natnets' 'dhcpservers' 'hostinfo' 'hostcpuids'
                    'hddbackends' 'hdds' 'dvds' 'floppies' 'usbhost'
                    'usbfilters' 'systemproperties' 'extpacks' 'groups'
                    'webcams' 'screenshotformats' 'cloudproviders'
                    'cloudprofiles' 'cloudnets' 'cpu-profiles'
                )
                _arguments \
                    '-l[long format]' \
                    '--long[long format]' \
                    '-s[sorted output]' \
                    '--sorted[sorted output]' \
                    '1:what to list:(${list_opts})'
                ;;
            startvm)
                _arguments \
                    '--type=[start type]:(gui sdl headless separate)' \
                    '--putenv=[set environment variable]:VAR=VALUE' \
                    '1:VM name or UUID:'
                ;;
            controlvm)
                local -a control_actions
                control_actions=(
                    'pause' 'resume' 'reset' 'poweroff' 'savestate'
                    'acpipowerbutton' 'acpisleepbutton' 'keyboardputscancode'
                    'keyboardputstring' 'keyboardputfile' 'setlinkstate1'
                    'nic1' 'nic2' 'nic3' 'nic4' 'clipboard'
                    'draganddrop' 'vrde' 'vrdeport' 'vrdeproperty'
                    'setvideomodehint' 'screenshotpng' 'recording'
                    'webcam' 'addencpassword' 'removeencpassword'
                    'removeallencpasswords' 'changeuartmode1'
                    'audioin' 'audioout'
                )
                _arguments \
                    '1:VM name or UUID:' \
                    '2:action:(${control_actions})'
                ;;
            modifyvm)
                _arguments \
                    '--name=[new VM name]:name' \
                    '--groups=[VM groups]:groups' \
                    '--description=[description]:description' \
                    '--ostype=[OS type]:type' \
                    '--iconfile=[icon file]:file:_files' \
                    '--memory=[memory size in MB]:megabytes' \
                    '--vram=[video memory in MB]:megabytes' \
                    '--cpus=[number of CPUs]:count' \
                    '--cpuexecutioncap=[CPU execution cap %]:percent' \
                    '--firmware=[firmware type]:(bios efi efi32 efi64)' \
                    '--boot1=[boot device 1]:(none floppy dvd disk net)' \
                    '--boot2=[boot device 2]:(none floppy dvd disk net)' \
                    '--boot3=[boot device 3]:(none floppy dvd disk net)' \
                    '--boot4=[boot device 4]:(none floppy dvd disk net)' \
                    '--acpi=[enable ACPI]:(on off)' \
                    '--ioapic=[enable I/O APIC]:(on off)' \
                    '--pae=[enable PAE]:(on off)' \
                    '--nested-hw-virt=[enable nested virtualization]:(on off)' \
                    '--audio=[audio driver]:(none default null oss alsa pulse coreaudio)' \
                    '--clipboard=[clipboard mode]:(disabled hosttoguest guesttohost bidirectional)' \
                    '--draganddrop=[drag and drop mode]:(disabled hosttoguest guesttohost bidirectional)' \
                    '--nic1=[NIC 1 type]:(none null nat bridged intnet hostonly generic natnetwork cloud)' \
                    '--nic2=[NIC 2 type]:(none null nat bridged intnet hostonly generic natnetwork cloud)' \
                    '--nictype1=[NIC 1 adapter type]:(Am79C970A Am79C973 82540EM 82543GC 82545EM virtio)' \
                    '--bridgeadapter1=[bridge adapter 1]:adapter' \
                    '--natpf1=[NAT port forward rule]:rule' \
                    '--usb=[enable USB]:(on off)' \
                    '--usbehci=[enable USB 2.0]:(on off)' \
                    '--usbxhci=[enable USB 3.0]:(on off)' \
                    '--vrde=[enable VRDE]:(on off)' \
                    '--vrdeport=[VRDE port]:port' \
                    '1:VM name or UUID:'
                ;;
            snapshot)
                _arguments \
                    '1:VM name or UUID:' \
                    '2:action:(take delete restore restorecurrent edit list showvminfo)'
                ;;
            createvm)
                _arguments \
                    '--name=[VM name]:name' \
                    '--groups=[groups]:groups' \
                    '--ostype=[OS type]:type' \
                    '--register[register the VM]' \
                    '--basefolder=[base folder]:folder:_directories' \
                    '--default[apply default settings]'
                ;;
            createmedium)
                _arguments \
                    '--filename=[output file]:file:_files' \
                    '--size=[size in MB]:megabytes' \
                    '--sizebyte=[size in bytes]:bytes' \
                    '--format=[format]:(VDI VMDK VHD)' \
                    '--variant=[variant]:(Standard Fixed Split2G Stream ESX Formatted)' \
                    '--property=[property]:name=value' \
                    '--property-file=[property file]:file:_files'
                ;;
            import)
                _arguments \
                    '--dry-run[show import parameters without importing]' \
                    '--options=[import options]:(keepallmacs keepmacsonnicx keepdisknamesondiskimagesimp)' \
                    '*:OVF/OVA file:_files -g "*.{ovf,ova}"'
                ;;
            export)
                _arguments \
                    '-o[output file]:file:_files -g "*.{ovf,ova}"' \
                    '--output=[output file]:file:_files -g "*.{ovf,ova}"' \
                    '--manifest[create manifest file]' \
                    '--options=[export options]' \
                    '--ovf10[OVF 1.0 format]' \
                    '--ovf20[OVF 2.0 format]' \
                    '*:VM name or UUID:'
                ;;
            *)
                _default
                ;;
        esac
        ;;
esac
