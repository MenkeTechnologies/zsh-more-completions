#compdef airolib-ng

local -a arguments

arguments=(
  '--stats[Output information about the database.]'
  '--sql[Execute specified SQL statement.]'
  '--clean[Clean the database from old junk. all will also]'
  '--batch[Start batch-processing all combinations of ESSIDs]'
  '--verify[Verify a set of randomly chosen PMKs.]'
  '--import[import passwords/essids from file]:file:_files'
  '--import[import passwords/essids from file]:file:_files'
  '--export[export passwords/essids to file]:essid: :file:_files'
  '*:filename:_files'
)

_arguments -s -S $arguments
