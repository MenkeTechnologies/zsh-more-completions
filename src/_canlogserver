#compdef canlogserver
# Documentation: https://man.archlinux.org/search?q=canlogserver
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-m[initial filter mask (default 0x00000000)]:mask:'
  '-v[initial filter value (default 0x00000000)]:value:'
  '-i[invert the specified ID filter]:flag:(0 1)'
  '-e[mask for error frames]:mask:'
  '-p[listen on port (default: 28700)]:port:'
  '*:filename:_files'
)

_arguments -s -S $arguments
