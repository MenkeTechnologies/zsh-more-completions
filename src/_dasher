#compdef dasher
# Documentation: https://man.archlinux.org/search?q=dasher
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    {-a,--appstyle}'[Application style.]'
    {-?,--help}'[Describe command line options.]'
    '--help-options[Describe the options available with --options\\FR.]'
    {-o,--options}'[Override stored options.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
