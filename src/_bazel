#compdef bazel

# Zsh completion for bazel - build tool

local curcontext="$curcontext" state line ret=1

local -a global_opts=(
  '(-h --help)'{-h,--help}'[show help]'
  '--version[show version]'
  '--output_base[set output base directory]:dir:_files -/'
  '--output_user_root[set output user root]:dir:_files -/'
  '--batch[run in batch mode]'
  '--batch_cpu_scheduling[use batch CPU scheduling]'
  '--block_for_lock[wait for a running command to complete]'
  '--client_debug[enable client debug logging]'
  '--connect_timeout_secs[set connection timeout]:seconds:'
  '--home_rc[look for the home bazelrc file]'
  '--ignore_all_rc_files[ignore all rc files]'
  '--nosystem_rc[ignore the system-wide bazelrc]'
  '--noworkspace_rc[ignore the workspace bazelrc]'
  '--blazerc[read the given rc file]:file:_files'
)

local -a subcommands=(
  'build:build the specified targets'
  'test:build and run the specified test targets'
  'run:run the specified target'
  'query:execute a dependency graph query'
  'aquery:execute an action graph query'
  'cquery:execute a configured target query'
  'info:display runtime info about the bazel server'
  'clean:remove output files and optionally stop the server'
  'fetch:fetch external repositories for targets'
  'sync:sync all repositories in the workspace'
  'version:show version information'
  'shutdown:stop the bazel server'
  'help:show help for a command or topic'
  'analyze-profile:analyze build profile data'
  'canonicalize-flags:canonicalize a list of bazel options'
  'dump:dump the internal state of the bazel server'
  'mobile-install:install targets to mobile devices'
  'coverage:generate code coverage report for tests'
  'print_action:print the command line args for compiling a file'
)

local -a build_opts=(
  '(-c --compilation_mode)'{-c,--compilation_mode}'[set compilation mode]:mode:(fastbuild opt dbg)'
  '--config[select additional config sections]:config name:'
  '--cpu[set target CPU architecture]:arch:'
  '--crosstool_top[set the crosstool top label]:label:'
  '--define[set a build variable]:key=value:'
  '--deleted_packages[packages to consider deleted]:package:'
  '--disk_cache[set disk cache directory]:dir:_files -/'
  '--distdir[additional directories to search for archives]:dir:_files -/'
  '--dynamic_mode[set dynamic linking mode]:mode:(off default fully)'
  '--features[set build features]:feature:'
  '--host_cpu[set the host CPU]:arch:'
  '(-j --jobs)'{-j,--jobs}'[number of concurrent jobs]:n:'
  '(-k --keep_going)'{-k,--keep_going}'[continue as much as possible after an error]'
  '--loading_phase_threads[number of loading phase threads]:n:'
  '--output_filter[filter output with regex]:regex:'
  '--output_groups[set output groups to build]:group:'
  '--package_path[set the colon-separated package path]:path:'
  '--platforms[set the target platform]:label:'
  '--profile[write a profile to the given file]:file:_files'
  '--remote_cache[set remote cache URL]:url:'
  '--remote_executor[set remote executor URL]:url:'
  '--sandbox_debug[enable sandbox debug mode]'
  '--show_progress[show progress messages]'
  '--show_timestamps[include timestamps in messages]'
  '--stamp[stamp binaries with build info]'
  '--strategy[set the build strategy]:mnemonic=strategy:'
  '--symlink_prefix[set the prefix for symlinks]:prefix:'
  '--verbose_failures[show full command lines of failed commands]'
  '--worker_sandboxing[use sandboxing for workers]'
)

local -a test_opts=(
  '--test_arg[pass an argument to the test binary]:arg:'
  '--test_env[set an environment variable for tests]:key=value:'
  '--test_filter[set the test filter]:filter:'
  '--test_output[set the test output mode]:mode:(errors all streamed summary)'
  '--test_tag_filters[filter by test tags]:tags:'
  '--test_timeout[set the test timeout]:seconds:'
)

_arguments -s -S \
  $global_opts \
  '1:subcommand:->subcmd' \
  '*::args:->args' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'bazel subcommand' subcommands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (build)
        _arguments -s -S $build_opts '*:target:_files' && ret=0
        ;;
      (test|coverage)
        _arguments -s -S $build_opts $test_opts '*:target:_files' && ret=0
        ;;
      (run)
        _arguments -s -S \
          $build_opts \
          '--script_path[write a script to run the target]:file:_files' \
          '*:target:_files' && ret=0
        ;;
      (query|aquery|cquery)
        _arguments -s -S \
          '--output[set the output format]:format:(label minrank maxrank package location graph xml proto jsonproto)' \
          '(-k --keep_going)'{-k,--keep_going}'[continue on errors]' \
          '--noimplicit_deps[do not include implicit dependencies]' \
          '--nohost_deps[do not include host dependencies]' \
          '--notool_deps[do not include tool dependencies]' \
          '*:query expression:' && ret=0
        ;;
      (clean)
        _arguments -s -S \
          '--expunge[remove the entire output base tree]' \
          '--async[perform clean asynchronously]' && ret=0
        ;;
      (info)
        local -a info_keys=(
          'bazel-bin:output directory for binaries'
          'bazel-genfiles:output directory for generated files'
          'bazel-testlogs:output directory for test logs'
          'command_log:location of the command log'
          'execution_root:execution root directory'
          'install_base:installation base directory'
          'java-home:location of the JDK'
          'output_base:output base directory'
          'output_path:output path'
          'release:release information'
          'server_pid:PID of the bazel server'
          'workspace:workspace root directory'
        )
        _describe -t info-keys 'info key' info_keys && ret=0
        ;;
      (fetch|sync)
        _arguments -s -S '*:target:_files' && ret=0
        ;;
      (help)
        _describe -t subcommands 'help topic' subcommands && ret=0
        ;;
      (*)
        _arguments -s -S $global_opts '*:arguments:' && ret=0
        ;;
    esac
    ;;
esac

return ret
