#compdef plistutil
# Documentation: https://man.archlinux.org/search?q=plistutil
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-i,--infile}'[The file to read in.]'
  {-o,--outfile}'[The file to convert to.]'
  {-d,-v,--debug}'[Provide extended debug information.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
