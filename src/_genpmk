#compdef genpmk
# Documentation: https://man.archlinux.org/search?q=genpmk
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-f[file]'
  '-d[hash file]'
  '-s[SSID]'
  '-h[this help information and exit]'
  '-v[verbose information (more -v for more verbosity)]'
  '-V[program version and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
