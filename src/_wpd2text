#compdef wpd2text
# Documentation: https://man.archlinux.org/search?q=wpd2text
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--info[display document metadata instead of the text]'
  '--help[show this help message]'
  '--password[try to decrypt password protected document]'
  '--version[print version and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
