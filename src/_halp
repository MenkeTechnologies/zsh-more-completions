#compdef halp

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-c --check)'{-c,--check}'[check if help text is available]' \
  '--config[path to config file]:config file:_files' \
  '(-m --man)'{-m,--man}'[display man page]' \
  '--no-pager[do not pipe output to a pager]' \
  '(-p --pager)'{-p,--pager}'[pager command]:pager command' \
  '(-P --plumber)'{-P,--plumber}'[plumber command]:plumber command' \
  '(-t --ttl)'{-t,--ttl}'[time to live for cache]:duration' \
  '(-u --update)'{-u,--update}'[update cached help text]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:_command_names' && ret=0
return ret
