#compdef samba-ldbdump
# Documentation: https://man.archlinux.org/search?q=samba-ldbdump
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[this help message]'
  '-d[dumps DN only]'
  '-e[emergency dump, for corrupt databases]'
  '-i[include index and @BASEINFO records in dump]'
  '-c[validate contents of the records]'
  '*:filename:_files'
)

_arguments -s -S $arguments
