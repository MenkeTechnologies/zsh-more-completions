#compdef specify
# Documentation: https://man.archlinux.org/search?q=specify
# Reference accessed: 2026-05-16

# Zsh completion for Spec Kit CLI (specify)

local -a commands
commands=(
  'init:Initialize a new Spec Kit project'
  'check:Verify system requirements'
  'version:Check the installed version'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[Print help message]' \
  '1: :_describe -t commands "command" commands' \
  '*:: :->args'

case $words[1] in
  init)
    _arguments \
      '--integration=[Specify agent integration]:agent:(claude copilot gemini)' \
      '*:directory:_files -/'
    ;;
esac
