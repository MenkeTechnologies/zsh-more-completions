#compdef susetags2solv
# Documentation: https://man.archlinux.org/search?q=susetags2solv
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-b[save as multiple files starting with <base>]'
  '-c[parse given contentfile (for product information)]'
  '-d[do not read from stdin, but use data in descrdir]'
  '-h[print help & exit]'
  '-n[save attributes as <name>.attr]'
  '*:filename:_files'
)

_arguments -s -S $arguments
