#compdef fdisk

# Zsh completion for fdisk (util-linux partition table manipulator)
# Covers util-linux 2.40+ fdisk options

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[display help text and exit]' \
  '(- *)'{-V,--version}'[display version information and exit]' \
  {-b,--sector-size}'[specify physical and logical sector size]:sector size (bytes):(512 1024 2048 4096)' \
  {-B,--protect-boot}'[do not erase the beginning of the first disk sector when creating a new disk label]' \
  {-c,--compatibility=-}'[compatibility mode]:mode:(dos nondos)' \
  {-L,--color=-}'[colorize output]:when:(auto always never)' \
  {-l,--list}'[list partition tables for the specified devices and then exit]' \
  {-x,--list-details}'[like --list but with extra detail for partition tables]' \
  '--lock=-[use exclusive device lock]:mode:(yes no nonblock)' \
  {-n,--noauto-pt}'[do not automatically create a default partition table on empty device]' \
  {-o,--output}'[specify output columns]:columns' \
  {-t,--type}'[recognize only the specified partition table type]:type:(aix bsd dos gpt mac mbr minix sgi solaris sun)' \
  {-u,--units=-}'[display units for partition sizes]:units:(cylinders sectors)' \
  {-s,--getsz}'[print the size of the device in 512-byte sectors (DEPRECATED)]' \
  {-C,--cylinders}'[specify the number of cylinders of the disk]:cylinders' \
  {-H,--heads}'[specify the number of heads of the disk]:heads' \
  {-S,--sectors}'[specify the number of sectors per track of the disk]:sectors' \
  {-w,--wipe}'[wipe filesystem/RAID/partition-table signatures]:when:(auto always never)' \
  {-W,--wipe-partitions}'[wipe filesystem/RAID signatures from new partitions]:when:(auto always never)' \
  '*:disk device:_files -g "*(-%)"' && ret=0

return ret
