#compdef fprcp
# Documentation: https://man.archlinux.org/search?q=fprcp
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-C[C header instead preprocessed resource script]'
  '-l[programming language for include files]'
  '-p[path to include files]'
  '-n[support of pascal comments nesting]'
  '*:filename:_files'
)

_arguments -s -S $arguments
