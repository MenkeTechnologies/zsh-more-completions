#compdef awk gawk

# Zsh completion for awk/gawk

local -a args

# Common POSIX awk options
args=(
  '*-f+[read program from file]:program file:_files'
  '-F+[set field separator]:field separator:'
  '*-v+[assign variable before execution]:assignment (var=val):'
)

# Detect if we are completing gawk or if gawk is the default awk
if [[ $service == gawk ]] || awk --version 2>&1 | command grep -q 'GNU Awk' 2>/dev/null; then
  args+=(
    '(- *)'{-h,--help}'[display help information and exit]'
    '(- *)'{-V,--version}'[print version and exit]'
    '*'{-f,--file}'=[read program from file]:program file:_files'
    {-F,--field-separator}'=[set field separator]:field separator:'
    '*-v=[assign variable before execution]:assignment (var=val):'
    {-b,--characters-as-bytes}'[treat all input data as single-byte characters]'
    {-c,--traditional}'[run in compatibility mode (disable GNU extensions)]'
    {-C,--copyright}'[print short copyright information and exit]'
    {-d,--dump-variables}'=-[dump global variables to file]:output file:_files'
    {-D,--debug}'=-[enable debugging mode]:debugger command file:_files'
    '*'{-e,--source}'=[use program-text as AWK source]:program text:'
    {-E,--exec}'=[like -f but last option processed, disables -f]:program file:_files'
    {-g,--gen-pot}'[scan awk program and generate a .pot file on stdout]'
    '*'{-i,--include}'=[include source library]:source file:_files'
    {-I,--trace}'[print internal byte code names as they are executed]'
    {-k,--csv}'[process comma-separated value data]'
    '*'{-l,--load}'=[load dynamic extension]:extension:_files'
    {-L,--lint}'=-[warn about dubious constructs]:lint level:(fatal invalid no-ext)'
    {-M,--bignum}'[use arbitrary precision arithmetic]'
    {-N,--use-lc-numeric}'[force use of the locale decimal point character]'
    {-n,--non-decimal-data}'[recognize octal and hexadecimal values in input data]'
    {-o,--pretty-print}'=-[output pretty-printed source to file]:output file:_files'
    {-O,--optimize}'[enable program optimization]'
    {-p,--profile}'=-[output profiling data to file]:output file:_files'
    {-P,--posix}'[operate in strict POSIX mode]'
    {-r,--re-interval}'[enable interval expressions in regular expressions]'
    {-s,--no-optimize}'[disable program optimization]'
    {-S,--sandbox}'[disable I/O redirection, system() calls, and extensions]'
    {-t,--lint-old}'[warn about non-portable constructs]'
    '*:input file:_files'
  )
else
  # Basic POSIX/BSD awk (macOS, etc.)
  args+=(
    '*:input file:_files'
  )
fi

_arguments -s -S $args
