#compdef qemu-sparc-static

local -a arguments

arguments=(
  '-h[print this help]'

  '-g[wait gdb connection to port]:port: '
  '-L[set the elf interpreter prefix to path]:path:_directories'
  '-s[set the stack size in bytes]:size: '
  '-cpu[select CPU (-cpu help for list)]:cpu: '
  '-E[value         QEMU_SET_ENV         sets targets environment variable (see below)]'
  '-U[unset target environment variable]:var: '
  '-0[0             QEMU_ARGV0           forces target process argv\[0\] to be argv0]'
  '-r[set qemu uname release string]:uname: '
  '-B[set guest_base address]:address: '
  '-R[reserve size bytes for guest virtual address space]:size: '
  '-d[enable logging of specified items (-d help for list)]:items: '
  '-dfilter[filter logging based on address range]:range: '
  '-D[write logs to logfile (default stderr)]:logfile:_files'
  '-p[set the host page size]:pagesize: '
  '-one-insn-per-tb[QEMU_ONE_INSN_PER_TB run with one guest instruction per emulated TB]'
  '-singlestep[QEMU_SINGLESTEP      deprecated synonym for -one-insn-per-tb]'
  '-strace[log system calls]'
  '-seed[seed for pseudo-random number generator]:seed: '
  '-trace[enable tracing options]:options: '
  '-version[display version information and exit]'
  '-perfmap[QEMU_PERFMAP         Generate a /tmp/perf-${pid}.map file for perf]'
  '-jitdump[QEMU_JITDUMP         Generate a jit-${pid}.dump file for perf]'
  '*:filename:_files'
)

_arguments -s -S $arguments
