#compdef ubertooth-follow

local -a arguments

arguments=(
  '-h[help]'
  '-l[LAP (in hexadecimal)]:LAP:'
  '-u[UAP (in hexadecimal)]:UAP:'
  '-U[set ubertooth device to use]:device:(0 1 2 3 4 5 6 7)'
  '-r[capture packets to PCAPNG file]:filename:'
  '-q[capture packets to PCAP file]:filename:'
  '-e[max errors]'
  '-d[debug output]'
  '-a[enable AFH]'
  '-b[Bluetooth device (hci0)]:device:'
  '-w[delay in 625us timeslots (default:5)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
