#compdef pls

# Zsh completion for pls (pretty ls)

_arguments -s -S \
  '(-d --det)'{-d,--det}'[detail level]:level:(1 2 3)' \
  '(-i --icon)'{-i,--icon}'[icon set]:set:(nerd emoji none)' \
  '--no-align[do not align columns]' \
  '(-s --sort)'{-s,--sort}'[sort by]:field:(name ext size cat ctime mtime)' \
  '--dirs-first[list directories first]' \
  '--no-dirs-first[do not list directories first]' \
  '(-a --all)'{-a,--all}'[show hidden files]' \
  '--exclude[exclude entries matching pattern]:pattern:' \
  '--only[only show entries matching pattern]:pattern:' \
  '--typ[only show entries of type]:type:(file dir symlink)' \
  '--no-grid[do not use grid layout]' \
  '--down[fill columns top to bottom]' \
  '--header[show header row]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:directory:_files -/' && return 0
