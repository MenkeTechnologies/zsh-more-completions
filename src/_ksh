#compdef ksh

local -a arguments

arguments=(
    '-c[Read the commands from the first arg.]'
    '-i[Specifies that the shell is interactive.]'
    '-l[Invoke the shell as a login shell]'
    '-r[Invoke the shell in a restricted mode]'
    '-s[Read the commands from standard input]'
    '-D[Do not execute the script, but output the set of double-quoted strings]'
    '-E[Reads the file /etc/ksh.kshrc, if it exists, as a profile]'
    '-R[Do not execute the script, but create a cross reference database]'
    '-a[Set the export attribute for each variable assigned to]'
    '-b[The shell writes a message to standard error as soon as a background job completes]'
    '-e[A simple command that has a non-zero exit status will cause the shell to exit]'
    '-f[Pathname expansion is disabled.]'
    '-h[Obsolete. Causes each command to become a tracked alias]'
    '-k[Obsolete. All arguments of the form name=value are removed and placed in the environment]'
    '-m[When enabled, the shell runs background jobs in a separate process group]'
    '-n[The shell reads commands and checks for syntax errors, but does not execute them]'
    '-o[set option by name]:option:'
    '-p[Privileged mode. Disabling -p sets the effective user id to the real user id]'
    '-t[Obsolete. The shell reads one command and then exits.]'
    '-u[If enabled, the shell displays an error message when it tries to expand an unset variable]'
    '-v[Verbose. The shell displays its input onto standard error as it reads it]'
    '-x[Execution trace. The shell will display each command after expanding it]'
    '-B[Enable {...} group expansion. On by default.]'
    '-C[Prevents existing regular files from being overwritten using the > redirection operator]'
    '-G[Causes ** by itself to also match all sub-directories during pathname expansion]'
    '-H[Enable !-style history expansion similar to csh.]'
    '-T[Enable implementation specific test code defined by mask.]'
    '*:filename:_files'
)

_arguments -s -S $arguments
