#compdef quartz-wm
# Documentation: https://man.archlinux.org/search?q=quartz-wm
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--version[print the version string]'
  '--prefs-domain[change the domain used for reading preferences]'
  '*:filename:_files'
)

_arguments -s -S $arguments
