#compdef blkiomon

local -a arguments

arguments=(
  '-I[sample interval]:interval:'
  '-h[human-readable output file]:file:_files'
  '-b[binary output file]:file:_files'
  '-d[output file for data emitted by low level device driver]:file:_files'
  '-D[output file for debugging data]:file:_files'
  '-Q[output to message queue using given ID]:queue id:'
  '-V[print program version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
