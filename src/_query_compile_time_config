#compdef query_compile_time_config
# Documentation: https://man.archlinux.org/search?q=query_compile_time_config
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-l[print all available configuration.]'
  '-all[return 0 if all configurations are defined. Otherwise, return 1]'
  '-any[return 0 if any configuration is defined. Otherwise, return 1]'
  '-h[print this usage]'
  '*:filename:_files'
)

_arguments -s -S $arguments
