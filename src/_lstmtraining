#compdef lstmtraining

local -a arguments

arguments=(
  '--debug_interval[how often to display the alignment]:int:'
  '--net_mode[controls network behavior]:int:'
  '--perfect_sample_delay[how many imperfect samples between perfect ones]:int:'
  '--max_image_MB[max memory to use for images (default 6000)]:int:'
  '--append_index[index in continue_from network at which to attach new network]:int:'
  '--max_iterations[if set, exit after this many iterations]:int:'
  '--debug_level[level of Trainer debugging]:int:'
  '--load_images[load images with tr files]:int:'
  '--target_error_rate[final error rate in percent]:double:'
  '--weight_range[range of initial random weights]:double:'
  '--learning_rate[weight factor for new deltas]:double:'
  '--momentum[decay factor for repeating deltas]:double:'
  '--adam_beta[decay factor for repeating deltas]:double:'
  '--clusterconfig_min_samples_fraction[min number of samples per proto as percent of total]:double:'
  '--clusterconfig_max_illegal[max percentage of samples in a cluster with more than 1 feature]:double:'
  '--clusterconfig_independence[desired independence between dimensions]:double:'
  '--clusterconfig_confidence[desired confidence in prototypes created]:double:'
  '--reset_learning_rate[resets all stored learning rates to the value specified by --learning_rate]'
  '--stop_training[just convert the training model to a runtime model]'
  '--convert_to_int[convert the recognition model to an integer model]'
  '--sequential_training[use the training files sequentially instead of round-robin]'
  '--debug_network[get info on distribution of weight values]'
  '--randomly_rotate[train OSD and randomly turn training samples upside-down]'
  '--net_spec[network specification]:string:'
  '--continue_from[existing model to extend]:string:'
  '--model_output[basename for output models]:string:'
  '--train_listfile[file listing training files in lstmf format]:file:_files'
  '--eval_listfile[file listing eval files in lstmf format]:file:_files'
  '--traineddata[combined Dawgs/Unicharset/Recoder for language model]:file:_files'
  '--old_traineddata[old character set to be replaced when changing character set]:file:_files'
  '--configfile[file to load more configs from]:file:_files'
  '--D[directory to write output files to]:dir:_files -/'
  '--F[file listing font properties]:file:_files'
  '--X[file listing font xheights]:file:_files'
  '--U[file to load unicharset from]:file:_files'
  '--O[file to write unicharset to]:file:_files'
  '--output_trainer[file to write trainer to]:file:_files'
  '--test_ch[UTF8 test character string]:string:'
  '--fonts_dir[fonts directory]:dir:_files -/'
  '--fontconfig_tmpdir[fontconfig temp directory]:dir:_files -/'
  '*:filename:_files'
)

_arguments -s -S $arguments
