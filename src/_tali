#compdef tali

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  '--help-all[show all help options]'
  '--help-gtk[show GTK+ Options]'
  {-d,--delay}'[delay computer moves]'
  {-t,--thoughts}'[display computer thoughts]'
  {-n,--computers}'[number of computer opponents]:number:'
  {-p,--humans}'[number of human opponents]:number:'
  {-g,--game}'[game choice: Regular or Colors]:game:(Regular Colors)'
  {-c,--computer-test}'[number of computer-only games to play]:number:'
  {-m,--monte-carlo-trials}'[number of trials for each roll for the computer]:trials:'
  '--display[X display to use]:display:'
  '*:filename:_files'
)

_arguments -s -S $arguments
