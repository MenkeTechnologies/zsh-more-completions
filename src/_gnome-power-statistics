#compdef gnome-power-statistics
# Documentation: https://man.archlinux.org/search?q=gnome-power-statistics
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  {-v,--verbose}'[show extra debugging information]'
  '--device[select this device at startup]'
  '*:filename:_files'
)

_arguments -s -S $arguments
