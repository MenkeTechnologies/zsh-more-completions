#compdef u3-tool
# Documentation: https://man.archlinux.org/search?q=u3-tool
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-c[change password]'
  '-d[disable device security]'
  '-D[dump all raw info(for debug)]'
  '-e[enable device security]'
  '-h[print this help message]'
  '-i[display device info]'
  '-l[Load CD image into device]:image:_files'
  '-p[Repartition device]:size:'
  '-R[reset device security, destroying private data]'
  '-u[unlock device]'
  '-v[use verbose output]'
  '-V[print version information]'
  '*:filename:_files'
)

_arguments -s -S $arguments
