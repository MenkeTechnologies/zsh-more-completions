#compdef peldd


local -a arguments

arguments=(
    {-f,--format-text}'[Change output format (default is text).]'
    {-v,--verbose}'[Show more information about found items.]'
    {-V,--version}'[Show version.]'
    '--format[Change output format (default is text).]'
    '--help[Show help.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
