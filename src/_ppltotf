#compdef ppltotf
# Documentation: https://man.archlinux.org/search?q=ppltotf
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-kanji[set Japanese encoding (STRING=euc|jis|sjis|utf8)]'
  '-help[print this message and exit.]'
  '-verbose[output progress reports.]'
  '-version[print version information and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
