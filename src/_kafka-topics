#compdef kafka-topics

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--command-config[Property file with configs to pass to Admin Client]:file:_files'
    '--zookeeper[DEPRECATED - ZooKeeper connect string]:host\:port:'
    '--create[Create a new topic]'
    '--delete[Delete a topic]'
    '--describe[List details for the given topics]'
    '--list[List all available topics]'
    '--alter[Alter the number of partitions and replica assignment]'
    '--topic[Topic name]:topic:'
    '--topic-id[Topic ID]:id:'
    '--topics-with-overrides[Show only topics that have overridden configs]'
    '--partitions[Number of partitions for the topic]:count:'
    '--replication-factor[Replication factor for each partition]:factor:'
    '--replica-assignment[Manual partition-to-broker assignment]:assignment:'
    '--config[Topic configuration override as name=value]:config:'
    '--if-exists[Only execute if topic exists]'
    '--if-not-exists[Only execute if topic does not exist]'
    '--exclude-internal[Exclude internal topics from listing]'
    '--at-min-isr-partitions[Show partitions at min ISR]'
    '--unavailable-partitions[Show unavailable partitions]'
    '--under-min-isr-partitions[Show partitions under min ISR]'
    '--under-replicated-partitions[Show under-replicated partitions]'
)

_arguments -s -S $arguments
