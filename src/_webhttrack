#compdef webhttrack

local -a arguments

arguments=(
    '-q[Quiet mode]'
    '-i[Continue interrupted mirror]'
    '-w[Mirror website]'
    '-O[Output path]:path:_directories'
    '-P[Proxy]:proxy address:'
    '-F[User-Agent]:user agent string:'
    '-r[Depth]:depth:'
    '-n[Get non-HTML files near links]'
    '-t[Test all links]'
    '-c[Number of connections]:connections:'
    '-T[Connection timeout]:timeout:'
    '-R[Retries]:retries:'
    '-H[Increase depth for external domains]'
    '-a[Remain on same address]'
    '-d[Remain on same domain]'
    '-l[Remain on same TLD]'
    '-e[External domain]'
    '-p[Port]:port:'
    '-N[Structure type]:type:'
    '-s[Follow robots.txt]'
    '-S[Stay on same directory]'
    '-o[Generate log file]'
    '-X[Purge old files]'
    '-A[Include pattern]:pattern:'
    '-V[Execute command]:command:'
    '--hierarchlock[Use file locking]'
    '--mirrorlinks[Mirror all links]'
    '--max-rate[Max transfer rate]:rate:'
    '--max-pause[Max pause time]:seconds:'
    '--max-size[Max file size]:bytes:'
    '--max-time[Max mirror time]:seconds:'
    '--path[Path]:path:_directories'
    '--lang[Language]:language:'
    '--update[Update mirror]'
    '--continue[Continue mirror]'
    '--help[Show help]'
    '*:URLs:'
)

_arguments -s -S $arguments
