#compdef twofi

local -a arguments

arguments=(
  {--help,-h}'[show help]'
  '--config[config file, default is twofi.yml]'
  {--count,-c}'[include the count with the words]'
  {--min_word_length,-m}'[minimum word length]:length:'
  {--term_file,-T}'[a file containing a list of terms]:file:_files'
  {--terms,-t}'[comma separated search terms]'
  {--user_file,-U}'[a file containing a list of users]:file:_files'
  {--users,-u}'[comma separated usernames]'
  {--verbose,-v}'[verbose]'
  '*:filename:_files'
)

_arguments -s -S $arguments
