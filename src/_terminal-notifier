#compdef terminal-notifier

local -a arguments

arguments=(
    '-message[Notification message (required)]:message text'
    '-title[Notification title]:title text'
    '-subtitle[Notification subtitle]:subtitle text'
    '-sound[Play sound with notification]:sound name:(default Basso Blow Bottle Frog Funk Glass Hero Morse Ping Pop Purr Sosumi Submarine Tink)'
    '-group[Group identifier for removing notifications]:group ID'
    '-remove[Remove notification by group ID]:group ID'
    '-list[List notification group IDs]:group ID:(ALL)'
    '-activate[Bundle ID of app to activate on click]:bundle ID'
    '-sender[Bundle ID of app to appear as sender]:bundle ID'
    '-appIcon[URL or path of icon to use]:icon path:_files -g "*.{png,jpg,jpeg,gif,tiff,icns}"'
    '-contentImage[URL or path of content image]:image path:_files -g "*.{png,jpg,jpeg,gif,tiff}"'
    '-open[URL to open on click]:URL'
    '-execute[Shell command to execute on click]:command'
    '-ignoreDnD[Send notification even in Do Not Disturb]'
    '-close[Close notification by group ID]:group ID'
    '-closeAll[Close all notifications]'
    '-timeout[Auto-close after seconds]:seconds'
    '-json[Output result as JSON]'
    '-reply[Enable reply button]'
    '-actions[Popup actions]:comma-separated actions'
    '-dropdownLabel[Dropdown label]:label'
)

_arguments -s -S $arguments
