#compdef haxe

# Zsh completion for Haxe (cross-platform language compiler)

_arguments -s -S \
  '-cp[add a class path]:path:_files -/' \
  '-js[compile to JavaScript]:output file:_files -g "*.js"' \
  '-lua[compile to Lua]:output file:_files -g "*.lua"' \
  '-swf[compile to SWF]:output file:_files -g "*.swf"' \
  '-neko[compile to Neko]:output file:_files -g "*.n"' \
  '-php[compile to PHP]:output directory:_files -/' \
  '-cpp[compile to C++]:output directory:_files -/' \
  '-cs[compile to C#]:output directory:_files -/' \
  '-java[compile to Java]:output directory:_files -/' \
  '-jvm[compile to JVM bytecode]:output file:_files' \
  '-python[compile to Python]:output file:_files -g "*.py"' \
  '-hl[compile to HashLink]:output file:_files -g "*.hl"' \
  '-interp[interpret with built-in interpreter]' \
  '-x[shortcut for compilation and execution]' \
  '-xml[generate XML types]:output file:_files -g "*.xml"' \
  '-main[set the main class]:class:' \
  '-lib[use a haxelib library]:library:' \
  '-D[define a conditional compilation flag]:flag:' \
  '-v[enable verbose mode]' \
  '--verbose[enable verbose mode]' \
  '-debug[add debug information]' \
  '--debug[add debug information]' \
  '-dce[set dead code elimination]:mode:(std full no)' \
  '-w[configure warning]:warning:' \
  '-resource[add a resource file]:file@name:_files' \
  '--cmd[run command after compilation]:command:' \
  '--connect[connect on given port for completion]:port:' \
  '--cwd[set current working directory]:dir:_files -/' \
  '--display[display code tips]' \
  '--each[separate target-specific arguments]' \
  '--haxelib-global[use global haxelib repository]' \
  '--macro[call initialization macro]:macro:' \
  '--no-inline[disable inlining]' \
  '--no-opt[disable code optimizations]' \
  '--no-output[compile but do not generate output]' \
  '--no-traces[do not compile trace calls]' \
  '--remap[remap a package]:package:' \
  '--run[compile and execute]:main class:' \
  '--times[measure compilation times]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:hxml file:_files -g "*.hxml *.hx"' && return 0
