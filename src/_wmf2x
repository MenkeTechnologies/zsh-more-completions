#compdef wmf2x
# Documentation: https://man.archlinux.org/search?q=wmf2x
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-display[where <display> is the display name.]'
  '--width[where <w> is the width of the image.]'
  '--height[where <h> is the height of the image.]'
  '--version[display version info and exit.]'
  '--help[display this help and exit.]'
  '--wmf-help[display wmf-related help and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
