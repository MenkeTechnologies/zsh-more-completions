#compdef sandi
# Documentation: https://man.archlinux.org/search?q=sandi
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-d,--database}'[supported Database Name]'
  {-k,--keyword}'[keyword For Search]'
  '*:filename:_files'
)

_arguments -s -S $arguments
