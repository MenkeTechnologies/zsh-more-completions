#compdef passwd

local -a arguments

if [[ "$OSTYPE" == darwin* ]]; then
  # macOS passwd
  arguments=(
    '-i[specify info system to operate on (file, NIS, OpenDirectory, PAM)]:infosystem:(file NIS OpenDirectory PAM)'
    '-l[specify location for the info system]:location:'
    '-u[specify the authentication name]:authname:'
    '1::user:_users'
  )
else
  # Linux passwd (shadow-utils)
  arguments=(
    {-k,--keep-tokens}'[keep non-expired authentication tokens]'
    {-d,--delete}'[delete the password for the named account (root only)]'
    {-l,--lock}'[lock the password for the named account (root only)]'
    {-u,--unlock}'[unlock the password for the named account (root only)]'
    {-e,--expire}'[expire the password for the named account (root only)]'
    {-f,--force}'[force operation]'
    {-x,--maximum=}'[maximum password lifetime in days (root only)]:days:'
    {-n,--minimum=}'[minimum password lifetime in days (root only)]:days:'
    {-w,--warning=}'[number of days warning before password expiration]:days:'
    {-i,--inactive=}'[number of days after password expiration to disable account]:days:'
    {-S,--status}'[report password status on the named account (root only)]'
    {-a,--all}'[show status for all accounts (with -S)]'
    {-q,--quiet}'[quiet mode]'
    {-r,--repository=}'[change password in specified repository]:repository:'
    {-R,--root=}'[apply changes in the specified chroot directory]:directory:_directories'
    '--stdin[read new tokens from stdin (root only)]'
    '(- * :)--usage[display brief usage message]'
    '(- * :)'{-h,--help}'[display help message and exit]'
    '1::user:_users'
  )
fi

_arguments -s -S $arguments
