#compdef cansniffer

local -a arguments

arguments=(
  '-m[initial filter mask (default 0x00000000)]:mask:'
  '-v[initial filter value (default 0x00000000)]:value:'
  '-q[quiet - all IDs deactivated]'
  '-r[read sniffset.name from file]'
  '-b[start with binary mode]'
  '-B[start with binary mode with gap]'
  '-c[color changes]'
  '-f[filter on CAN-ID only]'
  '-t[timeout for ID display in x10ms (default: 500, 0 = OFF)]:timeout:'
  '-h[hold marker on changes in x10ms (default: 100)]:hold:'
  '-l[loop time (display) in x10ms (default: 20)]:loop:'
  '*:filename:_files'
)

_arguments -s -S $arguments
