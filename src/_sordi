#compdef sordi
# Documentation: https://man.archlinux.org/search?q=sordi
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '-h[Print the command line options.]'
    '-i[Read input in SYNTAX (`turtle\ or `ntriples\).]:SYNTAX'
    '-o[Write output in SYNTAX (`turtle\ or `ntriples\).]:SYNTAX'
    '-s[Parse INPUT as a string (terminates options).]:INPUT'
    '-v[Display version information and exit.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
