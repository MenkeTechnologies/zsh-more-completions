#compdef lwp-dump5.34

local -a arguments

arguments=(
  '--agent[set the User-Agent header for requests]'
  '--keep-client-headers[do not remove client headers from the request]'
  '--max-length[maximum content length to display]'
  '--method[set the HTTP request method]'
  '--parse-head[parse the HTTP headers from the response]'
  '--request[set the HTTP request method]'
  '*:filename:_files'
)

_arguments -s -S $arguments
