#compdef kafka-reassign-partitions

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--command-config[Property file with configs to pass to Admin Client]:file:_files'
    '--generate[Generate a candidate partition reassignment configuration]'
    '--execute[Start the reassignment as specified by the reassignment-json-file]'
    '--verify[Verify if the reassignment completed]'
    '--cancel[Cancel an active reassignment]'
    '--list[List active partition reassignments]'
    '--zookeeper[DEPRECATED - ZooKeeper connect string]:host\:port:'
    '--reassignment-json-file[JSON file with the reassignment configuration]:file:_files'
    '--topics-to-move-json-file[JSON file with topics to reassign]:file:_files'
    '--broker-list[Comma-separated list of broker IDs]:broker-ids:'
    '--replica-alter-log-dirs-throttle[Throttle for moving replicas between log dirs in bytes/sec]:bytes:'
    '--throttle[Throttle in bytes/sec for replication]:bytes:'
    '--timeout[Timeout in ms for operations]:ms:'
    '--preserve-throttles[Do not modify throttles during verification]'
    '--additional[Return additional partition reassignment information]'
    '--disable-rack-aware[Disable rack-aware replica assignment]'
)

_arguments -s -S $arguments
