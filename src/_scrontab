#compdef scrontab
# Documentation: https://man.archlinux.org/search?q=scrontab
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '-e[Edit the crontab.]'
    '-l[List the crontab. (Prints directly to stdout. ).]'
    '-r[Remove the crontab.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
