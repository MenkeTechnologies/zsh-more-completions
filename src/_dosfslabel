#compdef fatlabel dosfslabel
# Documentation: https://man.archlinux.org/search?q=fatlabel
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    {-i,--volume-id}'[Switch to volume ID mode.]':4
    {-r,--reset}'[Remove label in label mode or generate new ID in volume ID mode.]':4
    {-c,--codepage}'[Use DOS codepage PAGE to encode/decode label.]'
    {-h,--help}'[Display a help message and terminate.]':4
    {-V,--version}'[Show version number and terminate.]':4
    '*:filename:_files'
)
_arguments -s -S $arguments
