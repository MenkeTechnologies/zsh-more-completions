#compdef optscript
# Documentation: https://man.archlinux.org/search?q=optscript
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[Print this option summary]'
  {-l,--list-operators}'[List built-in operators]'
  {-e,--eval}'[CODE        Evaluate the CODE]'
  '*:filename:_files'
)

_arguments -s -S $arguments
