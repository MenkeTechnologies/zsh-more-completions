#compdef rarian-sk-update
# Documentation: https://man.archlinux.org/search?q=rarian-sk-update
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-o[use the specified omf directories for input]'
  '-r[use the specified directory for the resulting scrollkeeper files]'
  '--c[rebuild the index entirely]'
  '-v[turn verbosity on]'
  '-p[specify a different place to store the mtimes file]'
  '-q[run silently (default)]'
  '-h[print this help message and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
