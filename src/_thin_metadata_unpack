#compdef thin_metadata_unpack

local -a arguments

arguments=(
    {-h,--help}'[Print help and exit.]'
    {-V,--version}'[Print version information and exit.]'
    {-i,--input}'[Input file or device with binary data.]:(device|file)'
    {-o,--output}'[Output file or device for binary data.]:(device|file)'
    '*:filename:_files'
)
_arguments -s -S $arguments
