#compdef hwloc-compress-dir
# Documentation: https://man.archlinux.org/search?q=hwloc-compress-dir
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-R,--reverse}'[uncompress instead of compressing]'
  {-v,--verbose}'[display verbose messages]'
  '*:filename:_files'
)

_arguments -s -S $arguments
