#compdef mdx

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'compile:compile MDX files'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'mdx command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (compile)
        _arguments -s -S \
          '--output-format=[output format]:format:(program function-body)' \
          '--jsx[keep JSX]' \
          '--jsx-runtime=[JSX runtime]:runtime:(automatic classic)' \
          '--pragma=[JSX pragma]:pragma' \
          '--pragma-frag=[JSX pragma for fragments]:pragma' \
          '--pragma-import-source=[JSX import source]:source' \
          '--development[enable development mode]' \
          '--extension=[file extension to scan]:extension' \
          '-o+[output file]:file:_files' \
          '--output=[output file]:file:_files' \
          '*:MDX files:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
