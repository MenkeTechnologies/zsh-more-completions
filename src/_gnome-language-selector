#compdef gnome-language-selector
# Documentation: https://man.archlinux.org/search?q=gnome-language-selector
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-n,--no-verify-installed-lang-support}'[dont verify installed language support]'
  {-d,--datadir}'[alternative datadir]'
  '*:filename:_files'
)

_arguments -s -S $arguments
