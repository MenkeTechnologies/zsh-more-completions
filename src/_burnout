#compdef burnout

# Zsh completion for burn-cli / burnout (Burn Rust DL framework CLI)

local -a commands
commands=(
  'new:Create a new Burn project'
  'train:Start model training'
  'eval:Run evaluation'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[Print help message]' \
  '1: :_describe -t commands "command" commands' \
  '*:: :->args'
