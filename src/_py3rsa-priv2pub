#compdef py3rsa-priv2pub
# Documentation: https://man.archlinux.org/search?q=py3rsa-priv2pub
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    {-h,--help}'[show help message and exit.]'
    {-i,--input}'[input filename. Read from stdin if not specified.]'
    '--output[output filename. write to stdout of not specified.]'
    '--inform[key format of input - default PEM.]:INFORM'
    '--outform[key format of output - default PEM]:OUTFORM'
    '*:filename:_files'
)
_arguments -s -S $arguments
