#compdef nl-fib-lookup
# Documentation: https://man.archlinux.org/search?q=nl-fib-lookup
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-t,--table}'[table id]'
  {-f,--fwmark}'[firewall mark]'
  {-s,--scope}'[routing scope]'
  {-T,--tos}'[type of Service]'
  '*:filename:_files'
)

_arguments -s -S $arguments
