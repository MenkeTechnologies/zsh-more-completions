#compdef cmedb
# Documentation: https://man.archlinux.org/search?q=cmedb
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  '--db-path[path to CME database (default: ~/.cme/cme.db)]'
  '--config-path[path to the CME configuration file]'
  '*:filename:_files'
)

_arguments -s -S $arguments
