#compdef vchiq_test

local -a arguments

arguments=(
  '-a[set the client and server bulk alignment (modulo 32)]:alignment:'
  '-A[set the client and server bulk alignment (modulo 4096)]:alignment:'
  '-e[disable echoing in the main bulk transfer mode]'
  '-k[skip the first n func data tests]:n:'
  '-m[set the client message quota]:n:'
  '-M[set the server message quota]:n:'
  '-q[disable data verification]'
  '-s[service (any 4 characters)]'
  '-v[enable more verbose output]'
  '-r[reserve bytes for specified seconds]:bytes,seconds:'
  '-K[send a SIGKILL after specified ms]:ms:'
  '-c[control test (size in bytes)]'
  '-b[bulk test (size in kilobytes)]'
  '-f[functional test]'
  '-p[ping test]'
  '-t[check the timer]'
  '*:filename:_files'
)

_arguments -s -S $arguments
