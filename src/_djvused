#compdef djvused
# Documentation: https://man.archlinux.org/search?q=djvused
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-v[verbose output]'
  '-f[read commands from a file]:file:_files'
  '-e[specify commands from the command line]:command'
  '-s[save after execution]'
  '-u[output utf8 instead of escaping non-ascii chars]'
  '-n[do not save anything]'
  '*:filename:_files'
)

_arguments -s -S $arguments
