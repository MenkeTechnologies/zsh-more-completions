#compdef fbsplash

local -a arguments

arguments=(
  '-s[splash image]:image:_files'
  '-c[hide cursor]'
  '-d[framebuffer device (default /dev/fb0)]:device:_files'
  '-i[config file (var=value)]:file:_files'
  '-f[control pipe (else exit after drawing image)]:pipe:_files'
  '-T[switch to TTY to hide all console messages]:tty:'
  '*:filename:_files'
)

_arguments -s -S $arguments
