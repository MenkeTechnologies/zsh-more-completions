#compdef sbattach
# Documentation: https://man.archlinux.org/search?q=sbattach
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--attach[set <sigfile> as the boot images]'
  '--detach[copy the boot images signature table]'
  '--remove[remove the boot images signature]'
  '*:filename:_files'
)

_arguments -s -S $arguments
