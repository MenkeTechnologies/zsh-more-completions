#compdef tigris

# Zsh completion for Tigris CLI (object storage)

local -a commands
commands=(
  'ls:List buckets or objects'
  'mk:Create a bucket or a folder'
  'cp:Copy files'
  'mv:Move or rename objects'
  'rm:Remove a bucket, folder, or object'
  'touch:Create an empty object'
  'stat:Show storage stats or metadata'
  'presign:Generate a temporary URL'
  'login:Authenticate via browser or credentials'
  'logout:End the current session'
  'whoami:Show current user and organization'
  'configure:Save persistent access keys'
  'buckets:Advanced bucket operations'
  'objects:Low-level object operations'
  'access-keys:Manage IAM access keys'
  'organizations:List and switch organizations'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[Print help message]' \
  '1: :_describe -t commands "command" commands' \
  '*:: :->args'

case $words[1] in
  ls|mk|cp|mv|rm|touch|stat|presign)
    _arguments \
      '*:path:_files'
    ;;
  buckets)
    local -a bucket_cmds
    bucket_cmds=('list' 'create' 'update' 'delete')
    _arguments \
      '1: :_describe -t bucket_cmds "bucket command" bucket_cmds'
    ;;
  objects)
    local -a obj_cmds
    obj_cmds=('list' 'put' 'get' 'delete')
    _arguments \
      '1: :_describe -t obj_cmds "object command" obj_cmds'
    ;;
  access-keys)
    local -a key_cmds
    key_cmds=('list' 'create' 'delete')
    _arguments \
      '1: :_describe -t key_cmds "key command" key_cmds'
    ;;
  organizations)
    local -a org_cmds
    org_cmds=('list' 'switch')
    _arguments \
      '1: :_describe -t org_cmds "organization command" org_cmds'
    ;;
esac
