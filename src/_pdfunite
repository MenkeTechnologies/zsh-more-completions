#compdef pdfunite
# Documentation: https://man.archlinux.org/search?q=pdfunite
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-v[print copyright and version info]'
  '-h[print usage information]'
  '-help[print usage information]'
  '--help[print usage information]'
  '*:filename:_files'
)

_arguments -s -S $arguments
