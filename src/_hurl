#compdef hurl

# Zsh completion for hurl - Run and test HTTP requests with plain text

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--color[colorize output]' \
  '--no-color[do not colorize output]' \
  '--no-output[suppress output of HTTP response body]' \
  '(-o --output)'{-o,--output}'[write output to file]:output file:_files' \
  '(-i --include)'{-i,--include}'[include HTTP headers in output]' \
  '(-v --verbose)'{-v,--verbose}'[turn on verbose output]' \
  '--very-verbose[turn on very verbose output]' \
  '--interactive[turn on interactive mode]' \
  '(-k --insecure)'{-k,--insecure}'[allow insecure SSL connections]' \
  '--cacert=[CA certificate to verify peer against]:CA cert:_files' \
  '--cert=[client certificate file]:cert file:_files' \
  '--key=[private key file]:key file:_files' \
  '(-L --location)'{-L,--location}'[follow redirects]' \
  '--location-trusted[like --location but send auth to other hosts too]' \
  '--max-redirs=[maximum number of redirects]:number:' \
  '--connect-timeout=[maximum time for connection in seconds]:seconds:' \
  '--max-time=[maximum time for the command in seconds]:seconds:' \
  '--retry=[maximum number of retries]:number:' \
  '--retry-interval=[time between retries in milliseconds]:milliseconds:' \
  '--delay=[delay between requests in milliseconds]:milliseconds:' \
  '(-x --proxy)'{-x,--proxy}'[use proxy]:proxy URL:' \
  '--resolve=[provide custom address for a host]:host\:port\:address:' \
  '(-u --user)'{-u,--user}'[server user and password]:user\:password:' \
  '--variable=[define variable]:name=value:' \
  '--variables-file=[define variable file]:variable file:_files' \
  '--glob=[specify input files using glob pattern]:glob pattern:' \
  '--report-html=[generate HTML report]:directory:_files -/' \
  '--report-json=[generate JSON report]:directory:_files -/' \
  '--report-junit=[generate JUnit XML report]:file:_files' \
  '--report-tap=[generate TAP report]:file:_files' \
  '--test[activate test mode]' \
  '--fail-at-end[fail at end with test mode]' \
  '--to-entry=[execute hurl file to specified entry number]:entry number:' \
  '--json[output each hurl file result to JSON]' \
  '--continue-on-error[continue executing requests even when a test fails]' \
  '--file-root=[set root filesystem to import files]:root dir:_files -/' \
  '--unix-socket=[connect through Unix domain socket]:socket path:_files' \
  '--compressed[request a compressed response using one of the supported algorithms]' \
  '--aws-sigv4=[use AWS V4 signature authentication]:provider:' \
  '*:hurl file:_files -g "*.hurl"' && ret=0

return ret
