#compdef sandbox-exec
# Documentation: https://man.archlinux.org/search?q=sandbox-exec
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-f[read profile from file]:file:_files'
  '-n[use pre-defined profile]:profile'
  '-p[specify profile on the command line]:profile'
  '-D[define a profile parameter]:key=value'
  '*:filename:_files'
)

_arguments -s -S $arguments
