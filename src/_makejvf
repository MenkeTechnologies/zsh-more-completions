#compdef makejvf

local -a arguments

arguments=(
  '-C[long body mode]'
  '-K[name of PS font TFM file for non-kanji characters]:tfm'
  '-b[baseline correction value]:value'
  '-m[use minute marks instead of quotes for vertical writing]'
  '-a[AFM file name (used when squeezing kana)]:file:_files'
  '-k[kana squeeze margin value]:value'
  '-i[start mapped font ID from No. 0]'
  '-e[enhanced mode; the horizontal shift amount is determined]'
  '-t[use <CNFfile> as a configuration file]:file:_files'
  '-u[UCS mode]'
  '-J[map single/double quote to another JIS-encoded PSfont TFM]'
  '-U[map single/double quote to another UCS-encoded PSfont TFM]'
  '-3[use set3, enable non-BMP characters support]'
  '-H[use half-width katakana]'
  '*:filename:_files'
)

_arguments -s -S $arguments
