#compdef mktexpk
# Documentation: https://man.archlinux.org/search?q=mktexpk
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--dpi[use resolution DPI.]'
  '--bdpi[use base resolution BDPI.]'
  '--mag[use magnificiation MAG.]'
  '--mfmode[use MODE as the METAFONT mode.]'
  '--destdir[write fonts in DESTDIR.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
