#compdef bpython bpython3-curses


local -a arguments

arguments=(
    '--config[Use <config> instead of default config file.]:config'
    {-h,--help}'[Show the help message and exit.]'
    {-i,--interactive}'[Drop to bpython shell after running file instead of exiting.]'
    {-q,--quiet}'[Do not flush the output to stdout.]'
    {-V,--version}'[Print bpython\'\''s version and exit.]'
    {-L,--log}'[Write debugging messages to the file bpython. log.]'
    {-p,--paste}'[Paste in the contents of a file at startup.]'
    {-r,--reactor}'[Use Twisted\'\''s <reactor> instead of urwid\'\''s event loop.]'
    '--help-reactors[Display a list of available Twisted reactors.]'
    '--plugin[Execute a twistd plugin. Use twistd to get a list of available plugins.]'
    {-s,--server}'[Run an eval server on port <port>.]'
    '--LL'
    '*:filename:_files'
)
_arguments -s -S $arguments
