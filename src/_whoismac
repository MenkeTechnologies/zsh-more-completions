#compdef whoismac
# Documentation: https://man.archlinux.org/search?q=whoismac
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-m[mac (six bytes of mac addr) or]'
  '-p[input PMKID hashline]'
  '-P[input EAPOL hashline from potfile]'
  '-e[input ESSID]'
  '-x[input ESSID in hex]'
  '-e[input ESSID]'
  '-v[vendor name]'
  '-h[this help screen]'
  '*:filename:_files'
)

_arguments -s -S $arguments
