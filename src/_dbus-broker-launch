#compdef dbus-broker-launch
# Documentation: https://man.archlinux.org/search?q=dbus-broker-launch
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    {-h,--help}'[print usage information and exit immediately.]'
    '--version[print build-version and exit immediately.]'
    '--audit[enable logging to the linux audit subsystem (no-op if audit support was not c]'
    '--config-file[config file to use (Default: /usr/share/dbus-1/{system,session}. conf).]:PATH'
    '--scope[select scope to run in (one of: system, user; Default: system).]:SCOPE'
    '*:filename:_files'
)
_arguments -s -S $arguments
