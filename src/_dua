#compdef dua

# Zsh completion for dua - disk usage analyzer

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'aggregate:Aggregate disk usage of the given directories or files'
  'interactive:Launch an interactive disk space usage explorer'
  'help:Print help'
)

_arguments -s -S \
  '(-t --threads)'{-t,--threads}'[number of threads to use]:N:' \
  '--format[output format]:format:(metric binary bytes)' \
  '(-A --apparent-size)'{-A,--apparent-size}'[display apparent size instead of disk usage]' \
  '(-x --stay-on-filesystem)'{-x,--stay-on-filesystem}'[prevent traversal of mount points]' \
  '(-o --output-format)'{-o,--output-format}'[output format for aggregate command]:format:(human-readable bytes)' \
  '(-i --ignore-dirs)'{-i,--ignore-dirs}'[ignore entries matching glob patterns]:pattern:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    _arguments '*:directory:_files -/' && ret=0
    ;;
esac

return ret
