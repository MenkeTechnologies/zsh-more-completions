#compdef unbound-control
# Documentation: https://man.archlinux.org/search?q=unbound-control
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-c[config file, default is /var/unbound/unbound.conf]'
  '-s[@port\] server address, if omitted config is used.]'
  '-q[quiet (dont print anything if it works ok).]'
  '-h[show this usage help.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
