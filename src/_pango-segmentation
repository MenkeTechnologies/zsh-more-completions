#compdef pango-segmentation
# Documentation: https://man.archlinux.org/search?q=pango-segmentation
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  '--kind[kind of boundary (grapheme/word/line/sentence)]'
  '--version[show version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
