#compdef wpa_supplicant

local -a arguments

arguments=(
  '-b[optional bridge interface name]:interface:'
  '-B[run daemon in the background]'
  '-c[configuration file]:file:_files'
  '-C[ctrl_interface parameter (only used if -c is not given)]:dir:_directories'
  '-d[increase debugging verbosity (-dd even more)]'
  '-D[driver name (can be multiple drivers: nl80211,wext)]:driver:'
  '-e[entropy file]:file:_files'
  '-f[log output to debug file instead of stdout]:file:_files'
  '-g[global ctrl_interface]:path:'
  '-G[global ctrl_interface group]:group:'
  '-h[show this help text]'
  '-i[interface name]:interface:'
  '-I[additional configuration file]:file:_files'
  '-K[include keys (passwords, etc.) in debug output]'
  '-L[show license (BSD)]'
  '-m[configuration file for the P2P Device interface]:file:_files'
  '-N[start describing new interface]'
  '-o[override driver parameter for new interfaces]'
  '-O[override ctrl_interface parameter for new interfaces]'
  '-p[driver parameters]'
  '-P[PID file]:file:_files'
  '-q[decrease debugging verbosity (-qq even less)]'
  '-s[log output to syslog instead of stdout]'
  '-t[include timestamp in debug messages]'
  '-T[record to Linux tracing in addition to logging]'
  '-u[enable DBus control interface]'
  '-v[show version]'
  '-W[wait for a control interface monitor before starting]'
  '*:filename:_files'
)

_arguments -s -S $arguments
