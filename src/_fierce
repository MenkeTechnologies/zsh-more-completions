#compdef fierce

local -a arguments

arguments=(
  '-connect[attempt to make http connections to any non RFC1918 address]'
  '-delay[the number of seconds to wait between lookups]:seconds:'
  '-dns[the domain you would like scanned]:domain:'
  '-dnsfile[use DNS servers provided by a file (one per line)]:file:_files'
  '-dnsserver[use a particular DNS server for reverse lookups]:server:'
  '-file[a file you would like output logged to]:file:_files'
  '-fulloutput[when combined with -connect this will output everything]'
  '-help[this screen.]'
  '-nopattern[do not use a search pattern when looking for nearby hosts]'
  '-range[scan an internal IP range (must be combined with -dnsserver)]:range:'
  '-search[search list for traverse lookups]:list:'
  '-suppress[suppress all TTY output (when combined with -file).]'
  '-tcptimeout[specify a different timeout (default 10 seconds)]:seconds:'
  '-threads[specify how many threads to use while scanning]:count:'
  '-traverse[specify a number of IPs above and below to scan]:count:'
  '-version[output the version number.]'
  '-wide[scan the entire class C after finding any matching host]'
  '-wordlist[use a separate wordlist (one word per line)]:file:_files'
  '*:filename:_files'
)

_arguments -s -S $arguments
