#compdef tail

local -a arguments

arguments=(
  {-c,--bytes}'[output the last K bytes; or use -c +K to output starting with byte K]:bytes:'
  {-f,--follow}'[output appended data as the file grows]:method:((name\:follow\ by\ name descriptor\:follow\ by\ descriptor))'
  '-F[same as --follow=name --retry]'
  {-n,--lines}'[output the last K lines, instead of the last 10]:lines:'
  '--max-unchanged-stats[with --follow=name, reopen a FILE which has not changed after N iterations]:iterations:'
  '--pid[with -f, terminate after process ID, PID dies]:pid:'
  {-q,--quiet,--silent}'[never output headers giving file names]'
  '--retry[keep trying to open a file if it is inaccessible]'
  {-s,--sleep-interval}'[with -f, sleep for approximately N seconds]:seconds:'
  {-v,--verbose}'[always output headers giving file names]'
  '--help[display this help and exit]'
  '--version[output version information and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
