#compdef et eternal-terminal

# Zsh completion for eternal-terminal (et) - persistent remote terminal

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --command)'{-c,--command}'[run command on connect]:command:' \
  '(-t --tunnel)'{-t,--tunnel}'[forward TCP port]:local\:remote:' \
  '(-r --reverse-tunnel)'{-r,--reverse-tunnel}'[reverse forward TCP port]:remote\:local:' \
  '(-f --forward-ssh-agent)'{-f,--forward-ssh-agent}'[forward SSH agent]' \
  '(-x --no-terminal)'{-x,--no-terminal}'[do not allocate a terminal]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '(-l --logtostdout)'{-l,--logtostdout}'[log to stdout]' \
  '(-e --ssh-option)'{-e,--ssh-option}'[additional SSH option]:SSH option:' \
  '(-N --no-reconnect)'{-N,--no-reconnect}'[disable reconnection]' \
  '(-p --port)'{-p,--port}'[port to connect to]:port:' \
  '--ssh-socket[SSH socket path]:socket path:_files' \
  '--prefix[set the prefix for the server]:prefix:' \
  '--serverfifo[FIFO path for server]:fifo path:_files' \
  '--telemetry[enable telemetry]' \
  '--no-telemetry[disable telemetry]' \
  '--jump-host[SSH jump host]:jump host:_hosts' \
  '--jport[jump host port]:port:' \
  '1:hostname:_hosts' && ret=0

return ret
