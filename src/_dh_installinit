#compdef dh_installinit
# Documentation: https://man.archlinux.org/search?q=dh_installinit
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    {-n,--no-scripts}''
    {-o,--only-scripts}''
    {-R,--restart-after-upgrade}''
    '--no-restart-after-upgrade'
    {-r,--no-stop-on-upgrade,--no-restart-on-upgrade}'[do not stop or restart service on upgrade]'
    '--no-start'
    '--no-enable'
    '--update-rcd-params'
    {-d,--remove-d}''
    '--uparams'
    '--name'
    '--init-script'
    '--error-handler'
    '*:filename:_files'
)
_arguments -s -S $arguments
