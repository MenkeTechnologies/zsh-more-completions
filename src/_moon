#compdef moon

# Zsh completion for moon - repository management tool (moonrepo)

local curcontext="$curcontext" state line ret=1

local -a global_opts=(
  '(-h --help)'{-h,--help}'[show help information]'
  '(-V --version)'{-V,--version}'[show version]'
  '--color[force colored output]'
  '--concurrency[set concurrency limit]:n:'
  '--logLevel[set log level]:level:(off error warn info debug trace)'
  '--log[set log level]:level:(off error warn info debug trace)'
  '--cache[set cache mode]'
)

local -a subcommands=(
  'ci:run tasks affected by changed files in CI'
  'check:run check tasks against changed or all files'
  'clean:clean the workspace cache'
  'completions:generate shell completions'
  'docker:commands for Docker integration'
  'generate:generate code from a template'
  'graph:display various dependency graphs'
  'init:initialize a new moon workspace'
  'migrate:run migration operations'
  'node:commands for Node.js integration'
  'project:display information about a project'
  'project-graph:display the project graph'
  'query:query the workspace'
  'run:run one or more tasks'
  'setup:setup the workspace toolchain'
  'sync:sync the workspace'
  'syncs:run all sync operations'
  'teardown:teardown the workspace toolchain'
  'upgrade:upgrade moon to the latest version'
)

_arguments -s -S \
  $global_opts \
  '1:subcommand:->subcmd' \
  '*::args:->args' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'moon subcommand' subcommands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (run)
        _arguments -s -S \
          $global_opts \
          '--affected[only run against affected projects]' \
          '--dependents[also run tasks in dependent projects]' \
          '--force[force run even if already cached]' \
          '--interactive[run in interactive mode]' \
          '--passthrough[pass additional arguments through]:args:' \
          '--profile[generate a CPU or heap profile]:type:(cpu heap)' \
          '--query[filter projects using a query]:query:' \
          '--remote[run on a remote executor]' \
          '--status[filter tasks by status]:status:(failed passed running)' \
          '--summary[print a summary of all actions]' \
          '--update-cache[force update of the cache]' \
          '*:target (project\:task):' && ret=0
        ;;
      (ci)
        _arguments -s -S \
          $global_opts \
          '--base[set the base ref for change detection]:ref:' \
          '--head[set the head ref for change detection]:ref:' \
          '--job[current job index]:n:' \
          '--jobTotal[total number of jobs]:n:' \
          '--remote[run on a remote executor]' \
          '*:target:' && ret=0
        ;;
      (check)
        _arguments -s -S \
          $global_opts \
          '--all[check all projects]' \
          '--update-cache[force update of the cache]' \
          '--summary[print a summary of all actions]' \
          '*:target:' && ret=0
        ;;
      (init)
        _arguments -s -S \
          $global_opts \
          '--minimal[initialize with minimal configuration]' \
          '--to[initialize in the given directory]:dir:_files -/' \
          '--yes[auto-confirm all prompts]' && ret=0
        ;;
      (generate)
        _arguments -s -S \
          $global_opts \
          '--defaults[use default values for all prompts]' \
          '--dryRun[run without making changes]' \
          '--force[overwrite existing files]' \
          '--template[select a template]:template name:' \
          '--dest[set the destination directory]:dir:_files -/' \
          '*:template name:' && ret=0
        ;;
      (clean)
        _arguments -s -S \
          $global_opts \
          '--cache[only clean the cache]' \
          '--lifetime[remove cache older than duration]:duration:' && ret=0
        ;;
      (project)
        _arguments -s -S \
          $global_opts \
          '*:project id:' && ret=0
        ;;
      (graph)
        local -a graph_cmds=(
          'action:display the action graph'
          'dep:display the dependency graph'
          'project:display the project graph'
        )
        _describe -t subcommands 'graph subcommand' graph_cmds && ret=0
        ;;
      (docker)
        local -a docker_cmds=(
          'prune:prune the Docker workspace'
          'scaffold:scaffold Docker files'
          'setup:setup the Docker environment'
        )
        _describe -t subcommands 'docker subcommand' docker_cmds && ret=0
        ;;
      (node)
        local -a node_cmds=(
          'run-script:run a package.json script'
        )
        _describe -t subcommands 'node subcommand' node_cmds && ret=0
        ;;
      (query)
        local -a query_cmds=(
          'hash:inspect a hash'
          'hash-diff:diff two hashes'
          'projects:query projects in the workspace'
          'tasks:query tasks in the workspace'
          'touched-files:query touched files'
        )
        _arguments -s -S \
          '1:query subcommand:->querycmd' && ret=0
        case $state in
          (querycmd)
            _describe -t subcommands 'query subcommand' query_cmds && ret=0
            ;;
        esac
        ;;
      (*)
        _arguments -s -S $global_opts '*:arguments:' && ret=0
        ;;
    esac
    ;;
esac

return ret
