#compdef idiag-socket-details
# Documentation: https://man.archlinux.org/search?q=idiag-socket-details
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--summary[show socket detail summary.]'
  '--details[show socket details on multiple lines.]'
  '--stats[show full socket statistics.]'
  '(- * :)'{-h,--help}'[show this help.]'
  {-v,--version}'[show versioning information.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
