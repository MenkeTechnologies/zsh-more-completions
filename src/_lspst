#compdef lspst
# Documentation: https://man.archlinux.org/search?q=lspst
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-d[Debug to file. This is a binary log. Use readlog to print it]'
  '-h[Help. This screen]'
  '-V[Version. Display program version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
