#compdef icesh-default
# Documentation: https://man.archlinux.org/search?q=icesh-default
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-display[connects to the X server specified by DISPLAY.]'
  '-window[specifies the window to manipulate. Special]'
  '-class[window management class of the window(s) to]'
  '*:filename:_files'
)

_arguments -s -S $arguments
