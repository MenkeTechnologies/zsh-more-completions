#compdef tac gtac

local -a arguments

arguments=(
  '(-b --before)'{-b,--before}'[attach the separator before instead of after]'
  '(-r --regex)'{-r,--regex}'[interpret the separator as a regular expression]'
  '(-s --separator)'{-s+,--separator=}'[use STRING as the separator instead of newline]:separator string'
  '(- *)--help[display this help and exit]'
  '(- *)--version[output version information and exit]'
  '*:file:_files'
)

_arguments -s -S $arguments
