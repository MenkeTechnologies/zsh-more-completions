#compdef camlp4oof

local -a arguments

arguments=(
  '-I[add directory in search path for object files]:directory:_files -/'
  '-where[print camlp4 library directory and exit.]'
  '-nolib[no automatic search for object files in library directory.]'
  '-intf[parse file as an interface, whatever its extension]:file:_files'
  '-impl[parse file as an implementation, whatever its extension]:file:_files'
  '-str[parse string as an implementation]:string:'
  '-unsafe[generate unsafe accesses to array and strings.]'
  '-noassert[obsolete, do not use this option.]'
  '-verbose[more verbose in parsing errors.]'
  '-loc[name of the location variable (default: _loc)]:name:'
  '-QD[dump quotation expander result in case of syntax error.]'
  '-o[output on file instead of standard output]:file:_files'
  '-v[print Camlp4 version and exit.]'
  '-version[print Camlp4 version number and exit.]'
  '-vnum[print Camlp4 version number and exit.]'
  '-no_quot[do not parse quotations, allowing to use "<:>" as token]'
  '-loaded-modules[print the list of loaded modules.]'
  '-parser[load the parser Camlp4Parsers/<name>]:name:'
  '-printer[load the printer Camlp4Printers/<name>]:name:'
  '-filter[load the filter Camlp4Filters/<name>]:name:'
  '-ignore[ignore the next argument]:arg:'
  '*:filename:_files'
)

_arguments -s -S $arguments
