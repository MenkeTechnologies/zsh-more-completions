#compdef asn1Parser

local -a arguments

arguments=(
  {-c,--check}'[checks the syntax only]'
  {-o,--output}'[output file]'
  {-n,--name}'[array name]'
  '(- * :)'{-h,--help}'[display this help and exit]'
  {-v,--version}'[output version information and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
