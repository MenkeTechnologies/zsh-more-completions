#compdef prune
# Documentation: https://man.archlinux.org/search?q=prune
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[print this message]'
  '-v[verbose]'
  '-n[Name node to prune.]:node:'
  '-N[Attribute specification to apply to pruned nodes]:attrspec:'
  '*:filename:_files'
)

_arguments -s -S $arguments
