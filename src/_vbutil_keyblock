#compdef vbutil_keyblock

local -a arguments

arguments=(
  '--datapubkey[data public key in .vbpubk format]'
  '--signprivate[signing private key in .vbprivk format]:file:_files'
  '--signprivate-pem[signing private key in PEM format]:file:_files'
  '--pem-algorithm[PEM algorithm]:algo:'
  '--flags[specifies allowed use conditions.]'
  '--externalsigner[" Use an external program cmd to calculate the signatures.]'
  '--signpubkey[signing public key in .vbpubk format]:file:_files'
  '*:filename:_files'
)

_arguments -s -S $arguments
