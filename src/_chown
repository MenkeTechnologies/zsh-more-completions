#compdef chown

# Completes user:group specifications
_chown_user_group() {
  if compset -P '*:'; then
    _groups
  elif compset -S ':*'; then
    _users
  else
    local suf=':'
    if [[ "$OSTYPE" = darwin* ]] || [[ "$OSTYPE" = freebsd* ]]; then
      _alternative \
        "users:user:_users -S '$suf'" \
        "groups:group:_groups -P ':'"
    else
      _alternative \
        "users:user:_users -S '$suf'" \
        "groups:group:_groups -P ':'"
    fi
  fi
}

local -a arguments

# Detect platform - BSD (macOS/FreeBSD) vs GNU
if [[ "$OSTYPE" = darwin* ]] || [[ "$OSTYPE" = freebsd* ]] || [[ "$OSTYPE" = openbsd* ]]; then
  # BSD chown (macOS, FreeBSD, etc.)
  arguments=(
    '-f[do not report any failure to change file owner or group, nor modify exit status]'
    '-h[if the file is a symbolic link, change the user ID and/or the group ID of the link itself]'
    '-n[interpret user ID and group ID as numeric, avoiding name lookups]'
    '-v[cause chown to be verbose, showing files as the owner is modified]'
    '-x[file system mount points are not traversed]'
    '-R[change the user ID and/or the group ID of file hierarchies rooted in the files]'
    '-H[if -R is specified, follow symbolic links on the command line only]'
    '-L[if -R is specified, follow all symbolic links]'
    '-P[if -R is specified, do not follow any symbolic links (default)]'
    '1:owner[\:group]:_chown_user_group'
    '*:file:_files'
  )
else
  # GNU chown
  arguments=(
    {-c,--changes}'[like verbose but report only when a change is made]'
    {-f,--silent,--quiet}'[suppress most error messages]'
    {-v,--verbose}'[output a diagnostic for every file processed]'
    '--dereference[affect the referent of each symbolic link (this is the default)]'
    {-h,--no-dereference}'[affect symbolic links instead of any referenced file]'
    '--from=[change the owner and/or group only if current owner and/or group match]:current_owner\:current_group:_chown_user_group'
    '--no-preserve-root[do not treat / specially (the default)]'
    '--preserve-root[fail to operate recursively on /]'
    '--reference=[use specified file'\''s owner and group rather than specifying values]:reference file:_files'
    {-R,--recursive}'[operate on files and directories recursively]'
    '-H[if a command line argument is a symbolic link to a directory, traverse it]'
    '-L[traverse every symbolic link to a directory encountered]'
    '-P[do not traverse any symbolic links (default)]'
    '(- *)--help[display help and exit]'
    '(- *)--version[output version information and exit]'
    '1:owner[\:group]:_chown_user_group'
    '*:file:_files'
  )
fi

_arguments -s -S $arguments
