#compdef hardlink

# Completion for hardlink (util-linux / modern GNU hardlink)

_hardlink() {
  local arguments

  arguments=(
    '(- *)'{-h,--help}'[display help text and exit]'
    '(- *)'{-V,--version}'[print version and exit]'
    {-v,--verbose}'[verbose output (can be specified multiple times)]'
    {-q,--quiet}'[suppress warnings and summary]'
    {-n,--dry-run}'[do not act, just report what would be done]'
    {-y,--method}'[set file comparison method]:method:(sha256 sha1 crc32c memcmp)'
    {-f,--respect-name}'[filenames have to be identical]'
    {-p,--ignore-mode}'[ignore changes in file mode]'
    {-o,--ignore-owner}'[ignore changes in owner (user and group)]'
    {-t,--ignore-time}'[ignore changes in timestamps (mtime and ctime)]'
    {-c,--content}'[compare only file contents, ignore metadata]'
    {-X,--respect-xattrs}'[respect extended attributes]'
    {-m,--maximize}'[try to maximize the hardlink count]'
    {-M,--minimize}'[try to minimize the hardlink count]'
    {-s,--minimum-size}'[minimum file size to consider]:size (bytes)'
    {-S,--maximum-size}'[maximum file size to consider]:size (bytes)'
    {-b,--io-size}'[I/O buffer size for file comparisons]:size (bytes)'
    {-r,--cache-size}'[memory cache size for file hashes]:size (bytes)'
    {-x,--exclude}'[exclude files matching pattern]:regex pattern'
    {-i,--include}'[include files matching pattern]:regex pattern'
    '--reflink[create reflinks (CoW copies) instead of hardlinks]::when:(auto always)'
    '--skip-reflinks[skip already-cloned files]'
    '*:file or directory:_files'
  )

  _arguments -s -S $arguments
}

_hardlink "$@"
