#compdef sort-dctrl
# Documentation: https://man.archlinux.org/search?q=sort-dctrl
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-C,--copying}'[print out the copyright license.]'
  {-k,--key-spec}'[specify sort keys.]'
  {-l,--errorlevel}'[set debugging level to LEVEL.]'
  '--mmap[attempt mmapping input files]'
  '--usage[give a short usage message]'
  {-V,--version}'[print program version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
