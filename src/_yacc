#compdef yacc

# Completion for yacc (typically GNU Bison in POSIX mode)

_yacc_report_items() {
  local -a items
  items=(
    'state:describe the states'
    'itemset:complete the core item sets with their closure'
    'lookahead:explicitly associate lookahead tokens to items'
    'look-ahead:explicitly associate look-ahead tokens to items'
    'solved:describe shift/reduce conflicts solving'
    'all:include all the above information'
    'none:disable the report'
  )
  _values -s , 'report item' $items
}

local arguments

arguments=(
  '(- *)'{-h,--help}'[display help and exit]'
  '(- *)'{-V,--version}'[output version information and exit]'
  '(- *)--print-localedir[output directory containing locale-dependent data and exit]'

  # Operation modes
  {-y,--yacc}'[emulate POSIX Yacc]'

  # Parser
  {-S+,--skeleton=}'[specify the skeleton to use]:skeleton file:_files'
  {-t,--debug}'[instrument the parser for debugging]'
  '--locations[enable locations computation]'
  {-p+,--name-prefix=}'[prepend PREFIX to the external symbols]:prefix:'
  {-l,--no-lines}'[do not generate #line directives]'
  {-n,--no-parser}'[generate the tables only]'
  {-k,--token-table}'[include a table of token names]'

  # Output
  {-d,--defines}'[also produce a header file]'
  {-r+,--report=}'[also produce details on the automaton]:report items:_yacc_report_items'
  {-v,--verbose}'[same as --report=state]'
  {-b+,--file-prefix=}'[specify a PREFIX for output files]:prefix:'
  {-o+,--output=}'[leave output to FILE]:output file:_files'
  {-g,--graph}'[also produce a VCG description of the automaton]'

  '*:grammar file:_files -g "*.{y,yy,ypp,y++}(-.)"'
)

_arguments -s -S : $arguments
