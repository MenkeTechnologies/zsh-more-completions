#compdef gpg-error
# Documentation: https://man.archlinux.org/search?q=gpg-error
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--lib-version[print library version]'
  '--list[print all error codes]'
  '--defines[print all error codes as #define lines]'
  '--desc[print with error description]'
  '*:filename:_files'
)

_arguments -s -S $arguments
