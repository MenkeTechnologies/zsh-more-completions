#compdef mongoreplay
# Documentation: https://man.archlinux.org/search?q=mongoreplay
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-v,--verbosity}'[increase the detail regarding the tools performance on the output]'
  {-d,--debug}'[increase the detail regarding the operations and errors of]'
  {-s,--silent}'[silence all log output]'
  '(- * :)'{-h,--help}'[show this help message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
