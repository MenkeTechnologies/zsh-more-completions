#compdef pamrestack
# Documentation: https://man.archlinux.org/search?q=pamrestack
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '--width[The width of the output.]:width'
    '--trim[This option specifies what to do when the new width does not cleanly divide t]:{fill|crop|abort}'
    '--verbose[Print information about the processing to Standard Error. USAGE .]'
    '*:filename:_files'
)
_arguments -s -S $arguments
