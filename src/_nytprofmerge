#compdef nytprofmerge
# Documentation: https://man.archlinux.org/search?q=nytprofmerge
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {--out,-o}'[name of output file \[default: nytprof-merged.out\]]'
  {--help,-h}'[print this message]'
  {--verbose,-v}'[be more verbose]'
  '*:filename:_files'
)

_arguments -s -S $arguments
