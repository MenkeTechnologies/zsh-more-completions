#compdef sbcdec
# Documentation: https://man.archlinux.org/search?q=sbcdec
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[display help]'
  {-v,--verbose}'[verbose mode]'
  {-d,--device}'[sound device]'
  {-f,--file}'[decode to a file]'
  '*:filename:_files'
)

_arguments -s -S $arguments
