#compdef tracker-stats
# Documentation: https://man.archlinux.org/search?q=tracker-stats
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  {-a,--stat}'[show statistics for current index / data set]'
  '--all[show statistics about ALL RDF classes, not just common ones which is the default (implied by search terms)]'
  '--collect-debug-info[collect debug information useful for problem reporting and investigation, results are output to terminal]'
  '*:filename:_files'
)

_arguments -s -S $arguments
