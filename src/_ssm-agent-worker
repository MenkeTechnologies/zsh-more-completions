#compdef ssm-agent-worker
# Documentation: https://man.archlinux.org/search?q=ssm-agent-worker
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-clear[clear the agent registration]'
  '-code[activation code]:code:'
  '-fingerprint[show the fingerprint]'
  '-i[instance id]:instance-id:'
  '-id[activation id]:id:'
  '-r[instance region]:region:'
  '-region[instance region]:region:'
  '-register[register the agent]'
  '-similarityThreshold[similarity threshold (default 40)]:threshold:'
  '-worker[run as worker]'
  '-y[answer yes to all prompts]'
  '*:filename:_files'
)

_arguments -s -S $arguments
