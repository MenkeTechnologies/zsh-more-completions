#compdef socat

# Zsh completion for socat (multipurpose relay / bidirectional data transfer)

_socat_addresses() {
  local -a addresses
  addresses=(
    'ACCEPT-FD\::accept on existing file descriptor'
    'CREATE\::create a file for writing'
    'EXEC\::execute a program with fork'
    'FD\::use a file descriptor'
    'GOPEN\::generic open of a file'
    'IP-DATAGRAM\::send/receive IP datagrams'
    'IP-RECV\::receive raw IP packets'
    'IP-RECVFROM\::receive raw IP packets (fork per packet)'
    'IP-SENDTO\::send raw IP packets'
    'IP4-DATAGRAM\::send/receive IPv4 datagrams'
    'IP4-RECV\::receive raw IPv4 packets'
    'IP4-RECVFROM\::receive raw IPv4 packets (fork per packet)'
    'IP4-SENDTO\::send raw IPv4 packets'
    'IP6-DATAGRAM\::send/receive IPv6 datagrams'
    'IP6-RECV\::receive raw IPv6 packets'
    'IP6-RECVFROM\::receive raw IPv6 packets (fork per packet)'
    'IP6-SENDTO\::send raw IPv6 packets'
    'OPEN\::open a file'
    'OPENSSL\::SSL/TLS client connection'
    'OPENSSL-DTLS-CLIENT\::DTLS client connection'
    'OPENSSL-DTLS-SERVER\::DTLS server'
    'OPENSSL-LISTEN\::SSL/TLS server'
    'PIPE\::create or use a named pipe'
    'PROXY\::connect via HTTP proxy'
    'PTY\::create a pseudo terminal'
    'SCTP-CONNECT\::SCTP client connection'
    'SCTP-LISTEN\::SCTP server'
    'SCTP4-CONNECT\::SCTP4 client connection'
    'SCTP4-LISTEN\::SCTP4 server'
    'SCTP6-CONNECT\::SCTP6 client connection'
    'SCTP6-LISTEN\::SCTP6 server'
    'SHELL\::execute a shell command'
    'SOCKET-CONNECT\::generic socket connect'
    'SOCKET-DATAGRAM\::generic socket datagram'
    'SOCKET-LISTEN\::generic socket listen'
    'SOCKET-RECV\::generic socket receive'
    'SOCKET-RECVFROM\::generic socket receive from'
    'SOCKET-SENDTO\::generic socket send to'
    'SOCKETPAIR\::create a socket pair'
    'SOCKS4\::SOCKS4 client connection'
    'SOCKS4A\::SOCKS4A client connection'
    'SOCKS5-CONNECT\::SOCKS5 client connection'
    'SOCKS5-LISTEN\::SOCKS5 listen'
    'STALL\::stall data transfer'
    'STDERR\::use standard error'
    'STDIN\::use standard input'
    'STDIO\::use standard input/output'
    'STDOUT\::use standard output'
    'SYSTEM\::execute a system command'
    'TCP-CONNECT\::TCP client connection'
    'TCP-LISTEN\::TCP server'
    'TCP4-CONNECT\::TCP4 client connection'
    'TCP4-LISTEN\::TCP4 server'
    'TCP6-CONNECT\::TCP6 client connection'
    'TCP6-LISTEN\::TCP6 server'
    'TEXT\::provide text as data source'
    'UDP-CONNECT\::UDP client connection'
    'UDP-DATAGRAM\::UDP datagram'
    'UDP-LISTEN\::UDP server'
    'UDP-RECV\::UDP receive'
    'UDP-RECVFROM\::UDP receive from (fork per packet)'
    'UDP-SENDTO\::UDP send to'
    'UDP4-CONNECT\::UDP4 client connection'
    'UDP4-DATAGRAM\::UDP4 datagram'
    'UDP4-LISTEN\::UDP4 server'
    'UDP4-RECV\::UDP4 receive'
    'UDP4-RECVFROM\::UDP4 receive from (fork per packet)'
    'UDP4-SENDTO\::UDP4 send to'
    'UDP6-CONNECT\::UDP6 client connection'
    'UDP6-DATAGRAM\::UDP6 datagram'
    'UDP6-LISTEN\::UDP6 server'
    'UDP6-RECV\::UDP6 receive'
    'UDP6-RECVFROM\::UDP6 receive from (fork per packet)'
    'UDP6-SENDTO\::UDP6 send to'
    'UNIX-CLIENT\::UNIX domain socket client'
    'UNIX-CONNECT\::UNIX domain socket connect'
    'UNIX-LISTEN\::UNIX domain socket server'
    'UNIX-RECV\::UNIX domain socket receive'
    'UNIX-RECVFROM\::UNIX domain socket receive from'
    'UNIX-SENDTO\::UNIX domain socket send to'
    '-\::use stdio (alias for STDIO)'
  )
  _describe -t addresses 'socat address' addresses
}

_arguments -s -S \
  '-V[print version and feature information to stdout, and exit]' \
  '(-h)-h[print help text describing command line options and addresses]' \
  '(-hh)-hh[like -h, plus a list of all common address option names]' \
  '(-hhh)-hhh[like -hh, plus a list of all available address option names]' \
  '*-d[increase verbosity (use up to 4 times)]' \
  '-d0[set verbosity to errors only]' \
  '-d1[set verbosity to warnings and errors]' \
  '-d2[set verbosity to notices, warnings and errors]' \
  '-d3[set verbosity to info and above]' \
  '-d4[set verbosity to debug and above]' \
  '-D[analyze file descriptors before loop]' \
  '--experimental[enable experimental features]' \
  '--statistics[output transfer statistics on exit]' \
  '-ly[log to syslog, using facility (default is daemon)]:facility:(daemon user local0 local1 local2 local3 local4 local5 local6 local7)' \
  '-lf[log to file]:logfile:_files' \
  '-ls[log to stderr (default if no other log)]' \
  '-lm[mixed log mode (stderr during initialization, then syslog)]:facility:(daemon user local0 local1 local2 local3 local4 local5 local6 local7)' \
  '-lp[set the program name used for logging and vars]:progname: ' \
  '-lu[use microseconds for logging timestamps]' \
  '-lh[add hostname to log messages]' \
  '-v[verbose text dump of data traffic]' \
  '-x[verbose hexadecimal dump of data traffic]' \
  '-r[raw dump of data flowing from left to right]:file:_files' \
  '-R[raw dump of data flowing from right to left]:file:_files' \
  '-b[set data buffer size (default 8192)]:size: ' \
  '-s[sloppy (continue on error)]' \
  '-S[log these signals, override default]:sigmask: ' \
  '-t[wait seconds before closing second channel]:timeout: ' \
  '-T[total inactivity timeout in seconds]:timeout: ' \
  '-u[unidirectional mode (left to right)]' \
  '-U[unidirectional mode (right to left)]' \
  '-g[do not check option groups]' \
  '-L[try to obtain lock, or fail]:lockfile:_files' \
  '-W[try to obtain lock, or wait]:lockfile:_files' \
  '-0[do not prefer an IP version]' \
  '-4[prefer IPv4 if version is not explicitly specified]' \
  '-6[prefer IPv6 if version is not explicitly specified]' \
  '1:address1:_socat_addresses' \
  '2:address2:_socat_addresses'
