#compdef vmstat

local -a arguments

arguments=(
  {-a,--active}'[display active/inactive memory]'
  {-f,--forks}'[display number of forks since boot]'
  {-m,--slabs}'[display slabinfo]'
  {-n,--one-header}'[do not redisplay header]'
  {-s,--stats}'[display event counter statistics]'
  {-d,--disk}'[display disk statistics]'
  {-D,--disk-sum}'[summarize disk statistics]'
  {-p,--partition}'[display partition specific statistics]:device:_files -W /dev'
  {-S,--unit}'[define display unit]:unit:((k\:"1000 bytes" K\:"1024 bytes" m\:"1000000 bytes" M\:"1048576 bytes"))'
  {-w,--wide}'[wide output mode]'
  {-t,--timestamp}'[show timestamp on each line]'
  {-y,--no-first}'[omit first report with statistics since boot]'
  '(- * :)'{-h,--help}'[display help and exit]'
  {-V,--version}'[output version information and exit]'
  '1:delay (seconds):'
  '2:count:'
)

_arguments -s -S $arguments
