#compdef telnetd

local -a arguments

arguments=(
  {-D,--debug}'[set debugging level]:level:'
  {-E,--exec-login}'[set program to be executed instead of /bin/login]:program:_files'
  {-h,--no-hostinfo}'[do not print host information before login has been completed]'
  {-l,--linemode}'[set line mode]'
  {-n,--no-keepalive}'[disable TCP keep-alives]'
  {-U,--reverse-lookup}'[refuse connections from addresses that cannot be resolved]'
  '--usage[give a short usage message]'
  {-V,--version}'[print program version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
