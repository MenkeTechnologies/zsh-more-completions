#compdef cache_writeback
# Documentation: https://man.archlinux.org/search?q=cache_writeback
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--metadata-device[specify metadata device]:device:_files'
  '--origin-device[specify origin device]:device:_files'
  '--fast-device[specify fast device]:device:_files'
  '--buffer-size-meg[specify buffer size in megabytes]:size:'
  '--list-failed-blocks[list failed blocks]'
  '--no-metadata-update[do not update metadata]'
  '*:filename:_files'
)

_arguments -s -S $arguments
