#compdef cargo-expand

local -a arguments

arguments=(
  '--features[space-separated list of features to activate]:features:'
  '--all-features[activate all available features]'
  '--no-default-features[do not activate the `default` feature]'
  '--lib[expand only this packages library]'
  '--bin[expand only the specified binary]:binary:'
  '--example[expand only the specified example]:example:'
  '--test[expand only the specified test target]:test:'
  '--tests[include tests when expanding the lib or bin]'
  '--bench[expand only the specified bench target]:bench:'
  '--target[target triple which compiles will be for]:target:'
  '--target-dir[directory for all generated artifacts]:directory:_files -/'
  '--manifest-path[path to Cargo.toml]:path:_files'
  {-p,--package}'[package to expand]:package:'
  '--release[build artifacts in release mode, with optimizations]'
  {-j,--jobs}'[number of parallel jobs, defaults to # of CPUs]:jobs:'
  '--verbose[print command lines as they are executed]'
  '--color[coloring]:when:(auto always never)'
  '--frozen[require Cargo.lock and cache are up to date]'
  '--locked[require Cargo.lock is up to date]'
  '--offline[run without accessing the network]'
  '-Z[unstable (nightly-only) flags to Cargo]:flag:'
  '--ugly[do not attempt to run rustfmt]'
  '--theme[select syntax highlighting theme]:theme:'
  '--themes[print available syntax highlighting theme names]'
  {-h,--help}'[prints help information]'
  {-V,--version}'[prints version information]'
  '*:filename:_files'
)

_arguments -s -S $arguments
