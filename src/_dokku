#compdef dokku

local curcontext="$curcontext" state line ret=1

_dokku_commands() {
  local -a commands=(
    'apps:manage apps'
    'config:manage environment variables'
    'domains:manage domains'
    'git:manage git settings'
    'logs:show application logs'
    'proxy:manage proxy settings'
    'ps:manage application processes'
    'storage:manage mounted storage'
    'certs:manage SSL certificates'
    'checks:manage zero-downtime checks'
    'cleanup:clean up containers and images'
    'enter:enter a running container'
    'events:show dokku events'
    'ls:list applications'
    'report:show system report'
    'run:run a command in an app environment'
    'shell:start interactive shell'
    'tags:manage app image tags'
    'tar:manage tar deployments'
    'trace:enable or disable trace mode'
    'urls:show application URLs'
    'version:show version'
  )
  _describe -t commands 'dokku command' commands
}

_dokku_apps_subcommands() {
  local -a subcommands=(
    'create:create an app'
    'destroy:destroy an app'
    'clone:clone an app'
    'list:list all apps'
    'lock:lock an app'
    'report:show app report'
    'rename:rename an app'
    'unlock:unlock an app'
  )
  _describe -t subcommands 'apps subcommand' subcommands
}

_dokku_config_subcommands() {
  local -a subcommands=(
    'show:show config vars'
    'set:set config vars'
    'unset:unset config vars'
    'clear:clear all config vars'
    'export:export config vars'
    'bundle:bundle config vars'
    'keys:show config var keys'
  )
  _describe -t subcommands 'config subcommand' subcommands
}

_dokku_domains_subcommands() {
  local -a subcommands=(
    'add:add a domain'
    'clear:clear all domains'
    'disable:disable domains'
    'enable:enable domains'
    'remove:remove a domain'
    'report:show domains report'
    'set:set domains'
  )
  _describe -t subcommands 'domains subcommand' subcommands
}

_dokku_git_subcommands() {
  local -a subcommands=(
    'allow-host:add host to known hosts'
    'auth:configure git auth'
    'from-archive:deploy from archive'
    'from-image:deploy from image'
    'initialize:initialize git repo'
    'report:show git report'
    'set:set git property'
    'sync:sync git repo'
    'unlock:unlock git repo'
  )
  _describe -t subcommands 'git subcommand' subcommands
}

_dokku_proxy_subcommands() {
  local -a subcommands=(
    'disable:disable proxy'
    'enable:enable proxy'
    'ports:list proxy ports'
    'ports-add:add proxy ports'
    'ports-clear:clear proxy ports'
    'ports-remove:remove proxy ports'
    'ports-set:set proxy ports'
    'report:show proxy report'
  )
  _describe -t subcommands 'proxy subcommand' subcommands
}

_dokku_ps_subcommands() {
  local -a subcommands=(
    'inspect:inspect app containers'
    'rebuild:rebuild an app'
    'report:show process report'
    'restart:restart an app'
    'retire:retire old containers'
    'scale:manage process scaling'
    'set:set process property'
    'start:start an app'
    'stop:stop an app'
  )
  _describe -t subcommands 'ps subcommand' subcommands
}

_dokku_storage_subcommands() {
  local -a subcommands=(
    'ensure-directory:ensure storage directory exists'
    'list:list storage mounts'
    'mount:mount storage'
    'report:show storage report'
    'unmount:unmount storage'
  )
  _describe -t subcommands 'storage subcommand' subcommands
}

_arguments -s -S -C \
  '1:command:_dokku_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      apps) _arguments '1:subcommand:_dokku_apps_subcommands' '*:app name' && ret=0 ;;
      config) _arguments '1:subcommand:_dokku_config_subcommands' '*:app name or key=value' && ret=0 ;;
      domains) _arguments '1:subcommand:_dokku_domains_subcommands' '*:app name or domain' && ret=0 ;;
      git) _arguments '1:subcommand:_dokku_git_subcommands' '*:app name' && ret=0 ;;
      proxy) _arguments '1:subcommand:_dokku_proxy_subcommands' '*:app name' && ret=0 ;;
      ps) _arguments '1:subcommand:_dokku_ps_subcommands' '*:app name' && ret=0 ;;
      storage) _arguments '1:subcommand:_dokku_storage_subcommands' '*:app name' && ret=0 ;;
      logs) _arguments '-t[tail logs]' '-n[number of lines]:lines' '*:app name' && ret=0 ;;
      run) _arguments '*:app name and command' && ret=0 ;;
      enter) _arguments '*:app name' && ret=0 ;;
    esac
    ;;
esac

return ret
