#compdef redsocks
# Documentation: https://man.archlinux.org/search?q=redsocks
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[-\? this message]'
  '-v[print version]'
  '-t[test config syntax]'
  '-p[write pid to pidfile]'
  '*:filename:_files'
)

_arguments -s -S $arguments
