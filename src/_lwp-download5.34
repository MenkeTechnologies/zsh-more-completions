#compdef lwp-download5.34
# Documentation: https://man.archlinux.org/search?q=lwp-download5.34
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-a[save the file in ASCII mode]'
  '-s[use HTTP headers to guess output filename]'
  '*:filename:_files'
)

_arguments -s -S $arguments
