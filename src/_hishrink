#compdef hishrink
# Documentation: https://man.archlinux.org/search?q=hishrink
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--help[display this message]'
  '--version[display the HINT version]'
  '-l[redirect stderr to a log file]'
  '-o[specify an output file name]'
  '-a[use only localized names]'
  '-g[do not use localized names]'
  '-c[enable compression]'
  '*:filename:_files'
)

_arguments -s -S $arguments
