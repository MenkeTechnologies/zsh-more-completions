#compdef stunbdc
# Documentation: https://man.archlinux.org/search?q=stunbdc
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-4,--ipv4}'[force IP version 4]'
  {-6,--ipv6}'[force IP version 6]'
  {-n,--numeric}'[in numeric form]'
  '*:filename:_files'
)

_arguments -s -S $arguments
