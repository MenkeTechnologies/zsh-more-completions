#compdef bkt

# Zsh completion for bkt - subprocess caching utility

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--cache-dir[directory to store cached results]:directory:_files -/' \
  '--ttl[time-to-live for cached results]:duration:' \
  '--stale[duration after which to refresh in background]:duration:' \
  '--warm[warm the cache in the background]' \
  '--force[force re-execution ignoring cache]' \
  '--discard-failures[do not cache non-zero exit codes]' \
  '--env[include environment variable in cache key]:variable:' \
  '--modtime[include file modification time in cache key]:file:_files' \
  '--scope[additional scope for cache key]:scope:' \
  '--cwd[include working directory in cache key]' \
  '(--)--[end of bkt arguments]' \
  '*:command:_command_names -e' && return 0
