#compdef silicon

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-o+[output image file]:output file:_files' \
  '--output=[output image file]:output file:_files' \
  '-l+[language for syntax highlighting]:language' \
  '--language=[language for syntax highlighting]:language' \
  '-t+[color theme]:theme' \
  '--theme=[color theme]:theme' \
  '--list-themes[list available themes]' \
  '--list-fonts[list available fonts]' \
  '-f+[font]:font' \
  '--font=[font]:font' \
  '--font-size=[font size]:size' \
  '--pad-horiz=[horizontal padding]:padding' \
  '--pad-vert=[vertical padding]:padding' \
  '--no-line-number[hide line numbers]' \
  '--no-round-corner[disable rounded corners]' \
  '--no-window-controls[hide window controls]' \
  '--line-offset=[line number offset]:offset' \
  '--line-pad=[line padding]:padding' \
  '--shadow-blur-radius=[shadow blur radius]:radius' \
  '--shadow-color=[shadow color]:color' \
  '--shadow-offset-x=[shadow offset X]:offset' \
  '--shadow-offset-y=[shadow offset Y]:offset' \
  '--tab-width=[tab width]:width' \
  '--highlight-lines=[highlight specific lines]:lines' \
  '--background=[background color]:color' \
  '--from-clipboard[read code from clipboard]' \
  '--to-clipboard[copy image to clipboard]' \
  '*:input file:_files' && ret=0

return ret
