#compdef ocrmypdf
# Zsh completion for OCRmyPDF
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-l --language)'{-l,--language}'[OCR language]:lang:' \
  '--deskew[deskew pages]' \
  '--clean[clean pages before OCR]' \
  '--clean-final[clean pages in final output]' \
  '--rotate-pages[rotate pages to correct orientation]' \
  '--remove-background[remove background from pages]' \
  '--force-ocr[force OCR even if text is present]' \
  '--skip-text[skip pages that already contain text]' \
  '--redo-ocr[redo OCR on pages that already have it]' \
  '(-O --optimize)'{-O,--optimize}'[optimization level]:level:(0 1 2 3)' \
  '(-j --jobs)'{-j,--jobs}'[number of parallel jobs]:N:' \
  '--output-type[output PDF type]:type:(pdfa pdf pdfa-1 pdfa-2 pdfa-3 none)' \
  '--pdf-renderer[PDF renderer]:renderer:(auto hocr sandwich hocrdebug)' \
  '--tesseract-config[tesseract config file]:file:_files' \
  '--pages[pages to process]:ranges:' \
  '--image-dpi[image DPI]:N:' \
  '--max-image-mpixels[max image megapixels]:N:' \
  '--title[PDF title]:text:' \
  '--author[PDF author]:text:' \
  '--subject[PDF subject]:text:' \
  '--keywords[PDF keywords]:text:' \
  '--sidecar[sidecar text file]:file:_files' \
  '--skip-big[skip images larger than size in MB]:MB:' \
  '--jpeg-quality[JPEG quality]:N:' \
  '--png-quality[PNG quality]:N:' \
  '--jbig2-lossy[enable lossy JBIG2 compression]' \
  '--keep-temporary-files[keep temporary files]' \
  '--unpaper-args[arguments for unpaper]:args:' \
  '--tesseract-timeout[tesseract timeout in seconds]:seconds:' \
  '--rotate-pages-threshold[rotation confidence threshold]:float:' \
  '--oversample[oversample DPI]:dpi:' \
  '--tesseract-pagesegmode[tesseract page segmentation mode]:N:' \
  '--user-words[user words file]:file:_files' \
  '--user-patterns[user patterns file]:file:_files' \
  '--fast-web-view[linearize for fast web viewing]:MB:' \
  '--plugin[plugin name]:name:' \
  '--no-progress-bar[disable progress bar]' \
  '(-q --quiet)'{-q,--quiet}'[suppress informational messages]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)--version[show version]' \
  '1:input PDF:_files -g "*.pdf"' \
  '2:output PDF:_files -g "*.pdf"' && ret=0
return ret
