#compdef ttyd

_arguments \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-p --port)'{-p,--port}'[port to listen on]:port' \
  '(-i --interface)'{-i,--interface}'[network interface to bind]:interface' \
  '(-c --credential)'{-c,--credential}'[credential for basic auth]:user\:pass' \
  '(-u --uid)'{-u,--uid}'[user id to run with]:uid' \
  '(-g --gid)'{-g,--gid}'[group id to run with]:gid' \
  '(-s --signal)'{-s,--signal}'[signal to send to command on disconnect]:signal' \
  '(-r --reconnect)'{-r,--reconnect}'[reconnect time in seconds]:seconds' \
  '(-R --readonly)'{-R,--readonly}'[do not allow clients to write]' \
  '*'{-t,--client-option}'[set client option]:key=value' \
  '(-T --terminal-type)'{-T,--terminal-type}'[terminal type]:type' \
  '(-O --check-origin)'{-O,--check-origin}'[check origin header]' \
  '(-m --max-clients)'{-m,--max-clients}'[maximum number of clients]:number' \
  '(-o --once)'{-o,--once}'[accept only one client then exit]' \
  '(-B --browser)'{-B,--browser}'[open browser on startup]' \
  '(-I --index)'{-I,--index}'[custom index.html]:file:_files' \
  '(-b --base-path)'{-b,--base-path}'[base path for URL]:path' \
  '(-P --ping-interval)'{-P,--ping-interval}'[websocket ping interval]:seconds' \
  '(-6 --ipv6)'{-6,--ipv6}'[enable IPv6 support]' \
  '(-S --ssl)'{-S,--ssl}'[enable SSL]' \
  '(-C --ssl-cert)'{-C,--ssl-cert}'[SSL certificate file]:file:_files' \
  '(-K --ssl-key)'{-K,--ssl-key}'[SSL key file]:file:_files' \
  '(-A --ssl-ca)'{-A,--ssl-ca}'[SSL CA file]:file:_files' \
  '(-d --debug)'{-d,--debug}'[debug level]:level' \
  '(-w --cwd)'{-w,--cwd}'[working directory]:directory:_directories' \
  '--writable[allow clients to write to the terminal]' \
  '1:command:_command_names -e' \
  '*::arguments:_normal'
