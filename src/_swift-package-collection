#compdef swift-package-collection
# Documentation: https://man.archlinux.org/search?q=swift-package-collection
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--version[show the version.]'
  {-help,-h,--help}'[show help information.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
