#compdef ksshell

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-i,--input}'[a basis file to use for seeding the kickstart data]'
  {-o,--output}'[the location to write the finished kickstart file, or stdout if not given]:file:_files'
  {-v,--version}'[version of kickstart syntax to validate against]'
  '*:filename:_files'
)

_arguments -s -S $arguments
