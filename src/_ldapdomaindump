#compdef ldapdomaindump

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-u,--user}'[DOMAIN\username for authentication, leave empty for anonymous]:user:'
  {-p,--password}'[password or LM:NTLM hash, will prompt if not specified]'
  {-at,--authtype}'[authentication type]:type:(NTLM SIMPLE)'
  {-o,--outdir}'[directory in which the dump will be saved]:dir:_files -/'
  '--no-html[disable HTML output]'
  '--no-json[disable JSON output]'
  '--no-grep[disable Greppable output]'
  '--grouped-json[also write json files for grouped files]'
  {-d,--delimiter}'[field delimiter for greppable output (default: tab)]'
  {-r,--resolve}'[resolve computer hostnames (might take a while and require DNS access)]'
  {-n,--dns-server}'[use custom DNS resolver instead of system DNS]:server:'
  {-m,--minimal}'[only query minimal set of attributes to limit memmory]'
  '*:filename:_files'
)

_arguments -s -S $arguments
