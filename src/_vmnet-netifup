#compdef vmnet-netifup
# Documentation: https://man.archlinux.org/search?q=vmnet-netifup
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-d[file>: daemon mode]'
  '-D[debug mode]'
  '-s[optional pipe descriptor for service to send]'
  '*:filename:_files'
)

_arguments -s -S $arguments
