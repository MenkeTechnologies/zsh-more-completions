#compdef aria2c

# Zsh completion for aria2c - download utility

_arguments -s -S \
  '(-d --dir)'{-d,--dir}'[directory to store downloaded files]:dir:_files -/' \
  '(-i --input-file)'{-i,--input-file}'[downloads URIs found in FILE]:file:_files' \
  '(-l --log)'{-l,--log}'[log file name]:file:_files' \
  '(-j --max-concurrent-downloads)'{-j,--max-concurrent-downloads}'[maximum number of parallel downloads]:N:' \
  '(-c --continue)'{-c,--continue}'[continue downloading partially downloaded files]' \
  '--no-conf[disable loading aria2.conf]' \
  '--conf-path[change config file path]:file:_files' \
  '(-D --daemon)'{-D,--daemon}'[run as daemon process]' \
  '--no-file-allocation-limit[do not pre-allocate file for small files]:SIZE:' \
  '(-o --out)'{-o,--out}'[file name for downloaded files]:file:' \
  '(-s --split)'{-s,--split}'[download a file using N connections]:N:' \
  '--file-allocation[specify file allocation method]:method:(none prealloc trunc falloc)' \
  '(-r --max-tries)'{-r,--max-tries}'[set number of tries]:N:' \
  '(-m --max-connection-per-server)'{-m,--max-connection-per-server}'[maximum number of connections to one server]:N:' \
  '(-k --min-split-size)'{-k,--min-split-size}'[minimum size to split file]:SIZE:' \
  '--ftp-user[set FTP user]:user:' \
  '--ftp-passwd[set FTP password]:password:' \
  '--ftp-pasv[use passive mode in FTP]' \
  '--ftp-type[set FTP transfer type]:type:(binary ascii)' \
  '--ftp-reuse-connection[reuse connection in FTP]' \
  '--http-user[set HTTP user]:user:' \
  '--http-passwd[set HTTP password]:password:' \
  '--http-proxy[use HTTP proxy]:proxy:' \
  '--http-proxy-user[set HTTP proxy user]:user:' \
  '--http-proxy-passwd[set HTTP proxy password]:password:' \
  '--https-proxy[use HTTPS proxy]:proxy:' \
  '--ftp-proxy[use FTP proxy]:proxy:' \
  '--all-proxy[use proxy for all protocols]:proxy:' \
  '--all-proxy-user[set proxy user]:user:' \
  '--all-proxy-passwd[set proxy password]:password:' \
  '--no-proxy[specify no-proxy domains]:domains:' \
  '--header[append HEADER to HTTP request headers]:header:' \
  '--load-cookies[load cookies from FILE using Firefox3/Mozilla/Netscape format]:file:_files' \
  '--save-cookies[save cookies to FILE in Mozilla/Firefox format]:file:_files' \
  '--enable-http-keep-alive[enable HTTP/1.1 persistent connection]' \
  '--enable-http-pipelining[enable HTTP/1.1 pipelining]' \
  '--max-http-pipelining[maximum HTTP pipelining level]:N:' \
  '--check-certificate[verify SSL certificate]' \
  '--ca-certificate[use certificate authority certificates]:file:_files' \
  '--certificate[use client certificate]:file:_files' \
  '--private-key[use private key]:file:_files' \
  '--referer[set HTTP referer header]:URL:' \
  '--enable-metalink[enable Metalink support (not available)]' \
  '--metalink-servers[download using N connections]:N:' \
  '--metalink-language[preferred language]:lang:' \
  '--metalink-location[preferred location]:location:' \
  '--metalink-os[preferred operating system]:OS:' \
  '--metalink-preferred-protocol[preferred protocol]:protocol:(http https ftp sftp)' \
  '--metalink-enable-unique-protocol[use unique protocol]' \
  '--bt-min-crypto-level[set minimum encryption method for BitTorrent]:level:(plain arc4)' \
  '--bt-require-crypto[require encryption for BitTorrent]' \
  '--bt-request-peer-speed-limit[limit request peer speed]:SPEED:' \
  '--bt-max-peers[set maximum number of peers]:N:' \
  '--bt-external-ip[specify external IP for BitTorrent]:IP:' \
  '--bt-enable-lpd[enable Local Peer Discovery]' \
  '--bt-lpd-interface[use interface for Local Peer Discovery]:interface:' \
  '--bt-save-metadata[save metadata as .torrent]' \
  '--bt-metadata-only[download metadata only]' \
  '--bt-seed-unverified[seed previously downloaded files without verifying]' \
  '--bt-hash-check-seed[check file hash before seeding]' \
  '--bt-max-open-files[maximum number of files to open in multi-file BitTorrent]:N:' \
  '--bt-stop-timeout[stop BitTorrent seeding if no uploaded file in N seconds]:N:' \
  '--bt-tracker[append tracker list]:trackers:' \
  '--bt-exclude-tracker[exclude trackers]:trackers:' \
  '--dht-listen-port[DHT UDP port]:port:' \
  '--dht-file-path[change DHT routing table file]:file:_files' \
  '--dht-file-path6[change IPv6 DHT routing table file]:file:_files' \
  '--enable-dht[enable DHT (IPv4) for BitTorrent]' \
  '--enable-dht6[enable IPv6 DHT for BitTorrent]' \
  '--seed-ratio[BitTorrent seeding ratio]:ratio:' \
  '--seed-time[BitTorrent seeding time]:minutes:' \
  '(-T --torrent-file)'{-T,--torrent-file}'[path to torrent file]:file:_files -g "*.torrent"' \
  '--select-file[set file to download]:indexes:' \
  '--follow-torrent[set behavior of --torrent-file option]:mode:(true false mem)' \
  '--listen-port[BitTorrent/DHT listen port]:port:' \
  '--max-upload-limit[set maximum upload speed per session]:SPEED:' \
  '(-u --max-upload-limit)'{-u,--max-upload-limit}'[set maximum upload speed]:SPEED:' \
  '--max-overall-upload-limit[set maximum overall upload speed]:SPEED:' \
  '--max-overall-download-limit[set maximum overall download limit]:SPEED:' \
  '(-x --max-connection-per-server)'{-x,--max-connection-per-server}'[max connections to single server]:N:' \
  '--max-download-limit[set maximum download speed per each download]:SPEED:' \
  '--lowest-speed-limit[close connection if speed is lower than or equal to this]:SPEED:' \
  '--stream-piece-selector[specify piece selection algorithm]:algo:(default inorder geom)' \
  '--uri-selector[specify URI selection algorithm]:algo:(feedback adaptive roundrobin)' \
  '--timeout[set timeout in seconds]:seconds:' \
  '--connect-timeout[set connect timeout in seconds]:seconds:' \
  '--max-file-not-found[maximum file not found errors]:N:' \
  '--auto-file-renaming[rename file if same file exists]' \
  '--allow-overwrite[allow overwriting existing files]' \
  '--allow-piece-length-change[allow piece length change]' \
  '--realtime-chunk-checksum[validate each chunk checksum in real time]' \
  '--checksum[specify checksum]:TYPE\:DIGEST:' \
  '(-V --check-integrity)'{-V,--check-integrity}'[check file integrity by validating piece hashes]' \
  '--netrc-path[specify .netrc file]:file:_files' \
  '--netrc[enable .netrc support]' \
  '--log-level[set log level]:level:(debug info notice warn error)' \
  '--console-log-level[set log level for console]:level:(debug info notice warn error)' \
  '--summary-interval[interval in seconds to output download progress summary]:seconds:' \
  '--on-download-complete[set command to be executed on download completion]:cmd:' \
  '--on-download-error[set command to be executed on download error]:cmd:' \
  '--on-download-start[set command to be executed on download start]:cmd:' \
  '--on-download-stop[set command to be executed on download stop]:cmd:' \
  '--on-bt-download-complete[set command for BitTorrent download complete]:cmd:' \
  '--enable-rpc[enable JSON-RPC/XML-RPC server]' \
  '--rpc-listen-port[specify port number for RPC server]:port:' \
  '--rpc-max-request-size[maximum size of RPC request]:SIZE:' \
  '--rpc-listen-all[RPC server listens on all network interfaces]' \
  '--rpc-allow-origin-all[add Access-Control-Allow-Origin header]' \
  '--rpc-user[set RPC user]:user:' \
  '--rpc-passwd[set RPC password]:password:' \
  '--rpc-secret[set RPC authorization secret token]:token:' \
  '--rpc-secure[RPC transport will be encrypted as HTTPS/WSS]' \
  '--rpc-certificate[path to the RPC server certificate]:file:_files' \
  '--rpc-private-key[path to the RPC server private key]:file:_files' \
  '--rpc-save-upload-metadata[save uploaded torrent or metalink metadata as file]' \
  '--save-session[save error/unfinished downloads to FILE]:file:_files' \
  '--save-session-interval[save error/unfinished downloads every N seconds]:seconds:' \
  '--pause[pause download after start]' \
  '--pause-metadata[pause files whose file type is unknown]' \
  '--stop[stop application after N seconds]:seconds:' \
  '--force-save[save download with --save-session even if download is completed]' \
  '--rlimit-nofile[set the soft limit of open file descriptors]:N:' \
  '--show-console-readout[show console readout]' \
  '--truncate-console-readout[truncate console readout to fit in single line]' \
  '(-q --quiet)'{-q,--quiet}'[make aria2 quiet (no console output)]' \
  '--async-dns[enable asynchronous DNS]' \
  '--async-dns-server[specify comma separated list of DNS servers]:servers:' \
  '--human-readable[print sizes and speeds in human readable format]' \
  '--remove-control-file[remove control file before download]' \
  '--always-resume[always resume download]' \
  '--max-resume-failure-tries[retry N times if resume fails]:N:' \
  '(-v --version)'{-v,--version}'[print version number]' \
  '(-h --help)'{-h,--help}'[print usage and exit]' \
  '*:URL:_urls'
