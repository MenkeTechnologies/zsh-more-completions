#compdef t1dotlessj

local -a arguments

arguments=(
  {-a,--pfa}'[output PFA font.]'
  {-b,--pfb}'[output PFB font. This is the default.]'
  {-o,--output}'[write output to FILE instead of standard output.]:file:_files'
  {-n,--name}'[set output fonts PostScript name.]:name:'
  '(- * :)'{-h,--help}'[print this message and exit.]'
  {-q,--quiet}'[do not report errors to standard error.]'
  '--version[print version number and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
