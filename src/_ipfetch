#compdef ipfetch
# Documentation: https://man.archlinux.org/search?q=ipfetch
# Reference accessed: 2026-05-16

# Zsh completion for ipfetch (visual IP information tool)

_arguments -s -S \
  '(- *)'{-h,-help}'[Show help menu]' \
  '-ip[Specify a target IP address]:IP address:' \
  '-t[Specify the fetch method]:method:(curl wget)' \
  '--version[Show version]'
