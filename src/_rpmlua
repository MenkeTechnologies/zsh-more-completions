#compdef rpmlua
# Documentation: https://man.archlinux.org/search?q=rpmlua
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    {-i,--interactive}'[Run an interactive session after executing optional script or statement.]'
    {-e,--execute}'[Execute a Lua statement before executing optional script]'
    '*:filename:_files'
)
_arguments -s -S $arguments
