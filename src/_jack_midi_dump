#compdef jack_midi_dump
# Documentation: https://man.archlinux.org/search?q=jack_midi_dump
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-a[use absoute timestamps relative to application start]'
  '-h[display this help and exit]'
  '-r[use relative timestamps to previous MIDI event]'
  '*:filename:_files'
)

_arguments -s -S $arguments
