#compdef rcrack
# Documentation: https://man.archlinux.org/search?q=rcrack
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[load single hash]'
  '-l[load hashes from a file, each hash in a line]'
  '-lm[load lm hashes from pwdump file]'
  '-ntlm[load ntlm hashes from pwdump file]'
  '*:filename:_files'
)

_arguments -s -S $arguments
