#compdef sad

# Zsh completion for sad (Search And Displace)

_arguments -s -S \
  '(-0 --read0)'{-0,--read0}'[use \0 as delimiter for stdin]' \
  '(-e --exact)'{-e,--exact}'[use exact string matching instead of regex]' \
  '(-f --flags)'{-f,--flags}'[regex flags]:flags:' \
  '(-k --commit)'{-k,--commit}'[commit changes to files (no preview)]' \
  '(-u --unified)'{-u,--unified}'[unified diff context lines]:count:' \
  '(-p --pager)'{-p,--pager}'[pager command]:pager:' \
  '(-i --internal)'{-i,--internal}'[use internal instead of external diff]' \
  '1:pattern:' \
  '2:replacement:' \
  '*:file:_files' && return 0
