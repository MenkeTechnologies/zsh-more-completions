#compdef mount

# Zsh completion for mount - mount file systems
# Supports both BSD/macOS and GNU/Linux (util-linux) variants

local -a fs_types mount_opts

fs_types=(
  apfs hfs msdos exfat ntfs ext2 ext3 ext4 xfs btrfs zfs
  nfs smbfs cifs tmpfs devfs fdesc cd9660 udf iso9660
  proc sysfs debugfs fuse overlay squashfs vfat
)

mount_opts=(
  'async:all I/O done asynchronously'
  'sync:all I/O done synchronously'
  'noatime:do not update access time on read'
  'strictatime:always update access time on read'
  'nodev:do not interpret character or block special devices'
  'noexec:do not allow execution of binaries'
  'nosuid:do not allow set-user/group-identifier bits'
  'noowners:ignore ownership field for entire volume'
  'rdonly:mount read-only'
  'union:union mount with underlying filesystem'
  'nobrowse:do not show in GUI (macOS)'
  'nofollow:do not follow symlinks in mount-on directory'
  'force:force revocation of write access for downgrade'
  'update:change status of already mounted filesystem'
  'noauto:skip when mount -a is used'
  'ro:mount read-only'
  'rw:mount read-write'
  'remount:remount an already-mounted filesystem'
  'defaults:use default options (rw,suid,dev,exec,auto,nouser,async)'
  'bind:bind mount a subtree'
  'rbind:bind mount a subtree recursively'
  'user:allow ordinary user to mount'
  'nouser:forbid ordinary user to mount (default)'
  'auto:can be mounted with -a'
  'relatime:update atime relative to mtime/ctime'
  'norelatime:do not use relative atime'
  'lazytime:only update times on in-memory inode'
  'discard:enable TRIM/discard support'
  'loop:use loop device'
  'X-mount.mkdir:create mountpoint directory if missing'
)

_mount_options() {
  _describe -t mount-options 'mount option' mount_opts
}

_mount_types() {
  _describe -t fs-types 'filesystem type' fs_types
}

local arguments

arguments=(
  # Common BSD/macOS options
  '-a[mount all filesystems from fstab/vfstab]'
  '-d[dry run; do everything except the actual mount syscall]'
  '-f[force revocation of write access when downgrading to read-only]'
  '-F[mount FSKit-delivered filesystem type (macOS) / fork off for each device with -a (Linux)]'
  '-k[do not follow symlinks in mount-on directory]'
  '-r[mount read-only (same as -o rdonly)]'
  '-t[filesystem type]:filesystem type:_mount_types'
  '-o[mount options]:options:_mount_options'
  '-u[update status of an already mounted filesystem]'
  '-v[verbose mode]'
  '-w[mount read-write (default)]'

  # GNU/Linux (util-linux) long options
  '(-a --all)'{-a,--all}'[mount all filesystems from fstab]'
  '(-c --no-canonicalize)'{-c,--no-canonicalize}'[do not canonicalize paths]'
  '(-f --fake)'{-f,--fake}'[dry run; skip the mount(2) syscall]'
  '(-F --fork)'{-F,--fork}'[fork off for each device (use with -a)]'
  '(-T --fstab)'{-T,--fstab}'[alternative file to /etc/fstab]:fstab file:_files'
  '(-i --internal-only)'{-i,--internal-only}'[do not call mount.<type> helpers]'
  '(-l --show-labels)'{-l,--show-labels}'[show filesystem labels]'
  '(-n --no-mtab)'{-n,--no-mtab}'[do not write to /etc/mtab]'
  '(-o --options)'{-o,--options}'[comma-separated list of mount options]:options:_mount_options'
  '(-O --test-opts)'{-O,--test-opts}'[limit set of filesystems (use with -a)]:test options:'
  '(-r --read-only)'{-r,--read-only}'[mount read-only (same as -o ro)]'
  '(-t --types)'{-t,--types}'[filesystem type]:filesystem type:_mount_types'
  '--source[explicitly specify source (path, label, uuid)]:source:_files'
  '--target[explicitly specify mountpoint]:mountpoint:_files -/'
  '--target-prefix[specify path used for all mountpoints]:prefix:_files -/'
  '(-v --verbose)'{-v,--verbose}'[verbose mode]'
  '(-w --rw --read-write)'{-w,--rw,--read-write}'[mount read-write (default)]'
  '(-N --namespace)'{-N,--namespace}'[perform mount in given mount namespace]:namespace:'
  '(- *)'{-h,--help}'[display help]'
  '(- *)'{-V,--version}'[display version]'
  '(-L --label)'{-L,--label}'[mount by filesystem label]:label:'
  '(-U --uuid)'{-U,--uuid}'[mount by filesystem UUID]:uuid:'
  '(-B --bind)'{-B,--bind}'[bind mount a subtree somewhere else]'
  '(-M --move)'{-M,--move}'[move a subtree to another place]'
  '(-R --rbind)'{-R,--rbind}'[bind mount a subtree and all submounts recursively]'
  '--make-shared[mark a subtree as shared]'
  '--make-slave[mark a subtree as slave]'
  '--make-private[mark a subtree as private]'
  '--make-unbindable[mark a subtree as unbindable]'
  '--make-rshared[recursively mark a whole subtree as shared]'
  '--make-rslave[recursively mark a whole subtree as slave]'
  '--make-rprivate[recursively mark a whole subtree as private]'
  '--make-runbindable[recursively mark a whole subtree as unbindable]'
  '--mkdir=[create mountpoint directory if missing]:mode:'
  '--onlyonce[do not mount if already mounted]'

  '*:device or mountpoint:_files'
)

_arguments -s -S $arguments
