#compdef hackrf_transfer
# Documentation: https://man.archlinux.org/search?q=hackrf_transfer
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[this help]'
  '-r[receive data into file (use - for stdout)]:file:_files'
  '-t[transmit data from file (use - for stdin)]:file:_files'
  '-w[receive data into file with WAV header and automatic name.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
