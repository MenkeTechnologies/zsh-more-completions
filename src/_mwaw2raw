#compdef mwaw2raw
# Documentation: https://man.archlinux.org/search?q=mwaw2raw
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--callgraph[Display the call graph nesting level]'
  '(- * :)'{-h,--help}'[:    Shows this help message]'
  {-v,--version}'[:       Output mwaw2raw version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
