#compdef h2ph
# Documentation: https://man.archlinux.org/search?q=h2ph
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '-d[put the resulting .ph files beneath the specified directory]:destination directory:_directories'
    '-r[run recursively on all header files in directories]'
    '-a[run automagically; convert header files as well as any included files]'
    '-l[replicate symbolic links in the destination directory]'
    '-h[put hints in the .ph files to help locate problems with h2ph]'
    '-e[if an error is encountered during conversion, remove output file and exit]'
    '-D[include the code from the .h file as a comment in the .ph file]'
    '*:filename:_files'
)
_arguments -s -S $arguments
