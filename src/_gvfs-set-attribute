#compdef gvfs-set-attribute
# Documentation: https://man.archlinux.org/search?q=gvfs-set-attribute
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-t,--type}'[type of the attribute]'
  {-n,--nofollow-symlinks}'[don’t follow symbolic links]'
  '*:filename:_files'
)

_arguments -s -S $arguments
