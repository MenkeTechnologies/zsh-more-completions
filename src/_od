#compdef od god

local arguments

arguments=(
  '(-A --address-radix)'{-A+,--address-radix=}'[output format for file offsets]:radix:(d o x n)'
  '--endian=[swap input bytes according to the specified order]:byte order:(big little)'
  '(-j --skip-bytes)'{-j+,--skip-bytes=}'[skip BYTES input bytes first]:bytes'
  '(-N --read-bytes)'{-N+,--read-bytes=}'[limit dump to BYTES input bytes]:bytes'
  '(-S --strings)'{-S+,--strings=}'[output strings of at least BYTES printable characters]:bytes'
  '(-t --format)'{-t+,--format=}'[select output format or formats]:type'
  '(-v --output-duplicates)'{-v,--output-duplicates}'[do not use * to mark line suppression]'
  '(-w --width)'{-w+,--width=}'[output BYTES bytes per output line]:bytes'
  '--traditional[accept arguments in traditional form]'
  '(- *)--help[display this help and exit]'
  '(- *)--version[output version information and exit]'
  '-a[named characters, ignoring high-order bit (same as -t a)]'
  '-B[octal shorts (same as -t o2)]'
  '-b[octal bytes (same as -t o1)]'
  '-c[printable characters or backslash escapes (same as -t c)]'
  '-D[unsigned decimal ints (same as -t u4)]'
  '-d[unsigned decimal shorts (same as -t u2)]'
  '-e[double-precision floating point numbers (same as -t fD)]'
  '-F[double-precision floating point numbers (same as -t fD)]'
  '-f[single-precision floating point numbers (same as -t fF)]'
  '-H[hexadecimal ints (same as -t x4)]'
  '-h[hexadecimal shorts (same as -t x2)]'
  '-I[signed decimal longs (same as -t dL)]'
  '-i[signed decimal ints (same as -t dI)]'
  '-L[signed decimal longs (same as -t dL)]'
  '-l[signed decimal longs (same as -t dL)]'
  '-O[octal ints (same as -t o4)]'
  '-o[octal shorts (same as -t o2)]'
  '-s[signed decimal shorts (same as -t d2)]'
  '-X[hexadecimal ints (same as -t x4)]'
  '-x[hexadecimal shorts (same as -t x2)]'
  '*:file:_files'
)

_arguments -s -S $arguments
