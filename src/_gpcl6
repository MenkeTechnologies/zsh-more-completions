#compdef gpcl6
# Documentation: https://man.archlinux.org/search?q=gpcl6
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-sDEVICE,-g}'[<W>x<H> -r<X>\[x<Y>\] -d{First|Last}Page=<#>]'
  '-H[<l>x<b>x<r>x<t> -dNOCACHE]'
  '-sOutputFile[(-s<option>=<string> | -d<option>\[=<value>\])*]'
  '-J[<PJL commands>]'
  '*:filename:_files'
)

_arguments -s -S $arguments
