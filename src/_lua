#compdef lua lua5.1 lua5.2 lua5.3 lua5.4 lua5.5 luajit

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '*-e+[execute string]:statement' \
  '-i[enter interactive mode after executing script]' \
  '*-l+[require library into global variable]:module or assignment (g=mod)' \
  '(- *)-v[show version information]' \
  '-E[ignore environment variables (LUAINIT, LUA_PATH, LUA_CPATH)]' \
  '-W[turn warnings on]' \
  '(-)--[stop handling options]' \
  '(-)-[stop handling options and execute stdin]' \
  '1:script file:_files -g "*.lua(-.)"' \
  '*:script arguments:_files' && ret=0

return ret
