#compdef pkg-config pkgconf

# Zsh completion for pkg-config / pkgconf
# Covers both traditional pkg-config and pkgconf options

# Helper to complete package names from pkg-config database
_pkg_config_packages() {
  local -a packages
  packages=(${(f)"$(pkg-config --list-all 2>/dev/null | awk '{print $1}')"})
  _describe -t packages 'package' packages
}

_arguments -s -S \
  '(- *)'{-h,--help}'[show help options]' \
  '(- *)--version[output version of pkg-config]' \
  '(- *)--about[print pkgconf version and license to stdout]' \
  '(- *)--list-all[list all known packages]' \
  '(- *)--list-package-names[list all known package names]' \
  '--modversion[output version for package]' \
  '--atleast-pkgconfig-version=[require given version of pkg-config]:version' \
  '--libs[output all linker flags]' \
  '--libs-only-l[output -l flags]' \
  '--libs-only-L[output -L flags]' \
  '--libs-only-other[output other libs (e.g. -pthread)]' \
  '--cflags[output all pre-processor and compiler flags]' \
  '--cflags-only-I[output -I flags]' \
  '--cflags-only-other[output cflags not covered by the cflags-only-I option]' \
  '--internal-cflags[do not filter internal cflags from output]' \
  '--static[be more aggressive when computing dependency graph (for static linking)]' \
  '--shared[use a simplified dependency graph (usually default)]' \
  '--pure[optimize a static dependency graph as if it were a normal dependency graph]' \
  '--short-errors[print short errors]' \
  '--print-errors[show verbose information about missing or conflicting packages]' \
  '--silence-errors[be silent about errors]' \
  '--errors-to-stdout[print errors to stdout instead of stderr]' \
  '*--variable=[get the value of a variable]:variable name' \
  '*--define-variable=[set variable NAME to VALUE]:name=value' \
  '--exists[return 0 if the module(s) exist]' \
  '--uninstalled[return 0 if the uninstalled version will be used]' \
  '--no-uninstalled[never use uninstalled modules when satisfying dependencies]' \
  '--atleast-version=[return 0 if the module is at least version VERSION]:version' \
  '--exact-version=[return 0 if the module is at exactly version VERSION]:version' \
  '--max-version=[return 0 if the module is at no newer than version VERSION]:version' \
  '--print-variables[output list of variables defined by the module]' \
  '--print-requires[print which packages the package requires]' \
  '--print-requires-private[print which packages the package requires for static linking]' \
  '--print-provides[print which packages the package provides]' \
  '--validate[validate a package .pc file]' \
  '--debug[show verbose debug information]' \
  '--verbose[print additional information]' \
  '--define-prefix[override the prefix variable with a guessed value based on .pc file location]' \
  '--dont-define-prefix[do not override the prefix variable under any circumstances]' \
  '--prefix-variable=[set the name of the variable considered to be the package prefix]:variable name' \
  '--relocate=[relocate a path and exit]:path:_files -/' \
  '--dont-relocate-paths[disable path relocation support]' \
  '--personality=[set the personality to a triplet or filename]:triplet or file:_files' \
  '(- *)--dump-personality[dump details concerning selected personality]' \
  '--simulate[simulate walking the calculated dependency graph]' \
  '--no-cache[do not cache already seen packages when walking the dependency graph]' \
  '--log-file=[write an audit log to a specified file]:log file:_files' \
  '*--with-path=[add a directory to the search path]:directory:_files -/' \
  '--no-provides[do not use provides rules to resolve dependencies]' \
  '--maximum-traverse-depth=[maximum allowed depth for dependency graph]:depth' \
  '--env-only[look only for package entries in PKG_CONFIG_PATH]' \
  '--ignore-conflicts[ignore conflicts rules in modules]' \
  '--keep-system-cflags[keep system include entries in cflags output]' \
  '--keep-system-libs[keep system lib entries in libs output]' \
  '--path[show the exact filenames for any matching .pc files]' \
  '--digraph[print entire dependency graph in graphviz dot format]' \
  '--solution[print dependency graph solution in a simple format]' \
  '--msvc-syntax[print translatable fragments in MSVC syntax]' \
  '--fragment-filter=[filter output fragments to specified types]:types' \
  '--env=[print output as shell-compatible environmental variables]:prefix' \
  '--fragment-tree[visualize printed CFLAGS/LIBS fragments as a tree]' \
  '--license[print the specified module'\''s license to stdout if known]' \
  '--exists-cflags[add -DHAVE_FOO fragments to cflags for each found module]' \
  '*:package:_pkg_config_packages'
