#compdef faillog

local -a arguments

arguments=(
  {-a,--all}'[display faillog records for all users]'
  '(- * :)'{-h,--help}'[display this help message and exit]'
  {-l,--lock-secs}'[after failed login lock account for SEC seconds]:seconds:'
  {-m,--maximum}'[set maximum failed login counters to MAX]:max:'
  {-r,--reset}'[reset the counters of login failures]'
  {-R,--root}'[directory to chroot into]:directory:_files -/'
  {-t,--time}'[display faillog records more recent than DAYS]:days:'
  {-u,--user}'[display faillog record or maintain failure counters]:user:_users'
  '*:filename:_files'
)

_arguments -s -S $arguments
