#compdef devbox

# Zsh completion for Devbox - portable, isolated dev environments

local curcontext="$curcontext" state line ret=1

local -a global_flags=(
  '--config[Path to devbox config file]:config file:_files'
  '(-q --quiet)'{-q,--quiet}'[Suppress non-error output]'
  '--debug[Show debug output]'
  '--help[Show help]'
)

local -a commands=(
  'add:Add a package to your devbox'
  'create:Initialize a directory as a devbox project using a template'
  'generate:Generate supporting files'
  'global:Manage global devbox packages'
  'info:Display package info'
  'init:Initialize a directory as a devbox project'
  'install:Install all packages mentioned in devbox.json'
  'list:List packages in current devbox environment'
  'rm:Remove a package from your devbox'
  'run:Run a script or command in a devbox shell'
  'search:Search for available packages'
  'services:Manage services'
  'shell:Start a new shell with access to your packages'
  'shellenv:Print shell commands that create a devbox environment'
  'update:Update packages in your devbox'
  'version:Print version information'
  'help:Help about any command'
)

_devbox_packages() {
  local -a packages
  packages=(${(f)"$(devbox list --json 2>/dev/null | jq -r '.packages[]' 2>/dev/null)"})
  compadd -a packages
}

_devbox_scripts() {
  local -a scripts
  scripts=(${(f)"$(devbox run --list 2>/dev/null | tail -n +2 | awk '{print $1}')"})
  compadd -a scripts
}

_arguments -s -S -C \
  $global_flags \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'devbox command' commands && ret=0
    ;;
  args)
    case $words[1] in
      add)
        _arguments -s -S \
          $global_flags \
          '--allow-insecure[Allow insecure packages]:packages' \
          '--disable-plugin[Disable a plugin for this package]:plugin' \
          '--platform[Target platform]:platform' \
          '*:package' && ret=0
        ;;
      create)
        _arguments -s -S \
          $global_flags \
          ':template' && ret=0
        ;;
      generate)
        local -a generate_cmds=(
          'devcontainer:Generate a devcontainer.json'
          'dockerfile:Generate a Dockerfile'
          'direnv:Generate a .envrc file'
          'readme:Generate a README.md'
        )
        _arguments -s -S -C \
          $global_flags \
          '1:generate command:->gen_cmd' && ret=0
        case $state in
          gen_cmd)
            _describe -t commands 'generate command' generate_cmds && ret=0
            ;;
        esac
        ;;
      global)
        local -a global_cmds=(
          'add:Add a global package'
          'list:List global packages'
          'path:Print path to global devbox directory'
          'pull:Pull a global devbox config from a remote source'
          'push:Push global devbox config to a remote source'
          'remove:Remove a global package'
          'run:Run a script in global devbox shell'
          'shellenv:Print global shell environment'
          'update:Update global packages'
        )
        _arguments -s -S -C \
          $global_flags \
          '1:global command:->global_cmd' \
          '*::arg:->global_args' && ret=0
        case $state in
          global_cmd)
            _describe -t commands 'global command' global_cmds && ret=0
            ;;
          global_args)
            case $words[1] in
              add)
                _arguments -s -S \
                  $global_flags \
                  '--allow-insecure[Allow insecure packages]:packages' \
                  '--disable-plugin[Disable a plugin]:plugin' \
                  '--platform[Target platform]:platform' \
                  '*:package' && ret=0
                ;;
              remove)
                _arguments -s -S \
                  $global_flags \
                  '*:package' && ret=0
                ;;
              run)
                _arguments -s -S \
                  $global_flags \
                  '*:script or command' && ret=0
                ;;
              pull|push)
                _arguments -s -S \
                  $global_flags \
                  ':url or path' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      info)
        _arguments -s -S \
          $global_flags \
          '--markdown[Output in markdown format]' \
          ':package' && ret=0
        ;;
      init)
        _arguments -s -S \
          $global_flags \
          ':directory:_files -/' && ret=0
        ;;
      install)
        _arguments -s -S \
          $global_flags && ret=0
        ;;
      list)
        _arguments -s -S \
          $global_flags \
          '--json[Output in JSON format]' && ret=0
        ;;
      rm)
        _arguments -s -S \
          $global_flags \
          '*:package:_devbox_packages' && ret=0
        ;;
      run)
        _arguments -s -S \
          $global_flags \
          '--list[List available scripts]' \
          '*:script:_devbox_scripts' && ret=0
        ;;
      search)
        _arguments -s -S \
          $global_flags \
          ':search query' && ret=0
        ;;
      services)
        local -a services_cmds=(
          'ls:List available services'
          'restart:Restart services'
          'start:Start services'
          'stop:Stop services'
        )
        _arguments -s -S -C \
          $global_flags \
          '1:services command:->svc_cmd' \
          '*::arg:->svc_args' && ret=0
        case $state in
          svc_cmd)
            _describe -t commands 'services command' services_cmds && ret=0
            ;;
          svc_args)
            _arguments -s -S \
              $global_flags \
              '*:service' && ret=0
            ;;
        esac
        ;;
      shell)
        _arguments -s -S \
          $global_flags \
          '--print-env[Print the shell environment]' \
          '--pure[Start shell without inheriting environment]' \
          '*:packages to add' && ret=0
        ;;
      shellenv)
        _arguments -s -S \
          $global_flags \
          '--init-hook[Run init hooks]' \
          '--install[Install packages if needed]' \
          '--pure[Print a pure shell environment]' && ret=0
        ;;
      update)
        _arguments -s -S \
          $global_flags \
          '*:package:_devbox_packages' && ret=0
        ;;
    esac
    ;;
esac

return ret
