#compdef mariabackup

local -a arguments

arguments=(
  '--print-defaults[print the program argument list and exit.]'
  '--no-defaults[dont read default options from any option file.]'
  '--defaults-file[only read default options from the given file #.]'
  '--defaults-extra-file[read this file after the global files are read.]'
  '--defaults-group-suffix[additionally read default groups with # appended as a suffix.]'
  {-V,--verbose}'[display verbose output]'
  {-v,--version}'[print xtrabackup version information]'
  '--target-dir[destination directory]'
  '--backup[take backup to target-dir]'
  '--prepare[prepare a backup for starting mysql server on the backup.]'
  '--export[create files to import to another database when prepare.]'
  '--print-param[print parameter of mysqld needed for copyback.]'
  '--use-memory[the value is used instead of buffer_pool_size]'
  '--throttle[limit count of IO operations (pairs of read&write) per second]'
  '--log[ignored option for MySQL option compatibility]'
  '--log-copy-interval[time interval between checks done by log copying thread in milliseconds]'
  '--extra-lsndir[(for --backup): save an extra copy of the xtrabackup_checkpoints file]'
  '--incremental-dir[(for --prepare): apply .delta files and logfile in the specified directory]'
  '--tables[filtering by regexp for table names.]'
  '--tables-file[filtering by list of the exact database.table name in the specified file]'
  '--databases[filtering by list of databases]'
  '--databases-file[filtering by list of databases in the file]'
  '--tables-exclude[filtering by regexp for table names to exclude]'
  '--databases-exclude[excluding databases based on name]'
  '--stream[stream all backup files to the standard output in the specified format]'
  '--compress[compress individual backup files using the specified compression algorithm]'
  '--compress-threads[number of threads for parallel data compression]'
  '--compress-chunk-size[size of working buffer(s) for compression threads in bytes]'
  '--incremental-force-scan[perform a full-scan incremental backup even in the presence of changed page tracking data]'
  '--close-files[do not keep files opened. Use at your own risk.]'
  '--core-file[write core on fatal signals]'
  '--copy-back[copy all the files in a previously made backup from the backup directory to the original location]'
  '--move-back[move all the files in a previously made backup from the backup directory to the original location]'
  '--galera-info[this options creates the xtrabackup_galera_info file]'
  '--slave-info[this option is useful when backing up a replication slave]'
  '--no-lock[use this option to disable table lock with FLUSH TABLES WITH READ LOCK]'
  '--safe-slave-backup[stop slave SQL thread and wait to start backup until slave catches up]'
  '--rsync[uses the rsync utility to optimize local file transfers.]'
  '--force-non-empty-directories[makes --copy-back or --move-back transfer files to non-empty directories]'
  '--no-version-check[disable the version check]'
  '--no-backup-locks[this option controls if backup locks should be used]'
  '--decompress[decompress all files with the .qp extension in a backup]'
  {-u,--user}'[MySQL username used when connecting to the server]'
  {-H,--host}'[host to use when connecting to the database server]'
  {-P,--port}'[port to use when connecting to the database server]'
  {-p,--password}'[password to use when connecting to the server]'
  '--help[display help and exit]'
  '--protocol[the protocol to use for connection (tcp, socket, pipe, memory)]'
  {-S,--socket}'[socket to use when connecting to the local server]'
  '--incremental-history-name[name of the backup series stored in PERCONA_SCHEMA.xtrabackup_history]'
  '--incremental-history-uuid[UUID of the specific history record for incremental backup]'
  '--incremental-basedir[directory containing the full backup as base for incremental]:directory:_directories'
  '--incremental-lsn[specify the log sequence number for incremental backup]:lsn: '
  '--remove-original[remove .qp files after decompression.]'
  '--ftwrl-wait-query-type[specify which types of queries are allowed to complete before FTWRL]'
  '--kill-long-query-type[specify which types of queries should be killed to unblock FTWRL]'
  '--history[this option enables the tracking of backup history in the PERCONA_SCHEMA.xtrabackup_history table]'
  '--kill-long-queries-timeout[seconds to wait before killing long-running queries after FTWRL]'
  '--ftwrl-wait-timeout[time in seconds to wait for queries to complete before FTWRL]'
  '--ftwrl-wait-threshold[query run time threshold to wait for before FTWRL]'
  '--debug-sleep-before-unlock[debug-only option used by the XtraBackup test suite]'
  '--safe-slave-backup-timeout[how many seconds --safe-slave-backup should wait for slave to catch up]'
  '--binlog-info[controls how XtraBackup should retrieve server binary log coordinates]'
  '--secure-auth[refuse client connecting to server if it uses old protocol]'
  '--ssl[enable SSL for connection]'
  '--ssl-ca[CA file in PEM format (implies --ssl)]'
  '--ssl-capath[CA directory (check OpenSSL docs, implies --ssl).]'
  '--ssl-cert[X509 cert in PEM format (implies --ssl).]'
  '--ssl-cipher[SSL cipher to use (implies --ssl).]'
  '--ssl-key[X509 key in PEM format (implies --ssl).]'
  '--ssl-crl[certificate revocation list (implies --ssl).]'
  '--ssl-crlpath[certificate revocation list path (implies --ssl).]'
  '--ssl-verify-server-cert[verify servers Common Name in its cert against hostname]'
  {-h,--datadir}'[path to the database root.]'
  {-t,--tmpdir}'[path for temporary files]'
  '--parallel[number of threads to use for parallel datafiles transfer.]'
  '--extended-validation[enable extended validation for InnoDB data pages during backup]'
  '--log-bin[base name for the log sequence]'
  '--innodb[ignored option for MySQL option compatibility]'
  '--innodb-adaptive-hash-index[enable InnoDB adaptive hash index (enabled by default).]'
  '--innodb-autoextend-increment[data file autoextend increment in megabytes]'
  '--innodb-buffer-pool-size[the size of the memory buffer InnoDB uses to cache data and indexes]'
  '--innodb-data-file-path[path to individual files and their sizes.]'
  '--innodb-data-home-dir[the common part for InnoDB table spaces.]'
  '--innodb-doublewrite[enable InnoDB doublewrite buffer during --prepare.]'
  '--innodb-io-capacity[number of IOPs the server can do. Tunes the background IO rate]'
  '--innodb-file-io-threads[number of file I/O threads in InnoDB.]'
  '--innodb-read-io-threads[number of background read I/O threads in InnoDB.]'
  '--innodb-write-io-threads[number of background write I/O threads in InnoDB.]'
  '--innodb-file-per-table[stores each InnoDB table to an .ibd file in the database directory]'
  '--innodb-flush-method[with which method to flush data.]'
  '--innodb-log-buffer-size[the size of the buffer which InnoDB uses to write log to the log files on disk]'
  '--innodb-log-file-size[ignored for mysqld option compatibility]'
  '--innodb-log-files-in-group[ignored for mysqld option compatibility]'
  '--innodb-log-group-home-dir[path to InnoDB log files.]'
  '--innodb-max-dirty-pages-pct[percentage of dirty pages allowed in bufferpool.]'
  '--innodb-open-files[how many files at the maximum InnoDB keeps open at the same time]'
  '--innodb-use-native-aio[use native AIO if supported on this platform.]'
  '--innodb-page-size[the universal page size of the database.]'
  '--innodb-buffer-pool-filename[ignored for mysqld option compatibility]'
  '--debug-sync[debug sync point. Only used by the xtrabackup test suite]'
  '--innodb-checksum-algorithm[the algorithm InnoDB uses for page checksumming]'
  '--innodb-undo-directory[directory where undo tablespace files live]'
  '--innodb-undo-tablespaces[number of undo tablespaces to use.]'
  '--defaults-group[defaults group in config file (default "mysqld").]'
  '--plugin-dir[server plugin directory. Used to load encryption plugins]'
  '--innodb-encrypt-log[whether to encrypt innodb log]'
  '--innodb-log-checksums[whether to require checksums for InnoDB redo log blocks]'
  '--open-files-limit[the maximum number of file descriptors to reserve]'
  '--lock-ddl-per-table[lock DDL for each table before xtrabackup starts to copy it]'
  '--rocksdb-datadir[RocksDB data directory]'
  '--rocksdb-backup[backup RocksDB data, if RocksDB plugin is installed]'
  '--check-privileges[check database user privileges for the backup user]'
  '*:filename:_files'
)

_arguments -s -S $arguments
