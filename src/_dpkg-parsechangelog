#compdef dpkg-parsechangelog

local -a arguments

arguments=(
  '-l[get per-version info from this file.]'
  '-F[force changelog format.]'
  {-S,--show-field}'[show the values for <field>.]'
  '--version[show the version.]'
  '--format[set output format (defaults to dpkg).]'
  '--all[include all changes.]'
  {-s,-v,--since}'[include all changes later than <version>]:version'
  {-u,--until}'[include all changes earlier than <version>]:version'
  {-f,--from}'[include all changes equal or later than <version>]:version'
  {-t,--to}'[include all changes up to or equal than <version>]:version'
  {-c,-n,--count}'[include <number> entries from the top (or tail with negative)]:number'
  {-o,--offset}'[change starting point for --count, counted from]'
  '*:filename:_files'
)

_arguments -s -S $arguments
