#compdef clickhouse

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'client:start clickhouse client'
  'server:start clickhouse server'
  'local:start clickhouse local'
  'benchmark:run benchmark queries'
  'compressor:compress or decompress data'
  'extract-from-config:extract value from config'
  'format:format queries'
  'obfuscator:obfuscate data'
  'copier:copy data between clusters'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'clickhouse command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (client)
        _arguments -s -S \
          '--host=[server host]:host' \
          '--port=[server port]:port' \
          '(-u --user)'{-u,--user}'=[user name]:user' \
          '--password=[password]:password' \
          '(-d --database)'{-d,--database}'=[database name]:database' \
          '(-q --query)'{-q,--query}'=[query to execute]:query' \
          '--queries-file=[file with queries]:file:_files' \
          '(-m --multiquery)'{-m,--multiquery}'[allow multiple queries]' \
          '(-n --multiline)'{-n,--multiline}'[allow multiline queries]' \
          '--format=[output format]:format:(TabSeparated CSV JSON JSONEachRow Pretty PrettyCompact Vertical Native)' \
          '--vertical[vertical output format]' \
          '(-t --time)'{-t,--time}'[print query execution time]' \
          '--stacktrace[print stack traces on exceptions]' \
          '--config-file=[path to config file]:config:_files' \
          '--secure[use TLS connection]' \
          '--history_file=[path to history file]:file:_files' \
          '--pager=[pager program]:pager' \
          '--max_memory_usage=[max memory usage in bytes]:bytes' \
          '--max_threads=[max number of threads]:threads' \
          '--send_logs_level=[client logs level]:level:(none fatal error warning information debug trace)' \
          '--progress[show progress bar]' \
          '--no-warnings[disable warnings]' && ret=0
        ;;
      (local)
        _arguments -s -S \
          '(-S --structure)'{-S,--structure}'=[structure of input data]:structure' \
          '(-q --query)'{-q,--query}'=[query to execute]:query' \
          '--queries-file=[file with queries]:file:_files' \
          '--input-format=[input format]:format:(TabSeparated CSV JSON JSONEachRow Parquet ORC)' \
          '--output-format=[output format]:format:(TabSeparated CSV JSON JSONEachRow Pretty PrettyCompact Parquet)' \
          '--file=[path to data file]:file:_files' \
          '--table=[table name]:table' \
          '(-m --multiquery)'{-m,--multiquery}'[allow multiple queries]' \
          '--stacktrace[print stack traces on exceptions]' \
          '--logger.log=[path to log file]:file:_files' \
          '--logger.level=[log level]:level:(none fatal error warning information debug trace)' \
          '--config-file=[path to config file]:config:_files' && ret=0
        ;;
      (server)
        _arguments -s -S \
          '--config-file=[path to config file]:config:_files' \
          '--daemon[run as daemon]' \
          '--pid-file=[path to PID file]:file:_files' && ret=0
        ;;
      (benchmark)
        _arguments -s -S \
          '--host=[server host]:host' \
          '--port=[server port]:port' \
          '--user=[user name]:user' \
          '--password=[password]:password' \
          '--database=[database name]:database' \
          '--query=[query to benchmark]:query' \
          '--concurrency=[number of parallel queries]:number' \
          '--delay=[delay between queries in seconds]:seconds' \
          '--iterations=[total number of queries]:number' \
          '--timelimit=[time limit in seconds]:seconds' \
          '--randomize[randomize order of queries]' \
          '--cumulative[print cumulative data]' \
          '--json=[path for JSON output]:file:_files' && ret=0
        ;;
      (format)
        _arguments -s -S \
          '--hilite[enable syntax highlighting]' \
          '--oneline[format to single line]' \
          '--obfuscate[obfuscate queries]' \
          '--query=[query to format]:query' \
          '--max_query_size=[max query size]:size' \
          '--seed=[seed for obfuscation]:seed' && ret=0
        ;;
    esac
    ;;
esac

return ret
