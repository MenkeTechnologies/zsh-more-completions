#compdef rtpinsertsound
# Documentation: https://man.archlinux.org/search?q=rtpinsertsound
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-a[RTP IPv4 addr]'
  '-A[RTP port]'
  '-b[RTP IPv4 addr]'
  '-B[RTP port]'
  '-f[factor - amount by which to:]'
  '-i[(e.g. eth0)]'
  '-j[factor - the reception of a legitimate RTP]'
  '-p[to pause between setup and injection]'
  '-h[print this usage]'
  '-v[output mode]'
  '*:filename:_files'
)

_arguments -s -S $arguments
