#compdef ipvsadm

# Zsh completion for ipvsadm - Linux Virtual Server administration

local curcontext="$curcontext" state line ret=1

local -a schedulers=(
  'rr:round robin'
  'wrr:weighted round robin'
  'lc:least-connection'
  'wlc:weighted least-connection'
  'lblc:locality-based least-connection'
  'lblcr:locality-based least-connection with replication'
  'dh:destination hashing'
  'sh:source hashing'
  'sed:shortest expected delay'
  'nq:never queue'
  'fo:weighted failover'
  'ovf:weighted overflow'
  'mh:maglev hashing'
)

_arguments -s -S \
  '(-A --add-service)'{-A,--add-service}'[add virtual service]' \
  '(-E --edit-service)'{-E,--edit-service}'[edit virtual service]' \
  '(-D --delete-service)'{-D,--delete-service}'[delete virtual service]' \
  '(-C --clear)'{-C,--clear}'[clear the whole virtual server table]' \
  '(-R --restore)'{-R,--restore}'[restore rules from stdin]' \
  '(-S --save)'{-S,--save}'[save rules to stdout]' \
  '(-a --add-server)'{-a,--add-server}'[add real server]' \
  '(-e --edit-server)'{-e,--edit-server}'[edit real server]' \
  '(-d --delete-server)'{-d,--delete-server}'[delete real server]' \
  '(-L --list -l)'{-L,--list,-l}'[list virtual server table]' \
  '(-Z --zero)'{-Z,--zero}'[zero packet, byte and rate counters]' \
  '--set[set connection timeout values]:tcp tcpfin udp:' \
  '--start-daemon[start connection sync daemon]:state:(master backup)' \
  '--stop-daemon[stop connection sync daemon]:state:(master backup)' \
  '(-t --tcp-service)'{-t,--tcp-service}'[TCP virtual service]:host\:port:' \
  '(-u --udp-service)'{-u,--udp-service}'[UDP virtual service]:host\:port:' \
  '(-f --fwmark-service)'{-f,--fwmark-service}'[firewall-mark virtual service]:fwmark:' \
  '(-s --scheduler)'{-s,--scheduler}'[scheduling algorithm]:scheduler:((${(j: :)schedulers}))' \
  '(-p --persistent)'{-p,--persistent}'[persistent connection timeout]:seconds:' \
  '(-M --netmask)'{-M,--netmask}'[persistent granularity mask]:netmask:' \
  '(-r --real-server)'{-r,--real-server}'[real server address]:host\[\:port\]:' \
  '(-g --gatewaying)'{-g,--gatewaying}'[use gatewaying (direct routing)]' \
  '(-i --ipip)'{-i,--ipip}'[use ipip encapsulation (tunneling)]' \
  '(-m --masquerading)'{-m,--masquerading}'[use masquerading (NAT)]' \
  '(-w --weight)'{-w,--weight}'[real server weight]:weight:' \
  '(-x --u-threshold)'{-x,--u-threshold}'[upper connection threshold]:count:' \
  '(-y --l-threshold)'{-y,--l-threshold}'[lower connection threshold]:count:' \
  '-o[set one-packet scheduling mode]' \
  '--mcast-interface[multicast interface for sync daemon]:interface:_net_interfaces' \
  '--syncid[sync daemon syncid]:syncid:' \
  '--daemon[show daemon information]' \
  '--timeout[show timeout values]' \
  '--stats[show statistics]' \
  '--rate[show connection rate]' \
  '--thresholds[show thresholds]' \
  '--persistent-conn[show persistent connection info]' \
  '--tun-type[set tunnel type]:type:(ipip gue gre)' \
  '--tun-port[set tunnel port (for gue)]:port:' \
  '--tun-nocsum[disable tunnel checksum]' \
  '--tun-csum[enable tunnel checksum]' \
  '--tun-remcsum[enable tunnel remote checksum offload]' \
  '--sort[sort output]' \
  '(-n --numeric)'{-n,--numeric}'[print numeric addresses and port numbers]' \
  '--exact[expand numbers in output]' \
  '(-c --connection)'{-c,--connection}'[list current IPVS connections]' \
  '(-6 --ipv6)'{-6,--ipv6}'[use IPv6]' && ret=0

return ret
