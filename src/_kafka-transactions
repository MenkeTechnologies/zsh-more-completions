#compdef kafka-transactions

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--command-config[Property file with configs to pass to Admin Client]:file:_files'
    '1:command:(list describe describe-producers abort find-hanging)'
    '--topic[Topic name]:topic:'
    '--partition[Partition number]:partition:'
    '--transactional-id[Transactional ID]:id:'
    '--producer-id[Producer ID]:id:'
    '--producer-epoch[Producer epoch]:epoch:'
    '--coordinator-epoch[Transaction coordinator epoch]:epoch:'
    '--start-time[Start time for finding hanging transactions]:time:'
)

_arguments -s -S $arguments
