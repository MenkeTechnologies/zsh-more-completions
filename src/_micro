#compdef micro

# Zsh completion for micro - a modern and intuitive terminal-based text editor

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,-help}'[show help]' \
  '(- *)--version[show version]' \
  '-autoindent=[set autoindent]:value:(true false)' \
  '-autosave=[set autosave interval in seconds]:seconds:' \
  '-backup=[enable file backup]:value:(true false)' \
  '-basename=[show basename in tab bar]:value:(true false)' \
  '-colorcolumn=[set column for color indicator]:column:' \
  '-colorscheme=[set color scheme]:scheme:' \
  '-cursorline=[highlight cursor line]:value:(true false)' \
  '-diffgutter=[show VCS diff gutter]:value:(true false)' \
  '-encoding=[set file encoding]:encoding:' \
  '-eofnewline=[add newline at EOF]:value:(true false)' \
  '-fastdirty=[use fast dirty detection]:value:(true false)' \
  '-fileformat=[set file format]:format:(unix dos)' \
  '-filetype=[set file type]:type:' \
  '-hlsearch=[highlight search results]:value:(true false)' \
  '-ignorecase=[ignore case in search]:value:(true false)' \
  '-indentchar=[set indentation character]:char:' \
  '-infobar=[show info bar at bottom]:value:(true false)' \
  '-keepautoindent=[preserve indentation on blank lines]:value:(true false)' \
  '-keymenu=[show key menu at bottom]:value:(true false)' \
  '-matchbrace=[highlight matching braces]:value:(true false)' \
  '-mkparents=[create parent directories on save]:value:(true false)' \
  '-mouse=[enable mouse support]:value:(true false)' \
  '-multiopen=[how to open multiple files]:mode:(tab hsplit vsplit)' \
  '-parsecursor=[parse cursor position from filename]:value:(true false)' \
  '-paste=[treat terminal paste as literal]:value:(true false)' \
  '-readonly=[open in read-only mode]:value:(true false)' \
  '-rmtrailingws=[remove trailing whitespace on save]:value:(true false)' \
  '-ruler=[show column ruler]:value:(true false)' \
  '-savecursor=[remember cursor position]:value:(true false)' \
  '-saveundo=[persist undo history]:value:(true false)' \
  '-scrollbar=[show scrollbar]:value:(true false)' \
  '-scrollmargin=[set scroll margin]:lines:' \
  '-scrollspeed=[set scroll speed]:speed:' \
  '-smartpaste=[enable smart paste]:value:(true false)' \
  '-softwrap=[enable soft wrapping]:value:(true false)' \
  '-splitbottom=[new horizontal splits below]:value:(true false)' \
  '-splitright=[new vertical splits right]:value:(true false)' \
  '-statusformatl=[set left status format]:format:' \
  '-statusformatr=[set right status format]:format:' \
  '-statusline=[show status line]:value:(true false)' \
  '-sucmd=[set super user command]:command:' \
  '-syntax=[enable syntax highlighting]:value:(true false)' \
  '-tabmovement=[use tab for indentation movement]:value:(true false)' \
  '-tabsize=[set tab size]:size:' \
  '-tabstospaces=[convert tabs to spaces]:value:(true false)' \
  '-useprimary=[use primary clipboard on Linux]:value:(true false)' \
  '-wordwrap=[enable word wrapping]:value:(true false)' \
  '-config-dir=[set config directory]:directory:_files -/' \
  '-options[show all option help]' \
  '-debug[enable debug mode]' \
  '-plugin=[manage plugins]:action:(install remove update search list available)' \
  '-clean[clean configuration directory]' \
  '*:file:_files' && ret=0

return ret
