#compdef systemd-vpick


local -a arguments

arguments=(
    '--suffix[switch to configure the file suffix to look for.]'
    {--basename,-B}'[.]'
    '-V[.]'
    '-A[.]'
    '-S[.]'
    {--type,-t}'[.]'
    {--print,-p}'[.]'
    '--resolve[.]'
    {-h,--help}'[.]'
    '--version[.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
