#compdef systemd-vpick
# Documentation: https://man.archlinux.org/search?q=systemd-vpick
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '--suffix[switch to configure the file suffix to look for.]'
    {--basename,-B}'[match by basename]'
    '-V'
    '-A'
    '-S'
    {--type,-t}'[specify resource type]'
    {--print,-p}'[print selected entry path]'
    '--resolve'
    {-h,--help}'[show help message]'
    '--version'
    '*:filename:_files'
)
_arguments -s -S $arguments
