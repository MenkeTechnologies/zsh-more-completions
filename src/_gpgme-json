#compdef gpgme-json
# Documentation: https://man.archlinux.org/search?q=gpgme-json
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-i,--interactive}'[interactive REPL]'
  {-s,--single}'[single request mode]'
  '--lib-version[show library version]'
  '--debug[flyswatter]'
  '*:filename:_files'
)

_arguments -s -S $arguments
