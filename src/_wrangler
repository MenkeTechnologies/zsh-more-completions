#compdef wrangler

# Zsh completion for wrangler (Cloudflare Workers CLI)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a global_opts=(
  '(-c --config)'{-c,--config}'[path to wrangler.toml]:file:_files'
  '(-e --env)'{-e,--env}'[environment to use]:env:'
  '(-h --help)'{-h,--help}'[show help]'
  '(-v --version)'{-v,--version}'[show version number]'
)

local -a subcommands=(
  'init:create a new Cloudflare Workers project'
  'dev:start a local development server'
  'deploy:deploy your Worker to Cloudflare'
  'publish:deploy your Worker to Cloudflare (alias for deploy)'
  'delete:delete your Worker from Cloudflare'
  'tail:start a log tailing session'
  'secret:manage Worker secrets'
  'kv:interact with Workers KV'
  'r2:interact with Cloudflare R2'
  'd1:interact with Cloudflare D1'
  'pages:manage Cloudflare Pages projects'
  'ai:manage Workers AI'
  'queues:manage Cloudflare Queues'
  'login:authorize wrangler with your Cloudflare account'
  'logout:remove authorization from wrangler'
  'whoami:show the currently logged in user'
  'types:generate types from bindings and module rules'
  'docs:open the Cloudflare Workers documentation'
  'versions:manage Worker versions'
)

_arguments -s -S -C \
  $global_opts \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t subcommands 'wrangler command' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      dev)
        _arguments -s -S \
          $global_opts \
          '--name[name of the Worker]:name:' \
          '--entry[entry point for the Worker]:file:_files' \
          '--compatibility-date[date to use for compatibility flags]:date:' \
          '*--compatibility-flags[flags to use for compatibility]:flag:' \
          '--latest[use the latest version of the Workers runtime]' \
          '--ip[IP address to listen on]:ip:' \
          '--port[port to listen on]:port:' \
          '--inspector-port[port for devtools to connect to]:port:' \
          '*--routes[routes to register]:route:' \
          '--host[host to forward requests to]:host:' \
          '--local-protocol[protocol to listen to requests on]:protocol:(http https)' \
          '--experimental-local[use the new local runtime]' \
          '--no-bundle[skip bundling the Worker]' \
          '*--var[define a Worker binding variable]:key=value:' \
          '*--define[define a replacement value]:key=value:' \
          '--jsx-factory[the function that is called for each JSX element]:factory:' \
          '--jsx-fragment[the function that is called for each JSX fragment]:fragment:' \
          '--tsconfig[path to a custom tsconfig]:file:_files' \
          '*:script:_files' && ret=0
        ;;
      deploy|publish)
        _arguments -s -S \
          $global_opts \
          '--name[name of the Worker]:name:' \
          '--dry-run[do not actually deploy]' \
          '--outdir[output directory for --dry-run]:dir:_directories' \
          '--minify[minify the script]' \
          '--latest[use the latest version of the Workers runtime]' \
          '--compatibility-date[date to use for compatibility flags]:date:' \
          '*--compatibility-flags[flags to use for compatibility]:flag:' \
          '*:script:_files' && ret=0
        ;;
      delete)
        _arguments -s -S \
          $global_opts \
          '--name[name of the Worker]:name:' \
          '--dry-run[do not actually delete]' && ret=0
        ;;
      tail)
        _arguments -s -S \
          $global_opts \
          '--name[name of the Worker to tail]:name:' \
          '--format[output format]:format:(json pretty)' \
          '--status[filter by HTTP status]:status:(ok error canceled)' \
          '--header[filter by HTTP header]:header:' \
          '--method[filter by HTTP method]:method:' \
          '--sampling-rate[sampling rate (0-1)]:rate:' \
          '--search[filter by search string]:query:' \
          '--ip[filter by client IP]:ip:' && ret=0
        ;;
      init)
        _arguments -s -S \
          $global_opts \
          '--type[type of Worker to create]:type:(javascript rust webpack)' \
          '--yes[answer yes to all prompts]' \
          '--from-dash[name of existing Worker on Cloudflare]:name:' \
          ':name:' && ret=0
        ;;
      secret)
        local -a secret_commands=(
          'put:create or update a secret variable'
          'delete:delete a secret variable'
          'list:list all secret variables'
          'bulk:bulk manage secret variables'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->secret_cmd' \
          '*::arg:->secret_args' && ret=0
        case $state in
          secret_cmd)
            _describe -t commands 'secret subcommand' secret_commands && ret=0
            ;;
          secret_args)
            case $line[1] in
              put)
                _arguments -s -S $global_opts '--name[name of the Worker]:worker:' ':key:' && ret=0
                ;;
              delete)
                _arguments -s -S $global_opts '--name[name of the Worker]:worker:' ':key:' && ret=0
                ;;
              list)
                _arguments -s -S $global_opts '--name[name of the Worker]:worker:' && ret=0
                ;;
              bulk)
                _arguments -s -S $global_opts ':json file:_files' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      kv)
        local -a kv_commands=(
          'namespace:manage KV namespaces'
          'key:manage KV key-value pairs'
          'bulk:manage KV in bulk'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->kv_cmd' \
          '*::arg:->kv_args' && ret=0
        case $state in
          kv_cmd)
            _describe -t commands 'kv subcommand' kv_commands && ret=0
            ;;
          kv_args)
            case $line[1] in
              namespace)
                local -a ns_commands=(
                  'create:create a new KV namespace'
                  'delete:delete a KV namespace'
                  'list:list KV namespaces'
                )
                _arguments -s -S -C \
                  $global_opts \
                  '1:subcommand:->ns_cmd' \
                  '*::arg:->ns_args' && ret=0
                case $state in
                  ns_cmd)
                    _describe -t commands 'namespace subcommand' ns_commands && ret=0
                    ;;
                  ns_args)
                    case $line[1] in
                      create)
                        _arguments -s -S $global_opts '--preview[interact with a preview namespace]' ':title:' && ret=0
                        ;;
                      delete)
                        _arguments -s -S $global_opts '--namespace-id[the ID of the namespace]:id:' '--preview[interact with a preview namespace]' && ret=0
                        ;;
                      list)
                        _arguments -s -S $global_opts && ret=0
                        ;;
                    esac
                    ;;
                esac
                ;;
              key)
                local -a key_commands=(
                  'put:write a key-value pair'
                  'get:read a value by key'
                  'delete:remove a key-value pair'
                  'list:list keys in a namespace'
                )
                _arguments -s -S -C \
                  $global_opts \
                  '1:subcommand:->key_cmd' \
                  '*::arg:->key_args' && ret=0
                case $state in
                  key_cmd)
                    _describe -t commands 'key subcommand' key_commands && ret=0
                    ;;
                  key_args)
                    case $line[1] in
                      put)
                        _arguments -s -S $global_opts \
                          '--namespace-id[the ID of the namespace]:id:' \
                          '--preview[interact with a preview namespace]' \
                          '--ttl[time to live in seconds]:seconds:' \
                          '--expiration[expiration timestamp]:timestamp:' \
                          '--path[read value from a file]:file:_files' \
                          ':key:' && ret=0
                        ;;
                      get)
                        _arguments -s -S $global_opts '--namespace-id[the ID of the namespace]:id:' '--preview[interact with a preview namespace]' ':key:' && ret=0
                        ;;
                      delete)
                        _arguments -s -S $global_opts '--namespace-id[the ID of the namespace]:id:' '--preview[interact with a preview namespace]' ':key:' && ret=0
                        ;;
                      list)
                        _arguments -s -S $global_opts '--namespace-id[the ID of the namespace]:id:' '--preview[interact with a preview namespace]' '--prefix[filter by key prefix]:prefix:' && ret=0
                        ;;
                    esac
                    ;;
                esac
                ;;
              bulk)
                local -a bulk_commands=(
                  'put:write multiple key-value pairs'
                  'delete:remove multiple key-value pairs'
                )
                _arguments -s -S -C \
                  $global_opts \
                  '1:subcommand:->bulk_cmd' \
                  '*::arg:->bulk_args' && ret=0
                case $state in
                  bulk_cmd)
                    _describe -t commands 'bulk subcommand' bulk_commands && ret=0
                    ;;
                  bulk_args)
                    _arguments -s -S $global_opts '--namespace-id[the ID of the namespace]:id:' '--preview[interact with a preview namespace]' ':json file:_files' && ret=0
                    ;;
                esac
                ;;
            esac
            ;;
        esac
        ;;
      r2)
        local -a r2_commands=(
          'object:manage R2 objects'
          'bucket:manage R2 buckets'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->r2_cmd' \
          '*::arg:->r2_args' && ret=0
        case $state in
          r2_cmd)
            _describe -t commands 'r2 subcommand' r2_commands && ret=0
            ;;
          r2_args)
            case $line[1] in
              object)
                local -a obj_commands=(
                  'get:fetch an object from a bucket'
                  'put:upload an object to a bucket'
                  'delete:delete an object from a bucket'
                )
                _arguments -s -S -C \
                  $global_opts \
                  '1:subcommand:->obj_cmd' \
                  '*::arg:->obj_args' && ret=0
                case $state in
                  obj_cmd)
                    _describe -t commands 'object subcommand' obj_commands && ret=0
                    ;;
                  obj_args)
                    case $line[1] in
                      put)
                        _arguments -s -S $global_opts '--file[path to the file to upload]:file:_files' '--content-type[MIME type of the object]:type:' ':object path:' && ret=0
                        ;;
                      get|delete)
                        _arguments -s -S $global_opts ':object path:' && ret=0
                        ;;
                    esac
                    ;;
                esac
                ;;
              bucket)
                local -a bucket_commands=(
                  'create:create a new R2 bucket'
                  'delete:delete an R2 bucket'
                  'list:list R2 buckets'
                )
                _arguments -s -S -C \
                  $global_opts \
                  '1:subcommand:->bucket_cmd' \
                  '*::arg:->bucket_args' && ret=0
                case $state in
                  bucket_cmd)
                    _describe -t commands 'bucket subcommand' bucket_commands && ret=0
                    ;;
                  bucket_args)
                    case $line[1] in
                      create)
                        _arguments -s -S $global_opts ':bucket name:' && ret=0
                        ;;
                      delete)
                        _arguments -s -S $global_opts ':bucket name:' && ret=0
                        ;;
                      list)
                        _arguments -s -S $global_opts && ret=0
                        ;;
                    esac
                    ;;
                esac
                ;;
            esac
            ;;
        esac
        ;;
      d1)
        local -a d1_commands=(
          'create:create a new D1 database'
          'delete:delete a D1 database'
          'list:list D1 databases'
          'info:get information about a D1 database'
          'execute:execute SQL against a D1 database'
          'migrations:manage D1 migrations'
          'backup:manage D1 backups'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->d1_cmd' \
          '*::arg:->d1_args' && ret=0
        case $state in
          d1_cmd)
            _describe -t commands 'd1 subcommand' d1_commands && ret=0
            ;;
          d1_args)
            case $line[1] in
              create)
                _arguments -s -S $global_opts ':database name:' && ret=0
                ;;
              delete)
                _arguments -s -S $global_opts ':database name:' && ret=0
                ;;
              info)
                _arguments -s -S $global_opts ':database name:' && ret=0
                ;;
              execute)
                _arguments -s -S $global_opts \
                  '--command[SQL statement to execute]:sql:' \
                  '--file[SQL file to execute]:file:_files' \
                  '--local[execute locally]' \
                  '--json[output as JSON]' \
                  ':database name:' && ret=0
                ;;
              list)
                _arguments -s -S $global_opts && ret=0
                ;;
              migrations)
                local -a mig_commands=(
                  'create:create a new migration'
                  'apply:apply pending migrations'
                  'list:list available migrations'
                )
                _arguments -s -S -C \
                  $global_opts \
                  '1:subcommand:->mig_cmd' \
                  '*::arg:->mig_args' && ret=0
                case $state in
                  mig_cmd)
                    _describe -t commands 'migrations subcommand' mig_commands && ret=0
                    ;;
                  mig_args)
                    case $line[1] in
                      create)
                        _arguments -s -S $global_opts ':migration name:' && ret=0
                        ;;
                      apply)
                        _arguments -s -S $global_opts '--local[apply locally]' ':database name:' && ret=0
                        ;;
                      list)
                        _arguments -s -S $global_opts ':database name:' && ret=0
                        ;;
                    esac
                    ;;
                esac
                ;;
              backup)
                local -a bk_commands=(
                  'create:create a new backup'
                  'list:list available backups'
                  'restore:restore a backup'
                  'download:download a backup'
                )
                _arguments -s -S -C \
                  $global_opts \
                  '1:subcommand:->bk_cmd' \
                  '*::arg:->bk_args' && ret=0
                case $state in
                  bk_cmd)
                    _describe -t commands 'backup subcommand' bk_commands && ret=0
                    ;;
                  bk_args)
                    case $line[1] in
                      create)
                        _arguments -s -S $global_opts ':database name:' && ret=0
                        ;;
                      list)
                        _arguments -s -S $global_opts ':database name:' && ret=0
                        ;;
                      restore)
                        _arguments -s -S $global_opts ':database name:' ':backup id:' && ret=0
                        ;;
                      download)
                        _arguments -s -S $global_opts '--output[output file]:file:_files' ':database name:' ':backup id:' && ret=0
                        ;;
                    esac
                    ;;
                esac
                ;;
            esac
            ;;
        esac
        ;;
      pages)
        local -a pages_commands=(
          'project:manage Pages projects'
          'deploy:deploy a Pages project'
          'deployment:manage Pages deployments'
          'dev:start a local Pages dev server'
          'download:download settings from a Pages project'
          'functions:manage Pages Functions'
          'secret:manage Pages secrets'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->pages_cmd' \
          '*::arg:->pages_args' && ret=0
        case $state in
          pages_cmd)
            _describe -t commands 'pages subcommand' pages_commands && ret=0
            ;;
          pages_args)
            case $line[1] in
              project)
                local -a pp_commands=(
                  'create:create a new Pages project'
                  'list:list Pages projects'
                  'delete:delete a Pages project'
                )
                _arguments -s -S -C \
                  $global_opts \
                  '1:subcommand:->pp_cmd' \
                  '*::arg:->pp_args' && ret=0
                case $state in
                  pp_cmd)
                    _describe -t commands 'project subcommand' pp_commands && ret=0
                    ;;
                  pp_args)
                    case $line[1] in
                      create)
                        _arguments -s -S $global_opts '--production-branch[production branch name]:branch:' ':project name:' && ret=0
                        ;;
                      delete)
                        _arguments -s -S $global_opts ':project name:' && ret=0
                        ;;
                      list)
                        _arguments -s -S $global_opts && ret=0
                        ;;
                    esac
                    ;;
                esac
                ;;
              deploy)
                _arguments -s -S $global_opts \
                  '--project-name[the name of the project]:name:' \
                  '--branch[the branch to deploy]:branch:' \
                  '--commit-hash[the commit hash of the deployment]:hash:' \
                  '--commit-message[the commit message of the deployment]:message:' \
                  ':directory:_directories' && ret=0
                ;;
              deployment)
                local -a dep_commands=(
                  'list:list deployments'
                  'tail:tail deployment logs'
                )
                _arguments -s -S -C \
                  $global_opts \
                  '1:subcommand:->dep_cmd' \
                  '*::arg:->dep_args' && ret=0
                case $state in
                  dep_cmd)
                    _describe -t commands 'deployment subcommand' dep_commands && ret=0
                    ;;
                  dep_args)
                    _arguments -s -S $global_opts '--project-name[the name of the project]:name:' && ret=0
                    ;;
                esac
                ;;
              secret)
                local -a ps_commands=(
                  'put:create or update a secret'
                  'delete:delete a secret'
                  'list:list secrets'
                  'bulk:bulk manage secrets'
                )
                _arguments -s -S -C \
                  $global_opts \
                  '1:subcommand:->ps_cmd' \
                  '*::arg:->ps_args' && ret=0
                case $state in
                  ps_cmd)
                    _describe -t commands 'secret subcommand' ps_commands && ret=0
                    ;;
                  ps_args)
                    case $line[1] in
                      put)
                        _arguments -s -S $global_opts '--project-name[project name]:name:' ':key:' && ret=0
                        ;;
                      delete)
                        _arguments -s -S $global_opts '--project-name[project name]:name:' ':key:' && ret=0
                        ;;
                      list)
                        _arguments -s -S $global_opts '--project-name[project name]:name:' && ret=0
                        ;;
                      bulk)
                        _arguments -s -S $global_opts '--project-name[project name]:name:' ':json file:_files' && ret=0
                        ;;
                    esac
                    ;;
                esac
                ;;
              dev|download|functions)
                _arguments -s -S $global_opts '*:directory:_directories' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      queues)
        local -a queues_commands=(
          'create:create a new queue'
          'delete:delete a queue'
          'list:list queues'
          'consumer:manage queue consumers'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->queues_cmd' \
          '*::arg:->queues_args' && ret=0
        case $state in
          queues_cmd)
            _describe -t commands 'queues subcommand' queues_commands && ret=0
            ;;
          queues_args)
            case $line[1] in
              create)
                _arguments -s -S $global_opts ':queue name:' && ret=0
                ;;
              delete)
                _arguments -s -S $global_opts ':queue name:' && ret=0
                ;;
              list)
                _arguments -s -S $global_opts && ret=0
                ;;
              consumer)
                local -a consumer_commands=(
                  'add:add a consumer to a queue'
                  'remove:remove a consumer from a queue'
                )
                _arguments -s -S -C \
                  $global_opts \
                  '1:subcommand:->consumer_cmd' \
                  '*::arg:->consumer_args' && ret=0
                case $state in
                  consumer_cmd)
                    _describe -t commands 'consumer subcommand' consumer_commands && ret=0
                    ;;
                  consumer_args)
                    _arguments -s -S $global_opts ':queue name:' ':script name:' && ret=0
                    ;;
                esac
                ;;
            esac
            ;;
        esac
        ;;
      login|logout|whoami|types|docs|versions|ai)
        _arguments -s -S $global_opts && ret=0
        ;;
    esac
    ;;
esac

return ret
