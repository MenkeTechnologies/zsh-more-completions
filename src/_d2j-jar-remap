#compdef d2j-jar-remap
# Documentation: https://man.archlinux.org/search?q=d2j-jar-remap
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-c,--config}'[config file for remap, this is REQUIRED]'
  {-f,--force}'[force overwrite]'
  '(- * :)'{-h,--help}'[print this help message]'
  {-o,--output}'[output .jar file, default is $current_dir/\[jar-name\]-remap.jar]:file:_files'
  '*:filename:_files'
)

_arguments -s -S $arguments
