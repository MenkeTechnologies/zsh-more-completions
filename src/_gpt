#compdef gpt

local -a subcommands
subcommands=(
    'create:Create a GPT partition table'
    'destroy:Destroy a GPT partition table'
    'add:Add a partition entry'
    'remove:Remove a partition entry'
    'label:Label a partition'
    'recover:Recover GPT from backup'
    'show:Show partition table'
    'backup:Backup GPT to file'
    'restore:Restore GPT from file'
    'boot:Set/display boot partition'
    'resize:Resize a partition entry'
    'resizedisk:Resize backup GPT after disk expansion'
    'unset:Unset partition attribute'
    'set:Set partition attribute'
    'migrate:Migrate MBR to GPT'
)

_arguments -C \
    '1:subcommand:->subcmd' \
    '*:: :->args'

case $state in
    subcmd)
        _describe -t subcommands 'gpt subcommand' subcommands
        ;;
    args)
        case $words[1] in
            add)
                _arguments \
                    '-a[Alignment]:alignment' \
                    '-b[Start block]:block' \
                    '-i[Partition index]:index' \
                    '-l[Partition label]:label' \
                    '-s[Size in blocks]:size' \
                    '-t[Partition type GUID]:type' \
                    '*:device:_files -g "/dev/*"'
                ;;
            remove)
                _arguments \
                    '-a[Remove all partitions]' \
                    '-b[Start block of partition]:block' \
                    '-i[Partition index]:index' \
                    '-l[Partition label]:label' \
                    '-s[Size in blocks]:size' \
                    '-t[Partition type GUID]:type' \
                    '*:device:_files -g "/dev/*"'
                ;;
            label)
                _arguments \
                    '-a[Label all partitions]' \
                    '-b[Start block]:block' \
                    '-f[Force label]' \
                    '-i[Partition index]:index' \
                    '-l[Partition label]:label' \
                    '*:device:_files -g "/dev/*"'
                ;;
            show)
                _arguments \
                    '-g[Show GUIDs]' \
                    '-l[Show labels]' \
                    '-u[Show UUIDs]' \
                    '-i[Partition index]:index' \
                    '*:device:_files -g "/dev/*"'
                ;;
            resize)
                _arguments \
                    '-i[Partition index]:index' \
                    '-s[New size in blocks]:size' \
                    '*:device:_files -g "/dev/*"'
                ;;
            backup|restore)
                _arguments \
                    '-f[Backup file]:file:_files' \
                    '*:device:_files -g "/dev/*"'
                ;;
            set|unset)
                _arguments \
                    '-a[Attribute]:attribute:(bootme bootonce bootfailed)' \
                    '-i[Partition index]:index' \
                    '*:device:_files -g "/dev/*"'
                ;;
            *)
                _arguments '*:device:_files -g "/dev/*"'
                ;;
        esac
        ;;
esac
