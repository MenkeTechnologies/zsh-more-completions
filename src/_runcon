#compdef runcon

local -a arguments

arguments=(
  {-c,--compute}'[compute process transition context before modifying]'
  {-t,--type}'[type (for same role as parent)]:type: '
  {-u,--user}'[user identity]:user: '
  {-r,--role}'[role]:role: '
  {-l,--range}'[level range]:range: '
  '--help[display this help and exit]'
  '--version[output version information and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
