#compdef hwloc-assembler
# Documentation: https://man.archlinux.org/search?q=hwloc-assembler
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-v,--verbose}'[show verbose messages]'
  {-f,--force}'[ignore errors while reading input files]'
  {-n,--name}'[set the name of the next input topology]'
  '*:filename:_files'
)

_arguments -s -S $arguments
