#compdef imsettings-reload
# Documentation: https://man.archlinux.org/search?q=imsettings-reload
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  {-f,--force}'[force reloading imsettings-daemon (deprecated).]'
  '*:filename:_files'
)

_arguments -s -S $arguments
