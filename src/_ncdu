#compdef ncdu

# Zsh completion for ncdu (NCurses Disk Usage)
# https://dev.yorhel.nl/ncdu

_ncdu() {
  local -a arguments

  arguments=(
    # Mode selection
    '(- *)'{-h,--help}'[display help message]'
    '(- *)'{-v,-V,--version}'[print version]'
    '--ignore-config[do not load config files]'

    # Scan options
    {-x,--one-file-system}'[stay on the same filesystem]'
    '*--exclude[exclude files that match pattern]:exclude pattern'
    {-X,--exclude-from}'[exclude files that match any pattern in file]:exclude file:_files'
    '--exclude-caches[exclude directories containing CACHEDIR.TAG]'
    {-L,--follow-symlinks}'[follow symbolic links (excluding directories)]'
    '--exclude-kernfs[exclude Linux pseudo filesystems (procfs, sysfs, cgroup, ...)]'
    {-e,--extended}'[enable extended information]'
    {-t,--threads}'[number of threads to use for scanning]:number of threads'

    # Import/export options
    '-f[import scanned directory from file]:input file:_files'
    '-o[export scanned directory to file in JSON format]:output file:_files'
    '-O[export scanned directory to file in binary format]:output file:_files'
    {-c,--compress}'[use Zstandard compression with -o]'
    '--compress-level[set compression level]:level'
    '--export-block-size[set export block size with -O]:size in KiB'

    # Interface options
    '-0[do not show any scanning UI]'
    '-1[show a single-line scanning UI]'
    '-2[show full ncurses scanning UI]'
    {-q,--slow-ui-updates}'[quiet mode, refresh interval 2 seconds]'
    '-r[read only (disable file deletion)]'
    '-rr[read only++ (disable deletion and shell)]'
    '--enable-shell[enable shell spawning feature]'
    '--disable-shell[disable shell spawning feature]'
    '--enable-delete[enable file deletion feature]'
    '--disable-delete[disable file deletion feature]'
    '--enable-refresh[enable directory refresh feature]'
    '--disable-refresh[disable directory refresh feature]'
    '--si[use base 10 (SI) prefixes instead of base 2]'
    '--apparent-size[show apparent size instead of disk usage by default]'
    '--hide-hidden[hide hidden or excluded files by default]'
    '--show-itemcount[show item count column by default]'
    '--show-mtime[show mtime column by default (requires -e)]'
    '--show-graph[show graph column by default]'
    '--show-percent[show percent column by default]'
    '--graph-style[set the style of the file size bar graph]:style:(hash half-block eighth-block)'
    '--shared-column[set shared size column mode]:mode:(off shared unique)'
    '--sort[set the default sort column and order]:column-order:(disk-usage-asc disk-usage-desc name-asc name-desc apparent-size-asc apparent-size-desc itemcount-asc itemcount-desc mtime-asc mtime-desc)'
    '--enable-natsort[use natural order when sorting by name]'
    '--group-directories-first[sort directories before files]'
    '--confirm-quit[ask confirmation before quitting ncdu]'
    '--no-confirm-delete[do not ask confirmation before deletion]'
    '--delete-command[command to run for file deletion]:command:_command_names -e'
    '--color[set color scheme]:scheme:(off dark dark-bg)'

    # Positional: directory to scan
    '*:directory:_directories'
  )

  _arguments -s -S $arguments
}

_ncdu "$@"
