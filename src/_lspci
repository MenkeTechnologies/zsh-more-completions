#compdef lspci

# zsh completions for 'lspci'

_lspci() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -s -S \
        '-m[produce machine-readable output (backward-compatible format)]' \
        '-mm[produce machine-readable output for easy script parsing]' \
        '-t[show a tree-like diagram of buses, bridges, devices and connections]' \
        '-v[be verbose and display detailed information about all devices]' \
        '-vv[be very verbose and display more details]' \
        '-vvv[be even more verbose and display everything parseable]' \
        '-k[show kernel drivers handling each device and capable modules]' \
        '-x[show hex-dump of the standard part of the config space]' \
        '-xxx[show hex-dump of the whole PCI config space (dangerous; root only)]' \
        '-xxxx[show hex-dump of the 4096-byte extended config space (root only)]' \
        '-b[bus-centric view (addresses and IRQs as seen by the bus)]' \
        '-D[always show PCI domain numbers]' \
        '-P[identify PCI devices by path through each bridge]' \
        '-PP[identify PCI devices by path, showing bus and device number]' \
        '-n[show PCI vendor and device codes as numbers]' \
        '-nn[show PCI vendor and device codes as both numbers and names]' \
        '-q[query the central PCI ID database via DNS for unknown IDs]' \
        '-qq[query via DNS, resetting the local cache]' \
        '-Q[query the central PCI ID database for all IDs via DNS]' \
        '-s[show only devices in selected slots]:slot (\[domain\:\]\[bus\:\]\[device\]\[.function\]):' \
        '-d[show only devices with specified vendor/device/class IDs]:IDs (\[vendor\]\:\[device\]\[\:class\[\:prog-if\]\]):' \
        '-i[use specified PCI ID database file]:PCI ID file:_files' \
        '-p[look up kernel modules in specified file]:module map file:_files' \
        '-M[invoke bus mapping mode (dangerous; root only)]' \
        '-A[use the specified PCI access method]:access method:->accessmethod' \
        '-O[set PCI access parameter]:parameter=value:' \
        '-H1[use direct hardware access via Intel config mechanism 1]' \
        '-H2[use direct hardware access via Intel config mechanism 2]' \
        '-F[read PCI configuration dump from a given file]:dump file:_files' \
        '-G[increase debug level of the library]' \
        '--version[show lspci version]' \
        '*:device:_files' && ret=0

    case $state in
        accessmethod)
            local -a methods
            methods=(
                'linux-sysfs:Linux sysfs'
                'linux-proc:Linux procfs'
                'intel-conf1:Intel configuration mechanism 1'
                'intel-conf2:Intel configuration mechanism 2'
                'dump:Read from dump file'
            )
            _describe -t methods 'access method' methods && ret=0
            ;;
    esac

    return ret
}

_lspci "$@"
