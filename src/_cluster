#compdef cluster
# Documentation: https://man.archlinux.org/search?q=cluster
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-C[generate no more than k clusters (0)]'
  '-c[use clustering method k (0)]'
  '-o[output file (stdout)]'
  '-v[verbose mode]'
  '*:filename:_files'
)

_arguments -s -S $arguments
