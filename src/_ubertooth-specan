#compdef ubertooth-specan
# Documentation: https://man.archlinux.org/search?q=ubertooth-specan
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[help]'
  '-v[(print debug information to stderr)]'
  '-g[suitable for feedgnuplot]'
  '-G[suitable for 3D feedgnuplot]'
  '-d[output to file]:filename:_files'
  '-l[lower frequency (default 2402)]:freq:'
  '-u[upper frequency (default 2480)]:freq:'
  '-U[set ubertooth device to use]:0-7:'
  '*:filename:_files'
)

_arguments -s -S $arguments
