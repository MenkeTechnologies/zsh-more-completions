#compdef gtscheck
# Documentation: https://man.archlinux.org/search?q=gtscheck
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-v,--verbose}'[print statistics about the surface]'
  '(- * :)'{-h,--help}'[display this help and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
