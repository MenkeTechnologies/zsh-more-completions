#compdef etcd

local -a arguments

arguments=(
  '--name[human-readable name for this member]:name:'
  '--data-dir[path to the data directory]:directory:_directories'
  '--wal-dir[path to the dedicated wal directory]:directory:_directories'
  '--snapshot-count[number of committed transactions to trigger a snapshot to disk]:count:'
  '--heartbeat-interval[time in ms of a heartbeat interval]:interval:'
  '--election-timeout[time in ms of an election timeout]:timeout:'
  '--initial-election-tick-advance[whether to fast-forward initial election ticks on boot]'
  '--listen-peer-urls[list of URLs to listen on for peer traffic]:urls:'
  '--listen-client-urls[list of URLs to listen on for client traffic]:urls:'
  '--max-snapshots[maximum number of snapshot files to retain]:count:'
  '--max-wals[maximum number of wal files to retain]:count:'
  '--quota-backend-bytes[raise alarms when backend size exceeds the given quota]:bytes:'
  '--backend-bbolt-freelist-type[backend bbolt freelist type]:type:'
  '--backend-batch-interval[backend batch interval]:interval:'
  '--backend-batch-limit[backend batch limit]:limit:'
  '--max-txn-ops[maximum number of operations permitted in a transaction]:count:'
  '--max-request-bytes[maximum client request size in bytes]:bytes:'
  '--grpc-keepalive-min-time[minimum interval for client pings]:duration:'
  '--grpc-keepalive-interval[frequency of server-to-client pings]:duration:'
  '--grpc-keepalive-timeout[additional wait time before closing non-responsive connection]:duration:'
  '--socket-reuse-port[enable socket SO_REUSEPORT]'
  '--socket-reuse-address[enable socket SO_REUSEADDR]'
  '--initial-advertise-peer-urls[list of peer URLs to advertise to the rest of the cluster]:urls:'
  '--initial-cluster[initial cluster configuration for bootstrapping]:config:'
  '--initial-cluster-state[initial cluster state (new or existing)]:state:(new existing)'
  '--initial-cluster-token[initial cluster token]:token:'
  '--advertise-client-urls[list of client URLs to advertise to the public]:urls:'
  '--discovery[discovery URL used to bootstrap the cluster]:url:'
  '--discovery-fallback[expected behavior when discovery services fails]:action:(proxy exit)'
  '--discovery-proxy[HTTP proxy to use for traffic to discovery service]:proxy:'
  '--discovery-srv[DNS srv domain used to bootstrap the cluster]:domain:'
  '--discovery-srv-name[suffix to the DNS srv name queried when bootstrapping]:name:'
  '--strict-reconfig-check[reject reconfiguration requests that would cause quorum loss]'
  '--pre-vote[enable the raft pre-vote algorithm]'
  '--auto-compaction-retention[auto compaction retention for mvcc key value store]:retention:'
  '--auto-compaction-mode[auto compaction mode (periodic or revision)]:mode:(periodic revision)'
  '--enable-v2[accept etcd V2 client requests]'
  '--v2-deprecation[v2store deprecation stage]:stage:'
  '--cert-file[path to the client server TLS cert file]:file:_files'
  '--key-file[path to the client server TLS key file]:file:_files'
  '--client-cert-auth[enable client cert authentication]'
  '--client-crl-file[path to the client certificate revocation list file]:file:_files'
  '--client-cert-allowed-hostname[allowed TLS hostname for client cert authentication]:hostname:'
  '--trusted-ca-file[path to the client server TLS trusted CA cert file]:file:_files'
  '--auto-tls[client TLS using generated certificates]'
  '--peer-cert-file[path to the peer server TLS cert file]:file:_files'
  '--peer-key-file[path to the peer server TLS key file]:file:_files'
  '--peer-client-cert-auth[enable peer client cert authentication]'
  '--peer-trusted-ca-file[path to the peer server TLS trusted CA file]:file:_files'
  '--peer-cert-allowed-cn[allowed CN for inter-peer TLS authentication]:cn:'
  '--peer-cert-allowed-hostname[allowed TLS hostname for inter-peer authentication]:hostname:'
  '--peer-auto-tls[peer TLS using generated certificates]'
  '--self-signed-cert-validity[validity period of the self-signed certificate in years]:years:'
  '--peer-crl-file[path to the peer certificate revocation list file]:file:_files'
  '--cipher-suites[comma-separated list of supported TLS cipher suites]:suites:'
  '--cors[comma-separated list of CORS origins]:origins:'
  '--host-whitelist[comma-separated list of acceptable hostnames]:hostnames:'
  '--auth-token[specify auth token specific options]:token-type:'
  '--bcrypt-cost[specify bcrypt algorithm cost factor]:cost:'
  '--auth-token-ttl[time to live in seconds of the auth token]:ttl:'
  '--enable-pprof[enable runtime profiling data via HTTP server]'
  '--metrics[set level of detail for exported metrics]:level:(basic extensive)'
  '--listen-metrics-urls[list of URLs to listen on for the metrics and health endpoints]:urls:'
  '--logger[specify logger (zap or capnslog)]:logger:(zap)'
  '--log-outputs[specify log outputs (stdout, stderr, or file path)]:outputs:'
  '--log-level[configures log level (debug, info, warn, error, panic, fatal)]:level:(debug info warn error panic fatal)'
  '--enable-log-rotation[enable log rotation of a single log-outputs file target]'
  '--log-rotation-config-json[configures log rotation as JSON]:json:'
  '--experimental-enable-distributed-tracing[enable experimental distributed tracing]'
  '--experimental-distributed-tracing-address[distributed tracing collector address]:address:'
  '--experimental-distributed-tracing-service-name[distributed tracing service name]:name:'
  '--experimental-distributed-tracing-instance-id[distributed tracing instance ID]:id:'
  '--proxy[proxy mode setting (off, readonly, or on)]:mode:(off readonly on)'
  '--proxy-failure-wait[time in ms before retrying to proxy a failed request]:ms:'
  '--proxy-refresh-interval[time in ms of the endpoints refresh interval]:ms:'
  '--proxy-dial-timeout[time in ms for a dial to timeout]:ms:'
  '--proxy-write-timeout[time in ms for a write to timeout]:ms:'
  '--proxy-read-timeout[time in ms for a read to timeout]:ms:'
  '--experimental-initial-corrupt-check[enable to check data corruption before serving any client/peer traffic]'
  '--experimental-corrupt-check-time[duration of time between cluster corruption check passes]:duration:'
  '--experimental-enable-v2v3[serve v2 requests through the v3 backend under a given prefix]:prefix:'
  '--experimental-enable-lease-checkpoint[enable primary lessor to persist lease remainingTTL to consensus]'
  '--experimental-compaction-batch-limit[sets the maximum revisions deleted in each compaction batch]:limit:'
  '--experimental-peer-skip-client-san-verification[skip verification of SAN field in client certificate for peer connections]'
  '--experimental-watch-progress-notify-interval[duration of periodic watch progress notifications]:duration:'
  '--experimental-warning-apply-duration[warning duration for apply requests taking too long]:duration:'
  '--experimental-txn-mode-write-with-shared-buffer[enable write transaction to use shared buffer]'
  '--experimental-bootstrap-defrag-threshold-megabytes[enable defrag during bootstrap when free space exceeds threshold]:megabytes:'
  '--force-new-cluster[force to create a new one-member cluster]'
  '--unsafe-no-fsync[disables fsync, unsafe, will cause data loss]'
  '*:filename:_files'
)

_arguments -s -S $arguments
