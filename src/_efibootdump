#compdef efibootdump

local -a arguments

arguments=(
  {-g,--guid}'[{guid}\] GUID namespace the variable is in]'
  {-f,--file}'[\[ <file>\] File to read variable data from]'
  {-v,--verbose}'[be more verbose on errors]'
  '--usage[display brief usage message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
