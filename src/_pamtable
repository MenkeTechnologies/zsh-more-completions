#compdef pamtable
# Documentation: https://man.archlinux.org/search?q=pamtable
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '--tuple[Print the tuple values in mathematical tuple notation, like this: (0]'
    '--hex[Display sample values in hexadecimal instead of decimal.]'
    '--verbose'
    '*:filename:_files'
)
_arguments -s -S $arguments
