#compdef comedi_calibrate
# Documentation: https://man.archlinux.org/search?q=comedi_calibrate
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {--verbose,-v}'[enable verbose output]'
  {--quiet,-q}'[suppress output]'
  {--help,-h}'[show help message]'
  {--file,-f}'[/dev/comediN\]]'
  {--save-file,-S}'[specify calibration save file]'
  '--driver-name[driver name]'
  '--device-name[--\[no-\]reset]'
  '*:filename:_files'
)

_arguments -s -S $arguments
