#compdef monodocs2slashdoc
# Documentation: https://man.archlinux.org/search?q=monodocs2slashdoc
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-o,--out}'=-[the XML FILE to generate]:file:_files'
  '(- * :)'{-h,--help}'[Show this message and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
