#compdef mate-cpufreq-selector
# Documentation: https://man.archlinux.org/search?q=mate-cpufreq-selector
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  {-c,--cpu}'[CPU Number]'
  {-g,--governor}'[governor]'
  {-f,--frequency}'[frequency in KHz]'
  '*:filename:_files'
)

_arguments -s -S $arguments
