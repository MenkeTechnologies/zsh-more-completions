#compdef pango-list
# Documentation: https://man.archlinux.org/search?q=pango-list
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  '--verbose[print verbose information]'
  '--metrics[print font metrics]'
  '--variations[print font variations]'
  '*:filename:_files'
)

_arguments -s -S $arguments
