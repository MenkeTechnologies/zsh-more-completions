#compdef gawk

# Zsh completion for GNU awk (gawk)
# https://www.gnu.org/software/gawk/

_arguments -s -S \
  '*'{-f,--file=}'[read program from file]:program file:_files' \
  {-F,--field-separator=}'[set field separator]:separator:' \
  '*'{-v,--assign=}'[assign variable before execution]:assignment (var=val):' \
  {-b,--characters-as-bytes}'[treat all input data as single-byte characters]' \
  {-c,--traditional}'[run in compatibility mode]' \
  '(- *)'{-C,--copyright}'[print short copyright information and exit]' \
  {-d,--dump-variables}'=-[dump global variables to file]::file:_files' \
  {-D,--debug}'=-[enable debugging]::file:_files' \
  '*'{-e,--source=}'[use program-text as AWK source]:program-text:' \
  {-E,--exec=}'[like -f but last option processed]:file:_files' \
  {-g,--gen-pot}'[scan awk program and generate a .pot file on stdout]' \
  '(- *)'{-h,--help}'[display help information and exit]' \
  '*'{-i,--include=}'[include source library]:file:_files' \
  {-I,--trace}'[print internal byte code names as they are executed]' \
  {-k,--csv}'[process comma-separated values input]' \
  '*'{-l,--load=}'[load dynamic extension]:extension:' \
  {-L,--lint}'=-[warn about dubious constructs]::level:(fatal invalid no-ext)' \
  {-M,--bignum}'[use arbitrary precision arithmetic]' \
  {-N,--use-lc-numeric}'[force use of the locale decimal point character]' \
  {-n,--non-decimal-data}'[recognize octal and hex values in input data]' \
  {-o,--pretty-print}'=-[output pretty-printed source to file]::file:_files' \
  {-O,--optimize}'[enable program optimization]' \
  {-p,--profile}'=-[output profiling data to file]::file:_files' \
  {-P,--posix}'[operate in strict POSIX mode]' \
  {-r,--re-interval}'[enable interval expressions in regex]' \
  {-s,--no-optimize}'[disable program optimization]' \
  {-S,--sandbox}'[disable output redirections, system(), and extensions]' \
  {-t,--lint-old}'[warn about non-portable constructs]' \
  '(- *)'{-V,--version}'[print version information and exit]' \
  '1: :_guard "^-*" "program text"' \
  '*:input file:_files'
