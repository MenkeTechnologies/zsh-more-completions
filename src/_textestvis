#compdef textestvis
# Documentation: https://man.archlinux.org/search?q=textestvis
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-c[clears cache.]'
  '-s[enables shell escape.]'
  '-d[sets density in ppi (default 72).]'
  '-e[sets latex engine (default xelatex).]'
  '--help[prints a help message.]'
  '--version[prints version information.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
