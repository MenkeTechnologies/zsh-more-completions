#compdef sleep

# Zsh completion for sleep (suspend execution for an interval)
# Supports both BSD (macOS/FreeBSD) and GNU coreutils versions

local curcontext="$curcontext" ret=1

if [[ "$OSTYPE" == linux* ]]; then
  # GNU coreutils sleep
  _arguments -s -S \
    '(- *)--help[display help and exit]' \
    '(- *)--version[output version information and exit]' \
    '*:duration (NUMBER[smhd])' && ret=0
else
  # BSD sleep (macOS/FreeBSD) - supports number with unit suffix
  _arguments -s -S \
    '*:duration (number[smhd], e.g. 5s 2m 1h 0.5d)' && ret=0
fi

return ret
