#compdef protoc-gen-go

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--go_out=[output directory for Go files]:directory:_directories' \
  '--go_opt=[Go code generation options]:option:(paths=source_relative paths=import module=)' \
  '--go-grpc_out=[output directory for gRPC Go files]:directory:_directories' \
  '--go-grpc_opt=[gRPC Go options]:option:(paths=source_relative paths=import require_unimplemented_servers=true require_unimplemented_servers=false)' && ret=0

return ret
