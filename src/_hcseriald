#compdef hcseriald
# Documentation: https://man.archlinux.org/search?q=hcseriald
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-f[tty device name, ex. /dev/cuau1]'
  '-n[set Netgraph node name to node_name]'
  '-s[set tty speed, ex. 115200]'
  '-d[run in foreground]'
  '-h[display this message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
