#compdef cspctl
# Documentation: https://man.archlinux.org/search?q=cspctl
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[this help]'
  '-c[select card number, default = 0]'
  '-f[select CSP function #, defaults to 1]'
  '-d[optional codec description string]'
  '*:filename:_files'
)

_arguments -s -S $arguments
