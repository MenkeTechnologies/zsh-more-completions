local -a arguments

arguments=(
  {-v,--verbose}'[be more verbose when running program]'
  {-V,--version}'[print program version and exit]'
  {-d,--datadir}'[directory to store generated files.]'
  {-s,--suffix}'[suffix to be added in certificate subject line]'
