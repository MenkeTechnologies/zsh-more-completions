#compdef antidote

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'bundle:download a plugin and print its source line'
  'init:initialize the shell for static loading'
  'install:clone missing plugins without loading them'
  'list:list cloned plugins'
  'load:load plugins from a file'
  'path:print the path of a cloned plugin'
  'purge:remove a plugin'
  'update:update cloned plugins'
  'home:print the antidote home directory'
  'help:show help'
  'version:show version'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'antidote command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (bundle)
        _arguments '1:plugin (user/repo)' && ret=0
        ;;
      (load)
        _arguments '1:bundle file:_files' && ret=0
        ;;
      (purge)
        _arguments '1:plugin name' && ret=0
        ;;
      (path)
        _arguments '1:plugin name' && ret=0
        ;;
      (update)
        _arguments '--self[update antidote itself]' \
          '*:plugin name' && ret=0
        ;;
    esac
    ;;
esac

return ret
