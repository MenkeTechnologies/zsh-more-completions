#compdef pdf90

local -a arguments

arguments=(
  '--help[(or -h, or -u)]'
  '--configpath[output the configpath variable and exit immediately; no]'
  {--version,-V}'[)]'
  '--quiet[(or -q)]'
  '--batch[run pdfjam sequentially on each input file in turn, and]'
  '--outfile[(or -o PATH)]'
  '--suffix[specifies a suffix for output file names, to be used when]'
  '--outfile[either (a) a directory, or]'
  '--suffix[output filename suffix]'
  '--checkfiles[check if input files exist]'
  '--no-checkfiles[if the Unix file utility is available, with options]'
  {-L,-b}'[the output of file -Lb FILE1 should be]'
  '--preamble[append the supplied STRING to the preamble of the LaTeX]'
  '--preamble[extra LaTeX preamble code]:preamble'
  '--keepinfo[preserve PDF metadata]'
  '--no-keepinfo[preserve (or not) Title, Author, Subject and Keywords]'
  '--pdftitle[set PDF title metadata]'
  '--pdfauthor[set PDF author metadata]'
  '--pdfsubject[set PDF subject metadata]'
  '--pdfkeywords[provide text for the Title, Author, Subject and Keywords]'
  '--landscape[landscape orientation]'
  '--no-landscape[specify landscape page orientation (or not) in the]'
  '--twoside[two-sided printing layout]'
  '--no-twoside[specify (or not) the twoside document class option.]'
  '--paper[(or simply --PAPERSPEC)]'
  '--papersize[{WIDTH,HEIGHT}]'
  '--papersize[{10in,18cm}]'
  '--pagecolor[specify a background colour for the output pages. The]'
  '--pagecolor[50,200,150]'
  '--tidy[remove temporary files after run]'
  '--no-tidy[specify whether the temporary directory created by]'
  '--vanilla[suppress the reading of any site-wide or user-specific]'
  '--KEY[specify options to \includepdfmerge, in the LaTeX]'
  '--nup[1 (for 2-up side-by-side imposition)]'
  '--scale[.7 (to scale all input pages to 70% size)]'
  '--offset[1cm 0.5cm]'
  '--frame[(to put a frame round each input page)]'
  '--trim[1cm 2cm 1cm 2cm --clip true]'
  '*:filename:_files'
)

_arguments -s -S $arguments
