#compdef imlib2_load
# Documentation: https://man.archlinux.org/search?q=imlib2_load
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-e[Break on error]'
  '-f[Load with imlib_load_image_fd()]'
  '-n[reeat load N times]'
  '-p[Check that progress is called]'
  '-x[Print to stderr]'
  '*:filename:_files'
)

_arguments -s -S $arguments
