#compdef cfssl

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'bundle:create certificate bundle'
      'certinfo:output certinfo about a cert'
      'gencert:generate a new key and certificate'
      'gencrl:generate a new CRL'
      'genkey:generate a new key and CSR'
      'info:get info about a remote signer'
      'newkey:generate a new key and CSR (deprecated)'
      'ocsprefresh:refresh OCSP responses'
      'ocspsign:sign OCSP responses'
      'ocspserve:serve OCSP responses'
      'print-defaults:print default configurations'
      'revoke:revoke a certificate'
      'scan:scan a host'
      'selfsign:generate a new self-signed key and certificate'
      'serve:start the API server'
      'sign:sign a certificate'
      'version:print version'
    )
    _describe -t commands 'cfssl command' commands && ret=0
    ;;
  args)
    case $words[1] in
      gencert|sign|selfsign)
        _arguments -s -S \
          '-ca=[CA certificate file]:ca:_files' \
          '-ca-key=[CA key file]:key:_files' \
          '-config=[config file]:config:_files' \
          '-profile=[signing profile]:profile' \
          '-hostname=[hostname list]:hostnames' \
          '-cn=[common name]:cn' \
          '-key=[key file]:key:_files' \
          '-label=[key label]:label' \
          '-loglevel=[log level]:level:(0 1 2 3 4 5)' \
          '-db-config=[database config file]:db config:_files' \
          '-remote=[remote CFSSL server]:remote' \
          '-f=[CSR json file]:csr:_files' \
          '*:csr:_files' \
          && ret=0
        ;;
      bundle)
        _arguments -s -S \
          '-cert=[certificate file]:cert:_files' \
          '-key=[key file]:key:_files' \
          '-ca-bundle=[CA bundle file]:bundle:_files' \
          '-int-bundle=[intermediate bundle file]:bundle:_files' \
          '-f=[bundler flavor]:flavor:(ubiquitous optimal force)' \
          && ret=0
        ;;
      certinfo)
        _arguments -s -S \
          '-cert=[certificate file]:cert:_files' \
          '-domain=[domain to fetch cert from]:domain' \
          && ret=0
        ;;
      serve)
        _arguments -s -S \
          '-address=[listening address]:address' \
          '-port=[listening port]:port' \
          '-ca=[CA certificate file]:ca:_files' \
          '-ca-key=[CA key file]:key:_files' \
          '-ca-bundle=[CA bundle file]:bundle:_files' \
          '-int-bundle=[intermediate bundle file]:bundle:_files' \
          '-config=[config file]:config:_files' \
          '-db-config=[database config file]:db config:_files' \
          && ret=0
        ;;
      scan)
        _arguments -s -S \
          '-host=[host to scan]:host' \
          '-timeout=[timeout]:timeout' \
          && ret=0
        ;;
      print-defaults)
        _arguments -s -S \
          '1:type:(config csr)' \
          && ret=0
        ;;
      *)
        _arguments -s -S \
          '-loglevel=[log level]:level:(0 1 2 3 4 5)' \
          '*:file:_files' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
