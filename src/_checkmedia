#compdef checkmedia
# Documentation: https://man.archlinux.org/search?q=checkmedia
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--verbose[show some more info]'
  '--version[display version number]'
  '--help[short help text]'
  '*:filename:_files'
)

_arguments -s -S $arguments
