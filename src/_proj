#compdef proj invproj
# Documentation: https://proj.org/en/stable/apps/proj.html
# Source: OSGeo/PROJ src/apps/proj.cpp — cartographic projections of geographic data (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-b[binary I/O]' \
    '-d+[decimal places for output]:n:_default' \
    '-e+[alternative error line]:value:_default' \
    '-E[echo ASCII input to ASCII output]' \
    '-f+[output format (printf-style)]:format:_default' \
    '-i[binary input]' \
    '-I[inverse projection (xy→lonlat)]' \
    '-l-[list info]:type:(=ellps =units =meridians =datums =projections)' \
    '-m+[cartesian multiplier]:multiplier:_default' \
    '-o[binary output]' \
    '-r[reverse input order]' \
    '-s[reverse output order]' \
    '-S[compute scale factors]' \
    '-t+[column-1 marker character]:char:_default' \
    '-T+[run convergence/scale check on grid]:opts:_default' \
    '-v[monitor PROJ initialization dump]' \
    '-V[very verbose processing]' \
    '-w+[output precision (constant width)]:n:_default' \
    '-W+[output precision (seconds)]:n:_default' \
    '*:input file:_files' \
    && ret=0

return ret
