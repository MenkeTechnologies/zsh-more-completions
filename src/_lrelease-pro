#compdef lrelease-pro
# Documentation: https://man.archlinux.org/search?q=lrelease-pro
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-help[display this information and exit]'
  '-keep[keep the temporary project dump around]'
  '-silent[do not explain what is being done]'
  '-version[display the version of lrelease-pro and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
