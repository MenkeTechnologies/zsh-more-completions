#compdef erb27
# Documentation: https://man.archlinux.org/search?q=erb27
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-x[print ruby script]'
  '-n[print ruby script with line number]'
  '-v[enable verbose mode]'
  '-d[set $DEBUG to true]'
  '-r[load a library]'
  '-E[set default external/internal encodings]'
  '-U[set default encoding to UTF-8]'
  '-T[specify trim_mode (0..2, -)]'
  '-P[disable ruby code evaluation for lines beginning with %]'
  '*:filename:_files'
)

_arguments -s -S $arguments
