#compdef unbound-checkconf
# Documentation: https://man.archlinux.org/search?q=unbound-checkconf
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-o[print value of option to stdout.]'
  '-f[output full pathname with chroot applied, eg. with -o pidfile.]'
  '-h[show this usage help.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
