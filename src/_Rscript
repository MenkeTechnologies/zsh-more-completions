#compdef Rscript

local -a arguments

arguments=(
  '--default-packages[specify default packages to load]:packages: '
  '--help[print usage and exit]'
  '--version[print version and exit]'
  '--verbose[print information on progress]'
  '--save[do save workspace at the end of the session]'
  '--no-environ[dont read the site and user environment files]'
  '--no-site-file[dont read the site-wide Rprofile]'
  '--no-init-file[dont read the user R profile]'
  '--restore[do restore previously saved objects at startup]'
  '--vanilla[combine --no-save, --no-restore, --no-site-file, --no-init-file, --no-environ]'
  '*:filename:_files'
)

_arguments -s -S $arguments
