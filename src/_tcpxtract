#compdef tcpxtract

local -a arguments

arguments=(
  {-f,--file}'[specify an input capture file instead of a device]:file:_files'
  {-d,--device}'[specify an input device (i.e. eth0)]:device:'
  {-c,--config}'[use FILE as the config file]:file:_files'
  {-o,--output}'[dump files to DIRECTORY instead of current directory]:directory:_directories'
  {-v,--version}'[display the version number of this program]'
  {-h,--help}'[display this lovely screen]'
  '*:filename:_files'
)

_arguments -s -S $arguments
