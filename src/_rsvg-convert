#compdef rsvg-convert

local -a arguments

arguments=(
  {-d,--dpi-x}'[pixels per inch (defaults to 90dpi)]:dpi: '
  {-p,--dpi-y}'[pixels per inch (defaults to 90dpi)]:dpi: '
  {-x,--x-zoom}'[x zoom factor (defaults to 1.0)]:factor: '
  {-y,--y-zoom}'[y zoom factor (defaults to 1.0)]:factor: '
  {-z,--zoom}'[zoom factor (defaults to 1.0)]:factor: '
  {-w,--width}'[width (defaults to the SVG width)]:width: '
  {-h,--height}'[height (defaults to the SVG height)]:height: '
  {-f,--format}'[save format (defaults to png)]:format:(png pdf ps eps svg xml recording)'
  {-o,--output}'[output filename (defaults to stdout)]:file:_files'
  {-i,--export-id}'[SVG id of object to export]:id: '
  {-a,--keep-aspect-ratio}'[whether to preserve the aspect ratio]'
  {-b,--background-color}'[set the background color (defaults to None)]:color: '
  {-u,--unlimited}'[allow huge SVG files]'
  '--keep-image-data[keep image data]'
  '--no-keep-image-data[dont keep image data]'
  {-v,--version}'[show version information]'
  '*:filename:_files'
)

_arguments -s -S $arguments
