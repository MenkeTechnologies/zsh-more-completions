#compdef rofi

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-v,--version}'[display version]' \
  '-show[show a specific mode]:mode:(run drun window windowcd ssh combi keys filebrowser)' \
  '-modi[enabled modes]:modes' \
  '-dmenu[run rofi in dmenu mode]' \
  '-width[set width]:width' \
  '-lines[number of lines]:lines' \
  '-columns[number of columns]:columns' \
  '-font[set font]:font' \
  '-theme[set theme]:theme:_files -g "*.rasi"' \
  '-terminal[set terminal emulator]:terminal:_command_names -e' \
  '-ssh-command[set ssh command]:command' \
  '-run-command[set run command]:command' \
  '-run-list-command[set command to generate run list]:command' \
  '-run-shell-command[set shell command for run mode]:command' \
  '-matching[set matching algorithm]:algorithm:(normal regex glob fuzzy)' \
  '-tokenize[tokenize input]' \
  '-case-sensitive[enable case-sensitive matching]' \
  '-filter[set pre-filter]:filter string' \
  '-no-lazy-grab[disable lazy grab]' \
  '-no-custom[disable custom entries]' \
  '-no-plugins[disable plugins]' \
  '-plugin-path[set plugin directory]:directory:_directories' \
  '-p[set prompt]:prompt' \
  '-mesg[set message]:message' \
  '-markup-rows[allow pango markup in rows]' \
  '-auto-select[auto-select single entry]' \
  '-selected-row[set initially selected row]:row number' \
  '-monitor[set monitor to display on]:monitor' \
  '-location[set window location]:location:(0 1 2 3 4 5 6 7 8)' \
  '-fixed-num-lines[keep a fixed number of lines visible]' \
  '-sidebar-mode[enable sidebar mode]' \
  '-hover-select[select entry under mouse]' \
  '-eh[set row height]:row height' \
  '-padding[set padding]:padding' \
  '-fullscreen[enable fullscreen mode]' \
  '-dpi[set DPI]:dpi' \
  '-threads[set number of threads]:threads' \
  '-scroll-method[set scroll method]:method:(0 1)' \
  '-no-show-match[do not highlight matching text]' \
  '-config[specify config file]:config file:_files' \
  '-dump-config[dump current config]' \
  '-dump-theme[dump current theme]' \
  '-dump-xresources[dump xresources theme]' \
  '-show-icons[show application icons]' \
  '-icon-theme[set icon theme]:theme' \
  '-drun-display-format[set display format for drun]:format' \
  '-disable-history[disable history]' \
  '-sort[enable sorting]' \
  '-sorting-method[set sorting method]:method:(normal fzf)' \
  '-cycle[enable cycling through results]' \
  '-cache-dir[set cache directory]:directory:_directories' \
  '-pid[specify pidfile path]:pidfile:_files' \
  '-replace[replace running instance]' \
  '-input[read from file instead of stdin]:file:_files' \
  '-markup[enable pango markup]' \
  '-normal-window[open as normal window]' \
  && ret=0

return ret
