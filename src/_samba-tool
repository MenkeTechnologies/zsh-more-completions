#compdef samba-tool
# Documentation: https://man.archlinux.org/search?q=samba-tool
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-V,--version}'[display version number]'
  '*:filename:_files'
)

_arguments -s -S $arguments
