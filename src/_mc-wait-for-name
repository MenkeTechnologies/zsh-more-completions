#compdef mc-wait-for-name
# Documentation: https://man.archlinux.org/search?q=mc-wait-for-name
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  '--activate[activate NAME before waiting for the other name]'
  '*:filename:_files'
)

_arguments -s -S $arguments
