#compdef automake

# Zsh completion for GNU Automake
# Based on automake 1.18

local -a warning_categories
warning_categories=(
  'cross:cross compilation issues'
  'gnu:GNU coding standards (default in gnu and gnits modes)'
  'obsolete:obsolete features or constructions (default)'
  'override:user redefinitions of Automake rules or variables'
  'portability:portability issues (default in gnu and gnits modes)'
  'portability-recursive:nested Make variables (default with -Wportability)'
  'extra-portability:extra portability issues related to obscure tools'
  'syntax:dubious syntactic constructs (default)'
  'unsupported:unsupported or incomplete features (default)'
  'all:turn on all the warnings'
  'none:turn off all the warnings'
  'error:treat all enabled warnings as errors'
)

_arguments -s -S \
  '(- *)--help[print this help, then exit]' \
  '(- *)--version[print version number, then exit]' \
  {-v,--verbose}'[verbosely list files processed]' \
  '--no-force[only update Makefile.in'\''s that are out of date]' \
  {-W,--warnings=}'[report the warnings falling in CATEGORY]:warning category:_values -s , "warning category" $warning_categories' \
  {-i,--ignore-deps}'[disable dependency tracking code]' \
  '--include-deps[enable dependency tracking code]' \
  '(--gnits --gnu)--foreign[set strictness to foreign]' \
  '(--foreign --gnu)--gnits[set strictness to gnits]' \
  '(--foreign --gnits)--gnu[set strictness to gnu]' \
  {-a,--add-missing}'[add missing standard files to package]' \
  '--libdir=[set directory storing library files]:directory:_files -/' \
  '(- *)--print-libdir[print directory storing library files]' \
  {-c,--copy}'[with -a, copy missing files (default is symlink)]' \
  {-f,--force-missing}'[force update of standard files]' \
  '*:Makefile:_files -g "Makefile*"'
