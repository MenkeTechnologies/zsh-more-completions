#compdef df

# Zsh completion for df - display free disk space
# Supports both GNU/Linux and BSD/macOS variants

local -a arguments

if _pick_variant gnu='Free Software' unix --version 2>/dev/null; then
  # GNU coreutils df
  arguments=(
    '(- *)--help[display help and exit]'
    '(- *)--version[output version information and exit]'
    {-a,--all}'[include pseudo, duplicate, inaccessible file systems]'
    {-B,--block-size=}'[scale sizes by SIZE before printing]:size (e.g. 1K, 1M, 1G)'
    '(-B --block-size -g -h -H --si -k -m -P)'{-h,--human-readable}'[print sizes in powers of 1024 (e.g. 1023M)]'
    '(-B --block-size -g -h -H --si -k -m -P)'{-H,--si}'[print sizes in powers of 1000 (e.g. 1.1G)]'
    {-i,--inodes}'[list inode information instead of block usage]'
    '(-B --block-size -g -h -H --si -m -P)-k[like --block-size=1K]'
    {-l,--local}'[limit listing to local file systems]'
    '--no-sync[do not invoke sync before getting usage info (default)]'
    '--output=-[use the output format defined by FIELD_LIST]:field list:(source fstype itotal iused iavail ipcent size used avail pcent file target)'
    {-P,--portability}'[use the POSIX output format]'
    '--sync[invoke sync before getting usage info]'
    '--total[elide all entries insignificant to available space and produce a grand total]'
    {-t,--type=}'[limit listing to file systems of type TYPE]:filesystem type:_file_systems'
    {-T,--print-type}'[print file system type]'
    {-x,--exclude-type=}'[limit listing to file systems not of type TYPE]:filesystem type:_file_systems'
    '-v[(ignored)]'
    '*:file or filesystem:_files'
  )
else
  # BSD/macOS df
  arguments=(
    '-a[show all mount points, including those with MNT_IGNORE flag]'
    '(-g -h -H -k -m -P)-b[use 512 byte blocks (same as -P)]'
    '-c[display a grand total]'
    '(-b -h -H -k -m -P)-g[use 1 Gibibyte blocks]'
    '(-b -g -H -k -m -P)-h[human-readable output using powers of 1024]'
    '(-b -g -h -k -m -P)-H[human-readable output using powers of 1000 (SI)]'
    '-I[suppress inode counts]'
    '-i[include inode statistics]'
    '(-b -g -h -H -m -P)-k[use 1 Kibibyte blocks]'
    '-l[select only locally-mounted file systems]'
    '(-b -g -h -H -k -P)-m[use 1 Mebibyte blocks]'
    '-n[print previously obtained statistics (no new sync)]'
    '(-b -g -h -H -k -m)-P[use 512 byte blocks and POSIX output format]'
    '-T[select file systems by type]:filesystem type:_file_systems'
    '-t[no-op on macOS; deprecated alias for -T with argument]'
    '-Y[include file system type]'
    '-,[print sizes grouped and separated by thousands]'
    '--libxo[generate output via libxo in various formats]'
    '*:file or filesystem:_files'
  )
fi

_arguments -s -S $arguments
