#compdef fakeCMY
# Documentation: https://man.archlinux.org/search?q=fakeCMY
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-v[verbose]'
  '-r[set surface point resolution (default 3)]'
  '-l[set total ink limit, 0 - 400% (estimate by default)]'
  '-L[set black ink limit, 0 - 100% (estimate by default)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
