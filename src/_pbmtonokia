#compdef pbmtonokia
# Documentation: https://man.archlinux.org/search?q=pbmtonokia
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-fmt[output format (default=HEX_NOL)]'
  '-net[code> Network code for NOL operator logos]'
  '-txt[message> Text for NMP picture messages]'
  '*:filename:_files'
)

_arguments -s -S $arguments
