#compdef cypress

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'open:open Cypress interactive test runner'
  'run:run Cypress tests from the CLI'
  'install:install Cypress binary'
  'verify:verify that Cypress is installed correctly'
  'cache:manage the Cypress binary cache'
  'info:print Cypress and system information'
  'version:print Cypress version'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'cypress command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (run)
        _arguments -s -S \
          '--browser=[browser to run tests in]:browser:(chrome chromium edge electron firefox)' \
          '--ci-build-id=[unique identifier for a run]:build id' \
          '--component[run component tests]' \
          '--config=[set configuration values]:config' \
          '--config-file=[path to config file]:config file:_files' \
          '--e2e[run end-to-end tests]' \
          '--env=[set environment variables]:env vars' \
          '--group=[group recorded tests under a name]:group name' \
          '--headed[run in headed browser]' \
          '--headless[run in headless mode]' \
          '--key=[set record key]:record key' \
          '--no-exit[keep Cypress open after tests finish]' \
          '--parallel[run recorded specs in parallel]' \
          '--port=[override default port]:port' \
          '--project=[path to project]:project path:_directories' \
          '--quiet[suppress output to stdout]' \
          '--record[record the test run]' \
          '--reporter=[specify mocha reporter]:reporter' \
          '--reporter-options=[reporter options]:options' \
          '--spec=[specify tests to run]:spec files:_files' \
          '--tag=[add tags to the run]:tags' \
          '*:spec files:_files' && ret=0
        ;;
      (open)
        _arguments -s -S \
          '--browser=[browser to use]:browser:(chrome chromium edge electron firefox)' \
          '--component[open component testing]' \
          '--config=[set configuration values]:config' \
          '--config-file=[path to config file]:config file:_files' \
          '--detached[open Cypress in detached mode]' \
          '--e2e[open end-to-end testing]' \
          '--env=[set environment variables]:env vars' \
          '--global[run in global mode]' \
          '--port=[override default port]:port' \
          '--project=[path to project]:project path:_directories' && ret=0
        ;;
      (cache)
        local -a cache_cmds=(
          'path:print the path to the cache'
          'list:list installed Cypress versions'
          'clear:clear the cache'
          'prune:remove old cached versions'
        )
        _arguments '1:cache command:_describe -t cache-commands "cache command" cache_cmds' && ret=0
        ;;
      (install)
        _arguments '--force[install even if already installed]' && ret=0
        ;;
    esac
    ;;
esac

return ret
