#compdef xvidtune
# Documentation: https://man.archlinux.org/search?q=xvidtune
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-show[print current modeline to stdout]'
  '-next[switch to next video mode]'
  '-prev[switch to previous video mode]'
  '-unlock[enable mode switch hot-keys]'
  '-timeout[set testmode timeout in seconds]'
  '*:filename:_files'
)

_arguments -s -S $arguments
