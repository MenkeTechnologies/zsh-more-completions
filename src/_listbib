#compdef listbib

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[shows help]'
  {-o,--output}'[generates FILE.dvi / FILE.ps (default listedbibs)]:file:'
  {-O,--same}'[as -o, but generate FILE.dvi and BIBFILE_N.ps]'
  {-p,--ps,--postscript}'[generate PostScript as well as dvi]'
  {-d,--deltemp}'[delete all generated files but .dvi]'
  {-P,--psonly}'[generate only PostScript]'
  '*:filename:_files'
)

_arguments -s -S $arguments
