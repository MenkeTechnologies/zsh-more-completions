#compdef wget

# Zsh completion for GNU Wget 1.25+

local -a arguments

arguments=(
  # Startup
  {-V,--version}'[display version and exit]'
  {-h,--help}'[print help]'
  {-b,--background}'[go to background after startup]'
  {-e,--execute}'[execute .wgetrc-style command]:command:'
  '--config=[specify config file to use]:file:_files'
  '--no-config[do not read any config file]'

  # Logging and input
  {-o,--output-file}'=[log messages to file]:log file:_files'
  {-a,--append-output}'=[append messages to file]:log file:_files'
  {-d,--debug}'[print lots of debugging information]'
  {-q,--quiet}'[quiet mode (no output)]'
  {-v,--verbose}'[verbose mode (default)]'
  {-nv,--no-verbose}'[turn off verboseness without being fully quiet]'
  '--report-speed=[output bandwidth in specified type]:type:(bits)'
  {-i,--input-file}'=[download URLs found in local or external file]:file:_files'
  {-F,--force-html}'[treat input file as HTML]'
  {-B,--base}'=[resolve relative URLs using URL as base]:URL:_urls'
  '--rejected-log=[log reasons for URL rejection to file]:file:_files'

  # Download
  {-t,--tries}'=[set number of retries (0 for unlimited)]:number:'
  '--retry-connrefused[retry even if connection is refused]'
  '--retry-on-host-error[consider host errors as non-fatal transient errors]'
  '--retry-on-http-error=[comma-separated list of HTTP errors to retry]:errors:'
  {-O,--output-document}'=[write documents to file]:file:_files'
  {-nc,--no-clobber}'[skip downloads that would overwrite existing files]'
  '--no-netrc[do not try to obtain credentials from .netrc]'
  {-c,--continue}'[resume getting a partially-downloaded file]'
  '--start-pos=[start downloading from zero-based position]:offset:'
  '--progress=[select progress gauge type]:type:(bar dot bar\:force bar\:noscroll bar\:force\:noscroll)'
  '--show-progress[display the progress bar in any verbosity mode]'
  {-N,--timestamping}'[only retrieve files newer than local]'
  '--no-if-modified-since[do not use If-Modified-Since for timestamping]'
  '--no-use-server-timestamps[do not set local file timestamp from server]'
  {-S,--server-response}'[print server response]'
  '--spider[do not download anything]'
  {-T,--timeout}'=[set all timeout values]:seconds:'
  '--dns-timeout=[set DNS lookup timeout]:seconds:'
  '--connect-timeout=[set connect timeout]:seconds:'
  '--read-timeout=[set read timeout]:seconds:'
  {-w,--wait}'=[wait between retrievals]:seconds:'
  '--waitretry=[wait between retries of a retrieval]:seconds:'
  '--random-wait[random wait between retrievals 0.5x-1.5x of --wait]'
  '--no-proxy[explicitly turn off proxy]'
  {-Q,--quota}'=[set retrieval quota]:quota:'
  '--bind-address=[bind to address on local machine]:address:'
  '--limit-rate=[limit download rate]:rate:'
  '--no-dns-cache[disable caching of DNS lookups]'
  '--restrict-file-names=[restrict chars in file names to ones OS allows]:mode:(unix windows nocontrol ascii lowercase uppercase)'
  '--ignore-case[ignore case when matching files/directories]'
  {-4,--inet4-only}'[connect only to IPv4 addresses]'
  {-6,--inet6-only}'[connect only to IPv6 addresses]'
  '--prefer-family=[connect first to addresses of specified family]:family:(IPv4 IPv6 none)'
  '--user=[set both ftp and http user]:user:'
  '--password=[set both ftp and http password]:password:'
  '--ask-password[prompt for passwords]'
  '--use-askpass=[specify credential handler for requesting username and password]:command:_command_names'
  '--no-iri[turn off IRI support]'
  '--local-encoding=[use specified encoding as the default for local IRI]:encoding:'
  '--remote-encoding=[use specified encoding as the default for remote IRI]:encoding:'
  '--unlink[force removal of file before clobber]'
  '--xattr[turn on storage of metadata in extended file attributes]'

  # Directories
  {-nd,--no-directories}'[do not create directories]'
  {-x,--force-directories}'[force creation of directories]'
  {-nH,--no-host-directories}'[do not create host directories]'
  '--protocol-directories[use protocol name as a directory component]'
  '--cut-dirs=[ignore specified number of remote directory components]:number:'
  {-P,--directory-prefix}'=[save files to specified directory]:prefix:_directories'

  # HTTP
  '--default-page=[change the default page name]:name:'
  {-E,--adjust-extension}'[save HTML/CSS documents with proper extensions]'
  '--http-user=[set http user]:user:'
  '--http-password=[set http password]:password:'
  '--no-http-keep-alive[disable HTTP keep-alive (persistent connections)]'
  '--no-cache[do not allow server-cached data]'
  '--no-cookies[do not use cookies]'
  '--load-cookies=[load cookies from file before session]:file:_files'
  '--save-cookies=[save cookies to file after session]:file:_files'
  '--keep-session-cookies[load and save session (non-permanent) cookies]'
  '--ignore-length[ignore Content-Length header field]'
  '*--header=[send specified string as header]:header:'
  '--compression=[choose compression type]:type:(auto gzip none)'
  '--max-redirect=[maximum number of redirections allowed]:number:'
  '--proxy-user=[set proxy user]:user:'
  '--proxy-password=[set proxy password]:password:'
  '--referer=[include Referer header in HTTP request]:URL:_urls'
  '--save-headers[save HTTP headers to file]'
  {-U,--user-agent}'=[identify as agent-string]:agent:'
  '--post-data=[send string in a POST request]:string:'
  '--post-file=[send contents of file in a POST request]:file:_files'
  '--method=[use specified HTTP method]:method:(GET POST HEAD PUT DELETE PATCH OPTIONS)'
  '--body-data=[send string as data in the request body]:data:'
  '--body-file=[send contents of file in the request body]:file:_files'
  '--content-disposition[honor the Content-Disposition header when choosing local file names]'
  '--content-on-error[output the received content on server errors]'
  '--trust-server-names[use the name specified by redirection URL]'
  '--auth-no-challenge[send Basic HTTP authentication without challenge]'

  # HTTPS (SSL/TLS)
  '--secure-protocol=[choose secure protocol]:protocol:(auto SSLv2 SSLv3 TLSv1 TLSv1_1 TLSv1_2 TLSv1_3 PFS)'
  '--https-only[only follow secure HTTPS links]'
  '--no-check-certificate[do not validate the server certificate]'
  '--certificate=[client certificate file]:file:_files'
  '--certificate-type=[client certificate type]:type:(PEM DER)'
  '--private-key=[private key file]:file:_files'
  '--private-key-type=[private key type]:type:(PEM DER)'
  '--ca-certificate=[file with bundle of CAs]:file:_files'
  '--ca-directory=[directory where hash list of CAs is stored]:directory:_directories'
  '--crl-file=[file with bundle of CRLs]:file:_files'
  '--pinnedpubkey=[public key (PEM/DER) file or SHA256 hash for peer verification]:pinned key:_files'
  '--random-file=[file with random data for seeding SSL PRNG]:file:_files'
  '--ciphers=[set the priority string for ciphers directly]:ciphers:'

  # HSTS
  '--no-hsts[disable HSTS]'
  '--hsts-file=[path of HSTS database]:file:_files'

  # FTP/FTPS
  '--ftp-user=[set ftp user]:user:'
  '--ftp-password=[set ftp password]:password:'
  '--no-remove-listing[do not remove .listing files]'
  '--no-glob[turn off FTP file name globbing]'
  '--no-passive-ftp[disable passive transfer mode]'
  '--preserve-permissions[preserve remote file permissions]'
  '--retr-symlinks[retrieve FTP symbolic links]'

  # FTPS
  '--ftps-implicit[use implicit FTPS (default port is 990)]'
  '--ftps-resume-ssl[resume the SSL/TLS session started in the control connection]'
  '--ftps-clear-data-connection[cipher the control channel only, data in plaintext]'
  '--ftps-fallback-to-ftp[fall back to FTP if FTPS is not supported]'

  # WARC
  '--warc-file=[save request/response data to a WARC file]:file:_files'
  '--warc-header=[insert specified string into the WARC header]:string:'
  '--warc-max-size=[set maximum size of WARC files]:size:'
  '--warc-cdx[write CDX index files]'
  '--warc-dedup=[do not store records listed in this CDX file]:file:_files'
  '--no-warc-compression[do not compress WARC files with GZIP]'
  '--no-warc-digests[do not calculate SHA1 digests]'
  '--no-warc-keep-log[do not store the log file in a WARC record]'
  '--warc-tempdir=[location for temporary files created by WARC writer]:directory:_directories'

  # Recursive download
  {-r,--recursive}'[specify recursive download]'
  {-l,--level}'=[maximum recursion depth (inf or 0 for infinite)]:depth:'
  '--delete-after[delete files locally after downloading]'
  {-k,--convert-links}'[make links in downloaded HTML/CSS point to local files]'
  '--convert-file-only[convert the file part of the URLs only (basename)]'
  '--backups=[before writing file X, rotate up to N backup files]:number:'
  {-K,--backup-converted}'[before converting file X, back up as X.orig]'
  {-m,--mirror}'[shortcut for -N -r -l inf --no-remove-listing]'
  {-p,--page-requisites}'[get all images etc. needed to display HTML page]'
  '--strict-comments[turn on strict (SGML) handling of HTML comments]'

  # Recursive accept/reject
  {-A,--accept}'=[comma-separated list of accepted extensions]:extensions:'
  {-R,--reject}'=[comma-separated list of rejected extensions]:extensions:'
  '--accept-regex=[regex matching accepted URLs]:regex:'
  '--reject-regex=[regex matching rejected URLs]:regex:'
  '--regex-type=[regex type]:type:(posix pcre)'
  {-D,--domains}'=[comma-separated list of accepted domains]:domains:'
  '--exclude-domains=[comma-separated list of rejected domains]:domains:'
  '--follow-ftp[follow FTP links from HTML documents]'
  '--follow-tags=[comma-separated list of followed HTML tags]:tags:'
  '--ignore-tags=[comma-separated list of ignored HTML tags]:tags:'
  {-H,--span-hosts}'[go to foreign hosts when recursive]'
  {-L,--relative}'[follow relative links only]'
  {-I,--include-directories}'=[list of allowed directories]:list:'
  {-X,--exclude-directories}'=[list of excluded directories]:list:'
  {-np,--no-parent}'[do not ascend to the parent directory]'

  # Positional URL
  '*:URL:_urls'
)

_arguments -s -S $arguments
