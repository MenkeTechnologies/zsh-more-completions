#compdef fabric

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-p --pattern)'{-p,--pattern}'=[use a pattern]:pattern' \
  '(-C --context)'{-C,--context}'=[use a context]:context' \
  '(-S --session)'{-S,--session}'=[use a session]:session' \
  '--setup[set up fabric]' \
  '--changeDefaultModel[change default model]' \
  '--model=[use a specific model]:model' \
  '--listPatterns[list available patterns]' \
  '--listModels[list available models]' \
  '--listContexts[list available contexts]' \
  '--listSessions[list available sessions]' \
  '--updatePatterns[update patterns]' \
  '--copy[copy output to clipboard]' \
  '--output=[output to file]:file:_files' \
  '-o+[output to file]:file:_files' \
  '--stream[stream output]' \
  '-s[stream output]' \
  '--text=[input text]:text' \
  '-t+[input text]:text' \
  '--url=[process content from URL]:url' \
  '-u+[process content from URL]:url' \
  '--youtube=[process YouTube video]:url' \
  '-y+[process YouTube video]:url' \
  '--transcript[get YouTube transcript]' \
  '--dry-run[show what would be sent]' \
  '--temperature=[set temperature]:temperature' \
  '--top_p=[set top_p]:top_p' \
  '--frequency_penalty=[set frequency penalty]:penalty' \
  '--presence_penalty=[set presence penalty]:penalty' && ret=0

return ret
