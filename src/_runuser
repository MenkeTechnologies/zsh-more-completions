#compdef runuser

local -a arguments

arguments=(
  {-u,--user}'[username]:user:_users'
  {-m,-p,--preserve-environment}'[do not reset environment variables]'
  {-g,--group}'[specify the primary group]:group:_groups'
  {-G,--supp-group}'[specify a supplemental group]:group:_groups'
  {-c,--command}'[pass a single command to the shell with -c]:command: '
  '--session-command[pass a single command to the shell with -c]:command: '
  {-f,--fast}'[pass -f to the shell (for csh or tcsh)]'
  {-s,--shell}'[run specified shell if /etc/shells allows it]:shell:_files'
  {-P,--pty}'[create a new pseudo-terminal]'
  '(- * :)'{-h,--help}'[display this help]'
  {-V,--version}'[display version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
