#compdef prettier

# Zsh completion for Prettier code formatter
# https://prettier.io/docs/en/cli.html

_prettier() {
  local -a arguments

  arguments=(
    # Output options
    {-c,--check}'[Check if files are formatted, print summary and paths to unformatted files]'
    {-l,--list-different}'[Print the names of files that are different from Prettier formatting]'
    {-w,--write}'[Edit files in-place]'

    # Format options
    '--arrow-parens=[Include parentheses around a sole arrow function parameter]:style:(always avoid)'
    '--bracket-same-line[Put > of opening tags on the last line instead of on a new line]'
    '--no-bracket-spacing[Do not print spaces between brackets]'
    '--embedded-language-formatting=[Control how Prettier formats quoted code embedded in the file]:mode:(auto off)'
    '--end-of-line=[Which end of line characters to apply]:eol:(lf crlf cr auto)'
    '--experimental-operator-position=[Where to print operators when binary expressions wrap lines]:position:(start end)'
    '--no-experimental-ternaries[Keep question marks on the same line as the consequent]'
    '--html-whitespace-sensitivity=[How to handle whitespaces in HTML]:sensitivity:(css strict ignore)'
    '--jsx-single-quote[Use single quotes in JSX]'
    '--object-wrap=[How to wrap object literals]:mode:(preserve collapse)'
    '--parser=[Which parser to use]:parser:(flow babel babel-flow babel-ts typescript acorn espree meriyah css less scss json json5 jsonc json-stringify graphql markdown mdx vue yaml glimmer html angular lwc mjml)'
    '--print-width=[The line length where Prettier will try wrap]:width:'
    '--prose-wrap=[How to wrap prose (markdown)]:mode:(always never preserve)'
    '--quote-props=[When to quote properties in objects]:mode:(as-needed consistent preserve)'
    '--no-semi[Do not print semicolons, except at the beginning of lines which may need them]'
    '--single-attribute-per-line[Enforce single attribute per line in HTML, Vue and JSX]'
    '--single-quote[Use single quotes instead of double quotes]'
    '--tab-width=[Number of spaces per indentation level]:width:'
    '--trailing-comma=[Print trailing commas wherever possible when multi-line]:mode:(all es5 none)'
    '--use-tabs[Indent with tabs instead of spaces]'
    '--vue-indent-script-and-style[Indent script and style tags in Vue files]'

    # Config options
    '--config=[Path to a Prettier configuration file]:config file:_files'
    '--no-config[Do not look for a configuration file]'
    '--config-precedence=[Define in which order config files and CLI options should be evaluated]:precedence:(cli-override file-override prefer-file)'
    '--no-editorconfig[Do not take .editorconfig into account when parsing configuration]'
    '--find-config-path=[Find and print the path to a configuration file for the given input file]:path:_files'
    '*--ignore-path=[Path to a file with patterns describing files to ignore]:path:_files'
    '*--plugin=[Add a plugin]:plugin path:_files'
    '--with-node-modules[Process files inside node_modules directory]'

    # Editor options
    '--cursor-offset=[Print (to stderr) where a cursor at the given position would move to after formatting]:offset:'
    '--range-end=[Format code ending at a given character offset (exclusive)]:offset:'
    '--range-start=[Format code starting at a given character offset]:offset:'

    # Other options
    '--cache[Only format changed files]'
    '--cache-location=[Path to the cache file]:path:_files'
    '--cache-strategy=[Strategy for the cache to use for detecting changed files]:strategy:(metadata content)'
    '--check-ignore-pragma[Check for @noprettier or @noformat pragma to determine if file should be formatted]'
    '--no-color[Do not colorize error messages]'
    '--no-error-on-unmatched-pattern[Prevent errors when pattern is unmatched]'
    '--file-info=[Extract file info as JSON for a given file path]:path:_files'
    '(- *)'{-h,--help}'[Show CLI usage, or details about the given flag]:flag:'
    {-u,--ignore-unknown}'[Ignore unknown files]'
    '--insert-pragma[Insert @format pragma into file first docblock comment]'
    '--log-level=[What level of logs to report]:level:(silent error warn log debug)'
    '--require-pragma[Require @prettier or @format to be present in file first docblock comment]'
    '--stdin-filepath=[Path to the file to pretend that stdin comes from]:path:_files'
    '--support-info[Print support information as JSON]'
    '(- *)'{-v,--version}'[Print Prettier version]'

    '*:file or directory:_files'
  )

  _arguments -s -S $arguments
}

_prettier "$@"
