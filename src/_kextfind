#compdef kextfind

local -a arguments

arguments=(
  '-help[print help information]'
  '-case-insensitive[make query predicates case-insensitive]'
  '-relative-paths[print relative paths in output]'
  '-substring[match by substring rather than exact match]'
  '-no-paths[do not print paths in output]'
  '-bundle-id[match kexts by bundle identifier]:id:'
  '-bundle-name[match kexts by bundle name]:name:'
  '-match-property[match kexts by property name and value]:name: :value:'
  '-property[check if kext has the given property]:name: :value:'
  '-loaded[match loaded kexts]'
  '-nonloadable[match kexts that are not loadable]'
  '-invalid[match invalid kexts]'
  '-inauthentic[match inauthentic kexts]'
  '-dependencies-missing[match kexts with missing dependencies]'
  '-warnings[match kexts with warnings]'
  '-arch[match kexts containing code for specified architectures]:arch:'
  '-executable[match kexts that contain an executable]'
  '-library[match library kexts]'
  '-defines-symbol[match kexts that define a symbol]:symbol:'
  '-references-symbol[match kexts that reference a symbol]:symbol:'
  '*:filename:_files'
)

_arguments -s -S $arguments
