#compdef ccmake

local -a arguments

arguments=(
  '-C[pre-load a script to populate the cache]:script:_files'
  '-D[= Create a cmake cache entry.]:value:'
  '-U[remove matching entries from CMake cache]:pattern:'
  '-G[specify a build system generator]:generator:'
  '-T[specify toolset name if supported by generator]:toolset:'
  '-Wno-dev[suppress developer warnings.]'
  '-Wdev[enable developer warnings.]'
  '--copyright[print the CMake copyright and exit.]'
  {--help,-help,-usage,-h,-H}'[print usage information and exit]'
  '--help-full[print full help and exit.]'
  '--help-html[print full help in HTML format.]'
  '--help-man[print full help as a UNIX man page and exit.]'
  {--version,-version}'[show program name/version banner and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
