#compdef cccheck
# Documentation: https://man.archlinux.org/search?q=cccheck
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--help[show this help.]'
  '--assembly[assembly to check]:assembly:_files'
  '--method[method name (if you want to check only it)]:method:'
  '--debug[show debug information]'
  '*:filename:_files'
)

_arguments -s -S $arguments
