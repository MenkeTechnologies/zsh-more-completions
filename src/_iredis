#compdef iredis

# Zsh completion for iredis - interactive Redis client

_arguments \
  '(- *)--help[show help]' \
  '(- *)--iredis-version[show version]' \
  '-h[server hostname]:host' \
  '-p[server port]:port' \
  '-n[database number]:database' \
  '-a[password]:password' \
  '--username[username for AUTH]:username' \
  '--url[Redis URL]:url' \
  '--tls[enable TLS]' \
  '--certfile[TLS certificate file]:file:_files' \
  '--keyfile[TLS key file]:file:_files' \
  '--ca-certs[CA certificates file]:file:_files' \
  '--newbie[enable newbie mode with extra help]' \
  '--no-newbie[disable newbie mode]' \
  '--pager[pager command]:command' \
  '--no-pager[disable pager]' \
  '--decode[decode responses with encoding]:encoding' \
  '--no-decode[disable response decoding]' \
  '--raw[enable raw output]' \
  '--no-raw[disable raw output]' \
  '--shell[enable shell mode]' \
  '--no-shell[disable shell mode]' \
  '--prompt[prompt format string]:format' \
  '--greetings[show greeting message]' \
  '--no-greetings[hide greeting message]' \
  '--warnings[show warnings]' \
  '--no-warnings[hide warnings]' \
  '--pattern[key pattern for scan commands]:pattern'
