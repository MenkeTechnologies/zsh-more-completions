#compdef anaconda-navigator
# Documentation: https://man.archlinux.org/search?q=anaconda-navigator
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[show this help message and exit]'
  '--version[print version information]'
  '--reset[reset Navigator configuration]'
  '--remove-lock[remove Navigator lock]'
  '--verbose[print information statements]'
  '--debug[print debug statements]'
  '*:filename:_files'
)

_arguments -s -S $arguments
