#compdef parallel

# Zsh completion for GNU parallel and moreutils parallel

_parallel() {
  local -a arguments

  # Detect which parallel is installed
  if parallel --version 2>/dev/null | head -1 | grep -q "GNU"; then
    # GNU parallel
    arguments=(
      # Job control
      '(-j --jobs)'{-j,--jobs}'[number of jobslots on each machine (default\: one per CPU)]:number of jobs:'
      '(-k --keep-order)'{-k,--keep-order}'[keep sequence of output same as the order of input]'
      '--lb[line buffer output (mix lines from different jobs)]'
      '--line-buffer[line buffer output]'
      '--group[group output for each job (default)]'
      '(-u --ungroup)'{-u,--ungroup}'[output directly without grouping]'
      '--tag[tag lines with arguments]'
      '--tagstring[use string as tag]:tag string:'
      '--color[colorize output from each job]'
      '--color-failed[color output from failing jobs]'

      # Input sources
      '(-a --arg-file)'{-a,--arg-file}'[use input-file as input source]:input file:_files'
      '(--)--[arguments after -- are treated as input arguments]'
      '::::'{::::,----}'[input file(s)]:input file:_files'
      '--arg-sep[use sep instead of ::: as argument separator]:separator:'
      '--arg-file-sep[use sep instead of :::: as argument file separator]:separator:'
      '-d[input items are terminated by delim]:delimiter:'
      '--delimiter[input items are terminated by delim]:delimiter:'
      '-0[like -d \0; items are separated by NUL]'
      '--null[like -d \0; items are separated by NUL]'
      '-E[set the end-of-file string]:eof string:'
      '--eof[set the end-of-file string]:eof string:'

      # Replacement strings
      '-i[replace {} with each input line]:replace string:'
      '-I[use replacement string instead of {}]:replace string:'
      '--replace[use replacement string instead of {}]::replace string:'
      '-X[multiple arguments with context replace]'
      '-m[multiple arguments per command line]'
      '-n[number of arguments per command line]:max args:'
      '--max-args[number of arguments per command line]:max args:'
      '-N[number of arguments per command line (round robin)]:max args:'
      '-L[max number of non-blank lines per command line]:max lines:'
      '--max-lines[max number of non-blank lines per command line]::max lines:'

      # Column handling
      '--colsep[split input on regexp for positional replacements]:regexp:'
      '--csv[treat input as CSV format]'
      '--header[use first line as header for replacement strings]:regexp:'

      # SSH / remote execution
      '-S[server(s) to use for remote execution]:ssh login:'
      '--sshlogin[server(s) to use for remote execution]:ssh login:'
      '--sshloginfile[file with ssh logins]:file:_files'
      '--slf[file with ssh logins]:file:_files'
      '--onall[run the given command on all sshlogins]'
      '--nonall[run the given command with no arguments on all sshlogins]'
      '--transfer[transfer files to remote computers]'
      '--transferfile[transfer files to remote]:filename:'
      '--trc[shorthand for --transfer --return {}.bar --cleanup]:{}.bar:'
      '--return[transfer files from remote]:filename:'
      '--cleanup[remove transferred files on remote]'
      '--basefile[file to transfer to each sshlogin before first job]:file:_files'
      '--workdir[working directory on remote]:dir:_directories'
      '--sshdelay[delay between ssh calls]:seconds:'
      '--ssh[program to use for ssh]:program:_command_names'
      '--controlmaster[use ssh ControlMaster for ssh logins (experimental)]'

      # Resource and load control
      '-l[max load before starting new jobs]:max load:'
      '--load[max load before starting new jobs]:max load:'
      '--noswap[do not start job if there is swap activity]'
      '--memfree[minimum memory free before starting new jobs]:size:'
      '--tmpdir[directory for temporary files]:dir:_directories'
      '--tempdir[directory for temporary files]:dir:_directories'

      # Flow control
      '--halt[when to halt (default\: none)]:when:(now soon never success=N fail=N):percentage:'
      '--retries[number of retries if job fails]:num:'
      '--retry-failed[retry previously failed jobs]'
      '--timeout[kill jobs running longer than duration]:duration:'
      '--delay[wait before starting next job]:seconds:'
      '--nice[adjustment to scheduling priority]:nice level:'

      # Pipe mode
      '--pipe[split stdin to multiple jobs]'
      '--pipepart[pipe parts of a physical file]'
      '--block[block size for --pipe]:size:'
      '--recstart[record start separator for --pipe]:start separator:'
      '--recend[record end separator for --pipe]:end separator:'
      '--regexp[interpret --recstart/--recend as regular expressions]'
      '--remove-rec-sep[remove record separator from output]'
      '--roundrobin[distribute chunks to jobs in round robin fashion]'

      # Logging and progress
      '--progress[show progress of computations]'
      '--bar[show progress as a progress bar]'
      '--eta[show estimated total time]'
      '--joblog[log information about each job to file]:file:_files'
      '--resume[resume from last unfinished job in --joblog]:file:_files'
      '--resume-failed[retry failed and unfinished jobs from --joblog]'

      # Output
      '--results[save output to files in dir]:dir:_directories'
      '--res[save output to files in dir]:dir:_directories'

      # Shell and execution
      '--shell[shell to use for commands]:shell:_command_names'
      '--shebang[can be used in the header of a script]'
      '--shebang-wrap[can be used to wrap scripts]'
      '--env[copy exported environment variable to remote]:variable:_parameters'
      '--record-env[record current exported environment]'

      # Semaphore mode
      '--semaphore[work as a counting semaphore]'
      '--semaphoretimeout[time to wait for semaphore]:seconds:'
      '--semaphorename[name of semaphore]:name:'
      '--fg[run semaphore job in foreground]'
      '--bg[run semaphore job in background]'
      '--wait[wait for semaphore jobs to complete]'
      '--mutex[shorthand for --semaphore --semaphoretimeout 0]'

      # Misc
      '--dry-run[print the jobs that would be run without running them]'
      '(-v --verbose)'{-v,--verbose}'[print the job before running it]'
      '--no-run-if-empty[skip empty input lines]'
      '--xargs[multiple arguments without context replace]'
      '--max-chars[max total length of the command]:max chars:'
      '-s[max total length of the command]:max chars:'
      '--show-limits[show limits on command length]'
      '--number-of-cpus[print the number of physical CPUs and exit]'
      '--number-of-cores[print the number of CPU cores and exit]'
      '--number-of-sockets[print the number of CPU sockets and exit]'
      '--number-of-threads[print the number of hyperthreads and exit]'
      '--use-cpus-instead-of-cores[use CPUs instead of cores for -j]'
      '--citation[print citation notice]'
      '--bibtex[print bibtex entry]'
      '--embed[output completion/embedding code]'
      '--will-cite[do not print citation notice]'
      '(- *)--help[display help and exit]'
      '(- *)--version[display version and exit]'
      '*:command:_cmdstring'
    )
  else
    # moreutils parallel
    arguments=(
      '-j[run n jobs in parallel (default\: one per CPU)]:number of jobs:'
      '-l[wait until load average is below limit]:max load:'
      '-i[replace {} in command with argument]'
      '-n[number of arguments to pass to command at a time]:num args:'
      '*:command:_cmdstring'
    )
  fi

  _arguments -s -S $arguments
}

_parallel "$@"
