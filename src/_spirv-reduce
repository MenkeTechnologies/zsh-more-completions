#compdef spirv-reduce

local -a arguments

arguments=(
  '--fail-on-validation-error[stop reduction with an error if any reduction step produces a]'
  '(- * :)'{-h,--help}'[print this help.]'
  '--step-limit[32-bit unsigned integer specifying maximum number of steps the]'
  '--version[display reducer version information.]'
  '--before-hlsl-legalization[allow SPIR-V not yet legalized for HLSL]'
  '--relax-block-layout[allow block layout relaxation]'
  '--relax-logical-pointer[allow logical pointer relaxation]'
  '--relax-struct-store[allow struct store relaxation]'
  '--scalar-block-layout[enable scalar block layout validation]'
  '--skip-block-layout[skip block layout validation]'
  '*:filename:_files'
)

_arguments -s -S $arguments
