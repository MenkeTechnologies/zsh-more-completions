#compdef gtest

local -a arguments

arguments=(
  '--help[display this help and exit]'
  '--version[output version information and exit]'
  '-n[the length of STRING is nonzero]'
  '-z[the length of STRING is zero]'
  '-b[exists and is block special]:file'
  '-c[exists and is character special]:file'
  '-d[exists and is a directory]:file'
  '-e[exists]:file'
  '-f[exists and is a regular file]:file'
  '-g[exists and is set-group-ID]:file'
  '-G[exists and is owned by the effective group ID]:file'
  '-h[exists and is a symbolic link (same as -L)]:file'
  '-k[exists and has its sticky bit set]:file'
  '-L[exists and is a symbolic link (same as -h)]:file'
  '-O[exists and is owned by the effective user ID]:file'
  '-p[exists and is a named pipe]:file'
  '-r[exists and read permission is granted]:file'
  '-s[exists and has a size greater than zero]:file'
  '-S[exists and is a socket]:file'
  '-t[file descriptor FD is opened on a terminal]'
  '-u[exists and its set-user-ID bit is set]:file'
  '-w[exists and write permission is granted]:file'
  '-x[exists and execute (or search) permission is granted]:file'
  '*:filename:_files'
)

_arguments -s -S $arguments
