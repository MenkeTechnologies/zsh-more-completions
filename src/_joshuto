#compdef joshuto

# Zsh completion for joshuto - Terminal file manager

_arguments \
  '(-h --help)'{-h,--help}'[print help information]' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '--output-file[file to write last directory on exit]:file:_files' \
  '--change-directory[change directory on exit]' \
  '--file-chooser[start in file chooser mode]' \
  '--choosefile[write chosen file to path]:file:_files' \
  '--choosefiles[write chosen files to path]:file:_files' \
  '--printwd[print working directory on exit]' \
  '--mouse[enable mouse support]' \
  '--no-mouse[disable mouse support]' \
  '--session[specify session name]:session name:' \
  '*:directory:_directories'
