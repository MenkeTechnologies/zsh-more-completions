#compdef flask

_flask_commands() {
  local -a commands
  commands=(
    'run:Run a development server'
    'shell:Run a shell in the app context'
    'routes:Show the routes for the app'
  )
  _describe -t commands 'flask command' commands
}

_flask_run() {
  _arguments -s \
    '(-h --host)'{-h,--host}'[The interface to bind to]:host' \
    '(-p --port)'{-p,--port}'[The port to bind to]:port' \
    '--cert[Specify a certificate file to use HTTPS]:cert file:_files' \
    '--key[The key file to use when specifying a certificate]:key file:_files' \
    '(--reload --no-reload)--reload[Enable the reloader]' \
    '(--reload --no-reload)--no-reload[Disable the reloader]' \
    '(--debugger --no-debugger)--debugger[Enable the debugger]' \
    '(--debugger --no-debugger)--no-debugger[Disable the debugger]' \
    '(--with-threads --without-threads)--with-threads[Enable multithreading]' \
    '(--with-threads --without-threads)--without-threads[Disable multithreading]' \
    '--extra-files[Extra files that trigger a reload on change]:files:_files' \
    '--exclude-patterns[Files matching these fnmatch patterns will not trigger a reload]:patterns' \
    '(--debug --no-debug)--debug[Set debug mode]' \
    '(--debug --no-debug)--no-debug[Disable debug mode]' \
    '--help[Show this message and exit]'
}

_flask_routes() {
  _arguments -s \
    '(-s --sort)'{-s,--sort}'[Method to sort routes by]:sort method:(endpoint methods rule match)' \
    '--all-methods[Show HEAD and OPTIONS methods]' \
    '--help[Show this message and exit]'
}

_flask_shell() {
  _arguments -s \
    '--help[Show this message and exit]'
}

_flask() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-A --app)'{-A,--app}'[The Flask application or factory function to load]:app module' \
    '(-e --env-file)'{-e,--env-file}'[Load environment variables from this file]:env file:_files' \
    '(--debug --no-debug)--debug[Set debug mode]' \
    '(--debug --no-debug)--no-debug[Disable debug mode]' \
    '--version[Show the Flask version]' \
    '--help[Show this message and exit]' \
    '(-): :_flask_commands' \
    '(-)*::arg:->args'

  case $state in
    args)
      case $line[1] in
        run) _flask_run ;;
        shell) _flask_shell ;;
        routes) _flask_routes ;;
      esac
      ;;
  esac
}

_flask "$@"
