#compdef d2j-decrypt-string

local -a arguments

arguments=(
  {-cp,--classpath}'[add extra lib to classpath]'
  {-d,--delete}'[delete the method which can decrypt the string]'
  {-da,--deep-analyze}'[use dex2jar IR to static analyze and find decrypt methods]'
  {-f,--force}'[force overwrite]'
  '(- * :)'{-h,--help}'[print this help message]'
  {-m,--methods}'[a file containing a list of methods, each line is a method]:file:_files'
  {-mn,--decrypt-method-name}'[the name of the method which can decrypt strings]'
  {-mo,--decrypt-method-owner}'[the owner of the method which can decrypt strings]'
  {-o,--output}'[output of .jar files, default is $current_dir/\[file-name\]-decrypted.jar]:file:_files'
  {-pd,--parameters-descriptor}'[the descriptor for the method which can decrypt strings]'
  {-t,--arg-types}'[comma-separated list of types: boolean, byte, short, char, int, long, float, double]'
  {-v,--verbose}'[show more on output]'
  '*:filename:_files'
)

_arguments -s -S $arguments
