#compdef t1reencode

local -a arguments

arguments=(
  {-e,--encoding}'[read the encoding from FILE (in DVIPS format).]:file:_files'
  {-E,--encoding-text}'[the ENC argument is the encoding text.]:encoding:'
  {-n,--name}'[set output fonts PostScript name.]:name:'
  {-N,--full-name}'[set output fonts full name.]:name:'
  {-a,--pfa}'[output PFA font.]'
  {-b,--pfb}'[output PFB font. This is the default.]'
  {-o,--output}'[write output to FILE instead of standard out.]:file:_files'
  '(- * :)'{-h,--help}'[print this message and exit.]'
  '--version[print version number and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
