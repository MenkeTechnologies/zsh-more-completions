#compdef reordercap
# Documentation: https://man.archlinux.org/search?q=reordercap
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-n[dont write to output file if the input file is ordered.]'
  '-h[display this help and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
