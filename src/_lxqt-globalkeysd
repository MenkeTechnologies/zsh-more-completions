#compdef lxqt-globalkeysd
# Documentation: https://man.archlinux.org/search?q=lxqt-globalkeysd
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--no-daemon[run as a usual application, not a daemon]'
  '--daemon[run as a daemon, not a usual application]'
  '--use-syslog[print messages to syslog if run as a usual application.]'
  '--log-level[set minimal log level.]'
  '--multiple-actions-behaviour[set the behaviour for the case of multiple actions]'
  '--config-file[use config file FILENAME. Can be used several times.]'
  {-h,--help}'[display help message and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
