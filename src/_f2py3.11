#compdef f2py3.11

local -a arguments

arguments=(
  '-h[write signatures of the fortran routines to file]:filename:_files'
  '-m[name of the module for Python/C API generation]:module name:'
  '--lower[do not preserve case in fortran routines]'
  '--build-dir[directory for generated files]:dirname:_files -/'
  '--overwrite-signature[overwrite existing signature file.]'
  '--short-latex[create short LaTeX document]'
  '--debug-capi[create C/API code that reports wrapper state]'
  '--include-paths[search include files from given directories]:paths:'
  '--help-link[list system resources found by system_info.py]'
  '--f2cmap[load Fortran-to-Python KIND specification from the given]'
  '--quiet[run quietly.]'
  '--verbose[run with extra verbosity.]'
  '--skip-empty-wrappers[only generate wrapper files when needed.]'
  '-v[print f2py version ID and exit.]'
  '--fcompiler[specify Fortran compiler type by vendor \[NO_MESON\]]'
  '--compiler[specify distutils C compiler type \[NO_MESON\]]'
  '--help-fcompiler[list available Fortran compilers and exit \[NO_MESON\]]'
  '--f77exec[specify the path to F77 compiler \[NO_MESON\]]'
  '--f90exec[specify the path to F90 compiler \[NO_MESON\]]'
  '--f77flags[specify F77 compiler flags]:flags:'
  '--f90flags[specify F90 compiler flags]:flags:'
  '--opt[specify optimization flags \[NO_MESON\]]'
  '--arch[specify architecture specific optimization flags \[NO_MESON\]]'
  '--noopt[compile without optimization \[NO_MESON\]]'
  '--noarch[compile without arch-dependent optimization \[NO_MESON\]]'
  '--debug[compile with debugging information]'
  '--dep[<dependency>]'
  '--backend[<backend_type>]'
  '-L[add library search path]:path:_files -/'
  '-D[define macro]:define:'
  '-I[add include search path]:path:_files -/'
  '*:filename:_files'
)

_arguments -s -S $arguments
