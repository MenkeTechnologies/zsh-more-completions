#compdef zhack
# Documentation: https://man.archlinux.org/search?q=zhack
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-d[sets the features description]'
  '-d[instead of increase the refcount]'
  '-m[the feature to the label if increasing refcount]'
  '*:filename:_files'
)

_arguments -s -S $arguments
