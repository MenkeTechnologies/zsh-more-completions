#compdef sncfgtemplate
# Documentation: https://man.archlinux.org/search?q=sncfgtemplate
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-n[name of file system]'
  '-M[message format: ASCII, XML (default ASCII)]'
  '-h[this usage]'
  '*:filename:_files'
)

_arguments -s -S $arguments
