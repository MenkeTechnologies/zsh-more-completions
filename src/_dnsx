#compdef dnsx

# Zsh completion for dnsx - fast and multi-purpose DNS toolkit

_arguments -s -S \
  '(-l --list)'{-l,--list}'[file containing list of domains to resolve]:file:_files' \
  '(-d --domain)'{-d,--domain}'[single domain to resolve]:domain:' \
  '(-w --wordlist)'{-w,--wordlist}'[list of words to bruteforce DNS]:file:_files' \
  '(-r --resolvers)'{-r,--resolvers}'[file containing a list of resolvers]:file:_files' \
  '(-t --threads)'{-t,--threads}'[number of concurrent goroutines]:N:' \
  '(-rl --rate-limit)'{-rl,--rate-limit}'[number of DNS requests per second]:N:' \
  '(-retries --retries)--retries[number of DNS retries]:N:' \
  '(-a --resp-only)'{-a,--resp-only}'[return only DNS response records]' \
  '-A[query A record]' \
  '--a[query A record]' \
  '-AAAA[query AAAA record]' \
  '--aaaa[query AAAA record]' \
  '-CNAME[query CNAME record]' \
  '--cname[query CNAME record]' \
  '-MX[query MX record]' \
  '--mx[query MX record]' \
  '-NS[query NS record]' \
  '--ns[query NS record]' \
  '-TXT[query TXT record]' \
  '--txt[query TXT record]' \
  '-PTR[query PTR record]' \
  '--ptr[query PTR record]' \
  '-SOA[query SOA record]' \
  '--soa[query SOA record]' \
  '-CAA[query CAA record]' \
  '--caa[query CAA record]' \
  '-any[query ANY record]' \
  '--any[query ANY record]' \
  '-axfr[try AXFR zone transfer]' \
  '-ra --resp[return DNS response]' \
  '--resp[return DNS response]' \
  '--rcode[filter result by DNS status code]:codes:' \
  '-cdn[display CDN names in output]' \
  '--cdn[display CDN names in output]' \
  '-asn[display ASN information in output]' \
  '--asn[display ASN information in output]' \
  '(-o --output)'{-o,--output}'[file to write output]:file:_files' \
  '--json[write output in JSONL format]' \
  '--omit-raw[omit raw DNS response from JSON output]' \
  '(-nc --no-color)'{-nc,--no-color}'[disable colors in output]' \
  '(-silent --silent)--silent[display results only]' \
  '(-verbose --verbose)--verbose[display verbose output]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]'
