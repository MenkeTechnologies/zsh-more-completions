#compdef rfcat

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-r,--research}'[interactive Python with the "d" instance to talk to the dongle]'
  {-i,--index}'[dongle index]:index: '
  {-s,--specan}'[start spectrum analyzer]'
  {-f,--centfreq}'[center frequency]:frequency: '
  {-c,--inc}'[frequency increment]:increment: '
  {-n,--specchans}'[number of spectrum channels]:channels: '
  '--bootloader[trigger the bootloader for flashing firmware]'
  '--force[use this to make sure you want to set bootloader mode]'
  '*:filename:_files'
)

_arguments -s -S $arguments
