#compdef stunnel4 stunnel
# Documentation: https://man.archlinux.org/search?q=stunnel4
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '--fd[Read the config file from specified file descriptor.]'
    '--help[Print stunnel help menu.]'
    '--version[Print stunnel version and compile time defaults.]'
    '--sockets[Print default socket options.]'
    '--options[Print supported TLS options.]'
    '--install[Install NT Service.]'
    '--uninstall[Uninstall NT Service.]'
    '--start[Start NT Service.]'
    '--stop[Stop NT Service.]'
    '--reload[Reload the configuration file of the running NT Service.]'
    '--reopen[Reopen the log file of the running NT Service.]'
    '--exit[Exit an already started stunnel.]:only)'
    '*:filename:_files'
)
_arguments -s -S $arguments
