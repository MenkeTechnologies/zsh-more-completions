#compdef fvm

# Zsh completion for fvm - Flutter Version Management

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'config:set configuration for FVM'
  'dart:proxy to Dart SDK from current Flutter version'
  'doctor:shows information about environment'
  'exec:execute scripts in a Flutter environment'
  'flutter:proxy to Flutter SDK from current version'
  'global:set/view the global Flutter SDK version'
  'install:install a Flutter SDK version'
  'list:list installed Flutter SDK versions'
  'releases:view all Flutter SDK releases'
  'remove:remove a Flutter SDK version'
  'spawn:spawn a command in a Flutter SDK version'
  'use:set a project to use a Flutter SDK version'
  'destroy:destroy FVM cache'
)

local -a installed_versions
installed_versions=( ${(f)"$(command fvm list 2>/dev/null | awk '{print $1}')"} )

_arguments -s -S \
  '1:subcommand:->subcmd' \
  '*::args:->args' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--verbose[print verbose output]' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'fvm subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (install)
        _arguments \
          '--skip-setup[skip Flutter setup after install]' \
          '1:Flutter version:(stable beta dev master ${installed_versions})' && ret=0
        ;;
      (use)
        _arguments \
          '-f[force use even if not installed]' \
          '--force[force use even if not installed]' \
          '-p[pin to an exact version]' \
          '--pin[pin to an exact version]' \
          '--flavor[set custom SDK flavor]:flavor:' \
          '--skip-setup[skip Flutter setup after install]' \
          '1:Flutter version:(stable beta dev master ${installed_versions})' && ret=0
        ;;
      (global)
        _arguments '1:Flutter version:(stable beta dev master ${installed_versions})' && ret=0
        ;;
      (remove)
        _arguments '1:installed version:(${installed_versions})' && ret=0
        ;;
      (spawn)
        _arguments \
          '1:Flutter version:(stable beta dev master ${installed_versions})' \
          '*:command:' && ret=0
        ;;
      (config)
        _arguments \
          '--cache-path[set custom cache path]:path:_files -/' \
          '--flutter-url[set custom Flutter repo URL]:url:' \
          '--use-git-cache[use git cache for Flutter SDK]' \
          '--no-use-git-cache[do not use git cache]' \
          '--git-cache-path[set custom git cache path]:path:_files -/' && ret=0
        ;;
      (exec)
        _arguments '*:command:_command_names -e' && ret=0
        ;;
      (releases)
        _arguments '--channel[filter by channel]:channel:(stable beta dev)' && ret=0
        ;;
    esac
    ;;
esac

return ret
