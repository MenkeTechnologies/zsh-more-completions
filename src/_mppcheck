#compdef mppcheck
# Documentation: https://man.archlinux.org/search?q=mppcheck
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-v[verbose mode]'
  '-c[show CIE94 delta E values]'
  '-k[show CIEDE2000 delta E values]'
  '-s[check spectral model too]'
  '-y[detail each value]'
  '*:filename:_files'
)

_arguments -s -S $arguments
