#compdef fastjar

local -a arguments

arguments=(
  '-c[create new archive]'
  '-t[list table of contents for archive]'
  '-x[extract named (or all) files from archive]'
  '-u[update existing archive]'
  '-0[store only; use no ZIP compression]'
  '-C[change to specified directory and include]:directory:_files -/'
  '-E[do not include the files found in a directory]'
  '-f[specify archive file name]:file:_files'
  '--help[print this help, then exit]'
  '-m[include manifest information from specified manifest file]:file:_files'
  '-M[do not create a manifest file for the entries]'
  '-i[generate an index of the packages in this jar]'
  '-v[generate verbose output on standard output]'
  {-V,--version}'[display version information]'
  '-J[* -J options are ignored]'
  '*:filename:_files'
)

_arguments -s -S $arguments
