#compdef genkeys
# Documentation: https://man.archlinux.org/search?q=genkeys
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-r[dictionary file, one word per line]'
  '-f[pass+hash filename]'
  '-n[index filename]'
  '-h[2 hash bytes to filter with (optional)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
