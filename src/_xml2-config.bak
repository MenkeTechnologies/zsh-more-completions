#compdef xml2-config.bak
# Documentation: https://man.archlinux.org/search?q=xml2-config.bak
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--prefix[change libxml prefix \[default /opt/homebrew/anaconda3\]]'
  '--exec-prefix[change libxml exec prefix \[default /opt/homebrew/anaconda3\]]'
  '--libs[print library linking information]'
  '--cflags[print pre-processor and compiler flags]'
  '--modules[module support enabled]'
  '--help[display this help and exit]'
  '--version[output version information]'
  '*:filename:_files'
)

_arguments -s -S $arguments
