#compdef blkcalc

local -a arguments

arguments=(
  '-d[the given address is from a dd image]'
  '-s[the given address is from a blkls -s (slack) image]'
  '-u[the given address is from a blkls (unallocated) image]'
  '-f[the file system type (use -f list for supported types)]:type:'
  '-i[the format of the image file (use -i list for supported types)]:format:'
  '-b[the size (in bytes) of the device sectors]:size:'
  '-o[the offset of the file system in the image (in sectors)]:offset:'
  '-v[verbose output to stderr]'
  '-V[print version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
