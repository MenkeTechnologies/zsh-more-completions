#compdef mpicalc
# Documentation: https://man.archlinux.org/search?q=mpicalc
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--version[print version information]'
  '--print-config[print the Libgcrypt config]'
  '--disable-hwf[disable feature NAME]'
  '*:filename:_files'
)

_arguments -s -S $arguments
