#compdef update-binfmts

local -a arguments

arguments=(
  '--magic[\[--mask <byte-sequence>\] \[--offset <offset>\]]'
  '--extension[match by file extension]:extension:'
  '--detector[use specified program as detector]:detector:_files'
  '--package[for --install and --remove, specify the current package]:package:'
  '--admindir[administration directory]:dir:_directories'
  '--importdir[import directory (default: /usr/share/binfmts)]'
  '--test[dont do anything, just demonstrate]'
  '--usage[give a short usage message]'
  {-V,--version}'[print program version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
