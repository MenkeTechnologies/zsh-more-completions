#compdef starship

# Zsh completion for Starship prompt (https://starship.rs)
# Covers Starship 1.x commands and options

# Available starship modules for completion
_starship_modules() {
  local -a modules
  modules=(
    'aws' 'azure' 'battery' 'buf' 'bun' 'c' 'character' 'cmake'
    'cmd_duration' 'cobol' 'conda' 'container' 'crystal' 'daml'
    'dart' 'deno' 'directory' 'direnv' 'docker_context' 'dotnet'
    'elixir' 'elm' 'env_var' 'erlang' 'fennel' 'fill' 'fossil_branch'
    'fossil_metrics' 'gcloud' 'git_branch' 'git_commit' 'git_metrics'
    'git_state' 'git_status' 'gleam' 'golang' 'gradle' 'guix_shell'
    'haskell' 'haxe' 'helm' 'hostname' 'java' 'jobs' 'julia'
    'kotlin' 'kubernetes' 'line_break' 'localip' 'lua' 'memory_usage'
    'meson' 'mercurial_branch' 'mojo' 'nats' 'nim' 'nix_shell'
    'nodejs' 'ocaml' 'odin' 'opa' 'openstack' 'os' 'package'
    'perl' 'php' 'pijul_channel' 'pulumi' 'purescript' 'python'
    'quarto' 'rlang' 'raku' 'red' 'ruby' 'rust' 'scala' 'shell'
    'shlvl' 'singularity' 'solidity' 'spack' 'status' 'sudo'
    'swift' 'terraform' 'time' 'typst' 'username' 'vagrant'
    'vcsh' 'vlang' 'zig'
  )
  compadd -a modules
}

# Available presets
_starship_presets() {
  local -a presets
  presets=(
    'bracketed-segments' 'gruvbox-rainbow' 'jetpack' 'nerd-font-symbols'
    'no-empty-icons' 'no-nerd-font' 'no-runtime-versions'
    'pastel-powerline' 'plain-text-symbols' 'pure-preset'
    'tokyo-night'
  )
  compadd -a presets
}

_starship_commands() {
  local -a commands
  commands=(
    'bug-report:Create a pre-populated GitHub issue with information about your configuration'
    'completions:Generate shell completions for your shell'
    'config:Edit the starship configuration'
    'explain:Explains the currently showing modules'
    'init:Prints the shell function used to execute starship'
    'module:Prints a specific prompt module'
    'preset:Prints a preset config'
    'print-config:Prints the computed starship configuration'
    'prompt:Prints the full starship prompt'
    'session:Generate a random session key'
    'time:Prints time in milliseconds'
    'timings:Prints timings of all active modules'
    'toggle:Toggle a given starship module'
    'help:Print help for a command or subcommand'
  )
  _describe -t commands 'starship command' commands
}

# Shared prompt-related flags used by prompt, explain, timings, module
_starship_prompt_flags() {
  local -a flags
  flags=(
    '--status[The status code of the previously run command]:status code:'
    '*--pipestatus[Pipe exit status codes of the previously run command]:status code:'
    '--terminal-width[The width of the current interactive terminal]:width:'
    '--path[The path that the prompt should render for]:path:_files -/'
    '--logical-path[The logical path that the prompt should render for]:path:_files -/'
    '--cmd-duration[The execution duration of the last command in milliseconds]:duration:'
    '--keymap[The keymap of fish/zsh]:keymap:(default viins vicmd visual viopp)'
    '--jobs[The number of currently running jobs]:jobs:'
    '(-h --help)'{-h,--help}'[Print help information]'
  )
  echo "${(j: :)${(q)flags}}"
}

_starship() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Print help information]' \
    '(-V --version)'{-V,--version}'[Print version information]' \
    '1:command:_starship_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        bug-report)
          _arguments \
            '(-h --help)'{-h,--help}'[Print help information]'
          ;;
        completions)
          _arguments \
            '(-h --help)'{-h,--help}'[Print help information]' \
            '1:shell:(bash elvish fish powershell zsh)'
          ;;
        config)
          _arguments \
            '(-h --help)'{-h,--help}'[Print help information]' \
            '1:name:' \
            '2:value:'
          ;;
        explain)
          _arguments \
            '--status[The status code of the previously run command]:status code:' \
            '*--pipestatus[Pipe exit status codes of the previously run command]:status code:' \
            '--terminal-width[The width of the current interactive terminal]:width:' \
            '(-p --path)'{-p,--path}'[The path that the prompt should render for]:path:_files -/' \
            '(-P --logical-path)'{-P,--logical-path}'[The logical path that the prompt should render for]:path:_files -/' \
            '--cmd-duration[The execution duration of the last command in milliseconds]:duration:' \
            '--keymap[The keymap of fish/zsh]:keymap:(default viins vicmd visual viopp)' \
            '--jobs[The number of currently running jobs]:jobs:' \
            '(-h --help)'{-h,--help}'[Print help information]'
          ;;
        init)
          _arguments \
            '--print-full-init[Print the main initialization script (for use in eval)]' \
            '(-h --help)'{-h,--help}'[Print help information]' \
            '1:shell:(bash elvish fish cmd powershell tcsh nu xonsh zsh)'
          ;;
        module)
          _arguments \
            '--list[List out all supported modules]' \
            '--status[The status code of the previously run command]:status code:' \
            '*--pipestatus[Pipe exit status codes of the previously run command]:status code:' \
            '--terminal-width[The width of the current interactive terminal]:width:' \
            '(-p --path)'{-p,--path}'[The path that the prompt should render for]:path:_files -/' \
            '(-P --logical-path)'{-P,--logical-path}'[The logical path that the prompt should render for]:path:_files -/' \
            '--cmd-duration[The execution duration of the last command in milliseconds]:duration:' \
            '--keymap[The keymap of fish/zsh]:keymap:(default viins vicmd visual viopp)' \
            '--jobs[The number of currently running jobs]:jobs:' \
            '(-h --help)'{-h,--help}'[Print help information]' \
            '1:module:_starship_modules'
          ;;
        preset)
          _arguments \
            '(-o --output)'{-o,--output}'[Output the preset to a file instead of stdout]:file:_files' \
            '--list[List out all preset names]' \
            '(-h --help)'{-h,--help}'[Print help information]' \
            '1:preset:_starship_presets'
          ;;
        print-config)
          _arguments \
            '(-d --default)'{-d,--default}'[Print the default configuration]' \
            '(-h --help)'{-h,--help}'[Print help information]' \
            '*:name:'
          ;;
        prompt)
          _arguments \
            '--profile[Print the prompt with the specified profile name]:profile:' \
            '--right[Print the right prompt (instead of the standard left prompt)]' \
            '--continuation[Print the continuation prompt]' \
            '--status[The status code of the previously run command]:status code:' \
            '*--pipestatus[Pipe exit status codes of the previously run command]:status code:' \
            '--terminal-width[The width of the current interactive terminal]:width:' \
            '(-p --path)'{-p,--path}'[The path that the prompt should render for]:path:_files -/' \
            '(-P --logical-path)'{-P,--logical-path}'[The logical path that the prompt should render for]:path:_files -/' \
            '--cmd-duration[The execution duration of the last command in milliseconds]:duration:' \
            '--keymap[The keymap of fish/zsh]:keymap:(default viins vicmd visual viopp)' \
            '--jobs[The number of currently running jobs]:jobs:' \
            '(-h --help)'{-h,--help}'[Print help information]'
          ;;
        session)
          _arguments \
            '(-h --help)'{-h,--help}'[Print help information]'
          ;;
        time)
          _arguments \
            '(-h --help)'{-h,--help}'[Print help information]'
          ;;
        timings)
          _arguments \
            '--status[The status code of the previously run command]:status code:' \
            '*--pipestatus[Pipe exit status codes of the previously run command]:status code:' \
            '--terminal-width[The width of the current interactive terminal]:width:' \
            '(-p --path)'{-p,--path}'[The path that the prompt should render for]:path:_files -/' \
            '(-P --logical-path)'{-P,--logical-path}'[The logical path that the prompt should render for]:path:_files -/' \
            '--cmd-duration[The execution duration of the last command in milliseconds]:duration:' \
            '--keymap[The keymap of fish/zsh]:keymap:(default viins vicmd visual viopp)' \
            '--jobs[The number of currently running jobs]:jobs:' \
            '(-h --help)'{-h,--help}'[Print help information]'
          ;;
        toggle)
          _arguments \
            '(-h --help)'{-h,--help}'[Print help information]' \
            '1:module:_starship_modules' \
            '2:key:'
          ;;
        help)
          _arguments \
            '1:command:(bug-report completions config explain init module preset print-config prompt session time timings toggle)'
          ;;
      esac
      ;;
  esac
}

_starship "$@"
