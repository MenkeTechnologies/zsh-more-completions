#compdef rsh-redone-rlogin
# Documentation: https://man.archlinux.org/search?q=rsh-redone-rlogin
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '-4[Use only IPv4 to connect to the remote host.]'
    '-6[Use only IPv6 to connect to the remote host.]'
    '-v[Be verbose.]'
    '-l[Connect to the remote machine as a different user than on the local machine.]'
    '-p[Connect to a different port than the default one for rsh-redone-rlogin.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
