#compdef mate-tweak
# Documentation: https://man.archlinux.org/search?q=mate-tweak
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  '--layout[switch to a panel layout]'
  '--get-layout[get the current panel layout]'
  '*:filename:_files'
)

_arguments -s -S $arguments
