#compdef abrt-server
# Documentation: https://man.archlinux.org/search?q=abrt-server
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-v,--verbose}'[be verbose]'
  '-u[use NUM as client uid]'
  '-s[log to syslog]'
  '-p[add program names to log]'
  '*:filename:_files'
)

_arguments -s -S $arguments
