#compdef bthidd
# Documentation: https://man.archlinux.org/search?q=bthidd
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-a[specify address to listen on (default ANY)]'
  '-c[specify config file name]'
  '-d[run in foreground]'
  '-H[specify known HIDs file name]'
  '-h[display this message]'
  '-p[specify PID file name]'
  '-t[specify client rescan interval (sec)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
