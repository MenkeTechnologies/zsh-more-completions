#compdef ksverdiff
# Documentation: https://man.archlinux.org/search?q=ksverdiff
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-f,--from}'[specify starting version for comparison]:version:'
  {-t,--to}'[specify ending version for comparison]:version:'
  {-l,--listversions}'[list the available versions of kickstart syntax]'
  '*:filename:_files'
)

_arguments -s -S $arguments
