#compdef json_xs
# Documentation: https://man.archlinux.org/search?q=json_xs
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '-v[Be slightly more verbose]'
    '-f[Read a file in the given format from STDIN]:fromformat:(json json-pretty cbor storable storable-file ub yaml clzf bencode eval string)'
    '-t[Output format]:toformat:(json json-pretty cbor storable storable-file ub yaml clzf bencode eval none)'
    '-e[Evaluate Perl code on each input record]:expr'
    '*:filename:_files'
)
_arguments -s -S $arguments
