#compdef nfsdclnts

local -a arguments

arguments=(
    {-t,--type}'[specify NFS version type]:type:'
    '--clientinfo[display client info]'
    '--hostname[display hostname]'
    {-q,--quiet}'[quiet mode]'
    {-v,--verbose}'[verbose mode]'
    {-f,--file}'[specify file]:file:_files'
    '(- * :)'{-h,--help}'[display help]'
    '*:filename:_files'
)
_arguments -s -S $arguments
