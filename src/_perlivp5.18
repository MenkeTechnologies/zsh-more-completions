#compdef perlivp5.18
# Documentation: https://man.archlinux.org/search?q=perlivp5.18
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-p[a preface before each test telling what it will test.]'
  '-v[mode in which extra information about test results]'
  '-h[this help message.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
