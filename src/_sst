#compdef sst

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:initialize SST in your project'
  'dev:start the dev environment'
  'deploy:deploy your application'
  'remove:remove your application'
  'diff:compare infrastructure changes'
  'bind:bind resources to a command'
  'shell:start a shell with resource bindings'
  'console:start the SST Console'
  'secret:manage secrets'
  'telemetry:manage telemetry preferences'
  'upgrade:upgrade SST to the latest version'
  'version:show current version'
  'refresh:refresh the state of your application'
  'unlock:unlock the state'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--stage=[target stage]:stage' \
  '--verbose[enable verbose logging]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'sst command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (dev)
        _arguments -s -S \
          '--stage=[target stage]:stage' \
          '--verbose[enable verbose logging]' \
          '--increase-timeout[increase function timeout]' && ret=0
        ;;
      (deploy|remove)
        _arguments -s -S \
          '--stage=[target stage]:stage' \
          '--verbose[enable verbose logging]' \
          '--from=[deploy from a specific step]:step' && ret=0
        ;;
      (secret)
        local -a secret_cmds=(
          'set:set a secret'
          'remove:remove a secret'
          'list:list all secrets'
          'load:load secrets from .env file'
        )
        _arguments \
          '1:subcommand:_describe -t secret-commands "secret command" secret_cmds' \
          '*:args' && ret=0
        ;;
      (bind)
        _arguments -s -S \
          '--stage=[target stage]:stage' \
          '*:command' && ret=0
        ;;
      (shell)
        _arguments -s -S \
          '--stage=[target stage]:stage' && ret=0
        ;;
    esac
    ;;
esac

return ret
