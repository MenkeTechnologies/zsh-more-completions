#compdef gnome-disks
# Documentation: https://man.archlinux.org/search?q=gnome-disks
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  '--help-all[show all help options]'
  '--help-gapplication[show GApplication options]'
  '--help-gtk[show GTK+ Options]'
  '--block-device[select device]'
  '--format-device[format selected device]'
  '--xid[parent window XID for the format dialog]'
  '--restore-disk-image[restore disk image]'
  '--display[X display to use]'
  '*:filename:_files'
)

_arguments -s -S $arguments
