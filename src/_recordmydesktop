#compdef recordmydesktop

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[print this help and exit.]'
  '--version[print program version and exit.]'
  '--print-config[print info about options selected]'
  '--windowid[id of window to be recorded]:window-id: '
  '--display[display to connect to]:display: '
  '-x[offset in x direction]:x-offset: '
  '-y[offset in y direction]:y-offset: '
  '--width[width of recorded window]:width: '
  '--height[height of recorded window]:height: '
  '--dummy-cursor[color of the dummy cursor]:color:(black white)'
  '--no-cursor[disable drawing of the cursor]'
  '--no-shared[disable usage of MIT-shared memory extension]'
  '--full-shots[take full screenshot at every frame]'
  '--follow-mouse[makes the capture area follow the mouse cursor]'
  '--quick-subsampling[do subsampling of the chroma planes by discarding]'
  '--fps[frames per second for the recording]:fps: '
  '--channels[number of sound channels]:channels: '
  '--freq[sound frequency]:frequency: '
  '--buffer-size[buffer size for sound recording]:size: '
  '--ring-buffer-size[ring buffer size in seconds]:seconds: '
  '--device[sound device (default hw:0,0)]:device: '
  '--use-jack[record audio from the specified JACK ports]:ports: '
  '--no-sound[do not record sound]'
  '--on-the-fly-encoding[encode the audio-video data while recording]'
  '--v_quality[video quality (0 to 63)]:quality: '
  '--v_bitrate[video bitrate (0 to 2000000)]:bitrate: '
  '--s_quality[audio quality (-1 to 10)]:quality: '
  '--rescue[encode data from a previous session]:path:_files'
  '--no-wm-check[do not try to detect the window manager]'
  '--no-frame[do not show the frame around capture area]'
  '--pause-shortcut[shortcut used for pausing the recording]:shortcut: '
  '--stop-shortcut[shortcut used to stop the recording]:shortcut: '
  '--compress-cache[image data are cached with light compression]'
  '--workdir[location where a temporary directory will be created]:dir:_directories'
  '--delay[number of seconds to delay before recording]:delay: '
  '--overwrite[overwrite existing output file]'
  {-o,--output}'[name of recorded video file]:file:_files'
  '*:filename:_files'
)

_arguments -s -S $arguments
