#compdef avahi-set-host-name
# Documentation: https://man.archlinux.org/search?q=avahi-set-host-name
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help]'
  {-V,--version}'[show version]'
  {-v,--verbose}'[enable verbose mode]'
  '*:filename:_files'
)

_arguments -s -S $arguments
