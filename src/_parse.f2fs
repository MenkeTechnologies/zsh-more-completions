#compdef parse.f2fs
# Documentation: https://man.archlinux.org/search?q=parse.f2fs
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-a[sorted by pid & file types]'
  '-f[sorted by file types]'
  '-p[sorted by pid]'
  '-m[number]'
  '-n[number]'
  '*:filename:_files'
)

_arguments -s -S $arguments
