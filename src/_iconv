#compdef iconv

local arguments ret=1

# Helper function to generate encoding list from iconv -l
_iconv_encodings() {
  local -a encodings
  encodings=( ${(f)"$(iconv -l 2>/dev/null | tr ' ' '\n' | grep -v '^$')"} )
  _describe -t encodings 'encoding' encodings && ret=0
}

arguments=(
  {-f+,--from-code=}'[encoding of original text]:from encoding:_iconv_encodings'
  {-t+,--to-code=}'[encoding for output]:to encoding:_iconv_encodings'
  '(-l --list)'{-l,--list}'[list all known coded character sets]'
  '-c[omit invalid characters from output]'
  {-o+,--output=}'[output file]:output file:_files'
  {-s,--silent}'[suppress warnings]'
  '--verbose[print progress information]'
  '(- *)--usage[give a short usage message]'
  '(- *)'{-\?,--help}'[display help information]'
  '(- *)'{-V,--version}'[print program version]'
  '*:input file:_files'
)

_arguments -s -S $arguments && ret=0
return ret
