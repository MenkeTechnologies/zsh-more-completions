#compdef fd fdfind

# Zsh completion for fd (https://github.com/sharkdp/fd)

_fd() {
    local -a arguments

    arguments=(
        # Search behavior
        {-H,--hidden}'[include hidden directories and files in search results]'
        '--no-hidden[overrides --hidden]'
        {-I,--no-ignore}'[show results from .gitignore, .ignore, .fdignore ignored files]'
        '--ignore[override --no-ignore]'
        '--no-ignore-vcs[show results from .gitignore ignored files]'
        '--ignore-vcs[override --no-ignore-vcs]'
        '--no-require-git[do not require a git repository to respect gitignores]'
        '--require-git[override --no-require-git]'
        '--no-ignore-parent[do not respect ignore files from parent directories]'
        '--no-global-ignore-file[do not respect the global ignore file]'
        {-u,--unrestricted}'[unrestricted search (alias for --no-ignore --hidden), repeat for more]'

        # Pattern matching
        {-s,--case-sensitive}'[perform a case-sensitive search]'
        {-i,--ignore-case}'[perform a case-insensitive search]'
        {-g,--glob}'[perform a glob-based search instead of a regular expression search]'
        '--regex[perform a regular-expression based search (default)]'
        {-F,--fixed-strings}'[treat the pattern as a literal string instead of a regular expression]'
        '*--and[add additional required search patterns, all of which must match]:pattern:'

        # Path display
        {-a,--absolute-path}'[show the full path starting from the root]'
        '--relative-path[override --absolute-path, show relative paths]'
        {-l,--list-details}'[use a long listing format with file metadata (like ls -l)]'
        {-L,--follow}'[follow symbolic links when traversing directories]'
        '--no-follow[override --follow]'
        {-p,--full-path}'[match the full absolute path instead of just the filename]'
        {-0,--print0}'[separate search results by the null character instead of newlines]'

        # Filtering
        {-d,--max-depth}'[limit directory traversal to a given depth]:depth:'
        '--min-depth[only show results starting at the given depth]:depth:'
        '--exact-depth[only show results at the exact given depth]:depth:'
        '*'{-t,--type}'[filter the search by type]:type:((
            f\:"regular files"
            file\:"regular files"
            d\:"directories"
            dir\:"directories"
            directory\:"directories"
            l\:"symbolic links"
            symlink\:"symbolic links"
            s\:"sockets"
            socket\:"sockets"
            p\:"named pipes (FIFO)"
            pipe\:"named pipes (FIFO)"
            b\:"block devices"
            block-device\:"block devices"
            c\:"character devices"
            char-device\:"character devices"
            x\:"executables"
            executable\:"executables"
            e\:"empty files or directories"
            empty\:"empty files or directories"
        ))'
        '*'{-e,--extension}'[filter search results by file extension]:extension:'
        '*'{-E,--exclude}'[exclude entries matching the given glob pattern]:pattern:'
        {-S,--size}'[limit results based on file size (e.g. +500k, -10M)]:size:'
        '--changed-within[filter by modification time (newer than)]:date or duration:'
        '--changed-before[filter by modification time (older than)]:date or duration:'
        '--changed-after[alias for --changed-within]:date or duration:'
        '--change-newer-than[alias for --changed-within]:date or duration:'
        '--newer[alias for --changed-within]:date or duration:'
        '--change-older-than[alias for --changed-before]:date or duration:'
        '--older[alias for --changed-before]:date or duration:'
        '--owner[filter results by owning user and/or group]:owner\:group:'
        '--prune[do not descend into directories that match the search criteria]'

        # Execution
        '*'{-x,--exec}'[execute a command for each search result in parallel]:command:'
        '*'{-X,--exec-batch}'[execute a command with all search results at once]:command:'
        '--batch-size[maximum number of arguments to pass to -X command]:size:'

        # Output
        {-c,--color}'[when to use color for pattern match output]:when:(auto always never)'
        '--hyperlink=[add terminal hyperlink to file URL for each path]:when:(auto always never)'
        '--show-errors[enable the display of filesystem errors]'
        '--strip-cwd-prefix=[strip ./ prefix from relative paths]:when:(auto always never)'
        '--path-separator[set the path separator for printing file paths]:separator:'
        '--format[specify a custom format string for search results]:format:'
        '--max-results[limit the number of search results]:count:'
        '-1[limit the search to a single result (alias for --max-results=1)]'
        {-q,--quiet}'[print nothing, exit code 0 if match found, 1 otherwise]'
        '--has-results[alias for --quiet]'

        # Directory options
        '*--search-path[provide paths to search]:directory:_files -/'
        {-C,--base-directory}'[change the current working directory before searching]:directory:_files -/'
        '--one-file-system[do not cross file system boundaries]'
        '*--ignore-file[add a custom ignore-file in .gitignore format]:ignore file:_files'
        '--ignore-contain[ignore directories containing the named entry]:name:'

        # Threads
        {-j,--threads}'[set number of threads for searching and executing]:num:'

        # Misc
        '--max-buffer-time[maximum time in milliseconds to buffer results]:milliseconds:'
        '(- *)'{-h,--help}'[print help information]'
        '(- *)'{-V,--version}'[print version information]'

        # Positional arguments
        '1:search pattern:'
        '*:directory:_files -/'
    )

    _arguments -s -S $arguments
}

_fd "$@"
