#compdef GenPat
# Documentation: https://man.archlinux.org/search?q=GenPat
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '-R[generate reverse patch]'
    '-B[set block size]:block-size:'
    '-V[show version information]'
    '-O[set output file]:file:_files'
    '-A[set maximum add size]:size:'
    '*:filename:_files'
)
_arguments -s -S $arguments
