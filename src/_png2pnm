#compdef png2pnm
# Documentation: https://man.archlinux.org/search?q=png2pnm
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-r[write pnm-file in binary format (P4/P5/P6) (default)]'
  '-n[write pnm-file in ascii format (P1/P2/P3)]'
  '-a[<file>.pgm write PNG alpha channel as pgm-file]'
  '-h[-\?  print this help-information]'
  '*:filename:_files'
)

_arguments -s -S $arguments
