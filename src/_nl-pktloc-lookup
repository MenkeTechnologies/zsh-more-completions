#compdef nl-pktloc-lookup
# Documentation: https://man.archlinux.org/search?q=nl-pktloc-lookup
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help text.]'
  {-v,--version}'[show versioning information.]'
  {-l,--list}'[list all packet location definitions.]'
  '--u32[print in iproute2s u32 selector style]'
  '*:filename:_files'
)

_arguments -s -S $arguments
