#compdef apache2

local -a arguments

arguments=(
    '-D[define a name for use in IfDefine directives]:name: '
    '-d[specify an alternate initial ServerRoot]:directory:_directories'
    '-f[specify an alternate ServerConfigFile]:config file:_files'
    '-C[process directive before reading config files]:directive: '
    '-c[process directive after reading config files]:directive: '
    '-e[show startup errors of level (see LogLevel)]:level: '
    '-E[log startup errors to file]:file:_files'
    '-v[show version number]'
    '-V[show compile settings]'
    '-h[list available command line options]'
    '-l[list compiled in modules]'
    '-L[list available configuration directives]'
    '-S[show parsed vhost and run settings]'
    '-M[show all loaded modules]'
    '-t[run syntax check for config files]'
    '-T[start without DocumentRoot(s) check]'
    '-X[debug mode (only one worker, do not detach)]'
    '*:filename:_files'
)

_arguments -s -S $arguments
