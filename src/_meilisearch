#compdef meilisearch

# Zsh completion for Meilisearch

_arguments -s -S \
  '--db-path[path to the database]:path:_files -/' \
  '--env[environment]:env:(production development)' \
  '--http-addr[address and port to listen on]:addr:' \
  '--master-key[master key for API access]:key:' \
  '--no-analytics[disable analytics]' \
  '--http-payload-size-limit[max payload size]:size:' \
  '--log-level[log level]:level:(OFF ERROR WARN INFO DEBUG TRACE)' \
  '--max-indexing-memory[max memory for indexing]:size:' \
  '--max-indexing-threads[max threads for indexing]:threads:' \
  '--config-file-path[path to config file]:file:_files' \
  '--import-dump[import a dump file]:file:_files' \
  '--ignore-missing-dump[do not error if dump is missing]' \
  '--ignore-dump-if-db-exists[skip dump import if DB exists]' \
  '--import-snapshot[import a snapshot]:file:_files' \
  '--ignore-missing-snapshot[do not error if snapshot is missing]' \
  '--ignore-snapshot-if-db-exists[skip snapshot import if DB exists]' \
  '--schedule-snapshot[create snapshots on a schedule]' \
  '--snapshot-dir[directory for snapshots]:dir:_files -/' \
  '--ssl-auth-path[path to client authentication]:path:_files' \
  '--ssl-cert-path[path to SSL certificate]:file:_files' \
  '--ssl-key-path[path to SSL private key]:file:_files' \
  '--ssl-ocsp-path[path to OCSP file]:file:_files' \
  '--ssl-require-auth[require client auth for SSL]' \
  '--ssl-resumption[enable SSL session resumption]' \
  '--ssl-tickets[enable SSL tickets]' \
  '--dump-dir[directory for dumps]:dir:_files -/' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && return 0
