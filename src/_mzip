#compdef mzip
# Documentation: https://man.archlinux.org/search?q=mzip
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-q[status]'
  '-e[disk]'
  '-f[disk even when mounted]'
  '-r[protected (read-only)]'
  '-w[write-protected (read-write)]'
  '-p[write protected]'
  '-x[protected]'
  '-u[till disk ejecting]'
  '*:filename:_files'
)

_arguments -s -S $arguments
