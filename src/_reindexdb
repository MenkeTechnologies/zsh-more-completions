#compdef reindexdb

local -a arguments

arguments=(
  {-a,--all}'[reindex all databases]'
  {-d,--dbname}'[database to reindex]:dbname: '
  {-e,--echo}'[show the commands being sent to the server]'
  {-i,--index}'[recreate specific index(es) only]:index: '
  {-q,--quiet}'[dont write any messages]'
  {-s,--system}'[reindex system catalogs]'
  {-S,--schema}'[reindex specific schema(s) only]:schema: '
  {-t,--table}'[reindex specific table(s) only]:table: '
  {-v,--verbose}'[write a lot of output]'
  {-V,--version}'[output version information, then exit]'
  {-h,--host}'[database server host or socket directory]:host:_hosts'
  {-p,--port}'[database server port]:port: '
  {-U,--username}'[user name to connect as]:username: '
  {-w,--no-password}'[never prompt for password]'
  {-W,--password}'[force password prompt]'
  '--maintenance-db[alternate maintenance database]:dbname: '
  '*:filename:_files'
)

_arguments -s -S $arguments
