#compdef lxsession-db
# Documentation: https://man.archlinux.org/search?q=lxsession-db
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  {-m,--mode}'[specify the mode to launch (display or write)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
