#compdef sqlfluff

# Zsh completion for sqlfluff - SQL linter and formatter

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'lint:lint SQL files'
  'fix:fix SQL files'
  'parse:parse SQL files and output parse tree'
  'render:render SQL files with Jinja templating'
  'dialects:list available SQL dialects'
  'rules:list available rules'
  'version:show sqlfluff version'
)

local -a dialects=(
  ansi bigquery clickhouse databricks db2 duckdb exasol
  hive mysql oracle postgres redshift snowflake soql
  sparksql sqlite teradata tsql
)

local -a common_flags=(
  '(-d --dialect)'{-d,--dialect}'[SQL dialect]:dialect:('"${dialects[*]}"')'
  '--config[path to config file]:file:_files'
  '--exclude-rules[comma-separated list of rules to exclude]:rules'
  '--rules[comma-separated list of rules to include]:rules'
  '--ignore[comma-separated list of rules to ignore]:rules'
  '(-p --processes)'{-p,--processes}'[number of parallel processes]:number'
  '--encoding[file encoding]:encoding'
  '--disable-progress-bar[disable the progress bar]'
  '--library-path[override path for rule plugins]:path:_directories'
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]'
  '(-n --nocolor)'{-n,--nocolor}'[disable color output]'
  '(-h --help)'{-h,--help}'[show help]'
)

_arguments -s -S \
  '1:command:->command' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'sqlfluff command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (lint)
        _arguments -s -S \
          $common_flags \
          '(-f --format)'{-f,--format}'[output format]:format:(human json yaml github-annotation github-annotation-native)' \
          '--annotation-level[annotation level for github format]:level:(notice warning failure)' \
          '--nofail[always exit with zero]' \
          '--disregard-sqlfluffignores[ignore .sqlfluffignore]' \
          '--stdin-filename[filename for stdin]:name' \
          '*:file:_files' && ret=0
        ;;
      (fix)
        _arguments -s -S \
          $common_flags \
          '(-f --force)'{-f,--force}'[skip confirmation prompt]' \
          '--fixed-suffix[suffix for fixed files]:suffix' \
          '--FIX-EVEN-UNPARSABLE[attempt to fix even unparsable files]' \
          '--show-lint-violations[show lint violations]' \
          '--stdin-filename[filename for stdin]:name' \
          '*:file:_files' && ret=0
        ;;
      (parse)
        _arguments -s -S \
          $common_flags \
          '(-f --format)'{-f,--format}'[output format]:format:(human json yaml)' \
          '--profiler[enable rule profiling]' \
          '--nofail[always exit with zero]' \
          '--stdin-filename[filename for stdin]:name' \
          '*:file:_files' && ret=0
        ;;
      (render)
        _arguments -s -S \
          $common_flags \
          '(-f --format)'{-f,--format}'[output format]:format:(human json yaml)' \
          '--stdin-filename[filename for stdin]:name' \
          '*:file:_files' && ret=0
        ;;
      (*)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
