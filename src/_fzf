#compdef fzf

# Zsh completion for fzf - interactive fuzzy finder
# https://github.com/junegunn/fzf

local -a border_styles
border_styles=(rounded sharp bold block thinblock double horizontal vertical top bottom left right line none)

_arguments -s -S \
  '(-e --exact)'{-e,--exact}'[enable exact-match]' \
  '(+x --no-extended)'{+x,--no-extended}'[disable extended-search mode]' \
  '(-i --ignore-case +i --no-ignore-case --smart-case)'{-i,--ignore-case}'[case-insensitive match]' \
  '(-i --ignore-case +i --no-ignore-case --smart-case)'{+i,--no-ignore-case}'[case-sensitive match]' \
  '(-i --ignore-case +i --no-ignore-case --smart-case)--smart-case[smart-case match (default)]' \
  '--scheme=[scoring scheme]:scheme:(default path history)' \
  '--algo=[fuzzy matching algorithm]:algorithm:(v1 v2)' \
  {-n,--nth=}'[comma-separated list of field index expressions for limiting search scope]:field index expressions:' \
  '--with-nth=[transform the presentation of each line using field index expressions]:field index expressions:' \
  '--accept-nth=[define which fields to print on accept]:field index expressions:' \
  {-d,--delimiter=}'[field delimiter regex (default: AWK-style)]:delimiter:' \
  '(+s --no-sort)'{+s,--no-sort}'[do not sort the result]' \
  '--literal[do not normalize latin script letters before matching]' \
  '--tail=[maximum number of items to keep in memory]:number:' \
  '--disabled[do not perform search]' \
  '--tiebreak=[comma-separated list of sort criteria for tied scores]:criteria:(length chunk pathname begin end index)' \
  '--tac[reverse the order of the input]' \
  '--read0[read input delimited by ASCII NUL characters]' \
  '--print0[print output delimited by ASCII NUL characters]' \
  '--ansi[enable processing of ANSI color codes]' \
  '--sync[synchronous search for multi-staged filtering]' \
  '--style=[apply a style preset]:preset:' \
  '--color=[base scheme and/or custom colors]:color spec:' \
  '--no-color[disable colors]' \
  '--no-bold[do not use bold text]' \
  '--height=[display fzf window with the given height]:height:' \
  '--min-height=[minimum height when --height is given as a percentage]:min height:' \
  '--tmux=[start fzf in a tmux popup]:position and size:' \
  '--layout=[choose layout]:layout:(default reverse reverse-list)' \
  '--margin=[screen margin (TRBL | TB,RL | T,RL,B | T,R,B,L)]:margin:' \
  '--padding=[padding inside border]:padding:' \
  "--border=[draw border around the finder]:border style:(${(j: :)border_styles})" \
  '--border-label=[label to print on the border]:label:' \
  '--border-label-pos=[position of the border label]:position:' \
  {-m,--multi}'=[enable multi-select with tab/shift-tab]::max selections:' \
  '--highlight-line[highlight the whole current line]' \
  '--cycle[enable cyclic scroll]' \
  '--wrap=-[enable line wrap]::mode:(char word)' \
  '--wrap-sign=[indicator for wrapped lines]:sign:' \
  '--no-multi-line[disable multi-line display of items when using --read0]' \
  '--raw[enable raw mode (show non-matching items)]' \
  '--track[track the current selection when the result is updated]' \
  '--no-track[do not track the current selection]' \
  '--gap=-[render empty lines between each item]::number of lines:' \
  '--gap-line=-[draw horizontal line on each gap]::string:' \
  '--freeze-left=[number of fields to freeze on the left]:number:' \
  '--freeze-right=[number of fields to freeze on the right]:number:' \
  '--keep-right[keep the right end of the line visible on overflow]' \
  '--scroll-off=[number of screen lines to keep above or below]:lines:' \
  '--no-hscroll[disable horizontal scroll]' \
  '--hscroll-off=[number of screen columns to keep to the right]:columns:' \
  '--jump-labels=[label characters for jump mode]:label chars:' \
  '--gutter=[character used for the gutter column]:character:' \
  '--gutter-raw=[character used for the gutter column in raw mode]:character:' \
  '--pointer=[pointer to the current line]:pointer string:' \
  '--marker=[multi-select marker]:marker string:' \
  '--marker-multi-line=[multi-select marker for multi-line entries (3 chars)]:marker:' \
  '--ellipsis=[ellipsis to show when line is truncated]:ellipsis:' \
  '--tabstop=[number of spaces for a tab character (default: 8)]:number of spaces:' \
  '--scrollbar=-[scrollbar character(s)]::characters:' \
  '--no-scrollbar[hide scrollbar]' \
  "--list-border=-[draw border around the list section]::border style:(${(j: :)border_styles})" \
  '--list-label=[label to print on the list border]:label:' \
  '--list-label-pos=[position of the list label]:position:' \
  '--no-input[disable and hide the input section]' \
  '--prompt=[input prompt (default: "> ")]:prompt:' \
  '--info=[finder info style]:info style:(default right hidden inline inline-right)' \
  '--info-command=[command to generate info line]:command:' \
  '--separator=[draw horizontal separator on info line]:separator string:' \
  '--no-separator[hide info line separator]' \
  '--no-info[do not display finder info]' \
  '--ghost=[ghost text to display when the input is empty]:text:' \
  '--filepath-word[make word-wise movements respect path separators]' \
  "--input-border=-[draw border around the input section]::border style:(${(j: :)border_styles})" \
  '--input-label=[label to print on the input border]:label:' \
  '--input-label-pos=[position of the input label]:position:' \
  '--preview=[command to preview highlighted line ({})]:command:' \
  '--preview-window=[preview window layout]:layout:' \
  "--preview-border=-[border style for the preview window]::border style:(${(j: :)border_styles})" \
  '--preview-label=[label to print on the preview window border]:label:' \
  '--preview-label-pos=[position of the preview window label]:position:' \
  '--preview-wrap-sign=[indicator for wrapped lines in the preview window]:string:' \
  '--header=[string to print as header]:header:' \
  '--header-lines=[the first N lines of the input are treated as header]:number of lines:' \
  '--header-first[print header before the prompt line]' \
  "--header-border=-[draw border around the header section]::border style:(${(j: :)border_styles})" \
  "--header-lines-border=-[display header from --header-lines with a separate border]::border style:(${(j: :)border_styles})" \
  '--header-label=[label to print on the header border]:label:' \
  '--header-label-pos=[position of the header label]:position:' \
  '--footer=[string to print as footer]:footer:' \
  "--footer-border=-[draw border around the footer section]::border style:(${(j: :)border_styles})" \
  '--footer-label=[label to print on the footer border]:label:' \
  '--footer-label-pos=[position of the footer label]:position:' \
  {-q,--query=}'[start the finder with the given query]:query:' \
  {-1,--select-1}'[automatically select the only match]' \
  {-0,--exit-0}"[exit immediately when there's no match]" \
  {-f,--filter=}'[filter mode - do not start interactive finder]:query:' \
  '--print-query[print query as the first line]' \
  '--expect=[comma-separated list of keys to complete fzf]:keys:' \
  '--bind=[custom key/event bindings]:bindings:' \
  '--with-shell=[shell command and flags to start child processes with]:shell command:' \
  '--listen=-[start HTTP server to receive actions]::address and port:' \
  '--walker=[directory walker options]:options:(file dir follow hidden)' \
  '*--walker-root=[root directory for the walker]:directory:_directories' \
  '--walker-skip=[comma-separated list of directory names to skip]:directories:' \
  '--history=[file to store fzf search history]:history file:_files' \
  '--history-size=[maximum number of entries in history (default: 1000)]:size:' \
  '--bash[print script to set up Bash shell integration]' \
  '--zsh[print script to set up Zsh shell integration]' \
  '--fish[print script to set up Fish shell integration]' \
  '--version[display version information and exit]' \
  '(- *)--help[show help message]' \
  '(- *)--man[show man page]' \
  '*:filename:_files'
