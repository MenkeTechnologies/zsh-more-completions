#compdef vgchange

local -a arguments

arguments=(
  {-p,--maxphysicalvolumes}'[set maximum number of physical volumes]:number:'
  {-u,--uuid}'[generate new random UUID]'
  {-c,--clustered}'[set clustered attribute]:yn:(y n)'
  {-s,--physicalextentsize}'[set physical extent size]:size:'
  {-x,--resizeable}'[set resizeable attribute]:yn:(y n)'
  '--addtag[add tag]:tag:'
  '--deltag[delete tag]:tag:'
  '--alloc[set allocation policy]:policy:(anywhere contiguous cling normal)'
  '--pvmetadatacopies[number of metadata copies per PV]:copies:(0 1 2)'
  '--vgmetadatacopies[number of metadata copies per VG]:copies:'
  '--profile[use configuration profile]:profile:'
  '--detachprofile[detach metadata profile]'
  '--metadataprofile[use metadata profile]:profile:'
  '*:filename:_files'
)

_arguments -s -S $arguments
