#compdef pager

local -a arguments

arguments=(
  '-a[search skip screen]'
  '-A[search skip screen (from target line)]'
  '-b[number of buffers]:buffers'
  '-B[auto buffers]'
  '-c[clear screen]'
  '-d[dumb terminal mode]'
  '-D[color setting]:color'
  {-e,-E}'[quit at end of file]'
  '-f[force open non-regular files]'
  '-F[quit if one screen]'
  '-g[highlight only last search match]'
  '-G[no search highlighting]'
  '-h[max backward scroll]:lines'
  '-i[ignore case in searches]'
  '-I[ignore case even with uppercase pattern]'
  '-j[jump target line]:line'
  '-J[status column]'
  '-k[lesskey file]:file:_files'
  {-K,--quit-on-intr}'[exit less in response to ctrl-C]'
  '-L[no lessopen]'
  {-m,-M}'[long prompt]'
  {-n,-N}'[line numbers]'
  '-o[log file]:file:_files'
  '-O[log file (overwrite)]:file:_files'
  '-p[pattern]:pattern'
  '-P[prompt]:prompt'
  {-q,-Q}'[quiet mode]'
  {-r,-R}'[raw control chars]'
  '-s[squeeze blank lines]'
  '-S[chop long lines]'
  '-t[tag]:tag'
  '-T[tags file]:file:_files'
  {-u,-U}'[underline special]'
  '-V[version]'
  '-w[highlight first unread line]'
  '-W[highlight first unread line after movement]'
  '-x[tab stops]:tabs'
  '-X[no init]'
  '-y[max forward scroll]:lines'
  '-z[window size]:lines'
  '*:filename:_files'
)

_arguments -s -S $arguments
