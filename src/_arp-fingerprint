#compdef arp-fingerprint
# Documentation: https://man.archlinux.org/search?q=arp-fingerprint
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[this usage message.]'
  '-v[verbose progress messages.]'
  '-o[pass specified options to arp-scan]'
  '-l[all targets in the local net.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
