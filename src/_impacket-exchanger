#compdef impacket-exchanger
# Documentation: https://man.archlinux.org/search?q=impacket-exchanger
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[show this help message and exit]'
  '-debug[turn DEBUG and EXTENDED output ON]'
  '-rpc-hostname[A name of the server in GUID (preferred) or NetBIOS]'
  '-hashes[NTLM hashes, format is LMHASH:NTHASH]'
  '*:filename:_files'
)

_arguments -s -S $arguments
