#compdef nix

# Zsh completion for nix (Nix package manager next-gen CLI)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a global_opts=(
  '--debug[enable debug output]'
  '(-h --help)'{-h,--help}'[show help]'
  '(-L --print-build-logs)'{-L,--print-build-logs}'[print full build logs on stderr]'
  '--log-format[format of log output]:format:(bar bar-with-logs internal-json raw)'
  '--quiet[decrease verbosity level]'
  '(-v --verbose)'{-v,--verbose}'[increase verbosity level]'
  '--version[show version information]'
  '*--option[set a Nix configuration option]:name: :value:'
  '--no-net[disable substituters and flake fetching]'
  '--refresh[consider all previously downloaded files out-of-date]'
  '--repair[during evaluation, rewrite missing or corrupted files]'
  '--derivation[operate on the store derivation rather than its outputs]'
  '--inputs-from[use the inputs of the specified flake as registry entries]:flake-url:'
  '--override-flake-registries[override the flake registries]:url:'
  '*--override-input[override a flake input]:input-path: :flake-url:'
  '--recreate-lock-file[recreate the flake lock file from scratch]'
  '--no-registries[do not use flake registries]'
  '--no-update-lock-file[do not update the flake lock file]'
  '--no-write-lock-file[do not write the flake lock file]'
  '*--update-input[update a specific flake input]:input-path:'
  '--commit-lock-file[commit the lock file changes]'
  '--accept-flake-config[accept configuration from flakes without prompting]'
  '--no-accept-flake-config[do not accept configuration from flakes]'
)

local -a subcommands=(
  'build:build a derivation or fetch a store path'
  'develop:run a bash shell that provides the build environment of a derivation'
  'flake:manage Nix flakes'
  'profile:manage Nix profiles'
  'registry:manage the flake registry'
  'run:run a Nix application'
  'search:search for packages'
  'shell:start a shell providing specific packages'
  'store:manipulate a Nix store'
  'derivation:work with derivations'
  'doctor:check your system for potential problems'
  'edit:open the Nix expression of a package in an editor'
  'eval:evaluate a Nix expression'
  'fmt:reformat your Nix code'
  'hash:compute and convert cryptographic hashes'
  'key:manage secret keys for signing store paths'
  'log:show the build log of a derivation'
  'nar:create or inspect NAR archives'
  'path-info:query information about store paths'
  'print-dev-env:print shell code that can be sourced by bash'
  'repl:start an interactive Nix environment'
  'copy:copy paths between Nix stores'
  'upgrade-nix:upgrade Nix to the latest stable version'
  'why-depends:show why a package depends on another'
  'daemon:run the Nix daemon'
  'describe-stores:show registered store types and their parameters'
  'help:show help for a command'
)

_arguments -s -S -C \
  $global_opts \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t subcommands 'nix command' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      build)
        _arguments -s -S \
          $global_opts \
          '--out-link[path of the symlink to the build result]:path:_files' \
          '-o[path of the symlink to the build result]:path:_files' \
          '(-L --print-build-logs)'{-L,--print-build-logs}'[print full build logs on stderr]' \
          '--no-link[do not create a symlink to the build result]' \
          '--json[produce output in JSON format]' \
          '--rebuild[rebuild an already built package and compare the result]' \
          '--derivation[operate on the store derivation]' \
          '*:installable:' && ret=0
        ;;
      develop)
        _arguments -s -S \
          $global_opts \
          '--command[command to run in the shell]:command:_command_names' \
          '--phase[phase to run]:phase:' \
          '--unpack[unpack the source]' \
          '--configure[run the configure phase]' \
          '--build[run the build phase]' \
          '--check[run the check phase]' \
          '--install[run the install phase]' \
          '--installcheck[run the installcheck phase]' \
          '--redirect[redirect a store path to a mutable location]:from: :to:_directories' \
          '*:installable:' && ret=0
        ;;
      run)
        _arguments -s -S \
          $global_opts \
          '*:installable:' && ret=0
        ;;
      search)
        _arguments -s -S \
          $global_opts \
          ':installable:' \
          '*:regex:' && ret=0
        ;;
      shell)
        _arguments -s -S \
          $global_opts \
          '--command[command to run]:command:' \
          '*:installable:' && ret=0
        ;;
      eval)
        _arguments -s -S \
          $global_opts \
          '--apply[apply a function to the evaluation result]:expr:' \
          '--json[produce output in JSON format]' \
          '--raw[print strings without quoting]' \
          '--read-expression[read expression from a file]:file:_files' \
          '--write-to[write each evaluation result to a file]:path:_directories' \
          '*:installable:' && ret=0
        ;;
      log)
        _arguments -s -S \
          $global_opts \
          '*:installable:' && ret=0
        ;;
      edit)
        _arguments -s -S \
          $global_opts \
          ':installable:' && ret=0
        ;;
      copy)
        _arguments -s -S \
          $global_opts \
          '--from[URL of the source store]:store-uri:' \
          '--to[URL of the destination store]:store-uri:' \
          '--no-check-sigs[do not verify path signatures]' \
          '--all[copy the entire store]' \
          '*:installable:' && ret=0
        ;;
      path-info)
        _arguments -s -S \
          $global_opts \
          '--json[produce output in JSON format]' \
          '--sigs[show signatures]' \
          '--size[show size]' \
          '--closure-size[show closure size]' \
          '--human-readable[show sizes in human-readable format]' \
          '*:installable:' && ret=0
        ;;
      why-depends)
        _arguments -s -S \
          $global_opts \
          '--all[show all edges, not just the shortest path]' \
          '--precise[show exact dependency information]' \
          ':package:' \
          ':dependency:' && ret=0
        ;;
      print-dev-env)
        _arguments -s -S \
          $global_opts \
          '--json[produce output in JSON format]' \
          '*:installable:' && ret=0
        ;;
      fmt)
        _arguments -s -S \
          $global_opts \
          '*:file:_files' && ret=0
        ;;
      hash)
        _arguments -s -S \
          $global_opts \
          '--type[hash algorithm]:type:(md5 sha1 sha256 sha512)' \
          '--base32[print hash in base-32]' \
          '--sri[print hash in SRI format]' \
          '--to-base16[convert to base-16]' \
          '--to-base32[convert to base-32]' \
          '--to-sri[convert to SRI]' \
          '*:path:_files' && ret=0
        ;;
      repl)
        _arguments -s -S \
          $global_opts \
          '*:installable:' && ret=0
        ;;
      flake)
        local -a flake_commands=(
          'check:check whether the flake evaluates and run its tests'
          'clone:clone a flake'
          'info:show flake metadata (deprecated, use metadata)'
          'init:create a flake in the current directory'
          'lock:create missing lock file entries'
          'metadata:show flake metadata'
          'new:create a flake in a new directory'
          'prefetch:fetch a flake and print its hash'
          'show:show the outputs provided by a flake'
          'update:update flake lock file'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->flake_cmd' \
          '*::arg:->flake_args' && ret=0
        case $state in
          flake_cmd)
            _describe -t commands 'flake subcommand' flake_commands && ret=0
            ;;
          flake_args)
            case $line[1] in
              init)
                _arguments -s -S $global_opts '--template[template flake URL]:url:' && ret=0
                ;;
              new)
                _arguments -s -S $global_opts '--template[template flake URL]:url:' ':path:_directories' && ret=0
                ;;
              clone)
                _arguments -s -S $global_opts '--dest[destination directory]:dir:_directories' ':flake-url:' && ret=0
                ;;
              update)
                _arguments -s -S $global_opts '*--update-input[update a specific input]:input:' ':flake-url:' && ret=0
                ;;
              lock)
                _arguments -s -S $global_opts ':flake-url:' && ret=0
                ;;
              check|info|metadata|show|prefetch)
                _arguments -s -S $global_opts '--json[produce output in JSON format]' ':flake-url:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      profile)
        local -a profile_commands=(
          'diff-closures:show the closure difference between two profile versions'
          'history:show all versions of a profile'
          'install:install a package into a profile'
          'list:list installed packages'
          'remove:remove packages from a profile'
          'rollback:roll back to the previous version of a profile'
          'upgrade:upgrade packages in a profile'
          'wipe-history:delete non-current profile versions'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->profile_cmd' \
          '*::arg:->profile_args' && ret=0
        case $state in
          profile_cmd)
            _describe -t commands 'profile subcommand' profile_commands && ret=0
            ;;
          profile_args)
            case $line[1] in
              install)
                _arguments -s -S $global_opts '--profile[the profile to operate on]:profile:_files' '*:installable:' && ret=0
                ;;
              remove)
                _arguments -s -S $global_opts '--profile[the profile to operate on]:profile:_files' '*:package:' && ret=0
                ;;
              upgrade)
                _arguments -s -S $global_opts '--profile[the profile to operate on]:profile:_files' '*:regex:' && ret=0
                ;;
              rollback)
                _arguments -s -S $global_opts '--profile[the profile to operate on]:profile:_files' ':version:' && ret=0
                ;;
              wipe-history)
                _arguments -s -S $global_opts '--profile[the profile to operate on]:profile:_files' '--older-than[delete versions older than this]:period:' && ret=0
                ;;
              diff-closures)
                _arguments -s -S $global_opts '--profile[the profile to operate on]:profile:_files' ':version before:' ':version after:' && ret=0
                ;;
              history|list)
                _arguments -s -S $global_opts '--profile[the profile to operate on]:profile:_files' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      registry)
        local -a registry_commands=(
          'add:add a flake to the user registry'
          'list:list flake registries'
          'pin:pin a flake to its current version'
          'remove:remove a flake from the user registry'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->registry_cmd' \
          '*::arg:->registry_args' && ret=0
        case $state in
          registry_cmd)
            _describe -t commands 'registry subcommand' registry_commands && ret=0
            ;;
          registry_args)
            case $line[1] in
              add)
                _arguments -s -S $global_opts ':from:' ':to:' && ret=0
                ;;
              pin)
                _arguments -s -S $global_opts ':flake-url:' && ret=0
                ;;
              remove)
                _arguments -s -S $global_opts ':flake-url:' && ret=0
                ;;
              list)
                _arguments -s -S $global_opts && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      store)
        local -a store_commands=(
          'add-file:add a file to the Nix store'
          'add-path:add a path to the Nix store'
          'cat:print the contents of a file in the Nix store'
          'copy-log:copy build logs between stores'
          'delete:delete paths from the Nix store'
          'diff-closures:show the closure difference between two store paths'
          'dump-path:dump a store path to stdout in NAR format'
          'gc:perform garbage collection on the Nix store'
          'info:show information about the Nix store'
          'ls:list a directory in the Nix store'
          'make-content-addressed:rewrite a path to be content-addressed'
          'optimise:optimise the Nix store by hard-linking identical files'
          'path-from-hash-part:get a store path from its hash part'
          'path-info:show information about store paths'
          'ping:test whether a store can be accessed'
          'prefetch-file:download a file into the Nix store'
          'realise:realise the given store paths'
          'repair:repair store paths'
          'sign:sign store paths'
          'verify:verify the integrity of store paths'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->store_cmd' \
          '*::arg:->store_args' && ret=0
        case $state in
          store_cmd)
            _describe -t commands 'store subcommand' store_commands && ret=0
            ;;
          store_args)
            case $line[1] in
              gc)
                _arguments -s -S $global_opts '--max[maximum bytes to free]:bytes:' && ret=0
                ;;
              sign)
                _arguments -s -S $global_opts '--key-file[path to the secret key]:file:_files' '*:store path:' && ret=0
                ;;
              verify)
                _arguments -s -S $global_opts '--sigs-needed[require this many valid signatures]:num:' '--no-contents[do not verify the contents]' '--no-trust[do not use trusted substituters]' '*:store path:' && ret=0
                ;;
              delete)
                _arguments -s -S $global_opts '--ignore-liveness[do not check whether paths are roots]' '*:store path:' && ret=0
                ;;
              ls)
                _arguments -s -S $global_opts '--long[show detailed info]' '--json[produce output in JSON format]' '-R[list recursively]' '--recursive[list recursively]' ':store path:' && ret=0
                ;;
              cat)
                _arguments -s -S $global_opts ':store path:' && ret=0
                ;;
              prefetch-file)
                _arguments -s -S $global_opts '--hash-type[hash algorithm]:type:(sha256 sha512)' '--unpack[unpack the file]' ':url:' && ret=0
                ;;
              add-file|add-path)
                _arguments -s -S $global_opts ':path:_files' && ret=0
                ;;
              *)
                _arguments -s -S $global_opts '*:store path:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      key)
        _arguments -s -S \
          $global_opts \
          '1:action:(generate-secret convert-secret-to-public)' \
          '*:key file:_files' && ret=0
        ;;
      nar)
        _arguments -s -S \
          $global_opts \
          '1:action:(cat dump-path ls)' \
          '*:path:_files' && ret=0
        ;;
      doctor|daemon|describe-stores|upgrade-nix)
        _arguments -s -S $global_opts && ret=0
        ;;
      help)
        _arguments -s -S '1:command:(build develop flake profile registry run search shell store derivation doctor edit eval fmt hash key log nar path-info print-dev-env repl copy upgrade-nix why-depends daemon describe-stores)' && ret=0
        ;;
    esac
    ;;
esac

return ret
