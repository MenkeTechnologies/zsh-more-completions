#compdef split

# Completion for split - split a file into pieces
# Supports both BSD (macOS) and GNU coreutils options

local arguments

arguments=(
  {-a,--suffix-length}'[generate suffixes of length N (default 2)]:suffix length'
  '--additional-suffix=[append an additional SUFFIX to file names]:suffix'
  {-b,--bytes}'[put SIZE bytes per output file]:size (e.g. 10K, 5M, 1G)'
  {-C,--line-bytes}'[put at most SIZE bytes of records per output file]:size'
  '-c[continue creating files, do not overwrite existing output]'
  '-d[use numeric suffixes starting at 0, not alphabetic]'
  '--numeric-suffixes=-[same as -d, but allow setting the start value]::start value'
  '-x[use hex suffixes starting at 0, not alphabetic]'
  '--hex-suffixes=-[same as -x, but allow setting the start value]::start value'
  {-e,--elide-empty-files}'[do not generate empty output files with -n]'
  '--filter=[write to shell COMMAND; file name is $FILE]:command:_command_names -e'
  {-l,--lines}'[put NUMBER lines/records per output file]:number of lines'
  {-n,--number}'[generate CHUNKS output files]:chunks (N, K/N, l/N, l/K/N, r/N, r/K/N)'
  '-p[split whenever input line matches pattern]:pattern'
  {-t,--separator}'[use SEP instead of newline as the record separator]:separator'
  {-u,--unbuffered}'[immediately copy input to output with -n r/...]'
  '--verbose[print a diagnostic just before each output file is opened]'
  '--help[display help and exit]'
  '--version[output version information and exit]'
  '1:input file:_files'
  '2:output prefix'
)

_arguments -s -S $arguments
