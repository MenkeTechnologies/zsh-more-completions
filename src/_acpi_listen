#compdef acpi_listen

local -a arguments

arguments=(
  {-c,--count}'[set the maximum number of events]:count: '
  {-s,--socketfile}'[use the specified socket file]:socket file:_files'
  {-t,--time}'[listen for the specified time (in seconds)]:seconds: '
  {-v,--version}'[print version information]'
  '(- * :)'{-h,--help}'[print this message]'
)

_arguments -s -S $arguments
