#compdef ov

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-d --delimiter)'{-d,--delimiter}'[column delimiter]:delimiter' \
  '(-H --header)'{-H,--header}'[number of header lines]:lines' \
  '(-w --wrap)'{-w,--wrap}'[enable line wrapping]' \
  '--skip-lines[number of lines to skip]:lines' \
  '(-t --tab-width)'{-t,--tab-width}'[tab width]:width' \
  '(-n --line-number)'{-n,--line-number}'[show line numbers]' \
  '(-F --follow-mode)'{-F,--follow-mode}'[follow mode]' \
  '(-A --follow-all)'{-A,--follow-all}'[follow all mode]' \
  '--follow-name[follow by file name]' \
  '--section-delimiter[section delimiter]:delimiter' \
  '--section-header[treat section delimiter as header]' \
  '--exec[execute command]:command' \
  '--multi-color[enable multi-color highlight]:colors' \
  '--jump-target[jump target line]:line' \
  '--quit-if-one-screen[quit if content fits one screen]' \
  '(-X --exit-write)'{-X,--exit-write}'[write to terminal on exit]' \
  '(-C --column-mode)'{-C,--column-mode}'[enable column mode]' \
  '--column-delimiter[column delimiter character]:delimiter' \
  '--column-rainbow[enable column rainbow coloring]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:file:_files' && ret=0
return ret
