#compdef bombardier

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--version[show version]' \
  '-c+[maximum number of concurrent connections]:connections' \
  '--connections=[maximum number of concurrent connections]:connections' \
  '-d+[duration of test]:duration' \
  '--duration=[duration of test]:duration' \
  '-n+[number of requests]:requests' \
  '--requests=[number of requests]:requests' \
  '-r+[rate limit (requests per second)]:rate' \
  '--rate=[rate limit (requests per second)]:rate' \
  '-t+[timeout per request]:timeout' \
  '--timeout=[timeout per request]:timeout' \
  '-m+[HTTP method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
  '--method=[HTTP method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
  '-b+[request body]:body' \
  '--body=[request body]:body' \
  '-f+[path to file to use as body]:body file:_files' \
  '--body-file=[path to file to use as body]:body file:_files' \
  '*-H+[HTTP header]:header' \
  '*--header=[HTTP header]:header' \
  '-k[disable TLS certificate verification]' \
  '--insecure[disable TLS certificate verification]' \
  '-l[print latency statistics]' \
  '--latencies[print latency statistics]' \
  '-p[print real-time progress bar]' \
  '--print=[output type]:format:(result intro req)' \
  '-o+[output format]:format:(plain-text json)' \
  '--format=[output format]:format:(plain-text json)' \
  '--http1[force HTTP/1.1]' \
  '--http2[force HTTP/2]' \
  '-q[suppress output]' \
  '--no-print[suppress output]' \
  '1:url' && ret=0

return ret
