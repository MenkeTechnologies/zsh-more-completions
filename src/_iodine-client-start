#compdef iodine-client-start
# Documentation: https://man.archlinux.org/search?q=iodine-client-start
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[print help and exit]'
  {-v,--version}'[print version info and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
