#compdef repotrack

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-c,--config}'[config file to use (defaults to /etc/yum.conf)]'
  {-a,--arch}'[check as if running the specified arch]:arch: '
  {-r,--repoid}'[specify repo ids to query, can be specified multiple times]:repoid: '
  {-t,--tempcache}'[use a temp dir for storing/accessing yum-cache]'
  {-p,--download_path}'[path to download packages to]:destdir:_directories'
  {-u,--urls}'[just list urls of what would be downloaded, dont]'
  {-n,--newest}'[toggle downloading only the newest packages]'
  {-q,--quiet}'[output as little as possible]'
  '*:filename:_files'
)

_arguments -s -S $arguments
