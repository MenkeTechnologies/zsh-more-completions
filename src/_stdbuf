#compdef stdbuf gstdbuf

# stdbuf - run a command with modified buffering operations for its standard streams
# Part of GNU coreutils

local -a modes
modes=('L:line buffered' '0:unbuffered')

_arguments -s -S \
  {-i,--input=}'[adjust standard input stream buffering]:mode:(0 L)' \
  {-o,--output=}'[adjust standard output stream buffering]:mode:(0 L)' \
  {-e,--error=}'[adjust standard error stream buffering]:mode:(0 L)' \
  '(- *)--help[display help text and exit]' \
  '(- *)--version[output version information and exit]' \
  '(-):command:_command_names -e' \
  '*::arguments:_normal'
