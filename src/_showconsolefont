#compdef showconsolefont
# Documentation: https://man.archlinux.org/search?q=showconsolefont
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-V,--version}'[print version number and exit.]'
  '-C[device to read the font from. Default: current tty.]'
  '-v[be more verbose.]'
  '-i[dont print out the font table, just show]'
  '*:filename:_files'
)

_arguments -s -S $arguments
