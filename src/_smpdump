#compdef smpdump


local -a arguments

arguments=(
    {-s,--string}'[Print strings in packet if possible.]'
    '-d[raise the IB debugging level. May be used several times (-ddd or -d -d -d).]'
    '-e[show send and receive errors (timeouts and others).]'
    {-v,--verbose}'[increase the application verbosity level.]'
    {-D,--Direct}'[Examples: \[options\] -D \[options\] "0" # self port \[options\] -D]'
    {-L,--Lid}'[Port Selection flags.]'
    {-C,--Ca}''
    {-P,--Port}'[Local port Selection.]'
    {-h,--help}''
    {-V,--version}'[Configuration flags.]'
    {-t,--timeout}''
    {--config,-z}'[Default: /etc/infiniband-diags/ibdiag. conf]'
    '*:filename:_files'
)
_arguments -s -S $arguments
