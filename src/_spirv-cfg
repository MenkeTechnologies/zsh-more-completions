#compdef spirv-cfg
# Documentation: https://man.archlinux.org/search?q=spirv-cfg
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[print this help.]'
  '--version[display version information.]'
  '-o[set the output filename.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
