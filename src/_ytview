#compdef ytview
# Documentation: https://man.archlinux.org/search?q=ytview
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-s[searches youtube]'
  '-c[shows the latest videos of a channel]'
  '-u[update Bash-Snippet Tools]'
  '-h[show the help]'
  '-v[get the tool version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
