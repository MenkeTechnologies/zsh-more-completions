#compdef k3d

# Zsh completion for k3d (k3s in Docker)

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'cluster:Manage cluster(s)'
  'completion:Generate completion scripts'
  'config:Work with config file(s)'
  'image:Handle container images'
  'kubeconfig:Manage kubeconfig(s)'
  'node:Manage node(s)'
  'registry:Manage registry/registries'
  'runtime-info:Show runtime information'
  'version:Show k3d and default k3s version'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[Help for k3d]' \
  '--timestamps[Enable log timestamps]' \
  '--trace[Enable super verbose output (trace logging)]' \
  '--verbose[Enable verbose output (debug logging)]' \
  '--version[Show k3d and default k3s version]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'k3d command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      cluster)
        local -a cluster_cmds
        cluster_cmds=(
          'create:Create a new cluster'
          'delete:Delete cluster(s)'
          'edit:Edit cluster(s)'
          'list:List cluster(s)'
          'start:Start existing k3d cluster(s)'
          'stop:Stop existing k3d cluster(s)'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd)
            _describe -t cluster_cmds 'cluster subcommand' cluster_cmds && ret=0
            ;;
          subargs)
            case "${line[1]}" in
              create)
                _arguments \
                  '1:name:' \
                  '--agents=[Specify how many agent nodes you want]:count:' \
                  {-c,--config}'=[Path to a k3d config file]:file:_files' \
                  {-e,--env}'=[Add environment variables to nodes]:env:' \
                  '--gpus=[GPU devices to add to the cluster node containers]:gpus:' \
                  {-i,--image}'=[Specify k3s image]:image:' \
                  '--k3s-arg=[Additional args passed to k3s command]:arg:' \
                  '--kubeconfig-switch-context[Switch current-context to new cluster]' \
                  '--kubeconfig-update-default[Update default kubeconfig with new cluster]' \
                  '--network=[Join an existing network]:network:' \
                  '--no-image-volume[Disable image volume for cluster]' \
                  '--no-lb[Disable load balancer in front of server nodes]' \
                  '--no-rollback[Disable rollback of changes on error]' \
                  {-p,--port}'=[Map ports from the node containers to the host]:port:' \
                  '--registry-config=[Specify registries config file]:file:_files' \
                  '--registry-create=[Create a k3d registry]' \
                  '--registry-use=[Use an existing k3d registry]:registry:' \
                  '--runtime-label=[Add label to container runtime]:label:' \
                  {-s,--servers}'=[Specify how many server nodes you want]:count:' \
                  '--servers-memory=[Set memory limit for server nodes]:memory:' \
                  '--subnet=[Define a subnet for the cluster]:subnet:' \
                  '--timeout=[Rollback if cluster creation exceeds timeout]:duration:' \
                  '--token=[Specify a cluster token]:token:' \
                  {-v,--volume}'=[Mount volumes into the nodes]:volume:' \
                  '--wait[Wait for control plane node to be ready]' && ret=0
                ;;
              delete)
                _arguments \
                  '1:name:' \
                  {-a,--all}'[Delete all clusters]' \
                  {-c,--config}'=[Path to config file]:file:_files' && ret=0
                ;;
              list)
                _arguments \
                  '--no-headers[Disable headers]' \
                  {-o,--output}'=[Output format]:format:(json yaml)' \
                  '--token[Show cluster token]' && ret=0
                ;;
              start|stop)
                _arguments \
                  '1:name:' \
                  {-a,--all}'[Start/Stop all clusters]' \
                  '--wait[Wait for the cluster to start]' && ret=0
                ;;
              edit)
                _arguments \
                  '1:name:' \
                  '--port-add=[Map an additional port]:port:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      image)
        local -a image_cmds
        image_cmds=(
          'import:Import image(s) from docker into k3d cluster(s)'
          'list:List images in a k3d cluster'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t image_cmds 'image subcommand' image_cmds && ret=0 ;;
          subargs)
            case "${line[1]}" in
              import)
                _arguments \
                  {-c,--cluster}'=[Select clusters to import into]:cluster:' \
                  {-k,--keep-tarball}'[Do not delete tar after import]' \
                  {-t,--keep-tools}'[Do not delete tools node after import]' \
                  '*:image:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      kubeconfig)
        local -a kc_cmds
        kc_cmds=(
          'get:Print kubeconfig(s) from cluster(s)'
          'merge:Write/merge kubeconfig(s) from cluster(s) into new or existing file'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t kc_cmds 'kubeconfig subcommand' kc_cmds && ret=0 ;;
        esac
        ;;
      node)
        local -a node_cmds
        node_cmds=(
          'create:Create new node(s)'
          'delete:Delete node(s)'
          'edit:Edit node(s)'
          'list:List node(s)'
          'start:Start existing node(s)'
          'stop:Stop existing node(s)'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t node_cmds 'node subcommand' node_cmds && ret=0 ;;
        esac
        ;;
      registry)
        local -a reg_cmds
        reg_cmds=(
          'create:Create a new registry'
          'delete:Delete registry/registries'
          'list:List registries'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t reg_cmds 'registry subcommand' reg_cmds && ret=0 ;;
        esac
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
