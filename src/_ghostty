#compdef ghostty

# Zsh completion for ghostty (fast terminal emulator)

local curcontext="$curcontext" state line ret=1

local -a ghostty_commands
ghostty_commands=(
  '+list-fonts:list available fonts'
  '+list-keybinds:list current keybindings'
  '+list-themes:list available color themes'
  '+list-colors:list terminal color names'
  '+list-actions:list available keybinding actions'
  '+show-config:show the current configuration'
  '+validate-config:validate the configuration file'
  '+crash-report:show the last crash report'
  '+version:show the version'
)

_arguments -s -S \
  '--help[show help message]' \
  '--version[show version information]' \
  '-h[show help message]' \
  '-e[command to run]:command:_cmdstring' \
  '--class=[set the window class]:class:' \
  '--title=[set the window title]:title:' \
  '--working-directory=[set the working directory]:directory:_directories' \
  '--config-file=[path to configuration file]:config:_files' \
  '--config-default-files=[load default configuration files]:bool:(true false)' \
  '--wait-after-command=[wait after command exits]:bool:(true false)' \
  '--font-family=[set the font family]:font family:' \
  '--font-size=[set the font size]:size:' \
  '--font-style=[set the font style]:style:' \
  '--font-style-bold=[set the bold font style]:style:' \
  '--font-style-italic=[set the italic font style]:style:' \
  '--font-style-bold-italic=[set the bold italic font style]:style:' \
  '--font-variation=[set a font variation]:axis=value:' \
  '--font-feature=[set a font feature]:feature:' \
  '--font-codepoint-map=[map codepoints to specific fonts]:map:' \
  '--font-thicken=[thicken font strokes]:bool:(true false)' \
  '--adjust-cell-width=[adjust cell width]:adjustment:' \
  '--adjust-cell-height=[adjust cell height]:adjustment:' \
  '--adjust-font-baseline=[adjust font baseline]:adjustment:' \
  '--adjust-underline-position=[adjust underline position]:adjustment:' \
  '--adjust-underline-thickness=[adjust underline thickness]:adjustment:' \
  '--adjust-strikethrough-position=[adjust strikethrough position]:adjustment:' \
  '--adjust-strikethrough-thickness=[adjust strikethrough thickness]:adjustment:' \
  '--adjust-overline-position=[adjust overline position]:adjustment:' \
  '--adjust-overline-thickness=[adjust overline thickness]:adjustment:' \
  '--grapheme-width-method=[method for calculating grapheme width]:method:(legacy unicode)' \
  '--theme=[set the color theme]:theme:' \
  '--background=[set the background color]:color:' \
  '--foreground=[set the foreground color]:color:' \
  '--selection-foreground=[set the selection foreground color]:color:' \
  '--selection-background=[set the selection background color]:color:' \
  '--cursor-color=[set the cursor color]:color:' \
  '--cursor-style=[set the cursor style]:style:(block bar underline)' \
  '--cursor-style-blink=[enable cursor blinking]:bool:(true false)' \
  '--cursor-text=[set the cursor text color]:color:' \
  '--cursor-opacity=[set cursor opacity]:opacity:' \
  '--mouse-hide-while-typing=[hide mouse while typing]:bool:(true false)' \
  '--mouse-scroll-multiplier=[set mouse scroll multiplier]:multiplier:' \
  '--background-opacity=[set background opacity]:opacity:' \
  '--background-blur-radius=[set background blur radius]:radius:' \
  '--unfocused-split-opacity=[opacity of unfocused splits]:opacity:' \
  '--minimum-contrast=[set minimum contrast ratio]:ratio:' \
  '--palette=[set a color palette entry]:index=color:' \
  '--bold-is-bright=[use bright colors for bold]:bool:(true false)' \
  '--window-padding-x=[set horizontal window padding]:padding:' \
  '--window-padding-y=[set vertical window padding]:padding:' \
  '--window-padding-balance=[balance padding across window]:bool:(true false)' \
  '--window-padding-color=[set padding area color]:color:(background extend)' \
  '--window-inherit-font-size=[inherit font size from parent]:bool:(true false)' \
  '--window-inherit-working-directory=[inherit cwd from parent]:bool:(true false)' \
  '--window-decoration=[show window decorations]:bool:(true false)' \
  '--window-theme=[set the window theme]:theme:(auto system light dark ghostty)' \
  '--window-colorspace=[set the window colorspace]:colorspace:(srgb display-p3)' \
  '--window-save-state=[save/restore window state]:mode:(default never always)' \
  '--clipboard-read=[allow reading from clipboard]:mode:(allow deny ask)' \
  '--clipboard-write=[allow writing to clipboard]:mode:(allow deny ask)' \
  '--clipboard-trim-trailing-spaces=[trim trailing spaces on copy]:bool:(true false)' \
  '--clipboard-paste-protection=[confirm pasting with escape sequences]:bool:(true false)' \
  '--clipboard-paste-bracketed-safe=[use safe paste bracketing]:bool:(true false)' \
  '--copy-on-select=[copy on text selection]:mode:(true false clipboard)' \
  '--click-repeat-interval=[click repeat interval in ms]:interval:' \
  '--initial-window=[set initial window size]:size:' \
  '--confirm-close-surface=[confirm before closing]:bool:(true false)' \
  '--quit-after-last-window-closed=[quit when last window closes]:bool:(true false)' \
  '--shell-integration=[shell integration mode]:mode:(none detect bash elvish fish zsh)' \
  '--shell-integration-features=[features to enable]:features:' \
  '--osc-color-report-format=[format for color reports]:format:(none 8-bit 16-bit)' \
  '--scrollback-limit=[set scrollback buffer size]:lines:' \
  '--link-url=[enable URL detection]:bool:(true false)' \
  '--fullscreen=[start in fullscreen]:bool:(true false)' \
  '--keybind=[set a keybinding]:binding:' \
  '--macos-option-as-alt=[use option as alt on macOS]:mode:(true false left right)' \
  '--gtk-single-instance=[use single GTK instance]:mode:(true false desktop)' \
  '--gtk-tabs-location=[location of tabs]:position:(top bottom left right hidden)' \
  '--gtk-wide-tabs=[use wide tabs]:bool:(true false)' \
  '--gtk-adwaita=[use Adwaita theme]:bool:(true false)' \
  '--desktop-notifications=[enable desktop notifications]:bool:(true false)' \
  '--auto-update=[check for updates]:mode:(off check download)' \
  '1:command:_describe -t commands command ghostty_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      +list-fonts)
        _arguments -s -S \
          '--family=[filter by font family]:family:' \
          '--style=[filter by font style]:style:' \
          '--bold[filter bold fonts]' \
          '--italic[filter italic fonts]' && ret=0
        ;;
      +list-themes)
        _arguments -s -S \
          '--plain[plain output without preview]' && ret=0
        ;;
      +show-config)
        _arguments -s -S \
          '--default[show default configuration]' \
          '--changes-only[only show changed values]' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
