#compdef fig4latex
# Documentation: https://man.archlinux.org/search?q=fig4latex
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-d[directory containing the figures (a path relative to]'
  '-m[magnification factor.]'
  {-p,--}'[makefile for use with pdflatex -- the images]'
  {-l,--}'[makefile for use with (regular) latex -- the images]'
  {-h,--}'[this message and quit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
