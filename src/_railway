#compdef railway

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add:add a service to your project'
  'completion:generate shell completions'
  'connect:connect to a database service'
  'deploy:deploy a directory to Railway'
  'docs:open Railway documentation'
  'domain:add a custom domain or generate a Railway domain'
  'down:remove the most recent deployment'
  'environment:change the active environment'
  'init:create a new Railway project'
  'link:associate existing project with current directory'
  'list:list all projects'
  'login:login to your Railway account'
  'logout:logout of your Railway account'
  'logs:view logs from the most recent deployment'
  'open:open your project dashboard'
  'run:run a local command with Railway variables'
  'service:link a service to the current project'
  'shell:open a subshell with Railway variables'
  'status:show the status of your Railway project'
  'unlink:disassociate project from current directory'
  'up:deploy a directory to Railway'
  'variables:view or manage Railway variables'
  'volume:manage project volumes'
  'whoami:get the current logged in user'
  'redeploy:redeploy the latest deployment'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--json[output in JSON format]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'railway command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (up|deploy)
        _arguments -s -S \
          '(-d --detach)'{-d,--detach}'[detach from cloud build/deploy]' \
          '(-e --environment)'{-e,--environment}'=[environment to deploy to]:environment' \
          '(-s --service)'{-s,--service}'=[service to deploy to]:service' \
          '--no-gitignore[do not use .gitignore]' \
          '1:path:_directories' && ret=0
        ;;
      (run)
        _arguments -s -S \
          '(-e --environment)'{-e,--environment}'=[environment to use]:environment' \
          '(-s --service)'{-s,--service}'=[service to use]:service' \
          '*:command' && ret=0
        ;;
      (logs)
        _arguments -s -S \
          '(-d --deployment)'{-d,--deployment}'[show deployment logs]' \
          '(-b --build)'{-b,--build}'[show build logs]' \
          '(-n --num)'{-n,--num}'=[number of lines]:lines' \
          '(-f --follow)'{-f,--follow}'[follow log output]' && ret=0
        ;;
      (variables)
        local -a var_cmds=(
          'get:get the value of a variable'
          'set:create or update a variable'
          'delete:delete a variable'
        )
        _arguments \
          '1:subcommand:_describe -t var-commands "variables command" var_cmds' \
          '*:args' && ret=0
        ;;
      (link)
        _arguments -s -S \
          '(-p --project)'{-p,--project}'=[project ID]:project id' \
          '(-e --environment)'{-e,--environment}'=[environment]:environment' \
          '(-s --service)'{-s,--service}'=[service]:service' && ret=0
        ;;
      (volume)
        local -a vol_cmds=(
          'add:add a volume to a service'
          'delete:delete a volume'
          'list:list volumes'
          'detach:detach a volume from a service'
        )
        _arguments \
          '1:subcommand:_describe -t vol-commands "volume command" vol_cmds' \
          '*:args' && ret=0
        ;;
    esac
    ;;
esac

return ret
