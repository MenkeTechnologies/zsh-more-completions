#compdef busctl

_busctl_commands() {
  local -a commands=(
    'list:show all peers on the bus by their service names'
    'status:display process information and credentials of a service'
    'monitor:dump messages being exchanged on the bus'
    'capture:capture messages in pcapng format'
    'tree:show object tree of one or more services'
    'introspect:reveal interfaces, methods, properties and signals'
    'call:invoke a method and show the response'
    'emit:emit a signal'
    'wait:wait for a signal from the bus'
    'get-property:retrieve the current value of object properties'
    'set-property:modify the value of an object property'
    'help:display command syntax help'
  )
  _describe -t commands 'busctl command' commands
}

_busctl() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a options=(
    '(- *)'{-h,--help}'[show help text]'
    '(- *)--version[show package version]'
    '--no-pager[do not pipe output into a pager]'
    '--no-legend[do not show column headers and footer]'
    '--json=[format output as JSON]:mode:(short pretty off)'
    '-j[pretty JSON on terminals, compact otherwise]'
    '(--user)--system[connect to the system bus]'
    '(--system)--user[connect to the user service manager bus]'
    {-H,--host=}'[operate on remote host via SSH]:[user@]host:_hosts'
    {-M,--machine=}'[operate on local container]:machine'
    {-C,--capsule=}'[operate on specified capsule]:capsule'
    '--address=[connect to bus specified by address]:address'
    '--show-machine[show machine ID column in list]'
    '--unique[only show unique names]'
    '--acquired[only show acquired names]'
    '--activatable[only show activatable names]'
    '--match=[filter messages by match criteria]:match'
    '--size=[set maximum message capture size]:bytes'
    '--list[show simple object path list instead of tree]'
    {-q,--quiet}'[suppress response message output]'
    '--verbose[show result values in long format]'
    '--xml-interface[output raw XML from introspection calls]'
    '--expect-reply=[specify whether to await method completion]:bool:(yes no)'
    '--auto-start=[enable implicit service activation]:bool:(yes no)'
    '--allow-interactive-authorization=[allow interactive authorization]:bool:(yes no)'
    '--timeout=[maximum time to wait for method call completion]:seconds'
    '--limit-messages=[exit after receiving specified message count]:number'
    '-N+[exit after receiving specified message count (alias for --limit-messages)]:number'
    '--augment-creds=[extend credential data with data from /proc/$PID]:bool:(yes no)'
    '--watch-bind=[wait for AF_UNIX bus socket to appear]:bool:(yes no)'
    '--destination=[specify signal destination service]:service'
    {-l,--full}'[do not ellipsize output in list mode]'
  )

  _arguments -s -S : \
    $options \
    '1:command:_busctl_commands' \
    '*:arguments'
}

_busctl "$@"
