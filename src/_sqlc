#compdef sqlc

# Zsh completion for sqlc (compile SQL to type-safe code)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'compile:statically check SQL for syntax and type errors'
  'completion:generate shell completion'
  'createdb:create a database'
  'diff:compare generated code to existing'
  'generate:generate source code from SQL'
  'init:create an empty sqlc.yaml file'
  'push:push the schema to the sqlc cloud'
  'verify:verify schema and queries'
  'version:print the sqlc version'
  'vet:vet SQL queries'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --file)'{-f,--file}'[config file]:file:_files -g "*.yaml *.yml *.json"' \
  '--no-remote[disable remote plugins]' \
  '--experimental[enable experimental features]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'sqlc command' commands && ret=0
    ;;
esac

return ret
