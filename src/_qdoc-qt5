#compdef qdoc-qt5

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[displays help on commandline options.]'
  '--help-all[displays help including Qt specific options]'
  {-v,--version}'[displays version information]'
  '-D[define the argument as a macro while parsing sources]'
  '--depends[specify dependent modules]'
  '--highlighting[turn on syntax highlighting (makes qdoc run slower)]'
  '--showinternal[include content marked internal]'
  '--redirect-documentation-to-dev-null[save all documentation content to /dev/null]'
  '--no-examples[do not generate documentation for examples]'
  '--indexdir[specify a directory where QDoc should search for index files]'
  '--installdir[specify the directory where the output should be installed]'
  '--obsoletelinks[report links from obsolete items to non-obsolete items]'
  '--outputdir[specify output directory, overrides configuration]'
  '--outputformat[specify output format, overrides configuration]'
  '--no-link-errors[do not print link errors (i.e. missing targets)]'
  '--autolink-errors[show errors when automatic linking fails]'
  '--debug[enable debug output]'
  '--prepare[run qdoc only to generate an index file]'
  '--generate[run qdoc to read the index files and generate documentation]'
  '--log-progress[log progress on stderr]'
  '--single-exec[run qdoc once over all the qdoc conf files]'
  '--write-qa-pages[write QA pages]'
  '-I[add dir to the include path for header files]'
  '--isystem[add dir to the system include path for header files]'
  '-F[add macOS framework to the include path]'
  '--timestamps[timestamp each qdoc log line.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
