#compdef autopsy
# Documentation: https://man.archlinux.org/search?q=autopsy
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-c[force a cookie in the URL]'
  '-C[force NO cookie in the URL]'
  '-d[specify the evidence locker directory]'
  '-i[filesystem mnt: Specify info for live analysis]'
  '-p[specify the server port (default: 9999)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
