#compdef upx

local -a arguments

arguments=(
  '-1[compress faster]'
  '-9[compress better]'
  '--best[best compression (can be slow for big files)]'
  '-d[decompress]'
  '-l[list compressed file]'
  '-t[test compressed file]'
  '-V[display version number]'
  '-h[give this help]'
  '-L[display software license]'
  '-q[be quiet]'
  '-v[be verbose]'
  '-o[output to file]:file:_files'
  '-f[force compression of suspicious files]'
  {--no-color,--mono,--color,--no-progress}'[change look]'
  '--brute[try all available compression methods & filters \[slow\]]'
  '--ultra-brute[try even more compression variants \[very slow\]]'
  {-k,--backup}'[keep backup files]'
  '--no-backup[no backup files \[default\]]'
  '--overlay[handle overlay data]:action:(copy strip skip)'
  '--coff[produce COFF output \[default: EXE\]]'
  '--8086[make compressed binary work on any 8086]'
  '--no-reloc[put no relocations in to the exe header]'
  '--8-bit[uses 8 bit size compression \[default: 32 bit\]]'
  '--8mib-ram[8 megabyte memory limit \[default: 2 MiB\]]'
  '--boot-only[disables client/host transfer compatibility]'
  '--no-align[dont align to 2048 bytes \[enables: --console-run\]]'
  '--le[produce LE output \[default: EXE\]]'
  '--compress-exports[compress the export section]:bool:(0 1)'
  '--compress-icons[compress icons]:level:(0 1 2 3)'
  '--compress-resources[compress resources]:bool:(0 1)'
  '--keep-resource[do not compress resources specified by list]'
  '--strip-relocs[strip relocations]:bool:(0 1)'
  '--preserve-build-id[copy .gnu.note.build-id to compressed output]'
  '*:filename:_files'
)

_arguments -s -S $arguments
