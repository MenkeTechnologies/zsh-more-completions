#compdef lsmem

local arguments

arguments=(
  {-a,--all}'[list each individual memory block]'
  {-b,--bytes}'[print sizes in bytes rather than in human readable format]'
  {-J,--json}'[use JSON output format]'
  {-n,--noheadings}'[do not print a header line]'
  {-o,--output}'[specify which columns to display]:list'
  '--output-all[display all available columns]'
  {-P,--pairs}'[produce output in the form of key="value" pairs]'
  {-r,--raw}'[produce output in raw format]'
  {-S,--split}'[specify which columns are used to split memory blocks into ranges]:list'
  {-s,--sysroot}'[gather memory data for a Linux instance other than the current one]:directory:_directories'
  '--summary[control summary output]:when:(never always only)'
  '(- * :)'{-h,--help}'[display help text and exit]'
  '(- * :)'{-V,--version}'[display version information and exit]'
)

_arguments -s $arguments
