#compdef semantic-release

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-b --branches)'{-b,--branches}'=[git branches to release from]:branches' \
  '--repository-url=[git repository URL]:url' \
  '(-t --tag-format)'{-t,--tag-format}'=[git tag format]:format' \
  '(-p --plugins)'{-p,--plugins}'=[list of plugins]:plugins' \
  '(-e --extends)'{-e,--extends}'=[shareable config to extend]:config' \
  '--no-ci[skip CI environment verifications]' \
  '--verify-conditions=[plugins to verify release conditions]:plugins' \
  '--analyze-commits=[plugin to analyze commits]:plugin' \
  '--verify-release=[plugins to verify release]:plugins' \
  '--generate-notes=[plugin to generate release notes]:plugin' \
  '--prepare=[plugins for prepare step]:plugins' \
  '--publish=[plugins for publish step]:plugins' \
  '--success=[plugins for success step]:plugins' \
  '--fail=[plugins for fail step]:plugins' \
  '(-d --dry-run)'{-d,--dry-run}'[skip publishing, only log steps]' \
  '--debug[output debug logs]' && ret=0

return ret
