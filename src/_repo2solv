#compdef repo2solv

local -a arguments

arguments=(
  '-h[print help & exit]'
  '-o[.solv>: write to this file instead of stdout]'
  '-F[add filelist]'
  '-R[also search subdirectories for rpms]'
  '-X[generate pattern/product pseudo packages]'
  '-A[add appdata packages]'
  '*:filename:_files'
)

_arguments -s -S $arguments
