#compdef candump

local -a arguments

arguments=(
  '-t[timestamp mode]:mode:((a\:absolute d\:delta z\:zero A\:absolute-with-date))'
  '-H[read hardware timestamps instead of system timestamps]'
  '-c[increment color mode level]'
  '-i[binary output - may exceed 80 chars/line]'
  '-a[enable additional ASCII output]'
  '-S[swap byte order in printed CAN data]'
  '-s[silent mode]:level:((0\:off 1\:animation 2\:silent))'
  '-b[bridge mode - send received frames to interface]:can:'
  '-B[bridge mode - like -b with disabled loopback]:can:'
  '-u[delay bridge forwarding by microseconds]:usecs:'
  '-l[log CAN-frames into file, sets -s 2 by default]'
  '-L[use log file format on stdout]'
  '-n[terminate after reception of count CAN frames]:count:'
  '-r[set socket receive buffer to size]:size:'
  '-D[do not exit if a detected can device goes down]'
  '-d[monitor dropped CAN frames]'
  '-e[dump CAN error frames in human-readable format]'
  '-x[print extra message infos, rx/tx brs esi]'
  '-T[terminate after msecs without any reception]:msecs:'
  '*:filename:_files'
)

_arguments -s -S $arguments
