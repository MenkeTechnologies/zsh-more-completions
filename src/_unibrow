#compdef unibrow
# Documentation: https://man.archlinux.org/search?q=unibrow
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-i[*for pcap file to read]'
  '-o[for output file (append mode)]'
  '-v[verbose operation]'
  '-h[display help that you are reading]'
  '*:filename:_files'
)

_arguments -s -S $arguments
