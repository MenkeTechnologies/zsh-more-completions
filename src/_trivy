#compdef trivy

# Zsh completion for Trivy - vulnerability scanner

local curcontext="$curcontext" state line ret=1

_trivy_commands() {
  local -a commands=(
    'image:scan a container image'
    'filesystem:scan a local filesystem'
    'rootfs:scan a root filesystem'
    'repository:scan a repository'
    'server:start server mode'
    'client:client mode'
    'config:scan config files for misconfigurations'
    'plugin:manage plugins'
    'module:manage modules'
    'kubernetes:scan kubernetes cluster'
    'sbom:scan SBOM for vulnerabilities'
    'version:print version'
    'help:show help'
    'clean:remove cached files'
    'convert:convert a report format'
    'registry:manage registry authentication'
    'vex:manage VEX documents'
  )
  _describe -t commands 'trivy command' commands
}

_trivy_image() {
  _arguments -s -S \
    '--input[input file path instead of image name]:file:_files' \
    '--removed-pkgs[detect removed packages]' \
    '--platform[set platform for multi-arch images]:platform:(linux/amd64 linux/arm64 linux/arm/v7)' \
    '--docker-host[docker daemon socket to connect to]:host' \
    '--image-src[image source]:source:(docker containerd podman remote)' \
    '--scanners[comma-separated list of scanners]:scanners:(vuln misconfig secret license)' \
    '--severity[severities of vulnerabilities to report]:severity:(UNKNOWN LOW MEDIUM HIGH CRITICAL)' \
    '--format[report format]:format:(table json sarif cyclonedx spdx spdx-json github cosign-vuln template)' \
    '--output[output file name]:file:_files' \
    '--template[output template]:template:_files' \
    '--ignore-unfixed[display only fixed vulnerabilities]' \
    '--vuln-type[comma-separated list of vulnerability types]:type:(os library)' \
    '--skip-dirs[specify directories to skip]:dirs' \
    '--skip-files[specify files to skip]:files' \
    '--offline-scan[do not send requests to the Internet]' \
    '--timeout[timeout for scan]:duration' \
    '--no-progress[suppress progress bar]' \
    '--ignore-policy[specify OPA Rego file]:file:_files' \
    '--list-all-pkgs[output all packages regardless of vulnerability]' \
    '--cache-backend[cache backend]:backend:(fs redis)' \
    '--cache-dir[cache directory]:dir:_directories' \
    '--db-repository[OCI repository to retrieve trivy-db]:repo' \
    '--skip-db-update[skip updating vulnerability database]' \
    '--download-db-only[download vulnerability database only]' \
    '--reset[remove all caches and databases]' \
    '--clear-cache[clear image caches without scanning]' \
    '--java-db-repository[OCI repository to retrieve trivy-java-db]:repo' \
    '--skip-java-db-update[skip updating Java index database]' \
    '--token[token for authentication]:token' \
    '--token-header[token header name]:header' \
    '--custom-headers[custom headers in HTTP requests]:headers' \
    '--compliance[compliance report]:spec' \
    '--pkg-types[comma-separated list of package types]:types:(os library)' \
    '--pkg-relationships[filter by package relationships]:rel:(unknown root direct indirect all)' \
    '--parallel[number of goroutines for concurrent scanning]:num' \
    '--secret-config[secret config path]:file:_files' \
    '1:image:' && ret=0
}

_trivy_filesystem() {
  _arguments -s -S \
    '--scanners[comma-separated list of scanners]:scanners:(vuln misconfig secret license)' \
    '--severity[severities to report]:severity:(UNKNOWN LOW MEDIUM HIGH CRITICAL)' \
    '--format[report format]:format:(table json sarif cyclonedx spdx spdx-json github template)' \
    '--output[output file name]:file:_files' \
    '--template[output template]:template:_files' \
    '--ignore-unfixed[display only fixed vulnerabilities]' \
    '--vuln-type[comma-separated list of vulnerability types]:type:(os library)' \
    '--skip-dirs[specify directories to skip]:dirs' \
    '--skip-files[specify files to skip]:files' \
    '--offline-scan[do not send requests to the Internet]' \
    '--timeout[timeout for scan]:duration' \
    '--no-progress[suppress progress bar]' \
    '--list-all-pkgs[output all packages]' \
    '--skip-db-update[skip updating vulnerability database]' \
    '--cache-dir[cache directory]:dir:_directories' \
    '--secret-config[secret config path]:file:_files' \
    '--compliance[compliance report]:spec' \
    '1:path:_files -/' && ret=0
}

_trivy_repository() {
  _arguments -s -S \
    '--branch[pass the branch name to be scanned]:branch' \
    '--commit[pass the commit hash to be scanned]:commit' \
    '--tag[pass the tag name to be scanned]:tag' \
    '--scanners[comma-separated list of scanners]:scanners:(vuln misconfig secret license)' \
    '--severity[severities to report]:severity:(UNKNOWN LOW MEDIUM HIGH CRITICAL)' \
    '--format[report format]:format:(table json sarif cyclonedx spdx spdx-json github template)' \
    '--output[output file name]:file:_files' \
    '--ignore-unfixed[display only fixed vulnerabilities]' \
    '--vuln-type[comma-separated list of vulnerability types]:type:(os library)' \
    '--skip-dirs[specify directories to skip]:dirs' \
    '--skip-files[specify files to skip]:files' \
    '--offline-scan[do not send requests to the Internet]' \
    '--timeout[timeout for scan]:duration' \
    '--no-progress[suppress progress bar]' \
    '--skip-db-update[skip updating vulnerability database]' \
    '--cache-dir[cache directory]:dir:_directories' \
    '1:repository URL:' && ret=0
}

_trivy_config() {
  _arguments -s -S \
    '--severity[severities to report]:severity:(UNKNOWN LOW MEDIUM HIGH CRITICAL)' \
    '--format[report format]:format:(table json sarif template)' \
    '--output[output file name]:file:_files' \
    '--template[output template]:template:_files' \
    '--skip-dirs[specify directories to skip]:dirs' \
    '--skip-files[specify files to skip]:files' \
    '--timeout[timeout for scan]:duration' \
    '--no-progress[suppress progress bar]' \
    '--file-patterns[specify config file patterns]:patterns' \
    '--include-non-failures[include successes and exceptions]' \
    '--policy-namespaces[Rego namespaces]:namespaces' \
    '--config-policy[specify paths to OPA Rego policy files]:paths' \
    '--config-data[specify paths to data files]:paths' \
    '--trace[enable more verbose trace output for custom policies]' \
    '--helm-set[specify Helm values on command line]:values' \
    '--helm-set-file[specify Helm values from files]:files:_files' \
    '--helm-set-string[specify Helm string values on command line]:values' \
    '--helm-values[specify Helm values YAML files]:files:_files' \
    '--tf-vars[specify terraform tfvars file]:file:_files' \
    '--compliance[compliance report]:spec' \
    '1:path:_files -/' && ret=0
}

_trivy_kubernetes() {
  _arguments -s -S \
    '--context[specify Kubernetes context]:context' \
    '--namespace[specify Kubernetes namespace]:namespace' \
    '--kubeconfig[specify kubeconfig file path]:file:_files' \
    '--all-namespaces[scan all namespaces]' \
    '--scanners[comma-separated list of scanners]:scanners:(vuln misconfig secret rbac)' \
    '--severity[severities to report]:severity:(UNKNOWN LOW MEDIUM HIGH CRITICAL)' \
    '--format[report format]:format:(table json sarif cyclonedx spdx spdx-json github template)' \
    '--output[output file name]:file:_files' \
    '--report[specify report type]:type:(summary all)' \
    '--components[specify components to scan]:components:(infra workload)' \
    '--node-collector-namespace[namespace for node collector job]:namespace' \
    '--tolerations[specify tolerations]:tolerations' \
    '--parallel[number of goroutines for concurrent scanning]:num' \
    '--timeout[timeout for scan]:duration' \
    '--no-progress[suppress progress bar]' \
    '--compliance[compliance report]:spec' \
    '--skip-images[skip scanning images]' \
    '--burst[specify burst for Kubernetes client throttling]:num' \
    '--qps[specify QPS for Kubernetes client throttling]:qps' \
    '1:resource:' && ret=0
}

_trivy_server() {
  _arguments -s -S \
    '--listen[listen address]:address' \
    '--token[token for authentication]:token' \
    '--token-header[token header name]:header' \
    '--cache-dir[cache directory]:dir:_directories' \
    '--skip-db-update[skip updating vulnerability database]' \
    '--download-db-only[download vulnerability database only]' \
    '--db-repository[OCI repository to retrieve trivy-db]:repo' \
    '--reset[remove all caches and databases]' \
    '--debug[debug mode]' && ret=0
}

_trivy_plugin() {
  local -a plugin_commands=(
    'install:install a plugin'
    'uninstall:uninstall a plugin'
    'list:list installed plugins'
    'info:show plugin information'
    'run:run a plugin'
    'update:update installed plugins'
    'search:search for plugins'
  )
  _describe -t plugin-commands 'plugin command' plugin_commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[suppress progress bar and log output]' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '--cache-dir[cache directory]:dir:_directories' \
  '--config[config path]:file:_files' \
  '--generate-default-config[write default config to trivy-default.yaml]' \
  '--insecure[allow insecure server connections]' \
  '--timeout[timeout]:duration' \
  '1: :_trivy_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      image)      _trivy_image ;;
      filesystem) _trivy_filesystem ;;
      fs)         _trivy_filesystem ;;
      repository) _trivy_repository ;;
      repo)       _trivy_repository ;;
      config)     _trivy_config ;;
      conf)       _trivy_config ;;
      kubernetes) _trivy_kubernetes ;;
      k8s)        _trivy_kubernetes ;;
      server)     _trivy_server ;;
      plugin)     _trivy_plugin ;;
      rootfs)     _trivy_filesystem ;;
      sbom)       _trivy_image ;;
    esac
    ;;
esac

return ret
