#compdef mariadbd-multi

local -a arguments

arguments=(
  '--no-defaults[do not read any defaults file]'
  '--defaults-file[read only this configuration file]'
  '--defaults-extra-file[read this configuration file in addition to the usual ones]'
  '--example[give an example of a config file with extra information.]'
  '--help[print this help and exit.]'
  '--log[full path to the log file]'
  '--mysqladmin[mysqladmin binary to be used for a server shutdown]'
  '--mysqld[mysqld binary to be used]'
  '--no-log[print to stdout instead of the log file]'
  '--password[password for mysqladmin user]'
  '--silent[disable warnings.]'
  '--tcp-ip[connect to the MariaDB server(s) via TCP/IP port instead of socket]'
  '--user[mysqladmin user]'
  '--verbose[be more verbose.]'
  '--version[print the version number and exit.]'
  '--wsrep-new-cluster[bootstrap a cluster.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
