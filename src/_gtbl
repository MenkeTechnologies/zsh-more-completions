local -a arguments

arguments=(
    '-C[Enable compatibility mode to recognize . TS and .]'
    '-t[option of groff.]'
    '-v[Print the version number.]'
    '--ms[macros which provide this functionality if a table starts with .]'
    '*:filename:_files'
)
_arguments -s -S $arguments
