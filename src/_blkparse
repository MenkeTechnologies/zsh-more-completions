#compdef blkparse

local -a arguments

arguments=(
  {-i,--input}'[file containing trace data, or - for stdin]:file:_files'
  '-a[trace specified actions]:actions:'
  '-A[trace mask as a single value]:mask:'
  '-b[read batching]:batch:'
  '-d[write binary data to file]:file:_files'
  '-D[directory to prepend to input file names]:directory:_files -/'
  '-f[customize the output format]:format:'
  '-F[output format specification]:spec:'
  '-h[hash processes by name, not pid]'
  '-o[output file (default: stdout)]:file:_files'
  '-O[do NOT output text data]'
  '-q[dont display any stats at the end of the trace]'
  '-s[show per-program io statistics]'
  '-t[track individual ios and show request time]'
  '-w[parse data between the given time interval in seconds]:interval:'
  '-M[do not output messages to binary file]'
  '-v[verbose for marginal errors]'
  '-V[program version info]'
  '*:filename:_files'
)

_arguments -s -S $arguments
