#compdef sg_wr_mode

local -a arguments

arguments=(
  {--contents,-c}'[comma separated hex numbers for mode page contents (use - for stdin)]'
  {--dbd,-d}'[disable block descriptors (DBD bit in cdb)]'
  {--force,-f}'[force the contents to be written]'
  {--help,-h}'[print out usage message]'
  {--len,-l}'[use 10 byte (def) or 6 byte variants]'
  {--mask,-m}'[comma separated hex numbers for mask]'
  {--page,-p}'[page code (and optionally subpage) to be written (in hex)]'
  {--save,-s}'[set save page (SP) bit; default dont so]'
  {--verbose,-v}'[increase verbosity]'
  {--version,-V}'[print version string and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
