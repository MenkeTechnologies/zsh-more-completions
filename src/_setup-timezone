#compdef setup-timezone
# Documentation: https://man.archlinux.org/search?q=setup-timezone
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[show this help]'
  '-i[install tzdata and symlink instead of making a copy]'
  '-k[keep previous copies of tzdata]'
  '-z[set given timezone. (relative /usr/share/zoneinfo)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
