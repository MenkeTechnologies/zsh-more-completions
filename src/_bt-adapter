#compdef bt-adapter
# Documentation: https://man.archlinux.org/search?q=bt-adapter
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  {-l,--list}'[list all available adapters]'
  {-a,--adapter}'[adapter Name or MAC]'
  {-i,--info}'[show adapter info]'
  {-d,--discover}'[discover remote devices]'
  {-s,--set}'[set adapter property]'
  '--set[<value>]'
  '*:filename:_files'
)

_arguments -s -S $arguments
