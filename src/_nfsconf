#compdef nfsconf

local -a arguments

arguments=(
  '-v[increase Verbosity]'
  '--file[load this config file]:file:_files'
  '--dump[output the configuration to the named file]:file:_files'
  '--get[get a configuration value]'
  '--isset[check if a configuration value is set]'
  '--set[set a configuration value]'
  '--unset[unset a configuration value]'
  '*:filename:_files'
)

_arguments -s -S $arguments
