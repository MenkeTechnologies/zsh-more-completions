#compdef termineter

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-v,--version}'[show programs version number and exit]'
  {-L,--log}'[set log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)'
  {-r,--rc-file}'[execute a resource file]:file:_files'
  '*:filename:_files'
)

_arguments -s -S $arguments
