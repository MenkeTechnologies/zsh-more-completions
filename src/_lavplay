#compdef lavplay

local -a arguments

arguments=(
  {-H,--H-offset}'[horizontal offset for hardware playback]'
  {-V,--V-offset}'[vertical offset for hardware playback]'
  {-s,--skip}'[skip num seconds before playing]'
  {-c,--synchronization}'[sync correction off/on (default on)]'
  {-n,--mjpeg-buffers}'[number of MJPEG buffers]'
  {-q,--no-quit}'[do not quit at end of video]'
  {-g,--gui-mode}'[GUI-mode (used by xlav and LVS)]'
  {-x,--exchange-fields}'[exchange fields of an interlaced video]'
  {-z,--zoom}'[zoom video to fill screen as much as possible]'
  {-Z,--full-screen}'[switch to fullscreen]'
  {-P,--preserve-pathnames}'[do not canonicalise pathnames in editlists]'
  {-p,--playback}'[playback mode: (S)oftware, (H)ardware or (C)ard]'
  {-a,--audio}'[when to play audio, 0:never, or sum of flags]'
  {-U,--use-write}'[use write instead of mmap for audio playback]'
  {-F,--flicker}'[disable flicker reduction]'
  {-S,--size}'[width X height for SDL or video window]'
  '--s-x-offset[video window X offset from topleft corner]'
  '--s-y-offset[video window Y offset from topleft corner]'
  '--display[the X-display to use (default: :0.0)]'
  {-v,--verbose}'[verbosity level (0, 1, or 2)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
