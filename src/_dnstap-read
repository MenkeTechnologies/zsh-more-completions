#compdef dnstap-read
# Documentation: https://man.archlinux.org/search?q=dnstap-read
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-m[trace memory allocations]'
  '-p[print the full DNS message]'
  '-y[print YAML format (implies -p)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
