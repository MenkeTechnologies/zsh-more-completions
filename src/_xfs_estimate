#compdef xfs_estimate
# Documentation: https://man.archlinux.org/search?q=xfs_estimate
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-b[(fundamental filesystem blocksize)]'
  '-i[(internal log size)]'
  '-e[(external log size)]'
  '-v[more verbose messages]'
  '-V[version and exits]'
  '-h[this usage message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
