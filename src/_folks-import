#compdef folks-import
# Documentation: https://man.archlinux.org/search?q=folks-import
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  {-s,--source}'[source backend name (default: 'pidgin')]'
  '--source-filename[source filename (default: specific to source backend)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
