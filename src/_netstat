#compdef netstat

# Zsh completion for netstat (supports both Linux and macOS/BSD variants)

_netstat() {
    local curcontext="$curcontext" state line ret=1

    if [[ "$OSTYPE" == darwin* || "$OSTYPE" == freebsd* || "$OSTYPE" == openbsd* ]]; then
        # macOS / BSD variant
        _arguments -s \
            '-A[show address of protocol control blocks and flow hash]' \
            '-a[show state of all sockets including server sockets]' \
            '-B[show bpf device statistics]' \
            '-b[with -i, show bytes in and out]' \
            '-c[with -q, show only specified queue]:queue:' \
            '-d[with -i, show number of dropped packets]' \
            '-f[limit to specified address family]:address family:(inet inet6 unix vsock)' \
            '-g[show multicast group memberships]' \
            '-I[show info about specified interface]:interface:_net_interfaces' \
            '-i[show state of auto-configured interfaces]' \
            '-L[show size of listen queues]' \
            '-l[print full IPv6 addresses]' \
            '-m[show mbuf memory management statistics]' \
            '-n[show addresses as numbers, do not resolve names]' \
            '-p[show statistics about specified protocol]:protocol:(tcp udp icmp igmp ip ip6 icmp6 ipsec bdg)' \
            '-q[show network interface send queue statistics]' \
            '-R[show reachability information]' \
            '-r[show routing tables]' \
            '-S[show interface link status and state information]' \
            '-s[show per-protocol statistics]' \
            '-t[with -i, show contents of watchdog timers]' \
            '-v[increase verbosity]' \
            '-W[avoid truncating addresses]' \
            '-w[show statistics at intervals of specified seconds]:wait interval (seconds):' \
            '-x[show extended link-layer reachability information]' \
            && ret=0
    else
        # Linux variant
        _arguments -s \
            '(- *)'{-h,--help}'[display help information]' \
            {-r,--route}'[display routing table]' \
            {-i,--interfaces}'[display interface table]' \
            {-I,--interface}'[display specified interface]:interface:_net_interfaces' \
            {-g,--groups}'[display multicast group memberships]' \
            {-s,--statistics}'[display networking statistics (like SNMP)]' \
            {-M,--masquerade}'[display masqueraded connections]' \
            {-v,--verbose}'[be verbose]' \
            {-W,--wide}'[do not truncate IP addresses]' \
            {-n,--numeric}'[do not resolve names]' \
            '--numeric-hosts[do not resolve host names]' \
            '--numeric-ports[do not resolve port names]' \
            '--numeric-users[do not resolve user names]' \
            {-N,--symbolic}'[resolve hardware names]' \
            {-e,--extend}'[display other/more information]' \
            {-p,--programs}'[display PID/Program name for sockets]' \
            {-o,--timers}'[display timers]' \
            {-c,--continuous}'[continuous listing]' \
            {-l,--listening}'[display listening server sockets]' \
            {-a,--all}'[display all sockets (default: connected)]' \
            {-F,--fib}'[display Forwarding Information Base (default)]' \
            {-C,--cache}'[display routing cache instead of FIB]' \
            {-Z,--context}'[display SELinux security context for sockets]' \
            '-t[display TCP sockets]' \
            '-u[display UDP sockets]' \
            '-U[display Unix domain sockets]' \
            '-w[display RAW sockets]' \
            '-x[display Unix domain sockets (same as -U)]' \
            '-2[display SCTP sockets]' \
            '--protocol[show sockets of specified protocol]:protocol:(unix inet inet6 ax25 netrom ipx ddp bluetooth)' \
            '-4[display IPv4 sockets]' \
            '-6[display IPv6 sockets]' \
            && ret=0
    fi

    return ret
}

_netstat "$@"
