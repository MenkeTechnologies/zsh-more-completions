#compdef ropper

# Zsh completion for Ropper (ROP/JOP/SOP gadget finder)

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message and exit]' \
  '(- *)--version[show version]' \
  '(-f --file)'{-f,--file}'[path to binary file]:file:_files' \
  '(-a --arch)'{-a,--arch}'[target architecture]:arch:(x86 x86_64 ARM ARMTHUMB ARM64 MIPS MIPS64 PPC PPC64 SPARC64)' \
  '(-t --type)'{-t,--type}'[type of gadgets to search for]:type:(rop jop sys all)' \
  '(-s --search)'{-s,--search}'[search for gadgets matching string]:search string:' \
  '--string[search for a string in the binary]:string:' \
  '(-i --inst-count)'{-i,--inst-count}'[maximum number of instructions per gadget]:count:' \
  '(-q --quality)'{-q,--quality}'[quality of gadgets (1=best)]:quality:' \
  '(-b --badbytes)'{-b,--badbytes}'[bytes to avoid in addresses]:bad bytes:' \
  '(-o --opcode)'{-o,--opcode}'[search for opcode]:opcode:' \
  '(-I --detailed)'{-I,--detailed}'[show detailed gadget information]' \
  '--all[show all gadgets including duplicates]' \
  '--nocolor[disable colored output]' \
  '(-c --chain)'{-c,--chain}'[generate a ROP chain]:chain type:(execve mprotect virtualprotect)' \
  '--db[gadget database file]:db file:_files' && ret=0

return ret
