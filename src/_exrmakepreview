#compdef exrmakepreview
# Documentation: https://man.archlinux.org/search?q=exrmakepreview
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-w[sets the width of the preview image to x pixels]'
  '-e[adjusts the preview images exposure by s f-stops]'
  '-v[verbose mode]'
  '-h[prints this message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
