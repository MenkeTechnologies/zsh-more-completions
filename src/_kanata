#compdef kanata

# Zsh completion for kanata - cross-platform software keyboard remapper

_arguments -s -S \
  '(-c --cfg)'{-c,--cfg}'[configuration file]:config file:_files -g "*.kbd"' \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '(-t --trace)'{-t,--trace}'[enable trace logging]' \
  '(-n --nodelay)'{-n,--nodelay}'[skip startup delay]' \
  '--log-layer-changes[log layer changes]' \
  '-l[list input devices and exit]' \
  '--list[list input devices and exit]' \
  '--check[check config file for errors and exit]' \
  '--port[TCP port for live reloading]:port:' \
  '(-w --wait-on-startup-error)'{-w,--wait-on-startup-error}'[wait instead of crashing on startup error]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && return 0
