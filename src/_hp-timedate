#compdef hp-timedate

local -a arguments

arguments=(
    {-d,--device}'[specify a CUPS printer by device URI]:device-uri:'
    {-p,--printer}'[specify a CUPS printer by name]:printer:'
    {-i,--interactive}'[run in interactive mode]'
    {-l,--logging}'[set the logging level]:level:(none info error warn debug)'
    {-g,--ldebug}'[run in debug mode]'
    '(- * :)'{-h,--help}'[display this help information]'
    '*:filename:_files'
)
_arguments -s -S $arguments
