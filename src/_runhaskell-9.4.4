#compdef runhaskell-9.4.4
# Documentation: https://man.archlinux.org/search?q=runhaskell-9.4.4
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-f[/to/ghc       Tell runghc where GHC is]'
  '--ghc-arg[pass an option or argument to GHC]'
  '--help[print this usage information]'
  '--version[print version number]'
  '*:filename:_files'
)

_arguments -s -S $arguments
