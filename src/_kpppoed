#compdef kpppoed
# Documentation: https://man.archlinux.org/search?q=kpppoed
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '--config[specify configuration file path (default \\\[lq\]/etc/kpppoed/kpppoed.]:string'
    '--verbose[toggle verbose log output CONFIGURATION The kpppoed file, kpppoed.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
