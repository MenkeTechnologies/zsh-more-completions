#compdef kafka-metadata-quorum

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--command-config[Property file with configs to pass to Admin Client]:file:_files'
    '--describe[Describe the metadata quorum]'
    '--status[Show quorum status]'
    '--replication[Show replication status]'
    '--add-controller[Add a controller to the quorum]'
    '--remove-controller[Remove a controller from the quorum]'
)

_arguments -s -S $arguments
