#compdef concurrently

# Zsh completion for concurrently - Run commands concurrently

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-n --names)'{-n,--names}'[list of custom names for each process]:names (comma-separated):' \
  '--name-separator=[separator for the names]:separator:' \
  '(-s --success)'{-s,--success}'[return exit code of zero only when specified condition is met]:condition:(first last all command-name command-index)' \
  '(-r --raw)'{-r,--raw}'[output raw output of processes]' \
  '--no-color[disable colors in output]' \
  '(-p --prefix)'{-p,--prefix}'[prefix used in logging for each process]:prefix type:(index pid time command name none)' \
  '(-c --prefix-colors)'{-c,--prefix-colors}'[comma-separated list of chalk colors]:colors:' \
  '(-l --prefix-length)'{-l,--prefix-length}'[limit how many characters of the command is displayed]:length:' \
  '(-t --timestamp-format)'{-t,--timestamp-format}'[specify the timestamp format]:format:' \
  '(-k --kill-others)'{-k,--kill-others}'[kill other processes if one exits or dies]' \
  '--kill-others-on-fail[kill other processes if one exits with non-zero]' \
  '--kill-signal=[signal to send to other processes on kill]:signal:(SIGTERM SIGINT SIGHUP SIGKILL)' \
  '(-m --max-processes)'{-m,--max-processes}'[maximum number of processes to run at once]:number:' \
  '--restart-tries=[number of times to restart a process]:number:' \
  '--restart-after=[delay before restarting a process in ms]:milliseconds:' \
  '--hide=[comma-separated list of processes to hide output]:processes:' \
  '--group[group output by process]' \
  '--handle-input[enable input handling]' \
  '--default-input-target=[default target for stdin]:target index:' \
  '--passthrough-arguments[pass additional arguments to commands]' \
  '*:command:' && ret=0

return ret
