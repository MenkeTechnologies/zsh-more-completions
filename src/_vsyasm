#compdef vsyasm

local -a arguments

arguments=(
  '--version[show version text]'
  '--license[show license text]'
  '(- * :)'{-h,--help}'[show help text]'
  '--arch[select architecture (list with -a help)]'
  '-a[select architecture]:arch:'
  '--parser[select parser (list with -p help)]'
  '-p[select parser]:parser:'
  '--preproc[select preprocessor (list with -r help)]'
  '-r[select preprocessor]:preprocessor:'
  '--oformat[select object format (list with -f help)]'
  '-f[select object format]:format:'
  '--dformat[select debugging format (list with -g help)]'
  '-g[select debugging format]:format:'
  '--lformat[select list format (list with -L help)]'
  '-L[select list format]:format:'
  '--list[name of list-file output directory]'
  '-l[name of list-file output directory]:dir:_directories'
  '--objdir[name of object-file output directory]:dir:_directories'
  '-o[name of object-file output directory]:dir:_directories'
  '--mapdir[name of map-file output directory]'
  '--listext[list-file extension (default `lst)]'
  '--objext[object-file extension (default is by object format)]'
  '--mapext[map-file extension (default `map)]'
  '--machine[select machine (list with -m help)]'
  '-m[select machine]:machine:'
  '--force-strict[treat all sized operands as if `strict was used]'
  '-w[inhibits warning messages]'
  '-W[enables/disables warning]'
  '-E[redirect error messages to file]'
  '-s[redirect error messages to stdout]'
  '-i[add include path]'
  '-I[add include path]'
  '-P[pre-include file]'
  '-d[pre-define a macro, optionally to value]:macro:'
  '-D[pre-define a macro, optionally to value]:macro:'
  '-u[undefine a macro]'
  '-U[undefine a macro]'
  '-X[select error/warning message style (`gnu or `vc)]'
  '--prefix[prepend argument to name of all external symbols]'
  '--suffix[append argument to name of all external symbols]'
  '--postfix[append argument to name of all external symbols]'
  '*:filename:_files'
)

_arguments -s -S $arguments
