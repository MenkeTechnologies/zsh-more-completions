#compdef spfquery
# Documentation: https://man.archlinux.org/search?q=spfquery
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {--identity,--id}'[identity to check]:identity'
  {--file,-f}'[read query from file]:filename:_files'
  '*:filename:_files'
)

_arguments -s -S $arguments
