#compdef zgrep zegrep zfgrep

# Completion for zgrep (grep through compressed files)
# zgrep accepts the same options as grep, operating on gzip-compressed files

_zgrep() {
  local arguments

  arguments=(
    '(- *)--help[print a brief help message]'
    '(- *)'{-V,--version}'[display version information and exit]'

    # Pattern interpretation
    {-E,--extended-regexp}'[interpret pattern as an extended regular expression]'
    {-F,--fixed-strings}'[interpret pattern as fixed strings]'
    {-G,--basic-regexp}'[interpret pattern as a basic regular expression (default)]'
    {-P,--perl-regexp}'[interpret pattern as a Perl-compatible regular expression]'

    # Matching control
    '*-e+[use pattern for matching]:pattern'
    '*--regexp=+[use pattern for matching]:pattern'
    {-f+,--file=}'[read patterns from file]:pattern file:_files'
    {-i,--ignore-case}'[ignore case distinctions in patterns and data]'
    '-y[obsolete synonym for -i]'
    {-v,--invert-match}'[select non-matching lines]'
    {-w,--word-regexp}'[match only whole words]'
    {-x,--line-regexp}'[match only whole lines]'

    # General output control
    {-c,--count}'[print only a count of matching lines per file]'
    '--color=[mark up the matching text]:when:(never always auto)'
    '--colour=[mark up the matching text]:when:(never always auto)'
    {-l,--files-with-matches}'[print only names of files with matches]'
    {-L,--files-without-match}'[print only names of files with no matches]'
    {-m+,--max-count=}'[stop after specified number of matches]:num'
    {-o,--only-matching}'[show only the part of a line matching the pattern]'
    {-q,--quiet,--silent}'[suppress all normal output]'
    {-s,--no-messages}'[suppress error messages about nonexistent or unreadable files]'

    # Output line prefix control
    {-b,--byte-offset}'[print the byte offset with output lines]'
    '-H[always print filename headers with output lines]'
    {-h,--no-filename}'[suppress the file name prefix on output]'
    '--label=[use specified label for standard input file name]:label'
    {-n,--line-number}'[prefix each output line with line number]'
    '-T[make sure first character of content lines up on a tab stop]'
    {-u,--unix-byte-offsets}'[report Unix-style byte offsets]'
    '-Z[print a zero byte after the file name]'

    # Context control
    {-A+,--after-context=}'[print specified lines of trailing context]:lines'
    {-B+,--before-context=}'[print specified lines of leading context]:lines'
    {-C+,--context=}'[print specified lines of output context]:lines'
    '--line-buffered[use line buffering on output]'

    # File and directory selection
    {-a,--text}'[process binary file as if it were text]'
    '--binary-files=[set action for binary files]:type:(binary without-match text)'
    {-D+,--devices=}'[how to handle devices, FIFOs and sockets]:action:(read skip)'
    {-d+,--directories=}'[how to handle directories]:action:(read skip recurse)'
    '--exclude=[skip files matching pattern]:pattern'
    '--exclude-from=[skip files matching patterns in file]:file:_files'
    '--exclude-dir=[skip directories matching pattern]:pattern'
    '--include=[search only files matching pattern]:pattern'
    {-I,--binary}'[equivalent to --binary-files=without-match]'
    {-r,-R,--recursive}'[read all files under each directory recursively]'

    # Compression options
    {-J,--bz2decompress}'[decompress bzip2 compressed input before searching]'

    # Other
    '--null[print a zero byte after the file name]'
    '--null-data[treat input/output data as NUL-terminated lines]'
    '--mmap[use mmap instead of read for input]'
    '-U[treat file as binary (DOS/Windows)]'

    '1:pattern:'
    '*:file:_files'
  )

  _arguments -s -S $arguments
}

_zgrep "$@"
