#compdef nl gnl

# Zsh completion for nl (GNU coreutils and BSD)

_nl() {
  local -a args
  local -a numbering_styles
  numbering_styles=('a:number all lines' 't:number only non-empty lines' 'n:no line numbering' 'p:number lines matching a regex')

  args=(
    {-b+,--body-numbering=}'[use STYLE for numbering body lines]:style:(('"${numbering_styles[*]}"'))'
    {-d+,--section-delimiter=}'[use CC for logical page delimiters]:delimiter'
    {-f+,--footer-numbering=}'[use STYLE for numbering footer lines]:style:(('"${numbering_styles[*]}"'))'
    {-h+,--header-numbering=}'[use STYLE for numbering header lines]:style:(('"${numbering_styles[*]}"'))'
    {-i+,--line-increment=}'[line number increment at each line]:increment'
    {-l+,--join-blank-lines=}'[group of NUMBER empty lines counted as one]:number'
    {-n+,--number-format=}'[insert line numbers according to FORMAT]:format:((ln\:"left justified" rn\:"right justified, no leading zeros" rz\:"right justified, leading zeros"))'
    {-p,--no-renumber}'[do not reset line numbers for each section]'
    {-s+,--number-separator=}'[add STRING after line number]:separator string'
    {-v+,--starting-line-number=}'[first line number for each section]:start number'
    {-w+,--number-width=}'[use NUMBER columns for line numbers]:width'
    '(- *)--help[display help and exit]'
    '(- *)--version[output version information and exit]'
    '*:file:_files'
  )

  _arguments -s -S $args
}

_nl "$@"
