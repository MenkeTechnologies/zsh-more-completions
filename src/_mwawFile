#compdef mwawFile
# Documentation: https://man.archlinux.org/search?q=mwawFile
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-f[Does not print the filename]'
  '-F[Prints the filename\[default\]]'
  '-h[Shows this help message]'
  '-v[Output mwawFile version]'
  '-wNum[define the verbose level.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
