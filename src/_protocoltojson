#compdef protocoltojson
# Documentation: https://man.archlinux.org/search?q=protocoltojson
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-v,--version}'[displays version information.]'
  '(- * :)'{-h,--help}'[displays this help.]'
  {-o,--output}'[output file name for JSON data.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
