#compdef hal-disable-polling
# Documentation: https://man.archlinux.org/search?q=hal-disable-polling
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--udi[unique Device Id]'
  '--device[device file]'
  '--enable-polling[polling instead of disabling it]'
  '--version[show version and exit]'
  '--help[show this information and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
