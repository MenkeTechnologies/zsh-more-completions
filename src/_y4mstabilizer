#compdef y4mstabilizer
# Documentation: https://man.archlinux.org/search?q=y4mstabilizer
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-v[verbose. Repeat -v to increase verbosity/debug info]'
  '-a[A "viscosity" measure (see below).]'
  '-r[how far to look for movement.]'
  '-s[how far apart the motion search points are.]'
  '-n[do not supersample the chroma to get 1-pixel shifts.]'
  '-i[try alternate interlaced mode (does not work yet)]'
  '-a[.7:0.9]'
  '*:filename:_files'
)

_arguments -s -S $arguments
