#compdef ctr

# Zsh completion for ctr (containerd CLI)

_ctr() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a global_opts
    global_opts=(
        '--debug[Enable debug output in logs]'
        {-a,--address}'[Address for containerd GRPC server]:address'
        '--timeout[Total timeout for ctr commands]:timeout'
        '--connect-timeout[Timeout for connecting to containerd]:timeout'
        {-n,--namespace}'[Namespace to use with commands]:namespace'
        '(- *)'{-h,--help}'[Show help]'
        '(- *)'{-v,--version}'[Print the version]'
    )

    _arguments -C \
        $global_opts \
        '(-): :->command' \
        '(-)*:: :->option-or-argument' && ret=0

    case $state in
        (command)
            local -a commands
            commands=(
                'plugins:Provides information about containerd plugins'
                'version:Print the client and server versions'
                'containers:Manage containers'
                'content:Manage content'
                'events:Display containerd events'
                'images:Manage images'
                'leases:Manage leases'
                'namespaces:Manage namespaces'
                'pprof:Provide golang pprof outputs for containerd'
                'run:Run a container'
                'snapshots:Manage snapshots'
                'tasks:Manage tasks'
                'install:Install a new package'
                'oci:OCI tools'
                'sandboxes:Manage sandboxes'
                'info:Print the server info'
                'deprecations:Display deprecation warnings'
                'shim:Interact with a shim directly'
            )
            _describe -t commands 'command' commands && ret=0
            ;;
        (option-or-argument)
            curcontext=${curcontext%:*:*}:ctr-$words[1]:
            case $words[1] in
                (images|image|i)
                    _arguments -C \
                        '(-): :->subcmd' \
                        '(-)*:: :->subargs' && ret=0
                    case $state in
                        (subcmd)
                            local -a image_cmds
                            image_cmds=(
                                'check:Check existing images to ensure all content is available locally'
                                'export:Export images'
                                'import:Import images'
                                'inspect:Inspect an image'
                                'list:List images known to containerd'
                                'mount:Mount an image to a target path'
                                'unmount:Unmount the image from the target'
                                'pull:Pull an image from a remote'
                                'push:Push an image to a remote'
                                'prune:Prune unused images'
                                'delete:Delete one or more images by reference'
                                'tag:Tag an image'
                                'label:Set and clear labels for an image'
                                'convert:Convert an image'
                                'usage:Display usage of snapshots for an image'
                            )
                            _describe -t image-commands 'image command' image_cmds && ret=0
                            ;;
                        (subargs)
                            case $words[1] in
                                (pull)
                                    _arguments -s \
                                        '--skip-verify[Skip SSL certificate validation]' \
                                        '--plain-http[Allow connections using plain HTTP]' \
                                        {-k,--skip-tls}'[Skip TLS verification]' \
                                        '--user[User\:password for registry authentication]:user' \
                                        '--refresh[Refresh token for authorization server]:token' \
                                        '--hosts-dir[Custom hosts configuration directory]:dir:_directories' \
                                        '--tlscacert[Path to TLS root CA]:file:_files' \
                                        '--tlscert[Path to TLS client cert]:file:_files' \
                                        '--tlskey[Path to TLS client key]:file:_files' \
                                        '--http-dump[Dump all HTTP request/responses when interacting with container registry]' \
                                        '--http-trace[Enable HTTP tracing for registry interactions]' \
                                        '--snapshotter[Snapshotter name]:snapshotter' \
                                        '--label[Labels to attach to the image]:key=value' \
                                        '--platform[Pull content from a specific platform]:platform' \
                                        '--all-platforms[Pull content from all platforms]' \
                                        '--all-metadata[Pull metadata for all platforms]' \
                                        '--print-chainid[Print the resulting image chain ID]' \
                                        '--max-concurrent-downloads[Set the max concurrent downloads for each pull]:n' \
                                        '*:image ref:' \
                                        && ret=0
                                    ;;
                                (push)
                                    _arguments -s \
                                        '--skip-verify[Skip SSL certificate validation]' \
                                        '--plain-http[Allow connections using plain HTTP]' \
                                        '--user[User\:password for registry authentication]:user' \
                                        '--refresh[Refresh token for authorization server]:token' \
                                        '--hosts-dir[Custom hosts configuration directory]:dir:_directories' \
                                        '--tlscacert[Path to TLS root CA]:file:_files' \
                                        '--tlscert[Path to TLS client cert]:file:_files' \
                                        '--tlskey[Path to TLS client key]:file:_files' \
                                        '--http-dump[Dump all HTTP request/responses]' \
                                        '--http-trace[Enable HTTP tracing]' \
                                        '--manifest[Digest of manifest]' \
                                        '--manifest-type[Media type of manifest digest]:type' \
                                        '--platform[Push content from a specific platform]:platform' \
                                        '--max-concurrent-uploaded-layers[Set the max concurrent uploads]:n' \
                                        '*:image ref:' \
                                        && ret=0
                                    ;;
                                (import)
                                    _arguments -s \
                                        '--base-name[Base image name for added images]:name' \
                                        '--digests[Whether to create digest images]' \
                                        '--snapshotter[Snapshotter name]:snapshotter' \
                                        '--index-name[Image name to keep index as]:name' \
                                        '--all-platforms[Imports content for all platforms]' \
                                        '--no-unpack[Skip unpacking the images]' \
                                        '--compress-blobs[Compress uncompressed blobs when creating manifest]' \
                                        '--label[Labels to attach to image]:key=value' \
                                        '*:file:_files' \
                                        && ret=0
                                    ;;
                                (export)
                                    _arguments -s \
                                        '--platform[Pull content from a specific platform]:platform' \
                                        '--all-platforms[Exports content from all platforms]' \
                                        '--skip-manifest-json[Do not add Docker compatible manifest.json to archive]' \
                                        '--skip-non-distributable[Do not add non-distributable blobs]' \
                                        '*:output file and images:_files' \
                                        && ret=0
                                    ;;
                                (list|ls)
                                    _arguments -s \
                                        {-q,--quiet}'[Print only the image refs]' \
                                        '*:filter:' \
                                        && ret=0
                                    ;;
                                (delete|del|remove|rm)
                                    _arguments -s \
                                        '--sync[Synchronously remove image and all associated resources]' \
                                        '*:image ref:' \
                                        && ret=0
                                    ;;
                                (*)
                                    _arguments -s '*:arguments:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                (containers|container|c)
                    _arguments -C \
                        '(-): :->subcmd' \
                        '(-)*:: :->subargs' && ret=0
                    case $state in
                        (subcmd)
                            local -a container_cmds
                            container_cmds=(
                                'create:Create a container'
                                'delete:Delete one or more existing containers'
                                'info:Get info about a container'
                                'list:List containers'
                                'label:Set and clear labels for a container'
                                'checkpoint:Checkpoint a container'
                                'restore:Restore a container from checkpoint'
                            )
                            _describe -t container-commands 'container command' container_cmds && ret=0
                            ;;
                        (subargs)
                            case $words[1] in
                                (create)
                                    _arguments -s \
                                        '--snapshotter[Snapshotter name]:snapshotter' \
                                        '--config[Path to the runtime-specific spec config file]:file:_files' \
                                        '--env[Specify additional container environment variables]:KEY=VALUE' \
                                        '--label[Specify additional labels]:key=value' \
                                        '--mount[Specify additional container mount]:type=TYPE,src=SRC,dst=DST,options=OPT' \
                                        '--net-host[Enable host networking for the container]' \
                                        '--privileged[Run privileged container]' \
                                        '--null-io[Send all IO to /dev/null]' \
                                        '--platform[Run image for specific platform]:platform' \
                                        '--runtime[Runtime name]:runtime' \
                                        '--runtime-config-path[Optional runtime config path]:path:_files' \
                                        '--cwd[Specify the working directory of the process]:dir' \
                                        '--rootfs[Use custom rootfs that is not managed by containerd snapshotter]' \
                                        '--no-pivot[Disable use of pivot-root (linux only)]' \
                                        '--with-ns[Specify existing Linux namespace]:key=value' \
                                        '*:image and container id:' \
                                        && ret=0
                                    ;;
                                (list|ls)
                                    _arguments -s \
                                        {-q,--quiet}'[Print only container IDs]' \
                                        '*:filter:' \
                                        && ret=0
                                    ;;
                                (delete|del|remove|rm)
                                    _arguments -s \
                                        '*:container id:' \
                                        && ret=0
                                    ;;
                                (*)
                                    _arguments -s '*:arguments:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                (tasks|task|t)
                    _arguments -C \
                        '(-): :->subcmd' \
                        '(-)*:: :->subargs' && ret=0
                    case $state in
                        (subcmd)
                            local -a task_cmds
                            task_cmds=(
                                'attach:Attach to the IO of a running container'
                                'checkpoint:Checkpoint a container'
                                'delete:Delete one or more tasks'
                                'exec:Execute additional processes in an existing container'
                                'list:List tasks'
                                'kill:Signal a container (default: SIGTERM)'
                                'metrics:Get a single data point of metrics for a task'
                                'pause:Pause an existing container'
                                'ps:List processes for container'
                                'resume:Resume a paused container'
                                'start:Start a container that has been created'
                            )
                            _describe -t task-commands 'task command' task_cmds && ret=0
                            ;;
                        (subargs)
                            case $words[1] in
                                (kill)
                                    _arguments -s \
                                        {-s,--signal}'[Signal to send to the container]:signal:(SIGTERM SIGKILL SIGHUP SIGINT SIGQUIT SIGUSR1 SIGUSR2)' \
                                        {-a,--all}'[Send signal to all processes inside the container]' \
                                        '--exec-id[Process ID to kill]:id' \
                                        '*:container id:' \
                                        && ret=0
                                    ;;
                                (exec)
                                    _arguments -s \
                                        '--cwd[Working directory of the new process]:dir' \
                                        '--tty[Allocate a TTY for the container]' \
                                        {-d,--detach}'[Detach from the task after it has started execution]' \
                                        '--exec-id[Exec specific id for the process]:id' \
                                        '--fifo-dir[Directory used for storing IO FIFOs]:dir:_directories' \
                                        '--log-uri[Log uri]:uri' \
                                        '--user[User id or name]:user' \
                                        '--env[Specify additional container environment variables]:KEY=VALUE' \
                                        '*:container id and command:' \
                                        && ret=0
                                    ;;
                                (delete|del|remove|rm)
                                    _arguments -s \
                                        {-f,--force}'[Force delete task process]' \
                                        '--exec-id[Process ID to kill]:id' \
                                        '*:container id:' \
                                        && ret=0
                                    ;;
                                (list|ls)
                                    _arguments -s \
                                        {-q,--quiet}'[Print only the task IDs]' \
                                        '*:filter:' \
                                        && ret=0
                                    ;;
                                (*)
                                    _arguments -s '*:container id:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                (content)
                    _arguments -C \
                        '(-): :->subcmd' \
                        '(-)*:: :->subargs' && ret=0
                    case $state in
                        (subcmd)
                            local -a content_cmds
                            content_cmds=(
                                'active:Display active transfers'
                                'delete:Permanently delete one or more blobs'
                                'edit:Edit a blob and return a new digest'
                                'fetch:Fetch all content for an image into containerd'
                                'fetch-object:Retrieve objects from a remote'
                                'fetch-blob:Retrieve a blob from a remote'
                                'get:Get the data for an object'
                                'ingest:Accept content into the store'
                                'list:List all blobs in the store'
                                'push-object:Push an object to a remote'
                                'label:Add labels to content'
                                'prune:Prune unused content'
                                'references:List references for a blob'
                            )
                            _describe -t content-commands 'content command' content_cmds && ret=0
                            ;;
                        (subargs)
                            _arguments -s '*:arguments:' && ret=0
                            ;;
                    esac
                    ;;
                (snapshots|snapshot)
                    _arguments -C \
                        '(-): :->subcmd' \
                        '(-)*:: :->subargs' && ret=0
                    case $state in
                        (subcmd)
                            local -a snapshot_cmds
                            snapshot_cmds=(
                                'commit:Commit an active snapshot into the provided name'
                                'diff:Get the diff of two snapshots'
                                'info:Get info about a snapshot'
                                'list:List snapshots'
                                'mounts:Mount gets mount commands for the active snapshots'
                                'prepare:Prepare a snapshot from a committed snapshot'
                                'delete:Remove snapshots'
                                'label:Add labels to content'
                                'tree:Display tree view of snapshot branches'
                                'unpack:Unpack a container image to a snapshot'
                                'usage:Usage snapshots'
                                'view:Create a read-only snapshot from a committed snapshot'
                            )
                            _describe -t snapshot-commands 'snapshot command' snapshot_cmds && ret=0
                            ;;
                        (subargs)
                            case $words[1] in
                                (list|ls)
                                    _arguments -s \
                                        '--snapshotter[Snapshotter name]:snapshotter' \
                                        '*:filter:' \
                                        && ret=0
                                    ;;
                                (*)
                                    _arguments -s \
                                        '--snapshotter[Snapshotter name]:snapshotter' \
                                        '*:arguments:' \
                                        && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                (namespaces|namespace|ns)
                    _arguments -C \
                        '(-): :->subcmd' \
                        '(-)*:: :->subargs' && ret=0
                    case $state in
                        (subcmd)
                            local -a ns_cmds
                            ns_cmds=(
                                'create:Create a new namespace'
                                'list:List namespaces'
                                'remove:Remove one or more namespaces'
                                'label:Set and clear labels for a namespace'
                            )
                            _describe -t namespace-commands 'namespace command' ns_cmds && ret=0
                            ;;
                        (subargs)
                            _arguments -s '*:namespace:' && ret=0
                            ;;
                    esac
                    ;;
                (leases)
                    _arguments -C \
                        '(-): :->subcmd' \
                        '(-)*:: :->subargs' && ret=0
                    case $state in
                        (subcmd)
                            local -a lease_cmds
                            lease_cmds=(
                                'list:List all active leases'
                                'create:Create lease'
                                'delete:Delete a lease'
                            )
                            _describe -t lease-commands 'lease command' lease_cmds && ret=0
                            ;;
                        (subargs)
                            _arguments -s '*:arguments:' && ret=0
                            ;;
                    esac
                    ;;
                (plugins)
                    _arguments -C \
                        '(-): :->subcmd' \
                        '(-)*:: :->subargs' && ret=0
                    case $state in
                        (subcmd)
                            local -a plugin_cmds
                            plugin_cmds=(
                                'list:List all plugins'
                                'inspect-runtime:Display runtime plugin information'
                            )
                            _describe -t plugin-commands 'plugin command' plugin_cmds && ret=0
                            ;;
                        (subargs)
                            case $words[1] in
                                (list|ls)
                                    _arguments -s \
                                        {-q,--quiet}'[Print only the plugin IDs]' \
                                        '--detailed[Print detailed information about each plugin]' \
                                        '*:filter:' \
                                        && ret=0
                                    ;;
                                (*)
                                    _arguments -s '*:arguments:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                (pprof)
                    _arguments -C \
                        '(-): :->subcmd' \
                        '(-)*:: :->subargs' && ret=0
                    case $state in
                        (subcmd)
                            local -a pprof_cmds
                            pprof_cmds=(
                                'block:Goroutine blocking profile'
                                'goroutines:Dump goroutine stack dump'
                                'heap:Dump heap profile'
                                'profile:CPU profile'
                                'threadcreate:Goroutine thread creating profile'
                                'trace:Collect execution trace'
                            )
                            _describe -t pprof-commands 'pprof command' pprof_cmds && ret=0
                            ;;
                        (subargs)
                            case $words[1] in
                                (profile)
                                    _arguments -s \
                                        '--debug[Enable debug pprof]' \
                                        '--seconds[Duration for collection]:seconds' \
                                        && ret=0
                                    ;;
                                (trace)
                                    _arguments -s \
                                        '--seconds[Duration for collection]:seconds' \
                                        && ret=0
                                    ;;
                                (*)
                                    _arguments -s \
                                        '--debug[Enable debug pprof]' \
                                        && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                (run)
                    _arguments -s \
                        '--snapshotter[Snapshotter name]:snapshotter' \
                        '--config[Path to the runtime-specific spec config file]:file:_files' \
                        '--cwd[Specify the working directory]:dir' \
                        '--env[Specify additional container environment variables]:KEY=VALUE' \
                        '--label[Specify additional labels]:key=value' \
                        '--mount[Specify additional container mount]:type=TYPE,src=SRC,dst=DST,options=OPT' \
                        '--net-host[Enable host networking for the container]' \
                        '--privileged[Run privileged container]' \
                        '--null-io[Send all IO to /dev/null]' \
                        '--log-uri[Log uri]:uri' \
                        {-d,--detach}'[Detach from the task after it has started execution]' \
                        '--fifo-dir[Directory used for storing IO FIFOs]:dir:_directories' \
                        '--runtime[Runtime name]:runtime' \
                        '--runtime-config-path[Optional runtime config path]:path:_files' \
                        '--rm[Remove the container after running]' \
                        '--tty[Allocate a TTY for the container]' \
                        '--rootfs[Use custom rootfs]' \
                        '--no-pivot[Disable use of pivot-root]' \
                        '--cpu-quota[Limit CPU CFS quota]:quota' \
                        '--cpu-period[Limit CPU CFS period]:period' \
                        '--cpus[Set the CFS quota]:cpus' \
                        '--memory-limit[Memory limit in bytes]:bytes' \
                        '--gpus[Add gpus to the container]:gpus' \
                        '--runc-binary[Specify runc binary]:path:_files' \
                        '--runc-root[Specify runc root directory]:path:_directories' \
                        '--runc-systemd-cgroup[Start runc with systemd cgroup manager]' \
                        '--platform[Run image for specific platform]:platform' \
                        '--cni[Enable CNI networking for the container]' \
                        '--with-ns[Specify existing Linux namespace]:key=value' \
                        '--pid-file[File path to write the task PID]:file:_files' \
                        '--user[User id or name]:user' \
                        '*:image and container id:' \
                        && ret=0
                    ;;
                (sandboxes|sandbox|sb|s)
                    _arguments -C \
                        '(-): :->subcmd' \
                        '(-)*:: :->subargs' && ret=0
                    case $state in
                        (subcmd)
                            local -a sandbox_cmds
                            sandbox_cmds=(
                                'run:Create and run a new sandbox'
                                'list:List sandboxes'
                                'remove:Remove one or more sandboxes'
                                'info:Get info about a sandbox'
                            )
                            _describe -t sandbox-commands 'sandbox command' sandbox_cmds && ret=0
                            ;;
                        (subargs)
                            _arguments -s '*:arguments:' && ret=0
                            ;;
                    esac
                    ;;
                (oci)
                    _arguments -C \
                        '(-): :->subcmd' \
                        '(-)*:: :->subargs' && ret=0
                    case $state in
                        (subcmd)
                            local -a oci_cmds
                            oci_cmds=(
                                'spec:Generate the default OCI spec'
                            )
                            _describe -t oci-commands 'OCI command' oci_cmds && ret=0
                            ;;
                        (subargs)
                            _arguments -s '*:arguments:' && ret=0
                            ;;
                    esac
                    ;;
                (shim)
                    _arguments -C \
                        '(-): :->subcmd' \
                        '(-)*:: :->subargs' && ret=0
                    case $state in
                        (subcmd)
                            local -a shim_cmds
                            shim_cmds=(
                                'delete:Delete a container with a shim'
                                'exec:Exec a process in a container'
                                'start:Start a container with a shim'
                                'state:Get the state of all processes in a container'
                                'shutdown:Shutdown a shim'
                                'pprof:Provide golang pprof outputs for a shim'
                            )
                            _describe -t shim-commands 'shim command' shim_cmds && ret=0
                            ;;
                        (subargs)
                            _arguments -s '*:arguments:' && ret=0
                            ;;
                    esac
                    ;;
                (deprecations)
                    _arguments -C \
                        '(-): :->subcmd' \
                        '(-)*:: :->subargs' && ret=0
                    case $state in
                        (subcmd)
                            local -a dep_cmds
                            dep_cmds=(
                                'list:List all deprecation warnings'
                            )
                            _describe -t deprecation-commands 'deprecation command' dep_cmds && ret=0
                            ;;
                        (subargs)
                            _arguments -s '*:arguments:' && ret=0
                            ;;
                    esac
                    ;;
                (events|event)
                    _arguments -s '*:arguments:' && ret=0
                    ;;
                (version|info|install)
                    _arguments -s '*:arguments:' && ret=0
                    ;;
                (*)
                    _arguments -s '*:arguments:' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_ctr "$@"
