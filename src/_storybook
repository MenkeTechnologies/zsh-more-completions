#compdef storybook

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'dev:start Storybook in development mode'
  'build:build Storybook as a static web application'
  'init:initialize Storybook in your project'
  'upgrade:upgrade Storybook to the latest version'
  'automigrate:run automigrations to update Storybook'
  'doctor:check Storybook for known issues'
  'sandbox:create a sandbox project'
  'add:add an addon to your Storybook'
  'remove:remove an addon from your Storybook'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'storybook command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (dev)
        _arguments -s -S \
          '(-p --port)'{-p,--port}'=[port to run on]:port' \
          '(-h --host)'{-h,--host}'=[host to bind]:host' \
          '--https[enable https]' \
          '--ssl-ca=[ssl CA certificate]:file:_files' \
          '--ssl-cert=[ssl certificate]:file:_files' \
          '--ssl-key=[ssl key]:file:_files' \
          '(-s --static-dir)'{-s,--static-dir}'=[directory for static files]:directory:_directories' \
          '--smoke-test[exit after initialization]' \
          '--ci[CI mode]' \
          '--no-open[do not open browser]' \
          '--quiet[suppress verbose output]' \
          '--debug-webpack[display webpack config]' \
          '--docs[start in docs mode]' \
          '--no-version-updates[disable update notifications]' \
          '-c+[directory where to load config from]:config dir:_directories' \
          '--config-dir=[directory where to load config from]:config dir:_directories' \
          '--loglevel=[log level]:level:(silly verbose info warn error silent)' \
          '--disable-telemetry[disable telemetry]' && ret=0
        ;;
      (build)
        _arguments -s -S \
          '(-o --output-dir)'{-o,--output-dir}'=[directory for output]:output dir:_directories' \
          '(-s --static-dir)'{-s,--static-dir}'=[directory for static files]:directory:_directories' \
          '-c+[directory where to load config from]:config dir:_directories' \
          '--config-dir=[directory where to load config from]:config dir:_directories' \
          '--quiet[suppress verbose output]' \
          '--debug-webpack[display webpack config]' \
          '--docs[build in docs mode]' \
          '--test[build for testing]' \
          '--loglevel=[log level]:level:(silly verbose info warn error silent)' \
          '--disable-telemetry[disable telemetry]' && ret=0
        ;;
      (init)
        _arguments -s -S \
          '--type=[project type]:type:(react vue angular html web_components ember preact svelte)' \
          '--builder=[builder]:builder:(webpack5 vite)' \
          '--force[force initialization]' \
          '--package-manager=[package manager to use]:pm:(npm yarn pnpm)' \
          '--skip-install[skip installing dependencies]' \
          '--yes[auto-accept all prompts]' && ret=0
        ;;
      (upgrade)
        _arguments -s -S \
          '--tag=[upgrade to version tag]:tag:(latest next canary)' \
          '--prerelease[include prerelease versions]' \
          '--skip-check[skip postinstall checks]' \
          '--yes[auto-accept all prompts]' \
          '--package-manager=[package manager to use]:pm:(npm yarn pnpm)' \
          '--dry-run[preview changes without applying]' \
          '--config-dir=[directory where to load config from]:config dir:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
