#compdef auditctl

local -a arguments

arguments=(
  '-a[append rule to end of list with action]:list,action:'
  '-A[add rule at beginning of list with action]:list,action:'
  '-b[set max number of outstanding audit buffers]:backlog:'
  '-c[continue through errors in rules]'
  '-C[compare collected fields if available]:field:'
  '-d[delete rule from list with action]:list,action:'
  '-D[delete all rules and watches]'
  '-e[set enabled flag (0..2)]:flag:'
  '-f[set failure flag (0..2)]:flag:'
  '-F[build rule with field name and operator]:field=value:'
  '-h[help]'
  '-i[ignore errors when reading rules from file]'
  '-k[set filter key on audit rule]:key:'
  '-l[list rules]'
  '-m[send a user-space message]:message:'
  '-p[set permissions filter on watch]:permissions:'
  '-q[make subtree part of mount points dir watches]:mount_point,subtree:'
  '-r[set limit in messages/sec (0=none)]:rate:'
  '-R[read rules from file]:file:_files'
  '-s[report status]'
  '-S[build rule: syscall name or number]:syscall:'
  '-t[trim directory watches]'
  '-v[version]'
  '-w[insert watch at path]:path:_files'
  '-W[remove watch at path]:path:_files'
  '--loginuid-immutable[make loginuids unchangeable once set]'
  '--reset-lost[reset the lost record counter]'
  '*:filename:_files'
)

_arguments -s -S $arguments
