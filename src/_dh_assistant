#compdef dh_assistant
# Documentation: https://man.archlinux.org/search?q=dh_assistant
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '--output-format'
    {--no-linter-exit-code,--linter-exit-code}''
    {--with,--without}'[add or remove a debhelper addon]'
    '--indep[parses the records.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
