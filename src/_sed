#compdef sed

_arguments -s -S \
  {-n,--quiet,--silent}'[suppress automatic printing of pattern space]' \
  '--debug[annotate program execution]' \
  '*'{-e+,--expression=}'[add script to the commands to be executed]:script' \
  '*'{-f+,--file=}'[add contents of script-file to the commands]:script file:_files' \
  '--follow-symlinks[follow symlinks when processing in place]' \
  {-i-,--in-place=-}'[edit files in place (makes backup if SUFFIX supplied)]::suffix' \
  '-I+[edit files in-place, saving backups with extension]:extension' \
  {-l+,--line-length=}'[specify desired line-wrap length for the l command]:length' \
  '--posix[disable all GNU extensions]' \
  '(-E -r --regexp-extended)'{-E,-r,--regexp-extended}'[use extended regular expressions in the script]' \
  {-s,--separate}'[consider files as separate rather than as a single continuous stream]' \
  '--sandbox[operate in sandbox mode (disable e/r/w commands)]' \
  {-u,--unbuffered}'[load minimal amounts of data and flush output buffers more often]' \
  {-z,--null-data}'[separate lines by NUL characters]' \
  '-a[delay opening files for w function until applied]' \
  '-H[enable enhanced features in regular expression syntax]' \
  '-l[make output line buffered]' \
  '(- *)--help[display help and exit]' \
  '(- *)--version[output version information and exit]' \
  '*:file:_files'
