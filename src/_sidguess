#compdef sidguess
# Documentation: https://man.archlinux.org/search?q=sidguess
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-p[use specific port (default 1521)]'
  '-r[report to file]'
  '-m[findfirst OR findall(default)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
