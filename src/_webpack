#compdef webpack

_webpack_commands() {
  local -a commands
  commands=(
    'build:Run webpack (default command)'
    'bundle:Run webpack (alias for build)'
    'watch:Run webpack and watch for file changes'
    'serve:Run webpack-dev-server'
    'server:Run webpack-dev-server (alias for serve)'
    'configtest:Validate a webpack configuration'
    'info:Output information about your system'
    'init:Initialize a new webpack project'
    'loader:Scaffold a loader'
    'plugin:Scaffold a plugin'
    'version:Output the version numbers of webpack packages'
    'help:Display help for commands and options'
  )
  _describe -t commands 'webpack command' commands
}

_webpack_common_flags() {
  _arguments -s \
    '*--entry[Entry point(s) of the application]:entry file:_files' \
    '(-c --config)'{-c,--config}'[Path to webpack configuration file]:config file:_files' \
    '*--config-name[Name of the configuration to use]:config name' \
    '--name[Name of configuration for multiple configs]:name' \
    '--merge[Merge two or more configurations using webpack-merge]' \
    '(-e --extends)'{-e,--extends}'[Extend an existing configuration]:config file:_files' \
    '--mode[Define the mode to pass to webpack]:mode:(development production none)' \
    '(-o --output-path)'{-o,--output-path}'[Output location of the file generated by webpack]:output path:_directories' \
    '(-t --target)'{-t,--target}'[Sets the build target]:target:(web node async-node webworker electron-main electron-renderer electron-preload)' \
    '(-d --devtool)'{-d,--devtool}'[Controls source map generation]:devtool:(false eval cheap-source-map cheap-module-source-map source-map inline-source-map hidden-source-map nosources-source-map eval-source-map eval-cheap-source-map eval-cheap-module-source-map inline-cheap-source-map inline-cheap-module-source-map)' \
    '--no-devtool[Do not generate source maps]' \
    '(-w --watch)'{-w,--watch}'[Watch for file changes]' \
    '--no-watch[Do not watch for file changes]' \
    '--watch-options-stdin[Stop watching when stdin stream has ended]' \
    '--no-watch-options-stdin[Do not stop watching when stdin ends]' \
    '*--env[Environment passed to the config when it is a function]:env' \
    '--node-env[Set process.env.NODE_ENV to the specified value]:node env' \
    '--progress[Print compilation progress during build]::type:(profile)' \
    '(-j --json)'{-j,--json}'[Print result as JSON or store in a file]::output file:_files' \
    '--stats[Instruct webpack on how to treat stats]:stats preset:(normal verbose errors-only errors-warnings none detailed summary)' \
    '--no-stats[Disable stats output]' \
    '--analyze[Invoke webpack-bundle-analyzer plugin to analyze bundle]' \
    '--fail-on-warnings[Stop webpack-cli process with non-zero exit code on warnings]' \
    '--disable-interpret[Disable interpret for loading the config file]' \
    '(--color --no-color)--color[Enable colors on console]' \
    '(--color --no-color)--no-color[Disable colors on console]' \
    '--hot[Enable Hot Module Replacement]' \
    '--no-hot[Disable Hot Module Replacement]' \
    '(-h --help)'{-h,--help}'[Show help]' \
    '(-v --version)'{-v,--version}'[Show version number]' \
    '*:filename:_files'
}

_webpack() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-): :_webpack_commands' \
    '(-)*::arg:->args' \
    '(-c --config)'{-c,--config}'[Path to webpack configuration file]:config file:_files' \
    '*--config-name[Name of the configuration to use]:config name' \
    '--name[Name of configuration]:name' \
    '--merge[Merge two or more configurations]' \
    '(-e --extends)'{-e,--extends}'[Extend an existing configuration]:config file:_files' \
    '*--entry[Entry point(s) of the application]:entry file:_files' \
    '--mode[Define the mode]:mode:(development production none)' \
    '(-o --output-path)'{-o,--output-path}'[Output location]:output path:_directories' \
    '(-t --target)'{-t,--target}'[Sets the build target]:target:(web node async-node webworker electron-main electron-renderer electron-preload)' \
    '(-d --devtool)'{-d,--devtool}'[Controls source map generation]:devtool' \
    '--no-devtool[Do not generate source maps]' \
    '(-w --watch)'{-w,--watch}'[Watch for file changes]' \
    '--no-watch[Do not watch for file changes]' \
    '--watch-options-stdin[Stop watching when stdin ends]' \
    '*--env[Environment passed to config function]:env' \
    '--node-env[Set process.env.NODE_ENV]:node env' \
    '--progress[Print compilation progress]::type:(profile)' \
    '(-j --json)'{-j,--json}'[Print result as JSON or store in a file]::file:_files' \
    '--stats[How to treat stats]:preset:(normal verbose errors-only errors-warnings none detailed summary)' \
    '--no-stats[Disable stats output]' \
    '--analyze[Invoke webpack-bundle-analyzer]' \
    '--fail-on-warnings[Exit with non-zero code on warnings]' \
    '--disable-interpret[Disable interpret for loading config]' \
    '(--color --no-color)--color[Enable colors on console]' \
    '(--color --no-color)--no-color[Disable colors on console]' \
    '--hot[Enable Hot Module Replacement]' \
    '--no-hot[Disable Hot Module Replacement]' \
    '(-h --help)'{-h,--help}'[Show help]' \
    '(-v --version)'{-v,--version}'[Show version number]' \
    '*:filename:_files'

  case $state in
    args)
      case $line[1] in
        build|bundle|b|watch|w)
          _webpack_common_flags
          ;;
        serve|server|s)
          _arguments -s \
            '--host[The hostname/ip address the server will bind to]:host' \
            '--port[The port server will listen to]:port' \
            '--static[A directory to serve static content from]:directory:_directories' \
            '--live-reload[Enable live reloading]' \
            '--no-live-reload[Disable live reloading]' \
            '--open[Open the default browser]' \
            '--no-open[Do not open the default browser]' \
            '--client-logging[Log level in the browser]:level:(none error warn info log verbose)' \
            '--https[Use HTTPS protocol]' \
            '--http2[Use HTTP/2]' \
            '--allowed-hosts[Hosts allowed to access the dev server]:hosts' \
            '--history-api-fallback[Fall back to /index.html for SPAs]' \
            '--compress[Enable gzip compression]' \
            '--no-compress[Disable gzip compression]' \
            '--proxy[Proxy requests to backend]:proxy config' \
            '--client-progress[Print compilation progress in browser]' \
            '--setup-exit-signals[Allow to close dev server gracefully]' \
            '--client-overlay[Show a full-screen overlay on errors]' \
            '--no-client-overlay[Disable full-screen overlay on errors]' \
            '--client-reconnect[Number of times to reconnect]:count' \
            '--server-type[Set server type]:type:(http https spdy)' \
            '(-c --config)'{-c,--config}'[Path to webpack config file]:config file:_files' \
            '*--config-name[Name of the config to use]:config name' \
            '--mode[Define the mode]:mode:(development production none)' \
            '*--entry[Entry point(s)]:entry file:_files' \
            '(-o --output-path)'{-o,--output-path}'[Output location]:output path:_directories' \
            '(-t --target)'{-t,--target}'[Build target]:target' \
            '(-d --devtool)'{-d,--devtool}'[Source map generation]:devtool' \
            '--hot[Enable Hot Module Replacement]' \
            '--no-hot[Disable Hot Module Replacement]' \
            '*--env[Environment passed to config]:env' \
            '--progress[Print compilation progress]::type:(profile)' \
            '(--color --no-color)--color[Enable colors]' \
            '(--color --no-color)--no-color[Disable colors]' \
            '(-h --help)'{-h,--help}'[Show help]' \
            '*:filename:_files'
          ;;
        configtest|t)
          _arguments -s \
            '1:config file:_files' \
            '(-h --help)'{-h,--help}'[Show help]'
          ;;
        info|i)
          _arguments -s \
            '--output[Output format]:format:(json markdown)' \
            '--additional-package[Show info for additional packages]:package' \
            '(-h --help)'{-h,--help}'[Show help]'
          ;;
        help|h)
          _arguments -s \
            '1: :_webpack_commands'
          ;;
        version|v)
          _arguments -s \
            '(-h --help)'{-h,--help}'[Show help]'
          ;;
        init)
          _arguments -s \
            '--template[Path to template]:template:_files' \
            '--force[Generate without questions using default answers]' \
            '(-h --help)'{-h,--help}'[Show help]' \
            '*:output directory:_directories'
          ;;
      esac
      ;;
  esac
}

_webpack "$@"
