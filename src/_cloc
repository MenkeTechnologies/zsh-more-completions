#compdef cloc

# Zsh completion for cloc - Count Lines of Code

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--diff[compute differences in code and comments between file sets]' \
  '--git[force interpretation of inputs as git targets]' \
  '--vcs=[use version control to determine files]:vcs:(git svn)' \
  '--by-file[report results for every source file encountered]' \
  '--by-file-by-lang[report results for every source file by language]' \
  '--by-percent=[instead of line counts show percentage]:format:(c cm cb cmb)' \
  '--csv[write results in comma separated value format]' \
  '--csv-delimiter=[use specified delimiter instead of comma]:delimiter:' \
  '--json[write results in JSON format]' \
  '--md[write results as Markdown-formatted text]' \
  '--yaml[write results in YAML format]' \
  '--xml[write results in XML format]' \
  '--out=[synonym for --report-file]:output file:_files' \
  '--report-file=[write results to specified file]:output file:_files' \
  '--sql=[write results as SQL create and insert statements]:sql file:_files' \
  '--sql-project=[use as the project identifier]:project name:' \
  '--sql-style=[write SQL statements in specified style]:style:(named)' \
  '--count-and-diff[first count then do diff]:sets:' \
  '--diff-alignment=[write to specified file a list of file pairs]:alignment file:_files' \
  '--diff-list-file=[take diff file pairs from specified file]:list file:_files' \
  '--diff-timeout=[timeout for diff of a single file in seconds]:seconds:' \
  '--exclude-content=[exclude files containing specified text]:regex:' \
  '--exclude-dir=[exclude directories matching specified regex]:regex:' \
  '--exclude-ext=[exclude file extensions]:extensions:' \
  '--exclude-lang=[exclude languages]:languages:' \
  '--exclude-list-file=[ignore files listed in specified file]:list file:_files' \
  '--fullpath[modifies the behavior of --match-d and --not-match-d]' \
  '--include-ext=[count only languages with these extensions]:extensions:' \
  '--include-lang=[count only specified languages]:languages:' \
  '--match-d=[only count files in directories matching regex]:regex:' \
  '--not-match-d=[count all files except those in directories matching regex]:regex:' \
  '--match-f=[only count files whose basenames match regex]:regex:' \
  '--not-match-f=[count all files except those whose basenames match regex]:regex:' \
  '--skip-uniqueness[skip file uniqueness checks]' \
  '--strip-comments=[for each file write to target directory without comments]:target dir:_files -/' \
  '--original-dir[write unchanged files to same directory as changed files]' \
  '--force-lang=[process all files with given extension as language]:lang,ext:' \
  '--force-lang-def=[load language processing filters from file]:definition file:_files' \
  '--read-lang-def=[load new language processing filters from file]:definition file:_files' \
  '--write-lang-def=[write language processing filters to file]:definition file:_files' \
  '--script-lang=[map scripting language to file type]:lang,type:' \
  '--sdir=[use specified directory for building temporary files]:scratch dir:_files -/' \
  '--skip-win-hidden[ignore hidden files on Windows]' \
  '--stdin-name=[give a file name to use counting stdin]:file name:' \
  '--sum-reports[process input files as report files and show total]' \
  '--unix[override auto-detection of operating system]' \
  '--windows[override auto-detection of operating system]' \
  '--use-sloccount[use SLOCCount method for duplicates]' \
  '--no3[suppress third-generation language output]' \
  '--3[print third-generation language output]' \
  '--progress-rate=[show progress update after every N files]:number:' \
  '--quiet[suppress all information except the final report]' \
  '-v=[verbose level]:level:(0 1 2)' \
  '--verbose=[verbose level]:level:(0 1 2)' \
  '--hide-rate[do not show line and file processing rates]' \
  '--processes=[use multiple cores]:number of processes:' \
  '--max-file-size=[skip files larger than given size in MB]:size MB:' \
  '--follow-links[follow symbolic links to directories]' \
  '--autoconf[count .in files as language counterparts]' \
  '--docstring-as-code[count docstrings as code]' \
  '--no-autogen[ignore files generated by code-generation systems]' \
  '--lang-no-ext=[language for files without extensions]:language:' \
  '--sort=[sort output]:sort key:(code files lines blanks comments name)' \
  '*:file or directory:_files' && ret=0

return ret
