#compdef bogoupgrade
# Documentation: https://man.archlinux.org/search?q=bogoupgrade
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-b[to bogoutil>]'
  '-d[name of directory containing database files. Old files will be]'
  '-i[file>]'
  '-o[file>]'
  '-b[to bogoutil program>]'
  '(- * :)'{-h,--help}'[print the help - you are currently reading it.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
