#compdef y4mspatialfilter
# Documentation: https://man.archlinux.org/search?q=y4mspatialfilter
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-v[somewhat verbose]'
  '-h[this usage summary]'
  '-x[/-X/-y/-Y change a vertical/horizontal parameter without affecting the other dimensions value]'
  '*:filename:_files'
)

_arguments -s -S $arguments
