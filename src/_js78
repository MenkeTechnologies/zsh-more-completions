  '--no-blinterp[disable Baseline Interpreter]'
  '--blinterp-eager[always Baseline-interpret scripts]'
  '--blinterp-warmup-threshold[wait for COUNT calls or iterations before interpreting]:count:'
  '--non-writable-jitcode[(NOP for fuzzers) allocate JIT code as non-writable]'
  '--no-sse3[pretend CPU does not support SSE3]'
  '--no-ssse3[pretend CPU does not support SSSE3]'
  '--no-sse41[pretend CPU does not support SSE4.1]'
  '--no-sse4[alias for --no-sse41]'
  '--no-sse42[pretend CPU does not support SSE4.2]'
  '--enable-avx[enable AVX support (disabled by default)]'
  '--no-avx[disable AVX support (no-op, AVX is disabled by default)]'
  '--more-compartments[make newGlobal default to creating a new compartment]'
  '--fuzzing-safe[dont expose functions that arent safe for fuzzing]'
  '--disable-oom-functions[disable functions that cause artificial OOMs]'
  '--no-threads[disable helper threads]'
  '--no-ggc[disable Generational GC]'
  '--no-cgc[disable Compacting GC]'
  '--no-incremental-gc[disable Incremental GC]'
  '--nursery-strings[allocate strings in the nursery]:toggle:(on off)'
  '--nursery-bigints[allocate BigInts in the nursery]:toggle:(on off)'
  '--available-memory[select GC settings based on available memory (MB)]:MB:'
  '--arm-hwcap[specify ARM code generation features]:features:'
  '--arm-asm-nop-fill[insert the given number of NOP instructions]:count:'
  '--asm-pool-max-offset[the maximum pc relative offset permitted for pool entries]:offset:'
  '--arm-sim-icache-checks[enable icache flush checks in the ARM simulator]'
  '--arm-sim-stop-at[stop the ARM simulator after the given number of instructions]:count:'
  '--mips-sim-icache-checks[enable icache flush checks in the MIPS simulator]'
  '--mips-sim-stop-at[stop the MIPS simulator after the given number of instructions]:count:'
  '--nursery-size[set the maximum nursery size in MB]:MB:'
  {-z,--gc-zeal}'[set GC zeal level and frequency]:level:'
  '--module-load-path[set directory to load modules from]:dir:_files -/'
  '--no-source-pragmas[disable source(Mapping)URL pragma parsing]'
  '--no-async-stacks[disable async stacks]'
  '--dll[dynamically load LIBRARY]:library:_files'
  '--suppress-minidump[suppress crash minidumps]'
  '--smoosh[no-op]'
  '--wasm-compile-and-serialize[compile the wasm bytecode from stdin and serialize to stdout]'
  '*:filename:_files'
)

_arguments -s -S $arguments
