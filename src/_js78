#compdef js78

local -a arguments

arguments=(
  {-f,--file}'[file path to run, parsing file contents]:file:_files'
  {-u,--utf16-file}'[file path to run, inflating the file to UTF-16]:file:_files'
  {-m,--module}'[module path to run]:file:_files'
  {-B,--binast}'[no-op]'
  '--binast-format[no-op]'
  {-e,--execute}'[inline code to run]:code:'
  {-i,--shell}'[enter prompt after running code]'
  {-c,--compileonly}'[only compile, dont run (syntax checking)]'
  {-w,--warnings}'[emit warnings]'
  {-W,--nowarnings}'[dont emit warnings]'
  {-D,--dump-bytecode}'[dump bytecode with exec count for all scripts]'
  {-b,--print-timing}'[print sub-ms runtime for each file that is run]'
  '--code-coverage[enable code coverage instrumentation]'
  '--disable-parser-deferred-alloc[disable deferred allocation of GC objects]'
  '--cpu-count[set the number of CPUs (hardware threads)]:count:'
  '--thread-count[alias for --cpu-count]:count:'
  '--ion[enable IonMonkey (default)]'
  '--no-ion[disable IonMonkey]'
  '--no-ion-for-main-context[disable IonMonkey for the main context]'
  '--warp[no-op on non-Nightly]'
  '--no-warp[disable WarpBuilder (default)]'
  '--no-asmjs[disable asm.js compilation]'
  '--wasm-compiler[choose to enable a subset of the wasm compilers]:compilers:'
  '--wasm-verbose[enable WebAssembly verbose logging]'
  '--disable-wasm-huge-memory[disable WebAssembly huge memory]'
  '--test-wasm-await-tier2[forcibly activate tiering and block until done]'
  '--no-wasm-reftypes[disable wasm reference types features]'
  '--wasm-gc[no-op]'
  '--no-wasm-multi-value[disable wasm multi-value features]'
  '--no-wasm-simd[no-op]'
  '--no-native-regexp[disable native regexp compilation]'
  '--regexp-warmup-threshold[wait for COUNT invocations before compiling]:count:'
  '--trace-regexp-parser[trace regexp parsing]'
  '--trace-regexp-assembler[trace regexp assembler]'
  '--trace-regexp-interpreter[trace regexp interpreter]'
  '--trace-regexp-peephole[trace regexp peephole optimization]'
  '--no-unboxed-objects[disable creating unboxed plain objects]'
  '--enable-streams[enable WHATWG Streams (default)]'
  '--no-streams[disable WHATWG Streams]'
  '--enable-readable-byte-streams[enable support for WHATWG ReadableStreams]'
  '--enable-byob-stream-readers[enable support for getting BYOB readers]'
  '--enable-writable-streams[enable support for WHATWG WritableStreams]'
  '--enable-readablestream-pipeto[enable support for WHATWG ReadableStream pipeTo]'
  '--enable-weak-refs[enable weak references]'
  '--disable-tosource[disable toSource/uneval]'
  '--disable-property-error-message-fix[disable fix for the error message when accessing properties]'
  '--enable-iterator-helpers[enable iterator helpers]'
  '--shared-memory[SharedArrayBuffer and Atomics]:toggle:(on off)'
  '--spectre-mitigations[whether Spectre mitigations are enabled]:toggle:(on off)'
  '--cache-ir-stubs[use CacheIR stubs]:toggle:(on off call)'
  '--ion-shared-stubs[use shared stubs]:toggle:(on off)'
  '--ion-scalar-replacement[scalar replacement]:toggle:(on off)'
  '--ion-gvn[specify Ion global value numbering]:mode:(off on optimistic pessimistic)'
  '--ion-licm[loop invariant code motion]:toggle:(on off)'
  '--ion-edgecase-analysis[find edge cases where Ion can avoid bailouts]:toggle:(on off)'
  '--ion-pgo[profile guided optimization]:toggle:(on off)'
  '--ion-range-analysis[range analysis]:toggle:(on off)'
  '--ion-sink[sink code motion]:toggle:(on off)'
  '--ion-optimization-levels[use multiple Ion optimization levels]:toggle:(on off)'
  '--ion-loop-unrolling[(NOP for fuzzers)]:toggle:(on off)'
  '--ion-instruction-reordering[instruction reordering]:toggle:(on off)'
  '--ion-check-range-analysis[range analysis checking]'
  '--ion-extra-checks[perform extra dynamic validation checks]'
  '--ion-inlining[inline methods where possible]:toggle:(on off)'
  '--ion-osr[on-stack replacement]:toggle:(on off)'
  '--ion-limit-script-size[dont compile very large scripts]:toggle:(on off)'
  '--ion-warmup-threshold[wait for COUNT calls or iterations before compiling]:count:'
  '--ion-full-warmup-threshold[wait for COUNT calls or iterations before full compilation]:count:'
  '--ion-regalloc[specify Ion register allocation]:mode:(backtracking testbed stupid lsra)'
  '--ion-eager[always ion-compile methods (implies --baseline-eager)]'
  '--ion-offthread-compile[compile scripts off thread]:toggle:(on off)'
  '--baseline[enable baseline compiler (default)]'
  '--no-baseline[disable baseline compiler]'
  '--baseline-eager[always baseline-compile methods]'
  '--baseline-warmup-threshold[wait for COUNT calls or iterations before compiling]:count:'
