#compdef spumux
# Documentation: https://man.archlinux.org/search?q=spumux
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-m[dvd, cvd, or svcd (only the first letter is checked).]'
  '-s[number of the substream to insert (default 0)]'
  '-v[verbosity level (default 0)]'
  '-P[enable progress indicator]'
  '*:filename:_files'
)

_arguments -s -S $arguments
