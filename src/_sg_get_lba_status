#compdef sg_get_lba_status
# Documentation: https://man.archlinux.org/search?q=sg_get_lba_status
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {--brief,-b}'[a descriptor per line: <lba_hex blocks_hex p_status>]'
  {--help,-h}'[print out usage message]'
  {--hex,-H}'[output in hexadecimal]'
  '--lba[LBA starting LBA (logical block address) (def: 0)]'
  '--maxlen[LEN max response length (allocation length in cdb)]'
  {--raw,-r}'[output in binary]'
  {--verbose,-v}'[increase verbosity]'
  {--version,-V}'[print version string and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
