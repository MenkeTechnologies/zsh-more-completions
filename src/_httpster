#compdef httpster

local -a arguments

arguments=(
  {-V,--version}'[output the version number]'
  {-p,--port}'[port for server to run on - defaults to 3333]'
  {-d,--dir}'[server directory - defaults to ./]'
  {-z,--compress}'[add support for compression]'
  {-s,--pushstate}'[add support for HTML5 pushstate]'
  {-e,--env}'[add support for setting environmental variables from .env file]'
  {-b,--basic-auth}'[add support for basic auth security]'
  {-c,--cors}'[add cors support]'
  '(- * :)'{-h,--help}'[output usage information]'
  '*:filename:_files'
)

_arguments -s -S $arguments
