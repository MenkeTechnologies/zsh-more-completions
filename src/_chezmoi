#compdef chezmoi

# Zsh completion for chezmoi - manage your dotfiles across multiple machines

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'add:Add an existing file, directory, or symlink to the source state'
  'apply:Update the destination directory to match the target state'
  'archive:Generate a tar archive of the target state'
  'cat:Print the target contents of a file, script, or symlink'
  'cat-config:Print the current configuration'
  'cd:Launch a shell in the source directory'
  'chattr:Change the attributes of a source state entry'
  'completion:Generate shell completion code'
  'data:Print the template data'
  'destroy:Permanently delete an entry from the source state'
  'diff:Print the diff between the target state and the destination state'
  'docs:Print documentation'
  'doctor:Check for potential problems'
  'dump:Generate a dump of the target state'
  'dump-config:Dump the configuration'
  'edit:Edit the source state of a file'
  'edit-config:Edit the configuration file'
  'encrypt:Encrypt a file'
  'execute-template:Execute a template'
  'forget:Remove a file, directory, or symlink from the source state'
  'generate:Generate files'
  'git:Run a git command inside the source directory'
  'ignored:Print all entries ignored by chezmoi'
  'init:Setup the source directory and update the destination directory'
  'import:Import an archive into the source state'
  'license:Print the chezmoi license'
  'list:List the target state'
  'managed:List all managed entries in the destination directory'
  'merge:Perform a three-way merge between the destination state and the source state'
  'merge-all:Perform a three-way merge for each modified file'
  'purge:Purge chezmoi'\''s configuration and data'
  'remove:Remove a target in the destination directory'
  're-add:Re-add modified files'
  'secret:Interact with a secret manager'
  'source-path:Print the source path of a target'
  'state:Manipulate the persistent state'
  'status:Show the status of targets'
  'target-path:Print the target path of a source path'
  'unmanaged:List all unmanaged files in the destination directory'
  'update:Pull changes from the source VCS and apply any changes'
  'upgrade:Upgrade chezmoi to the latest released version'
  'verify:Exit with success if the destination state matches the target state'
  'help:Show help'
  'version:Print the version number of chezmoi'
)

_arguments -s -S \
  '--cache[set cache directory]:dir:_files -/' \
  '(-c --config)'{-c,--config}'[set config file]:file:_files' \
  '--config-format[set config file format]:format:(json toml yaml)' \
  '--color[use colorized output]:mode:(auto on off)' \
  '-D[set destination directory]:dir:_files -/' \
  '--destination[set destination directory]:dir:_files -/' \
  '-n[dry run, do not make any changes]' \
  '--dry-run[dry run, do not make any changes]' \
  '--force[overwrite existing targets even if the modification time has changed]' \
  '-k[keep going, even when errors occur]' \
  '--keep-going[keep going, even when errors occur]' \
  '--interactive[interactive prompting for each action]' \
  '--no-pager[do not use the pager]' \
  '--no-tty[do not attempt to read directly from the TTY]' \
  '-o[write output to file instead of stdout]:file:_files' \
  '--output[write output to file instead of stdout]:file:_files' \
  '--persistent-state[set the persistent state file]:file:_files' \
  '--progress[display progress bars (default true)]:flag:(true false)' \
  '-R[recurse into subdirectories]' \
  '--recursive[recurse into subdirectories]' \
  '--safe[use safe version of script]' \
  '-S[set source directory]:dir:_files -/' \
  '--source[set source directory]:dir:_files -/' \
  '--source-path[use source paths instead of target paths]' \
  '--use-builtin-age[use builtin age]:flag:(auto false true)' \
  '--use-builtin-git[use builtin git]:flag:(auto false true)' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '--version[print version]' \
  '-h[show help]' \
  '--help[show help]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      add|apply|cat|chattr|destroy|diff|edit|forget|managed|merge|remove|re-add|source-path|status|target-path|unmanaged|verify)
        _arguments '*:file:_files' && ret=0
        ;;
      completion)
        _arguments ':shell:(bash fish powershell zsh)' && ret=0
        ;;
    esac
    ;;
esac

return ret
