#compdef httpstat

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-H[add header]:header' \
  '-d[request data]:data' \
  '-k[allow insecure connections]' \
  '-o[write output to file]:file:_files' \
  '-L[follow redirects]' \
  '-X[request method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
  '-p[show curl primitive output]' \
  '1:url' && ret=0
return ret
