#compdef ifdtool


local -a arguments

arguments=(
    {-d,--dump}'[dump intel firmware descriptor.]'
    {-f,--layout}'[dump regions into a flashrom layout file.]'
    {-t,--validate}'[Validate that the firmware descriptor layout matches the fmap layout.]'
    {-x,--extract}'[extract intel fd modules.]'
    {-i,--inject}'[inject file <module> into region <region>.]'
    {-n,--newlayout}'[update regions using a flashrom layout file.]'
    {-O,--output}'[output filename.]'
    {-s,--spifreq}'[set the SPI frequency.]'
    {-D,--density}'[set chip density]'
    {-C,--chip}'[select spi chip to operate on]:chip'
    {-e,--em100}'[set SPI frequency to 20MHz and disable Dual Output Fast Read Support.]'
    {-l,--lock}'[Lock firmware descriptor and ME region.]'
    {-r,--read}'[Enable CPU/BIOS read access for ME region.]'
    {-u,--unlock}'[Unlock firmware descriptor and ME region.]'
    {-M,--altmedisable}'[set the MeDisable and AltMeDisable bits]'
    {-p,--platform}'[add platform-specific quirks]:platform'
    {-S,--setpchstrap}'[Write a PCH strap.]'
    {-V,--newvalue}'[The new value to write into PCH strap specified by -S.]'
    {-v,--version}'[print the version.]'
    {-h,--help}'[print this help.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
