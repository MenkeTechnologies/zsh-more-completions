#compdef oha

# Zsh completion for oha - HTTP load generator

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-n,--requests}'[number of requests to run]:number:' \
  {-c,--concurrency}'[number of connections to run concurrently]:number:' \
  {-z,--duration}'[duration of application to send requests]:duration:' \
  {-q,--query-per-second}'[rate limit per second]:rate:' \
  '--burst-delay[introduce delay between bursts]:delay:' \
  '--burst-rate[rate of burst requests]:rate:' \
  '--fps[frame per second for tui]:fps:' \
  '--latency-correction[correct latency to avoid coordinated omission]' \
  '--no-tui[no real-time TUI]' \
  {-j,--json}'[print results as JSON]' \
  '--method[HTTP method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
  {-H,--header}'[custom HTTP header]:header:' \
  {-t,--timeout}'[timeout for each request]:timeout:' \
  {-A,--accept-header}'[HTTP accept header]:accept:' \
  {-d,--body}'[HTTP request body]:body:' \
  {-D,--body-file}'[HTTP request body from file]:file:_files' \
  {-T,--content-type}'[content type header]:content-type:' \
  {-a,--basic-auth}'[basic authentication]:user\:password:' \
  '--http-version[HTTP version]:version:(0.9 1.0 1.1 2)' \
  '--http2[use HTTP/2]' \
  '--host[HTTP Host header]:host:_hosts' \
  {-p,--redirect}'[number of redirects to follow]:number:' \
  '--disable-keepalive[disable keep-alive]' \
  '--ipv6[use IPv6 only]' \
  '--ipv4[use IPv4 only]' \
  '--insecure[accept invalid certs]' \
  '--connect-to[override DNS resolution]:host\:port:' \
  '--disable-color[disable color scheme]' \
  '--unix-socket[connect to a Unix socket]:path:_files' \
  '--stats-success-breakdown[show breakdown of successful/failed requests]' \
  '*:url:_urls' \
  && return 0
