#compdef atk6-covert_send6
# Documentation: https://man.archlinux.org/search?q=atk6-covert_send6
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-m[specifies the maximum MTU (default: interface MTU, min: 1000)]'
  '-k[encrypt the content with Blowfish-160]'
  '-s[send each packet RESEND number of times, default: 1]'
  '*:filename:_files'
)

_arguments -s -S $arguments
