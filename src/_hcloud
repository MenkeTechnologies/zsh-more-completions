#compdef hcloud

# Zsh completion for hcloud (Hetzner Cloud CLI)

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'all:List all resources'
  'certificate:Manage certificates'
  'completion:Output shell completion code'
  'context:Manage contexts'
  'datacenter:Manage datacenters'
  'firewall:Manage firewalls'
  'floating-ip:Manage floating IPs'
  'image:Manage images'
  'iso:Manage ISOs'
  'load-balancer:Manage load balancers'
  'load-balancer-type:Manage load balancer types'
  'location:Manage locations'
  'network:Manage networks'
  'placement-group:Manage placement groups'
  'primary-ip:Manage primary IPs'
  'server:Manage servers'
  'server-type:Manage server types'
  'ssh-key:Manage SSH keys'
  'version:Print version information'
  'volume:Manage volumes'
)

_arguments -C \
  '--endpoint=[Hetzner Cloud API endpoint]:url:' \
  {-h,--help}'[Help for hcloud]' \
  '--poll-interval=[Interval at which to poll information]:interval:' \
  '--quiet[Only print error messages]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'hcloud command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      server)
        local -a server_cmds
        server_cmds=(
          'add-label:Add a label to a server'
          'add-to-placement-group:Add a server to a placement group'
          'attach-iso:Attach an ISO to a server'
          'attach-to-network:Attach a server to a network'
          'change-alias-ips:Change alias IPs of a server'
          'change-dns-ptr:Change reverse DNS of a server'
          'change-type:Change type of a server'
          'create:Create a server'
          'create-image:Create an image from a server'
          'delete:Delete a server'
          'describe:Describe a server'
          'detach-from-network:Detach a server from a network'
          'detach-iso:Detach an ISO from a server'
          'disable-backup:Disable backup for a server'
          'disable-protection:Disable resource protection for a server'
          'disable-rescue:Disable rescue for a server'
          'enable-backup:Enable backup for a server'
          'enable-protection:Enable resource protection for a server'
          'enable-rescue:Enable rescue for a server'
          'ip:Print a servers IP address'
          'list:List servers'
          'metrics:Get metrics for a server'
          'poweroff:Poweroff a server'
          'poweron:Poweron a server'
          'reboot:Reboot a server'
          'rebuild:Rebuild a server'
          'remove-from-placement-group:Remove a server from a placement group'
          'remove-label:Remove a label from a server'
          'request-console:Request a WebSocket VNC console for a server'
          'reset:Reset a server'
          'reset-password:Reset the root password of a server'
          'set-rdns:Change reverse DNS of a server'
          'shutdown:Shutdown a server'
          'ssh:Spawn an SSH connection for the server'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t server_cmds 'server subcommand' server_cmds && ret=0 ;;
          subargs)
            case "${line[1]}" in
              create)
                _arguments \
                  '--allow-deprecated-image[Allow deprecated images]' \
                  '--automount[Automount volumes after attach]' \
                  '--backups[Enable automatic backups]' \
                  '--datacenter=[Datacenter]:datacenter:(fsn1-dc14 nbg1-dc3 hel1-dc2 ash-dc1 hil-dc1)' \
                  '--enable-ipv4[Enable IPv4]' \
                  '--enable-ipv6[Enable IPv6]' \
                  '--firewall=[Firewall IDs or names]:firewall:' \
                  '--image=[Image ID or name]:image:' \
                  {-l,--label}'=[User-defined labels]:label:' \
                  '--location=[Location]:location:(fsn1 nbg1 hel1 ash hil)' \
                  '--name=[Server name]:name:' \
                  '--network=[Network IDs or names]:network:' \
                  '--placement-group=[Placement group]:group:' \
                  '--primary-ipv4=[Primary IPv4 address ID]:id:' \
                  '--primary-ipv6=[Primary IPv6 address ID]:id:' \
                  '--public-net-enable-ipv4[Attach server to public IPv4]' \
                  '--public-net-enable-ipv6[Attach server to public IPv6]' \
                  '--ssh-key=[SSH key IDs or names]:key:' \
                  '--start-after-create[Start server after creation]' \
                  '--type=[Server type]:type:(cx11 cx21 cx31 cx41 cx51 cpx11 cpx21 cpx31 cpx41 cpx51 cax11 cax21 cax31 cax41 ccx13 ccx23 ccx33 ccx43 ccx53 ccx63)' \
                  '--user-data-from-file=[Path to user data file]:file:_files' \
                  '--volume=[Volume IDs or names]:volume:' \
                  '--without-ipv4[Create server without IPv4]' \
                  '--without-ipv6[Create server without IPv6]' && ret=0
                ;;
              list)
                _arguments \
                  '--all[List all servers]' \
                  {-l,--label-selector}'=[Filter by label selector]:selector:' \
                  {-o,--output}'=[Output format]:format:(table json yaml noheader columns)' \
                  '--sort=[Sort by field]:field:(id name status created)' \
                  '--status=[Filter by status]:status:(initializing starting running stopping off deleting rebuilding migrating unknown)' && ret=0
                ;;
              delete)
                _arguments \
                  '1:server:' && ret=0
                ;;
              describe)
                _arguments \
                  {-o,--output}'=[Output format]:format:(json yaml)' \
                  '1:server:' && ret=0
                ;;
              ssh)
                _arguments \
                  '--port=[SSH port]:port:' \
                  '--user=[SSH user]:user:' \
                  '1:server:' && ret=0
                ;;
              rebuild)
                _arguments \
                  '--image=[Image ID or name]:image:' \
                  '1:server:' && ret=0
                ;;
              change-type)
                _arguments \
                  '--keep-disk[Keep current disk size]' \
                  '1:server:' \
                  '2:server-type:' && ret=0
                ;;
              enable-rescue)
                _arguments \
                  '--ssh-key=[SSH key IDs or names]:key:' \
                  '--type=[Rescue type]:type:(linux64 linux32)' \
                  '1:server:' && ret=0
                ;;
              create-image)
                _arguments \
                  '--description=[Image description]:description:' \
                  {-l,--label}'=[Labels]:label:' \
                  '--type=[Image type]:type:(snapshot backup)' \
                  '1:server:' && ret=0
                ;;
              metrics)
                _arguments \
                  '--end=[End time]:time:' \
                  '--start=[Start time]:time:' \
                  '--type=[Metric type]:type:(cpu disk network)' \
                  '1:server:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      network)
        local -a network_cmds
        network_cmds=(
          'add-label:Add a label to a network'
          'add-route:Add a route to a network'
          'add-subnet:Add a subnet to a network'
          'change-ip-range:Change IP range of a network'
          'create:Create a network'
          'delete:Delete a network'
          'describe:Describe a network'
          'disable-protection:Disable resource protection'
          'enable-protection:Enable resource protection'
          'expose-routes-to-vswitch:Expose routes to a vSwitch'
          'list:List networks'
          'remove-label:Remove a label from a network'
          'remove-route:Remove a route from a network'
          'remove-subnet:Remove a subnet from a network'
          'update:Update a network'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t network_cmds 'network subcommand' network_cmds && ret=0 ;;
          subargs)
            case "${line[1]}" in
              create)
                _arguments \
                  '--ip-range=[IP range]:cidr:' \
                  {-l,--label}'=[Labels]:label:' \
                  '--name=[Network name]:name:' && ret=0
                ;;
              list)
                _arguments \
                  {-l,--label-selector}'=[Label selector]:selector:' \
                  {-o,--output}'=[Output format]:format:(table json yaml noheader columns)' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      firewall)
        local -a fw_cmds
        fw_cmds=(
          'add-label:Add a label to a firewall'
          'add-rule:Add a rule to a firewall'
          'apply-to-resource:Apply a firewall to a resource'
          'create:Create a firewall'
          'delete:Delete a firewall'
          'delete-rule:Delete a rule from a firewall'
          'describe:Describe a firewall'
          'list:List firewalls'
          'remove-from-resource:Remove a firewall from a resource'
          'remove-label:Remove a label from a firewall'
          'replace-rules:Replace all rules of a firewall'
          'update:Update a firewall'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t fw_cmds 'firewall subcommand' fw_cmds && ret=0 ;;
        esac
        ;;
      volume)
        local -a vol_cmds
        vol_cmds=(
          'attach:Attach a volume to a server'
          'create:Create a volume'
          'delete:Delete a volume'
          'describe:Describe a volume'
          'detach:Detach a volume from a server'
          'disable-protection:Disable resource protection'
          'enable-protection:Enable resource protection'
          'list:List volumes'
          'resize:Resize a volume'
          'update:Update a volume'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t vol_cmds 'volume subcommand' vol_cmds && ret=0 ;;
          subargs)
            case "${line[1]}" in
              create)
                _arguments \
                  '--automount[Automount volume after attach]' \
                  '--format=[Filesystem format]:format:(ext4 xfs)' \
                  {-l,--label}'=[Labels]:label:' \
                  '--location=[Location]:location:(fsn1 nbg1 hel1 ash hil)' \
                  '--name=[Volume name]:name:' \
                  '--server=[Server to attach to]:server:' \
                  '--size=[Size in GB]:size:' && ret=0
                ;;
              list)
                _arguments \
                  '--all[List all volumes]' \
                  {-l,--label-selector}'=[Label selector]:selector:' \
                  {-o,--output}'=[Output format]:format:(table json yaml noheader columns)' \
                  '--sort=[Sort by field]:field:(id name size)' \
                  '--status=[Filter by status]:status:(creating available)' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      load-balancer)
        local -a lb_cmds
        lb_cmds=(
          'add-label:Add a label to a load balancer'
          'add-service:Add a service to a load balancer'
          'add-target:Add a target to a load balancer'
          'attach-to-network:Attach to a network'
          'change-algorithm:Change algorithm'
          'change-dns-ptr:Change reverse DNS'
          'change-type:Change type'
          'create:Create a load balancer'
          'delete:Delete a load balancer'
          'delete-service:Delete a service from a load balancer'
          'describe:Describe a load balancer'
          'detach-from-network:Detach from a network'
          'disable-protection:Disable resource protection'
          'disable-public-interface:Disable public interface'
          'enable-protection:Enable resource protection'
          'enable-public-interface:Enable public interface'
          'list:List load balancers'
          'metrics:Get metrics'
          'remove-label:Remove a label'
          'remove-target:Remove a target'
          'update:Update a load balancer'
          'update-health-check:Update health check'
          'update-service:Update a service'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t lb_cmds 'load-balancer subcommand' lb_cmds && ret=0 ;;
        esac
        ;;
      floating-ip)
        local -a fip_cmds
        fip_cmds=(
          'assign:Assign a floating IP to a server'
          'create:Create a floating IP'
          'delete:Delete a floating IP'
          'describe:Describe a floating IP'
          'disable-protection:Disable resource protection'
          'enable-protection:Enable resource protection'
          'list:List floating IPs'
          'set-rdns:Set reverse DNS'
          'unassign:Unassign a floating IP from a server'
          'update:Update a floating IP'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t fip_cmds 'floating-ip subcommand' fip_cmds && ret=0 ;;
        esac
        ;;
      primary-ip)
        local -a pip_cmds
        pip_cmds=(
          'assign:Assign a primary IP to a server'
          'changereverse-dns:Change reverse DNS'
          'create:Create a primary IP'
          'delete:Delete a primary IP'
          'describe:Describe a primary IP'
          'disable-protection:Disable resource protection'
          'enable-protection:Enable resource protection'
          'list:List primary IPs'
          'set-rdns:Set reverse DNS'
          'unassign:Unassign a primary IP from a server'
          'update:Update a primary IP'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t pip_cmds 'primary-ip subcommand' pip_cmds && ret=0 ;;
        esac
        ;;
      certificate)
        local -a cert_cmds
        cert_cmds=(
          'create:Create a certificate'
          'delete:Delete a certificate'
          'describe:Describe a certificate'
          'list:List certificates'
          'update:Update a certificate'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t cert_cmds 'certificate subcommand' cert_cmds && ret=0 ;;
        esac
        ;;
      ssh-key)
        local -a key_cmds
        key_cmds=(
          'add-label:Add a label to an SSH key'
          'create:Create a SSH key'
          'delete:Delete a SSH key'
          'describe:Describe a SSH key'
          'list:List SSH keys'
          'remove-label:Remove a label from a SSH key'
          'update:Update a SSH key'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t key_cmds 'ssh-key subcommand' key_cmds && ret=0 ;;
          subargs)
            case "${line[1]}" in
              create)
                _arguments \
                  {-l,--label}'=[Labels]:label:' \
                  '--name=[SSH key name]:name:' \
                  '--public-key=[Public key]:key:' \
                  '--public-key-from-file=[Path to public key file]:file:_files' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      image)
        local -a image_cmds
        image_cmds=(
          'add-label:Add a label to an image'
          'delete:Delete an image'
          'describe:Describe an image'
          'disable-protection:Disable resource protection'
          'enable-protection:Enable resource protection'
          'list:List images'
          'remove-label:Remove a label from an image'
          'update:Update an image'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t image_cmds 'image subcommand' image_cmds && ret=0 ;;
          subargs)
            case "${line[1]}" in
              list)
                _arguments \
                  '--architecture=[Filter by architecture]:arch:(x86 arm)' \
                  {-l,--label-selector}'=[Label selector]:selector:' \
                  {-o,--output}'=[Output format]:format:(table json yaml noheader columns)' \
                  '--sort=[Sort by field]:field:(id name created)' \
                  '--type=[Filter by type]:type:(system snapshot backup app)' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      placement-group)
        local -a pg_cmds
        pg_cmds=(
          'add-label:Add a label to a placement group'
          'create:Create a placement group'
          'delete:Delete a placement group'
          'describe:Describe a placement group'
          'list:List placement groups'
          'remove-label:Remove a label from a placement group'
          'update:Update a placement group'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t pg_cmds 'placement-group subcommand' pg_cmds && ret=0 ;;
        esac
        ;;
      context)
        local -a ctx_cmds
        ctx_cmds=(
          'active:Show active context'
          'create:Create a new context'
          'delete:Delete a context'
          'list:List contexts'
          'use:Use a context'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t ctx_cmds 'context subcommand' ctx_cmds && ret=0 ;;
        esac
        ;;
      datacenter)
        local -a dc_cmds
        dc_cmds=(
          'describe:Describe a datacenter'
          'list:List datacenters'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t dc_cmds 'datacenter subcommand' dc_cmds && ret=0 ;;
        esac
        ;;
      location)
        local -a loc_cmds
        loc_cmds=(
          'describe:Describe a location'
          'list:List locations'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t loc_cmds 'location subcommand' loc_cmds && ret=0 ;;
        esac
        ;;
      server-type)
        local -a st_cmds
        st_cmds=(
          'describe:Describe a server type'
          'list:List server types'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t st_cmds 'server-type subcommand' st_cmds && ret=0 ;;
        esac
        ;;
      iso)
        local -a iso_cmds
        iso_cmds=(
          'describe:Describe an ISO'
          'list:List ISOs'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t iso_cmds 'iso subcommand' iso_cmds && ret=0 ;;
        esac
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
