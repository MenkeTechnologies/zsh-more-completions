#compdef nvim

# Zsh completion for nvim (Neovim text editor)

_nvim() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -s -S \
        '-t+[edit file where tag is defined]:tag:' \
        '-q+[start in quickfix mode]:error file:_files' \
        '-e[ex mode]' \
        '-E[improved ex mode]' \
        '-s[silent (batch) mode]' \
        '-d[diff mode]' \
        '-R[readonly mode]' \
        '-Z[restricted mode]' \
        '-m[modifications (writing files) not allowed]' \
        '-M[modifications in text not allowed]' \
        '-b[binary mode]' \
        '-l[Lua mode]' \
        '-n[no swap file, use memory only]' \
        '-o+[open N windows (default: one for each file)]:number:' \
        '-O+[open N windows split vertically]:number:' \
        '-p+[open N tab pages (default: one for each file)]:number:' \
        '(-L)-r[recover crashed session / list swap files]:swap file:_files' \
        '(-r)-L[same as -r]:swap file:_files' \
        '-u+[use specified vimrc file instead of default]:vimrc:_files' \
        '-i+[use specified shada file instead of default]:shada file:_files' \
        '--noplugin[do not load plugins]' \
        '--clean[factory defaults (skip vimrc, plugins, shada)]' \
        '*-c+[execute command after loading first file]:command:' \
        '*--cmd+[execute command before loading any vimrc]:command:' \
        '*-S+[source file after loading first file]:file:_files' \
        '-w+[record all typed characters to file]:script file:_files' \
        '-W+[record all typed characters to file (overwrite)]:script file:_files' \
        '--startuptime+[write startup timing messages to file]:file:_files' \
        '--api-info[print API metadata serialized as msgpack and exit]' \
        '--embed[use stdin/stdout as a msgpack-rpc channel]' \
        '--headless[do not start a UI]' \
        '--listen+[serve RPC API from this address]:address:' \
        '--remote[edit files on a running Nvim server]' \
        '--server+[specify Nvim server to send commands to]:address:' \
        '(- *)'{-h,--help}'[print help message and exit]' \
        '(- *)'{-v,--version}'[print version information and exit]' \
        '-V+[set verbose level]:level:' \
        '--luamod-dev[run in Lua module development mode]' \
        '*:file:_files'
}

_nvim "$@"
