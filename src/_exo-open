#compdef exo-open
# Documentation: https://man.archlinux.org/search?q=exo-open
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-V,--version}'[print version information and exit]'
  '--launch[\[PARAMETERs...\]       Launch the preferred application of]'
  '--working-directory[default working directory for applications]'
  '*:filename:_files'
)

_arguments -s -S $arguments
