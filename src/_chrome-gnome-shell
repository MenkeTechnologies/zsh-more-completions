#compdef chrome-gnome-shell
# Documentation: https://man.archlinux.org/search?q=chrome-gnome-shell
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  '--help-all[show all help options]'
  '*:filename:_files'
)

_arguments -s -S $arguments
