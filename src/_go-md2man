#compdef go-md2man
# Documentation: https://man.archlinux.org/search?q=go-md2man
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-in[path to file to be processed (default: stdin)]'
  '-out[path to output processed file (default: stdout)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
