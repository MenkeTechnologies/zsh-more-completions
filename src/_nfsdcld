#compdef nfsdcld


local -a arguments

arguments=(
    {-d,--debug}'[Enable debug level logging.]'
    {-F,--foreground}'[Runs the daemon in the foreground and prints all output to stderr.]'
    {-p,--pipefsdir}'[Location of the rpc_pipefs filesystem.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
