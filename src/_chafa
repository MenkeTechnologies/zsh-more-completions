#compdef chafa

# Zsh completion for chafa - terminal image viewer

_arguments \
  '--help[show help message]' \
  '--version[show version]' \
  '(-c --colors)'{-c,--colors}'[set number of colors]:colors:(2 8 16 240 256 full none)' \
  '--color-extractor[set color extractor]:extractor:(average median)' \
  '--color-space[set color space]:space:(din99d rgb)' \
  '(-d --duration)'{-d,--duration}'[set animation duration in seconds]:seconds:' \
  '--dither[set dither mode]:mode:(none character ordered diffusion)' \
  '--dither-grain[set dither grain size]:WxH:' \
  '--dither-intensity[set dither intensity]:intensity:' \
  '(-f --format)'{-f,--format}'[set output format]:format:(symbols sixels kitty iterm)' \
  '--font-ratio[set font ratio]:W/H:' \
  '(-O --optimize)'{-O,--optimize}'[set optimization level]:level:' \
  '--polite[polite mode]:toggle:(on off)' \
  '--preprocess[enable preprocessing]:toggle:(on off)' \
  '(-s --size)'{-s,--size}'[set output size]:WxH:' \
  '--speed[set animation speed]:speed:' \
  '--stretch[stretch image to fit]' \
  '--symbols[set symbol selection]:symbols:' \
  '--fill[set fill symbol selection]:symbols:' \
  '(-t --threshold)'{-t,--threshold}'[set transparency threshold]:threshold:' \
  '--watch[watch file for changes]' \
  '(-w --work)'{-w,--work}'[set processing intensity]:level:(1 2 3 4 5 6 7 8 9)' \
  '--animate[enable animation]:toggle:(on off)' \
  '--center[center output]:toggle:(on off)' \
  '--clear[clear screen before output]' \
  '--fg-only[use foreground colors only]' \
  '--invert[invert colors]' \
  '--margin-bottom[set bottom margin]:lines:' \
  '--margin-right[set right margin]:columns:' \
  '--passthrough[set passthrough mode]:mode:(auto on off)' \
  '--scale[set scale mode]:mode:(max fit)' \
  '--view-size[set view size]:WxH:' \
  '*:image file:_files'
