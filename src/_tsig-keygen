#compdef tsig-keygen
# Documentation: https://man.archlinux.org/search?q=tsig-keygen
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-a[algorithm (default hmac-sha256)]'
  '-r[source of random data (use "keyboard" for key timing)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
