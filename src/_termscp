#compdef termscp

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-b --address)'{-b,--address}'[bind address]:address' \
  '(-P --port)'{-P,--port}'[port number]:port' \
  '(-c --config)'{-c,--config}'[config file path]:config file:_files' \
  '(-e --explorer)'{-e,--explorer}'[explorer path]:path:_files -/' \
  '(-p --password)'{-p,--password}'[password]:password' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-T --ticks)'{-T,--ticks}'[set tick interval in ms]:milliseconds' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:connection string (protocol\://user@host\:port\:path)' && ret=0
return ret
