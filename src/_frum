#compdef frum

# Zsh completion for frum - fast Ruby version manager written in Rust

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'init:set up frum for the shell'
  'install:install a Ruby version'
  'uninstall:uninstall a Ruby version'
  'versions:list all installed Ruby versions'
  'local:set the current directory Ruby version'
  'global:set the global Ruby version'
)

_arguments -s -S \
  '1:subcommand:->subcmd' \
  '*::args:->args' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'frum subcommand' subcommands && ret=0
    ;;
  (args)
    local -a installed_versions
    installed_versions=( ${(f)"$(command frum versions 2>/dev/null)"} )

    case ${line[1]} in
      (install)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--with-openssl-dir[set openssl directory]:directory:_files -/' \
          '--jobs[number of make jobs]:number:' \
          '1:Ruby version:' && ret=0
        ;;
      (uninstall)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:installed version:(${installed_versions})' && ret=0
        ;;
      (local|global)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:version:(${installed_versions})' && ret=0
        ;;
      (init)
        _arguments \
          '--shell[specify shell]:shell:(zsh bash fish)' && ret=0
        ;;
      (versions)
        _arguments '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
