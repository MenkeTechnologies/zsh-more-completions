#compdef grolbp

local -a arguments

arguments=(
  {-o,--orientation}'[set page orientation]:orientation:(portrait landscape)'
  {-v,--version}'[show version information]'
  {-c,--copies}'[set number of copies]:copies:'
  {-l,--landscape}'[use landscape orientation]'
  {-p,--papersize}'[set paper size]:size:'
  {-w,--linewidth}'[set default line width]:width:'
  {-F,--fontdir}'[set font directory]:directory:_directories'
  '(- * :)'{-h,--help}'[show help information]'
  '*:filename:_files'
)

_arguments -s -S $arguments
