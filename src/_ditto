#compdef ditto

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show full usage]' \
  '-v[print a status line for each source]' \
  '-V[print a status line for every file]' \
  '-X[do not descend into different device]' \
  '-c[create an archive at dst]' \
  '-x[src(s) are archives]' \
  '-z[use gzip when compressing CPIO archive]' \
  '-j[use bzip2 when compressing CPIO archive]' \
  '-k[create archive in PKZip format]' \
  '--keepParent[embed parent directory name of src]' \
  '*--arch=[thin fat files to architecture]:arch:(arm64 x86_64 i386 ppc)' \
  '--bom=[copy only objects present in index bom]:file:_files' \
  '*--lang=[filter index bom by language]:lang:' \
  '--outBom=[create output bom of matched paths]:file:_files' \
  '--rsrc[preserve resource data]' \
  '--norsrc[do not preserve resource data]' \
  '--extattr[preserve extended attributes]' \
  '--noextattr[do not preserve extended attributes]' \
  '--qtn[preserve quarantine information]' \
  '--noqtn[do not preserve quarantine information]' \
  '--acl[preserve ACLs]' \
  '--noacl[do not preserve ACLs]' \
  '--sequesterRsrc[copy resources via __MACOSX (PKZip only)]' \
  '--zlibCompressionLevel=[PKZip compression level]:n:' \
  '--password[request password for encrypted PKZip]' \
  '--hfsCompression[compress files at destination]' \
  '--nohfsCompression[do not compress files at destination]' \
  '--preserveHFSCompression[preserve fs compression when copying]' \
  '--nopreserveHFSCompression[do not preserve fs compression]' \
  '--nocache[do not use filesystem cache]' \
  '--nonAtomicCopies[do not perform atomic copies]' \
  '--segmentLargeFiles[segment files >8GB into multiple CPIO entries]' \
  '--persistRootless[persist SF_RESTRICTED flag]' \
  '--nopersistRootless[do not persist SF_RESTRICTED flag]' \
  '--keepBinaries[set aside original Mach-O when replaced]' \
  '--keepBinariesList=[record kept binaries in file]:file:_files' \
  '--keepBinariesPattern=[only keep files matching regex]:regex:' \
  '--clone[attempt to clone files when copying]' \
  '--noclone[do not attempt to clone files]' \
  '*:source / destination:_files' && ret=0

return ret
