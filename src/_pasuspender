#compdef pasuspender
# Documentation: https://man.archlinux.org/search?q=pasuspender
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help]'
  '--version[show version]'
  {-s,--server}'[the name of the server to connect to]'
  '*:filename:_files'
)

_arguments -s -S $arguments
