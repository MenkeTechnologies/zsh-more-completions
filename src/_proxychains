#compdef proxychains
# Documentation: https://man.archlinux.org/search?q=proxychains
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-q[proxychains quiet - this overrides the config setting]'
  '-f[one to manually specify a configfile to use]'
  '*:filename:_files'
)

_arguments -s -S $arguments
