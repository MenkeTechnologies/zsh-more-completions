#compdef free

# Zsh completion for free (procps-ng) - display amount of free and used memory

local -a arguments

arguments=(
  '(- *)'{-V,--version}'[output version information and exit]'
  '(- *)--help[display help and exit]'
  '(-b --bytes -k --kilo -m --mega -g --giga --tera --peta -h --human --si)'{-b,--bytes}'[show output in bytes]'
  '(-b --bytes -k --kilo -m --mega -g --giga --tera --peta -h --human --si)'{-k,--kilo}'[show output in kilobytes]'
  '(-b --bytes -k --kilo -m --mega -g --giga --tera --peta -h --human --si)'{-m,--mega}'[show output in megabytes]'
  '(-b --bytes -k --kilo -m --mega -g --giga --tera --peta -h --human --si)'{-g,--giga}'[show output in gigabytes]'
  '(-b --bytes -k --kilo -m --mega -g --giga --tera --peta -h --human --si)--tera[show output in terabytes]'
  '(-b --bytes -k --kilo -m --mega -g --giga --tera --peta -h --human --si)--peta[show output in petabytes]'
  '(-b --bytes -k --kilo -m --mega -g --giga --tera --peta -h --human --si)'{-h,--human}'[show human-readable output (automatic unit scaling)]'
  '(-b --bytes -k --kilo -m --mega -g --giga --tera --peta -h --human --si)--si[use powers of 1000 instead of 1024]'
  {-l,--lohi}'[show detailed low and high memory statistics]'
  {-t,--total}'[show total for RAM + swap]'
  {-s,--seconds}'[repeat printing every N seconds]:interval (seconds)'
  {-c,--count}'[repeat printing N times, then exit]:count'
  {-w,--wide}'[wide output (swap split into used/free)]'
  '--committed[show committed memory and commit limit]'
  '-L[show line per NUMA node]'
)

_arguments -s -S $arguments
