#compdef tcsd_emu
# Documentation: https://man.archlinux.org/search?q=tcsd_emu
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-f,--foreground}'[run in the foreground. Logging goes to stderr instead of syslog.]'
  '-e[attempts to connect to software TPMs over TCP]'
  {-c,--config}'[path to configuration file]:file:_files'
  {-h,--help}'[display this help message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
