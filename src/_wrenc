#compdef wrenc
# Documentation: https://man.archlinux.org/search?q=wrenc
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[print wrenc command line options]'
  {-v,--version}'[print wrenc and Wren version]'
  '-e[      evaluate code]'
  '*:filename:_files'
)

_arguments -s -S $arguments
