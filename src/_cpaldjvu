#compdef cpaldjvu
# Documentation: https://man.archlinux.org/search?q=cpaldjvu
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-colors[2-4096\] Maximum number of colors during quantization (default 256).]'
  '-dpi[25-6000\] Resolution written into the output file (default 100).]'
  '-verbose[displays additional messages.]'
  '-bgwhite[use the lightest color for background (usually white).]'
  '*:filename:_files'
)

_arguments -s -S $arguments
