#compdef urlbst
# Documentation: https://man.archlinux.org/search?q=urlbst
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--nohyperlinks[do not include active links anywhere]'
  '--hypertex[include HyperTeX-style hyperlink support]'
  '--hyperref[include {hyperref}-style hyperlink support]'
  '--literal[value set one of the literal strings]'
  '--help[print this help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
