#compdef hub-tool
# Documentation: https://man.archlinux.org/search?q=hub-tool
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[help for /usr/local/bin/hub-tool]'
  '--verbose[print logs]'
  '--version[display the version of this tool]'
  '*:filename:_files'
)

_arguments -s -S $arguments
