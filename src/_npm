            '(-S --save)'{-S,--save}'[save updated versions to package.json]' \
            '--no-save[do not save to package.json]' \
            '(--global -g)'{--global,-g}'[update global packages]' \
            '--install-strategy[set the strategy for installing packages]:strategy:(hoisted nested shallow linked)' \
            '--legacy-bundling[install in legacy bundled way]' \
            '--global-style[only install direct deps in top level node_modules]' \
            '--omit[dependency types to omit]:type:(dev optional peer)' \
