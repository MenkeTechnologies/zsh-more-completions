    args)
      case $line[1] in
        install|i|add)
          _arguments -s \
            '(-S --save)'{-S,--save}'[package will appear in your dependencies]' \
            '--no-save[prevents saving to dependencies]' \
            '--save-prod[package will appear in your dependencies]' \
            '(-D --save-dev)'{--save-dev,-D}'[package will appear in your devDependencies]' \
            '(-O --save-optional)'{--save-optional,-O}'[package will appear in your optionalDependencies]' \
            '--save-peer[package will appear in your peerDependencies]' \
            '--save-bundle[package will also be added to your bundleDependencies]' \
            '(-E --save-exact)'{--save-exact,-E}'[saved dependencies will be configured with an exact version]' \
            '(--global -g)'{--global,-g}'[install the package globally]' \
            '--install-strategy[set the strategy for installing packages in node_modules]:strategy:(hoisted nested shallow linked)' \
            '--legacy-bundling[install packages in the legacy bundled way]' \
            '--global-style[only install direct dependencies in the top level node_modules]' \
            '--omit[dependency types to omit from the installation tree]:type:(dev optional peer)' \
            '--include[dependency types to include in the installation tree]:type:(prod dev optional peer)' \
            '--strict-peer-deps[fail and abort for any conflicting peerDependencies]' \
            '--prefer-dedupe[prefer to deduplicate packages if possible]' \
            '--no-package-lock[do not read or generate a package-lock.json file]' \
            '--package-lock-only[only update the package-lock.json]' \
            '--foreground-scripts[run all build scripts in the foreground]' \
            '--ignore-scripts[do not run any scripts defined in the package.json]' \
            '--allow-git[limits the ability to fetch dependencies from git references]:mode:(all none root)' \
            '--no-audit[disable sending audit reports]' \
            '--before[only install packages published before this date]:date:' \
            '--min-release-age[only install versions published at least this many days ago]:days:' \
