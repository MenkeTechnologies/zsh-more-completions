          ;;

        test|tst|t|start|stop|restart)
          _arguments \
            '--ignore-scripts[do not run any scripts]' \
            '--script-shell[the shell to use for scripts]:shell:_command_names' \
            '*:args:'
          ;;

        help)
          local -a help_topics
          help_topics=(
            access adduser audit bugs cache ci completion config
            dedupe deprecate diff dist-tag docs doctor edit exec
            explain explore find-dupes fund help help-search hook
            init install install-ci-test install-test link ll
            login logout ls org outdated owner pack ping pkg
            prefix profile prune publish query rebuild repo
            restart root run sbom search shrinkwrap star stars
            start stop team test token trust undeprecate uninstall
            unpublish unstar update version view whoami
          )
          _arguments '1:command:($help_topics)'
          ;;

        view|info|show)
          _arguments -s \
            '--json[output as JSON]' \
            '(--workspace -w)'{--workspace,-w}'[run in the context of the given workspace]:workspace:' \
            '--workspaces[run in the context of all workspaces]' \
            '--include-workspace-root[include the workspace root]' \
            '*:package:'
          ;;

        unpublish)
          _arguments -s \
            '(--force -f)'{--force,-f}'[remove all versions]' \
            '--dry-run[show what would be done]' \
            '*:package:'
          ;;

        deprecate)
          _arguments \
            '--registry[the base URL of the npm registry]:url:' \
            '--otp[one-time password]:otp:' \
            '1:package@version:' \
            '2:message:'
          ;;

        undeprecate)
          _arguments -s \
            '--registry[the base URL of the npm registry]:url:' \
            '--otp[one-time password]:otp:' \
            '--dry-run[show what would be done]' \
            '1:package@version:'
          ;;

        trust)
          _arguments -C \
            '1:subcommand:(github gitlab circleci list revoke)' \
            '*:args:'
          ;;

        owner|author)
          _arguments -C \
            '1:subcommand:(add rm ls)' \
            '*:package:'
          ;;

        token)
          _arguments -C \
            '1:subcommand:(list create revoke)' \
            '--read-only[mark the token as unable to publish]' \
            '--cidr[list of CIDR address to limit]:cidr:'
          ;;

        team)
          _arguments -C \
            '1:subcommand:(create destroy add rm ls)' \
            '*:args:'
          ;;

        profile)
          _arguments -C \
            '1:subcommand:(get set enable-2fa disable-2fa)' \
            '*:args:'
          ;;

        pkg)
          _arguments -C \
            '1:subcommand:(get set delete fix)' \
            '*:args:'
          ;;

        access)
          _arguments -C \
            '1:subcommand:(list get set grant revoke)' \
            '*:args:'
          ;;

        hook)
          _arguments -C \
            '1:subcommand:(add ls update rm)' \
            '*:args:'
          ;;

        org)
          _arguments -C \
            '1:subcommand:(set rm ls)' \
            '*:args:'
          ;;

        query)
          _arguments -s \
            '(--global -g)'{--global,-g}'[operate in global mode]' \
            '(--workspace -w)'{--workspace,-w}'[run in the context of the given workspace]:workspace:' \
            '--workspaces[run in the context of all workspaces]' \
            '--include-workspace-root[include the workspace root]' \
            '--package-lock-only[only use the package-lock.json]' \
            '--expect-results[tell npm whether to expect results from the command]' \
            '--expect-result-count[tell npm the expected number of results]:count:' \
            '1:selector:'
          ;;

        diff)
          _arguments -s \
            '*--diff[packages to diff]:package:' \
            '--diff-name-only[prints only file names]' \
            '--diff-unified[number of lines of context]:lines:' \
            '--diff-ignore-all-space[ignore whitespace]' \
            '--diff-no-prefix[do not show any source or destination prefix]' \
            '--diff-src-prefix[source prefix]:prefix:' \
            '--diff-dst-prefix[destination prefix]:prefix:' \
            '--diff-text[treat all files as text]' \
            '(--global -g)'{--global,-g}'[operate in global mode]' \
            '--tag[the tag to compare against]:tag:' \
            '(--workspace -w)'{--workspace,-w}'[run in the context of the given workspace]:workspace:' \
            '--workspaces[run in the context of all workspaces]' \
            '--include-workspace-root[include the workspace root]'
          ;;

        explain|why)
          _arguments '*:package:_npm_installed_packages'
          ;;

        *)
          _default
          ;;
      esac
      ;;
  esac
}

_npm "$@"
