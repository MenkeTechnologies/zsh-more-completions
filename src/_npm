#compdef npm npx

# Zsh completion for npm (Node Package Manager)
# Compatible with npm v10/v11

_npm_installed_packages() {
  local -a packages
  packages=(${(f)"$(npm ls --depth=0 --parseable 2>/dev/null | tail -n +2 | xargs -I{} basename {})"})
  _describe 'installed packages' packages
}

_npm_run_scripts() {
  local -a scripts
  if [[ -f package.json ]]; then
    scripts=(${(f)"$(node -e "try{Object.keys(require('./package.json').scripts||{}).forEach(s=>console.log(s))}catch(e){}" 2>/dev/null)"})
  fi
  _describe 'scripts' scripts
}

_npm_config_keys() {
  local -a keys
  keys=(${(f)"$(npm config ls -l 2>/dev/null | sed -n 's/^\([a-z_-]*\) = .*/\1/p')"})
  _describe 'config keys' keys
}

_npm_cache_commands() {
  local -a cmds
  cmds=(
    'add:add the specified packages to the local cache'
    'clean:delete all data out of the cache folder'
    'ls:show the data in the cache'
    'verify:verify the contents of the cache folder'
    'npx:manage the npx cache'
  )
  _describe 'cache command' cmds
}

_npm_config_commands() {
  local -a cmds
  cmds=(
    'set:set a config key to a value'
    'get:echo a config value to stdout'
    'delete:delete a key from all configuration files'
    'list:show all the config settings'
    'edit:open an editor to modify the npmrc file'
    'fix:attempt to repair invalid configuration items'
  )
  _describe 'config command' cmds
}

_npm_version_bumps() {
  local -a bumps
  bumps=(
    'major:bump the major version'
    'minor:bump the minor version'
    'patch:bump the patch version'
    'premajor:bump to premajor version'
    'preminor:bump to preminor version'
    'prepatch:bump to prepatch version'
    'prerelease:bump to prerelease version'
    'from-git:use version from git tag'
  )
  _describe 'version bump' bumps
}

_npm_audit_levels() {
  local -a levels
  levels=(info low moderate high critical none)
  _describe 'audit level' levels
}

_npm() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a global_flags
  global_flags=(
    '--registry[the base URL of the npm registry]:url:'
    '--loglevel[what level of logs to report]:level:(silent error warn notice http timing info verbose silly)'
    '--json[output JSON data]'
    '(--long -l)'{--long,-l}'[show extended information]'
    '(--global -g)'{--global,-g}'[operate in global mode]'
    '(--workspace -w)'{--workspace,-w}'[enable running in the context of the given workspace]:workspace:'
    '--workspaces[run the command in the context of all workspaces]'
    '--include-workspace-root[include the workspace root when workspaces are enabled]'
    '--color[controls color output]:color:(true false always)'
    '--no-color[disable color output]'
    '--unicode[controls unicode output]'
    '--no-unicode[disable unicode output]'
    '--otp[one-time password for two-factor authentication]:otp:'
    '--auth-type[authentication strategy]:type:(legacy web)'
    '--call[companion option for npm exec]:command:'
    '--dry-run[report what would be done without actually doing it]'
    '--ignore-scripts[do not run any scripts defined in package.json]'
    '--foreground-scripts[run all build scripts in the foreground]'
    '--script-shell[the shell to use for scripts]:shell:_command_names'
  )

  _arguments -C \
    $global_flags \
    '1:command:->command' \
    '*::arg:->args' && return 0

  case $state in
    command)
      local -a commands
      commands=(
        'access:set access level on published packages'
        'adduser:add a registry user account'
        'login:add a registry user account'
        'audit:run a security audit'
        'bugs:report bugs for a package in a web browser'
        'cache:manipulates packages cache'
        'ci:clean install a project'
        'completion:tab completion for npm'
        'config:manage the npm configuration files'
        'c:manage the npm configuration files'
        'set:set a config key to a value'
        'get:get a config value'
        'dedupe:reduce duplication in the package tree'
        'deprecate:deprecate a version of a package'
        'diff:the registry diff command'
        'dist-tag:modify package distribution tags'
        'docs:open documentation for a package in a web browser'
        'home:open documentation for a package in a web browser'
        'doctor:check your npm environment'
        'edit:edit an installed package'
        'exec:run a command from a local or remote npm package'
        'x:run a command from a local or remote npm package'
        'explain:explain installed packages'
        'why:explain installed packages'
        'explore:browse an installed package'
        'find-dupes:find duplication in the package tree'
        'fund:retrieve funding information'
        'help:get help on npm'
        'help-search:search npm help documentation'
        'hook:manage registry hooks'
        'init:create a package.json file'
        'create:create a package.json file'
        'install:install a package'
        'i:install a package'
        'add:install a package'
        'install-ci-test:install and test a project'
        'cit:install and test a project'
        'install-test:install and test a package'
        'it:install and test a package'
        'link:symlink a package folder'
        'ln:symlink a package folder'
        'll:list installed packages with details'
        'la:list installed packages with details'
        'logout:log out of the registry'
        'ls:list installed packages'
        'list:list installed packages'
        'org:manage orgs'
        'outdated:check for outdated packages'
        'owner:manage package owners'
        'author:manage package owners'
        'pack:create a tarball from a package'
        'ping:ping npm registry'
        'pkg:manages your package.json'
        'prefix:display prefix'
        'profile:change settings on your registry profile'
        'prune:remove extraneous packages'
        'publish:publish a package'
        'query:retrieve a filtered list of packages'
        'rebuild:rebuild a package'
        'rb:rebuild a package'
        'repo:open package repository page in the browser'
        'restart:restart a package'
        'root:display npm root'
        'run-script:run arbitrary package scripts'
        'run:run arbitrary package scripts'
        'sbom:generate a software bill of materials'
        'search:search for packages'
        's:search for packages'
        'find:search for packages'
        'se:search for packages'
        'shrinkwrap:lock down dependency versions for publication'
        'star:mark your favorite packages'
        'stars:view packages marked as favorites'
        'start:start a package'
        'stop:stop a package'
        'team:manage organization teams and team memberships'
        'test:test a package'
        'tst:test a package'
        't:test a package'
        'token:manage your authentication tokens'
        'trust:manage trusted relationships with CI/CD providers'
        'undeprecate:undeprecate a version of a package'
        'uninstall:remove a package'
        'remove:remove a package'
        'rm:remove a package'
        'r:remove a package'
        'un:remove a package'
        'unlink:remove a package'
        'unpublish:remove a package from the registry'
        'unstar:remove an item from your favorite packages'
        'update:update packages'
        'up:update packages'
        'upgrade:update packages'
        'version:bump a package version'
