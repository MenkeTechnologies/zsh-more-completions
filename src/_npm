            '--include-workspace-root[include the workspace root]' \
            '--ignore-scripts[do not run any scripts]' \
            '1:bump:_npm_version_bumps'
          ;;

        init|create)
          _arguments -s \
            '--init-author-name[default author name]:name:' \
            '--init-author-url[default author URL]:url:' \
            '--init-license[default license]:license:' \
            '--init-module[module loaded by npm init]:module:_files' \
