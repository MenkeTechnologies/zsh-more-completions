            '--editor[editor to use with edit subcommand]:editor:_command_names' \
            '(-L --location)'{-L,--location}'[which config file to use]:location:(global user project)' \
            '(-l --long)'{-l,--long}'[show extended information]' \
            '1:config command:_npm_config_commands' \
