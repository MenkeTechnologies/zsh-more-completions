        outdated)
          _arguments -s \
            '(--all -a)'{--all,-a}'[show all outdated or installed packages]' \
            '--json[output as JSON]' \
            '(--long -l)'{--long,-l}'[show extended information]' \
            '(-p --parseable)'{-p,--parseable}'[output parseable results]' \
            '(--global -g)'{--global,-g}'[check global packages]' \
            '(--workspace -w)'{--workspace,-w}'[check in the context of the given workspace]:workspace:' \
            '--before[only consider packages published before this date]:date:' \
            '--min-release-age[only consider versions at least this many days old]:days:' \
