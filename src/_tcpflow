#compdef tcpflow

local -a arguments

arguments=(
  '-a[do ALL post-processing.]'
  '-b[max number of bytes per flow to save]:bytes:'
  '-d[debug level; default is 1]:level:'
  '-f[maximum number of file descriptors to use]:count:'
  '-h[print this help message (-hh for more help)]'
  '-H[print detailed information about each scanner]'
  '-i[network interface on which to listen]:interface:'
  '-I[write for each flow another file *.findx to provide byte-indexed timestamps]'
  '-g[output each flow in alternating colors (note change!)]'
  '-l[treat non-flag arguments as input files rather than a pcap expression]'
  '-L[specifies that writes are locked using a named semaphore]:semlock:'
  '-p[dont use promiscuous mode]'
  '-q[quiet mode - do not print warnings]'
  '-r[read packets from tcpdump pcap file (may be repeated)]:file:_files'
  '-R[read packets from tcpdump pcap file TO FINISH CONNECTIONS]:file:_files'
  '-v[verbose operation equivalent to -d 10]'
  '-V[print version number and exit]'
  '-w[write packets not processed to file]:file:_files'
  '-o[specify output directory (default .)]:directory:_directories'
  '-X[DFXML output to filename]:file:_files'
  '-m[specifies skip that starts a new stream (default 16777216)]:bytes:'
  '-F[filename prefix/suffix (-hh for options)]:format:'
  '-T[filename template (-hh for options)]:template:'
  '-Z[do not decompress gzip-compressed HTTP transactions]'
  '-U[relinquish privileges and become user (if running as root)]:user:_users'
  '-z[chroot to dir (requires that -U be used)]:directory:_directories'
  '-E[turn off all scanners except scanner]:scanner:'
  '-S[set a configuration parameter (-hh for info)]:name=value:'
  '-B[binary output, even with -c or -C (normally -c or -C turn it off)]'
  '-c[console print only (dont create files)]'
  '-C[console print only, but without the display of source/dest header]'
  '-0[dont print newlines after packets when printing to console]'
  '-s[strip non-printable characters (change to .)]'
  '-D[output in hex (useful to combine with -c or -C)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
