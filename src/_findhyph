#compdef findhyph
# Documentation: https://man.archlinux.org/search?q=findhyph
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-f[display font selectors]'
  '-h[display this help message]'
  '-v[display version]'
  '-p[generate file with prepositions left at the end of line]'
  '-l[use prepositions/conjunctions listed in STRING]'
  '*:filename:_files'
)

_arguments -s -S $arguments
