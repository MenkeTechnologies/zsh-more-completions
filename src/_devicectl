#compdef devicectl

local -a subcommands

subcommands=(
    'list:List available devices'
    'manage:Manage device configurations'
    'device:Device-specific operations'
)

local -a device_subcommands
device_subcommands=(
    'install:Install an app on a device'
    'uninstall:Uninstall an app from a device'
    'process:Manage processes on a device'
    'info:Show device information'
    'pair:Pair with a device'
    'unpair:Unpair a device'
    'console:Stream device console output'
    'shutdown:Shut down a device'
    'restart:Restart a device'
    'reboot:Reboot a device'
)

_arguments -s -S \
    '--help[Show help information]' \
    '--version[Show version]' \
    '--device[Specify device by name or UDID]:device name or UDID' \
    '--quiet[Suppress output]' \
    '--json-output[Output results as JSON]:output file:_files' \
    '--timeout[Operation timeout in seconds]:seconds' \
    '1:subcommand:->subcmd' \
    '*:: :->args' && return

case $state in
    subcmd)
        _describe 'devicectl subcommand' subcommands
        ;;
    args)
        case $words[1] in
            list)
                _arguments \
                    '--filter[Filter devices]:filter expression' \
                    '1:list target:(devices apps)'
                ;;
            device)
                _describe 'device subcommand' device_subcommands
                ;;
            manage)
                _arguments \
                    '1:manage target:(pair unpair)'
                ;;
        esac
        ;;
esac
