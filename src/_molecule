#compdef molecule

# Zsh completion for molecule - Ansible role testing tool

local -a subcmds
local line state

subcmds=(
  'check:use the provisioner to perform a dry-run'
  'cleanup:use the provisioner to cleanup changes'
  'converge:use the provisioner to configure instances'
  'create:use the provisioner to start instances'
  'dependency:manage role dependencies'
  'destroy:use the provisioner to destroy instances'
  'drivers:list available drivers'
  'idempotence:use the provisioner to test idempotence'
  'init:initialize a new role or scenario'
  'lint:lint the role'
  'list:list status of instances'
  'login:log in to one of the instances'
  'matrix:list matrix of steps used to test instances'
  'prepare:use the provisioner to prepare instances'
  'reset:reset molecule temporary directories'
  'side-effect:use the provisioner to perform side-effects'
  'syntax:use the provisioner to syntax check the role'
  'test:run test sequence for the role'
  'verify:run automated tests against instances'
)

_arguments -s -S \
  {-d,--debug}'[enable debug mode]' \
  '--no-color[disable colored output]' \
  '--base-config[path to a base config]:config file:_files' \
  '--env-file[path to an env file]:env file:_files' \
  {-s,--scenario-name}'[name of the scenario to target]:scenario name' \
  '--version[show version and exit]' \
  '1:subcommand:->subcmd' \
  '*::arguments:->args'

case "$state" in
  subcmd)
    _describe -t commands 'molecule subcommand' subcmds
    ;;
  args)
    case "$line[1]" in
      test)
        _arguments \
          '--destroy[destroy strategy]:strategy:(always never)' \
          '--all[test all scenarios]' \
          '--parallel[run scenarios in parallel]' \
          {-s,--scenario-name}'[name of the scenario to target]:scenario name'
        ;;
      converge|create|destroy|verify|prepare|cleanup|side-effect|syntax|idempotence|check)
        _arguments \
          {-s,--scenario-name}'[name of the scenario to target]:scenario name'
        ;;
      login)
        _arguments \
          {-s,--scenario-name}'[name of the scenario to target]:scenario name' \
          '--host[host to log in to]:host name'
        ;;
    esac
    ;;
esac
