#compdef broot br

# Zsh completion for broot (file manager/navigator)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-d --dates)'{-d,--dates}'[show last modified dates]' \
  '(-D --no-dates)'{-D,--no-dates}'[do not show dates]' \
  '(-f --only-folders)'{-f,--only-folders}'[only show folders]' \
  '(-F --no-only-folders)'{-F,--no-only-folders}'[show files and folders]' \
  '--show-root-fs[show filesystem info on root]' \
  '(-g --show-git-info)'{-g,--show-git-info}'[show git status on files]' \
  '(-G --no-show-git-info)'{-G,--no-show-git-info}'[do not show git info]' \
  '--git-status[show git status on files and dirs]' \
  '(-h --hidden)'{-h,--hidden}'[show hidden files]' \
  '(-H --no-hidden)'{-H,--no-hidden}'[do not show hidden files]' \
  '(-i --show-gitignored)'{-i,--show-gitignored}'[show gitignored files]' \
  '(-I --no-show-gitignored)'{-I,--no-show-gitignored}'[do not show gitignored files]' \
  '(-p --permissions)'{-p,--permissions}'[show permissions]' \
  '(-P --no-permissions)'{-P,--no-permissions}'[do not show permissions]' \
  '(-s --sizes)'{-s,--sizes}'[show directory sizes]' \
  '(-S --no-sizes)'{-S,--no-sizes}'[do not show sizes]' \
  '--sort-by-count[sort by count of files in directories]' \
  '--sort-by-date[sort by modification date]' \
  '--sort-by-size[sort by size]' \
  '--sort-by-type[sort by type]' \
  '--sort-by-type-dirs-first[sort by type with directories first]' \
  '--no-sort[do not sort]' \
  '(-w --whale-spotting)'{-w,--whale-spotting}'[whale spotting mode (big files)]' \
  '(-t --trim-root)'{-t,--trim-root}'[trim root directory]' \
  '(-T --no-trim-root)'{-T,--no-trim-root}'[do not trim root directory]' \
  '--install[install or reinstall the br shell function]' \
  '--set-install-state[set installation state]:state:(undefined refused installed)' \
  '--print-shell-function[print the br shell function]:shell:(bash zsh fish)' \
  '(-c --cmd)'{-c,--cmd}'[send commands to broot]:command' \
  '--color[color mode]:color:(auto yes no)' \
  '--conf[path to config file]:config file:_files' \
  '--height[terminal height]:height' \
  '--listen[listen for commands on given address]:address' \
  '--get-root[print root path on exit]' \
  '--outcmd[output command file]:file:_files' \
  '--write-default-conf[write default config files]:path:_directories' \
  '--help[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:root directory:_directories' && ret=0

return ret
