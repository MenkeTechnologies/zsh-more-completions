#compdef tsup

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--entry=[entry file(s)]:entry files:_files' \
  '--config=[path to config file]:config file:_files' \
  '(-d --out-dir)'{-d,--out-dir}'=[output directory]:directory:_directories' \
  '--format=[output format]:format:(cjs esm iife)' \
  '--minify[enable minification]' \
  '--minify-whitespace[minify whitespace]' \
  '--minify-identifiers[minify identifiers]' \
  '--minify-syntax[minify syntax]' \
  '--target=[target environment]:target:(es5 es2015 es2016 es2017 es2018 es2019 es2020 es2021 es2022 esnext node12 node14 node16 node18)' \
  '--dts[generate declaration files]' \
  '--dts-only[only emit declaration files]' \
  '--dts-resolve[resolve externals used in dts]' \
  '--sourcemap[generate sourcemaps]' \
  '--watch[enable watch mode]' \
  '--ignore-watch=[paths to ignore in watch mode]:paths' \
  '--clean[clean output directory before build]' \
  '--splitting[enable code splitting]' \
  '--shims[enable cjs and esm shims]' \
  '--external=[external packages]:packages' \
  '--global-name=[global variable name for iife]:name' \
  '--env.*=[define environment variables]:value' \
  '--inject=[inject files]:files:_files' \
  '--treeshake[enable tree shaking]' \
  '--no-config[disable config file]' \
  '--platform=[target platform]:platform:(browser node neutral)' \
  '--bundle[bundle dependencies]' \
  '--no-bundle[skip bundling]' \
  '--metafile[generate metafile]' \
  '--tsconfig=[path to tsconfig file]:tsconfig:_files' \
  '--silent[suppress output]' \
  '--onSuccess=[command to run after build]:command' \
  '--keep-names[keep original function/class names]' \
  '--name=[bundle name]:name' \
  '*:entry files:_files' && ret=0

return ret
