#compdef kl2tpd


local -a arguments

arguments=(
    '--config[specify configuration file path (default \\\[lq\]/etc/kl2tpd/kl2tpd. toml\\\[rq\]).]:string'
    '--null[toggle null data plane (establish L2TP tunnel and session but do not spawn \[B…]'
    '--verbose[toggle verbose log output]'
    '*:filename:_files'
)
_arguments -s -S $arguments
