#compdef gotestsum

_arguments -s -S \
  '--format[test output format]:format:(standard-quiet standard-verbose dots dots-v2 pkgname pkgname-and-test-fails testname testdox github-actions)' \
  '--format-icons[icon set for format]:icons:(default hivis text codicons octicons)' \
  '--format-hide-empty-pkg[hide packages with no tests]' \
  '--no-color[disable color output]' \
  '--hide-summary[hide summary sections]:sections:(skipped failed errors output)' \
  '--raw-command[use raw command instead of go test]' \
  '--jsonfile[write JSON output to file]:file:_files' \
  '--junitfile[write JUnit XML to file]:file:_files' \
  '--junitfile-testcase-classname[format for testcase classname]:format:(full relative short)' \
  '--junitfile-testsuite-name[format for testsuite name]:format:(full relative short)' \
  '--junitfile-hide-empty-pkg[hide empty packages in JUnit output]' \
  '--post-run-command[command to run after tests]:command:_command_names' \
  '--rerun-fails[rerun failed tests count]:count:' \
  '--rerun-fails-max-failures[max failures for rerun]:count:' \
  '--rerun-fails-run-root-test[rerun root test of failed subtests]' \
  '--packages[space-separated list of packages]:packages:' \
  '--watch[watch for file changes]' \
  '--watch-chdir[change to package directory when watching]' \
  '--max-fails[max number of failures before stopping]:count:' \
  '--debug[enable debug logging]' \
  '--help[show help]' \
  '--version[show version]' \
  '*:go test args:'
