#compdef rootlesskit-docker-proxy

local -a arguments

arguments=(
  '-container-ip[container ip]'
  '-container-port[container port (default -1)]'
  '-host-ip[host ip]'
  '-host-port[host port (default -1)]'
  '-proto[proxy protocol (default "tcp")]'
  '*:filename:_files'
)

_arguments -s -S $arguments
