#compdef findcmd

local -a arguments

arguments=(
  {-depth,--help,-maxdepth,-mindepth,-mount,-noleaf}'[set search depth and options]'
  {--version,-xdev,-xautofs,-ignore}'[_readdir_race -noignore_readdir_race]'
  {-cnewer,-ctime,-empty,-false,-fstype,-gid,-group}'[filter by file attributes]'
  {-ilname,-iname,-inum,-iwholename,-iregex}'[filter by name patterns case-insensitively]'
  {-links,-lname,-mmin,-mtime,-name,-newer}'[filter by name, time, and links]'
  {-nouser,-nogroup,-path,-perm}'[/\]MODE -regex PATTERN]'
  {-readable,-writable,-executable}'[filter by file permissions]'
  {-wholename,-size,-true,-type,-uid}'[filter by name, size, type, and owner]'
  {-used,-user,-xtype}'[filter by user and type]'
  '-context[]'
  {-fprint0,-fprint,-ls,-fls,-prune,-quit}'[specify output action]'
  '-exec[; -exec COMMAND {} + -ok COMMAND ;]'
  '-execdir[; -execdir COMMAND {} + -okdir COMMAND ;]'
  '*:filename:_files'
)

_arguments -s -S $arguments
