#compdef mmdblookup
# Documentation: https://man.archlinux.org/search?q=mmdblookup
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--file[) The path to the MMDB file. Required.]'
  '--ip[) The IP address to look up. Required.]'
  '--verbose[) Turns on verbose output. Specifically, this causes this]'
  '--version[print the programs version number and exit.]'
  '--help[-\?) Show usage information.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
