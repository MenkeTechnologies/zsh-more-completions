#compdef jdeprscan

local -a arguments

arguments=(
  '--class-path[specify where to find user class files]:path:_files'
  '--for-removal[only report uses of deprecated APIs with forRemoval=true]'
  '--full-version[print full version information and exit]'
  {-l,--list}'[print the set of deprecated APIs]'
  '--release[specify the source release version]:release:(7 8 9 10 11)'
  {-v,--verbose}'[enable additional message output]'
  '--version[print version information and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
