#compdef ln

# Zsh completion for ln - create links between files
# Supports both GNU coreutils and BSD/macOS variants

local -a arguments

if [[ "$OSTYPE" == darwin* || "$OSTYPE" == freebsd* ]]; then
  # BSD/macOS variant
  arguments=(
    '(-P)-L[when creating hard link to symlink, link to target (default)]'
    '(-L)-P[when creating hard link to symlink, link to symlink itself]'
    '-s[create a symbolic link]'
    '-F[remove existing target directory before linking (with -s)]'
    '(-i -w)-f[remove existing destination files without prompting]'
    '(-f)-i[prompt before removing existing destinations]'
    '-w[warn if source of a symbolic link does not exist]'
    '(-n)-h[do not follow target if it is a symbolic link]'
    '(-h)-n[same as -h, for compatibility]'
    '-v[be verbose, show files as they are processed]'
    '*:file:_files'
  )
else
  # GNU coreutils variant
  arguments=(
    '--backup=-[make a backup of each existing destination file]::method:(none off numbered t existing nil simple never)'
    '-b[like --backup but does not accept an argument]'
    {-d,-F,--directory}'[allow the superuser to attempt to hard link directories]'
    '(-i)-f[remove existing destination files]'
    {-f,--force}'[remove existing destination files]'
    '(-f)-i[prompt whether to remove destinations]'
    {-i,--interactive}'[prompt whether to remove destinations]'
    '(-P)-L[dereference TARGETs that are symbolic links]'
    {-L,--logical}'[dereference TARGETs that are symbolic links]'
    {-n,--no-dereference}'[treat LINK_NAME as a normal file if it is a symlink]'
    '(-L)-P[make hard links directly to symbolic links]'
    {-P,--physical}'[make hard links directly to symbolic links]'
    {-r,--relative}'[create symbolic links relative to link location]'
    {-s,--symbolic}'[make symbolic links instead of hard links]'
    {-S,--suffix}'=[override the usual backup suffix]:suffix: '
    {-t,--target-directory}'=[specify the directory in which to create the links]:directory:_directories'
    {-T,--no-target-directory}'[treat LINK_NAME as a normal file always]'
    {-v,--verbose}'[print name of each linked file]'
    '--help[display help and exit]'
    '--version[output version information and exit]'
    '*:file:_files'
  )
fi

_arguments -s -S $arguments
