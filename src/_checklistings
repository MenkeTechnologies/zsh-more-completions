#compdef checklistings
# Documentation: https://man.archlinux.org/search?q=checklistings
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--no-colors[log to terminal without control codes]'
  '--no-line-adjust[do not try to adjust error line numbers]'
  '*:filename:_files'
)

_arguments -s -S $arguments
