#compdef mesg
# Documentation: https://man.archlinux.org/search?q=mesg
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-v,--verbose}'[explain what is being done]'
  '(- * :)'{-h,--help}'[display this help]'
  {-V,--version}'[display version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
