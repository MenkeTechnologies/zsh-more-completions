#compdef scotest
# Documentation: https://man.archlinux.org/search?q=scotest
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-d[run as server daemon]'
  '-c[run as client]'
  '-m[number of connects (client)]:count'
  '-r[run as server]'
  '-s[send data (client)]'
  '-n[be silent (client)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
