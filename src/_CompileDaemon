#compdef CompileDaemon

# Zsh completion for CompileDaemon - Go compile daemon

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '-build[build command]:command' \
  '-command[command to run after build]:command' \
  '-directory[directory to watch]:directory:_files -/' \
  '-pattern[file pattern to watch]:pattern' \
  '-exclude-dir[directory to exclude]:directory:_files -/' \
  '-exclude[file pattern to exclude]:pattern' \
  '-include[file pattern to include]:pattern' \
  '-graceful-kill[send SIGTERM instead of SIGKILL]' \
  '-graceful-timeout[timeout for graceful shutdown]:duration' \
  '-log-prefix[enable log prefix]' \
  '-color[enable colored output]' \
  '-recursive[watch directories recursively]'
