#compdef fastboot

local -a arguments

arguments=(
  '--cmdline[override kernel command line]:cmdline:'
  '--base[set kernel base address (default: 0x10000000)]:address:'
  '--kernel-offset[set kernel offset (default: 0x00008000)]:offset:'
  '--ramdisk-offset[set ramdisk offset (default: 0x01000000)]:offset:'
  '--tags-offset[set tags offset (default: 0x00000100)]:offset:'
  '--page-size[set flash page size (default: 2048)]:size:'
  '--header-version[set boot image header version]:version:'
  '--os-version[set boot image OS version]:version:'
  '--os-patch-level[set boot image OS security patch level]:level:'
  '-w[wipe userdata.]'
  '-s[specify a USB or network device]:device:'
  '-S[break into sparse files no larger than SIZE]:size:'
  '--slot[use SLOT; all for both slots, other for non-current]:slot:'
  '--set-active[sets the active slot before rebooting]:slot:'
  '--skip-secondary[do not flash secondary slots in flashall/update]'
  '--skip-reboot[dont reboot device after flashing.]'
  '--disable-verity[sets disable-verity when flashing vbmeta.]'
  '--disable-verification[sets disable-verification when flashing vbmeta.]'
  '--wipe-and-use-fbe[enable file-based encryption, wiping userdata.]'
  '--unbuffered[dont buffer input or output.]'
  {--verbose,-v}'[verbose output.]'
  '--version[display version.]'
  {--help,-h}'[show this message.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
