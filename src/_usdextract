#compdef usdextract
# Documentation: https://man.archlinux.org/search?q=usdextract
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[print this help message and exit]'
  {-o,--out}'[extract the input file to this directory]'
  '--version[display program version information and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
