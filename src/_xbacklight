#compdef xbacklight

local -a arguments

arguments=(
  {-display,-d}'[specify X display]:display:'
  '-help[display help]'
  '-set[set backlight brightness percentage]:percentage:'
  '-inc[increase backlight brightness by percentage]:percentage:'
  '-dec[decrease backlight brightness by percentage]:percentage:'
  '-get[get current backlight brightness]'
  '-time[fade time in milliseconds]:milliseconds:'
  '-steps[number of steps in fade]:steps:'
  '*:filename:_files'
)

_arguments -s -S $arguments
