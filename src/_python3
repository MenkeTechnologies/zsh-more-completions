#compdef python3

# Zsh completion for Python 3.13+

local curcontext="$curcontext" state state_descr line
typeset -A opt_args

_arguments -C -s -S \
    '(-bb)-b[issue warnings about comparing bytes/bytearray with str]' \
    '(-b)-bb[issue errors about comparing bytes/bytearray with str]' \
    "-B[don't write .pyc files on import (also PYTHONDONTWRITEBYTECODE)]" \
    '(1 -)-c+[program passed in as string (terminates option list)]:python command' \
    '-d[turn on parser debugging output (for experts only, debug builds)]' \
    '-E[ignore PYTHON* environment variables (such as PYTHONPATH)]' \
    '(1 * -)'{-h,--help}'[print help message and exit]' \
    '-i[inspect interactively after running script (also PYTHONINSPECT)]' \
    "-I[isolate Python from the user's environment (implies -E, -P, -s)]" \
    '(1 -)-m+[run library module as a script (terminates option list)]:module:_python_modules' \
    '-O[remove assert and __debug__-dependent statements; add .opt-1 before .pyc extension]' \
    '-OO[do -O changes and also discard docstrings; add .opt-2 before .pyc extension]' \
    '(-P --safe-path)'{-P,--safe-path}"[don't prepend a potentially unsafe path to sys.path (also PYTHONSAFEPATH)]" \
    "-q[don't print version and copyright messages on interactive startup]" \
    "-s[don't add user site directory to sys.path (also PYTHONNOUSERSITE)]" \
    "-S[don't imply 'import site' on initialization]" \
    '-u[force stdout and stderr streams to be unbuffered (also PYTHONUNBUFFERED)]' \
    '*-v[verbose (trace import statements); can be supplied multiple times]' \
    '(1 * -)'{-V,--version}'[print the Python version number and exit (use -VV for more info)]' \
    '*-W+[warning control (action\:message\:category\:module\:lineno)]:warning filter:(default always ignore module once error)' \
    '-x[skip first line of source, allowing use of non-Unix forms of \#!cmd]' \
    '*-X+[set implementation-specific option]:option:->xoption' \
    '(-)--check-hash-based-pycs[control how Python invalidates hash-based .pyc files]:mode:(always default never)' \
    '(1 * -)--help-env[print help about Python environment variables and exit]' \
    '(1 * -)--help-xoptions[print help about implementation-specific -X options and exit]' \
    '(1 * -)--help-all[print complete help information and exit]' \
    '(-)1:Python script:_files -g "*.py(|c|o)(-.)"' \
    '*::script argument:= ->normal' && return

case "$state" in
    xoption)
        local -a xopts
        xopts=(
            'cpu_count=:override os.cpu_count() return value'
            'dev:enable Python Development Mode'
            'faulthandler:dump Python traceback on fatal errors'
            'frozen_modules=:whether to use frozen modules (on/off)'
            'importtime:show how long each import takes'
            'int_max_str_digits=:limit size of int-str conversions (0 disables)'
            'no_debug_ranges:omit extra location information in code objects'
            'perf:support the Linux perf profiler'
            'perf_jit:support the Linux perf profiler with DWARF support'
            'pycache_prefix=:write .pyc files to a parallel tree'
            'showrefcount:output total reference count (debug builds only)'
            'tracemalloc:trace Python memory allocations'
            'utf8:enable UTF-8 mode'
            'warn_default_encoding:enable EncodingWarning for encoding=None'
        )
        _describe -t xoptions 'implementation-specific option' xopts
        ;;
    normal)
        if [[ -z "$opt_args[(I)-(c|m)]" ]]; then
            shift words
            (( CURRENT-- ))
        fi
        _normal && return
        ;;
esac

return 1
