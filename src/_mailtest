#compdef mailtest

local -a arguments

arguments=(
    {-d,--debug}'[enable debugging output]'
    {-h,--host}'[specify the host to connect to]:host:_hosts'
    {-m,--ehlo}'[specify the machine name for EHLO]:machine: '
    {-r,--rcptto}'[specify the recipient of message]:recipient: '
    {-v,--vrfy}'[use recipient parameter for VRFY command]'
    {-e,--expn}'[use recipient parameter for EXPN command]'
    {-f,--mailfrom}'[specify the MAIL FROM address]:from-address: '
    {-u,--from822}'[specify the From header value]:from-user: '
    {-B,--bounce}'[replace mailfrom address with empty sender]'
    {-p,--port}'[specify port to connect to]:port: '
    {-S,--tls}'[use TLS directly on connection]'
    {-s,--nostarttls}'[disable attempting STARTTLS]'
    '--stricttls[require strict TLS verification]'
    '--sslargs[specify additional SSL arguments]:args: '
    {-b,--body}'[generate a body for the message]'
    {-O,--include-options}'[include details of options in the message]'
    {-H,--include-headers}'[include generated headers in the message body]'
    {-w,--wellknown}'[specify path for WELLKNOWN command]:path:_files'
    {-W,--output}'[specify output file]:file:_files'
    '--help[display help information]'
    '*:filename:_files'
)
_arguments -s -S $arguments
