#compdef rustdoc

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message]'
  {-V,--version}'[print rustdocs version]'
  {-v,--verbose}'[use verbose output]'
  {-r,--input-format}'[the input type of the specified file]:format: '
  {-w,--output-format}'[the output type to write]:format: '
  {-o,--output}'[where to place the output]:dir:_directories'
  '--crate-name[specify the name of this crate]:name: '
  {-L,--library-path}'[directory to add to crate search path]:dir:_directories'
  '--cfg[pass a --cfg to rustc]:spec: '
  '--extern[specify where an external library is located]:name=path: '
  {-C,--codegen}'[pass a codegen option to rustc]:opt=value: '
  '--passes[list of passes to also run]:passes: '
  '--no-defaults[dont run the default passes]'
  '--document-private-items[document private items]'
  '--test[run code examples as tests]'
  '--test-args[arguments to pass to the test runner]:args: '
  '--target[target triple to document]:target: '
  '--markdown-css[CSS files to include via link in rendered Markdown]:file:_files'
  '--html-in-header[files to include inline in the head section]:file:_files'
  '--html-before-content[files to include inline between body and the content]:file:_files'
  '--html-after-content[files to include inline after the content]:file:_files'
  '--markdown-before-content[files to include inline between body and the content]:file:_files'
  '--markdown-after-content[files to include inline after the content]:file:_files'
  '--markdown-playground-url[URL to send code snippets to]:url: '
  '--markdown-no-toc[dont include table of contents]'
  {-e,--extend-css}'[add CSS rules from a given file]:file:_files'
  '-Z[internal and debugging options (only on nightly build)]:option: '
  '--sysroot[override the system root]:path:_directories'
  '--playground-url[URL to send code snippets to]:url: '
  '--display-warnings[print code warnings when testing doc]'
  '--crate-version[crate version to print into documentation]:version: '
  '--linker[linker used for building executable test code]:linker: '
  '--sort-modules-by-appearance[sort modules by where they appear in the program]'
  '--themes[additional themes which will be added to the generated docs]:file:_files'
  '--theme-checker[check if given theme is valid]:file:_files'
  '--resource-suffix[suffix to add to CSS and JavaScript files]:suffix: '
  '--edition[edition to use when compiling rust code]:edition:(2015 2018 2021)'
  '--color[configure coloring of output]:color:(auto always never)'
  '--error-format[how errors and other messages are produced]:format:(human json short)'
  '--disable-minification[disable minification applied on JS files]'
  '*:filename:_files'
)

_arguments -s -S $arguments
