#compdef pg_createcluster


local -a arguments

arguments=(
    {-u,--user}'[specify owning user]'
    {-g,--group}'[specify owning group]'
    {-d,--datadir}'[specify data directory]'
    {-s,--socketdir}'[specify socket directory]'
    {-l,--logfile}'[specify log file path]'
    '--locale'
    '--lc-collate'
    '--lc-ctype'
    '--lc-messages'
    '--lc-monetary'
    '--lc-numeric'
    '--lc-time[Like --locale, but only sets the locale in the specified category.]'
    {-e,--encoding}'[specify character encoding]'
    {-p,--port}'[specify port number]'
    {-q,--quiet,--no-status}'[suppress status output]'
    '--start'
    '--start-conf'
    {-o,--pgoption}'[pass option to PostgreSQL server]'
    '--createclusterconf'
    '--environment'
    '*:filename:_files'
)
_arguments -s -S $arguments
