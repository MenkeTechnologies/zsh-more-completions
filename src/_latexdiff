#compdef latexdiff

local -a arguments

arguments=(
  {--type,-t}'[add code to preamble for selected markup style]:type:'
  {--subtype,-s}'[add code to preamble for selected style for bracketing]:subtype:'
  {--floattype,-f}'[add code to preamble for selected float markup style]:floattype:'
  {--encoding,-e}'[specify encoding of old.tex and new.tex]:encoding:'
  {--preamble,-p}'[insert file at end of preamble instead of auto-generating]:file:_files'
  {-A,--exclude-safecmd}'[exclude from the list of safe commands]:commands:'
  '--replace-safecmd[replace the list of safe commands]:commands:'
  {-a,--append-safecmd}'[append to the list of safe commands]:commands:'
  {-X,--exclude-textcmd}'[exclude from the list of text commands]:commands:'
  '--replace-textcmd[replace the list of text commands]:commands:'
  {-x,--append-textcmd}'[append to the list of text commands]:commands:'
  '--replace-context1cmd[replace the list of context1 commands]:commands:'
  '--append-context1cmd[append to the list of context1 commands]:commands:'
  '--replace-context2cmd[replace the list of context2 commands]:commands:'
  '--append-context2cmd[append to the list of context2 commands]:commands:'
  '--exclude-mboxsafecmd[exclude from the list of mbox safe commands]:commands:'
  '--append-mboxsafecmd[append to the list of mbox safe commands]:commands:'
  {--config,-c}'[set configuration variables]:config:'
  '--packages[set list of packages to tell latexdiff about]:packages:'
  '--show-preamble[print generated or included preamble commands to stdout]'
  '--show-safecmd[print list of regex matching and excluding safe commands]'
  '--show-textcmd[print list of regex matching and excluding commands with text argument]'
  '--show-config[show values of configuration variables]'
  '--show-all[show all of the above]'
  '--allow-spaces[allow spaces between bracketed or braced arguments to commands]'
  '--math-markup[determine granularity of markup in displayed math environments]:level:'
  '--graphics-markup[change highlight style for graphics embedded with \includegraphics commands]:style:'
  '--disable-citation-markup[suppress citation markup in changed sections]'
  '--disable-auto-mbox[suppress auto-mbox protection of vulnerable commands]'
  '--enable-citation-markup[enable citation markup]'
  '--enforce-auto-mbox[protect citation commands and other vulnerable commands in changed sections]'
  {--label,-L}'[set label for old or new file]:label:'
  '--no-label[suppress inclusion of old and new file names as comment in output file]'
  '--visible-label[include old and new filenames as visible text in the output]'
  '--flatten[replace \input and \include commands within body by the content of the files]'
  '(- * :)'{--help,-h}'[show help text]'
  '--ignore-warnings[suppress warnings about inconsistencies in length between input and output]'
  {--verbose,-V}'[output various status information to stderr during processing]'
  '--version[show version number]'
  '*:filename:_files'
)

_arguments -s -S $arguments
