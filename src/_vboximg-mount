#compdef vboximg-mount

local -a arguments

arguments=(
    '--image=[virtual disk image UUID or path]:image:_files -g "*.{vdi,vmdk,vhd,hdd}"'
    '-i[virtual disk image UUID or path]:image:_files -g "*.{vdi,vmdk,vhd,hdd}"'
    '--vm=[VM name or UUID]:VM name'
    '--rw[open image read-write]'
    '--root[present FUSE filesystem as root]'
    '--verbose[verbose output]'
    '-v[verbose output]'
    '--wide[wide output format for list]'
    '-w[wide output format for list]'
    '--list[list available images]'
    '-l[list available images]'
    '--partition=[partition number to mount]:partition number'
    '-p[partition number to mount]:partition number'
    '--offset=[offset into image]:offset bytes'
    '-o[offset into image]:offset bytes'
    '--size=[restrict size]:size bytes'
    '-s[restrict size]:size bytes'
    '--help[show help]'
    '-h[show help]'
    '*:mount point:_directories'
)

_arguments -s -S $arguments
