#compdef journalctl

# Comprehensive zsh completion for journalctl (systemd 256+)

_journalctl() {
  local curcontext="$curcontext" state lstate line
  typeset -A opt_args

  local -a _journalctl_output_modes=(
    short short-full short-iso short-iso-precise short-precise
    short-monotonic short-delta short-unix verbose export
    json json-pretty json-sse json-seq cat with-unit
  )

  _arguments -s -S \
    '(- *)'{-h,--help}'[Show help text]' \
    '(- *)--version[Show package version]' \
    '--system[Show the system journal only]' \
    '--user[Show the user journal for the current user]' \
    {-M+,--machine=}'[Operate on local container]:container name' \
    {-m,--merge}'[Show entries from all available journals]' \
    {-D+,--directory=}'[Show journal files from directory]:directory:_directories' \
    '*'{-i+,--file=}'[Show journal file]:journal file:_files' \
    '--root=[Operate on journal files below a root directory]:root directory:_directories' \
    '--image=[Operate on journal files in disk image]:image file:_files' \
    '--image-policy=[Enforce image dissection policy]:policy string' \
    '--namespace=[Show log data from specified namespace]:namespace' \
    {-S+,--since=}'[Start showing entries on or newer than date]:date/time (YYYY-MM-DD HH\:MM\:SS)' \
    {-U+,--until=}'[Stop showing entries on or older than date]:date/time (YYYY-MM-DD HH\:MM\:SS)' \
    {-c+,--cursor=}'[Start showing entries from specified cursor]:cursor string' \
    '--after-cursor=[Start showing entries from after specified cursor]:cursor string' \
    '--cursor-file=[Read/write cursor position from file]:cursor file:_files' \
    '--show-cursor[Print the cursor after all entries]' \
    {-b,--boot}'[Show data only from specified boot or current boot]:boot ID or offset' \
    '--list-boots[Show terse information about recorded boots]' \
    {-u+,--unit=}'[Show data only from the specified unit]:unit name:_systemd_units' \
    '--user-unit=[Show data only from the specified user session unit]:unit name' \
    {-I+,--invocation=}'[Show messages from specific invocation]:invocation ID' \
    '--list-invocations=[List invocation IDs of a unit]:unit name' \
    {-t+,--identifier=}'[Show messages with specified syslog identifier]:syslog identifier' \
    {-T+,--exclude-identifier=}'[Exclude messages with specified syslog identifier]:syslog identifier' \
    {-p+,--priority=}'[Show only messages within specified priority range]:priority:(emerg alert crit err warning notice info debug)' \
    '--facility=[Filter output by syslog facility]:facility:(kern user mail daemon auth syslog lpr news uucp cron authpriv ftp local0 local1 local2 local3 local4 local5 local6 local7)' \
    {-g+,--grep=}'[Filter entries by message regex]:pattern' \
    '--case-sensitive=[Make pattern matching case sensitive]:boolean:(true false)' \
    {-k,--dmesg}'[Show kernel message log from the current boot]' \
    {-e,--pager-end}'[Jump to the end of the journal in the pager]' \
    {-f,--follow}'[Follow the journal, printing new entries as they appear]' \
    {-n+,--lines=}'[Number of journal entries to show]:number of lines' \
    '--no-tail[Show all lines, even in follow mode]' \
    {-r,--reverse}'[Show the newest entries first]' \
    {-o+,--output=}'[Change journal output mode]:output mode:(${_journalctl_output_modes[@]})' \
    '--truncate-newline[Truncate entries at first newline character]' \
    '--output-fields=[Comma-separated list of fields to output]:field list' \
    '--utc[Express time in UTC]' \
    {-x,--catalog}'[Add message explanations where available]' \
    {-W,--no-hostname}'[Suppress output of hostname field]' \
    '--no-full[Ellipsize fields]' \
    '(-a --all)'{-a,--all}'[Show all fields, including long and unprintable]' \
    {-l,--full}'[Show all fields in full]' \
    {-q,--quiet}'[Suppress informational messages and privilege warnings]' \
    '--no-pager[Do not pipe output into a pager]' \
    '--synchronize-on-exit=[Sync journal when exiting follow mode]:boolean:(true false)' \
    {-N,--fields}'[Print all field names currently used in all entries]' \
    {-F+,--field=}'[List all values a specified field takes]:field name' \
    '--disk-usage[Show total disk usage of all journal files]' \
    '--vacuum-size=[Remove old journal files to reduce disk use below size]:size (bytes)' \
    '--vacuum-time=[Remove old journal files older than specified time]:time span' \
    '--vacuum-files=[Reduce number of journal files to specified number]:number' \
    '--verify[Verify journal file consistency]' \
    '--sync[Synchronize unwritten journal data to disk]' \
    '--relinquish-var[Ask journal daemon to write to /run/log/journal/]' \
    '--smart-relinquish-var[Like --relinquish-var but only if on different mount point]' \
    '--flush[Flush journal data from /run to /var]' \
    '--rotate[Request immediate rotation of journal files]' \
    '--header[Show internal journal header information]' \
    '--list-catalog[Show message IDs of all entries in the catalog]' \
    '--dump-catalog[Show entries in the message catalog]' \
    '--update-catalog[Update the message catalog database]' \
    '--setup-keys[Generate a new FSS key pair]' \
    '--interval=[Time interval for changing the FSS sealing key]:time interval' \
    '--verify-key=[Specify FSS verification key]:verification key' \
    '--force[Force overriding of the FSS key pair with --setup-keys]' \
    '*: :_files'
}

# Helper to complete systemd unit names
_systemd_units() {
  local -a units
  units=( $(systemctl list-units --no-legend --no-pager --all --full 2>/dev/null | \
    while read -r a rest; do echo "$a"; done) )
  if (( ${#units} )); then
    compadd "$@" -a - units
  fi
}

_journalctl "$@"
