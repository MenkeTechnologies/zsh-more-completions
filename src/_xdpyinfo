#compdef xdpyinfo

local -a arguments

arguments=(
  '-display[server to query]'
  '-version[print program version and exit]'
  '-queryExtensions[print info returned by XQueryExtension]'
  '-ext[print detailed info for all supported extensions]'
  '-ext[print detailed info for extension-name if one]'
  '*:filename:_files'
)

_arguments -s -S $arguments
