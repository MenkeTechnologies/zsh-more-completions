#compdef odin

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:compile directory of .odin files as an executable'
  'run:same as build but also runs the produced executable'
  'check:parse and type-check directory of .odin files'
  'test:build and run procedures with the test attribute'
  'doc:generate documentation from a directory'
  'strip-semicolons:parse and remove all semicolons'
  'version:print version'
  'report:print useful bug report information'
)

_arguments -s -S \
  '(- *)-help[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'odin command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (build|run|check|test)
        _arguments -s -S \
          '-file[treat the given file as a single-file package]' \
          '-out=[set output filename]:filename:_files' \
          '-o=[set optimization mode]:mode:(none minimal size speed aggressive)' \
          '-debug[enable debug info]' \
          '-disable-assert[disable assert evaluation]' \
          '-define=[define a constant]:ident=value' \
          '-collection=[define a library collection]:name=path' \
          '-target=[set the target]:target:(darwin_amd64 darwin_arm64 linux_amd64 linux_arm64 windows_amd64 freestanding_amd64 wasm32 wasm64p32 js_wasm32 js_wasm64p32)' \
          '-microarch=[set microarchitecture]:microarch' \
          '-show-timings[show compilation timings]' \
          '-show-more-timings[show more compilation timings]' \
          '-export-timings=[export timings]:format:(json csv)' \
          '-export-timings-file=[export timings to file]:file:_files' \
          '-keep-temp-files[keep generated temp files]' \
          '-error-pos-style=[error position style]:style:(default unix)' \
          '-max-error-count=[max number of errors]:count' \
          '-no-crt[do not link the C runtime]' \
          '-no-entry-point[no default entry point]' \
          '-build-mode=[build mode]:mode:(exe dll shared obj object asm llvm-ir)' \
          '-reloc-mode=[relocation mode]:mode:(default static pic dynamic-no-pic)' \
          '-sanitize=[enable sanitizers]:sanitizer:(address memory thread)' \
          '-extra-linker-flags=[extra linker flags]:flags' \
          '-extra-assembler-flags=[extra assembler flags]:flags' \
          '-vet[enable all vet checks]' \
          '-vet-unused[enable unused declarations check]' \
          '-vet-unused-variables[enable unused variables check]' \
          '-vet-unused-imports[enable unused imports check]' \
          '-vet-shadowing[enable shadowing check]' \
          '-vet-style[enable style check]' \
          '-vet-cast[enable cast check]' \
          '-warnings-as-errors[treat warnings as errors]' \
          '-no-threaded-checker[disable threaded checker]' \
          '-show-system-calls[show system calls]' \
          '-min-link-libs[minimize number of linked libraries]' \
          '-thread-count=[override thread count]:count' \
          '-terse-errors[show terse errors]' \
          '-verbose-errors[show verbose errors]' \
          '-pdb-name=[set PDB file name]:filename' \
          '-subsystem=[set exe subsystem]:subsystem:(console windows)' \
          '1:directory or file:_files' && ret=0
        ;;
      (doc)
        _arguments -s -S \
          '-short[show short documentation]' \
          '-all-packages[generate docs for all packages]' \
          '-doc-format[generate in odin doc format]' \
          '1:directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
