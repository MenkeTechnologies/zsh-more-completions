#compdef ntfsfallocate
# Documentation: https://man.archlinux.org/search?q=ntfsfallocate
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-f[force execution despite errors]'
  '-n[do not change the apparent size of file]'
  '-l[allocate length bytes]'
  '-o[start allocating at offset]'
  '-v[verbose execution]'
  '-vv[very verbose execution]'
  '-V[display version information]'
  '-h[display this help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
