#compdef mcp-cli

# Zsh completion for mcp-cli (Model Context Protocol CLI)

local -a commands
commands=(
  'info:List configured servers or tools'
  'grep:Search for tools across servers'
  'call:Execute a tool'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[Print help message]' \
  '--config-file=[Path to mcp_servers.json]:file:_files' \
  '--server=[Specify a subset of servers]:servers:' \
  '--verbose[Enable detailed logging]' \
  '1: :_describe -t commands "command" commands' \
  '*:: :->args'

case $words[1] in
  info)
    _arguments \
      '1:server:' \
      '2:tool:'
    ;;
  grep)
    _arguments \
      '1:pattern:'
    ;;
  call)
    _arguments \
      '1:server:' \
      '2:tool:' \
      '3:args (JSON):'
    ;;
esac
