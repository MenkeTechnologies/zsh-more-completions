#compdef gsec

local -a arguments

arguments=(
  '-user[administrator name]:name:'
  '-password[administrator password]:password:'
  '-fetch_password[file to fetch password from]:file:_files'
  '-role[administrator SQL role name]:role:'
  '-trusted[use trusted authentication]'
  '-database[database to manage]:database:'
  '-z[set password]'
  '-pw[set password]:password:'
  '-uid[set user ID]:uid:'
  '-gid[set group ID]:gid:'
  '-fname[set first name]:firstname:'
  '-mname[set middle name]:middlename:'
  '-lname[set last name]:lastname:'
  '-admin[set admin privileges]'
  '*:filename:_files'
)

_arguments -s -S $arguments
