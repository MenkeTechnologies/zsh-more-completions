#compdef in2csv

# Zsh completion for in2csv (csvkit)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --delimiter)'{-d,--delimiter}'[delimiting character]:delimiter:' \
  '(-t --tabs)'{-t,--tabs}'[specify that input is tab-delimited]' \
  '(-q --quotechar)'{-q,--quotechar}'[character for quoting]:char:' \
  '(-u --quoting)'{-u,--quoting}'[quoting style]:style:(0 1 2 3)' \
  '(-e --encoding)'{-e,--encoding}'[input encoding]:encoding:' \
  '(-f --format)'{-f,--format}'[input format]:format:(csv dbf fixed geojson json ndjson tsv xls xlsx)' \
  '(-s --schema)'{-s,--schema}'[fixed-width schema file]:file:_files' \
  '(-k --key)'{-k,--key}'[top-level key for JSON]:key:' \
  '(-n --names)'{-n,--names}'[print sheet names]' \
  '--sheet[sheet to convert]:sheet:' \
  '--write-sheets[write all sheets to files]:prefix:' \
  '--no-inference[disable type inference]' \
  '--date-format[strptime date format]:format:' \
  '--datetime-format[strptime datetime format]:format:' \
  '(-H --no-header-row)'{-H,--no-header-row}'[no header row]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:input file:_files' && return 0
