#compdef hey

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-n[number of requests]:count' \
  '-c[number of concurrent workers]:count' \
  '-q[rate limit per worker]:qps' \
  '-z[duration of requests]:duration' \
  '-o[output type]:type:(csv)' \
  '-m[HTTP method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
  '-H[custom HTTP header]:header' \
  '-t[request timeout]:seconds' \
  '-A[HTTP Accept header]:accept' \
  '-d[HTTP request body]:body' \
  '-D[HTTP request body from file]:file:_files' \
  '-T[content type]:content-type' \
  '-a[basic authentication]:username\:password' \
  '-x[HTTP proxy address]:proxy' \
  '-h2[enable HTTP/2]' \
  '-host[custom Host header]:host' \
  '-disable-compression[disable compression]' \
  '-disable-keepalive[disable keep-alive]' \
  '-disable-redirects[disable following redirects]' \
  '-cpus[number of CPUs to use]:count' \
  '1:URL' && ret=0

return ret
