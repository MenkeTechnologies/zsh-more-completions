#compdef jdeps

local -a arguments

arguments=(
  '--dot-output[destination directory for DOT file output]:dir:_files -/'
  {-s,-summary}'[print dependency summary only]'
  {-v,-verbose}'[print all class level dependences]'
  '--api-only[restrict analysis to APIs i.e. dependences from public and protected types]'
  '--jdk-internals[finds class-level dependences on JDK internal APIs]'
  {-cp,-classpath,--class-path}'[specify where to find class files]:path:_files'
  '--module-path[specify module path]:path:_files'
  '--upgrade-module-path[specify upgrade module path]:path:_files'
  '--system[specify an alternate system module path]:path:_files -/'
  '--add-modules[specify root modules to resolve]:modules:'
  '--multi-release[specifies the version when processing multi-release jar files]:version:'
  {-q,-quiet}'[suppress warning messages]'
  {-version,--version}'[version information]'
  '--module[specify the root module for analysis]:module:'
  '--generate-module-info[generate module-info.java under the specified directory]:dir:_files -/'
  '--generate-open-module[generate module-info.java for open modules under the specified directory]:dir:_files -/'
  '--check[analyze dependences of the specified modules]:modules:'
  '--list-deps[lists the module dependences and also prints internal API packages]'
  '--list-reduced-deps[same as --list-deps without listing implied reads]'
  '--print-module-deps[same as --list-reduced-deps with printing a comma-separated list]'
  {-p,--package}'[finds dependences matching the given package name]:package:'
  {-e,--regex}'[finds dependences matching the given pattern]:pattern:'
  '--require[finds dependences matching the given module name]:module:'
  {-f,-filter}'[filter dependences matching the given pattern]:pattern:'
  '-include[restrict analysis to classes matching pattern]:pattern:'
  {-P,-profile}'[show profile containing a package]'
  {-R,-recursive}'[recursively traverse all run-time dependences]'
  {-I,--inverse}'[analyzes the dependences per other given options and filters results]'
  '--compile-time[compile-time view of transitive dependences]'
  '*:filename:_files'
)

_arguments -s -S $arguments
