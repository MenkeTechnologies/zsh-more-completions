#compdef aeskeyfind
# Documentation: https://man.archlinux.org/search?q=aeskeyfind
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-v[verbose output -- prints the extended keys and]'
  '-q[dont display a progress bar]'
  '-t[sets the maximum number of bit errors allowed]'
  '-h[displays this help message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
