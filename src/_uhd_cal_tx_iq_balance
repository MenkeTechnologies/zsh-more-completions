#compdef uhd_cal_tx_iq_balance

local -a arguments

arguments=(
  '--help[help message]'
  '--verbose[enable some verbose]'
  '--args[device address args \[default = ""\]]'
  '--subdev[subdevice specification (default: first]'
  '--tx_wave_freq=[Transmit wave frequency in Hz]:value'
  '--tx_wave_ampl=[(=0.69999999999999996)]:value'
  '--rx_offset=[RX LO offset from the TX LO in Hz]:value'
  '--freq_start=[Frequency start in Hz (do not specify]:value'
  '--freq_stop=[Frequency stop in Hz (do not specify]:value'
  '--freq_step=[Step size for LO sweep in Hz]:value'
  '--nsamps[samples per data capture]'
  '--precision[(=0.0001) Correction precision (default=0.0001)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
