#compdef cargo-hack

# cargo-hack - a cargo subcommand for testing each feature independently

local arguments

arguments=(
    '--each-feature[Perform for each feature of the package]'
    '--feature-powerset[Perform for the feature powerset of the package]'
    '--optional-deps[Use optional dependencies as features]'
    '--skip[Space-separated list of features to skip]:features'
    '--exclude-features[Alias for --skip]:features'
    '--depth[Specify the max number of simultaneous feature flags]:depth'
    '--group-features[Space-separated list of features to group and treat as one]:features'
    '--at-least-one-of[Require at least one of the listed features]:features'
    '--include-features[Include only the listed features in the powerset]:features'
    '--no-dev-deps[Perform without dev-dependencies]'
    '--remove-dev-deps[Equivalent to --no-dev-deps flag]'
    '--ignore-private[Skip packages with publish = false]'
    '--ignore-unknown-features[Skip unknown features]'
    '--clean-per-run[Run cargo clean before each cargo invocation]'
    '--version-range[Perform commands on a specified range of Rust versions]:range'
    '--version-step[Specify the version step for --version-range]:step'
    '--rust-version[Perform with the Rust version from rust-version field]'
    '--no-manifest-path[Do not pass --manifest-path to cargo]'
    '--exclude[Exclude specific packages]:spec'
    '--workspace[Perform on all packages in the workspace]'
    '--package[Perform on specific packages]:spec'
    '--verbose[Use verbose output]'
    '--color[Control when colored output is used]:when:(auto always never)'
    '*:filename:_files'
)
_arguments -s $arguments
