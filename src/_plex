#compdef plex

local curcontext="$curcontext" state state_descr line
typeset -A opt_args

local -a subcommands
subcommands=(
    'scan:scan media library'
    'refresh:refresh metadata'
    'analyze:analyze media files'
    'optimize:optimize database'
    'vacuum:vacuum database'
    'clean:clean bundles and media'
    'list:list libraries'
    'status:show server status'
    'start:start Plex Media Server'
    'stop:stop Plex Media Server'
    'restart:restart Plex Media Server'
)

_arguments -s -S \
    '--help[show help]' \
    '-h[show help]' \
    '--version[show version]' \
    '-v[show version]' \
    '--token=[Plex auth token]:token' \
    '--server=[server URL]:URL' \
    '1:subcommand:->subcmd' \
    '*::arguments:->args'

case $state in
    subcmd)
        _describe -t subcommands 'plex subcommand' subcommands
        ;;
    args)
        case $words[1] in
            scan|refresh|analyze)
                _arguments \
                    '--section=[library section ID]:section ID' \
                    '--path=[path to scan]:path:_directories' \
                    '--force[force operation]'
                ;;
            clean)
                _arguments \
                    '--bundles[clean bundles]' \
                    '--media[clean transcoded media]'
                ;;
            *)
                _default
                ;;
        esac
        ;;
esac
