#compdef systemd-inhibit
# Documentation: https://man.archlinux.org/search?q=systemd-inhibit
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help]'
  '--version[show package version]'
  '--what[operations to inhibit, colon separated list]'
  '--who[A descriptive string who is inhibiting]'
  '--why[A descriptive string why is being inhibited]'
  '--mode[one of block or delay]'
  '--list[list active inhibitors]'
  '*:filename:_files'
)

_arguments -s -S $arguments
