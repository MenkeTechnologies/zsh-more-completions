#compdef qalc

local -a arguments

arguments=(
  {-b,-base}'[set the number base for results and, optionally, expressions]:base: '
  {-e,-exrates}'[update exchange rates]'
  {-f,-file}'[execute commands from a file first]:file:_files'
  {-i,-interactive}'[start in interactive mode]'
  {-l,-list}'[display a list of all user-defined or matching variables, functions and units]'
  '--list-functions[display a list of all or matching functions]'
  '--list-units[display a list of all or matching units]'
  '--list-variables[display a list of all or matching variables]'
  {-m,-time}'[terminate calculation and display of result after specified amount of time]:milliseconds: '
  {-n,-nodefs}'[do not load any functions, units, or variables from file]'
  '-nocurrencies[do not load any global currencies from file]'
  '-nodatasets[do not load any global data sets from file]'
  '-nofunctions[do not load any global functions from file]'
  '-nounits[do not load any global units from file]'
  '-novariables[do not load any global variables from file]'
  '-p[start in programming mode (same as -b "BASE BASE" -s "xor^", with base conversion)]'
  {-s,-set}'[set a variable value]:variable setting: '
  {-t,-terse}'[reduce output to just the result of the input expression]'
  {-v,-version}'[show application version and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
