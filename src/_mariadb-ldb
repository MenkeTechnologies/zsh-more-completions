#compdef mariadb-ldb

local -a arguments

arguments=(
  '--key_hex[keys are input/output as hex]'
  '--value_hex[values are input/output as hex]'
  '--hex[both keys and values are input/output as hex]'
  '--column_family=[name of the column family to operate on]:column family name: '
  '--ttl[DB supports ttl and value is internally timestamp-suffixed]'
  '--try_load_options[try to load option file from DB]'
  '--ignore_unknown_options[ignore unknown options when loading option file]'
  '--bloom_bits=[number of bloom filter bits per key]:bits: '
  '--fix_prefix_len=[fixed prefix length]:length: '
  '--compression_type=[compression type]:type:(no snappy zlib bzip2 lz4 lz4hc xpress zstd)'
  '--compression_max_dict_bytes=[max dictionary bytes for compression]:bytes: '
  '--block_size=[block size in bytes]:bytes: '
  '--auto_compaction=[enable auto compaction]:bool:(true false)'
  '--db_write_buffer_size=[DB write buffer size]:bytes: '
  '--write_buffer_size=[write buffer size]:bytes: '
  '--file_size=[target file size]:bytes: '
  '*:filename:_files'
)

_arguments -s -S $arguments
