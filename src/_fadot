#compdef fadot
# Documentation: https://man.archlinux.org/search?q=fadot
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-o[operation (show concat union intersect json)]:operation:(show concat union intersect json)'
  '-f[path of output .dot file]:file:_files'
  '-n[do not minimize resulting finite automaton]'
  '*:filename:_files'
)

_arguments -s -S $arguments
