#compdef fq

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-d --decode)'{-d,--decode}'[decode format]:format' \
  '(-r --raw-output)'{-r,--raw-output}'[output raw strings]' \
  '(-R --raw-input)'{-R,--raw-input}'[read raw strings]' \
  '(-j --json-output)'{-j,--json-output}'[output JSON]' \
  '(-c --compact-output)'{-c,--compact-output}'[compact output]' \
  '(-s --slurp)'{-s,--slurp}'[slurp all inputs into array]' \
  '(-n --null-input)'{-n,--null-input}'[use null as input]' \
  '(-f --from-file)'{-f,--from-file}'[read expression from file]:file:_files' \
  '(-e --exit-status)'{-e,--exit-status}'[set exit status based on output]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--formats[show supported formats]' \
  '--include-path[include search path]:path:_files -/' \
  '--decode-file[decode named file]:name file' \
  '--arg[set string variable]:name value' \
  '--argjson[set JSON variable]:name value' \
  '--rawfile[set variable to file contents]:name file:_files' \
  '--jsonfile[set variable to JSON file]:name file:_files' \
  '(-o --option)'{-o,--option}'[set output option]:option' \
  '(-C --color-output)'{-C,--color-output}'[force color output]' \
  '(-M --monochrome-output)'{-M,--monochrome-output}'[force monochrome output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:expression' \
  '*:file:_files' && ret=0
return ret
