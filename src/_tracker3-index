#compdef tracker3-index
# Documentation: https://man.archlinux.org/search?q=tracker3-index
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[show help options]'
  {-a,--add}'[adds FILE as an indexed location]'
  {-d,--remove}'[removes FILE from indexed locations]'
  {-r,--recursive}'[makes indexing recursive]'
  '*:filename:_files'
)

_arguments -s -S $arguments
