#compdef systemd-cat

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help]'
  '--version[show package version]'
  {-t+,--identifier=}'[set syslog identifier]:identifier'
  {-p+,--priority=}'[set priority value]:priority:(emerg alert crit err warning notice info debug)'
  '--stderr-priority=[set default priority level for standard error output]:priority:(emerg alert crit err warning notice info debug)'
  '--level-prefix=[control whether level prefix shall be parsed]:boolean:(true false)'
  '--namespace=[connect to specified journal namespace]:namespace'
  '*::command:_command_names -e'
)

_arguments -s -S $arguments
