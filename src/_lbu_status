#compdef lbu_status
# Documentation: https://man.archlinux.org/search?q=lbu_status
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-a[compare all files, not just since last commit.]'
  '-v[also show include and exclude lists.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
