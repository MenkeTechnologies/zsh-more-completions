#compdef traptoemail
# Documentation: https://man.archlinux.org/search?q=traptoemail
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-s[sets the smtpserver for where to send the mail through.]'
  '-f[sets the email address to be used on the From: line.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
