#compdef bc

# Zsh completion for bc (arbitrary-precision calculator)

_bc() {
    local -a arguments

    arguments=(
        # Digit clamping
        '(-c --digit-clamp)'{-C,--no-digit-clamp}'[disable clamping of digits >= ibase when parsing numbers]'
        '(-C --no-digit-clamp)'{-c,--digit-clamp}'[enable clamping of digits >= ibase when parsing numbers]'

        # Expressions and files
        '*'{-e,--expression=}'[run expression and quit]:expression:'
        '*'{-f,--file=}'[run bc code from file and exit]:file:_files'

        # Variable initialization
        {-E,--seed=}'[set the builtin variable seed (base 10)]:seed:'
        {-I,--ibase=}'[set the builtin variable ibase (base 10)]:ibase:'
        {-O,--obase=}'[set the builtin variable obase (base 10)]:obase:'
        {-S,--scale=}'[set the builtin variable scale (base 10)]:scale:'

        # Behavior options
        {-g,--global-stacks}'[turn scale, ibase, and obase into stacks]'
        {-i,--interactive}'[force interactive mode]'
        {-l,--mathlib}'[use predefined math routines (s, c, a, l, e, j)]'
        {-L,--no-line-length}'[disable line length checking]'
        {-P,--no-prompt}'[disable prompts in interactive mode]'
        {-R,--no-read-prompt}'[disable read prompt in interactive mode]'
        {-q,--quiet}'[do not print version and copyright banner]'
        {-s,--standard}'[error if any non-POSIX extensions are used]'
        {-w,--warn}'[warn about non-POSIX extensions]'
        {-z,--leading-zeroes}'[enable leading zeroes on numbers between -1 and 1]'

        # Redefine keywords
        '*'{-r,--redefine=}'[redefine keyword for use as function/variable/array name]:keyword:'

        # Info
        '(- *)'{-h,--help}'[print usage and exit]'
        '(- *)'{-v,--version}'[print version information and exit]'

        '*:file:_files'
    )

    _arguments -s -S $arguments
}

_bc "$@"
