#compdef quirks-handler

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-e,--enable-quirks}'[enable quirks for package]'
  {-d,--disable-quirks}'[disable quirks for package]'
  {-v,--verbose}'[show debug messages]'
  '*:filename:_files'
)

_arguments -s -S $arguments
