#compdef qmlcachegen

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[displays this help.]'
  {-v,--version}'[displays version information.]'
  '--filter-resource-file[filter out QML/JS files from a resource file]'
  '--resource-file-mapping[path from original resource file to new file]'
  '--resource[qt resource file that might later contain compiled files]'
  '--resource-path[qt resource file path]'
  '-o[output file name]'
  '*:filename:_files'
)

_arguments -s -S $arguments
