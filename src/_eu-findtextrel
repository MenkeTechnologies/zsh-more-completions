#compdef eu-findtextrel
# Documentation: https://man.archlinux.org/search?q=eu-findtextrel
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--debuginfo[use PATH as root of debuginfo hierarchy]'
  {-r,--root}'[prepend PATH to all file names]'
  '--usage[give a short usage message]'
  {-V,--version}'[print program version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
