#compdef virt-qemu-run
# Documentation: https://man.archlinux.org/search?q=virt-qemu-run
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    {-h,--help}'[show help message]'
    {-v,--verbose}'[enable verbose output]'
    {-r,--root}'[specify root directory]'
    {-s,--secret}'[specify secret for authentication]'
    '*:filename:_files'
)
_arguments -s -S $arguments
