#compdef polenum
# Documentation: https://man.archlinux.org/search?q=polenum
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {--username,-u}'[the specified username]'
  {--password,-p}'[the password of the user]'
  {--domain,-d}'[the domain or IP]'
  '--protocols[\[PROTOCOLS ...\]\]]'
  '*:filename:_files'
)

_arguments -s -S $arguments
