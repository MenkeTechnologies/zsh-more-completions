#compdef nc netcat ncat

# Zsh completion for nc (netcat) - arbitrary TCP and UDP connections and listens

_nc() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -s -S \
    '-4[use IPv4 only]' \
    '-6[use IPv6 only]' \
    '-A[set SO_RECV_ANYIF on socket]' \
    '-a[set SO_AWDL_UNRESTRICTED on socket]' \
    '-b[bind socket to interface]:interface:_net_interfaces' \
    '-C[do not use cellular connection]' \
    '-c[send CRLF as line-ending]' \
    '-D[enable debugging on the socket]' \
    '-d[do not attempt to read from stdin]' \
    '-E[do not use expensive interfaces]' \
    '-F[do not use flow advisory]' \
    '-G[TCP connection timeout in seconds]:timeout (seconds):' \
    '-H[initial TCP keep alive timeout in seconds]:keepidle (seconds):' \
    '-h[print help text]' \
    '-I[interval for repeating TCP keep alive timeouts]:keepintvl (seconds):' \
    '-i[delay interval for lines sent, ports scanned]:interval (seconds):' \
    '-J[number of times to repeat TCP keep alive packets]:keepcnt:' \
    '-K[specify traffic class]:traffic class:' \
    '-k[keep inbound sockets open for multiple connects]' \
    '-L[number of probes before adaptive read timeout event]:num probes:' \
    '-l[listen mode, for inbound connects]' \
    '-M[set SO_INTCOPROC_ALLOW on socket]' \
    '-m[set SO_INTCOPROC_ALLOW on socket]' \
    '-N[number of probes before adaptive write timeout event]:num probes:' \
    '-n[suppress name/port resolutions]' \
    '-O[use old-style connect instead of connectx]' \
    '-o[issue socket options after connect/bind]' \
    '-p[specify local port for remote connects]:source port:' \
    '-r[randomize remote ports]' \
    '-s[local source address]:source IP address:_hosts' \
    '-t[answer TELNET negotiation]' \
    '-U[use UNIX domain socket]' \
    '-u[UDP mode]' \
    '-v[verbose output]' \
    '-w[timeout for connects and final net reads]:timeout (seconds):' \
    '-X[proxy protocol]:protocol:((4\:"SOCKS v4" 5\:"SOCKS v5" connect\:"HTTPS proxy"))' \
    '-x[specify proxy address and port]:proxy address\[:port\]:' \
    '-z[zero-I/O mode (used for scanning)]' \
    '--apple-recv-anyif[set SO_RECV_ANYIF on socket]' \
    '--apple-awdl-unres[set SO_AWDL_UNRESTRICTED on socket]' \
    '--apple-boundif[bind socket to interface]:interface:_net_interfaces' \
    '--apple-no-cellular[do not use cellular data context]' \
    '--apple-no-expensive[do not use expensive interfaces]' \
    '--apple-no-flowadv[do not use flow advisory]' \
    '--apple-tcp-timeout[TCP connection timeout in seconds]:timeout (seconds):' \
    '--apple-tcp-keepalive[initial TCP keep alive timeout]:keepidle (seconds):' \
    '--apple-tcp-keepintvl[interval for repeating keep alive timeouts]:keepintvl (seconds):' \
    '--apple-tcp-keepcnt[number of times to repeat keep alive packets]:keepcnt:' \
    '--apple-tclass[specify traffic class]:traffic class:' \
    '--tcp-adp-rtimo[probes before adaptive read timeout event]:num probes:' \
    '--apple-intcoproc-allow[set SO_INTCOPROC_ALLOW on socket]' \
    '--apple-tcp-adp-wtimo[probes before adaptive write timeout event]:num probes:' \
    '--setsockopt-later[issue socket options after connect/bind]' \
    '--apple-no-connectx[use old-style connect instead of connectx]' \
    '--apple-delegate-pid[delegate socket for specified PID]:PID:_pids' \
    '--apple-delegate-uuid[delegate socket for specified UUID]:UUID:' \
    '--apple-kao[set keep alive offload]' \
    '--apple-ext-bk-idle[extended background idle time]' \
    '--apple-netsvctype[set network service type]:service type:' \
    '--apple-nowakefromsleep[no wake from sleep]:n:' \
    '--apple-notify-ack[receive events when data gets acknowledged]' \
    '--apple-sockev[receive and print socket events]' \
    '--apple-ecn[set ECN mode]:mode:(default enable disable)' \
    '--apple-tos[set IP_TOS or IPV6_TCLASS option]:TOS value:' \
    '--apple-tos-cmsg[set IP_TOS or IPV6_TCLASS via cmsg]' \
    '--apple-no-reuseport[do not use SO_REUSEPORT socket option]' \
    '--apple-tcp-maxseg[set TCP_MAXSEG option]:MSS value:' \
    ':hostname:_hosts' \
    '*:port:_ports'
}

_nc "$@"
