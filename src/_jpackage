#compdef jpackage

local -a arguments

arguments=(
  {--type,-t}'[the type of package to create]:type:(app-image dmg pkg)'
  '--app-version[version of the application and/or package]:version:'
  '--copyright[copyright for the application]:string:'
  '--description[description of the application]:string:'
  '(- * :)'{--help,-h}'[print the usage text with a list and description of each valid option]'
  {--name,-n}'[name of the application and/or package]:name:'
  {--dest,-d}'[path where generated output file is placed]:path:_files -/'
  '--temp[path of a temporary directory]:path:_files -/'
  '--vendor[vendor of the application]:string:'
  '--verbose[enables verbose output]'
  '--version[print the product version to the output stream and exit]'
  '--add-modules[comma separated list of modules to add]:modules:'
  {--module-path,-p}'[module path]:path:_files -/'
  '--bind-services[pass on --bind-services option to jlink]'
  '--runtime-image[path of the predefined runtime image]:path:_files -/'
  '--strip-debug[strip debug information]'
  '--no-header-files[exclude include header files]'
  '--no-man-pages[exclude man pages]'
  '--strip-native-commands[strip native commands]'
  '--icon[path of the icon of the application]:file path:_files'
  {--input,-i}'[path of the input directory]:path:_files -/'
  '--add-launcher[name and file path of a launcher]:name=path:'
  '--arguments[command line arguments for the main class]:arguments:'
  '--java-options[options to pass to the Java runtime]:options:'
  '--main-class[qualified name of the application main class]:class name:'
  '--main-jar[the main JAR of the application]:jar file:_files'
  {--module,-m}'[the main module of the application]:module/class:'
  '--mac-package-identifier[an identifier that uniquely identifies the application for macOS]:string:'
  '--mac-package-name[name of the application as it appears in the menu bar]:string:'
  '--mac-package-signing-prefix[signing prefix for signing the package]:string:'
  '--mac-sign[request that the package be signed]'
  '--mac-signing-keychain[path to the keychain to use for signing]:path:_files'
  '--mac-signing-key-user-name[user name portion of the signing identity]:name:'
  '--app-image[location of the predefined application image]:path:_files -/'
  '--file-associations[path to a properties file with file associations]:path:_files'
  '--install-dir[absolute path of the default install location]:path:_files -/'
  '--license-file[path to the license file]:path:_files'
  '--resource-dir[path to override jpackage resources]:path:_files -/'
  '*:filename:_files'
)

_arguments -s -S $arguments
