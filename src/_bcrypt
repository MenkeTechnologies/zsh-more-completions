#compdef bcrypt
# Documentation: https://man.archlinux.org/search?q=bcrypt
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-o[output to standard out]'
  '-r[do NOT remove input files after processing]'
  '-c[do NOT compress files before encryption]'
  '-s[number of times to overwrite input files with random data]:count:'
  '*:filename:_files'
)

_arguments -s -S $arguments
