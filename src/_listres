#compdef listres
# Documentation: https://man.archlinux.org/search?q=listres
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-all[list all known widget and object classes]'
  '-tree[list all widgets and objects in a tree]'
  '-nosuper[do not print superclass resources]'
  '-variable[show variable name instead of class name]'
  '-top[object to be top of tree]'
  '-format[printf format for instance, class, type]'
  '*:filename:_files'
)

_arguments -s -S $arguments
