#compdef rawshark

local -a arguments

arguments=(
  '-r[set the pipe or file name to read from]:file:_files'
  '-d[packet encapsulation or protocol]:encap: '
  '-F[field to display]:field: '
  '-m[virtual memory limit, in bytes]:bytes: '
  '-n[disable all name resolution (def: all enabled)]'
  '-N[enable specific name resolution(s)]:flags: '
  '-p[use the systems packet header format]'
  '-R[packet filter in Wireshark display filter syntax]:filter: '
  '-s[skip PCAP header on input]'
  '-l[flush output after each packet]'
  '-S[format string for fields]:format: '
  '-t[output format of time stamps (def: r: rel. to first)]:format: '
  '-h[display this help and exit]'
  '-o[override preference setting]:preference: '
  '-v[display version info and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
