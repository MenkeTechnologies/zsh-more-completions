#compdef argocd

# Zsh completion for Argo CD CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_argocd_global_flags=(
  '--server[Argo CD server address]:server address:'
  '--auth-token[Authentication token]:token:'
  '--client-crt[Client certificate file]:certificate file:_files'
  '--client-crt-key[Client certificate key file]:key file:_files'
  '--config[Path to Argo CD config]:config file:_files'
  '--grpc-web[Enables gRPC-web protocol]'
  '--grpc-web-root-path[Root path for gRPC-web]:path:'
  '--insecure[Skip server certificate and domain verification]'
  '--logformat[Log format]:format:(text json)'
  '--loglevel[Log level]:level:(debug info warn error)'
  '--plaintext[Disable TLS]'
  '--port-forward[Connect to a random argocd-server port using port forwarding]'
  '--port-forward-namespace[Namespace for port forwarding]:namespace:'
  '(-h --help)'{-h,--help}'[Show help]'
)

_argocd_app_commands() {
  local -a commands
  commands=(
    'create:Create an application'
    'delete:Delete an application'
    'diff:Perform a diff against the target and live state'
    'get:Get application details'
    'list:List applications'
    'set:Set application parameters'
    'sync:Sync an application to its target state'
    'wait:Wait for an application to reach a synced and healthy state'
    'patch:Patch application'
    'history:Show application deployment history'
    'rollback:Rollback application to a previous deployed version'
    'terminate-op:Terminate a running operation on an application'
    'resources:List resource of application'
    'logs:Get logs of application pods'
    'manifests:Print manifests of an application'
    'unset:Unset application parameters'
    'actions:Manage resource actions'
  )
  _describe -t commands 'app commands' commands
}

_argocd_cluster_commands() {
  local -a commands
  commands=(
    'add:Add an external cluster'
    'get:Get cluster information'
    'list:List clusters'
    'rm:Remove a cluster'
    'rotate-auth:Rotate cluster credentials'
  )
  _describe -t commands 'cluster commands' commands
}

_argocd_repo_commands() {
  local -a commands
  commands=(
    'add:Add a repository'
    'list:List configured repositories'
    'rm:Remove a repository'
  )
  _describe -t commands 'repo commands' commands
}

_argocd_proj_commands() {
  local -a commands
  commands=(
    'create:Create a project'
    'delete:Delete a project'
    'get:Get project details'
    'list:List projects'
    'set:Set project parameters'
    'add-destination:Add a project destination'
    'remove-destination:Remove a project destination'
    'add-source:Add a project source repository'
    'remove-source:Remove a project source repository'
    'allow-cluster-resource:Allow a cluster resource'
    'deny-cluster-resource:Deny a cluster resource'
    'allow-namespace-resource:Allow a namespace resource'
    'deny-namespace-resource:Deny a namespace resource'
    'role:Manage project roles'
    'windows:Manage project sync windows'
  )
  _describe -t commands 'proj commands' commands
}

_argocd_account_commands() {
  local -a commands
  commands=(
    'list:List accounts'
    'get-user-info:Get user info'
    'update-password:Update an account password'
    'generate-token:Generate account token'
    'can-i:Check RBAC permissions'
    'bcrypt:Generate bcrypt hash for input password'
    'delete-token:Delete account token'
  )
  _describe -t commands 'account commands' commands
}

_argocd_apps() {
  local -a apps
  apps=(${(f)"$(argocd app list -o name 2>/dev/null)"})
  [[ -n "$apps" ]] && compadd -a apps
}

_argocd_projects() {
  local -a projects
  projects=(${(f)"$(argocd proj list -o name 2>/dev/null)"})
  [[ -n "$projects" ]] && compadd -a projects
}

_argocd_clusters() {
  local -a clusters
  clusters=(${(f)"$(argocd cluster list -o name 2>/dev/null)"})
  [[ -n "$clusters" ]] && compadd -a clusters
}

_arguments -s -S -C \
  "${_argocd_global_flags[@]}" \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'app:Manage applications'
      'cluster:Manage cluster credentials'
      'repo:Manage repository connection parameters'
      'proj:Manage projects'
      'account:Manage accounts'
      'login:Log in to Argo CD'
      'logout:Log out from Argo CD'
      'version:Print version information'
      'context:Switch between contexts'
      'cert:Manage repository certificates and SSH known hosts entries'
      'gpg:Manage GPG keys'
      'repocreds:Manage repository connection parameters'
      'admin:Contains a set of commands for Argo CD administrators'
      'completion:Output shell completion code'
    )
    _describe -t commands 'argocd commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      app)
        _arguments -s -S -C \
          "${_argocd_global_flags[@]}" \
          '1:subcommand:_argocd_app_commands' \
          '*::arg:->app_args' && ret=0
        case "$state" in
          app_args)
            case "${line[1]}" in
              create)
                _arguments -s -S \
                  "${_argocd_global_flags[@]}" \
                  '1:app name:' \
                  '--repo[Repository URL]:url:' \
                  '--path[Path in repository]:path:' \
                  '--dest-server[Destination cluster URL]:url:' \
                  '--dest-namespace[Destination namespace]:namespace:' \
                  '--revision[Source revision]:revision:' \
                  '--project[Application project]:project:_argocd_projects' \
                  '--sync-policy[Sync policy]:policy:(none automated)' \
                  '--auto-prune[Enable auto-prune]' \
                  '--self-heal[Enable self-heal]' \
                  '--directory-recurse[Recurse directories]' \
                  '--values[Helm values files]:files:_files' \
                  '--helm-set[Helm set values]:key=value:' \
                  '--jsonnet-ext-var-str[Jsonnet ext vars]:key=value:' && ret=0
                ;;
              delete)
                _arguments -s -S \
                  "${_argocd_global_flags[@]}" \
                  '1:app name:_argocd_apps' \
                  '--cascade[Perform a cascaded deletion]' \
                  '--propagation-policy[Propagation policy]:policy:(foreground background orphan)' \
                  '(-y --yes)'{-y,--yes}'[Skip confirmation]' && ret=0
                ;;
              get|diff|wait|manifests|history|rollback|terminate-op|resources|logs)
                _arguments -s -S \
                  "${_argocd_global_flags[@]}" \
                  '1:app name:_argocd_apps' \
                  '(-o --output)'{-o,--output}'[Output format]:format:(json yaml wide tree)' && ret=0
                ;;
              list)
                _arguments -s -S \
                  "${_argocd_global_flags[@]}" \
                  '(-o --output)'{-o,--output}'[Output format]:format:(json yaml wide name)' \
                  '--project[Filter by project]:project:_argocd_projects' \
                  '(-l --selector)'{-l,--selector}'[Label selector]:selector:' \
                  '--repo[Filter by repo URL]:url:' && ret=0
                ;;
              set)
                _arguments -s -S \
                  "${_argocd_global_flags[@]}" \
                  '1:app name:_argocd_apps' \
                  '--repo[Repository URL]:url:' \
                  '--path[Path in repository]:path:' \
                  '--dest-server[Destination cluster URL]:url:' \
                  '--dest-namespace[Destination namespace]:namespace:' \
                  '--revision[Source revision]:revision:' \
                  '--project[Application project]:project:_argocd_projects' \
                  '--sync-policy[Sync policy]:policy:(none automated)' \
                  '--values[Helm values files]:files:_files' && ret=0
                ;;
              sync)
                _arguments -s -S \
                  "${_argocd_global_flags[@]}" \
                  '1:app name:_argocd_apps' \
                  '--revision[Sync to a specific revision]:revision:' \
                  '--prune[Allow deleting unexpected resources]' \
                  '--dry-run[Preview apply without affecting cluster]' \
                  '--force[Use a force apply]' \
                  '--strategy[Sync strategy]:strategy:(apply hook)' \
                  '--async[Do not wait for application to sync]' \
                  '--retry-limit[Max number of retries]:count:' \
                  '--resource[Sync only specific resources]:resource:' && ret=0
                ;;
              *)
                _arguments -s -S \
                  "${_argocd_global_flags[@]}" \
                  '1:app name:_argocd_apps' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      cluster)
        _arguments -s -S -C \
          "${_argocd_global_flags[@]}" \
          '1:subcommand:_argocd_cluster_commands' \
          '*::arg:->cluster_args' && ret=0
        case "$state" in
          cluster_args)
            case "${line[1]}" in
              add)
                _arguments -s -S \
                  "${_argocd_global_flags[@]}" \
                  '1:context:' \
                  '--name[Cluster name]:name:' \
                  '--kubeconfig[Path to kubeconfig]:file:_files' \
                  '--namespace[Namespace]:namespace:' \
                  '--in-cluster[Indicates Argo CD resides inside this cluster]' && ret=0
                ;;
              get|rm)
                _arguments -s -S \
                  "${_argocd_global_flags[@]}" \
                  '1:cluster:_argocd_clusters' \
                  '(-o --output)'{-o,--output}'[Output format]:format:(json yaml wide server)' && ret=0
                ;;
              list)
                _arguments -s -S \
                  "${_argocd_global_flags[@]}" \
                  '(-o --output)'{-o,--output}'[Output format]:format:(json yaml wide server)' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      repo)
        _arguments -s -S -C \
          "${_argocd_global_flags[@]}" \
          '1:subcommand:_argocd_repo_commands' \
          '*::arg:->repo_args' && ret=0
        case "$state" in
          repo_args)
            case "${line[1]}" in
              add)
                _arguments -s -S \
                  "${_argocd_global_flags[@]}" \
                  '1:repo url:' \
                  '--username[Username]:username:' \
                  '--password[Password]:password:' \
                  '--ssh-private-key-path[SSH private key path]:file:_files' \
                  '--insecure-ignore-host-key[Skip SSH host key verification]' \
                  '--name[Repository name]:name:' \
                  '--type[Repository type]:type:(git helm)' && ret=0
                ;;
              list)
                _arguments -s -S \
                  "${_argocd_global_flags[@]}" \
                  '(-o --output)'{-o,--output}'[Output format]:format:(json yaml wide)' && ret=0
                ;;
              rm)
                _arguments -s -S \
                  "${_argocd_global_flags[@]}" \
                  '1:repo url:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      proj)
        _arguments -s -S -C \
          "${_argocd_global_flags[@]}" \
          '1:subcommand:_argocd_proj_commands' \
          '*::arg:->proj_args' && ret=0
        case "$state" in
          proj_args)
            case "${line[1]}" in
              create)
                _arguments -s -S \
                  "${_argocd_global_flags[@]}" \
                  '1:project name:' \
                  '--description[Project description]:description:' \
                  '--dest[Permitted destination]:server,namespace:' \
                  '--src[Permitted source repository]:url:' \
                  '--orphaned-resources[Enables orphaned resources monitoring]' && ret=0
                ;;
              delete)
                _arguments -s -S \
                  "${_argocd_global_flags[@]}" \
                  '1:project name:_argocd_projects' && ret=0
                ;;
              get)
                _arguments -s -S \
                  "${_argocd_global_flags[@]}" \
                  '1:project name:_argocd_projects' \
                  '(-o --output)'{-o,--output}'[Output format]:format:(json yaml wide)' && ret=0
                ;;
              list)
                _arguments -s -S \
                  "${_argocd_global_flags[@]}" \
                  '(-o --output)'{-o,--output}'[Output format]:format:(json yaml)' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      account)
        _arguments -s -S -C \
          "${_argocd_global_flags[@]}" \
          '1:subcommand:_argocd_account_commands' \
          '*::arg:->account_args' && ret=0
        case "$state" in
          account_args)
            case "${line[1]}" in
              update-password)
                _arguments -s -S \
                  "${_argocd_global_flags[@]}" \
                  '--account[Account name]:account:' \
                  '--current-password[Current password]:password:' \
                  '--new-password[New password]:password:' && ret=0
                ;;
              generate-token)
                _arguments -s -S \
                  "${_argocd_global_flags[@]}" \
                  '--account[Account name]:account:' \
                  '--expires-in[Token expiry duration]:duration:' \
                  '--id[Token ID]:id:' && ret=0
                ;;
              can-i)
                _arguments -s -S \
                  "${_argocd_global_flags[@]}" \
                  '1:action:(get create update delete sync action override)' \
                  '2:resource:(applications clusters repositories projects accounts certificates gpgkeys logs exec)' \
                  '3:object:' && ret=0
                ;;
              list|get-user-info)
                _arguments -s -S \
                  "${_argocd_global_flags[@]}" \
                  '(-o --output)'{-o,--output}'[Output format]:format:(json yaml wide)' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      login)
        _arguments -s -S \
          "${_argocd_global_flags[@]}" \
          '1:server:' \
          '--username[Username]:username:' \
          '--password[Password]:password:' \
          '--sso[Perform SSO login]' \
          '--sso-port[Port for SSO login callback]:port:' && ret=0
        ;;
      logout)
        _arguments -s -S \
          "${_argocd_global_flags[@]}" \
          '1:server:' && ret=0
        ;;
      context)
        _arguments -s -S \
          "${_argocd_global_flags[@]}" \
          '1:context name:' \
          '--delete[Delete the context]' && ret=0
        ;;
      version)
        _arguments -s -S \
          "${_argocd_global_flags[@]}" \
          '--client[Only show client version]' \
          '--short[Show short version]' \
          '(-o --output)'{-o,--output}'[Output format]:format:(json yaml)' && ret=0
        ;;
    esac
    ;;
esac

return ret
