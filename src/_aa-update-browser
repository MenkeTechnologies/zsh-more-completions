#compdef aa-update-browser
# Documentation: https://man.archlinux.org/search?q=aa-update-browser
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-u[comma separated list of abstractions for profile to use]'
  '-d[dry-run. Only show what would be done.]'
  '-l[list available abstractions]'
  '-h[this message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
