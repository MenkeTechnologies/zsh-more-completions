#compdef csd-list-wacom
# Documentation: https://man.archlinux.org/search?q=csd-list-wacom
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  {-f,--fake}'[output fake devices]'
  {-m,--monitor}'[monitor changing styli]'
  {-d,--debug}'[debug output]'
  '*:filename:_files'
)

_arguments -s -S $arguments
