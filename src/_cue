#compdef cue

# Zsh completion for CUE language CLI

local curcontext="$curcontext" state line ret=1

local -a global_flags=(
  '(-v --verbose)'{-v,--verbose}'[Print information about programs being run]'
  '--trace[Trace computation]'
  '--help[Show help]'
)

local -a eval_export_flags=(
  '(-e --expression)'{-e,--expression}'[Evaluate this expression only]:expression'
  '--out[Output format]:format:(json yaml text cue)'
  '--outfile[Write output to this file]:output file:_files'
  '(-p --package)'{-p,--package}'[Package name for non-CUE files]:package name'
  '(-l --path)'{-l,--path}'[CUE expression for single path component]:path expression'
  '--force[Force overwriting existing files]'
  '--list[Concatenate multiple objects into a list]'
  '--merge[Merge non-CUE files]'
  '--all-errors[Print all errors]'
  '(-c --concrete)'{-c,--concrete}'[Require concrete values]'
  '(-S --simplify)'{-S,--simplify}'[Simplify output]'
  '--strict[Report errors for lossy mappings]'
  '(-t --inject)'{-t,--inject}'[Set value of a tagged field]:key=value'
  '(-T --inject-vars)'{-T,--inject-vars}'[Inject system variables]'
  '(-I --include)'{-I,--include}'[Include a directory for imports]:directory:_files -/'
)

local -a commands=(
  'cmd:Run a user-defined workflow command'
  'completion:Generate completion script'
  'def:Print CUE definitions'
  'eval:Evaluate and print a configuration'
  'export:Output data in a standard format'
  'fix:Rewrite packages to latest standards'
  'fmt:Formats CUE configuration files'
  'get:Add non-CUE dependencies'
  'import:Convert other formats to CUE'
  'mod:Module maintenance'
  'trim:Remove superfluous fields'
  'version:Print CUE version'
  'vet:Validate data'
  'help:Help about any command'
)

_arguments -s -S -C \
  $global_flags \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'cue command' commands && ret=0
    ;;
  args)
    case $words[1] in
      eval)
        _arguments -s -S \
          $global_flags \
          $eval_export_flags \
          '--all[Show optional and hidden fields]' \
          '--attributes[Display field attributes]' \
          '*:file:_files' && ret=0
        ;;
      export)
        _arguments -s -S \
          $global_flags \
          $eval_export_flags \
          '--escape[Use HTML escaping]' \
          '*:file:_files' && ret=0
        ;;
      def)
        _arguments -s -S \
          $global_flags \
          '(-e --expression)'{-e,--expression}'[Evaluate this expression only]:expression' \
          '--out[Output format]:format:(json yaml text cue)' \
          '--outfile[Write output to this file]:output file:_files' \
          '(-p --package)'{-p,--package}'[Package name]:package name' \
          '--force[Force overwriting existing files]' \
          '--all-errors[Print all errors]' \
          '(-S --simplify)'{-S,--simplify}'[Simplify output]' \
          '(-I --include)'{-I,--include}'[Include directory]:directory:_files -/' \
          '*:file:_files' && ret=0
        ;;
      vet)
        _arguments -s -S \
          $global_flags \
          '(-e --expression)'{-e,--expression}'[Evaluate this expression only]:expression' \
          '(-p --package)'{-p,--package}'[Package name]:package name' \
          '(-c --concrete)'{-c,--concrete}'[Require concrete values]' \
          '--all-errors[Print all errors]' \
          '--strict[Report errors for lossy mappings]' \
          '(-t --inject)'{-t,--inject}'[Set value of a tagged field]:key=value' \
          '(-T --inject-vars)'{-T,--inject-vars}'[Inject system variables]' \
          '(-I --include)'{-I,--include}'[Include directory]:directory:_files -/' \
          '*:file:_files' && ret=0
        ;;
      fmt)
        _arguments -s -S \
          $global_flags \
          '--check[Check if files are formatted without changing them]' \
          '--diff[Display diffs instead of rewriting files]' \
          '--simplify[Remove superfluous constructs]' \
          '*:file:_files -g "*.cue"' && ret=0
        ;;
      fix)
        _arguments -s -S \
          $global_flags \
          '--force[Rewrite even when there are errors]' \
          '*:file:_files' && ret=0
        ;;
      import)
        _arguments -s -S \
          $global_flags \
          '(-p --package)'{-p,--package}'[Package name]:package name' \
          '(-l --path)'{-l,--path}'[CUE expression for single path component]:path expression' \
          '--force[Force overwriting existing files]' \
          '--list[Concatenate multiple objects into a list]' \
          '--files[Split multiple entries into different files]' \
          '--recursive[Recursively process directories]' \
          '--ext[File extension for input]:extension' \
          '*:file:_files' && ret=0
        ;;
      get)
        local -a get_cmds=(
          'go:Add Go dependencies'
        )
        _arguments -s -S -C \
          $global_flags \
          '1:get command:->get_cmd' \
          '*::arg:->get_args' && ret=0
        case $state in
          get_cmd)
            _describe -t commands 'get command' get_cmds && ret=0
            ;;
          get_args)
            case $words[1] in
              go)
                _arguments -s -S \
                  $global_flags \
                  '--local[Generate CUE packages in the main module]' \
                  '--exclude[Exclude packages matching pattern]:pattern' \
                  '*:package' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      mod)
        local -a mod_cmds=(
          'init:Initialize a new module'
          'publish:Publish current module to a registry'
          'tidy:Download and tidy module dependencies'
        )
        _arguments -s -S -C \
          $global_flags \
          '1:mod command:->mod_cmd' \
          '*::arg:->mod_args' && ret=0
        case $state in
          mod_cmd)
            _describe -t commands 'mod command' mod_cmds && ret=0
            ;;
          mod_args)
            case $words[1] in
              init)
                _arguments -s -S \
                  $global_flags \
                  '--source[Module source]:source:(self git)' \
                  ':module path' && ret=0
                ;;
              publish)
                _arguments -s -S \
                  $global_flags \
                  ':version' && ret=0
                ;;
              tidy)
                _arguments -s -S \
                  $global_flags \
                  '--check[Check that module is tidy without making changes]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      trim)
        _arguments -s -S \
          $global_flags \
          '--out[Output format]:format:(json yaml text cue)' \
          '--outfile[Write output to this file]:output file:_files' \
          '(-p --package)'{-p,--package}'[Package name]:package name' \
          '*:file:_files' && ret=0
        ;;
      cmd)
        _arguments -s -S \
          $global_flags \
          ':command name' \
          '*:file:_files' && ret=0
        ;;
      completion)
        _arguments -s -S \
          $global_flags \
          ':shell:(bash zsh fish powershell)' && ret=0
        ;;
      version)
        _arguments -s -S \
          $global_flags && ret=0
        ;;
    esac
    ;;
esac

return ret
