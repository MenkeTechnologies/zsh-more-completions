#compdef luac
# Documentation: https://man.archlinux.org/search?q=luac
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-l[list]'
  '-o[output to file name (default is "luac.out")]'
  '-p[parse only]'
  '-s[strip debug information]'
  '-v[show version information]'
  '*:filename:_files'
)

_arguments -s -S $arguments
