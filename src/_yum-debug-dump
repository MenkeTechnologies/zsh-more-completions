#compdef yum-debug-dump
# Documentation: https://man.archlinux.org/search?q=yum-debug-dump
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[show this help message and exit]'
  '--norepos[do not attempt to dump the repository contents]'
  '*:filename:_files'
)

_arguments -s -S $arguments
