#compdef loc

# Zsh completion for loc - Lines of Code counter

_arguments \
  '--help[print help information]' \
  '--version[print version information]' \
  '--files[show statistics for individual files]' \
  '--sort[sort output by column]:column:(language blanks code comments files lines)' \
  '--unrestricted[do not respect ignore files]' \
  '*--exclude[exclude files matching pattern]:pattern:' \
  '*--include[include only files matching pattern]:pattern:' \
  '*:path:_files'
