#compdef gpgme-config

local -a arguments

arguments=(
  '--prefix[output installation prefix]'
  '--exec-prefix[output exec installation prefix]'
  '--version[output version information]'
  '--api-version[output API version]'
  '--host[output host triplet]'
  '--libs[output linker flags]'
  '--cflags[output compiler flags]'
  '--print-lang[print available language bindings]'
  '--have-lang[return success if LANG is available]'
  '*:filename:_files'
)

_arguments -s -S $arguments
