#compdef log2asc
# Documentation: https://man.archlinux.org/search?q=log2asc
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-I[(default stdin)]'
  '-O[(default stdout)]'
  '-4[(reduce decimal place to 4 digits)]'
  '-n[(set newline to cr/lf - default lf)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
