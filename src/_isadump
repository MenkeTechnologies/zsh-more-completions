#compdef isadump
# Documentation: https://man.archlinux.org/search?q=isadump
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-k[super-I/O configuration access key]'
  '-f[enable flat address space mode]'
  '-y[assume affirmative answer to all questions]'
  '-W[read and display word (16-bit) values]'
  '-L[read and display long (32-bit) values]'
  '*:filename:_files'
)

_arguments -s -S $arguments
