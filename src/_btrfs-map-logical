#compdef btrfs-map-logical
# Documentation: https://man.archlinux.org/search?q=btrfs-map-logical
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-l[extent to map]'
  '-c[of the extent to read (usually 1 or 2)]'
  '-o[file to hold the extent]'
  '-b[of bytes to read]'
  '*:filename:_files'
)

_arguments -s -S $arguments
