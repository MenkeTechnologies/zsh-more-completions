#compdef json_reformat
# Documentation: https://man.archlinux.org/search?q=json_reformat
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-m[json rather than beautify (default)]'
  '-u[invalid UTF8 inside strings during parsing]'
  '-e[any forward slashes (for embedding in HTML)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
