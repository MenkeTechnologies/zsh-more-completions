#compdef ri2.3

local -a arguments

arguments=(
  {-i,--}'[in interactive mode you can repeatedly look up methods]'
  {-a,--}'[show all documentation for a class or module]'
  {-l,--}'[list classes ri knows about]'
  '-T[synonym for --no-pager]'
  {-w,--width}'[set the width of the output.]'
  '--server[run RDoc server on the given port.]'
  {-f,--format}'[uses the selected formatter]'
  {-d,--doc-dir}'[list of directories from which to source documentation]'
  '--no-standard-docs[do not include documentation from the Ruby standard library]'
  '--dump[dumps data from an ri cache or data file]'
  '*:filename:_files'
)

_arguments -s -S $arguments
