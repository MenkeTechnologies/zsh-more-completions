#compdef bluetooth-player
# Documentation: https://man.archlinux.org/search?q=bluetooth-player
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--monitor[monitor output]'
  '--timeout[in seconds for non-interactive mode]'
  '--version[version]'
  '--help[display help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
