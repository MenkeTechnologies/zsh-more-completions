#compdef tabulate

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this message]'
  {-1,--header}'[use the first row of data as a table header]'
  {-o,--output}'[print table to FILE (default: stdout)]:file:_files'
  {-s,--sep}'[use a custom column separator (default: whitespace)]:separator:'
  {-F,--float}'[floating point number format (default: g)]:format:'
  {-f,--format}'[set output table format]:format:'
  '*:filename:_files'
)

_arguments -s -S $arguments
