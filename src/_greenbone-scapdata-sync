#compdef greenbone-scapdata-sync
# Documentation: https://man.archlinux.org/search?q=greenbone-scapdata-sync
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--describe[display current feed info]'
  '--feedversion[display version of this feed]'
  '--help[display this help]'
  '--identify[display information]'
  '--migrate[migrate database without downloading new state]'
  '--refresh[update database without downloading new state]'
  '--refresh-private[database using only user data]'
  '--selftest[perform self-test]'
  '--version[display version]'
  '--verbose[enable verbose log messages]'
  '*:filename:_files'
)

_arguments -s -S $arguments
