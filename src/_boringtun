#compdef boringtun

local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)--version[show version]'
  {-f,--foreground}'[run in the foreground]'
  '--threads=[number of threads]:n:'
  '--verbosity=[verbosity level]:level:(silent info debug trace)'
  '--uapi-fd=[file descriptor for UAPI]:fd:'
  '--log=[log file path]:file:_files'
  '--disable-drop-privileges[do not drop privileges after setup]'
  '--disable-connected-udp[disable connected UDP sockets]'
  '1:interface name:'
)

_arguments -s -S $arguments
