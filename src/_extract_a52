#compdef extract_a52
# Documentation: https://man.archlinux.org/search?q=extract_a52
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-s[set track number (0-7 or 0x80-0x87)]'
  '-t[use transport stream demultiplexer, pid 0x10-0x1ffe]'
  '*:filename:_files'
)

_arguments -s -S $arguments
