#compdef hal-is-caller-privileged
# Documentation: https://man.archlinux.org/search?q=hal-is-caller-privileged
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--caller[\[--help\] \[--version\]]'
  '--udi[unique Device Id]'
  '--action[policyKit action to check for]'
  '--caller[the name of the caller]'
  '--version[show version and exit]'
  '--help[show this information and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
