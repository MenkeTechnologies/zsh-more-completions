#compdef ion

# Zsh completion for ion (Ion shell)

_arguments -s -S \
  '(-c --command)'{-c,--command}'[evaluate given command]:command:' \
  '(-n --no-execute)'{-n,--no-execute}'[parse but do not execute]' \
  '(-x --trace)'{-x,--trace}'[enable execution tracing]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o)'-o'[set shell option]:option:' \
  '*:script file:_files' && return 0
