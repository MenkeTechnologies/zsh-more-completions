#compdef djxl_fuzzer_corpus
# Documentation: https://man.archlinux.org/search?q=djxl_fuzzer_corpus
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-r[files if already exist.]'
  '-q[quiet.]'
  '-j[number of parallel jobs to run.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
