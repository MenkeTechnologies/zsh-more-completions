#compdef execsnoop
# Documentation: https://man.archlinux.org/search?q=execsnoop
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-a[# print all data]'
  '-A[# dump all data, space delimited]'
  '-e[# safe output, parseable]'
  '-j[# print project ID]'
  '-s[# print start time, us]'
  '-v[# print start time, string]'
  '-c[# command name to snoop]'
  '*:filename:_files'
)

_arguments -s -S $arguments
