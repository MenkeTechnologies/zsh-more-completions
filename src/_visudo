#compdef visudo

local -a arguments

arguments=(
  {-c,--check}'[check-only mode; existing sudoers file will be checked for syntax errors]'
  {-f,--file=}'[specify an alternate sudoers file location]:sudoers file:_files'
  '(- * :)'{-h,--help}'[display help message and exit]'
  {-I,--no-includes}'[do not edit include files]'
  {-q,--quiet}'[less verbose (quiet) syntax error messages]'
  {-s,--strict}'[strict syntax checking; warn about entries not in canonical form]'
  '(- * :)'{-V,--version}'[display version information and exit]'
)

_arguments -s -S $arguments
