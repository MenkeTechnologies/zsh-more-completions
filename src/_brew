#compdef brew

# Zsh completion for Homebrew
# https://github.com/Homebrew/brew

_brew_installed_formulae() {
  local -a formulae
  formulae=(${(f)"$(brew list --formula -1 2>/dev/null)"})
  _describe 'installed formulae' formulae
}

_brew_installed_casks() {
  local -a casks
  casks=(${(f)"$(brew list --cask -1 2>/dev/null)"})
  _describe 'installed casks' casks
}

_brew_all_formulae() {
  local -a formulae
  formulae=(${(f)"$(brew formulae 2>/dev/null)"})
  _describe 'formulae' formulae
}

_brew_all_casks() {
  local -a casks
  casks=(${(f)"$(brew casks 2>/dev/null)"})
  _describe 'casks' casks
}

_brew_taps() {
  local -a taps
  taps=(${(f)"$(brew tap 2>/dev/null)"})
  _describe 'taps' taps
}

_brew_installed_or_all() {
  _alternative \
    'installed-formulae:installed formula:_brew_installed_formulae' \
    'all-formulae:formula:_brew_all_formulae' \
    'all-casks:cask:_brew_all_casks'
}

_brew_outdated() {
  local -a outdated
  outdated=(${(f)"$(brew outdated --quiet 2>/dev/null)"})
  _describe 'outdated formulae/casks' outdated
}

_brew_services_list() {
  local -a services
  services=(${(f)"$(brew services list 2>/dev/null | tail -n +2 | awk '{print $1}')"})
  _describe 'service' services
}

_brew_services_commands() {
  local -a cmds
  cmds=(
    'run:run the service formula without registering to launch at login'
    'start:start the service formula immediately and register it to launch at login'
    'stop:stop the service formula immediately and unregister it from launching at login'
    'restart:stop and start the service formula immediately'
    'list:list information about all managed services'
    'cleanup:remove all unused services'
    'info:show information about a service'
  )
  _describe 'services command' cmds
}

_brew_analytics_commands() {
  local -a cmds
  cmds=(
    'state:display the current state of analytics'
    'on:turn on analytics'
    'off:turn off analytics'
    'regenerate-uuid:regenerate the analytics UUID'
  )
  _describe 'analytics command' cmds
}

_brew_completions_commands() {
  local -a cmds
  cmds=(
    'state:display the current state of completions'
    'link:link completions'
    'unlink:unlink completions'
  )
  _describe 'completions command' cmds
}

_brew_developer_commands() {
  local -a cmds
  cmds=(
    'state:display the current state of developer mode'
    'on:turn on developer mode'
    'off:turn off developer mode'
  )
  _describe 'developer command' cmds
}

_brew() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a global_flags
  global_flags=(
    '(--help -h)'{--help,-h}'[show help message]'
    '--version[show version]'
    '(--verbose -v)'{--verbose,-v}'[make some output more verbose]'
    '(--debug -d)'{--debug,-d}'[display any debugging information]'
    '(--quiet -q)'{--quiet,-q}'[make some output more quiet]'
    '(--force -f)'{--force,-f}'[override warnings and enable potentially unsafe operations]'
    '--env[summarize the build environment]:env:(std super)'
  )

  _arguments -C \
    $global_flags \
    '1:command:->command' \
    '*::arg:->args' && return 0

  case $state in
    command)
      local -a commands
      commands=(
        # Principal commands
        'install:install a formula or cask'
        'uninstall:uninstall a formula or cask'
        'remove:uninstall a formula or cask'
        'rm:uninstall a formula or cask'
        'upgrade:upgrade outdated casks and formulae'
        'reinstall:uninstall and then reinstall a formula or cask'
        'info:display information about a formula or cask'
        'abv:display information about a formula or cask'
        'list:list installed formulae and casks'
        'ls:list installed formulae and casks'
        'search:perform a substring search of cask tokens and formula names'
        'update:fetch the newest version of Homebrew and all formulae'
        'outdated:list installed casks and formulae that have an updated version available'

        # Dependency commands
        'autoremove:uninstall formulae that were only installed as a dependency and are now no longer needed'
        'deps:show dependencies for a formula or cask'
        'uses:show formulae and casks that specify a formula as a dependency'
        'leaves:list installed formulae that are not dependencies of another installed formula'
        'missing:check the given formula kegs for missing dependencies'

        # Linking commands
        'pin:pin the specified formula to the current version'
        'unpin:unpin a formula allowing it to be upgraded'
        'link:symlink all installed files for a formula into the Homebrew prefix'
        'ln:symlink all installed files for a formula into the Homebrew prefix'
        'unlink:remove symlinks for a formula from the Homebrew prefix'

        # Tap commands
        'tap:tap a formula repository'
        'untap:remove a tapped formula repository'
        'tap-info:display detailed information about taps'

        # Informational commands
        'config:show Homebrew and system configuration info'
        'doctor:check your system for potential problems'
        'dr:check your system for potential problems'
        'commands:show lists of built-in and external commands'
        'command:display the path to a command'
        'desc:display a description of a formula or cask'
        'home:open the homepage of a formula or cask'
        'homepage:open the homepage of a formula or cask'
        'log:show the git log for a formula or cask'
        'options:show install options specific to a formula'
        'cat:display the source of a formula or cask'

        # Maintenance commands
        'cleanup:remove stale lock files and outdated downloads'
        'migrate:migrate renamed packages to new names'
        'readall:import all items from the specified tap or all installed taps'
        'postinstall:rerun the post-install steps for a formula'
        'shellenv:print export statements for Homebrew environment variables'

        # Development commands
        'audit:check a formula or cask for Homebrew coding style violations'
        'bump:display close to expiring or expired formulae and casks'
        'bump-formula-pr:create a pull request to update a formula'
        'bump-cask-pr:create a pull request to update a cask'
        'create:generate a formula or cask from a URL'
        'edit:open a formula or cask in an editor'
        'fetch:download a bottle or source for a formula or cask'
        'formulae:list all locally installable formulae'
        'casks:list all locally installable casks'
        'developer:switch between developer and normal mode'
        'irb:enter the interactive Homebrew Ruby shell'
        'prof:run Homebrew with a Ruby profiler'
        'test-bot:run Homebrew test-bot'
        'typecheck:check for typechecking errors using Sorbet'
        'unbottled:show the unbottled dependents of formulae'
        'update-report:display what changed after a successful brew update'
        'completions:manage completions for Homebrew commands'
        'gist-logs:upload logs for a failed build of a formula to a Gist'

        # Services
        'services:manage background services with macOS launchctl daemon manager'

        # Analytics
        'analytics:manage anonymous aggregate user behaviour analytics'

        # Bundle
        'bundle:bundler for non-Ruby dependencies from Homebrew, casks and the Mac App Store'

        # Cache / prefix
        '--cache:display Homebrew cache location'
        '--cellar:display Homebrew Cellar path'
        '--caskroom:display Homebrew Caskroom path'
        '--prefix:display Homebrew install path'
        '--repository:display Homebrew repository path'

        # MCP server
        'mcp-server:start Homebrew MCP server'
      )
      _describe 'brew command' commands
      ;;

    args)
      case $line[1] in
        install)
          _arguments -s \
            '--cask[treat all named arguments as casks]' \
            '--formula[treat all named arguments as formulae]' \
            '(--force -f)'{--force,-f}'[install without checking for previously installed keg-only or non-migrated versions]' \
            '(--verbose -v)'{--verbose,-v}'[make some output more verbose]' \
            '(--debug -d)'{--debug,-d}'[display any debugging information]' \
            '(--quiet -q)'{--quiet,-q}'[make some output more quiet]' \
            '(-n --dry-run)'{-n,--dry-run}'[show what would be installed]' \
            '--HEAD[install the HEAD version if available]' \
            '--fetch-HEAD[fetch the upstream repository to detect if the HEAD installation is outdated]' \
            '--keep-tmp[retain the temporary files created during installation]' \
            '(-s --build-from-source)'{-s,--build-from-source}'[compile the formula from source]' \
            '--force-bottle[install from a bottle even if it would not normally be used for installation]' \
            '--include-test[install testing dependencies required to run brew test]' \
            '--build-bottle[prepare the formula for eventual bottling during installation]' \
            '--bottle-arch[optimise bottles for the specified architecture]:architecture:(x86_64 arm64)' \
            '--interactive[download and patch formula, then open a shell]' \
            '--git[create a Git repository for building the formula from source]' \
            '--overwrite[delete files that already exist in the prefix while linking]' \
            '--appdir[target location for Applications]:dir:_directories' \
            '--language[comma-separated list of language codes to prefer for cask installation]:languages:' \
            '--no-binaries[disable/enable linking of helper executables]' \
            '--no-quarantine[disable quarantine of downloads]' \
            '--adopt[adopt existing artifacts in the destination that are identical to those being installed]' \
            '--skip-cask-deps[skip installing cask dependencies]' \
            '--zap[remove all files associated with a cask]' \
            '--require-sha[require all casks to have a checksum]' \
            '--display-times[print install times for each formula at the end of the run]' \
            '--skip-post-install[skip running post-install steps for formulae]' \
            '*:formula or cask:_brew_installed_or_all'
          ;;

        uninstall|remove|rm)
          _arguments -s \
            '(--force -f)'{--force,-f}'[delete all installed versions of a formula]' \
            '--zap[remove all files associated with a cask]' \
            '--cask[treat all named arguments as casks]' \
            '--formula[treat all named arguments as formulae]' \
            '--ignore-dependencies[do not fail uninstall even if formulae still depend on this one]' \
            '*:installed formula or cask:_alternative "formulae:formula:_brew_installed_formulae" "casks:cask:_brew_installed_casks"'
          ;;

        upgrade)
          _arguments -s \
            '--cask[treat all named arguments as casks]' \
            '--formula[treat all named arguments as formulae]' \
            '(--force -f)'{--force,-f}'[install formulae without checking for previously installed keg-only versions]' \
            '(--verbose -v)'{--verbose,-v}'[make some output more verbose]' \
            '(--debug -d)'{--debug,-d}'[display any debugging information]' \
            '(--quiet -q)'{--quiet,-q}'[make some output more quiet]' \
            '(-n --dry-run)'{-n,--dry-run}'[show what would be upgraded]' \
            '--greedy[include casks with auto_updates true or version :latest]' \
            '--greedy-latest[include casks with version :latest]' \
            '--greedy-auto-updates[include casks with auto_updates true]' \
            '--fetch-HEAD[fetch the upstream repository to detect if the HEAD installation is outdated]' \
            '--no-quarantine[disable quarantine of downloads]' \
            '--skip-cask-deps[skip installing cask dependencies]' \
            '--display-times[print install times for each formula at the end of the run]' \
            '--interactive[download and patch formula, then open a shell]' \
            '--no-binaries[disable linking of helper executables]' \
            '*:installed formula or cask:_brew_outdated'
          ;;

        search)
          _arguments -s \
            '--cask[search for casks]' \
            '--formula[search for formulae]' \
            '--desc[search for formulae with a description matching text]' \
            '--pull-request[search for GitHub pull requests containing text]' \
            '--open[search for only open GitHub pull requests]' \
            '--closed[search for only closed GitHub pull requests]' \
            '--eval-all[evaluate all available formulae and casks]' \
            '*:search text:'
          ;;

        info|abv)
          _arguments -s \
            '--cask[treat all named arguments as casks]' \
            '--formula[treat all named arguments as formulae]' \
            '--json[print a JSON representation]:version:(v1 v2)' \
            '--installed[print JSON of formulae that are currently installed]' \
            '--eval-all[evaluate all available formulae and casks]' \
            '--all[print JSON of all available formulae]' \
            '--variations[include variations hash in each formula JSON object]' \
            '--analytics[list global Homebrew analytics data]' \
            '--days[how many days of analytics data to retrieve]:days:(30 90 365)' \
            '--category[which type of analytics data to retrieve]:category:(install install-on-request cask-install build-error os-version)' \
            '--github[open the GitHub source page for a formula or cask in a browser]' \
            '(--verbose -v)'{--verbose,-v}'[show more verbose analytics data for formulae]' \
            '*:formula or cask:_brew_installed_or_all'
          ;;

        list|ls)
          _arguments -s \
            '--cask[list only casks]' \
            '--formula[list only formulae]' \
            '-1[force output to be one entry per line]' \
            '-l[use long listing format]' \
            '-r[reverse the order of the sort]' \
            '-t[sort by time modified]' \
            '--full-name[print formulae with fully-qualified names]' \
            '--versions[show the version number for installed formulae]' \
            '--pinned[list pinned formulae]' \
            '--multiple[only show formulae with multiple versions installed]' \
            '*:installed formula or cask:_brew_installed_formulae'
          ;;

        cleanup)
          _arguments -s \
            '--prune[remove all cache files older than specified days]:days:' \
            '(-n --dry-run)'{-n,--dry-run}'[show what would be removed]' \
            '-s[scrub the cache including downloads for even the latest versions]' \
            '--prune-prefix[only prune the symlinks and directories from the prefix]' \
            '*:formula or cask:_brew_installed_formulae'
          ;;

        services)
          _arguments -C \
            '--all[run command on all services]' \
            '--file[use the service file from this location]:file:_files' \
            '--json[output as JSON]' \
            '--no-wait[do not wait for service to finish]' \
            '--sudo-service-user[when run as root on macOS, run the service as this user]:user:_users' \
            '1:services command:_brew_services_commands' \
            '*:formula:_brew_services_list'
          ;;

        deps)
          _arguments -s \
            '--tree[show dependencies as a tree]' \
            '--graph[show dependencies as a directed graph]' \
            '--all[list dependencies for all available formulae]' \
            '--installed[list dependencies for all installed formulae]' \
            '--formula[treat all named arguments as formulae]' \
            '--cask[treat all named arguments as casks]' \
            '--eval-all[evaluate all available formulae and casks]' \
            '--for-each[switch into the mode used by the --all option]' \
            '--union[show the union of dependencies for multiple formula]' \
            '-1[only show dependencies one level down]' \
            '-n[show dependencies in topological order]' \
            '--annotate[mark any build, test, implicit, optional, or recommended dependencies]' \
            '--include-build[include :build dependencies]' \
            '--include-test[include :test dependencies]' \
            '--include-optional[include :optional dependencies]' \
            '--skip-recommended[skip :recommended dependencies]' \
            '--missing[show only missing dependencies]' \
            '*:formula or cask:_brew_installed_or_all'
          ;;

        uses)
          _arguments -s \
            '--formula[include only formulae]' \
            '--cask[include only casks]' \
            '--installed[only list uses that are currently installed]' \
            '--eval-all[evaluate all available formulae and casks]' \
            '--recursive[resolve more than one level of dependencies]' \
            '--include-build[include :build dependencies]' \
            '--include-test[include :test dependencies]' \
            '--include-optional[include :optional dependencies]' \
            '--skip-recommended[skip :recommended dependencies]' \
            '*:formula:_brew_all_formulae'
          ;;

        tap)
          _arguments -s \
            '--full[perform a full clone of the repository]' \
            '--shallow[perform a shallow clone of the repository]' \
            '--force-auto-update[auto-update tap even if it is not hosted on GitHub]' \
            '--no-force-auto-update[do not auto-update tap]' \
            '--custom-remote[install or change a tap with a custom remote]' \
            '--repair[repair tap formulae names]' \
            '--eval-all[evaluate all the formulae, casks, aliases, commands in the tap]' \
            '--list-pinned[list all pinned taps]' \
            '(--force -f)'{--force,-f}'[force tap even if the remote does not match]' \
            '*:tap:_brew_taps'
          ;;

        untap)
          _arguments -s \
            '(--force -f)'{--force,-f}'[untap even if formulae or casks from this tap are currently installed]' \
            '*:tap:_brew_taps'
          ;;

        tap-info)
          _arguments -s \
            '--json[print a JSON representation]' \
            '--installed[show information on each installed tap]' \
            '*:tap:_brew_taps'
          ;;

        pin)
          _arguments '*:installed formula:_brew_installed_formulae'
          ;;

        unpin)
          _arguments '*:installed formula:_brew_installed_formulae'
          ;;

        link|ln)
          _arguments -s \
            '--overwrite[delete files that already exist in the prefix while linking]' \
            '(-n --dry-run)'{-n,--dry-run}'[list files which would be linked or deleted]' \
            '(--force -f)'{--force,-f}'[allow keg-only formulae to be linked]' \
            '--HEAD[link the HEAD version of the formula if it is installed]' \
            '*:installed formula:_brew_installed_formulae'
          ;;

        unlink)
          _arguments -s \
            '(-n --dry-run)'{-n,--dry-run}'[list files which would be unlinked]' \
            '*:installed formula:_brew_installed_formulae'
          ;;

        analytics)
          _arguments '1:analytics command:_brew_analytics_commands'
          ;;

        completions)
          _arguments '1:completions command:_brew_completions_commands'
          ;;

        developer)
          _arguments '1:developer command:_brew_developer_commands'
          ;;

        audit)
          _arguments -s \
            '--strict[run additional strict style checks]' \
            '--git[verify git references within formulae]' \
            '--online[run additional slower style checks that require a network connection]' \
            '--new[run various additional style checks to determine if a new formula or cask is eligible for Homebrew]' \
            '--signing[audit for signed apps]' \
            '--token-conflicts[audit for token conflicts]' \
            '--display-cop-names[include the RuboCop cop name for each violation]' \
            '--display-filename[prefix every line of output with the file or formula name]' \
            '--formula[treat all named arguments as formulae]' \
            '--cask[treat all named arguments as casks]' \
            '--tap[check the formulae within the given tap]:tap:_brew_taps' \
            '--eval-all[evaluate all available formulae and casks]' \
            '--fix[fix style violations automatically using RuboCop auto-correct]' \
            '--skip-style[skip style checks]' \
            '--except[skip the given audit methods]:methods:' \
            '--only[only run the given audit methods]:methods:' \
            '*:formula or cask:_brew_installed_or_all'
          ;;

        cat)
          _arguments -s \
            '--formula[treat all named arguments as formulae]' \
            '--cask[treat all named arguments as casks]' \
            '*:formula or cask:_brew_installed_or_all'
          ;;

        desc)
          _arguments -s \
            '(-s --search)'{-s,--search}'[search both names and descriptions]' \
            '(-n --name)'{-n,--name}'[search just names]' \
            '(-d --description)'{-d,--description}'[search just descriptions]' \
            '--formula[treat all named arguments as formulae]' \
            '--cask[treat all named arguments as casks]' \
            '--eval-all[evaluate all available formulae and casks]' \
            '*:formula or cask:_brew_installed_or_all'
          ;;

        edit)
          _arguments -s \
            '--formula[treat all named arguments as formulae]' \
            '--cask[treat all named arguments as casks]' \
            '--print-path[print the file path to be edited, without opening an editor]' \
            '*:formula or cask:_brew_installed_or_all'
          ;;

        fetch)
          _arguments -s \
            '--HEAD[fetch HEAD version instead of stable]' \
            '(-s --build-from-source)'{-s,--build-from-source}'[fetch source packages for formulae]' \
            '--force-bottle[fetch a bottle even if it would not normally be used]' \
            '--bottle-tag[download a bottle for the given tag]:tag:' \
            '--retry[retry if downloading fails or re-download if the checksum has changed]' \
            '--deps[also download dependencies]' \
            '--formula[treat all named arguments as formulae]' \
            '--cask[treat all named arguments as casks]' \
            '--quarantine[quarantine the downloaded files]' \
            '--no-quarantine[disable quarantine of downloads]' \
            '*:formula or cask:_brew_installed_or_all'
          ;;

        home|homepage)
          _arguments -s \
            '--formula[treat all named arguments as formulae]' \
            '--cask[treat all named arguments as casks]' \
            '*:formula or cask:_brew_installed_or_all'
          ;;

        log)
          _arguments -s \
            '-1[show only one commit]' \
            '--max-count[show only specified number of commits]:count:' \
            '--oneline[show each commit as a single line]' \
            '--formula[treat all named arguments as formulae]' \
            '--cask[treat all named arguments as casks]' \
            '*:formula or cask:_brew_installed_or_all'
          ;;

        options)
          _arguments '*:formula:_brew_all_formulae'
          ;;

        bump)
          _arguments -s \
            '--formula[check only formulae]' \
            '--cask[check only casks]' \
            '--full-name[print formulae/casks with fully-qualified names]' \
            '--no-pull-requests[do not retrieve pull requests from GitHub]' \
            '--open-pr[open a pull request for any outdated formulae or casks]' \
            '--limit[limit the number of package results returned]:number:' \
            '--start-with[letter or word to start checking from]:text:' \
            '*:formula or cask:_brew_installed_or_all'
          ;;

        bump-formula-pr)
          _arguments -s \
            '(-n --dry-run)'{-n,--dry-run}'[print what would be done]' \
            '--write-only[make the expected file modifications without taking any Git actions]' \
            '--no-audit[do not run brew audit]' \
            '--no-browse[print the pull request URL instead of opening in a browser]' \
            '--online[run brew audit --online]' \
            '--strict[run brew audit --strict]' \
            '--mirror[use the specified URL as a mirror URL]:url:' \
            '--tag[specify the new git tag]:tag:' \
            '--revision[specify the new git commit revision]:revision:' \
            '--url[specify the URL for the new download]:url:' \
            '--sha256[specify the SHA-256 checksum]:sha256:' \
            '--version[specify the new version]:version:' \
            '--message[append message to default pull request message]:message:' \
            '(--force -f)'{--force,-f}'[remove all mirrors if --mirror was not specified]' \
            '*:formula:_brew_all_formulae'
          ;;

        bump-cask-pr)
          _arguments -s \
            '(-n --dry-run)'{-n,--dry-run}'[print what would be done]' \
            '--write-only[make the expected file modifications without taking any Git actions]' \
            '--no-audit[do not run brew audit]' \
            '--no-browse[print the pull request URL instead of opening in a browser]' \
            '--online[run brew audit --online]' \
            '--url[specify the URL for the new download]:url:' \
            '--sha256[specify the SHA-256 checksum]:sha256:' \
            '--version[specify the new version]:version:' \
            '--message[append message to default pull request message]:message:' \
            '--no-style[do not run brew style]' \
            '(--force -f)'{--force,-f}'[do not quit if no release notes are found]' \
            '*:cask:_brew_all_casks'
          ;;

        reinstall)
          _arguments -s \
            '--cask[treat all named arguments as casks]' \
            '--formula[treat all named arguments as formulae]' \
            '(--force -f)'{--force,-f}'[install without checking for previously installed keg-only versions]' \
            '(--verbose -v)'{--verbose,-v}'[make some output more verbose]' \
            '(--debug -d)'{--debug,-d}'[display any debugging information]' \
            '--no-quarantine[disable quarantine of downloads]' \
            '--adopt[adopt existing artifacts in the destination]' \
            '--skip-cask-deps[skip installing cask dependencies]' \
            '--no-binaries[disable linking of helper executables]' \
            '--interactive[download and patch formula, then open a shell]' \
            '--display-times[print install times for each formula at the end of the run]' \
            '--git[create a Git repository for building the formula from source]' \
            '(-s --build-from-source)'{-s,--build-from-source}'[compile the formula from source]' \
            '--force-bottle[install from a bottle even if it would not normally be used]' \
            '*:installed formula or cask:_alternative "formulae:formula:_brew_installed_formulae" "casks:cask:_brew_installed_casks"'
          ;;

        create)
          _arguments -s \
            '--cask[create a cask]' \
            '--formula[create a formula]' \
            '--autotools[use an Autotools-style build template]' \
            '--cmake[use a CMake-style build template]' \
            '--crystal[use a Crystal-style build template]' \
            '--go[use a Go-style build template]' \
            '--meson[use a Meson-style build template]' \
            '--node[use a Node-style build template]' \
            '--perl[use a Perl-style build template]' \
            '--python[use a Python-style build template]' \
            '--ruby[use a Ruby-style build template]' \
            '--rust[use a Rust-style build template]' \
            '--no-fetch[do not download URL to fill in the SHA-256]' \
            '--set-name[explicitly set the name of the new formula or cask]:name:' \
            '--set-version[explicitly set the version of the new formula or cask]:version:' \
            '--set-license[explicitly set the license of the new formula]:license:' \
            '--tap[generate a formula within the given tap]:tap:_brew_taps' \
            '(--force -f)'{--force,-f}'[ignore errors for disallowed formula names and names that shadow aliases]' \
            '*:URL:'
          ;;

        doctor|dr)
          _arguments -s \
            '--list-checks[list all audit methods]' \
            '--audit-debug[enable debugging and profiling of audit methods]'
          ;;

        outdated)
          _arguments -s \
            '--cask[list only outdated casks]' \
            '--formula[list only outdated formulae]' \
            '--json[print output in JSON format]:version:(v1 v2)' \
            '--greedy[include casks with auto_updates true or version :latest]' \
            '--greedy-latest[include casks with version :latest]' \
            '--greedy-auto-updates[include casks with auto_updates true]' \
            '--fetch-HEAD[fetch the upstream repository to detect if the HEAD installation is outdated]' \
            '(--quiet -q)'{--quiet,-q}'[list only names of outdated kegs]' \
            '(--verbose -v)'{--verbose,-v}'[include detailed version information]' \
            '*:formula or cask:_brew_installed_formulae'
          ;;

        update)
          _arguments -s \
            '--merge[use git merge to apply updates]' \
            '--auto-update[run on auto-updates]' \
            '(--force -f)'{--force,-f}'[always do a slower full update check]' \
            '(--quiet -q)'{--quiet,-q}'[make some output more quiet]' \
            '(--verbose -v)'{--verbose,-v}'[print the directories checked and git operations performed]'
          ;;

        autoremove)
          _arguments -s \
            '(-n --dry-run)'{-n,--dry-run}'[list what would be uninstalled without actually uninstalling]'
          ;;

        leaves)
          _arguments -s \
            '--installed-on-request[only list leaves that were manually installed]' \
            '--installed-as-dependency[only list leaves that were installed as dependencies]' \
            '-r[sort by install date]'
          ;;

        migrate)
          _arguments -s \
            '(--force -f)'{--force,-f}'[treat installed and provided formulae as if they are from the same tap]' \
            '(-n --dry-run)'{-n,--dry-run}'[show what would be migrated without actually migrating]' \
            '*:installed formula:_brew_installed_formulae'
          ;;

        missing)
          _arguments -s \
            '--hide[act as if none of the specified hidden are installed]:formulae:_brew_installed_formulae' \
            '*:formula:_brew_installed_formulae'
          ;;

        postinstall)
          _arguments '*:installed formula:_brew_installed_formulae'
          ;;

        gist-logs)
          _arguments -s \
            '--with-hierarchical-storage-management[include the log file in the Gist]' \
            '(-n --new-issue)'{-n,--new-issue}'[open a new issue in the appropriate GitHub repository]' \
            '-p[set the Gist to private]' \
            '*:formula:_brew_all_formulae'
          ;;

        bundle)
          local -a bundle_cmds
          bundle_cmds=(
            'dump:write all installed casks, formulae, images, taps, and mas apps into a Brewfile'
            'cleanup:uninstall all dependencies not listed from the Brewfile'
            'check:check if all dependencies are installed from the Brewfile'
            'list:list all dependencies present in the Brewfile'
            'exec:run an external command in an isolated environment'
            'add:add a dependency to the Brewfile'
            'remove:remove a dependency from the Brewfile'
            'install:install all dependencies from the Brewfile'
          )
          _arguments -C \
            '--file[read Brewfile from this location]:file:_files' \
            '--global[read Brewfile from ~/.Brewfile]' \
            '--no-lock[do not generate a Brewfile.lock.json]' \
            '--force[uninstall dependencies not listed in Brewfile]' \
            '--describe[add a description comment above each line in the Brewfile]' \
            '--cleanup[uninstall dependencies not listed from Brewfile]' \
            '--no-restart[do not restart services after install]' \
            '--all[list all dependencies]' \
            '--formula[list only formulae]' \
            '--cask[list only casks]' \
            '--tap[list only taps]' \
            '--mas[list only Mac App Store entries]' \
            '--whalebrew[list only whalebrew entries]' \
            '--vscode[list only VSCode extensions]' \
            '--no-vscode[do not list VSCode extensions]' \
            '--no-upgrade[do not upgrade outdated dependencies]' \
            '--quiet[make output more quiet]' \
            '--verbose[make output more verbose]' \
            '1:bundle command:_describe "bundle command" bundle_cmds' \
            '*:: :->bundle_args'
          ;;

        --cache)
          _arguments -s \
            '--formula[show the cache for formulae]' \
            '--cask[show the cache for casks]' \
            '*:formula or cask:_brew_installed_or_all'
          ;;

        --prefix)
          _arguments -s \
            '--unbrewed[list files not tracked by Homebrew]' \
            '--installed[verify that a formula is installed]' \
            '*:formula:_brew_installed_formulae'
          ;;

        --cellar)
          _arguments '*:formula:_brew_installed_formulae'
          ;;

        --caskroom)
          _arguments '*:cask:_brew_installed_casks'
          ;;

        shellenv)
          _arguments ':shell:(bash zsh fish csh tcsh)'
          ;;

        *)
          _default
          ;;
      esac
      ;;
  esac
}

_brew "$@"
