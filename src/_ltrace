#compdef ltrace

local -a arguments

arguments=(
  {-a,--align}'[align return values in a specific column]:column number:'
  '-A[maximum number of array elements to print]:max elements:'
  {-b,--no-signals}'[disable printing of signals received by the traced process]'
  '-c[count time and calls, and report a summary on exit]'
  {-C,--demangle}'[decode low-level symbol names into user-level names]'
  {-D,--debug}'[show debugging output of ltrace itself]:debug mask:'
  '-e[modify which library calls to trace]:filter expression:'
  '-f[trace child processes created by fork() and clone()]'
  {-F,--config}'[colon-separated list of paths for prototype libraries]:config paths:_files'
  '(- * :)'{-h,--help}'[display help and exit]'
  '-i[print instruction pointer at time of library call]'
  {-l,--library}'[only trace symbols implemented by libraries matching pattern]:library pattern:'
  '-L[do not assume the default @MAIN action when no -e is given]'
  {-n,--indent}'[indent output by NR spaces for each call level nesting]:indent spaces:'
  {-o,--output}'[write the trace output to file]:output file:_files'
  '*-p[attach to the process with given PID]:process ID:_pids'
  '-r[print relative timestamps]'
  '-s[specify the maximum string size to print]:max string size:'
  '-S[trace system calls as well as library calls]'
  '-t[prefix each line with the time of day]'
  '-tt[print time including microseconds]'
  '-ttt[print time including microseconds and seconds since epoch]'
  '-T[show the time spent inside each call]'
  '-u[run command with the userid, groupid of username]:username:_users'
  {-w,--where}'[show backtrace of nr stack frames for each traced function]:stack frames:'
  {-V,--version}'[output version information and exit]'
  '-x[modify which static functions to trace]:filter expression:'
  '*:command:_files'
)

_arguments -s -S $arguments
