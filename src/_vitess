#compdef vtctldclient

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'AddCellInfo:registers a local topology service'
  'AddCellsAlias:defines a group of cells'
  'ApplyRoutingRules:apply routing rules'
  'ApplySchema:apply schema changes to a keyspace'
  'ApplyShardRoutingRules:apply shard routing rules'
  'ApplyVSchema:apply VSchema to a keyspace'
  'Backup:take a backup of a tablet'
  'ChangeTabletType:change the type of a tablet'
  'CreateKeyspace:create a new keyspace'
  'CreateShard:create a new shard'
  'DeleteCellInfo:delete a cell info'
  'DeleteKeyspace:delete a keyspace'
  'DeleteShards:delete shards'
  'DeleteTablets:delete tablets'
  'EmergencyReparentShard:emergency reparent a shard'
  'ExecuteFetchAsDba:execute a SQL query as DBA'
  'FindAllShardsInKeyspace:find all shards in a keyspace'
  'GetBackups:list backups for a shard'
  'GetCellInfo:get cell info'
  'GetKeyspace:get keyspace info'
  'GetKeyspaces:list all keyspaces'
  'GetSchema:get schema for tablets'
  'GetShard:get shard info'
  'GetSrvVSchema:get SrvVSchema'
  'GetTablet:get tablet info'
  'GetTablets:get tablets'
  'GetVSchema:get VSchema for a keyspace'
  'LookupVindex:perform commands related to lookup vindexes'
  'Materialize:perform a materialization workflow'
  'MoveTables:move tables between keyspaces'
  'OnlineDDL:perform online DDL operations'
  'PingTablet:ping a tablet'
  'PlannedReparentShard:planned reparent a shard'
  'RebuildKeyspaceGraph:rebuild keyspace graph'
  'RebuildVSchemaGraph:rebuild VSchema graph'
  'RefreshState:refresh tablet state'
  'ReloadSchema:reload schema on tablets'
  'ReloadSchemaKeyspace:reload schema on all tablets in a keyspace'
  'Reshard:reshard a keyspace'
  'RunHealthCheck:run health check on a tablet'
  'SetKeyspaceDurabilityPolicy:set keyspace durability policy'
  'SetShardIsPrimaryServing:set shard primary serving'
  'SetWritable:set a tablet as writable or read-only'
  'ShardReplicationPositions:show replication positions'
  'SleepTablet:sleep a tablet for a duration'
  'SourceShardAdd:add a source shard'
  'SourceShardDelete:delete a source shard'
  'StartReplication:start replication on a tablet'
  'StopReplication:stop replication on a tablet'
  'Validate:validate cluster'
  'ValidateKeyspace:validate a keyspace'
  'ValidateSchemaKeyspace:validate schema across keyspace'
  'ValidateShard:validate a shard'
  'ValidateVersionKeyspace:validate version across keyspace'
  'VDiff:perform a VDiff operation'
  'Workflow:manage VReplication workflows'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--server=[vtctld server address]:address' \
  '--action_timeout=[timeout for the action]:duration' \
  '--alsologtostderr[log to stderr as well]' \
  '--log_dir=[log file directory]:directory:_directories' \
  '--stderrthreshold=[logs at or above this threshold go to stderr]:threshold:(INFO WARNING ERROR FATAL)' \
  '-v=[log level]:level' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'vtctldclient command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (CreateKeyspace)
        _arguments -s -S \
          '--type=[keyspace type]:type:(NORMAL SNAPSHOT)' \
          '--durability-policy=[durability policy]:policy:(none semi_sync cross_cell)' \
          '--force[force creation]' \
          '1:keyspace name' && ret=0
        ;;
      (ApplySchema)
        _arguments -s -S \
          '--sql=[SQL to apply]:sql' \
          '--sql-file=[file containing SQL]:file:_files' \
          '--ddl-strategy=[online DDL strategy]:strategy:(direct online vitess gh-ost pt-osc)' \
          '--request-context=[request context]:context' \
          '--wait-replicas-timeout=[timeout for waiting on replicas]:duration' \
          '1:keyspace name' && ret=0
        ;;
      (Backup)
        _arguments -s -S \
          '--allow-primary[allow backup on primary]' \
          '--concurrency=[backup concurrency]:number' \
          '1:tablet alias' && ret=0
        ;;
    esac
    ;;
esac

return ret
