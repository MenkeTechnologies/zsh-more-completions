#compdef opentofu tofu

# Zsh completion for OpenTofu (open-source Terraform alternative)

_opentofu() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    local -a common_flags=(
        '-chdir=[switch to a different working directory]:directory:_directories'
        '-help[show help]'
        '-version[show version]'
        '-no-color[disable color output]'
        '-json[produce output in machine-readable JSON format]'
    )

    local -a commands=(
        'init:prepare your working directory for other commands'
        'validate:check whether the configuration is valid'
        'plan:show changes required by the current configuration'
        'apply:create or update infrastructure'
        'destroy:destroy previously-created infrastructure'
        'console:try OpenTofu expressions at an interactive command prompt'
        'fmt:reformat your configuration in the standard style'
        'force-unlock:release a stuck lock on the current workspace'
        'get:install or update remote modules'
        'graph:generate a Graphviz graph of the steps in an operation'
        'import:associate existing infrastructure with an OpenTofu resource'
        'login:obtain and save credentials for a remote host'
        'logout:remove locally-stored credentials for a remote host'
        'metadata:metadata related commands'
        'output:show output values from your root module'
        'providers:show the providers required for this configuration'
        'refresh:update the state to match remote systems'
        'show:show a human-readable output of a state or plan file'
        'state:advanced state management'
        'taint:mark a resource instance as not fully functional'
        'test:execute integration tests for OpenTofu modules'
        'untaint:remove the taint marker from a resource instance'
        'version:show the current OpenTofu version'
        'workspace:workspace management'
    )

    _arguments -C \
        $common_flags \
        '1:command:->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'opentofu command' commands
            ;;
        args)
            case $words[1] in
                init)
                    _arguments -s -S \
                        '-backend=[configure the backend for this configuration]:backend:(true false)' \
                        '*-backend-config=[backend configuration key=value or file]:config:_files' \
                        '-force-copy[suppress prompts about copying state data]' \
                        '-from-module=[copy the contents of the given module]:module source:' \
                        '-get=[download any modules for this configuration]:get:(true false)' \
                        '-input=[ask for input for variables if not directly set]:input:(true false)' \
                        '-lock=[lock the state file when locking is supported]:lock:(true false)' \
                        '-lock-timeout=[duration to retry a state lock]:timeout:' \
                        '-no-color[disable color output]' \
                        '-plugin-dir=[directory containing plugin binaries]:plugin dir:_directories' \
                        '-reconfigure[reconfigure the backend]' \
                        '-migrate-state[reconfigure the backend and attempt to migrate any existing state]' \
                        '-upgrade[install the latest module and provider versions]'
                    ;;
                validate)
                    _arguments -s -S \
                        '-json[produce output in machine-readable JSON format]' \
                        '-no-color[disable color output]'
                    ;;
                plan)
                    _arguments -s -S \
                        '-destroy[create a plan to destroy all objects]' \
                        '-out=[write a plan file to the given path]:plan file:_files' \
                        '-parallelism=[limit the number of parallel resource operations]:number:' \
                        '-refresh-only[create a plan that only updates the state]' \
                        '-refresh=[update state prior to checking for differences]:refresh:(true false)' \
                        '*-replace=[force replacement of a particular resource instance]:resource address:' \
                        '*-target=[resource to target]:resource address:' \
                        '*-var=[set a variable in the configuration]:variable assignment:' \
                        '*-var-file=[set variables from a file]:var file:_files' \
                        '-generate-config-out=[write generated HCL to file]:output file:_files' \
                        '-lock=[lock the state file]:lock:(true false)' \
                        '-lock-timeout=[duration to retry a state lock]:timeout:' \
                        '-input=[ask for input for variables]:input:(true false)' \
                        '-compact-warnings[show warnings in compact form]' \
                        '-no-color[disable color output]' \
                        '-json[produce output in machine-readable JSON format]'
                    ;;
                apply)
                    _arguments -s -S \
                        '-auto-approve[skip interactive approval of plan before applying]' \
                        '-backup=[path to backup the existing state file]:backup file:_files' \
                        '-lock=[lock the state file]:lock:(true false)' \
                        '-lock-timeout=[duration to retry a state lock]:timeout:' \
                        '-input=[ask for input for variables]:input:(true false)' \
                        '-no-color[disable color output]' \
                        '-parallelism=[limit the number of parallel resource operations]:number:' \
                        '-state=[path to read and save state]:state file:_files' \
                        '-state-out=[path to write state]:state file:_files' \
                        '*-target=[resource to target]:resource address:' \
                        '*-var=[set a variable in the configuration]:variable assignment:' \
                        '*-var-file=[set variables from a file]:var file:_files' \
                        '-compact-warnings[show warnings in compact form]' \
                        '-json[produce output in machine-readable JSON format]' \
                        '1:plan file:_files'
                    ;;
                destroy)
                    _arguments -s -S \
                        '-auto-approve[skip interactive approval before destroying]' \
                        '-lock=[lock the state file]:lock:(true false)' \
                        '-lock-timeout=[duration to retry a state lock]:timeout:' \
                        '-no-color[disable color output]' \
                        '-parallelism=[limit the number of parallel resource operations]:number:' \
                        '*-target=[resource to target]:resource address:' \
                        '*-var=[set a variable in the configuration]:variable assignment:' \
                        '*-var-file=[set variables from a file]:var file:_files' \
                        '-compact-warnings[show warnings in compact form]'
                    ;;
                fmt)
                    _arguments -s -S \
                        '-list=[list files whose formatting differs]:list:(true false)' \
                        '-write=[write result to source file]:write:(true false)' \
                        '-diff[display diffs of formatting changes]' \
                        '-check[check if input is formatted]' \
                        '-recursive[also process files in subdirectories]' \
                        '-no-color[disable color output]' \
                        '*:file or directory:_files'
                    ;;
                force-unlock)
                    _arguments -s -S \
                        '-force[do not ask for input for unlock confirmation]' \
                        '1:lock ID:'
                    ;;
                get)
                    _arguments -s -S \
                        '-update[check modules for updates]' \
                        '-no-color[disable color output]'
                    ;;
                graph)
                    _arguments -s -S \
                        '-plan=[render graph using the given plan file]:plan file:_files' \
                        '-draw-cycles[highlight any cycles in the graph]' \
                        '-type=[type of graph to output]:type:(plan plan-refresh plan-destroy apply)'
                    ;;
                import)
                    _arguments -s -S \
                        '-config=[path to a directory of configuration files]:config dir:_directories' \
                        '-input=[ask for input for variables]:input:(true false)' \
                        '-lock=[lock the state file]:lock:(true false)' \
                        '-lock-timeout=[duration to retry a state lock]:timeout:' \
                        '-no-color[disable color output]' \
                        '-state=[path to read and save state]:state file:_files' \
                        '-state-out=[path to write state]:state file:_files' \
                        '*-var=[set a variable in the configuration]:variable assignment:' \
                        '*-var-file=[set variables from a file]:var file:_files' \
                        '1:resource address:' \
                        '2:resource ID:'
                    ;;
                output)
                    _arguments -s -S \
                        '-state=[path to the state file]:state file:_files' \
                        '-no-color[disable color output]' \
                        '-json[produce output in machine-readable JSON format]' \
                        '-raw[for value types that can be automatically converted to a string]' \
                        '1:output name:'
                    ;;
                refresh)
                    _arguments -s -S \
                        '-input=[ask for input for variables]:input:(true false)' \
                        '-lock=[lock the state file]:lock:(true false)' \
                        '-lock-timeout=[duration to retry a state lock]:timeout:' \
                        '-no-color[disable color output]' \
                        '-parallelism=[limit the number of parallel resource operations]:number:' \
                        '*-target=[resource to target]:resource address:' \
                        '*-var=[set a variable in the configuration]:variable assignment:' \
                        '*-var-file=[set variables from a file]:var file:_files' \
                        '-compact-warnings[show warnings in compact form]'
                    ;;
                show)
                    _arguments -s -S \
                        '-no-color[disable color output]' \
                        '-json[produce output in machine-readable JSON format]' \
                        '1:plan file:_files'
                    ;;
                state)
                    local -a state_commands=(
                        'list:list resources in the state'
                        'mv:move an item in the state'
                        'pull:pull current state and output to stdout'
                        'push:update remote state from a local state file'
                        'replace-provider:replace provider in the state'
                        'rm:remove instances from the state'
                        'show:show a resource in the state'
                    )
                    _arguments -C \
                        '1:state subcommand:->statecmd' \
                        '*::arg:->stateargs'
                    case $state in
                        statecmd)
                            _describe -t state_commands 'state subcommand' state_commands
                            ;;
                        stateargs)
                            case $line[1] in
                                list)
                                    _arguments -s -S \
                                        '-state=[path to the state file]:state file:_files' \
                                        '-id=[filter by resource ID]:id:'
                                    ;;
                                mv)
                                    _arguments -s -S \
                                        '-state=[path to the source state file]:state file:_files' \
                                        '-state-out=[path to the destination state file]:state file:_files' \
                                        '-lock=[lock the state files]:lock:(true false)' \
                                        '-lock-timeout=[duration to retry a state lock]:timeout:' \
                                        '1:source address:' \
                                        '2:destination address:'
                                    ;;
                                pull)
                                    _arguments -s -S
                                    ;;
                                push)
                                    _arguments -s -S \
                                        '-force[write state even if lineages do not match]' \
                                        '-lock=[lock the state file]:lock:(true false)' \
                                        '-lock-timeout=[duration to retry a state lock]:timeout:' \
                                        '1:state file:_files'
                                    ;;
                                replace-provider)
                                    _arguments -s -S \
                                        '-auto-approve[skip interactive approval]' \
                                        '-lock=[lock the state file]:lock:(true false)' \
                                        '-lock-timeout=[duration to retry a state lock]:timeout:' \
                                        '1:from provider:' \
                                        '2:to provider:'
                                    ;;
                                rm)
                                    _arguments -s -S \
                                        '-state=[path to the state file]:state file:_files' \
                                        '-lock=[lock the state file]:lock:(true false)' \
                                        '-lock-timeout=[duration to retry a state lock]:timeout:' \
                                        '-dry-run[only print the resource addresses that would be removed]' \
                                        '*:resource address:'
                                    ;;
                                show)
                                    _arguments -s -S \
                                        '-state=[path to the state file]:state file:_files' \
                                        '1:resource address:'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                taint)
                    _arguments -s -S \
                        '-allow-missing[if the resource is missing, succeed]' \
                        '-lock=[lock the state file]:lock:(true false)' \
                        '-lock-timeout=[duration to retry a state lock]:timeout:' \
                        '-state=[path to the state file]:state file:_files' \
                        '-state-out=[path to write state]:state file:_files' \
                        '-no-color[disable color output]' \
                        '1:resource address:'
                    ;;
                test)
                    _arguments -s -S \
                        '-filter=[only run test files matching the given filter]:filter:' \
                        '-json[produce output in machine-readable JSON format]' \
                        '-no-color[disable color output]' \
                        '-verbose[print the plan and state for each test run block]'
                    ;;
                untaint)
                    _arguments -s -S \
                        '-allow-missing[if the resource is missing, succeed]' \
                        '-lock=[lock the state file]:lock:(true false)' \
                        '-lock-timeout=[duration to retry a state lock]:timeout:' \
                        '-state=[path to the state file]:state file:_files' \
                        '-state-out=[path to write state]:state file:_files' \
                        '-no-color[disable color output]' \
                        '1:resource address:'
                    ;;
                version)
                    _arguments -s -S '-json[produce output in machine-readable JSON format]'
                    ;;
                workspace)
                    local -a ws_commands=(
                        'delete:delete a workspace'
                        'list:list workspaces'
                        'new:create a new workspace'
                        'select:select a workspace'
                        'show:show the name of the current workspace'
                    )
                    _arguments -C \
                        '1:workspace subcommand:->wscmd' \
                        '*::arg:->wsargs'
                    case $state in
                        wscmd)
                            _describe -t ws_commands 'workspace subcommand' ws_commands
                            ;;
                        wsargs)
                            case $line[1] in
                                delete)
                                    _arguments -s -S \
                                        '-force[remove even if non-empty state]' \
                                        '-lock=[lock the state file]:lock:(true false)' \
                                        '-lock-timeout=[duration to retry a state lock]:timeout:' \
                                        '1:workspace name:'
                                    ;;
                                new)
                                    _arguments -s -S \
                                        '-state=[copy an existing state file into the new workspace]:state file:_files' \
                                        '-lock=[lock the state file]:lock:(true false)' \
                                        '-lock-timeout=[duration to retry a state lock]:timeout:' \
                                        '1:workspace name:'
                                    ;;
                                select|list|show)
                                    _arguments -s -S '1:workspace name:'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                console)
                    _arguments -s -S \
                        '-state=[path to the state file]:state file:_files' \
                        '*-var=[set a variable]:variable assignment:' \
                        '*-var-file=[set variables from a file]:var file:_files'
                    ;;
                providers)
                    local -a providers_commands=(
                        'lock:write out dependency locks for the configured providers'
                        'mirror:save local copies of all required provider plugins'
                        'schema:show the schemas for the providers used in the configuration'
                    )
                    _arguments -C \
                        '1:providers subcommand:->provcmd' \
                        '*::arg:->provargs'
                    case $state in
                        provcmd)
                            _describe -t providers_commands 'providers subcommand' providers_commands
                            ;;
                    esac
                    ;;
                metadata)
                    local -a metadata_commands=(
                        'functions:show the available functions'
                    )
                    _arguments -C \
                        '1:metadata subcommand:->metacmd' \
                        '*::arg:->metaargs'
                    case $state in
                        metacmd)
                            _describe -t metadata_commands 'metadata subcommand' metadata_commands
                            ;;
                    esac
                    ;;
            esac
            ;;
    esac
}

_opentofu "$@"
