#compdef orte-server
# Documentation: https://man.archlinux.org/search?q=orte-server
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-d,--debug}'[Debug the Open MPI server]'
  {-h,--help}'[This help message]'
  '--no-daemonize[dont daemonize into the background]'
  {-r,--report-uri}'[<arg0> Report the servers uri on stdout \[-\], stderr \[+\]]'
  '*:filename:_files'
)

_arguments -s -S $arguments
