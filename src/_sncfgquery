#compdef sncfgquery
# Documentation: https://man.archlinux.org/search?q=sncfgquery
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-f[find information based on config file location]'
  '-n[find information based on file system name]'
  '-d[dump config]'
  '-l[list keywords]'
  '-q[query config]'
  '-h[print this help info]'
  '-k[keyword]'
  '-s[section]'
  '*:filename:_files'
)

_arguments -s -S $arguments
