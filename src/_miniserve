#compdef miniserve

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[be verbose]' \
  '(-p --port)'{-p,--port}'[port to listen on]:port' \
  '(-i --interfaces)'{-i,--interfaces}'[interface to listen on]:interface' \
  '--index[index file to serve]:file' \
  '(-u --upload-files)'{-u,--upload-files}'[enable file upload]' \
  '--mkdir[enable directory creation]' \
  '--allowed-upload-dir[restrict upload to directory]:dir:_directories' \
  '(-a --auth)'{-a,--auth}'[authentication credentials]:user\:pass' \
  '--auth-file[htpasswd file]:file:_files' \
  '--route-prefix[URL prefix]:prefix' \
  '--random-route[generate a random route]' \
  '--no-symlinks[do not follow symbolic links]' \
  '--hidden[show hidden files]' \
  '(-P --no-dot-files)'{-P,--no-dot-files}'[hide dot files]' \
  '--title[set page title]:title' \
  '--header[add custom header]:header' \
  '(-c --color-scheme)'{-c,--color-scheme}'[color scheme]:scheme:(archlinux monokai squirrel zenburn)' \
  '(-d --color-scheme-dark)'{-d,--color-scheme-dark}'[dark color scheme]:scheme:(archlinux monokai squirrel zenburn)' \
  '(-q --qrcode)'{-q,--qrcode}'[show QR code]' \
  '-D[enable directory listing]' \
  '--dirs-first[list directories first]' \
  '--spa[enable SPA mode]' \
  '--pretty-urls[enable pretty URLs]' \
  '--print-completions[print shell completions]:shell:(bash zsh fish elvish powershell)' \
  '--tls-cert[TLS certificate file]:file:_files -g "*.{pem,crt}"' \
  '--tls-key[TLS key file]:file:_files -g "*.{pem,key}"' \
  '--readme[render README files]' \
  '-W[show wget footer]' \
  '--disable-indexing[disable directory listing]' \
  '--compress-response[compress response body]' \
  '1:path to serve:_files -/' && ret=0

return ret
