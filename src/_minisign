#compdef minisign

# Zsh completion for minisign - dead simple tool to sign files and verify signatures

_arguments -s -S \
  '-G[generate a key pair]' \
  '-R[recreate a public key file from a secret key file]' \
  '-C[change/remove the password of the secret key]' \
  '-S[sign files]' \
  '-V[verify that a signature is valid for a given file]' \
  '-m[file to sign/verify]:file:_files' \
  '-o[signature file]:file:_files' \
  '-p[public key file]:file:_files' \
  '-P[public key (base64)]' \
  '-s[secret key file]:file:_files' \
  '-W[do not encrypt the secret key]' \
  '-x[signature file]:file:_files' \
  '-c[add a trusted comment]:comment:' \
  '-t[add an untrusted comment]:comment:' \
  '-q[quiet mode, do not print info messages]' \
  '-Q[extremely quiet mode]' \
  '-f[force overwrite]' \
  '-v[display version number]' \
  '-h[display help]'
