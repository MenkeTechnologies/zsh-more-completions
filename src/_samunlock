#compdef samunlock

local -a arguments

arguments=(
  '-U[unlock user]'
  '-l[list users in sam]'
  '-u[specify username or RID]:user'
  '-f[unlock admin user with lowest RID]'
  '-H[human readable output or confirmation message]'
  '-N[no allocate mode, only allow edit of existing values with same size]'
  '-E[no expand mode, do not expand hive file (safe mode)]'
  '-t[debug trace of allocated blocks]'
  '-v[some more verbose messages/debug]'
  '*:filename:_files'
)

_arguments -s -S $arguments
