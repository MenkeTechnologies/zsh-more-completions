#compdef geod invgeod
# Documentation: https://proj.org/en/stable/apps/geod.html
# Source: OSGeo/PROJ src/apps/geod.cpp — geodetic forward and inverse computations on the ellipsoid (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[output full set of values]' \
    '-f+[output format (printf-style)]:format:_default' \
    '-F+[alternate output format]:format:_default' \
    '-I[inverse problem (positions→distance)]' \
    '-l-[list info]:type:(=ellps =units =datums)' \
    '-p[output azimuths as positive]' \
    '-t+[column-1 marker character]:char:_default' \
    '-w+[output precision (constant width)]:n:_default' \
    '-W+[output precision (seconds)]:n:_default' \
    '*:input file:_files' \
    && ret=0

return ret
