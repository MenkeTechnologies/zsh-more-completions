#compdef can-calc-bit-timing

local -a arguments

arguments=(
  '-q[dont print header line]'
  '-l[list all support CAN controller names]'
  '-b[bit-rate in bits/sec]:bitrate:'
  '-s[sample-point in one-tenth of a percent]:sample-point:'
  '-c[real CAN system clock in Hz]:clock:'
  '*:filename:_files'
)

_arguments -s -S $arguments
