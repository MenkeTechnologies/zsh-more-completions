#compdef system-config-printer
# Documentation: https://man.archlinux.org/search?q=system-config-printer
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--debug[enable debugging output.]'
  '--show-jobs[show the print queue for <printer>]'
  '--embedded[enable to start in Embedded mode.]'
  '--help[show this message.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
