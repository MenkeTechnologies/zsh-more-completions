#compdef ubuntu-security-status
# Documentation: https://man.archlinux.org/search?q=ubuntu-security-status
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[show this help message and exit]'
  '--thirdparty[show third-party package status]'
  '--unavailable[show unavailable package status]'
  '*:filename:_files'
)

_arguments -s -S $arguments
