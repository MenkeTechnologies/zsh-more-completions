#compdef pamenlarge
# Documentation: https://man.archlinux.org/search?q=pamenlarge
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '--scale[specify the scale factor]:integer'
    '--xscale[specify the horizontal scale factor]:integer'
    '--yscale[These specify the scale factor.]:integer'
    '*:filename:_files'
)
_arguments -s -S $arguments
