#compdef less

local arguments

arguments=(
  '(-a --search-skip-screen)'{-a,--search-skip-screen}'[search skips current screen]'
  '(-A --SEARCH-SKIP-SCREEN)'{-A,--SEARCH-SKIP-SCREEN}'[search starts just after target line]'
  '(-b --buffers)'{-b+,--buffers=}'[set buffer space for each file]:number of buffers'
  '(-B --auto-buffers)'{-B,--auto-buffers}'[disable automatic buffer allocation for pipes]'
  '(-c --clear-screen)'{-c,--clear-screen}'[repaint from top rather than scrolling]'
  '(-C --CLEAR-SCREEN)'{-C,--CLEAR-SCREEN}'[like -c but clear entire screen]'
  '(-d --dumb)'{-d,--dumb}'[suppress dumb terminal error messages]'
  '(-D --color)'{-D+,--color=}'[set color for text]:color spec'
  '(-e --quit-at-eof)'{-e,--quit-at-eof}'[exit on second end-of-file]'
  '(-E --QUIT-AT-EOF)'{-E,--QUIT-AT-EOF}'[exit on first end-of-file]'
  '(-f --force)'{-f,--force}'[force open non-regular files]'
  '(-F --quit-if-one-screen)'{-F,--quit-if-one-screen}'[exit if content fits on one screen]'
  '(-g --hilite-search)'{-g,--hilite-search}'[highlight only last search match]'
  '(-G --HILITE-SEARCH)'{-G,--HILITE-SEARCH}'[suppress all search highlighting]'
  '(-h --max-back-scroll)'{-h+,--max-back-scroll=}'[set backward scroll limit]:number of lines'
  '(-i --ignore-case)'{-i,--ignore-case}'[ignore case in searches with no uppercase]'
  '(-I --IGNORE-CASE)'{-I,--IGNORE-CASE}'[ignore case in all searches]'
  '(-j --jump-target)'{-j+,--jump-target=}'[set target line for searches and jumps]:line number'
  '(-J --status-column)'{-J,--status-column}'[display a status column]'
  '(-k --lesskey-file)'{-k+,--lesskey-file=}'[use specified lesskey file]:file:_files'
  '(-K --quit-on-intr)'{-K,--quit-on-intr}'[exit on interrupt (Ctrl-C)]'
  '(-L --no-lessopen)'{-L,--no-lessopen}'[suppress LESSOPEN preprocessing]'
  '(-m --long-prompt)'{-m,--long-prompt}'[prompt with percent into file]'
  '(-M --LONG-PROMPT)'{-M,--LONG-PROMPT}'[prompt with line numbers and percent]'
  '(-n --line-numbers)'{-n,--line-numbers}'[suppress line number calculation]'
  '(-N --LINE-NUMBERS)'{-N,--LINE-NUMBERS}'[display line numbers]'
  '(-o --log-file)'{-o+,--log-file=}'[copy stdin to file]:log file:_files'
  '(-O --LOG-FILE)'{-O+,--LOG-FILE=}'[copy stdin to file unconditionally]:log file:_files'
  '(-p --pattern)'{-p+,--pattern=}'[start at first occurrence of pattern]:pattern'
  '(-P --prompt)'{-P+,--prompt=}'[set prompt string]:prompt string'
  '(-q --quiet --silent)'{-q,--quiet,--silent}'[do not ring bell for errors]'
  '(-Q --QUIET --SILENT)'{-Q,--QUIET,--SILENT}'[never ring terminal bell]'
  '(-r --raw-control-chars)'{-r,--raw-control-chars}'[display raw control characters]'
  '(-R --RAW-CONTROL-CHARS)'{-R,--RAW-CONTROL-CHARS}'[display ANSI color escapes in raw form]'
  '(-s --squeeze-blank-lines)'{-s,--squeeze-blank-lines}'[squeeze consecutive blank lines]'
  '(-S --chop-long-lines)'{-S,--chop-long-lines}'[chop long lines instead of wrapping]'
  '(-t --tag)'{-t+,--tag=}'[find a tag]:tag'
  '(-T --tag-file)'{-T+,--tag-file=}'[use specified tags file]:tags file:_files'
  '(-u --underline-special)'{-u,--underline-special}'[send backspaces and carriage returns to terminal]'
  '(-U --UNDERLINE-SPECIAL)'{-U,--UNDERLINE-SPECIAL}'[send backspaces, tabs and carriage returns to terminal]'
  '(- * :)'{-V,--version}'[display version information]'
  '(-w --hilite-unread)'{-w,--hilite-unread}'[highlight first new line after forward movement]'
  '(-W --HILITE-UNREAD)'{-W,--HILITE-UNREAD}'[highlight first new line after any forward movement]'
  '(-x --tabs)'{-x+,--tabs=}'[set tab stops]:tab stop positions'
  '(-X --no-init)'{-X,--no-init}'[do not use termcap init/deinit sequences]'
  '(-y --max-forw-scroll)'{-y+,--max-forw-scroll=}'[set maximum forward scroll limit]:number of lines'
  '(-z --window)'{-z+,--window=}'[set window size]:number of lines'
  '(-\~ --tilde)'{'-~',--tilde}'[do not display tildes after end of file]'
  '(-\# --shift)'{'-#'+,--shift=}'[set default horizontal scroll amount]:number of positions'
  '(-\" --quotes)'{-\"+,--quotes=}'[set filename quoting characters]:quote characters'
  '--autosave=[save parameters across invocations]:actions'
  '--cmd=[execute commands on startup]:commands'
  '--exit-follow-on-close[exit F mode when input file is removed or renamed]'
  '--file-size[determine file size on opening]'
  '--follow-name[follow file by name like tail -F]'
  '--form-feed[treat form feeds as newlines]'
  '--header=[set header lines and columns]:L\,C\,N'
  '--incsearch[incremental search]'
  '--intr=[set interrupt character]:character'
  '--lesskey-src=[use lesskey source file]:file:_files'
  '--lesskey-content=[use lesskey content string]:text'
  '--line-num-width=[set line number column width]:width'
  '--match-shift=[set horizontal shift for search matches]:positions'
  '--modelines=[read N lines for vim modelines]:number of lines'
  '--mouse[enable mouse input]'
  '--MOUSE[enable mouse input (reverse scroll direction)]'
  '--no-edit-warn[do not warn when editing a file opened via LESSOPEN]'
  '--no-keypad[disable keypad key handling]'
  '--no-histdups[remove duplicates from search history]'
  '--no-number-headers[do not give line numbers to header lines]'
  '--no-paste[ignore pasted input]'
  '--no-search-header-lines[exclude header lines from searches]'
  '--no-search-header-columns[exclude header columns from searches]'
  '--no-search-headers[exclude header lines and columns from searches]'
  '--no-vbell[disable terminal visual bell]'
  '--proc-backspace[process backspaces for bold/underline]'
  '--PROC-BACKSPACE[treat backspaces as control characters]'
  '--proc-return[delete carriage returns before newline]'
  '--PROC-RETURN[treat carriage returns as control characters]'
  '--proc-tab[expand tabs to spaces]'
  '--PROC-TAB[treat tabs as control characters]'
  '--redraw-on-quit[redraw final screen when quitting]'
  '--rscroll=[set character for truncated lines]:character'
  '--save-marks[retain marks across invocations of less]'
  '--search-options=[set default search options]:options'
  '--show-preproc-errors[show message if preprocessor exits with error]'
  '--status-col-width=[set status column width]:width'
  '--status-line[highlight or color line containing a mark]'
  '--use-backslash[use backslash as escape char in command line parameters]'
  '--use-color[enable colored text]'
  '--wheel-lines=[set lines to scroll per mouse wheel click]:lines'
  '--wordwrap[wrap long lines at spaces]'
  '(- * :)'{-\?,--help}'[display help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
