#compdef kextload
# Documentation: https://man.archlinux.org/search?q=kextload
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-bundle-id[(-b):]'
  '-dependency[(-d):]'
  '-repository[(-r):]'
  '-quiet'
  '-verbose[0-6 | 0x<flags> \] (-v):]'
  '-help[): print this message and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
