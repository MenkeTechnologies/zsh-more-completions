#compdef polaris

# Zsh completion for polaris (Kubernetes best practices)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'audit:run a Polaris audit'
  'dashboard:start the Polaris dashboard'
  'fix:fix a YAML file'
  'help:help about any command'
  'version:print version'
  'webhook:start the Polaris webhook'
)

_arguments -s -S \
  '(-c --config)'{-c,--config}'[config file]:file:_files' \
  '--log-level[log level]:level:(error warn info debug trace)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'polaris command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (audit)
        _arguments \
          '--audit-path[path to audit]:path:_files' \
          '--format[output format]:format:(pretty json yaml score ci)' \
          '--output-file[output file]:file:_files' \
          '--output-url[output URL]:url:_urls' \
          '--set-exit-code-below-score[exit code threshold]:score:' \
          '--set-exit-code-on-danger[exit with error on danger]' \
          '--only-show-failed-tests[only show failures]' \
          '--severity[minimum severity]:severity:(ignore warning danger)' \
          '--helm-chart[Helm chart path]:path:_files' \
          '--helm-values[Helm values file]:file:_files' \
          '--resource[resource to audit]:resource:_files -g "*.yaml *.yml"' \
          '--kubeconfig[kubeconfig file]:file:_files' && ret=0
        ;;
      (dashboard)
        _arguments \
          '--audit-path[path to audit]:path:_files' \
          '--display-name[dashboard display name]:name:' \
          '--listening-address[address to listen on]:address:' \
          '--port[port to listen on]:port:' \
          '--kubeconfig[kubeconfig file]:file:_files' && ret=0
        ;;
      (fix)
        _arguments \
          '--files-path[path to YAML files]:path:_files' \
          '--checks[checks to fix]:checks:' && ret=0
        ;;
    esac
    ;;
esac

return ret
