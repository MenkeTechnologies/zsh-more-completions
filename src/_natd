#compdef natd

local -a arguments

arguments=(
  '-unregistered_only[only allow packets from unregistered addresses]'
  '-u[only allow packets from unregistered addresses]'
  '-log[log activity]'
  '-l[log activity]'
  '-proxy_only[only proxy, do not NAT]'
  '-reverse[reverse operation mode]'
  '-deny_incoming[deny incoming connections]'
  '-d[deny incoming connections]'
  '-use_sockets[use sockets to establish connections]'
  '-s[use sockets to establish connections]'
  '-same_ports[try to keep same port number]'
  '-m[try to keep same port number]'
  '-verbose[verbose mode]'
  '-v[verbose mode]'
  '-dynamic[dynamic mode]'
  '-in_port[set incoming port]:port:'
  '-i[set incoming port]:port:'
  '-out_port[set outgoing port]:port:'
  '-o[set outgoing port]:port:'
  '-port[set port]:port:'
  '-p[set port]:port:'
  '-globalport[set global port]:port:'
  '-alias_address[set alias address]:address:'
  '-a[set alias address]:address:'
  '-target_address[set target address]:address:'
  '-t[set target address]:address:'
  '-interface[specify network interface]:interface:'
  '-n[specify network interface]:interface:'
  '-proxy_rule[specify proxy rule]:rule:'
  '-redirect_port[redirect port]:spec:'
  '-redirect_proto[redirect protocol]:spec:'
  '-redirect_address[redirect address]:spec:'
  '-config[configuration file]:file:_files'
  '-f[configuration file]:file:_files'
  '-log_denied[log denied packets]'
  '-log_facility[set log facility]:facility:'
  '-punch_fw[punch firewall]:spec:'
  '-skinny_port[set Skinny port]:port:'
  '-log_ipfw_denied[log IPFW denied packets]'
  '-pid_file[PID file]:file:_files'
  '-P[PID file]:file:_files'
  '-instance[set instance name]:name:'
  '-exit_delay[set exit delay in ms]:ms:'
  '*:filename:_files'
)

_arguments -s -S $arguments
