#compdef mongosh

# Zsh completion for mongosh (MongoDB Shell)
# https://www.mongodb.com/docs/mongodb-shell/

_mongosh() {
  local -a arguments

  arguments=(
    # General options
    '(- *)'{-h,--help}'[show usage information]'
    '(- *)--version[show version information]'
    '(- *)--build-info[show build information]'
    '*'{-f,--file}'[load the specified mongosh script]:script file:_files -g "*.js"'
    '--host[server to connect to]:hostname:_hosts'
    '--port[port to connect to]:port number'
    '--quiet[silence output from the shell during the connection process]'
    '--shell[run the shell after executing files]'
    '--nodb[do not connect to mongod on startup]'
    '--norc[will not run the .mongoshrc.js file on start up]'
    '--eval[evaluate javascript expression]:javascript expression'
    '--json=-[print result of --eval as Extended JSON]::format:(canonical relaxed)'
    '--retryWrites=-[automatically retry write operations upon transient network errors]::enabled:(true false)'
    '--deep-inspect=-[force full depth inspection of server results]::enabled:(true false)'
    '--verbose[increase the verbosity of the output of the shell]'
    '--ipv6[enable IPv6 support (disabled by default)]'
    '--jsContext[javascript execution context]:context:(repl plain-vm)'

    # Authentication options
    {-u,--username}'[username for authentication]:username'
    {-p,--password}'[password for authentication]:password'
    '--authenticationDatabase[user source (defaults to dbname)]:database name'
    '--authenticationMechanism[authentication mechanism]:mechanism:(SCRAM-SHA-1 SCRAM-SHA-256 MONGODB-X509 GSSAPI PLAIN MONGODB-AWS MONGODB-OIDC)'
    '--awsIamSessionToken[AWS IAM temporary session token ID]:token'
    '--gssapiServiceName[service name to use when authenticating using GSSAPI/Kerberos]:service name'
    '--sspiHostnameCanonicalization[specify the SSPI hostname canonicalization (Windows)]:mode:(none forward)'
    '--sspiRealmOverride[specify the SSPI server realm (Windows)]:realm'

    # TLS options
    '--tls[use TLS for all connections]'
    '--tlsCertificateKeyFile[PEM certificate/key file for TLS]:PEM file:_files -g "*.pem"'
    '--tlsCertificateKeyFilePassword[password for key in PEM file for TLS]:password'
    '--tlsCAFile[certificate authority file for TLS]:CA file:_files -g "*.pem"'
    '--tlsAllowInvalidHostnames[allow connections to servers with non-matching hostnames]'
    '--tlsAllowInvalidCertificates[allow connections to servers with invalid certificates]'
    '--tlsCertificateSelector[TLS certificate in system store (Windows and macOS only)]:selector'
    '--tlsCRLFile[specifies the .pem file that contains the Certificate Revocation List]:CRL file:_files -g "*.pem"'
    '--tlsDisabledProtocols[comma separated list of TLS protocols to disable]:protocols'
    '--tlsFIPSMode[enable the system TLS library'\''s FIPS mode]'

    # API version options
    '--apiVersion[specifies the API version to connect with]:version'
    '--apiStrict[use strict API version mode]'
    '--apiDeprecationErrors[fail deprecated commands for the specified API version]'

    # FLE (Field-Level Encryption) options
    '--awsAccessKeyId[AWS access key for FLE Amazon KMS]:access key'
    '--awsSecretAccessKey[AWS secret key for FLE Amazon KMS]:secret key'
    '--awsSessionToken[optional AWS session token ID]:session token'
    '--keyVaultNamespace[database.collection to store encrypted FLE parameters]:namespace'
    '--kmsURL[test parameter to override the URL of the KMS endpoint]:URL'
    '--cryptSharedLibPath[path to crypt shared library]:path:_files'

    # OIDC auth options
    '--oidcFlows=-[supported OIDC auth flows]::flows:(auth-code device-auth)'
    '--oidcRedirectUri=-[local auth code flow redirect URL]:URL'
    '--oidcTrustedEndpoint[treat the cluster/database as a trusted endpoint]'
    '--oidcIdTokenAsAccessToken[use ID tokens in place of access tokens for auth]'
    '--oidcDumpTokens=-[debug OIDC by printing tokens to output]::mode:(redacted include-secrets)'
    '--oidcNoNonce[do not send a nonce argument in the OIDC auth request]'
    '--browser[browser to use for OIDC auth]:browser command'

    # Positional: connection string or db name, then script files
    '*:db address or file:_files -g "*.js"'
  )

  _arguments -s -S $arguments
}

_mongosh "$@"
