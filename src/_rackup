#compdef rackup

local -a arguments

arguments=(
  {-e,--eval}'[evaluate a LINE of code]'
  '-b[evaluate a BUILDER_LINE of code as a builder script]'
  '--builder[use specified builder script]:builder_line: '
  {-d,--debug}'[set debugging flags (set $DEBUG to true)]'
  {-w,--warn}'[turn warnings on for your script]'
  {-q,--quiet}'[turn off logging]'
  {-I,--include}'[specify $LOAD_PATH (may be used more than once)]'
  {-r,--require}'[require the library, before executing your script]'
  {-s,--server}'[serve using SERVER (thin/puma/webrick/mongrel)]'
  {-o,--host}'[listen on HOST (default: localhost)]'
  {-p,--port}'[use PORT (default: 9292)]'
  {-O,--option}'[pass VALUE to the server as option NAME]:name=value: '
  {-E,--env}'[use ENVIRONMENT for defaults (default: development)]'
  {-D,--daemonize}'[run daemonized in the background]'
  {-P,--pid}'[file to store PID]'
  '(- * :)'{-h,--help}'[show this message]'
  '--version[show version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
