#compdef spice-vdagent
# Documentation: https://man.archlinux.org/search?q=spice-vdagent
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[print this text]'
  '-d[log debug messages]'
  '-s[set virtio serial port]'
  '-x[dont daemonize]'
  '-f[file xfer save dir]'
  '-o[0|1> open dir on file xfer completion]'
  '*:filename:_files'
)

_arguments -s -S $arguments
