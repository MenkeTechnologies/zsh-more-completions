#compdef dotnet

# Zsh completion for .NET CLI (dotnet)

_dotnet() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a global_opts
    global_opts=(
        {-d,--diagnostics}'[Enable diagnostic output]'
        '(- *)'{-h,--help}'[Show command line help]'
        '--info[Display .NET information]'
        '--list-runtimes[Display the installed runtimes]'
        '--list-sdks[Display the installed SDKs]'
        '--version[Display .NET SDK version in use]'
    )

    _arguments -C \
        $global_opts \
        '(-): :->command' \
        '(-)*:: :->option-or-argument' && ret=0

    case $state in
        (command)
            local -a sdk_commands bundled_commands
            sdk_commands=(
                'build:Build a .NET project'
                'build-server:Interact with servers started by a build'
                'clean:Clean build outputs of a .NET project'
                'format:Apply style preferences to a project or solution'
                'help:Show command line help'
                'msbuild:Run Microsoft Build Engine (MSBuild) commands'
                'new:Create a new .NET project or file'
                'nuget:Provides additional NuGet commands'
                'pack:Create a NuGet package'
                'package:Manage NuGet package references'
                'publish:Publish a .NET project for deployment'
                'reference:Manage project-to-project references'
                'restore:Restore dependencies specified in a .NET project'
                'run:Build and run a .NET project output'
                'sdk:Manage .NET SDK installation'
                'solution:Modify Visual Studio solution files'
                'store:Store assemblies in the runtime package store'
                'test:Run unit tests using the test runner'
                'tool:Install or manage tools that extend the .NET experience'
                'vstest:Run Microsoft Test Engine (VSTest) commands'
                'workload:Manage optional workloads'
            )
            bundled_commands=(
                'dev-certs:Create and manage development certificates'
                'fsi:Start F# Interactive / execute F# scripts'
                'user-jwts:Manage JSON Web Tokens in development'
                'user-secrets:Manage development user secrets'
                'watch:Start a file watcher that runs a command when files change'
            )
            _describe -t sdk-commands 'SDK command' sdk_commands && ret=0
            _describe -t bundled-commands 'bundled tool' bundled_commands && ret=0
            ;;
        (option-or-argument)
            curcontext=${curcontext%:*:*}:dotnet-$words[1]:
            case $words[1] in
                (build)
                    _arguments -s \
                        {-c,--configuration}'[The configuration to use for building]:configuration:(Debug Release)' \
                        {-f,--framework}'[The target framework to build for]:framework' \
                        {-r,--runtime}'[The target runtime to build for]:runtime' \
                        {-o,--output}'[The output directory]:directory:_directories' \
                        {-v,--verbosity}'[Set the MSBuild verbosity level]:verbosity:(quiet minimal normal detailed diagnostic)' \
                        '--no-dependencies[Do not build project-to-project references]' \
                        '--no-incremental[Do not use incremental building]' \
                        '--no-restore[Do not restore the project before building]' \
                        '--self-contained[Publish the .NET runtime with the application]' \
                        '--no-self-contained[Publish without the .NET runtime]' \
                        '--interactive[Allows the command to stop and wait for user input]' \
                        '--version-suffix[Set the value of the VersionSuffix property]:suffix' \
                        '--ucr[Use current runtime as the target runtime]' \
                        '--use-current-runtime[Use current runtime as the target runtime]' \
                        '--force[Force all dependencies to be resolved]' \
                        '--nologo[Do not display the startup banner or the copyright message]' \
                        '--disable-build-servers[Force the command to ignore any persistent build servers]' \
                        '--artifacts-path[All build output files will go in subfolders under the specified path]:path:_directories' \
                        '--tl[Set terminal logger mode]:mode:(auto on off)' \
                        '*:project or solution:_files -g "*.{csproj,fsproj,vbproj,sln,slnx,cs}"' \
                        && ret=0
                    ;;
                (clean)
                    _arguments -s \
                        {-c,--configuration}'[The configuration to clean]:configuration:(Debug Release)' \
                        {-f,--framework}'[The target framework to clean for]:framework' \
                        {-r,--runtime}'[The target runtime to clean for]:runtime' \
                        {-o,--output}'[The output directory to clean]:directory:_directories' \
                        {-v,--verbosity}'[Set the MSBuild verbosity level]:verbosity:(quiet minimal normal detailed diagnostic)' \
                        '--interactive[Allows the command to stop and wait for user input]' \
                        '--nologo[Do not display the startup banner]' \
                        '--artifacts-path[The artifacts path]:path:_directories' \
                        '*:project or solution:_files -g "*.{csproj,fsproj,vbproj,sln,slnx}"' \
                        && ret=0
                    ;;
                (new)
                    _arguments -s \
                        '--dry-run[Display a summary of what would happen if the command were run]' \
                        '--force[Force content to be generated even if it would change existing files]' \
                        '--language[Filter templates based on language]:language:(C# F# VB)' \
                        {-n,--name}'[The name for the output]:name' \
                        {-o,--output}'[Location to place the generated output]:directory:_directories' \
                        '--project[The project that the template is added to]:project:_files' \
                        '--type[Filter templates based on type]:type:(project item solution)' \
                        '--list[List templates containing the specified template name]' \
                        '--search[Search for templates on NuGet.org]' \
                        '--install[Install a template package]:package' \
                        '--uninstall[Uninstall a template package]:package' \
                        '--update-check[Check for available template package updates]' \
                        '--update-apply[Check for and apply available template package updates]' \
                        '--columns[Columns to display in list output]:columns' \
                        '--columns-all[Display all columns in list output]' \
                        '--tag[Filter templates based on tag]:tag' \
                        '--no-update-check[Disable checking for template package updates]' \
                        '*:template:' \
                        && ret=0
                    ;;
                (publish)
                    _arguments -s \
                        {-c,--configuration}'[The configuration to publish]:configuration:(Debug Release)' \
                        {-f,--framework}'[The target framework to publish for]:framework' \
                        {-r,--runtime}'[The target runtime to publish for]:runtime' \
                        {-o,--output}'[The output directory]:directory:_directories' \
                        {-v,--verbosity}'[Set the MSBuild verbosity level]:verbosity:(quiet minimal normal detailed diagnostic)' \
                        '--self-contained[Publish the .NET runtime with the application]' \
                        '--no-self-contained[Publish without the .NET runtime]' \
                        '--no-build[Do not build the project before publishing]' \
                        '--no-restore[Do not restore the project before publishing]' \
                        '--interactive[Allows the command to stop and wait for user input]' \
                        '--nologo[Do not display the startup banner]' \
                        '--version-suffix[Set the value of the VersionSuffix property]:suffix' \
                        '--manifest[Path to a target manifest file]:file:_files' \
                        '--force[Force all dependencies to be resolved]' \
                        '--ucr[Use current runtime as the target runtime]' \
                        '--use-current-runtime[Use current runtime as the target runtime]' \
                        '--artifacts-path[All build output files will go in subfolders under the specified path]:path:_directories' \
                        '--disable-build-servers[Force the command to ignore any persistent build servers]' \
                        '--os[The target operating system]:os' \
                        '--arch[The target architecture]:arch' \
                        '--tl[Set terminal logger mode]:mode:(auto on off)' \
                        '*:project or solution:_files -g "*.{csproj,fsproj,vbproj,sln,slnx}"' \
                        && ret=0
                    ;;
                (run)
                    _arguments -s \
                        {-c,--configuration}'[The configuration to run]:configuration:(Debug Release)' \
                        {-f,--framework}'[The target framework to run for]:framework' \
                        {-r,--runtime}'[The target runtime to run for]:runtime' \
                        {-v,--verbosity}'[Set the MSBuild verbosity level]:verbosity:(quiet minimal normal detailed diagnostic)' \
                        '--project[Path to the project file]:project:_files -g "*.{csproj,fsproj,vbproj}"' \
                        '--launch-profile[The name of the launch profile to use]:profile' \
                        '--no-launch-profile[Do not attempt to use launchSettings.json]' \
                        '--no-build[Do not build the project before running]' \
                        '--no-restore[Do not restore the project before building]' \
                        '--interactive[Allows the command to stop and wait for user input]' \
                        '--self-contained[Publish the .NET runtime with the application]' \
                        '--no-self-contained[Publish without the .NET runtime]' \
                        '--artifacts-path[All build output files will go in subfolders under the specified path]:path:_directories' \
                        '--tl[Set terminal logger mode]:mode:(auto on off)' \
                        '--property[Set one or more MSBuild properties]:key=value' \
                        '*:arguments:' \
                        && ret=0
                    ;;
                (test)
                    _arguments -s \
                        {-c,--configuration}'[The configuration to test]:configuration:(Debug Release)' \
                        {-f,--framework}'[The target framework to test for]:framework' \
                        {-r,--runtime}'[The target runtime to test for]:runtime' \
                        {-o,--output}'[The output directory]:directory:_directories' \
                        {-v,--verbosity}'[Set the MSBuild verbosity level]:verbosity:(quiet minimal normal detailed diagnostic)' \
                        '--filter[Run tests matching the given expression]:filter' \
                        '--test-adapter-path[Path to custom test adapters]:path:_directories' \
                        {-l,--logger}'[Specify a logger for test results]:logger' \
                        {-s,--settings}'[The settings file to use]:file:_files' \
                        '--no-build[Do not build the project before testing]' \
                        '--no-restore[Do not restore the project before building]' \
                        '--results-directory[The directory where the test results will be placed]:directory:_directories' \
                        '--collect[Enable data collector]:data-collector' \
                        '--blame[Run the tests in blame mode]' \
                        '--blame-crash[Run the tests in blame mode and collect a crash dump]' \
                        '--blame-hang[Run the tests in blame mode and collect a hang dump]' \
                        '--blame-hang-timeout[Per-test timeout for hang detection]:timeout' \
                        '--blame-hang-dump-type[The type of crash dump to collect]:type:(full mini none)' \
                        '--blame-crash-dump-type[The type of crash dump to collect]:type:(full mini none)' \
                        '--blame-crash-collect-always[Collect crash dump even on expected exit]' \
                        '--nologo[Do not display the startup banner]' \
                        '--interactive[Allows the command to stop and wait for user input]' \
                        '--artifacts-path[All build output files will go in subfolders under the specified path]:path:_directories' \
                        '--arch[The target architecture]:arch' \
                        '--os[The target operating system]:os' \
                        '--tl[Set terminal logger mode]:mode:(auto on off)' \
                        '--disable-build-servers[Force the command to ignore any persistent build servers]' \
                        '*:project or solution:_files -g "*.{csproj,fsproj,vbproj,sln,slnx}"' \
                        && ret=0
                    ;;
                (restore)
                    _arguments -s \
                        {-v,--verbosity}'[Set the MSBuild verbosity level]:verbosity:(quiet minimal normal detailed diagnostic)' \
                        {-s,--source}'[NuGet package source to use]:source' \
                        {-r,--runtime}'[The target runtime to restore for]:runtime' \
                        '--packages[The directory to restore packages to]:directory:_directories' \
                        '--disable-parallel[Prevent restoring multiple projects in parallel]' \
                        '--configfile[The NuGet configuration file to use]:file:_files' \
                        '--no-cache[Do not cache HTTP requests]' \
                        '--ignore-failed-sources[Treat package source failures as warnings]' \
                        '--force[Force all dependencies to be resolved]' \
                        '--force-evaluate[Force NuGet to re-evaluate all dependencies]' \
                        '--no-dependencies[Do not restore project-to-project references]' \
                        '--interactive[Allows the command to stop and wait for user input]' \
                        '--use-lock-file[Enables project lock file to be generated and used with restore]' \
                        '--locked-mode[Do not allow updating project lock file]' \
                        '--lock-file-path[Output location for project lock file]:path:_files' \
                        '--nologo[Do not display the startup banner]' \
                        '--artifacts-path[All build output files will go in subfolders under the specified path]:path:_directories' \
                        '--tl[Set terminal logger mode]:mode:(auto on off)' \
                        '--disable-build-servers[Force the command to ignore any persistent build servers]' \
                        '*:project or solution:_files -g "*.{csproj,fsproj,vbproj,sln,slnx}"' \
                        && ret=0
                    ;;
                (pack)
                    _arguments -s \
                        {-c,--configuration}'[The configuration to pack]:configuration:(Debug Release)' \
                        {-o,--output}'[The output directory]:directory:_directories' \
                        {-v,--verbosity}'[Set the MSBuild verbosity level]:verbosity:(quiet minimal normal detailed diagnostic)' \
                        '--no-build[Do not build the project before packing]' \
                        '--no-restore[Do not restore the project before building]' \
                        '--include-symbols[Include packages with symbols]' \
                        '--include-source[Include source files in the package]' \
                        '--version-suffix[Set the value of the VersionSuffix property]:suffix' \
                        '--serviceable[Set the serviceable flag in the package]' \
                        '--interactive[Allows the command to stop and wait for user input]' \
                        '--nologo[Do not display the startup banner]' \
                        '--artifacts-path[All build output files will go in subfolders under the specified path]:path:_directories' \
                        '--tl[Set terminal logger mode]:mode:(auto on off)' \
                        '*:project:_files -g "*.{csproj,fsproj,vbproj,nuspec}"' \
                        && ret=0
                    ;;
                (tool)
                    _arguments -s \
                        '1:tool command:(install uninstall update list search run restore)' \
                        '--global[Install or manage tools for the current user]' \
                        '--local[Install or manage tools in the local tool manifest]' \
                        '--tool-path[The directory where the tool will be installed]:directory:_directories' \
                        '--tool-manifest[Path to the manifest file]:file:_files' \
                        '--version[The version of the tool package]:version' \
                        '--configfile[The NuGet configuration file to use]:file:_files' \
                        '--add-source[Additional NuGet package source to use]:source' \
                        '--framework[The target framework to install the tool for]:framework' \
                        '--prerelease[Include prerelease packages]' \
                        '--disable-parallel[Prevent restoring multiple projects in parallel]' \
                        '--ignore-failed-sources[Treat package source failures as warnings]' \
                        '--no-cache[Do not cache HTTP requests]' \
                        '--interactive[Allows the command to stop and wait for user input]' \
                        '--allow-downgrade[Allow package downgrade]' \
                        '--create-manifest-if-needed[Create a local tool manifest if one does not exist]' \
                        '*:package:' \
                        && ret=0
                    ;;
                (workload)
                    _arguments -s \
                        '1:workload command:(install update restore repair list search uninstall)' \
                        '--skip-manifest-update[Skip updating the workload manifests]' \
                        '--temp-dir[Specify temporary directory]:directory:_directories' \
                        '--configfile[The NuGet configuration file to use]:file:_files' \
                        '--add-source[Additional NuGet package source to use]:source' \
                        '--skip-sign-check[Skip signature verification]' \
                        '--include-previews[Include preview workloads]' \
                        '--from-rollback-file[Path to rollback file]:file:_files' \
                        {-v,--verbosity}'[Set the MSBuild verbosity level]:verbosity:(quiet minimal normal detailed diagnostic)' \
                        '*:workload-id:' \
                        && ret=0
                    ;;
                (format)
                    _arguments -s \
                        '--diagnostics[Show third party formatter diagnostics]' \
                        '--severity[Set minimum severity of diagnostics]:severity:(info warning error)' \
                        '--no-restore[Do not restore the project before formatting]' \
                        '--include[Paths to include]:path' \
                        '--exclude[Paths to exclude]:path' \
                        '--verify-no-changes[Verify no formatting changes would be performed; returns non-zero exit code if any files would be formatted]' \
                        '--report[Produce a report in the given directory]:directory:_directories' \
                        '--binarylog[Log all project or solution load information to a binary log file]:file:_files' \
                        {-v,--verbosity}'[Set the verbosity level]:verbosity:(quiet minimal normal detailed diagnostic)' \
                        '*:project or solution:_files -g "*.{csproj,fsproj,vbproj,sln,slnx}"' \
                        && ret=0
                    ;;
                (solution)
                    _arguments -s \
                        '1:solution command:(add remove list)' \
                        '*:project or solution:_files -g "*.{csproj,fsproj,vbproj,sln,slnx}"' \
                        && ret=0
                    ;;
                (nuget)
                    _arguments -s \
                        '1:nuget command:(delete locals push verify trust sign)' \
                        '*:arguments:' \
                        && ret=0
                    ;;
                (package)
                    _arguments -s \
                        '1:package command:(add remove list search)' \
                        '*:arguments:' \
                        && ret=0
                    ;;
                (reference)
                    _arguments -s \
                        '1:reference command:(add remove list)' \
                        '*:project:_files -g "*.{csproj,fsproj,vbproj}"' \
                        && ret=0
                    ;;
                (watch)
                    _arguments -s \
                        '--project[Path to the project file]:project:_files -g "*.{csproj,fsproj,vbproj}"' \
                        '--no-hot-reload[Suppress hot reload for supported apps]' \
                        '--list[List all discovered files]' \
                        {-v,--verbosity}'[Set the verbosity level]:verbosity:(quiet minimal normal detailed diagnostic)' \
                        '*:arguments:' \
                        && ret=0
                    ;;
                (sdk)
                    _arguments -s \
                        '1:sdk command:(check)' \
                        && ret=0
                    ;;
                (dev-certs)
                    _arguments -s \
                        '1:dev-certs command:(https)' \
                        '--check[Check for the existence of the certificate]' \
                        '--clean[Remove all HTTPS development certificates]' \
                        '--export-path[Export the certificate to the given path]:path:_files' \
                        '--format[Export in the given format]:format:(Pfx Pem)' \
                        '--password[Password to use for the exported certificate]:password' \
                        '--trust[Trust the certificate on the current platform]' \
                        '--no-password[Do not use a password when exporting]' \
                        '--quiet[Display warnings and errors only]' \
                        {-v,--verbose}'[Display more detailed information]' \
                        && ret=0
                    ;;
                (*)
                    _arguments -s \
                        '*:filename:_files' \
                        && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_dotnet "$@"
