#compdef umount.ecryptfs_private
# Documentation: https://man.archlinux.org/search?q=umount.ecryptfs_private
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[display this help and exit]'
  '-f[forcibly unmount]'
  '-d[dont treat a non-zero session counter as an error]'
  '*:filename:_files'
)

_arguments -s -S $arguments
