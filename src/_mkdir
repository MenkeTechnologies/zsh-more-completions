#compdef mkdir

# Zsh completion for mkdir - make directories
# Supports both GNU coreutils and BSD/macOS variants

local -a arguments

if [[ "$OSTYPE" == darwin* || "$OSTYPE" == freebsd* ]]; then
  # BSD/macOS variant
  arguments=(
    '-m[set file permission bits]:mode: '
    '-p[create intermediate directories as required, no error if existing]'
    '-v[be verbose, list directories as they are created]'
    '*:directory:_directories'
  )
else
  # GNU coreutils variant
  arguments=(
    {-m,--mode}'=[set file mode (as in chmod)]:mode: '
    {-p,--parents}'[no error if existing, make parent directories as needed]'
    {-v,--verbose}'[print a message for each created directory]'
    '-Z[set SELinux security context of each created directory to default type]'
    '--context=-[like -Z, or if CTX is specified then set the SELinux or SMACK security context]:context: '
    '--help[display help and exit]'
    '--version[output version information and exit]'
    '*:directory:_directories'
  )
fi

_arguments -s -S $arguments
