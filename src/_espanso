#compdef espanso

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'edit:edit configuration files'
      'match:list and execute matches'
      'start:start the espanso daemon'
      'stop:stop the espanso daemon'
      'restart:restart the espanso daemon'
      'status:check daemon status'
      'path:print espanso data paths'
      'install:install a package'
      'uninstall:uninstall a package'
      'package:package management subcommands'
      'log:show espanso logs'
      'workaround:apply workarounds'
      'env-path:add/remove espanso from PATH'
      'service:manage espanso service'
      'cmd:send commands to running daemon'
    )
    _describe -t commands 'espanso command' commands && ret=0
    ;;
  args)
    case $line[1] in
      edit)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:file to edit' && ret=0
        ;;
      install)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--external[allow external packages]' \
          '1:package name' && ret=0
        ;;
      uninstall)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:package name' && ret=0
        ;;
      path)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:path type:(config packages runtime)' && ret=0
        ;;
      service)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(register unregister start stop restart status)' && ret=0
        ;;
      start|stop|restart|status|log)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
