#compdef bat

# Zsh completion for bat (a cat clone with syntax highlighting and Git integration)

_bat_languages() {
  local -a langs
  langs=(${(f)"$(bat --list-languages 2>/dev/null | while IFS=: read -r name exts; do
    print -- "${name// /_}:${name}"
  done)"})
  _describe -t languages 'language' langs
}

_bat_themes() {
  local -a themes
  themes=(${(f)"$(bat --list-themes 2>/dev/null | command grep -v '^ ')"})
  _describe -t themes 'theme' themes
}

_bat_style_components() {
  local -a components
  components=(
    'default:enables recommended style components'
    'full:enables all available components'
    'auto:same as default unless output is piped'
    'plain:disables all available components'
    'changes:show Git modification markers'
    'header:alias for header-filename'
    'header-filename:show filenames before content'
    'header-filesize:show file sizes before content'
    'grid:vertical/horizontal lines to separate sections'
    'rule:horizontal lines to delimit files'
    'numbers:show line numbers in the side bar'
    'snip:draw separation lines between distinct line ranges'
  )
  _describe -t style-components 'style component' components -S ','
}

_arguments -s -S \
  '(- *)'{-h,--help}'[print help message]' \
  '(- *)'{-V,--version}'[show version information]' \
  '(- *)'{-L,--list-languages}'[display a list of supported languages]' \
  '(- *)--list-themes[display a list of supported themes]' \
  '(- *)--diagnostic[show diagnostic information for bug reports]' \
  '(- *)--acknowledgements[show acknowledgements]' \
  '(- *)--config-file[display the path to the configuration file]' \
  '(- *)--config-dir[display the path to the configuration directory]' \
  '(- *)--generate-config-file[generate a default configuration file]' \
  '(- *)--completion[show shell completion script]:shell:(bash fish zsh ps1)' \
  {-A,--show-all}'[show non-printable characters (space, tab, newline, etc.)]' \
  '--nonprintable-notation[set notation for non-printable characters]:notation:(caret unicode)' \
  '--binary[how to treat binary content]:behavior:(no-printing as-text)' \
  '*'{-p,--plain}'[show plain style (alias for --style=plain); use -pp to also disable paging]' \
  {-l,--language}'[explicitly set the language for syntax highlighting]:language:_bat_languages' \
  '*'{-H,--highlight-line}'[highlight the specified line range]:line range (N\:M):' \
  '--file-name[specify the name to display for a file]:name:_files' \
  {-d,--diff}'[only show lines that have been added/removed/modified w.r.t. the Git index]' \
  '--diff-context[include N lines of context around changed lines when using --diff]:lines:' \
  '--tabs[set the tab width to T spaces (0 passes tabs through directly)]:tab width:' \
  '--wrap[specify the text-wrapping mode]:mode:(auto never character)' \
  {-S,--chop-long-lines}'[truncate all lines longer than screen width (alias for --wrap=never)]' \
  '--terminal-width[explicitly set the terminal width]:width:' \
  {-n,--number}'[show line numbers (alias for --style=numbers)]' \
  '--color[specify when to use colored output]:when:(auto never always)' \
  '--italic-text[specify when to use italics in output]:when:(always never)' \
  '--decorations[specify when to show decorations]:when:(auto never always)' \
  {-f,--force-colorization}'[alias for --decorations=always --color=always]' \
  '--paging[specify when to use the pager]:when:(auto never always)' \
  '--pager[determine which pager to use]:pager command:' \
  '*'{-m,--map-syntax}'[map a glob pattern to a syntax name]:mapping (glob\:syntax):' \
  '--ignored-suffix[ignore a file extension for syntax detection]:suffix:' \
  '--theme[set the color theme for syntax highlighting]:theme:_bat_themes' \
  '--theme-light[set theme for light terminal backgrounds]:theme:_bat_themes' \
  '--theme-dark[set theme for dark terminal backgrounds]:theme:_bat_themes' \
  '--style[configure which elements to display]:style components:_bat_style_components' \
  '*'{-r,--line-range}'[only print the specified range of lines]:range (N\:M):' \
  {-s,--squeeze-blank}'[squeeze consecutive empty lines into a single empty line]' \
  '--squeeze-limit[set max number of consecutive empty lines to print]:limit:' \
  '--strip-ansi[specify when to strip ANSI escape sequences from input]:when:(auto always never)' \
  '--set-terminal-title[set terminal title to filenames when using a pager]' \
  {-u,--unbuffered}'[POSIX-compliance option (output is always unbuffered)]' \
  '*:file:_files'
