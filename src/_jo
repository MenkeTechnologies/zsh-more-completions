#compdef jo

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-a)-a[create a JSON array]' \
  '(-B)-B[disable boolean detection]' \
  '(-d)-d[set delimiter for nested objects]:delimiter' \
  '(-e)-e[do not ignore empty stdin]' \
  '(-n)-n[do not print trailing newline]' \
  '(-p)-p[pretty print]' \
  '*:key=value pair' && ret=0

return ret
