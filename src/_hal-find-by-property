#compdef hal-find-by-property
# Documentation: https://man.archlinux.org/search?q=hal-find-by-property
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--key[key of the property to check]'
  '--string[string value of property]'
  '--verbose[be verbose]'
  '--version[show version and exit]'
  '--help[show this information and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
