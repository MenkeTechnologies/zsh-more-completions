#compdef marked

local -a arguments

arguments=(
    '-o[Output file]:file:_files'
    '--output[Output file]:file:_files'
    '-i[Input file]:file:_files -g "*.{md,markdown,mkd}"'
    '--input[Input file]:file:_files -g "*.{md,markdown,mkd}"'
    '-s[Read from stdin]:string'
    '--string[Read from stdin]:string'
    '-t[Tokenize only]'
    '--tokens[Tokenize only]'
    '--no-clobber[Do not overwrite output file]'
    '--pedantic[Conform to original markdown.pl]'
    '--gfm[Enable GitHub Flavored Markdown]'
    '--breaks[Enable GFM line breaks]'
    '--no-breaks[Disable GFM line breaks]'
    '--no-gfm[Disable GFM]'
    '--sanitize[Sanitize output]'
    '--silent[Silence error output]'
    '-h[Show help]'
    '--help[Show help]'
    '-v[Show version]'
    '--version[Show version]'
    '*:input files:_files -g "*.{md,markdown,mkd}"'
)

_arguments -s -S $arguments
