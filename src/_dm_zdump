#compdef dm_zdump
# Documentation: https://man.archlinux.org/search?q=dm_zdump
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[/--help : Print help.]'
  '-v[/--vebose : Prints a full description of each]'
  '-c[/--cutoff YEAR : Cut off verbose output near the]'
  '*:filename:_files'
)

_arguments -s -S $arguments
