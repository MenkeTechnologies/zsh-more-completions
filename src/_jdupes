#compdef jdupes
# Zsh completion for jdupes - Duplicate file finder and manager
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-r --recurse)'{-r,--recurse}'[recurse into subdirectories]' \
  '(-R --recurse\:)'{-R,--recurse:}'[recurse into specified subdirectories only]' \
  '(-d --delete)'{-d,--delete}'[prompt for files to delete]' \
  '(-D --print-dupes)'{-D,--print-dupes}'[print duplicate files]' \
  '(-S --size)'{-S,--size}'[show sizes of duplicate files]' \
  '(-s --symlinks)'{-s,--symlinks}'[follow symlinks]' \
  '(-H --hardlinks)'{-H,--hardlinks}'[treat hard links as duplicates]' \
  '(-L --linkhard)'{-L,--linkhard}'[hardlink duplicates]' \
  '(-m --summarize)'{-m,--summarize}'[summarize duplicate file information]' \
  '(-n --noempty)'{-n,--noempty}'[exclude zero-length files]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-Q --quick)'{-Q,--quick}'[skip byte-for-byte verification]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-z --zeromatch)'{-z,--zeromatch}'[consider zero-length files as duplicates]' \
  '(-Z --softabort)'{-Z,--softabort}'[if interrupted, act on found duplicates]' \
  '(-N --noprompt)'{-N,--noprompt}'[act without prompting user]' \
  '(-A --nohidden)'{-A,--nohidden}'[exclude hidden files]' \
  '(-o --order)'{-o,--order}'[select sort order]:order:(name time)' \
  '(-O --paramorder)'{-O,--paramorder}'[order matches by parameter order]' \
  '(-p --permissions)'{-p,--permissions}'[only match files with same owner/group/permissions]' \
  '(-P --print)'{-P,--print}'[print matches]' \
  '(-i --reverse)'{-i,--reverse}'[reverse sort order]' \
  '(-I --isolate)'{-I,--isolate}'[only match files from different parameter directories]' \
  '(-1 --one-file-system)'{-1,--one-file-system}'[do not match files on different filesystems]' \
  '(-T --partial-only)'{-T,--partial-only}'[match only based on partial hashes]' \
  '(-X --ext-filter)'{-X,--ext-filter}'[filter by extension specification]:spec:' \
  '(- *)--help[show help information]' \
  '(- *)--version[show version]' \
  '*:directory:_directories' && ret=0
return ret
