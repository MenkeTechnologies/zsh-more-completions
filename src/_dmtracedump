#compdef dmtracedump
# Documentation: https://man.archlinux.org/search?q=dmtracedump
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-d[Diff with this trace]'
  '-g[Write graph to outfile]'
  '-k[When writing a graph, keep the intermediate DOT file]'
  '-h[Turn on HTML output]'
  '-o[Dump the dmtrace file instead of profiling]'
  '-s[base to where the sortable javascript file]:url'
  '-t[Threshold percentage for including nodes in the graph]'
  '*:filename:_files'
)

_arguments -s -S $arguments
