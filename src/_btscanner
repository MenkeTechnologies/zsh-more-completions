#compdef btscanner
# Documentation: https://man.archlinux.org/search?q=btscanner
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--help[display help]'
  '--cfg[use <file> as the config file]'
  '--no-reset[do not reset the Bluetooth adapter before scanning]'
  '*:filename:_files'
)

_arguments -s -S $arguments
