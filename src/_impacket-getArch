#compdef impacket-getArch
# Documentation: https://man.archlinux.org/search?q=impacket-getArch
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[show this help message and exit]'
  '-target[<targetName or address>]'
  '-targets[input file with targets system to query Arch from (one per]'
  '-timeout[socket timeout out when connecting to the target]'
  '-debug[turn DEBUG output ON]'
  '*:filename:_files'
)

_arguments -s -S $arguments
