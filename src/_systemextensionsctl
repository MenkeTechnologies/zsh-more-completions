#compdef systemextensionsctl

local -a subcommands

subcommands=(
    'list:List system extensions'
    'reset:Reset system extensions state'
    'uninstall:Uninstall a system extension'
    'developer:Enable or disable developer mode'
)

_arguments -s -S \
    '1:subcommand:->subcmd' \
    '*:: :->args' && return

case $state in
    subcmd)
        _describe 'systemextensionsctl subcommand' subcommands
        ;;
    args)
        case $words[1] in
            uninstall)
                _arguments \
                    '1:team identifier' \
                    '2:bundle identifier'
                ;;
            developer)
                _arguments \
                    '1:mode:(on off)'
                ;;
        esac
        ;;
esac
