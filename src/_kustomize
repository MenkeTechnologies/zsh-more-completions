#compdef kustomize

# Zsh completion for kustomize (Kubernetes customization tool)

_kustomize() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    local -a commands
    commands=(
        'build:build a kustomization target from a directory or URL'
        'cfg:commands for reading and writing configuration'
        'completion:generate shell completion script'
        'create:create a new kustomization in the current directory'
        'edit:edit a kustomization file'
        'fn:commands for running functions against configuration'
        'version:prints the kustomize version'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[help for kustomize]' \
        '1:command:->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'kustomize command' commands
            ;;
        args)
            case $words[1] in
                build)
                    _arguments -s -S \
                        '--as-current-user[use the uid and gid of the command executor]' \
                        '--enable-alpha-plugins[enable alpha plugins]' \
                        '--enable-exec[enable exec functions]' \
                        '--enable-helm[enable use of the Helm chart inflator generator]' \
                        '--enable-managedby-label[enable adding app.kubernetes.io/managed-by label]' \
                        '--enable-star[enable the star function]' \
                        '--helm-command=[helm command]:helm command' \
                        '--load-restrictor=[set the load restrictor]:restrictor:(LoadRestrictionsRootOnly LoadRestrictionsNone)' \
                        '*--mount=[mount a local directory]:mount spec' \
                        '--network[enable network access for functions]' \
                        '--network-name=[the docker network to run the container in]:network name' \
                        '(-o --output)'{-o,--output}'=[write output to a file]:output file:_files' \
                        '--reorder=[reorder the resources]:reorder mode:(legacy none)' \
                        '1:kustomization directory:_directories'
                    ;;
                cfg)
                    local -a cfg_commands=(
                        'cat:display resources in a directory'
                        'count:count resources in a directory'
                        'grep:search for matching resources'
                        'tree:display resources and their structure'
                    )
                    _arguments -C \
                        '1:cfg subcommand:->cfgcmd' \
                        '*::arg:->cfgargs'
                    case $state in
                        cfgcmd)
                            _describe -t cfg_commands 'cfg subcommand' cfg_commands
                            ;;
                        cfgargs)
                            _arguments -s -S '*:path:_directories'
                            ;;
                    esac
                    ;;
                completion)
                    _arguments -s -S '1:shell:(bash zsh fish powershell)'
                    ;;
                create)
                    _arguments -s -S \
                        '--annotations=[add one or more common annotations]:annotations' \
                        '--labels=[add one or more common labels]:labels' \
                        '--nameprefix=[set the name prefix]:prefix' \
                        '--namesuffix=[set the name suffix]:suffix' \
                        '--namespace=[set the namespace]:namespace' \
                        '--autodetect[detect resources in the current directory]' \
                        '*--resource=[add a resource to the kustomization]:resource:_files' \
                        '--recursive[detect resources recursively]'
                    ;;
                edit)
                    local -a edit_commands=(
                        'add:add items to the kustomization file'
                        'fix:fix kustomization file'
                        'remove:remove items from the kustomization file'
                        'set:set values in the kustomization file'
                    )
                    _arguments -C \
                        '1:edit subcommand:->editcmd' \
                        '*::arg:->editargs'
                    case $state in
                        editcmd)
                            _describe -t edit_commands 'edit subcommand' edit_commands
                            ;;
                        editargs)
                            case $line[1] in
                                add)
                                    local -a add_commands=(
                                        'resource:add a resource to the kustomization file'
                                        'patch:add a patch to the kustomization file'
                                        'configmap:add a configmap to the kustomization file'
                                        'secret:add a secret to the kustomization file'
                                        'annotation:add an annotation to the kustomization file'
                                        'label:add a label to the kustomization file'
                                        'buildmetadata:add a buildmetadata entry'
                                    )
                                    _arguments -C \
                                        '1:add type:->addtype' \
                                        '*::arg:->addargs'
                                    case $state in
                                        addtype)
                                            _describe -t add_commands 'add type' add_commands
                                            ;;
                                        addargs)
                                            case $line[1] in
                                                resource)
                                                    _arguments -s -S '*:resource file:_files'
                                                    ;;
                                                patch)
                                                    _arguments -s -S \
                                                        '--path=[path to the patch file]:patch file:_files' \
                                                        '--kind=[target resource kind]:kind' \
                                                        '--group=[target resource group]:group' \
                                                        '--version=[target resource version]:version' \
                                                        '--name=[target resource name]:name' \
                                                        '--namespace=[target resource namespace]:namespace'
                                                    ;;
                                                configmap|secret)
                                                    _arguments -s -S \
                                                        '--from-literal=[key=value pair]:key=value' \
                                                        '--from-file=[file path]:file:_files' \
                                                        '--from-env-file=[env file path]:env file:_files' \
                                                        '--disableNameSuffixHash[disable name suffix hash generation]' \
                                                        '1:name:'
                                                    ;;
                                                annotation|label)
                                                    _arguments -s -S \
                                                        '--force[overwrite existing value]' \
                                                        '*:key\:value pair:'
                                                    ;;
                                                buildmetadata)
                                                    _arguments -s -S '1:buildmetadata:(originAnnotations transformerAnnotations managedByLabel)'
                                                    ;;
                                            esac
                                            ;;
                                    esac
                                    ;;
                                fix)
                                    _arguments -s -S '*:path:_directories'
                                    ;;
                                remove)
                                    local -a remove_commands=(
                                        'resource:remove a resource'
                                        'patch:remove a patch'
                                        'annotation:remove an annotation'
                                        'label:remove a label'
                                        'buildmetadata:remove a buildmetadata entry'
                                    )
                                    _arguments -C \
                                        '1:remove type:->removetype' \
                                        '*::arg:->removeargs'
                                    case $state in
                                        removetype)
                                            _describe -t remove_commands 'remove type' remove_commands
                                            ;;
                                        removeargs)
                                            _arguments -s -S '*:value:'
                                            ;;
                                    esac
                                    ;;
                                set)
                                    local -a set_commands=(
                                        'image:set the image in the kustomization file'
                                        'namespace:set the namespace in the kustomization file'
                                        'nameprefix:set the name prefix in the kustomization file'
                                        'namesuffix:set the name suffix in the kustomization file'
                                        'replicas:set the replica count for a resource'
                                    )
                                    _arguments -C \
                                        '1:set type:->settype' \
                                        '*::arg:->setargs'
                                    case $state in
                                        settype)
                                            _describe -t set_commands 'set type' set_commands
                                            ;;
                                        setargs)
                                            _arguments -s -S '*:value:'
                                            ;;
                                    esac
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                fn)
                    local -a fn_commands=(
                        'run:generate, transform, or validate configuration files using functions'
                        'source:read resources from a directory'
                        'sink:write resources to a directory'
                    )
                    _arguments -C \
                        '1:fn subcommand:->fncmd' \
                        '*::arg:->fnargs'
                    case $state in
                        fncmd)
                            _describe -t fn_commands 'fn subcommand' fn_commands
                            ;;
                        fnargs)
                            _arguments -s -S \
                                '--image=[run this container image]:image' \
                                '--mount=[mount a local directory]:mount spec' \
                                '--as-current-user[use the uid and gid of the command executor]' \
                                '--network[enable network access for functions]' \
                                '--enable-exec[enable exec functions]' \
                                '*:path:_directories'
                            ;;
                    esac
                    ;;
                version)
                    _arguments -s -S '--short[print just the version number]'
                    ;;
            esac
            ;;
    esac
}

_kustomize "$@"
