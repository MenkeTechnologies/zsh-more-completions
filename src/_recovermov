#compdef recovermov
# Documentation: https://man.archlinux.org/search?q=recovermov
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-b[block size in bytes]'
  '-n[basename of the mov files to create]'
  '-h[this help message]'
  '-i[initial movie index]'
  '-o[restore mov files into this directory]'
  '-V[display version and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
