#compdef msbuild

local -a arguments

arguments=(
  '-target[build specified targets]:targets: '
  '-property[set or override project-level properties]:name=value: '
  '-maxCpuCount[maximum number of concurrent processes]:count: '
  '-toolsVersion[version of the toolset to use]:version: '
  '-verbosity[display this amount of information in the event log]:level:(quiet minimal normal detailed diagnostic)'
  '-consoleLoggerParameters[parameters for the console logger]:parameters: '
  '-noConsoleLogger[disable the default console logger]'
  '-fileLogger[log build output to a file]'
  '-fileLoggerParameters[extra parameters for file loggers]:parameters: '
  '-distributedLogger[use specified distributed logger]:logger: '
  '-distributedFileLogger[log build output to multiple log files]'
  '-logger[use this logger to log events]:logger: '
  '-binaryLogger[log to a binary log file]:output file: '
  '-warnAsError[treat specified warnings as errors]:codes: '
  '-warnAsMessage[treat specified warnings as messages]:codes: '
  '-ignoreProjectExtensions[ignore specified extensions when finding project file]:extensions: '
  '-nodeReuse[enable or disable reuse of MSBuild nodes]:bool:(true false)'
  '-preprocess[create a single, aggregated project file]'
  '-detailedSummary[show detailed information at end of build]'
  '-restore[run Restore target prior to building]'
  '-restoreProperty[set or override restore properties]:name=value: '
  '-profileEvaluation[profile MSBuild evaluation to specified file]:file:_files'
  '-interactive[allow actions in the build to interact with the user]'
  '-isolateProjects[build each project in isolation]'
  '-inputResultsCaches[input cache files]:cache files: '
  '-outputResultsCache[output cache file]:cache file: '
  '-graphBuild[construct and build a project graph]'
  '-noAutoResponse[do not auto-include any MSBuild.rsp files]'
  '-noLogo[do not display the startup banner and copyright message]'
  '(- * :)-version[display version information only]'
  '(- * :)-help[display usage message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
