#compdef texi2html

local -a arguments

arguments=(
  '--conf-dir[append $s to the init file directories]'
  '--css-include[use css file $s]'
  '--css-ref[generate reference to the CSS URL $s]'
  '--debug[output HTML with debugging information]'
  '--disable-encoding[do not output accented and special characters]'
  '--docbook[output Docbook XML rather than HTML]'
  '--document-language[use as document language]:language:'
  '--enable-encoding[override --disable-encoding (default in Info)]'
  {--error-limit,-e}'[quit after NUM errors (default 1000)]:num:'
  {--fill-column,-f}'[break Info lines at NUM characters (default 72)]:num:'
  {--footnote-style,-s}'[output footnotes in specified style]:style:(separate end)'
  {--force,-F}'[preserve output even if errors]'
  '--headers[output navigation headers for each section]'
  '(- * :)'{--help,-h}'[print help and exit]'
  '-I[append directory to the @include search path]:directory:_directories'
  '--ifdocbook[expand ifdocbook and docbook sections]'
  '--ifhtml[expand ifhtml and html sections]'
  '--ifinfo[expand ifinfo]'
  '--ifplaintext[expand ifplaintext sections]'
  '--iftex[expand iftex and tex sections]'
  '--ifxml[expand ifxml and xml sections]'
  '--info[output Info rather than HTML.]'
  '--init-file[load init file $s]'
  '--internal-links[produce list of internal links in FILE.]'
  '--l2h[use latex2html for @math and @tex]'
  {--macro-expand,-E}'[output macro expanded source to file]:file:_files'
  '--menu[output Texinfo menus]'
  '--no-validate[suppress node cross-reference validation]'
  '--no-warn[suppress warnings (but not errors)]'
  '--node-files[produce one file per node for cross references]'
  '--number-footnotes[output footnote numbers]'
  '--number-sections[output chapter and sectioning numbers]'
  '--output-indent[indent XML output (ignored)]'
  {--output,-o}'[output destination (directory if split)]:dest:_files'
  '-P[prepend directory to the @include search path]:directory:_directories'
  {--paragraph-indent,-p}'[indent paragraphs by VAL spaces]:val:'
  '--plaintext[output plain text rather than HTML.]'
  '--prefix[use as prefix for output files, instead of <docname>]'
  '--program[call as $s, setting corresponding defaults]'
  '--raw-text[output raw text rather than HTML.]'
  '--short-ext[use "htm" extension for output HTML files]'
  '--short-ref[references are without section numbers]'
  '--split[split document on given boundary]:split:(section chapter node)'
  '--split-size[split Info files at size (default 300000)]:size:'
  '--toc-file[use $s as ToC file, instead of <docname>_toc.html]'
  '--toc-links[create links from headings to toc entries]'
  '--top-file[use $s as top file, instead of <docname>.html]'
  '--transliterate-file-names[produce file names in ASCII transliteration]'
  '--use-nodes[use nodes for sectioning]'
  {--verbose,-v}'[print progress info to stdout]'
  '--version[print version and exit]'
  '--xml[output Texinfo XML rather than HTML.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
