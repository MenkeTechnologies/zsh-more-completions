#compdef grcc

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-d,--directory}'[specify the directory to output the compile program]'
  {-e,--execute}'[run the program after compiling \[default=False\]]'
  '*:filename:_files'
)

_arguments -s -S $arguments
