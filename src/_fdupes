#compdef fdupes

local -a arguments

arguments=(
  {-r,--recurse}'[for every directory given follow subdirectories]'
  {-R,--recurse}'[for each directory given after this option follow subdirectories]'
  {-s,--symlinks}'[follow symlinks]'
  {-H,--hardlinks}'[treat hard links as duplicates]'
  {-n,--noempty}'[exclude zero-length files from consideration]'
  {-A,--nohidden}'[exclude hidden files from consideration]'
  {-f,--omitfirst}'[omit the first file in each set of matches]'
  {-1,--sameline}'[list each set of matches on a single line]'
  {-S,--size}'[show size of duplicate files]'
  {-m,--summarize}'[summarize dupe information]'
  {-q,--quiet}'[hide progress indicator]'
  {-d,--delete}'[prompt user for files to preserve and delete all others]'
  {-N,--noprompt}'[together with --delete, preserve the first file in each set]'
  {-I,--immediate}'[delete duplicates as they are encountered]'
  {-p,--permissions}'[do not consider files with different owner/group or permissions]'
  {-o,--order}'[select sort order for output and deleting]:order:(name time)'
  {-i,--reverse}'[reverse order while sorting]'
  {-v,--version}'[display fdupes version]'
  '(- * :)'{-h,--help}'[display this help message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
