#compdef zigmod

# Zsh completion for zigmod (Zig package manager)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'fetch:fetch dependencies'
  'init:initialize a new project'
  'aq:add a dependency'
  'ci:do clean install of dependencies'
  'diff:show diff of dependencies'
  'graph:show dependency graph'
  'license:manage licenses'
  'update:update dependencies'
  'version:show version'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'zigmod command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (aq)
        _arguments '1:dependency:' && ret=0
        ;;
    esac
    ;;
esac

return ret
