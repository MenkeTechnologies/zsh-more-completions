#compdef wlancap2wpasec
# Documentation: https://man.archlinux.org/search?q=wlancap2wpasec
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-k[wpa-sec user key]'
  '-u[set user defined URL]'
  '-t[set connection timeout]'
  '-e[address> : set email address, if required]'
  '-R[remove cap if upload was successful]'
  '-h[this help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
