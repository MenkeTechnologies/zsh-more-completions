#compdef ld.so

local -a arguments

arguments=(
  '--list[list all dependencies and how they are resolved]'
  '--verify[verify that given object really is a dynamically linked]'
  '--inhibit-cache[do not use /etc/ld.so.cache]'
  '--library-path[use given PATH instead of content of the environment]'
  '--glibc-hwcaps-prepend[search glibc-hwcaps subdirectories in LIST]'
  '--glibc-hwcaps-mask[only search built-in subdirectories if in LIST]'
  '--inhibit-rpath[ignore RUNPATH and RPATH information in object names]'
  '--audit[use objects named in LIST as auditors]'
  '--preload[preload objects named in LIST]'
  '--argv0[set argv\[0\] to STRING before running]'
  '--list-tunables[list all tunables with minimum and maximum values]'
  '--list-diagnostics[list diagnostics information]'
  '--help[display this help and exit]'
  '--version[output version information and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
