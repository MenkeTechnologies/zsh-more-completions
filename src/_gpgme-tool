#compdef gpgme-tool
# Documentation: https://man.archlinux.org/search?q=gpgme-tool
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-s,--server}'[server mode]'
  '--gpg-binary[use FILE for the GPG backend]'
  '--lib-version[show library version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
