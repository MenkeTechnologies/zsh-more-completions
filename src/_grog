#compdef grog

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[print this usage message and exit]'
  '(-v --version)'{-v,--version}'[print version information and exit]'
  '-C[compatibility mode]'
  '--ligatures[include options for ligatures in internal font]'
  '--run[run the checked-out groff command]'
  '--warnings[display more warnings to standard error]'
  '*:filename:_files'
)

_arguments -s -S $arguments
