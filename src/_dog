#compdef dog

# Zsh completion for dog - Command-line DNS client

local curcontext="$curcontext" state line ret=1

local -a record_types=(
  'A' 'AAAA' 'ANAME' 'CAA' 'CNAME' 'HINFO' 'LOC' 'MX' 'NAPTR' 'NS'
  'OPT' 'PTR' 'SOA' 'SRV' 'SSHFP' 'TLSA' 'TXT'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-q+[host name or IP address to query]:domain:' \
  '-t+[type of DNS record to look up]:record type:(${record_types})' \
  '-n+[nameserver to send queries to]:nameserver:' \
  '--class=[network class of the DNS record]:class:(IN CH HS)' \
  '-1[short mode - display just the results]' \
  '--short[short mode]' \
  '-J[display output as JSON]' \
  '--json[display output as JSON]' \
  '--color=[when to colourise output]:when:(always automatic never)' \
  '--colour=[when to colourise output]:when:(always automatic never)' \
  '--seconds[display durations in seconds]' \
  '--time[print when the response was received]' \
  '-U[send queries over encrypted HTTPS (DoH)]' \
  '--https[send queries over encrypted HTTPS (DoH)]' \
  '-S[send queries over encrypted TLS (DoT)]' \
  '--tls[send queries over encrypted TLS (DoT)]' \
  '--edns=[set whether to OPT in request]:setting:(disable hide show)' \
  '--txid=[set the transaction ID to a specific value]:id:' \
  '-Z=[set uncommon or obscure options]:option:' \
  '*:domain name:' && ret=0

return ret
