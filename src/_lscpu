#compdef lscpu

local -a arguments

arguments=(
  {-a,--all}'[include lines for online and offline CPUs in the output]'
  {-B,--bytes}'[print sizes in bytes rather than in human readable format]'
  {-b,--online}'[limit the output to online CPUs]'
  {-C,--caches}'[display details about CPU caches]::list'
  {-c,--offline}'[limit the output to offline CPUs]'
  {-e,--extended}'[display the CPU information in human readable format]::list'
  {-H,--list-columns}'[list available columns for --extended, --parse and --caches]'
  '--hierarchic[use subsections in summary output]::when:(auto never always)'
  {-J,--json}'[use JSON output format for the default summary or extended output]'
  '--output-all[output all available columns]'
  {-p,--parse}'[optimize the command output for easy parsing]::list'
  {-r,--raw}'[produce output in raw format]'
  {-s,--sysroot}'[gather CPU data for a Linux instance other than the current one]:directory:_directories'
  {-x,--hex}'[use hexadecimal masks for CPU sets]'
  {-y,--physical}'[display physical IDs for all columns with topology elements]'
  '--annotate[add annotations to each column header name]::when:(auto never always)'
  '(- * :)'{-h,--help}'[display help text and exit]'
  '(- * :)'{-V,--version}'[display version information and exit]'
)

_arguments -s -S $arguments
