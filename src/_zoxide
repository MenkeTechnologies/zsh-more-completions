#compdef zoxide

# Zsh completion for zoxide - a smarter cd command

_zoxide_commands() {
    local -a commands
    commands=(
        'add:Add a directory to the database'
        'edit:Edit the database'
        'import:Import entries from another application'
        'init:Generate shell configuration'
        'query:Search for a directory in the database'
        'remove:Remove a directory from the database'
    )
    _describe -t commands 'zoxide command' commands
}

_zoxide_add() {
    _arguments \
        {-h,--help}'[Print help]' \
        {-V,--version}'[Print version]' \
        '*:path:_files -/'
}

_zoxide_edit() {
    _arguments \
        '--no-header[Do not print column names]' \
        {-h,--help}'[Print help]' \
        {-V,--version}'[Print version]'
}

_zoxide_import() {
    _arguments \
        '--from=[Application to import from]:app:(autojump z zsh-z)' \
        '--merge[Merge into existing database]' \
        {-h,--help}'[Print help]' \
        {-V,--version}'[Print version]' \
        ':path:_files'
}

_zoxide_init() {
    _arguments \
        '--cmd=[Change the prefix of the z and zi commands]:cmd:' \
        '--hook=[Change the event that adds a directory to the database]:hook:(none prompt pwd)' \
        '--no-cmd[Prevent zoxide from defining the z and zi commands]' \
        {-h,--help}'[Print help]' \
        {-V,--version}'[Print version]' \
        ':shell:(bash elvish fish nushell posix powershell xonsh zsh)'
}

_zoxide_query() {
    _arguments \
        {-a,--all}'[Show deleted directories]' \
        {-i,--interactive}'[Use interactive selection]' \
        {-l,--list}'[List all matching directories]' \
        {-s,--score}'[Print score with results]' \
        '--exclude=[Exclude a path from results]:path:_files -/' \
        {-h,--help}'[Print help]' \
        {-V,--version}'[Print version]' \
        '*:keywords:'
}

_zoxide_remove() {
    _arguments \
        {-i,--interactive}'[Use interactive selection]' \
        {-h,--help}'[Print help]' \
        {-V,--version}'[Print version]' \
        '*:path:_files -/'
}

_zoxide() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        {-h,--help}'[Print help]' \
        {-V,--version}'[Print version]' \
        '1:command:_zoxide_commands' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                add) _zoxide_add ;;
                edit) _zoxide_edit ;;
                import) _zoxide_import ;;
                init) _zoxide_init ;;
                query) _zoxide_query ;;
                remove) _zoxide_remove ;;
            esac
            ;;
    esac
}

_zoxide "$@"
