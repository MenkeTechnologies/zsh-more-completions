#compdef black-primer

local -a arguments

arguments=(
  {-c,--config}'[JSON config file path]:config file:_files'
  '--debug[turn on debug logging]'
  {-k,--keep}'[keep workdir + repos post run]'
  {-L,--long-checkouts}'[pull big projects to test]'
  '--no-diff[disable showing source file changes in black output]'
  '--projects[comma separated list of projects to run]:projects:'
  {-R,--rebase}'[rebase project if already checked out]'
  {-w,--workdir}'[directory path for repo checkouts]:directory:_files -/'
  {-W,--workers}'[number of parallel worker coroutines]:workers:'
  {-h,--help}'[show this message and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
