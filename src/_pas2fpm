#compdef pas2fpm
# Documentation: https://man.archlinux.org/search?q=pas2fpm
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[this help]'
  '-p[set package name]'
  '-i[use interface units only for checking dependencies]'
  '-o[set output filename (default is standard output)]'
  '-v[write diagnostic output to stderr]'
  '*:filename:_files'
)

_arguments -s -S $arguments
