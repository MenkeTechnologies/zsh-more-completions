#compdef qbittorrent

local -a arguments

arguments=(
  {-v,--version}'[display program version and exit]'
  '(- * :)'{-h,--help}'[display this help message and exit]'
  '--webui-port[change the Web UI port]:port: '
  '--no-splash[disable splash screen]'
  '--profile[store configuration files in specified directory]:dir:_directories'
  '--configuration[store configuration files in directories]:name: '
  '--relative-fastresume[make file paths relative in fast resume data]'
  '--portable[shortcut for --profile=<exe dir>/profile]'
  '--save-path[torrent save path]:path:_directories'
  '--add-paused[add torrents as started or paused]:true/false:(true false)'
  '--skip-hash-check[skip hash check]'
  '--category[assign torrents to category]:category: '
  '--sequential[download files in sequential order]'
  '--first-and-last[download first and last pieces first]'
  '--skip-dialog[specify whether the Add New Torrent dialog opens]:true/false:(true false)'
  '*:filename:_files'
)

_arguments -s -S $arguments
