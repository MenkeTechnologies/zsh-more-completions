#compdef tcptrace
# Documentation: https://man.archlinux.org/search?q=tcptrace
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-hargs[tell me about the programs arguments]'
  '-hxargs[tell me about the module arguments]'
  '-hconfig[tell me about the configuration of this binary]'
  '-houtput[explain what the output means]'
  '-hfilter[output filtering help]'
  '-hhints[usage hints]'
  '*:filename:_files'
)

_arguments -s -S $arguments
