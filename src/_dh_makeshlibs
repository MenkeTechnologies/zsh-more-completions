#compdef dh_makeshlibs


local -a arguments

arguments=(
    {--mmajor,--major}'[specify major version number]'
    {-V,--Vdependencies}'':4
    {--version-info,--version-info}'[If a shlibs file is generated by this program, this option controls what vers]'
    '--VUpstream-Version:4'
    '--VNone:4'
    '--Vpackage-relation:4'
    {-n,--no-scripts}'':4
    {--Xitem,--exclude}'[exclude items from processing]'
    '--add-udeb:4'
    '--no-add-udeb:4'
    '*:filename:_files'
)
_arguments -s -S $arguments
