#compdef commitlint

# Zsh completion for commitlint - lint commit messages

_arguments -s -S \
  '(-e --edit)'{-e,--edit}'[read commit message from file]:file:_files' \
  '(-E --env)'{-E,--env}'[check message from environment variable]:variable:' \
  '(-x --extends)'{-x,--extends}'[configuration modules to extend]:modules:' \
  '(-g --config)'{-g,--config}'[path to configuration file]:file:_files -g "*.js *.json *.yaml *.yml *.ts *.cjs *.mjs"' \
  '--print-config[print resolved configuration]' \
  '(-d --cwd)'{-d,--cwd}'[set working directory]:directory:_files -/' \
  '(-f --from)'{-f,--from}'[lower end of commit range]:commit ref:' \
  '(-t --to)'{-t,--to}'[upper end of commit range]:commit ref:' \
  '--last[lint the last commit only]' \
  '(-o --format)'{-o,--format}'[output formatter]:formatter:' \
  '(-p --parser-preset)'{-p,--parser-preset}'[parser preset module]:preset:' \
  '(-H --help-url)'{-H,--help-url}'[help URL for commit format]:url:' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-V --verbose)'{-V,--verbose}'[enable verbose output]' \
  '--color[enable/disable color output]' \
  '--no-color[disable color output]' \
  '--strict[enable strict mode]' \
  '(-s --stdin)'{-s,--stdin}'[read from stdin]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-v --version)'{-v,--version}'[display version]' && return 0
