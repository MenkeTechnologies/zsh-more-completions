#compdef watch

# Zsh completion for watch - execute a program periodically

_watch() {
  local -a arguments

  arguments=(
    '(-b --beep)'{-b,--beep}'[beep if command has a non-zero exit]'
    '(-c --color)'{-c,--color}'[interpret ANSI color and style sequences]'
    '(-C --no-color)'{-C,--no-color}'[do not interpret ANSI color and style sequences]'
    '(-d --differences)'{-d,--differences}'=[highlight changes between updates]::mode:(permanent)'
    '(-e --errexit)'{-e,--errexit}'[exit if command has a non-zero exit]'
    '(-f --follow)'{-f,--follow}'[follow the output and do not clear screen]'
    '(-g --chgexit)'{-g,--chgexit}'[exit when output from command changes]'
    '(-q --equexit)'{-q,--equexit}'[exit when output from command does not change]:cycles:'
    '(-n --interval)'{-n,--interval}'[seconds to wait between updates]:seconds:'
    '(-p --precise)'{-p,--precise}'[attempt run command in precise intervals]'
    '(-r --no-rerun)'{-r,--no-rerun}'[do not rerun program on window resize]'
    '(-s --shotsdir)'{-s,--shotsdir}'[directory to store screenshots]:directory:_directories'
    '(-t --no-title)'{-t,--no-title}'[turn off header]'
    '(-w --no-wrap)'{-w,--no-wrap}'[turn off line wrapping]'
    '(-x --exec)'{-x,--exec}'[pass command to exec instead of "sh -c"]'
    '(- *)'{-h,--help}'[display help and exit]'
    '(- *)'{-v,--version}'[output version information and exit]'
    '*:command:_cmdstring'
  )

  _arguments -s -S $arguments
}

_watch "$@"
