#compdef rancher

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'login:log in to a Rancher server'
      'server:manage Rancher server'
      'context:switch context'
      'cluster:manage clusters'
      'node:manage nodes'
      'project:manage projects'
      'app:manage apps'
      'catalog:manage catalogs'
      'globaldns:manage global DNS entries'
      'inspect:inspect resources'
      'kubectl:run kubectl commands'
      'machines:manage machines'
      'multiclusterapp:manage multi-cluster apps'
      'namespace:manage namespaces'
      'ps:show workloads'
      'settings:manage settings'
      'ssh:SSH to a node'
      'token:manage tokens'
      'up:apply compose config'
      'wait:wait for resource condition'
      'help:show help'
    )
    _describe -t commands 'rancher command' commands && ret=0
    ;;
  args)
    case $words[1] in
      login)
        _arguments -s -S \
          {-t,--token}'=[bearer token]:token' \
          '--context=[context]:context' \
          '--cacerts=[CA certs file]:cacerts:_files' \
          '--name=[server name]:name' \
          '1:server URL' \
          && ret=0
        ;;
      cluster)
        _arguments -s -S -C \
          '1:subcommand:(ls create delete import export kf)' \
          && ret=0
        ;;
      project)
        _arguments -s -S -C \
          '1:subcommand:(ls create delete)' \
          && ret=0
        ;;
      namespace)
        _arguments -s -S -C \
          '1:subcommand:(ls create delete move)' \
          && ret=0
        ;;
      app)
        _arguments -s -S -C \
          '1:subcommand:(ls install upgrade delete rollback show-notes show-app)' \
          && ret=0
        ;;
      catalog)
        _arguments -s -S -C \
          '1:subcommand:(ls add delete refresh)' \
          && ret=0
        ;;
      ssh)
        _arguments -s -S \
          '1:node' \
          && ret=0
        ;;
      kubectl)
        _arguments -s -S \
          '*:kubectl args' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
