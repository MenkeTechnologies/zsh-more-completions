#compdef p7content
# Documentation: https://man.archlinux.org/search?q=p7content
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-d[key/Cert database directory (default is ~/.netscape)]'
  '-i[define an input file to use (default is stdin)]'
  '-o[define an output file to use (default is stdout)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
