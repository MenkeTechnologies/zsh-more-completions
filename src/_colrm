#compdef colrm
# Documentation: https://man.archlinux.org/search?q=colrm
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-V,--version}'[output version information and exit]'
  '(- * :)'{-h,--help}'[display this help and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
