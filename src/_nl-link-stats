#compdef nl-link-stats
# Documentation: https://man.archlinux.org/search?q=nl-link-stats
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-l,--list}'[list available statistic names]'
  '(- * :)'{-h,--help}'[show this help]'
  {-v,--version}'[show versioning information]'
  {-n,--name}'[link name]'
  {-i,--index}'[interface index]'
  '*:filename:_files'
)

_arguments -s -S $arguments
