#compdef xplico

local -a arguments

arguments=(
  '-v[verbose output]'
  '-c[configuration file]:file:_files'
  '-h[show help]'
  '-i[info of protocol]:protocol:'
  '-g[graph-tree of protocols]'
  '-l[show all log on screen]'
  '-s[show every second the decoding status]'
  '-m[module type]:module:'
  '*:filename:_files'
)

_arguments -s -S $arguments
