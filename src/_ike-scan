#compdef ike-scan

local -a arguments

arguments=(
  {--help,-h}'[display this usage message and exit.]'
  {--file,-f}'[read hostnames or addresses from the specified file]:file:_files'
  {--sport,-s}'[set UDP source port, default=500, 0=random]:port'
  {--dport,-d}'[set UDP destination port, default=500]:port'
  {--retry,-r}'[set total number of attempts per host]:count'
  {--timeout,-t}'[set initial per host timeout in ms, default=500]:ms'
  {--bandwidth,-B}'[set desired outbound bandwidth, default=56000]:bps'
  {--interval,-i}'[set minimum packet interval in ms]:ms'
  {--backoff,-b}'[set timeout backoff factor, default=1.50]:factor'
  {--verbose,-v}'[display verbose progress messages.]'
  {--quiet,-q}'[do not decode the returned packet.]'
  {--multiline,-M}'[split the payload decode across multiple lines.]'
  {--lifetime,-l}'[set IKE lifetime in seconds, default=28800]:seconds'
  {--lifesize,-z}'[set IKE lifesize in Kilobytes, default=0]:kilobytes'
  {--auth,-m}'[set auth method, default=1 (PSK)]:method'
  {--version,-V}'[display program version and exit.]'
  {--vendor,-e}'[set vendor id string to hex value]:hex'
  {--trans,-a}'[use custom transform instead of default set]:transform'
  {--showbackoff,-o}'[display the backoff fingerprint table]'
  {--fuzz,-u}'[set pattern matching fuzz in ms, default=500]:ms'
  {--patterns,-p}'[use IKE backoff patterns file]:file:_files'
  {--vidpatterns,-I}'[use Vendor ID patterns file]:file:_files'
  {--aggressive,-A}'[use IKE Aggressive Mode (The default is Main Mode)]'
  {--id,-n}'[use specified identification value]:id'
  {--idtype,-y}'[use identification type, default 3 (ID_USER_FQDN)]:type'
  {--dhgroup,-g}'[use Diffie Hellman Group, default 2]:group'
  {--gssid,-G}'[use GSS ID (hex string)]:hex'
  {--random,-R}'[randomise the host list.]'
  {--tcp,-T}'[use TCP transport instead of UDP]'
  {--tcptimeout,-O}'[set TCP connect timeout in seconds, default=10]:seconds'
  {--pskcrack,-P}'[crack aggressive mode pre-shared keys]:file:_files'
  {--nodns,-N}'[do not use DNS to resolve names.]'
  {--noncelen,-c}'[set the nonce length in bytes, default=20]:bytes'
  {--headerlen,-L}'[set the length in the ISAKMP header in bytes]:bytes'
  {--mbz,-Z}'[use value for reserved (MBZ) fields, default=0]:value'
  {--headerver,-E}'[specify the ISAKMP header version]:version'
  {--certreq,-C}'[add the CertificateRequest payload]:cert'
  {--doi,-D}'[set the SA DOI, default 1 (IPsec)]:doi'
  {--situation,-S}'[set the SA Situation, default 1]:situation'
  {--protocol,-j}'[set the Proposal protocol ID, default 1]:protocol'
  {--transid,-k}'[set the Transform ID, default 1]:id'
  '--spisize[set the proposal SPI size, default=0]:size'
  '--hdrflags[set the ISAKMP header flags, default=0]:flags'
  '--hdrmsgid[set the ISAKMP header message ID, default=0]:id'
  '--cookie[set the ISAKMP initiator cookie]:cookie'
  '--exchange[set the exchange type]:type'
  '--nextpayload[set the next payload in the ISAKMP header]:payload'
  '--randomseed[seed the pseudo random number generator]:seed'
  '--timestamp[display timestamps for received packets.]'
  '--sourceip[set source IP address for outgoing packets]:ip'
  '--shownum[display the host number for received packets.]'
  '--nat-t[use RFC 3947 NAT-Traversal encapsulation.]'
  '--rcookie[set the ISAKMP responder cookie]:cookie'
  {--ikev2,-2}'[use IKE version 2]'
  '*:filename:_files'
)

_arguments -s -S $arguments
