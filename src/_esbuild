#compdef esbuild

# Zsh completion for esbuild - JavaScript bundler and minifier

_arguments \
  '(-)--help[display help information]' \
  '(-)--version[display version information]' \
  '--bundle[bundle all dependencies into output]' \
  '--outfile[set output file]:file:_files' \
  '--outdir[set output directory]:directory:_directories' \
  '--outbase[set output base directory]:directory:_directories' \
  '--sourcemap=-[generate source maps]::type:(linked external inline both)' \
  '--minify[enable all minification]' \
  '--minify-syntax[minify syntax]' \
  '--minify-whitespace[minify whitespace]' \
  '--minify-identifiers[minify identifiers]' \
  '--target[set language target]:target:(es2015 es2016 es2017 es2018 es2019 es2020 es2021 es2022 esnext chrome firefox safari edge node)' \
  '--platform[set platform]:platform:(browser node neutral)' \
  '--format[set output format]:format:(iife cjs esm)' \
  '--splitting[enable code splitting]' \
  '--serve[start a local dev server]' \
  '--watch[watch for file changes and rebuild]' \
  '--analyze[analyze the bundle]' \
  '--metafile[write metadata to file]:file:_files' \
  '*--entry-names[set entry point output template]:template' \
  '*--chunk-names[set chunk output template]:template' \
  '*--asset-names[set asset output template]:template' \
  '*--loader[set loader for file extension]:.ext=type' \
  '--resolve-extensions[set resolve extensions]:.ext list' \
  '*--main-fields[set main fields]:field' \
  '*--conditions[set conditions]:condition' \
  '*--external[mark package as external]:package' \
  '*--alias[set package alias]:old=new' \
  '*--inject[inject file into all modules]:file:_files' \
  '*--define[define global constant]:key=value' \
  '*--pure[mark function as pure]:function name' \
  '--keep-names[preserve function and class names]' \
  '--tree-shaking[set tree shaking mode]:mode:(true false)' \
  '--ignore-annotations[ignore side-effect annotations]' \
  '*--drop[drop specified code]:type:(debugger console)' \
  '*--drop-labels[drop labeled statements]:label' \
  '--legal-comments[set legal comments handling]:mode:(none inline eof linked external)' \
  '--charset[set output charset]:charset:(utf8 ascii)' \
  '--jsx[set JSX transform mode]:mode:(transform preserve automatic)' \
  '--jsx-factory[set JSX factory function]:function' \
  '--jsx-fragment[set JSX fragment function]:function' \
  '--jsx-import-source[set JSX import source]:package' \
  '--jsx-dev[enable JSX dev mode]' \
  '--jsx-side-effects[preserve JSX side effects]' \
  '--tsconfig[set tsconfig file]:file:_files' \
  '--tsconfig-raw[set raw tsconfig JSON]:json' \
  '--packages[set package handling]:mode:(bundle external)' \
  '*--banner[add banner text]:type=text' \
  '*--footer[add footer text]:type=text' \
  '--global-name[set global name for IIFE]:name' \
  '--public-path[set public path]:path' \
  '--stdin[read from stdin]' \
  '--color[enable/disable colored output]:enabled:(true false)' \
  '--log-level[set log level]:level:(verbose debug info warning error silent)' \
  '--log-limit[set maximum log message count]:count' \
  '*--log-override[override log level for message]:id=level' \
  '*--supported[override feature support]:feature=bool' \
  '--allow-overwrite[allow overwriting input files]' \
  '*--out-extension[set output file extension]:.ext=.newext' \
  '--line-limit[set max line length]:length' \
  '--mangle-props[mangle matching property names]:regex' \
  '--reserve-props[reserve matching property names]:regex' \
  '--mangle-quoted[mangle quoted properties]:mode:(true false)' \
  '--mangle-cache[set mangle cache file]:file:_files' \
  '*:entry points:_files'
