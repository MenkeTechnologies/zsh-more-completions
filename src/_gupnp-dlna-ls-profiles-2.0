#compdef gupnp-dlna-ls-profiles-2.0
# Documentation: https://man.archlinux.org/search?q=gupnp-dlna-ls-profiles-2.0
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  {-r,--relaxed}'[read profiles in relaxed mode]'
  '*:filename:_files'
)

_arguments -s -S $arguments
