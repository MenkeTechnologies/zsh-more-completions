#compdef fbstat
# Documentation: https://man.archlinux.org/search?q=fbstat
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-a[analyze data and index pages]'
  '-d[analyze data pages]'
  '-e[analyze database encryption]'
  '-h[analyze header page ONLY]'
  '-i[analyze index leaf pages]'
  '-s[analyze system relations in addition to user tables]'
  '-u[username]:username:'
  '-p[password]:password:'
  '-fetch[fetch password from file]:file:_files'
  '-r[analyze average record and version length]'
  '-t[analyze specific tables (case sensitive)]:tablename:'
  '-role[SQL role name]:role:'
  '-z[display version number]'
  '*:filename:_files'
)

_arguments -s -S $arguments
