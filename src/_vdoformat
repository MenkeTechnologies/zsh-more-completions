#compdef vdoformat

local -a arguments

arguments=(
  '--force[format the block device, even if there is already a VDO volume on it]'
  '--help[print this help message and exit.]'
  '--logical-size[set the logical (provisioned) size of the VDO device]:size:'
  '--physical-size[set the physical size of the VDO device]:size:'
  '--slab-bits[specify the slab size in bits (max 23)]:bits:'
  '--uds-checkpoint-frequency[specify the frequency of checkpoints. The default is never.]'
  '--uds-memory-size[specify the amount of memory, in gigabytes, to devote to the index]:size:'
  '--uds-sparse[specify whether or not to use a sparse index.]'
  '--verbose[describe what is being formatted and with what parameters.]'
  '--version[show the version of vdoformat.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
