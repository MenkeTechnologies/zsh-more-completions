#compdef tempfile

local -a arguments

arguments=(
  {-d,--directory}'[place temporary file in DIR]:directory:_directories'
  {-m,--mode}'[open with MODE instead of 0600]:mode:'
  {-n,--name}'[use FILE instead of tempnam(3)]:file:_files'
  {-p,--prefix}'[set temporary files prefix to STRING]:prefix:'
  {-s,--suffix}'[set temporary files suffix to STRING]:suffix:'
  '--help[display this help and exit]'
  '--version[output version information and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
