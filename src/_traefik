#compdef traefik

# Zsh completion for traefik (Cloud-native reverse proxy)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-c --configFile)'{-c,--configFile}'[configuration file path]:file:_files' \
  '--configfile[configuration file path]:file:_files' \
  '--accesslog[enable access log]' \
  '--accesslog.filepath[access log file path]:file:_files' \
  '--accesslog.format[access log format]:format:(common json)' \
  '--accesslog.bufferingsize[number of access log lines to buffer]:size:' \
  '--api[enable API/dashboard]' \
  '--api.dashboard[activate dashboard]' \
  '--api.insecure[activate API on the entrypoint named traefik]' \
  '--api.debug[enable debug mode for API]' \
  '--certificatesresolvers.*.acme.email[email address for registration]:email:' \
  '--certificatesresolvers.*.acme.storage[storage path for certificates]:file:_files' \
  '--certificatesresolvers.*.acme.httpchallenge[activate HTTP-01 challenge]' \
  '--certificatesresolvers.*.acme.tlschallenge[activate TLS-ALPN-01 challenge]' \
  '--certificatesresolvers.*.acme.dnschallenge[activate DNS-01 challenge]' \
  '--entrypoints.*.address[entrypoint address]:address:' \
  '--global.checknewversion[periodically check if a new version has been released]' \
  '--global.sendanonymoususage[periodically send anonymous usage statistics]' \
  '--log[enable log]' \
  '--log.filepath[log file path]:file:_files' \
  '--log.format[log format]:format:(common json)' \
  '--log.level[log level]:level:(DEBUG PANIC FATAL ERROR WARN INFO)' \
  '--metrics.prometheus[enable Prometheus metrics]' \
  '--metrics.prometheus.addentrypointslabels[add entrypoint labels]' \
  '--metrics.prometheus.addrouterslabels[add router labels]' \
  '--metrics.prometheus.addserviceslabels[add service labels]' \
  '--metrics.prometheus.buckets[buckets for latency metrics]:buckets:' \
  '--metrics.prometheus.entrypoint[entrypoint for Prometheus]:entrypoint:' \
  '--ping[enable ping]' \
  '--ping.entrypoint[entrypoint for ping]:entrypoint:' \
  '--providers.docker[enable Docker provider]' \
  '--providers.docker.endpoint[Docker server endpoint]:endpoint:' \
  '--providers.docker.exposedbydefault[expose containers by default]' \
  '--providers.docker.network[default Docker network to use]:network:' \
  '--providers.docker.swarmmode[activate Docker Swarm Mode]' \
  '--providers.docker.watch[watch Docker events]' \
  '--providers.file.directory[load dynamic configuration from a directory]:dir:_directories' \
  '--providers.file.filename[load dynamic configuration from a file]:file:_files' \
  '--providers.file.watch[watch file or directory for changes]' \
  '--providers.kubernetescrd[enable Kubernetes CRD provider]' \
  '--providers.kubernetesingress[enable Kubernetes Ingress provider]' \
  '--providers.consulcatalog[enable Consul Catalog provider]' \
  '--serversTransport.insecureSkipVerify[disable SSL certificate verification for backends]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[print version]' && ret=0

return ret
