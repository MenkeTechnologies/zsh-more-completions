#compdef ppdpo
# Documentation: https://man.archlinux.org/search?q=ppdpo
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-D[value Set named variable to value.]'
  '-I[add include directory to search path.]'
  '-v[be verbose.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
