#compdef t1ascii

local -a arguments

arguments=(
  {-l,--line-length}'[set max encrypted line length (default 64).]:length:'
  {-o,--output}'[write output to FILE.]:file:_files'
  {-w,--warnings}'[warn on too-long lines.]'
  '(- * :)'{-h,--help}'[print this message and exit.]'
  '--version[print version number and warranty and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
