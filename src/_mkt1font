#compdef mkt1font
# Documentation: https://man.archlinux.org/search?q=mkt1font
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-n[name the font it is intended to generate. Avoid names]'
  '-d[refer to a font definition file. This file (which could]'
  '-a[refer to the AFM (Adobe Font Metrics) file for the input]'
  '-f[refer to the binary font file (PFB) for the input font.]'
  '-s[optionally give the factor, expressed as a per-thousand]'
  '-c[optionally give two comma-separated numerical values to]'
  '-b[optionally be specified to block the use of predefined]'
  '*:filename:_files'
)

_arguments -s -S $arguments
