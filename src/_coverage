#compdef coverage

# zsh completions for 'coverage'

_coverage() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a global_opts
  global_opts=(
    '(- *)'{-h,--help}'[show help message and exit]'
    '(- *)--version[show version and exit]'
    '--rcfile[specify configuration file]:config file:_files'
    '--debug[debug options, separated by commas]:debug opts:'
  )

  local -a subcommands
  subcommands=(
    'run:run a Python program and measure code execution'
    'report:report coverage stats on modules'
    'html:create an HTML report'
    'xml:create an XML report of coverage results'
    'json:create a JSON report of coverage results'
    'lcov:create an LCOV report of coverage results'
    'annotate:make annotated copies of the source files'
    'erase:erase previously collected coverage data'
    'combine:combine data from multiple coverage files'
    'debug:display information about the internals of coverage.py'
  )

  _arguments -s -S \
    $global_opts \
    '1: :->subcommand' \
    '*:: :->args' && return

  case $state in
    subcommand)
      _describe -t subcommands 'coverage subcommand' subcommands
      ;;
    args)
      case $line[1] in
        run)
          _arguments -s -S \
            '(- *)'{-h,--help}'[show help message and exit]' \
            '--source[a list of packages or directories of code to measure]:source:' \
            '--include[include only files matching these patterns]:pattern:' \
            '--omit[omit files matching these patterns]:pattern:' \
            '--branch[measure branch coverage in addition to statement coverage]' \
            '--concurrency[properly measure code using the given concurrency library]:library:(thread multiprocessing greenlet eventlet gevent)' \
            '--context[the context label to record for this coverage run]:context:' \
            '--data-file[write the collected data to this file]:data file:_files' \
            '(-p --parallel-mode)'{-p,--parallel-mode}'[append the machine name, process id and random number to the data file name]' \
            '--timid[use a simpler but slower trace function]' \
            '--rcfile[specify configuration file]:config file:_files' \
            '(-m)-m[run library module as a script (like python -m)]:module:' \
            '--pylib[measure coverage even inside the Python installed library]' \
            '--append[append to existing data rather than replacing it]' \
            '*:program and arguments:_files' \
            ;;
        report)
          _arguments -s -S \
            '(- *)'{-h,--help}'[show help message and exit]' \
            '(-m --show-missing)'{-m,--show-missing}'[show line numbers of statements in each module that were not executed]' \
            '--skip-covered[skip files with 100% coverage]' \
            '--no-skip-covered[do not skip files with 100% coverage]' \
            '--skip-empty[skip files with no code]' \
            '--include[include only files matching these patterns]:pattern:' \
            '--omit[omit files matching these patterns]:pattern:' \
            '--fail-under[exit with status 2 if coverage is less than this]:minimum:' \
            '--precision[number of digits after the decimal point]:digits:' \
            '--sort[sort the report by the named column]:column:(name stmts miss branch brpart cover)' \
            '--data-file[read the specified coverage data file]:data file:_files' \
            '--rcfile[specify configuration file]:config file:_files' \
            '*:module:_files' \
            ;;
        html)
          _arguments -s -S \
            '(- *)'{-h,--help}'[show help message and exit]' \
            '(-d --directory)'{-d,--directory}'[write the output files to this directory]:directory:_directories' \
            '--title[a text string to use as the title on the HTML]:title:' \
            '--skip-covered[skip files with 100% coverage]' \
            '--no-skip-covered[do not skip files with 100% coverage]' \
            '--skip-empty[skip files with no code]' \
            '--precision[number of digits after the decimal point]:digits:' \
            '--show-contexts[show contexts for each covered line]' \
            '--include[include only files matching these patterns]:pattern:' \
            '--omit[omit files matching these patterns]:pattern:' \
            '--data-file[read the specified coverage data file]:data file:_files' \
            '--rcfile[specify configuration file]:config file:_files' \
            '*:module:_files' \
            ;;
        xml)
          _arguments -s -S \
            '(- *)'{-h,--help}'[show help message and exit]' \
            {-o,--outfile}'[write the XML report to this file]:output file:_files' \
            '--include[include only files matching these patterns]:pattern:' \
            '--omit[omit files matching these patterns]:pattern:' \
            '--data-file[read the specified coverage data file]:data file:_files' \
            '--rcfile[specify configuration file]:config file:_files' \
            '--skip-empty[skip files with no code]' \
            '*:module:_files' \
            ;;
        json)
          _arguments -s -S \
            '(- *)'{-h,--help}'[show help message and exit]' \
            {-o,--outfile}'[write the JSON report to this file]:output file:_files' \
            '--include[include only files matching these patterns]:pattern:' \
            '--omit[omit files matching these patterns]:pattern:' \
            '--data-file[read the specified coverage data file]:data file:_files' \
            '--rcfile[specify configuration file]:config file:_files' \
            '--pretty-print[format the JSON for easy reading]' \
            '--show-contexts[show contexts for each covered line]' \
            '*:module:_files' \
            ;;
        lcov)
          _arguments -s -S \
            '(- *)'{-h,--help}'[show help message and exit]' \
            {-o,--outfile}'[write the LCOV report to this file]:output file:_files' \
            '--include[include only files matching these patterns]:pattern:' \
            '--omit[omit files matching these patterns]:pattern:' \
            '--data-file[read the specified coverage data file]:data file:_files' \
            '--rcfile[specify configuration file]:config file:_files' \
            '*:module:_files' \
            ;;
        annotate)
          _arguments -s -S \
            '(- *)'{-h,--help}'[show help message and exit]' \
            '(-d --directory)'{-d,--directory}'[write the output files to this directory]:directory:_directories' \
            '--include[include only files matching these patterns]:pattern:' \
            '--omit[omit files matching these patterns]:pattern:' \
            '--data-file[read the specified coverage data file]:data file:_files' \
            '--rcfile[specify configuration file]:config file:_files' \
            '*:module:_files' \
            ;;
        erase)
          _arguments -s -S \
            '(- *)'{-h,--help}'[show help message and exit]' \
            '--data-file[the coverage data file to erase]:data file:_files' \
            '--rcfile[specify configuration file]:config file:_files' \
            ;;
        combine)
          _arguments -s -S \
            '(- *)'{-h,--help}'[show help message and exit]' \
            '--keep[keep combined coverage files after combining]' \
            '--data-file[the coverage data file to write combined data to]:data file:_files' \
            '--append[append to existing combined data rather than replacing it]' \
            '--rcfile[specify configuration file]:config file:_files' \
            '*:data files:_files' \
            ;;
        debug)
          _arguments -s -S \
            '(- *)'{-h,--help}'[show help message and exit]' \
            '1:topic:(data sys config premain pybehave)' \
            ;;
      esac
      ;;
  esac
}

_coverage "$@"
