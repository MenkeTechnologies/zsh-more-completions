#compdef fnm

# Zsh completion for fnm (Fast Node Manager)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '--node-dist-mirror=[Mirror URL for node downloads]:url' \
  '--fnm-dir=[The root directory of fnm installations]:dir:_directories' \
  '--multishell-path=[Override the multishell path]:path:_directories' \
  '--log-level=[The log level of fnm commands]:level:(quiet info all error)' \
  '--arch=[Override the architecture]:arch:(x64 x86 arm64 armv7l ppc64le ppc64 s390x)' \
  '--version-file-strategy=[Strategy for resolving the Node version]:strategy:(local recursive)' \
  '--corepack-enabled[Enable corepack integration]' \
  '--resolve-engines[Resolve engines.node field in package.json]' \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'list:List all locally installed Node versions'
      'ls:List all locally installed Node versions'
      'list-remote:List all remote Node versions'
      'ls-remote:List all remote Node versions'
      'install:Install a new Node version'
      'use:Change Node version'
      'env:Print and set up required environment variables'
      'completions:Print shell completions to stdout'
      'alias:Set a version alias'
      'unalias:Remove an alias definition'
      'default:Set a version as the default version'
      'current:Print the current Node version'
      'exec:Run a command within fnm context'
      'uninstall:Uninstall a Node version'
    )
    _describe -t commands 'fnm command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      install)
        _arguments -s -S \
          '--lts[Install the latest LTS version]' \
          '--latest[Install the latest version]' \
          '--progress=[Show installation progress]:progress:(auto always never)' \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:version' && ret=0
        ;;
      use)
        _arguments -s -S \
          '--install-if-missing[Install the version if missing]' \
          '--silent-if-unchanged[Do not print a message if version is unchanged]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:version:->versions' && ret=0
        ;;
      env)
        _arguments -s -S \
          '--shell=[The shell type]:shell:(bash zsh fish powershell)' \
          '--use-on-cd[Print the script to change Node on directory change]' \
          '--json[Print as JSON]' \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
      completions)
        _arguments -s -S \
          '--shell=[The shell type]:shell:(bash zsh fish powershell)' \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
      alias)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:version:->versions' \
          '2:name' && ret=0
        ;;
      unalias)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:alias name' && ret=0
        ;;
      default)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:version:->versions' && ret=0
        ;;
      uninstall)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:version:->versions' && ret=0
        ;;
      exec)
        _arguments -s -S \
          '--using=[Use specified version]:version' \
          '--using-file=[Use version from file]:file:_files' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*::command:_command_names -e' && ret=0
        ;;
      list|ls)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
      list-remote|ls-remote)
        _arguments -s -S \
          '--sort=[Sort order]:sort:(asc desc)' \
          '--lts[Only show LTS versions]' \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
    esac

    if [[ $state == versions ]]; then
      local -a versions
      versions=( ${(f)"$(fnm list 2>/dev/null | sed 's/\* //;s/ .*//;s/^v//')"} )
      _describe -t versions 'node version' versions && ret=0
    fi
    ;;
esac

return ret
