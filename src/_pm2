#compdef pm2

# Zsh completion for pm2 (Node.js process manager)

_pm2() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    local -a commands=(
        'start:start and daemonize an app'
        'stop:stop a process'
        'restart:restart a process'
        'delete:stop and delete a process from pm2 list'
        {list,ls,status}':list all processes'
        {show,describe}':describe all parameters of a process'
        'logs:stream logs file'
        'flush:flush logs'
        'reloadLogs:reload all logs'
        'startup:setup script for pm2 at boot'
        'unstartup:disable and remove startup script'
        {save,dump}':dump all processes for resurrecting them later'
        'resurrect:resurrect previously dumped processes'
        'update:update in-memory pm2'
        {ecosystem,init}':generate a process conf file'
        'monit:launch termcaps monitoring'
        'plus:enable pm2 plus'
        'deploy:deploy your json'
        'sendSignal:send a system signal to the target process'
        'ping:ping pm2 daemon'
        'reset:reset counters for process'
        'install:install a module'
        'uninstall:uninstall a module'
        'package:check and create a package'
        'publish:publish the current module'
        'set:sets the specified config'
        'multiset:set multiple configs'
        'get:get value for specified key'
        'conf:get / set pm2 configuration values'
        'config:get / set pm2 configuration values'
        'unset:clear the specified config'
        'report:give a full pm2 report for https://github.com/Unitech/pm2/issues'
        'link:link to pm2 plus'
        'unlink:unlink from pm2 plus'
        'monitor:monitor a process'
        'unmonitor:unmonitor a process'
        'open:open dashboard in browser'
        'register:create an account on pm2 plus'
        'login:login to pm2 plus'
        'web:launch a health API on specified port'
        'env:display environment of a process'
        'kill:kill the pm2 daemon'
        'pull:updates repository for a given app'
        'forward:updates repository to the next commit for a given app'
        'backward:downgrades repository to the previous commit for a given app'
        'deepUpdate:performs a deep update of pm2'
        'serve:serve a directory over HTTP via a port'
        'autoinstall:auto install'
        'id:get process id by name'
        'prettylist:print json in a prettified JSON'
        'jlist:list all processes in JSON format'
        'sysmonit:display system monitor'
        'sysinfos:display system infos in JSON'
        'iprobe:internal probe'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[output usage information]' \
        '(- *)'{-v,--version}'[output version number]' \
        '--no-daemon[run pm2 daemon in the foreground]' \
        '--mini-list[display a compacted list without formatting]' \
        '-s --silent[hide all messages]' \
        '1:command:->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'pm2 command' commands
            ;;
        args)
            case $words[1] in
                start)
                    _arguments -s -S \
                        '--name=[set a name for the process]:name:' \
                        '--script=[path to the script]:script:_files' \
                        '(-i --instances)'{-i,--instances}'=[number of instances]:instances:' \
                        '--exec-mode=[set the execution mode]:mode:(fork cluster)' \
                        '(-w --watch)'{-w,--watch}'[watch folder for changes]' \
                        '*--ignore-watch=[list of paths to ignore]:pattern:' \
                        '--max-memory-restart=[restart when memory exceeds this size]:size:' \
                        '--env=[specify environment to get specific variables from ecosystem file]:env name:' \
                        '--log=[specify log file]:log file:_files' \
                        '(-o --output)'{-o,--output}'=[specify out log file]:output file:_files' \
                        '(-e --error)'{-e,--error}'=[specify error log file]:error file:_files' \
                        '--log-date-format=[add custom prefix timestamp to logs]:format:' \
                        '--pid=[specify pid file]:pid file:_files' \
                        '--cron=[a cron pattern for restart]:cron pattern:' \
                        '--no-daemon[run pm2 daemon in the foreground]' \
                        '--interpreter=[set a specific interpreter]:interpreter:' \
                        '--interpreter-args=[set arguments to pass to the interpreter]:args:' \
                        '--node-args=[space delimited arguments to pass to node]:args:' \
                        '--cwd=[set the current working directory]:directory:_directories' \
                        '(-f --force)'{-f,--force}'[force actions]' \
                        '--no-autorestart[do not automatically restart]' \
                        '--no-treekill[only kill the main process, not detached children]' \
                        '--no-vizion[start without vizion features (versioning control)]' \
                        '--no-pmx[start without pmx]' \
                        '--time[enable time logging]' \
                        '--wait-ready[ask pm2 to wait for ready event from your app]' \
                        '--listen-timeout=[time in ms to wait for the ready event]:ms:' \
                        '--merge-logs[merge logs from different instances but keep error and out separated]' \
                        '*:script or config:_files'
                    ;;
                stop|restart|delete|reset|describe|show|monitor|unmonitor|env)
                    _arguments -s -S \
                        '1:process (name or id):->process'
                    ;;
                logs)
                    _arguments -s -S \
                        '--json[json log output]' \
                        '--format[formatted log output]' \
                        '--raw[raw output]' \
                        '--err[only show error output]' \
                        '--out[only show standard output]' \
                        '--lines=[number of lines to output]:lines:' \
                        '--timestamp=[add timestamps]:format:' \
                        '--nostream[print logs and exit]' \
                        '--highlight=[highlight a string in logs]:string:' \
                        '1:process (name or id):->process'
                    ;;
                deploy)
                    _arguments -s -S \
                        '1:config file:_files' \
                        '2:environment:'
                    ;;
                sendSignal)
                    _arguments -s -S \
                        '1:signal:(SIGTERM SIGKILL SIGINT SIGHUP SIGUSR1 SIGUSR2 SIGSTOP SIGCONT)' \
                        '2:process (name or id):->process'
                    ;;
                install)
                    _arguments -s -S '1:module name:'
                    ;;
                uninstall)
                    _arguments -s -S '1:module name:'
                    ;;
                set|get|unset)
                    _arguments -s -S '1:key:' '2:value:'
                    ;;
                web)
                    _arguments -s -S '--port=[specify port]:port:'
                    ;;
                serve)
                    _arguments -s -S \
                        '--port=[specify port]:port:' \
                        '--spa[redirect all queries to index.html]' \
                        '1:directory:_directories'
                    ;;
                startup)
                    _arguments -s -S '1:platform:(systemd upstart launchd rcd systemv)'
                    ;;
                pull)
                    _arguments -s -S '1:process (name or id):->process'
                    ;;
                ecosystem|init)
                    _arguments -s -S '--simple[generate a simple ecosystem file]'
                    ;;
                link|plus)
                    _arguments -s -S \
                        '1:secret key:' \
                        '2:public key:' \
                        '3:machine name:'
                    ;;
                save|dump)
                    _arguments -s -S '--force[force dump even if empty process list]'
                    ;;
            esac

            case $state in
                process)
                    local -a processes
                    processes=(${(f)"$(pm2 jlist 2>/dev/null | python3 -c 'import sys,json; [print(p["name"]+":"+p.get("pm2_env",{}).get("status","")) for p in json.load(sys.stdin)]' 2>/dev/null)"})
                    if (( ${#processes} )); then
                        _describe -t processes 'process' processes
                    else
                        _message 'process name or id'
                    fi
                    ;;
            esac
            ;;
    esac
}

_pm2 "$@"
