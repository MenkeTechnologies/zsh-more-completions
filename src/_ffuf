#compdef ffuf

# Zsh completion for ffuf - fast web fuzzer

_arguments -s -S \
  '-u[target URL]:URL:' \
  '-w[wordlist and optional keyword]:wordlist\:keyword:_files' \
  '-c[colorize output]' \
  '-v[verbose output, printing full URL and redirect location]' \
  '-s[silent mode - no output except errors]' \
  '-p[seconds of delay between requests]:delay:' \
  '-t[number of concurrent threads]:threads:' \
  '-timeout[HTTP request timeout in seconds]:seconds:' \
  '-H[header]:header:' \
  '-b[cookie data]:cookie:' \
  '-d[POST data]:data:' \
  '-r[follow redirects]' \
  '-recursion[enable recursive fuzzing]' \
  '-recursion-depth[maximum depth for recursive fuzzing]:depth:' \
  '-recursion-strategy[recursion strategy]:strategy:(default greedy)' \
  '-replay-proxy[replay matched requests to this proxy]:URL:' \
  '-x[proxy URL]:URL:' \
  '-e[comma-separated list of extensions]:extensions:' \
  '-fc[filter HTTP status codes]:codes:' \
  '-fl[filter by number of lines]:lines:' \
  '-fr[filter regexp]:regexp:' \
  '-fs[filter HTTP response size]:size:' \
  '-ft[filter by number of words]:words:' \
  '-fw[filter by number of words]:words:' \
  '-mc[match HTTP status codes]:codes:(200 201 204 301 302 307 401 403 405 500)' \
  '-ml[match number of lines in response]:lines:' \
  '-mr[match regexp]:regexp:' \
  '-ms[match HTTP response size]:size:' \
  '-mt[match amount of milliseconds to first response byte]:milliseconds:' \
  '-mw[match number of words in response]:words:' \
  '-mode[multi-wordlist mode]:mode:(clusterbomb pitchfork sniper)' \
  '-rate[rate of requests per second]:rate:' \
  '-maxtime[maximum running time in seconds]:seconds:' \
  '-maxtime-job[maximum running time for a single job]:seconds:' \
  '-o[output file path]:file:_files' \
  '-od[output directory path for files]:dir:_files -/' \
  '-of[output file format]:format:(json ejson html csv ecsv md)' \
  '-ic[ignore comments in wordlist]' \
  '-input-cmd[use the output of a command as input]:cmd:' \
  '-input-num[number of inputs to generate for command fuzzing]:N:' \
  '-input-shell[shell to use for running input command]:shell:' \
  '-request[file containing the raw HTTP request]:file:_files' \
  '-request-proto[protocol for the raw request]:proto:(http https)' \
  '-json[use JSON output]' \
  '-noninteractive[disable interactive console]' \
  '-scraperfile[custom scraper file]:file:_files' \
  '-scrapers[active scrapers]:scrapers:' \
  '-se[stop on spurious errors]' \
  '-sf[stop after the first found match]' \
  '-sa[stop on all error cases]' \
  '-ac[automatically calibrate filtering options]' \
  '-acc[custom auto-calibration strings]:strings:' \
  '-ach[auto-calibrate against each host]' \
  '-ack[keyword for auto-calibration]:keyword:' \
  '-acs[auto-calibration strategy]:strategy:(basic advanced)' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]'
