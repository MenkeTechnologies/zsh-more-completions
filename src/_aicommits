#compdef aicommits

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'config:manage configuration'
  'hook:manage git hooks'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--all[stage all changes before generating commit message]' \
  '-a[stage all changes before generating commit message]' \
  '--generate=[number of messages to generate]:count' \
  '-g+[number of messages to generate]:count' \
  '--exclude=[files to exclude from diff]:files' \
  '-x+[files to exclude from diff]:files' \
  '--type=[type of commit message]:type:(conventional)' \
  '-t+[type of commit message]:type:(conventional)' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'aicommits command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (config)
        local -a config_cmds=(
          'get:get a config value'
          'set:set a config value'
        )
        _arguments \
          '1:subcommand:_describe -t config-commands "config command" config_cmds' \
          '2:key:(OPENAI_KEY generate type proxy model timeout max-length locale)' \
          '3:value' && ret=0
        ;;
      (hook)
        local -a hook_cmds=(
          'install:install git hook'
          'uninstall:uninstall git hook'
        )
        _arguments \
          '1:subcommand:_describe -t hook-commands "hook command" hook_cmds' && ret=0
        ;;
    esac
    ;;
esac

return ret
