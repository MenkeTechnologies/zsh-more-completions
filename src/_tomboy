#compdef tomboy

local -a arguments

arguments=(
  '--version[print version information.]'
  '--help[print this usage message.]'
  '--note-path[load/store note data in this directory.]'
  '--search[open the search all notes window with the search text.]'
  '--new-note[create and display a new note, optionally with a title]:title:'
  '--open-note[display the existing note matching title or URL]:title or url:'
  '--start-here[display the Start Here note]'
  '--highlight-search[search and highlight text in the opened note]:text:'
  '--addin[run an addin command]:addin:'
  '*:filename:_files'
)

_arguments -s -S $arguments
