#compdef bmpblk_utility
# Documentation: https://man.archlinux.org/search?q=bmpblk_utility
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-z[compression algorithm to use]'
  '-y[display as yaml]'
  '-d[directory to use (default .)]'
  '-f[force overwriting existing files]'
  '*:filename:_files'
)

_arguments -s -S $arguments
