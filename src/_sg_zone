#compdef sg_zone
# Documentation: https://man.archlinux.org/search?q=sg_zone
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {--all,-a}'[sets the ALL flag in the cdb]'
  {--close,-c}'[issue CLOSE ZONE command]'
  {--finish,-f}'[issue FINISH ZONE command]'
  {--help,-h}'[print out usage message]'
  {--open,-o}'[issue OPEN ZONE command]'
  {--verbose,-v}'[increase verbosity]'
  {--version,-V}'[print version string and exit]'
  '--zone[ID is the starting LBA of the zone (def: 0)]:id'
  '*:filename:_files'
)

_arguments -s -S $arguments
