#compdef umount.nfs4
# Documentation: https://man.archlinux.org/search?q=umount.nfs4
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-f[force unmount]'
  '-v[verbose]'
  '-n[do not update /etc/mtab]'
  '-r[remount]'
  '-l[lazy unmount]'
  '-h[print this help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
