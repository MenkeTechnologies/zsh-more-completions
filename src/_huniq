#compdef huniq

# Zsh completion for huniq - filter unique lines (hash-based)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --count)'{-c,--count}'[prefix lines with occurrence count]' \
  '(-d --repeated)'{-d,--repeated}'[only print duplicate lines]' \
  '(-w --max-width)'{-w,--max-width}'[maximum number of bytes to consider]:bytes:' \
  '(-0 --null)'{-0,--null}'[use null byte as line delimiter]' \
  '--help[show help]' \
  '--version[show version]' \
  '*:file:_files' && ret=0

return ret
