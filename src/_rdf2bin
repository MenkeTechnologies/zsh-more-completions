#compdef rdf2bin
# Documentation: https://man.archlinux.org/search?q=rdf2bin
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-o[specify the relocation origin]'
  '-p[specify minimum segment alignment]'
  '-f[select format (bin, com, ith, srec)]'
  '-q[run quiet]'
  '-v[run verbose]'
  '*:filename:_files'
)

_arguments -s -S $arguments
