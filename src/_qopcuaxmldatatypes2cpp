#compdef qopcuaxmldatatypes2cpp
# Documentation: https://man.archlinux.org/search?q=qopcuaxmldatatypes2cpp
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[displays help on commandline options.]'
  '--help-all[displays help, including generic Qt options.]'
  {-v,--version}'[displays version information.]'
  {-i,--input}'[a primary input file. Will generate code for all types]'
  {-d,--dependencyinput}'[a dependency input file. Only types required by primary inputs are used]'
  {-o,--output}'[output directory for the generated C++ files.]'
  {-p,--prefix}'[prefix for the generated files, default is]'
  '*:filename:_files'
)

_arguments -s -S $arguments
