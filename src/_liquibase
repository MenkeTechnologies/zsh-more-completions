#compdef liquibase

local -a arguments

arguments=(
  '--always-override-stored-logic-schema[always override stored logic schema]'
  '--auto-reorg[should Liquibase automatically include REORG TABLE]'
  '--changelog-lock-poll-rate[changelog lock poll rate in seconds]:seconds:'
  '--changelog-lock-wait-time-in-minutes[changelog lock wait time in minutes]:minutes:'
  '--classpath[additional classpath entries to use]:classpath:'
  '--convert-data-types[convert data types]'
  '--database-changelog-lock-table-name[name of the changelog lock table]:name:'
  '--database-changelog-table-name[name of the changelog table]:name:'
  '--database-class[class to use for Database implementation]:class:'
  '--defaultlogger-level[default logger level]:level:'
  '--defaults-file[file with default Liquibase properties]:file:_files'
  '--diff-column-order[diff column order]'
  '--driver[database driver class]:class:'
  '--driver-properties-file[driver properties file]:file:_files'
  '--filter-log-messages[filter log messages]'
  '--generate-changeset-created-values[generate changeset created values]'
  '--generated-changeset-ids-contains-description[generated changeset IDs contain description]'
  {-h,--help}'[show this help message and exit]'
  '--headless[force liquibase to think it has no access to a terminal]'
  '--hub-api-key[liquibase Hub API key for operations]:key:'
  '--hub-log-level[log level for filtering log messages to send to Hub]:level:'
  '--hub-mode[content to send to Liquibase Hub during operations]:mode:'
  '--hub-url[liquibase Hub URL for operations]:url:'
  '--include-catalog-in-specification[include catalog in specification]'
  '--include-system-classpath[include system classpath]'
  '--liquibase-catalog-name[Liquibase catalog name]:name:'
  '--liquibase-schema-name[Liquibase schema name]:name:'
  '--liquibase-tablespace-name[Liquibase tablespace name]:name:'
  '--log-file[log file path]:file:_files'
  '--log-level[controls which logs get set to stderr]:level:'
  '--output-file[output file path]:file:_files'
  '--output-file-encoding[output file encoding]:encoding:'
  '--output-line-separator[output line separator]:separator:'
  '--pro-license-key[Liquibase Pro license key]:key:'
  '--pro-mark-unused-not-drop[mark unused objects instead of dropping]'
  '--pro-sql-inline[generate changeSets with SQL-based changes inline]'
  '--pro-synonyms-drop-public[drop public synonyms]'
  '--prompt-for-non-local-database[prompt for non-local database]'
  '--property-provider-class[property provider class]:class:'
  '--should-run[should Liquibase commands execute]'
  '--should-snapshot-data[should snapshot data]'
  '--sqlplus-args[extra arguments to pass to sqlplus]:args:'
  '--sqlplus-keep-temp[keep temporary sqlplus files]'
  '--sqlplus-keep-temp-name[name for temporary sqlplus files]:name:'
  '--sqlplus-keep-temp-overwrite[overwrite temporary sqlplus files]'
  '--sqlplus-keep-temp-path[path for temporary sqlplus files]:path:_files -/'
  '--sqlplus-path[path to sqlplus executable]:path:_files'
  '--sqlplus-timeout[sqlplus timeout]:seconds:'
  '--support-property-escaping[support property escaping]'
  '--use-procedure-schema[use procedure schema]'
  {-v,--version}'[print version information and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
