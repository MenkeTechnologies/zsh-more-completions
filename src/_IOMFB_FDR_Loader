#compdef IOMFB_FDR_Loader
# Documentation: https://man.archlinux.org/search?q=IOMFB_FDR_Loader
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-n[do not attempt mode change]'
  '-C[do not ignore CDFD sections]'
  '-F[get data from FDR]'
  '--fs[read data from /System/Library/Display]'
  '--launchd[_boot: default boot action for this device]'
  '--latleak[_bin: set bin (float) for lateral leakage interpolation]'
  '*:filename:_files'
)

_arguments -s -S $arguments
