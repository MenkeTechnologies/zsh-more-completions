#compdef mdevctl


local -a arguments

arguments=(
    '--addattr[add an attribute to the device]:attribute: '
    {-a,--auto}'[automatically start the device]'
    {-d,--defined}'[only list defined devices]'
    '--delattr[delete an attribute from the device]'
    '--dumpjson[dump device config as JSON]'
    {-i,--index}'[specify device index]:index: '
    '--jsonfile[specify JSON config file]:file:_files'
    {-m,--manual}'[manually start the device]'
    {-p,--parent}'[specify parent device]:parent: '
    {-t,--type}'[specify device type]:type: '
    {-u,--uuid}'[specify device UUID]:uuid: '
    '--value[specify attribute value]:value: '
    {-v,--verbose}'[enable verbose output]'
    '*:filename:_files'
)
_arguments -s -S $arguments
