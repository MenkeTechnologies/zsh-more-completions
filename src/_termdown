#compdef termdown

# Zsh completion for termdown - terminal countdown timer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-f --font)'{-f,--font}'[figlet font to use]:font:' \
  '(-b --blink)'{-b,--blink}'[blink on expiration]' \
  '(-c --critical)'{-c,--critical}'[critical threshold in seconds]:seconds:' \
  '(-q --quit-after)'{-q,--quit-after}'[quit after N seconds past expiration]:seconds:' \
  '--no-figlet[do not use figlet]' \
  '--no-text-magic[do not interpret text as time]' \
  '--no-window-title[do not update window title]' \
  '(-T --title)'{-T,--title}'[custom title text]:title text:' \
  '(-v --voice)'{-v,--voice}'[voice for speech output]:voice name:' \
  '(-o --outfile)'{-o,--outfile}'[output file]:file:_files' \
  '--no-seconds[do not show seconds]' \
  '(-a --alt-format)'{-a,--alt-format}'[use alternative time format]' \
  '(-t --text)'{-t,--text}'[custom text to display]:text:' \
  '(-W)-W[do not update window title]' \
  '(-z --time)'{-z,--time}'[show current time]' \
  '1:time (e.g. 5m, 1h30m, 10):' && ret=0

return ret
