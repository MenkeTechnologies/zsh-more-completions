local -a arguments

arguments=(
  {-t,--timeout}'[wait timeout in seconds]'
  '(- * :)'{-h,--help}'[display this help message]'
  '--version[output version information and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
