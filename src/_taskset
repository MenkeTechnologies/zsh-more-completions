#compdef taskset

_taskset() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -S -s \
        {-a,--all-tasks}'[operate on all tasks (threads) for a given pid]' \
        {-p,--pid}'[operate on an existing pid and do not launch a new task]' \
        {-c,--cpu-list}'[interpret mask as numerical list of processors instead of a bitmask]' \
        '(- *)'{-h,--help}'[display help text and exit]' \
        '(- *)'{-V,--version}'[display version information and exit]' \
        '1:CPU mask or list:' \
        '2:pid or command: _alternative "pids:pid:_pids" "commands:command:_command_names -e"' \
        '*::arguments:_normal' && ret=0

    return ret
}

_taskset "$@"
