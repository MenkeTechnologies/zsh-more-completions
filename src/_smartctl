#compdef smartctl

# Zsh completion for smartctl (S.M.A.R.T. monitoring tools)
# Covers smartctl 7.4+ options

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help,--usage}'[display help and exit]' \
  '(- *)'{-V,--version,--copyright,--license}'[print license, copyright, and version information]' \
  \
  ':: :->info_options' \
  \
  {-i,--info}'[show identity information for device]' \
  '--identify=-[show words and bits from IDENTIFY DEVICE data (ATA)]:verbosity:((n\:hex\ dump v\:decoded w\:ATA\ command\ details wn\:both wv\:both wnv\:all))' \
  {-g,--get}'[get device setting]:setting:(all aam apm dsn lookahead security wcache rcache wcreorder)' \
  {-a,--all}'[show all SMART information for device]' \
  {-x,--xall}'[show all information for device]' \
  '--scan[scan for devices]' \
  '--scan-open[scan for devices and try to open each device]' \
  \
  {-q,--quietmode}'[set quiet mode]:mode:(errorsonly silent noserial)' \
  {-d,--device}'[specify device type]:type:(ata scsi nvme sat auto test
    sat,auto sat,12 sat,16
    usbcypress usbcypress,0x24
    usbjmicron usbjmicron,0 usbjmicron,p usbjmicron,x
    usbprolific usbsunplus usbasm1352r
    marvell areca 3ware hpt megaraid aacraid cciss
    intelliprop jmb39x jms56x)' \
  {-T,--tolerance}'[set tolerance of SMART command failures]:tolerance:(normal conservative permissive verypermissive)' \
  {-b,--badsum}'[set action on bad ATA checksum]:action:(warn exit ignore)' \
  {-r,--report}'[report transactions]:type:(ioctl ataioctl scsiioctl nvmeioctl)' \
  {-n,--nocheck}'[exit if device is in power mode]:mode:(never sleep standby idle)' \
  \
  {-s,--smart}'[enable/disable SMART on device]:state:(on off)' \
  {-o,--offlineauto}'[enable/disable automatic offline testing]:state:(on off)' \
  {-S,--saveauto}'[enable/disable attribute autosave]:state:(on off)' \
  '--set[set device setting]:setting:(aam dsn lookahead security wcache rcache wcreorder)' \
  \
  {-H,--health}'[show device SMART health status]' \
  {-c,--capabilities}'[show device general SMART capabilities (ATA, NVMe)]' \
  {-A,--attributes}'[show device SMART vendor-specific attributes and values]' \
  {-f,--format}'[set output format for attributes]:format:(old brief hex,id hex,val)' \
  {-l,--log}'[show device log]:log type:(error selftest selective directory
    xferror xerror xselftest
    scttemp scttempsts scttemphist
    scterc sataphy sasphy gplog smartlog nvmelog
    devstat devstat,0x04
    ssd defects envrep)' \
  {-v,--vendorattribute}'[set display option for vendor attribute N]:N,OPTION' \
  {-F,--firmwarebug}'[use firmware bug workaround]:bug:(none nologdir samsung samsung2 samsung3 xerrorlba swapid)' \
  {-P,--presets}'[drive-specific presets]:preset:(use ignore show showall)' \
  {-B,--drivedb}'[read drive database from FILE]:database file:_files' \
  \
  {-t,--test}'[run test]:test:(offline short long conveyance force vendor,N select,N-M pending,N afterselect,on afterselect,off)' \
  {-C,--captive}'[do test in captive mode (along with -t)]' \
  {-X,--abort}'[abort any non-captive test on device]' \
  \
  {-j,--json}'[print output in JSON format]::mode:(c g o s u v y)' \
  '--json=-[print output in JSON format]:mode:(c g o s u v y cgosuy)' \
  \
  '*:device:_files -g "*(-%)"' && ret=0

case $state in
  info_options)
    _message 'option'
    ;;
esac

return ret
