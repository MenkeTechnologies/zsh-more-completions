#compdef zipdetails5.34
# Documentation: https://man.archlinux.org/search?q=zipdetails5.34
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[display help]'
  '--scan[enable scannng mode.]'
  '-v[verbose - output more stuff]'
  '--version[version number]'
  '*:filename:_files'
)

_arguments -s -S $arguments
