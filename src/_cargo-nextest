#compdef cargo-nextest

# Zsh completion for cargo-nextest - Next-generation Rust test runner

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_cargo_nextest_target_opts=(
  '--workspace[Test all packages in the workspace]'
  '*'{-p,--package}'[Package to test]:package:'
  '--lib[Test only library]'
  '--bins[Test all binaries]'
  '*--bin[Test specific binary]:binary:'
  '--examples[Test all examples]'
  '*--example[Test specific example]:example:'
  '--tests[Test all test targets]'
  '*--test[Test specific integration test]:test:'
  '--benches[Test all bench targets]'
  '*--bench[Test specific benchmark]:bench:'
  '--all-targets[Test all targets]'
)

_cargo_nextest_build_opts=(
  '--release[Test with release profile]'
  '--cargo-profile[Build with specified Cargo profile]:profile:'
  '*--features[Space or comma separated list of features to activate]:features:'
  '--all-features[Activate all available features]'
  '--no-default-features[Do not activate the default feature]'
  '--target[Test for the specified target triple]:target:'
  '--target-dir[Directory for all generated artifacts]:dir:_directories'
  '--manifest-path[Path to Cargo.toml]:path:_files -g "*.toml"'
  '--frozen[Require Cargo.lock and cache are up to date]'
  '--locked[Require Cargo.lock is up to date]'
  '--offline[Run without accessing the network]'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[Show help]' \
  '(- *)'{-V,--version}'[Show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'run:Build and run tests'
      'list:List tests'
      'archive:Archive test binaries'
      'show-config:Show nextest configuration'
    )
    _describe -t commands 'cargo-nextest commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      run)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[Show help]' \
          "${_cargo_nextest_target_opts[@]}" \
          "${_cargo_nextest_build_opts[@]}" \
          '--config-file[Path to nextest config file]:file:_files -g "*.toml"' \
          '(-P --profile)'{-P,--profile}'[Nextest profile to use]:profile:' \
          '--retries[Number of retries for failing tests]:count:' \
          '--fail-fast[Exit after the first failure]' \
          '--no-fail-fast[Do not exit after the first failure]' \
          '(-j --test-threads)'{-j,--test-threads}'[Number of tests to run simultaneously]:threads:' \
          '--run-ignored[Run ignored tests]:which:(default ignored-only all)' \
          '--partition[Test partition]:partition:' \
          '(-E --filter-expr)'{-E,--filter-expr}'[Filter expression]:expr:' \
          '--no-capture[Do not capture test output]' \
          '*:filter:' && ret=0
        ;;
      list)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[Show help]' \
          "${_cargo_nextest_target_opts[@]}" \
          "${_cargo_nextest_build_opts[@]}" \
          '--config-file[Path to nextest config file]:file:_files -g "*.toml"' \
          '(-P --profile)'{-P,--profile}'[Nextest profile to use]:profile:' \
          '--run-ignored[Run ignored tests]:which:(default ignored-only all)' \
          '--partition[Test partition]:partition:' \
          '(-E --filter-expr)'{-E,--filter-expr}'[Filter expression]:expr:' \
          '(-T --list-type)'{-T,--list-type}'[Type of listing]:type:(full binaries-only)' \
          '--message-format[Output format]:format:(human json json-pretty)' \
          '*:filter:' && ret=0
        ;;
      archive)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[Show help]' \
          "${_cargo_nextest_target_opts[@]}" \
          "${_cargo_nextest_build_opts[@]}" \
          '--config-file[Path to nextest config file]:file:_files -g "*.toml"' \
          '--archive-file[Path to archive file]:file:_files' \
          '--archive-format[Archive format]:format:(tar-zst)' && ret=0
        ;;
      show-config)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[Show help]' \
          '--config-file[Path to nextest config file]:file:_files -g "*.toml"' \
          '1:subcommand:(test-groups version)' && ret=0
        ;;
    esac
    ;;
esac

return ret
