#compdef pcprofiledump
# Documentation: https://man.archlinux.org/search?q=pcprofiledump
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-u,--unbuffered}'[dont buffer output]'
  '--usage[give a short usage message]'
  {-V,--version}'[print program version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
