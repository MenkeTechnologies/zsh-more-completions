#compdef opensc-explorer
# Documentation: https://man.archlinux.org/search?q=opensc-explorer
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-r,--reader}'[uses reader number <arg> \[0\]]'
  {-c,--card-driver}'[forces the use of driver <arg> \[auto-detect\]]'
  {-m,--mf}'[selects path <arg> on start-up, or none if empty \[3F00\]]'
  {-w,--wait}'[wait for card insertion]'
  {-v,--verbose}'[verbose operation. Use several times to enable debug output.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
