#compdef gst-validate-rtsp-server-1.0
# Documentation: https://man.archlinux.org/search?q=gst-validate-rtsp-server-1.0
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[show help options]'
  '--help-all[show all help options]'
  '--help-gst[show GStreamer Options]'
  {-p,--port}'[port to listen on (default: 8554)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
