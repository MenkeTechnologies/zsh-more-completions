#compdef evince-thumbnailer
# Documentation: https://man.archlinux.org/search?q=evince-thumbnailer
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  {-s,--size}'[set thumbnail size]:size:'
  {-l,--no-limit}'[dont limit the thumbnailing time to 15 seconds]'
  '*:filename:_files'
)

_arguments -s -S $arguments
