#compdef fonttools

local -a subcommands
subcommands=(
    'ttx:Convert fonts to/from XML'
    'merge:Merge multiple fonts'
    'subset:Subset fonts (pyftsubset)'
    'instancer:Generate static font instances'
    'feaLib:Compile OpenType feature files'
    'varLib:Build variable fonts'
    'unicodedata:Query Unicode character data'
    'help:Show help for a subcommand'
)

_arguments -C \
    '-h[Show help]' \
    '--help[Show help]' \
    '1:subcommand:->subcmd' \
    '*:: :->args'

case $state in
    subcmd)
        _describe -t subcommands 'fonttools subcommand' subcommands
        ;;
    args)
        case $words[1] in
            ttx)
                _arguments \
                    '-o[Output file]:file:_files' \
                    '-y[Font number in TTC]:number' \
                    '-l[List table info]' \
                    '-t[Include table]:table tag' \
                    '-x[Exclude table]:table tag' \
                    '-s[Split tables to separate files]' \
                    '-i[Disassemble TrueType bytecode]' \
                    '-z[Specifies method for encoding binary data]:method:(raw extfile)' \
                    '-e[Specifies encoding]:encoding' \
                    '-q[Quiet mode]' \
                    '-d[Output directory]:dir:_directories' \
                    '--unicodedata[Use custom UnicodeData.txt]:file:_files' \
                    '--newline[Line ending]:newline:(LF CR CRLF)' \
                    '*:font file:_files -g "*.{ttf,otf,woff,woff2,ttc,dfont,ttx}"'
                ;;
            subset)
                _arguments \
                    '--output-file[Output file]:file:_files' \
                    '--text[Text to subset for]:text' \
                    '--text-file[File with text to subset for]:file:_files' \
                    '--unicodes[Unicode codepoints]:unicodes' \
                    '--glyphs[Glyph names]:glyphs' \
                    '--gids[Glyph IDs]:gids' \
                    '--layout-features[Layout features to retain]:features' \
                    '--no-layout-closure[Do not expand glyph set]' \
                    '--desubroutinize[Desubroutinize CFF]' \
                    '--no-hinting[Remove hinting]' \
                    '--notdef-outline[Keep .notdef outline]' \
                    '--name-IDs[Name IDs to retain]:ids' \
                    '--flavor[Output flavor]:flavor:(woff woff2)' \
                    '--with-zopfli[Use zopfli for WOFF]' \
                    '*:font file:_files -g "*.{ttf,otf,woff,woff2}"'
                ;;
            merge)
                _arguments \
                    '--output-file[Output file]:file:_files' \
                    '*:font files:_files -g "*.{ttf,otf}"'
                ;;
            instancer)
                _arguments \
                    '-o[Output file]:file:_files' \
                    '--output[Output file]:file:_files' \
                    '--no-overlap-flag[Do not set overlap flag]' \
                    '--remove-overlaps[Remove overlaps]' \
                    '--update-name-table[Update name table]' \
                    '*:font file or axis:_files -g "*.{ttf,otf}"'
                ;;
            *)
                _arguments '*:font file:_files -g "*.{ttf,otf,woff,woff2,ttc,dfont,ttx}"'
                ;;
        esac
        ;;
esac
