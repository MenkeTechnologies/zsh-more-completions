#compdef systemd-tmpfiles

local arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help]'
  '--version[show package version]'
  '--create[create marked files/directories]'
  '--clean[clean up marked directories]'
  '--remove[remove marked files/directories]'
  '--purge[remove files and directories created by tmpfiles.d entries]'
  '--user[execute user-specific configuration]'
  '--boot[execute actions only safe at boot]'
  '--graceful[ignore configuration lines for unknown users or groups]'
  '--dry-run[show what would be done without making changes]'
  '*--prefix=[only apply rules with the specified prefix]:path prefix:_directories'
  '*--exclude-prefix=[ignore rules with the specified prefix]:path prefix:_directories'
  '-E[exclude /dev, /proc, /run, /sys hierarchies]'
  '--root=[operate on an alternate filesystem root]:root directory:_directories'
  '--image=[operate on specified disk image or block device]:image:_files'
  '--image-policy=[enforce image dissection policy]:policy'
  '--replace=[use config as replacement for specified file]:config file:_files'
  '--cat-config[display configuration files to stdout]'
  '--tldr[display simplified configuration contents]'
  '--no-pager[do not pipe output into a pager]'
  '*:configuration file:_files'
)

_arguments -s $arguments
