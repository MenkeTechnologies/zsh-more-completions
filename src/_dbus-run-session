#compdef dbus-run-session
# Documentation: https://man.archlinux.org/search?q=dbus-run-session
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--dbus-daemon[run BINARY instead of dbus-daemon]'
  '--config-file[pass to dbus-daemon instead of --session]'
  '*:filename:_files'
)

_arguments -s -S $arguments
