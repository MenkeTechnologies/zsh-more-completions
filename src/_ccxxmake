#compdef ccxxmake

local -a arguments

arguments=(
  '-v[verbose mode]'
  '-S[create CCSS rather than CCMX]'
  '-f[create from one or two .ti3 files rather than measure]:file:_files'
  '-display[choose X11 display name]:display:'
  '-d[choose the display number (default 1)]:display:'
  '-dweb[display via a web server at port (default 8080)]:port:'
  '-dcc[display via nth ChromeCast (default 1, ? for list)]:number:'
  '-p[use telephoto mode (ie. for a projector) (if available)]'
  '-z[different display type for spectrometer (see -y)]'
  '-P[position test window and scale it]:position:'
  '-F[fill whole screen with black background]'
  '-n[dont set override redirect on test window]'
  '-N[disable initial calibration of instrument if possible]'
  '-H[use high resolution spectrum mode (if available)]'
  '-C[invoke shell command each time a color is set]:command:'
  '-o[choose CIE Observer for CCMX spectrometer data]:observer:'
  '-s[override default patch sequence combination steps (default 1)]:steps:'
  '-W[override serial port flow control]:mode:(n h x)'
  '-D[print debug diagnostics to stderr]'
  '-E[override the default overall description]:description:'
  '-I[set display make and model description (optional)]:description:'
  '-t[set display technology type]:type:'
  '-U[set UI selection character(s)]:chars:'
  '-Y[set or override refresh/non-refresh display type]'
  '-Y[override measured refresh rate with rate Hz]'
  '-Y[use non-adaptive integration time mode (if available).]'
  '*:filename:_files'
)

_arguments -s -S $arguments
