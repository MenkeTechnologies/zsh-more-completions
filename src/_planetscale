#compdef pscale

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'audit-log:list audit logs'
  'auth:login and logout'
  'backup:create, list, and manage branch backups'
  'branch:create, delete, and manage branches'
  'completion:generate shell completion scripts'
  'connect:create a secure connection to a database branch'
  'database:create, read, delete, and list databases'
  'data-imports:create and manage data imports'
  'deploy-request:create, review, and manage deploy requests'
  'keyspace:list and manage keyspaces'
  'org:list and switch organizations'
  'password:create, list, and manage branch passwords'
  'region:list available regions'
  'service-token:create, list, and manage access tokens'
  'shell:open a MySQL shell'
  'signup:sign up for a PlanetScale account'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--api-token=[PlanetScale API token]:token' \
  '--api-url=[PlanetScale API URL]:url' \
  '--config=[config file]:config file:_files' \
  '--debug[enable debug mode]' \
  '--org=[PlanetScale organization]:org' \
  '--no-color[disable color output]' \
  '--service-token=[service token for authenticating]:token' \
  '--service-token-id=[service token ID]:id' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'pscale command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (branch)
        local -a branch_cmds=(
          'create:create a new branch'
          'delete:delete a branch'
          'diff:show the schema diff of a branch'
          'list:list all branches'
          'promote:promote a branch to production'
          'demote:demote a production branch'
          'refresh-schema:refresh the schema for a branch'
          'schema:show the schema of a branch'
          'show:show a specific branch'
          'switch:switch to a different branch'
          'safe-migrations:enable or disable safe migrations on a branch'
          'keyspace:manage branch keyspaces'
          'vschema:show or update the VSchema'
        )
        _arguments \
          '1:subcommand:_describe -t branch-commands "branch command" branch_cmds' \
          '*:args' && ret=0
        ;;
      (database)
        local -a db_cmds=(
          'create:create a new database'
          'delete:delete a database'
          'dump:dump a database'
          'list:list all databases'
          'show:show a specific database'
        )
        _arguments \
          '1:subcommand:_describe -t db-commands "database command" db_cmds' \
          '*:args' && ret=0
        ;;
      (deploy-request)
        local -a dr_cmds=(
          'close:close a deploy request'
          'create:create a deploy request'
          'deploy:deploy a deploy request'
          'diff:show the schema diff of a deploy request'
          'edit:edit a deploy request'
          'list:list all deploy requests'
          'review:approve or comment on a deploy request'
          'revert:revert a deployed deploy request'
          'show:show a specific deploy request'
          'skip-revert:skip revert period for a deploy request'
        )
        _arguments \
          '1:subcommand:_describe -t dr-commands "deploy-request command" dr_cmds' \
          '*:args' && ret=0
        ;;
      (connect)
        _arguments -s -S \
          '--port=[local port]:port' \
          '--host=[local host]:host' \
          '--role=[connect as specific role]:role:(reader writer admin)' \
          '--execute=[execute a SQL query]:query' \
          '--execute-env-url=[env var to read database URL]:env var' \
          '--execute-protocol=[protocol for connections]:protocol:(mysql mysqlx)' \
          '1:database' \
          '2:branch' && ret=0
        ;;
      (shell)
        _arguments -s -S \
          '--org=[organization]:org' \
          '1:database' \
          '2:branch' && ret=0
        ;;
      (password)
        local -a pw_cmds=(
          'create:create a new branch password'
          'delete:delete a branch password'
          'list:list all branch passwords'
          'renew:renew a branch password'
        )
        _arguments \
          '1:subcommand:_describe -t pw-commands "password command" pw_cmds' \
          '*:args' && ret=0
        ;;
      (auth)
        local -a auth_cmds=(
          'login:authenticate with PlanetScale'
          'logout:log out of PlanetScale'
        )
        _arguments \
          '1:subcommand:_describe -t auth-commands "auth command" auth_cmds' && ret=0
        ;;
    esac
    ;;
esac

return ret
