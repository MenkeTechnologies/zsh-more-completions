#compdef cracklib-format

local -a arguments

arguments=(
  '--rsyncablemakersync-friendlyarchive[rsync-friendly archive]'
  {-1,--fastcompressfaster}'[compress faster]'
  {-9,--bestcompressbetter}'[compress better]'
  {-c,--stdoutwriteonstandardoutput}'[keeporiginalfilesunchanged]'
  {-d,--decompressdecompress}'[decompress input]'
  {-f,--forceforceoverwriteofoutputfileandcompresslinks}'[force overwrite of output file]'
  {-h,--helpgivethishelp}'[show help message]'
  {-l,--licensedisplaysoftwarelicense}'[display software license]'
  {-l,--listlistcompressedfilecontents}'[list compressed file contents]'
  {-n,--namesaveorrestoretheoriginalnameandtimestamp}'[save or restore original name and timestamp]'
  {-n,--no-namedonotsaveorrestoretheoriginalnameandtimestamp}'[do not save or restore original name]'
  {-q,--quietsuppressallwarnings}'[suppress all warnings]'
  {-r,--recursiveoperaterecursivelyondirectories}'[operate recursively on directories]'
  {-s,--suffix}'[specify file suffix]'
  {-t,--testtestcompressedfileintegrity}'[test compressed file integrity]'
  {-v,--verboseverbosemode}'[enable verbose mode]'
  {-v,--versiondisplayversionnumber}'[compressoruncompressfiles(bydefault,compressfilesin-place).]'
  '*:filename:_files'
)

_arguments -s -S $arguments
