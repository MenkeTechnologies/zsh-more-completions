#compdef tccutil

local -a subcommands

subcommands=(
    'reset:Reset TCC decisions for a service'
)

local -a services
services=(
    'All' 'Accessibility' 'AddressBook' 'AppleEvents' 'Calendar'
    'Camera' 'ContactsFull' 'ContactsLimited' 'DeveloperTool'
    'FileProviderDomain' 'FileProviderPresence' 'ListenEvent'
    'Liverpool' 'Location' 'MediaLibrary' 'Microphone' 'Motion'
    'Photos' 'PhotosAdd' 'PostEvent' 'Reminders' 'ScreenCapture'
    'ShareKit' 'SpeechRecognition' 'SystemPolicyAllFiles'
    'SystemPolicyDesktopFolder' 'SystemPolicyDeveloperFiles'
    'SystemPolicyDocumentsFolder' 'SystemPolicyDownloadsFolder'
    'SystemPolicyNetworkVolumes' 'SystemPolicyRemovableVolumes'
    'SystemPolicySysAdminFiles' 'Ubiquity' 'Willow'
    'EndpointSecurityClient' 'FocusStatus' 'BluetoothAlways'
    'FullDiskAccess' 'InputMonitoring'
)

_arguments -s -S \
    '1:subcommand:->subcmd' \
    '*:: :->args' && return

case $state in
    subcmd)
        _describe 'tccutil subcommand' subcommands
        ;;
    args)
        case $words[1] in
            reset)
                _arguments \
                    '1:service:('${(j: :)services}')' \
                    '2::bundle identifier'
                ;;
        esac
        ;;
esac
