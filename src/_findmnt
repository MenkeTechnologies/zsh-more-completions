#compdef findmnt

local arguments

arguments=(
  {-s,--fstab}'[search in /etc/fstab]'
  {-m,--mtab}'[search in /etc/mtab]'
  {-k,--kernel}'[search in kernel table of mounted filesystems]'
  {-p,--poll}'[monitor changes in /proc/self/mountinfo]::list'
  {-w,--timeout}'[upper limit in milliseconds that --poll will block]:milliseconds'
  {-A,--all}'[disable all built-in filters and print all filesystems]'
  {-a,--ascii}'[use ASCII characters for tree formatting]'
  {-b,--bytes}'[print sizes in bytes rather than in human readable format]'
  {-C,--nocanonicalize}'[do not canonicalize when comparing paths]'
  {-c,--canonicalize}'[canonicalize all printed paths]'
  {-D,--df}'[imitate the output of df(1)]'
  {-d,--direction}'[direction of search]:direction:(forward backward)'
  {-e,--evaluate}'[convert tags (LABEL, UUID, PARTUUID, PARTLABEL) to device names]'
  {-F,--tab-file}'[search in an alternative file]:file:_files'
  {-f,--first-only}'[print the first matching filesystem only]'
  {-H,--list-columns}'[list available columns for --output]'
  '--hyperlink[print paths as terminal hyperlinks]::when:(auto never always)'
  {-I,--dfi}'[imitate the output of df(1) with -i inode information]'
  {-i,--invert}'[invert the sense of matching]'
  '--id[select a filesystem using the mount node ID]:id'
  '--uniq-id[select a filesystem using the 64-bit mount node ID]:id'
  {-J,--json}'[use JSON output format]'
  {-l,--list}'[use list output format]'
  {-M,--mountpoint}'[explicitly define the mountpoint file or directory]:mountpoint:_files'
  {-N,--task}'[use alternative namespace (/proc/<tid>/mountinfo)]:tid'
  {-n,--noheadings}'[do not print column headings]'
  {-O,--options}'[limit the set of filesystems by mount options]:options'
  {-o,--output}'[define output columns]:list'
  '--output-all[output all available columns]'
  {-P,--pairs}'[produce output in the form of key="value" pairs]'
  '--pseudo[print only pseudo filesystems]'
  {-Q,--filter}'[filter filesystems using conditional expressions]:expression'
  {-R,--submounts}'[print recursively all submounts for the selected filesystems]'
  {-r,--raw}'[use raw output format]'
  '--real[print only real filesystems]'
  {-S,--source}'[explicitly define the mount source]:source'
  '--shadowed[print only filesystems over-mounted by another filesystem]'
  {-T,--target}'[explicitly define the mount target]:target:_files'
  {-t,--types}'[limit the set of filesystems by filesystem types]:types'
  '--tree[enable tree-like output if possible]'
  {-U,--uniq}'[ignore filesystems with duplicate mount targets]'
  {-u,--notruncate}'[do not truncate text in columns]'
  {-v,--nofsroot}'[do not print \[/dir\] for bind or btrfs mounts]'
  '--verbose[force findmnt to print more information]'
  '--vfs-all[display all VFS kernel flags with VFS-OPTIONS column]'
  {-x,--verify}'[check mount table content]'
  {-y,--shell}'[use column names that can be used as shell variable identifiers]'
  '(- * :)'{-h,--help}'[display help text and exit]'
  '(- * :)'{-V,--version}'[display version information and exit]'
  '*:device or mountpoint:_files'
)

_arguments -s $arguments
