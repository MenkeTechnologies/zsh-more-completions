#compdef oxipng

# Zsh completion for oxipng - PNG optimizer

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-o,--opt}'[optimization level (0-6)]:level:(0 1 2 3 4 5 6)' \
  {-r,--recursive}'[recurse into directories]' \
  '--dir[write output to directory]:directory:_directories' \
  '--out[write output file to path]:file:_files' \
  {-s,--strip}'[strip metadata]:mode:(safe all none)' \
  '--keep[keep specified metadata chunks]:chunks:' \
  {-a,--alpha}'[additional alpha optimizations]' \
  {-i,--interlace}'[PNG interlace type]:type:(0 1)' \
  '--filters[PNG delta filters to try]:filters:' \
  '--fix[fix errors in input files when possible]' \
  '--force[write output even if larger than input]' \
  {-Z,--zopfli}'[use Zopfli compression]' \
  '--timeout[timeout in seconds]:seconds:' \
  {-p,--preserve}'[preserve file attributes]' \
  {-P,--pretend}'[do not write output, only calculate savings]' \
  '--ng[do not change grayscale mode]' \
  '--nc[do not change color type]' \
  '--nb[do not change bit depth]' \
  '--np[do not change palette]' \
  '--nz[do not recompress IDAT]' \
  {-t,--threads}'[number of threads to use]:threads:' \
  {-q,--quiet}'[run in quiet mode]' \
  {-v,--verbose}'[run in verbose mode]' \
  '*:file:_files -g "*.png"' \
  && return 0
