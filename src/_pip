#compdef pip pip3

# Zsh completion for pip (Python package installer)
# Compatible with pip 24/25+

_pip() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    local -a commands
    commands=(
        'install:Install packages'
        'lock:Generate a lock file (experimental)'
        'download:Download packages'
        'uninstall:Uninstall packages'
        'freeze:Output installed packages in requirements format'
        'inspect:Inspect the python environment'
        'list:List installed packages'
        'show:Show information about installed packages'
        'check:Verify installed packages have compatible dependencies'
        'config:Manage local and global configuration'
        'search:Search PyPI for packages'
        'cache:Inspect and manage pip'\''s wheel cache'
        'index:Inspect information available from package indexes'
        'wheel:Build wheels from your requirements'
        'hash:Compute hashes of package archives'
        'completion:A helper command used for command completion'
        'debug:Show information useful for debugging'
        'help:Show help for commands'
    )

    local -a global_flags
    global_flags=(
        '(-h --help)'{-h,--help}'[Show help]'
        '--debug[Let unhandled exceptions propagate outside the main subroutine]'
        '--isolated[Run pip in an isolated mode, ignoring environment variables and user configuration]'
        '--require-virtualenv[Allow pip to only run in a virtual environment]'
        '--python[Run pip with the specified Python interpreter]:python:_files'
        '(-v --verbose)'{-v,--verbose}'[Give more output (additive, up to 3 times)]'
        '(-V --version)'{-V,--version}'[Show version and exit]'
        '(-q --quiet)'{-q,--quiet}'[Give less output (additive, up to 3 times)]'
        '--log[Path to a verbose appending log]:file:_files'
        '--no-input[Disable prompting for input]'
        '--keyring-provider[Enable the credential lookup via the keyring library]:provider:(auto disabled import subprocess)'
        '--proxy[Specify a proxy]:proxy:'
        '--retries[Maximum number of retries each connection should attempt]:retries:'
        '--timeout[Set the socket timeout]:seconds:'
        '--exists-action[Default action when a path already exists]:action:(s i w b a)'
        '--trusted-host[Mark this host or host\:port pair as trusted]:host:'
        '--cert[Path to PEM-encoded CA certificate bundle]:file:_files'
        '--client-cert[Path to SSL client certificate]:file:_files'
        '--cache-dir[Store the cache data in the specified directory]:dir:_directories'
        '--no-cache-dir[Disable the cache]'
        '--disable-pip-version-check[Don'\''t periodically check PyPI for a new pip version]'
        '--no-color[Suppress colored output]'
        '--no-python-version-warning[Silence deprecation warnings for upcoming unsupported Pythons]'
        '*--use-feature[Enable new functionality]:feature:'
        '*--use-deprecated[Enable deprecated functionality]:feature:'
        '--resume-retries[Maximum attempts to resume or restart an incomplete download]:retries:'
    )

    _arguments -C \
        $global_flags \
        '1:command:->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'pip command' commands
            ;;
        args)
            case $words[1] in
                install)
                    _arguments -s \
                        '*'{-r,--requirement}'[Install from the given requirements file]:file:_files' \
                        '*'{-c,--constraint}'[Constrain versions using the given constraints file]:file:_files' \
                        '*--build-constraint[Constrain build dependencies using the given constraints file]:file:_files' \
                        '--requirements-from-script[Install dependencies of the given script file (PEP 723)]:file:_files' \
                        '--no-deps[Don'\''t install package dependencies]' \
                        '--pre[Include pre-release and development versions]' \
                        '*--all-releases[Allow all release types including pre-releases for a package]:control:' \
                        '*--only-final[Only allow final releases (no pre-releases) for a package]:control:' \
                        '*'{-e,--editable}'[Install a project in editable mode]:path:_directories' \
                        '--dry-run[Don'\''t actually install anything, just print what would be]' \
                        '(-t --target)'{-t,--target}'[Install packages into target directory]:dir:_directories' \
                        '--platform[Only use wheels compatible with platform]:platform:' \
                        '--python-version[The Python interpreter version to use for compatibility checks]:version:' \
                        '--implementation[Only use wheels compatible with Python implementation]:impl:(cp pp jy ip py)' \
                        '--abi[Only use wheels compatible with Python abi]:abi:' \
                        '--user[Install to the Python user install directory]' \
                        '--root[Install everything relative to this alternate root directory]:dir:_directories' \
                        '--prefix[Installation prefix]:dir:_directories' \
                        '--src[Directory to check out editable projects into]:dir:_directories' \
                        '(-U --upgrade)'{-U,--upgrade}'[Upgrade all specified packages to the newest available version]' \
                        '--upgrade-strategy[Determines how dependency upgrading should be handled]:strategy:(eager only-if-needed)' \
                        '--force-reinstall[Reinstall all packages even if they are already up-to-date]' \
                        '(-I --ignore-installed)'{-I,--ignore-installed}'[Ignore the installed packages]' \
                        '--ignore-requires-python[Ignore the Requires-Python information]' \
                        '--no-build-isolation[Disable isolation when building a modern source distribution]' \
                        '--use-pep517[Use PEP 517 for building source distributions]' \
                        '--check-build-dependencies[Check the build dependencies when PEP 517 is used]' \
                        '--break-system-packages[Allow pip to modify an EXTERNALLY-MANAGED Python installation]' \
                        '*'{-C,--config-settings}'[Configuration settings to pass to the PEP 517 build backend]:setting:' \
                        '--compile[Compile Python source files to bytecode]' \
                        '--no-compile[Do not compile Python source files to bytecode]' \
                        '--no-warn-script-location[Do not warn when installing scripts outside PATH]' \
                        '--no-warn-conflicts[Do not warn about broken dependencies]' \
                        '*--no-binary[Do not use binary packages]:package:' \
                        '*--only-binary[Do not use source packages]:package:' \
                        '--prefer-binary[Prefer older binary packages over newer source packages]' \
                        '--require-hashes[Require a hash to check each requirement against]' \
                        '--progress-bar[Specify whether the progress bar should be used]:mode:(auto on off raw)' \
                        '--root-user-action[Action if pip is run as a root user]:action:(warn ignore)' \
                        '--report[Generate a JSON file describing what pip did]:file:_files' \
                        '*--group[Install a named dependency-group from pyproject.toml]:group:' \
                        '--no-clean[Don'\''t clean up build directories]' \
                        '(-i --index-url)'{-i,--index-url}'[Base URL of the Python Package Index]:url:' \
                        '*--extra-index-url[Extra URLs of package indexes]:url:' \
                        '--no-index[Ignore package index, only look at find-links URLs]' \
                        '*'{-f,--find-links}'[URL or path to look for packages]:url:' \
                        '--uploaded-prior-to[Only consider packages uploaded prior to this date]:datetime:' \
                        '*:packages:'
                    ;;
                lock)
                    _arguments -s \
                        '(-o --output)'{-o,--output}'[Lock file name (default=pylock.toml)]:path:_files' \
                        '*'{-r,--requirement}'[Install from the given requirements file]:file:_files' \
                        '--requirements-from-script[Install dependencies of the given script file (PEP 723)]:file:_files' \
                        '*'{-c,--constraint}'[Constrain versions using the given constraints file]:file:_files' \
                        '*--build-constraint[Constrain build dependencies]:file:_files' \
                        '--no-deps[Don'\''t install package dependencies]' \
                        '*'{-e,--editable}'[Install a project in editable mode]:path:_directories' \
                        '--src[Directory to check out editable projects into]:dir:_directories' \
                        '--ignore-requires-python[Ignore the Requires-Python information]' \
                        '--no-build-isolation[Disable isolation when building a modern source distribution]' \
                        '--check-build-dependencies[Check the build dependencies]' \
                        '*'{-C,--config-settings}'[Configuration settings to pass to the build backend]:setting:' \
                        '--require-hashes[Require a hash to check each requirement against]' \
                        '--progress-bar[Specify whether the progress bar should be used]:mode:(auto on off raw)' \
                        '*--group[Install a named dependency-group from pyproject.toml]:group:' \
                        '--no-clean[Don'\''t clean up build directories]' \
                        '--pre[Include pre-release and development versions]' \
                        '*--all-releases[Allow all release types including pre-releases]:control:' \
                        '*--only-final[Only allow final releases]:control:' \
                        '*--no-binary[Do not use binary packages]:package:' \
                        '*--only-binary[Do not use source packages]:package:' \
                        '--prefer-binary[Prefer binary packages over source packages]' \
                        '(-i --index-url)'{-i,--index-url}'[Base URL of the Python Package Index]:url:' \
                        '*--extra-index-url[Extra URLs of package indexes]:url:' \
                        '--no-index[Ignore package index]' \
                        '*'{-f,--find-links}'[URL or path to look for packages]:url:' \
                        '--uploaded-prior-to[Only consider packages uploaded prior to this date]:datetime:' \
                        '*:packages:'
                    ;;
                uninstall)
                    _arguments -s \
                        '*'{-r,--requirement}'[Uninstall all the packages listed in the given requirements file]:file:_files' \
                        '(-y --yes)'{-y,--yes}'[Don'\''t ask for confirmation of uninstall deletions]' \
                        '--root-user-action[Action if pip is run as a root user]:action:(warn ignore)' \
                        '--break-system-packages[Allow pip to modify an EXTERNALLY-MANAGED Python installation]' \
                        '*:packages:'
                    ;;
                download)
                    _arguments -s \
                        '(-d --dest)'{-d,--dest}'[Download packages into directory]:dir:_directories' \
                        '*'{-r,--requirement}'[Install from the given requirements file]:file:_files' \
                        '*'{-c,--constraint}'[Constrain versions using the given constraints file]:file:_files' \
                        '*--build-constraint[Constrain build dependencies]:file:_files' \
                        '--requirements-from-script[Install dependencies of the given script file (PEP 723)]:file:_files' \
                        '--no-deps[Don'\''t install package dependencies]' \
                        '--pre[Include pre-release and development versions]' \
                        '*--all-releases[Allow all release types including pre-releases]:control:' \
                        '*--only-final[Only allow final releases]:control:' \
                        '--platform[Only use wheels compatible with platform]:platform:' \
                        '--python-version[The Python interpreter version to use]:version:' \
                        '--implementation[Only use wheels compatible with Python implementation]:impl:(cp pp jy ip py)' \
                        '--abi[Only use wheels compatible with Python abi]:abi:' \
                        '*--no-binary[Do not use binary packages]:package:' \
                        '*--only-binary[Do not use source packages]:package:' \
                        '--prefer-binary[Prefer older binary packages over newer source packages]' \
                        '--require-hashes[Require a hash to check each requirement against]' \
                        '--no-build-isolation[Disable isolation when building a modern source distribution]' \
                        '--check-build-dependencies[Check the build dependencies]' \
                        '*'{-C,--config-settings}'[Configuration settings to pass to the build backend]:setting:' \
                        '--src[Directory to check out editable projects into]:dir:_directories' \
                        '--ignore-requires-python[Ignore the Requires-Python information]' \
                        '--progress-bar[Specify whether the progress bar should be used]:mode:(auto on off raw)' \
                        '--no-clean[Don'\''t clean up build directories]' \
                        '(-i --index-url)'{-i,--index-url}'[Base URL of the Python Package Index]:url:' \
                        '*--extra-index-url[Extra URLs of package indexes]:url:' \
                        '--no-index[Ignore package index, only look at find-links URLs]' \
                        '*'{-f,--find-links}'[URL or path to look for packages]:url:' \
                        '--uploaded-prior-to[Only consider packages uploaded prior to this date]:datetime:' \
                        '*:packages:'
                    ;;
                list)
                    _arguments -s \
                        '(-o --outdated)'{-o,--outdated}'[List outdated packages]' \
                        '(-u --uptodate)'{-u,--uptodate}'[List uptodate packages]' \
                        '(-e --editable)'{-e,--editable}'[List editable projects]' \
                        '(-l --local)'{-l,--local}'[If in a virtualenv, only list packages installed in the virtualenv]' \
                        '--user[Only output packages installed in user-site]' \
                        '*--path[Restrict to the specified installation path]:path:_directories' \
                        '--pre[Include pre-release and development versions]' \
                        '*--all-releases[Allow all release types including pre-releases]:control:' \
                        '*--only-final[Only allow final releases]:control:' \
                        '--format[Select the output format]:format:(columns freeze json)' \
                        '--not-required[List packages that are not dependencies of installed packages]' \
                        '--exclude-editable[Exclude editable packages from output]' \
                        '--include-editable[Include editable packages from output]' \
                        '*--exclude[Exclude specified package from the output]:package:'
                    ;;
                show)
                    _arguments -s \
                        '(-f --files)'{-f,--files}'[Show the full list of installed files for each package]' \
                        '*:packages:'
                    ;;
                freeze)
                    _arguments -s \
                        '*'{-r,--requirement}'[Use the order of a given requirements file]:file:_files' \
                        '(-l --local)'{-l,--local}'[If in a virtualenv, only list packages installed in the virtualenv]' \
                        '--user[Only output packages installed in user-site]' \
                        '--path[Restrict to the specified installation path]:path:_directories' \
                        '--all[Do not skip pip, setuptools, distribute, or wheel]' \
                        '--exclude-editable[Exclude editable packages from output]' \
                        '*--exclude[Exclude specified package from the output]:package:'
                    ;;
                check)
                    _arguments -s
                    ;;
                config)
                    local -a config_commands
                    config_commands=(
                        'list:List the active configuration'
                        'edit:Edit the configuration file in an editor'
                        'get:Get the value associated with a name'
                        'set:Set the name=value'
                        'unset:Unset the value associated with a name'
                        'debug:List the configuration files and values'
                    )
                    _arguments -C \
                        '--editor[Editor to use with the edit subcommand]:editor:_command_names' \
                        '--global[Use the system-wide configuration file only]' \
                        '--user[Use the user configuration file only]' \
                        '--site[Use the current environment configuration file only]' \
                        '1:config command:->configcmd' \
                        '*::arg:->configargs'
                    case $state in
                        configcmd)
                            _describe -t config_commands 'config command' config_commands
                            ;;
                    esac
                    ;;
                search)
                    _arguments -s \
                        '(-i --index)'{-i,--index}'[Base URL of Python Package Index]:url:' \
                        '*:query:'
                    ;;
                cache)
                    local -a cache_commands
                    cache_commands=(
                        'dir:Show the cache directory'
                        'info:Show information about the cache'
                        'list:List filenames of packages stored in the cache'
                        'purge:Remove all items from the cache'
                        'remove:Remove one or more packages from the cache'
                    )
                    _arguments -C \
                        '--format[Select the output format]:format:(human abspath)' \
                        '1:cache command:->cachecmd' \
                        '*::arg:->cacheargs'
                    case $state in
                        cachecmd)
                            _describe -t cache_commands 'cache command' cache_commands
                            ;;
                    esac
                    ;;
                index)
                    _arguments -s \
                        '(-i --index-url)'{-i,--index-url}'[Base URL of the Python Package Index]:url:' \
                        '*--extra-index-url[Extra URLs of package indexes]:url:' \
                        '--no-index[Ignore package index]' \
                        '--pre[Include pre-release and development versions]' \
                        '*--all-releases[Allow all release types including pre-releases]:control:' \
                        '*--only-final[Only allow final releases]:control:' \
                        '1:index subcommand:(versions)' \
                        '*:packages:'
                    ;;
                wheel)
                    _arguments -s \
                        '(-w --wheel-dir)'{-w,--wheel-dir}'[Build wheels into directory]:dir:_directories' \
                        '*'{-r,--requirement}'[Install from the given requirements file]:file:_files' \
                        '*'{-c,--constraint}'[Constrain versions using the given constraints file]:file:_files' \
                        '*--build-constraint[Constrain build dependencies]:file:_files' \
                        '--requirements-from-script[Install dependencies of the given script file (PEP 723)]:file:_files' \
                        '--no-deps[Don'\''t install package dependencies]' \
                        '--pre[Include pre-release and development versions]' \
                        '*--all-releases[Allow all release types including pre-releases]:control:' \
                        '*--only-final[Only allow final releases]:control:' \
                        '*'{-e,--editable}'[Install a project in editable mode]:path:_directories' \
                        '*--no-binary[Do not use binary packages]:package:' \
                        '*--only-binary[Do not use source packages]:package:' \
                        '--prefer-binary[Prefer older binary packages over newer source packages]' \
                        '--require-hashes[Require a hash to check each requirement against]' \
                        '--no-build-isolation[Disable isolation when building a modern source distribution]' \
                        '--use-pep517[Use PEP 517 for building source distributions]' \
                        '--check-build-dependencies[Check the build dependencies when PEP 517 is used]' \
                        '*'{-C,--config-settings}'[Configuration settings to pass to the build backend]:setting:' \
                        '--src[Directory to check out editable projects into]:dir:_directories' \
                        '--ignore-requires-python[Ignore the Requires-Python information]' \
                        '--progress-bar[Specify whether the progress bar should be used]:mode:(auto on off raw)' \
                        '--no-clean[Don'\''t clean up build directories]' \
                        '(-i --index-url)'{-i,--index-url}'[Base URL of the Python Package Index]:url:' \
                        '*--extra-index-url[Extra URLs of package indexes]:url:' \
                        '--no-index[Ignore package index, only look at find-links URLs]' \
                        '*'{-f,--find-links}'[URL or path to look for packages]:url:' \
                        '--uploaded-prior-to[Only consider packages uploaded prior to this date]:datetime:' \
                        '*:packages:'
                    ;;
                hash)
                    _arguments -s \
                        '(-a --algorithm)'{-a,--algorithm}'[The hash algorithm to use]:algorithm:(sha256 sha384 sha512)' \
                        '*:files:_files'
                    ;;
                inspect)
                    _arguments -s \
                        '--local[If in a virtualenv, only list packages installed in the virtualenv]' \
                        '--user[Only output packages installed in user-site]' \
                        '--path[Restrict to the specified installation path]:path:_directories'
                    ;;
                debug)
                    _arguments -s \
                        '--platform[Only use wheels compatible with platform]:platform:' \
                        '--python-version[The Python interpreter version to use]:version:' \
                        '--implementation[Only use wheels compatible with Python implementation]:impl:(cp pp jy ip py)' \
                        '--abi[Only use wheels compatible with Python abi]:abi:'
                    ;;
                completion)
                    _arguments -s \
                        '(-b --bash)'{-b,--bash}'[Emit completion code for bash]' \
                        '(-z --zsh)'{-z,--zsh}'[Emit completion code for zsh]' \
                        '(-f --fish)'{-f,--fish}'[Emit completion code for fish]' \
                        '(-p --powershell)'{-p,--powershell}'[Emit completion code for powershell]'
                    ;;
                help)
                    local -a help_topics
                    help_topics=(
                        install lock download uninstall freeze inspect list show
                        check config search cache index wheel hash completion debug
                    )
                    _arguments '1:command:($help_topics)'
                    ;;
            esac
            ;;
    esac
}

_pip "$@"
