#compdef grep

_arguments -s -S \
  '(-E -F -G -P)'{-E,--extended-regexp}'[interpret pattern as an extended regular expression]' \
  '(-E -F -G -P)'{-F,--fixed-strings}'[interpret pattern as a set of fixed strings]' \
  '(-E -F -G -P)'{-G,--basic-regexp}'[interpret pattern as a basic regular expression (default)]' \
  '(-E -F -G -P)'{-P,--perl-regexp}'[interpret pattern as a Perl-compatible regular expression]' \
  '*'{-e+,--regexp=}'[use PATTERN for matching]:pattern' \
  '*'{-f+,--file=}'[obtain patterns from FILE]:file:_files' \
  {-i,--ignore-case}'[ignore case distinctions in patterns and data]' \
  '(-i --ignore-case)-y[equivalent to -i (obsolete)]' \
  {-w,--word-regexp}'[match only whole words]' \
  {-x,--line-regexp}'[match only whole lines]' \
  {-z,--null-data}'[treat data lines as terminated by NUL, not newline]' \
  {-s,--no-messages}'[suppress error messages about nonexistent or unreadable files]' \
  {-v,--invert-match}'[select non-matching lines]' \
  '(- *)'{-V,--version}'[display version information and exit]' \
  '(- *)--help[display help text and exit]' \
  {-m+,--max-count=}'[stop after NUM selected lines]:number' \
  {-b,--byte-offset}'[print the byte offset with output lines]' \
  {-n,--line-number}'[print line number with output lines]' \
  '--line-buffered[flush output on every line]' \
  '(-h --no-filename)'{-H,--with-filename}'[print file name with output lines]' \
  '(-H --with-filename)'{-h,--no-filename}'[suppress the file name prefix on output]' \
  '--label=[use LABEL as the standard input file name prefix]:label' \
  {-o,--only-matching}'[show only nonempty parts of lines that match]' \
  {-q,--quiet,--silent}'[suppress all normal output]' \
  '--binary-files=[assume that binary files are TYPE]:type:(binary without-match text)' \
  {-a,--text}'[equivalent to --binary-files=text]' \
  '-I[equivalent to --binary-files=without-match]' \
  {-d+,--directories=}'[how to handle directories]:action:(read skip recurse)' \
  {-D+,--devices=}'[how to handle devices, FIFOs and sockets]:action:(read skip)' \
  '(-r --recursive -R --dereference-recursive)'{-r,-R,--recursive,--dereference-recursive}'[recursively search subdirectories]' \
  '*--include=[search only files matching FILE_PATTERN]:pattern' \
  '*--exclude=[skip files matching FILE_PATTERN]:pattern' \
  '--exclude-from=[skip files matching any pattern from FILE]:file:_files' \
  '*--exclude-dir=[skip directories matching PATTERN]:pattern:_directories' \
  '*--include-dir=[search only directories matching PATTERN]:pattern:_directories' \
  {-L,--files-without-match}'[print only names of files with no selected lines]' \
  {-l,--files-with-matches}'[print only names of files with selected lines]' \
  {-c,--count}'[print only a count of selected lines per file]' \
  {-T,--initial-tab}'[make tabs line up (if needed)]' \
  {-Z,--null}'[print NUL byte after file name]' \
  {-B+,--before-context=}'[print NUM lines of leading context]:lines' \
  {-A+,--after-context=}'[print NUM lines of trailing context]:lines' \
  {-C+,--context=}'[print NUM lines of output context]:lines' \
  '--color=-[use markers to highlight matching strings]::when:(never always auto)' \
  '--colour=-[use markers to highlight matching strings]::when:(never always auto)' \
  {-U,--binary}'[do not strip CR characters at EOL]' \
  '-J[decompress bzip2 compressed input before searching]' \
  '-M[decompress LZMA compressed input before searching]' \
  '-X[decompress xz compressed input before searching]' \
  '-Z[decompress gzip compressed input before searching]' \
  '-O[follow symlinks only if on command line (with -R)]' \
  '-p[do not follow symbolic links (default with -R)]' \
  '-S[follow all symbolic links (with -R)]' \
  '--mmap[use mmap instead of read for input]' \
  '1:pattern' \
  '*:file:_files'
