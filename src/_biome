#compdef biome

# Zsh completion for biome (JavaScript/TypeScript/JSON toolchain)

local curcontext="$curcontext" state line ret=1

_biome_check_flags() {
  _arguments -s \
    '--apply[apply safe fixes]' \
    '--apply-unsafe[apply safe and unsafe fixes]' \
    '--changed[only check changed files]' \
    '--since[check files changed since ref]:ref' \
    '--formatter-enabled[enable formatter]:bool:(true false)' \
    '--linter-enabled[enable linter]:bool:(true false)' \
    '--organize-imports-enabled[enable import organizing]:bool:(true false)' \
    '--assists-enabled[enable assists]:bool:(true false)' \
    '--staged[only check staged files]' \
    '--no-errors-on-unmatched[no errors for unmatched files]' \
    '--error-on-warnings[treat warnings as errors]' \
    '--colors[color output]:mode:(off force)' \
    '--use-server[use the daemon server]' \
    '--verbose[verbose output]' \
    '--config-path[path to configuration directory]:directory:_files -/' \
    '--max-diagnostics[max number of diagnostics]:number' \
    '--diagnostic-level[diagnostic level]:level:(info warn error)' \
    '--log-level[log level]:level:(none debug info warn error)' \
    '--log-kind[log kind]:kind:(pretty compact json)' \
    '--vcs-enabled[enable VCS integration]:bool:(true false)' \
    '--vcs-root[VCS root directory]:directory:_files -/' \
    '--vcs-client-kind[VCS client]:kind:(git)' \
    '--vcs-use-ignore-file[use VCS ignore file]:bool:(true false)' \
    '--vcs-default-branch[VCS default branch]:name' \
    '--files-max-size[max file size in bytes]:bytes' \
    '--files-ignore-unknown[ignore unknown files]:bool:(true false)' \
    '--json-formatter-enabled[enable JSON formatter]:bool:(true false)' \
    '--javascript-formatter-quote-style[quote style]:style:(single double)' \
    '--javascript-formatter-jsx-quote-style[JSX quote style]:style:(single double)' \
    '--javascript-formatter-quote-properties[quote properties]:style:(as-needed preserve)' \
    '--javascript-formatter-trailing-commas[trailing commas]:style:(all es5 none)' \
    '--javascript-formatter-semicolons[semicolons]:style:(always as-needed)' \
    '--javascript-formatter-arrow-parentheses[arrow parentheses]:style:(always as-needed)' \
    '--javascript-formatter-indent-style[indent style]:style:(tab space)' \
    '--javascript-formatter-indent-width[indent width]:number' \
    '--javascript-formatter-line-ending[line ending]:ending:(lf crlf cr)' \
    '--javascript-formatter-line-width[line width]:number' \
    '(- *)--help[show help]' \
    '*:files:_files' && ret=0
}

_biome_format_flags() {
  _arguments -s \
    '--write[write formatted output]' \
    '--changed[only format changed files]' \
    '--since[format files changed since ref]:ref' \
    '--staged[only format staged files]' \
    '--no-errors-on-unmatched[no errors for unmatched files]' \
    '--colors[color output]:mode:(off force)' \
    '--use-server[use the daemon server]' \
    '--verbose[verbose output]' \
    '--config-path[path to configuration directory]:directory:_files -/' \
    '--max-diagnostics[max number of diagnostics]:number' \
    '--diagnostic-level[diagnostic level]:level:(info warn error)' \
    '--log-level[log level]:level:(none debug info warn error)' \
    '--log-kind[log kind]:kind:(pretty compact json)' \
    '--javascript-formatter-quote-style[quote style]:style:(single double)' \
    '--javascript-formatter-indent-style[indent style]:style:(tab space)' \
    '--javascript-formatter-indent-width[indent width]:number' \
    '--javascript-formatter-line-ending[line ending]:ending:(lf crlf cr)' \
    '--javascript-formatter-line-width[line width]:number' \
    '--javascript-formatter-trailing-commas[trailing commas]:style:(all es5 none)' \
    '--javascript-formatter-semicolons[semicolons]:style:(always as-needed)' \
    '--javascript-formatter-arrow-parentheses[arrow parentheses]:style:(always as-needed)' \
    '(- *)--help[show help]' \
    '*:files:_files' && ret=0
}

_biome_lint_flags() {
  _arguments -s \
    '--apply[apply safe fixes]' \
    '--apply-unsafe[apply safe and unsafe fixes]' \
    '--changed[only lint changed files]' \
    '--since[lint files changed since ref]:ref' \
    '--staged[only lint staged files]' \
    '--no-errors-on-unmatched[no errors for unmatched files]' \
    '--error-on-warnings[treat warnings as errors]' \
    '--colors[color output]:mode:(off force)' \
    '--use-server[use the daemon server]' \
    '--verbose[verbose output]' \
    '--config-path[path to configuration directory]:directory:_files -/' \
    '--max-diagnostics[max number of diagnostics]:number' \
    '--diagnostic-level[diagnostic level]:level:(info warn error)' \
    '--log-level[log level]:level:(none debug info warn error)' \
    '--log-kind[log kind]:kind:(pretty compact json)' \
    '(- *)--help[show help]' \
    '*:files:_files' && ret=0
}

_biome() {
  local -a commands=(
    'check:run checks on files'
    'lint:run linter on files'
    'format:run formatter on files'
    'ci:run checks for CI'
    'init:initialize biome configuration'
    'migrate:migrate configuration'
    'explain:explain a diagnostic rule'
    'rage:collect debug information'
    'start:start the daemon server'
    'stop:stop the daemon server'
    'lsp-proxy:start LSP proxy'
  )

  _arguments -C \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '--colors[color output]:mode:(off force)' \
    '--use-server[use the daemon server]' \
    '--verbose[verbose output]' \
    '--config-path[path to configuration directory]:directory:_files -/' \
    '--log-level[log level]:level:(none debug info warn error)' \
    '--log-kind[log kind]:kind:(pretty compact json)' \
    '1:command:->command' \
    '*::args:->args' && ret=0

  case $state in
    command)
      _describe -t commands 'biome command' commands && ret=0
      ;;
    args)
      case $words[1] in
        check|ci)
          _biome_check_flags
          ;;
        format)
          _biome_format_flags
          ;;
        lint)
          _biome_lint_flags
          ;;
        init)
          _arguments '--jsonc[use JSONC format]' '(- *)--help[show help]'
          ;;
        migrate)
          _arguments '--write[write migrated config]' '(- *)--help[show help]'
          ;;
        *)
          _arguments '(- *)--help[show help]'
          ;;
      esac
      ;;
  esac

  return ret
}

_biome "$@"
