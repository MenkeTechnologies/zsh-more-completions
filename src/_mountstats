#compdef mountstats
# Documentation: https://man.archlinux.org/search?q=mountstats
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '--version[display the version of this command]'
    '--nfs[display only the NFS statistics]'
    '--rpc[display only the RPC statistics]'
    '--start[sample and save statistics]'
    '--end[resample statistics and compare them with saved]'
    '*:filename:_files'
)

_arguments -s -S $arguments
