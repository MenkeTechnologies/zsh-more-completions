#compdef scrollkeeper-update

local -a arguments

arguments=(
  '-o[use the specified omf directories for indexing]:directory:_directories'
  '-r[use the specified directory for the resulting database]:directory:_directories'
  '-c[rebuild the index entirely]'
  '-v[turn Verbosity on.]'
  '-p[specify a different place to store the mtimes file.]'
  '-q[run silently (default).]'
  '-h[print this help message and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
