#compdef which

# Autogenerated from man page /usr/share/man/man1/which.debianutils.1.gz

local -a arguments

arguments=(
    '-a[print all matching pathnames of each argument.]'
    '-s[silently return 0 if all of the executables were found or 1 otherwise EXIT S…]'
    '*:filename:_files'
)
_arguments -s -S $arguments
