#compdef which which.debianutils
# Documentation: https://man.archlinux.org/search?q=which
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '-a[print all matching pathnames of each argument.]'
    '-s[silently return 0 if all of the executables were found or 1 otherwise EXIT S]'
    '*:filename:_files'
)
_arguments -s -S $arguments
