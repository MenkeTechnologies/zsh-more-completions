#compdef xplsprinters
# Documentation: https://man.archlinux.org/search?q=xplsprinters
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-printer[printer to use]'
  '-l[list detailed printer info]'
  '-dump[dump all available printer attrbutes]'
  '*:filename:_files'
)

_arguments -s -S $arguments
