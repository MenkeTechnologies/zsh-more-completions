#compdef spicedb

# Zsh completion for SpiceDB (permissions database)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'datastore:manage the datastore'
  'head:show the head revision'
  'migrate:run datastore migrations'
  'serve:serve the SpiceDB API'
  'serve-devtools:serve development tools'
  'serve-testing:serve a testing-only SpiceDB server'
  'validate:validate schema files'
  'version:show version information'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'spicedb command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (serve)
        _arguments \
          '--grpc-addr[gRPC listen address]:address:' \
          '--grpc-tls-cert-path[gRPC TLS cert]:file:_files' \
          '--grpc-tls-key-path[gRPC TLS key]:file:_files' \
          '--http-addr[HTTP listen address]:address:' \
          '--metrics-addr[metrics listen address]:address:' \
          '--datastore-engine[datastore engine]:engine:(memory postgres cockroachdb mysql spanner)' \
          '--datastore-conn-uri[datastore connection URI]:uri:' \
          '--datastore-bootstrap-files[bootstrap schema files]:files:_files' \
          '--log-level[log level]:level:(trace debug info warn error fatal panic)' \
          '--log-format[log format]:format:(auto console json)' \
          '--grpc-preshared-key[preshared key]:key:' && ret=0
        ;;
      (migrate)
        _arguments \
          '--datastore-engine[datastore engine]:engine:(postgres cockroachdb mysql spanner)' \
          '--datastore-conn-uri[datastore connection URI]:uri:' \
          '1:migration command:(head)' && ret=0
        ;;
      (validate)
        _arguments '*:schema file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
