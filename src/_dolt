#compdef dolt

# Zsh completion for dolt (Git for Data / SQL database)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add:stage tables to the staging area'
  'blame:show what revision and author last modified rows'
  'branch:create, list, or delete branches'
  'checkout:switch branches or restore working tree tables'
  'cherry-pick:apply changes from existing commits'
  'clean:remove untracked tables'
  'clone:clone a repository'
  'commit:record changes to the repository'
  'conflicts:manage merge conflicts'
  'diff:diff a table'
  'dump:export all tables'
  'fetch:fetch from a remote'
  'filter-branch:edit commit history'
  'gc:clean up unreferenced data'
  'init:create an empty Dolt data repository'
  'log:show commit logs'
  'login:login to a remote host'
  'ls:list tables'
  'merge:join two or more development histories together'
  'migrate:execute a database migration'
  'pull:fetch and merge from a remote'
  'push:push to a remote'
  'read-tables:fetch table data at a specific commit'
  'reflog:show history of named refs'
  'remote:manage remotes'
  'reset:reset staged tables'
  'revert:undo commits'
  'schema:show or modify table schema'
  'sql:run a SQL query'
  'sql-server:start a MySQL-compatible server'
  'stash:stash changes in a dirty working directory'
  'status:show the working tree status'
  'table:table operations'
  'tag:create, list, or delete tags'
  'version:display version'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'dolt command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (sql)
        _arguments \
          '(-q --query)'{-q,--query}'[run a SQL query]:query:' \
          '(-r --result-format)'{-r,--result-format}'[output format]:format:(tabular csv json null vertical parquet)' \
          '(-s --schema)'{-s,--schema}'[run SQL from file]:file:_files -g "*.sql"' \
          '--batch[batch mode]' \
          '--multi-db-dir[directory with multiple databases]:dir:_files -/' \
          '--continue[continue on error]' \
          '--file[execute SQL from file]:file:_files -g "*.sql"' && ret=0
        ;;
      (commit)
        _arguments \
          '(-m --message)'{-m,--message}'[commit message]:message:' \
          '(-a --all)'{-a,--all}'[stage all modified tables]' \
          '--allow-empty[allow empty commit]' \
          '--author[override author]:author:' \
          '--date[override date]:date:' && ret=0
        ;;
      (clone)
        _arguments \
          '(-b --branch)'{-b,--branch}'[branch to clone]:branch:' \
          '--depth[shallow clone depth]:depth:' \
          '--remote[remote name]:name:' \
          '1:remote:' '2:directory:_files -/' && ret=0
        ;;
      (branch)
        _arguments \
          '(-a --all)'{-a,--all}'[list all branches]' \
          '(-d --delete)'{-d,--delete}'[delete branch]' \
          '(-D --force)'{-D,--force}'[force delete branch]' \
          '(-m --move)'{-m,--move}'[rename branch]' \
          '(-c --copy)'{-c,--copy}'[copy branch]' \
          '--show-current[show current branch]' \
          '*:branch:' && ret=0
        ;;
      (diff)
        _arguments \
          '--stat[show diffstat]' \
          '--summary[show summary]' \
          '--data[show data changes]' \
          '--schema[show schema changes]' \
          '(-r --result-format)'{-r,--result-format}'[output format]:format:(tabular json sql)' \
          '--where[SQL WHERE clause]:where:' \
          '--limit[limit rows]:limit:' \
          '*:ref or table:' && ret=0
        ;;
      (log)
        _arguments \
          '(-n --number)'{-n,--number}'[limit log entries]:count:' \
          '--stat[show diffstat]' \
          '--oneline[one line per commit]' \
          '--merges[show only merge commits]' \
          '--parents[show parent hashes]' \
          '--decorate[show ref names]:when:(short full auto no)' \
          '*:ref:' && ret=0
        ;;
      (sql-server)
        _arguments \
          '--host[host to listen on]:host:_hosts' \
          '--port[port to listen on]:port:' \
          '--user[default user]:user:' \
          '--password[default password]:password:' \
          '--timeout-millis[connection timeout]:ms:' \
          '--readonly[run in read-only mode]' \
          '--loglevel[log level]:level:(trace debug info warning error fatal)' \
          '--multi-db-dir[directory with multiple databases]:dir:_files -/' \
          '--config[config file]:file:_files' && ret=0
        ;;
      (remote)
        local -a remote_cmds=('add:add a remote' 'remove:remove a remote' 'rename:rename a remote')
        _arguments '1:remote command:((${(j: :)${remote_cmds// /\\:}}))' '*:args:' && ret=0
        ;;
      (push|pull|fetch)
        _arguments '1:remote:' '2:branch:' && ret=0
        ;;
      (checkout)
        _arguments \
          '(-b)'-b'[create new branch]:branch:' \
          '--track[set up tracking branch]' \
          '*:branch or table:' && ret=0
        ;;
    esac
    ;;
esac

return ret
