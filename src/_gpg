#compdef gpg gpg2

# Zsh completion for GnuPG (gpg/gpg2)

local curcontext="$curcontext" state line expl ret=1

local -a key_ids
_gpg_keys() {
  local -a keys
  keys=( ${${(f)"$(gpg --list-keys --with-colons 2>/dev/null | awk -F: '/^uid/{print $10}')"}:#} )
  _describe -t keys 'key' keys "$@"
}

_gpg_secret_keys() {
  local -a keys
  keys=( ${${(f)"$(gpg --list-secret-keys --with-colons 2>/dev/null | awk -F: '/^uid/{print $10}')"}:#} )
  _describe -t keys 'secret key' keys "$@"
}

