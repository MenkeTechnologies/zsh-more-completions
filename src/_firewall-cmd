#compdef firewall-cmd

# Zsh completion for firewall-cmd (firewalld)

_firewall-cmd_zones() {
    local -a zones
    zones=(${(f)"$(firewall-cmd --get-zones 2>/dev/null)"})
    compadd -a zones
}

_firewall-cmd_services() {
    local -a services
    services=(${(f)"$(firewall-cmd --get-services 2>/dev/null)"})
    compadd -a services
}

_firewall-cmd_icmptypes() {
    local -a icmptypes
    icmptypes=(${(f)"$(firewall-cmd --get-icmptypes 2>/dev/null)"})
    compadd -a icmptypes
}

_firewall-cmd_policies() {
    local -a policies
    policies=(${(f)"$(firewall-cmd --get-policies 2>/dev/null)"})
    compadd -a policies
}

_firewall-cmd() {
    local -a arguments

    arguments=(
        # General options
        '(- *)'{-h,--help}'[print a short help text and exit]'
        '(- *)'{-V,--version}'[print the version string of firewalld]'
        {-q,--quiet}'[do not print status messages]'

        # Status options
        '--state[return and print firewalld state]'
        '--reload[reload firewall and keep state information]'
        '--complete-reload[reload firewall and lose state information]'
        '--runtime-to-permanent[create permanent from runtime configuration]'
        '--check-config[check permanent configuration for errors]'

        # Log denied
        '--get-log-denied[print the log denied value]'
        '--set-log-denied=[set log denied value]:value:(all unicast broadcast multicast off)'

        # Automatic helpers
        '--get-automatic-helpers[print the automatic helpers value]'
        '--set-automatic-helpers=[set automatic helpers value]:value:(yes no system)'

        # Modifier options (used with other options)
        '--permanent[set an option permanently (survives reboot)]'
        '--timeout=[enable an option temporarily]:timeout (e.g. 30s, 5m, 1h):'
        '--zone=[use this zone to set or query options]:zone:_firewall-cmd_zones'
        '--policy=[use this policy to set or query options]:policy:_firewall-cmd_policies'

        # Default zone
        '--get-default-zone[print default zone for connections and interfaces]'
        '--set-default-zone=[set default zone]:zone:_firewall-cmd_zones'

        # Zone information
        '--get-active-zones[print currently active zones with interfaces and sources]'
        '--get-zones[print predefined zones]'
        '--list-all-zones[list everything added for or enabled in all zones]'
        '--info-zone=[print information about a zone]:zone:_firewall-cmd_zones'
        '--path-zone=[print file path of a zone]:zone:_firewall-cmd_zones'

        # Zone management
        '--new-zone=[add a new zone (permanent only)]:zone name:'
        '--new-zone-from-file=[add a new zone from file]:file:_files'
        '--delete-zone=[delete an existing zone (permanent only)]:zone:_firewall-cmd_zones'
        '--load-zone-defaults=[load zone default settings (permanent only)]:zone:_firewall-cmd_zones'
        '--get-target[get the zone target]'
        '--set-target=[set the zone target]:target:(default ACCEPT DROP REJECT)'

        # Zone description
        '--set-description=[set new description to zone]:description:'
        '--get-description[print description for zone]'
        '--set-short=[set new short description to zone]:short description:'
        '--get-short[print short description for zone]'

        # Zone items listing
        '--list-all[list everything added for or enabled in a zone]'

        # Service management
        '--get-services[print predefined services]'
        '--list-services[list services added for a zone]'
        '--add-service=[add a service for a zone]:service:_firewall-cmd_services'
        '--remove-service=[remove a service from a zone]:service:_firewall-cmd_services'
        '--query-service=[return whether service has been added for a zone]:service:_firewall-cmd_services'
        '--info-service=[print information about a service]:service:_firewall-cmd_services'
        '--path-service=[print file path of a service]:service:_firewall-cmd_services'
        '--new-service=[add a new service (permanent only)]:service name:'
        '--new-service-from-file=[add a new service from file (permanent only)]:file:_files'
        '--delete-service=[delete an existing service (permanent only)]:service:_firewall-cmd_services'
        '--load-service-defaults=[load service default settings (permanent only)]:service:_firewall-cmd_services'

        # Port management
        '--list-ports[list ports added for a zone]'
        '--add-port=[add a port and protocol for a zone]:port/protocol (e.g. 80/tcp):'
        '--remove-port=[remove a port and protocol from a zone]:port/protocol:'
        '--query-port=[query whether a port and protocol has been added]:port/protocol:'

        # Protocol management
        '--list-protocols[list protocols added for a zone]'
        '--add-protocol=[add a protocol for a zone]:protocol:'
        '--remove-protocol=[remove a protocol from a zone]:protocol:'
        '--query-protocol=[return whether the protocol has been added]:protocol:'

        # Source port management
        '--list-source-ports[list source ports added for a zone]'
        '--add-source-port=[add a source port and protocol for a zone]:port/protocol:'
        '--remove-source-port=[remove a source port and protocol from a zone]:port/protocol:'
        '--query-source-port=[query whether a source port and protocol has been added]:port/protocol:'

        # ICMP block management
        '--get-icmptypes[print predefined ICMP types]'
        '--list-icmp-blocks[list ICMP type blocks added for a zone]'
        '--add-icmp-block=[add an ICMP block for a zone]:icmptype:_firewall-cmd_icmptypes'
        '--remove-icmp-block=[remove the ICMP block from a zone]:icmptype:_firewall-cmd_icmptypes'
        '--query-icmp-block=[return whether an ICMP block has been added]:icmptype:_firewall-cmd_icmptypes'
        '--add-icmp-block-inversion[enable inversion of ICMP blocks for a zone]'
        '--remove-icmp-block-inversion[disable inversion of ICMP blocks for a zone]'
        '--query-icmp-block-inversion[return whether inversion of ICMP blocks is enabled]'

        # ICMP type management (permanent)
        '--new-icmptype=[add a new ICMP type (permanent only)]:icmptype name:'
        '--new-icmptype-from-file=[add a new ICMP type from file (permanent only)]:file:_files'
        '--delete-icmptype=[delete an existing ICMP type (permanent only)]:icmptype:_firewall-cmd_icmptypes'
        '--load-icmptype-defaults=[load ICMP type default settings (permanent only)]:icmptype:_firewall-cmd_icmptypes'
        '--info-icmptype=[print information about an ICMP type]:icmptype:_firewall-cmd_icmptypes'
        '--path-icmptype=[print file path of an ICMP type (permanent only)]:icmptype:_firewall-cmd_icmptypes'

        # Forward port management
        '--list-forward-ports[list IPv4 forward ports added for a zone]'
        '--add-forward-port=[add IPv4 forward port for a zone]:port\:proto\:toport\:toaddr:'
        '--remove-forward-port=[remove IPv4 forward port from a zone]:port\:proto\:toport\:toaddr:'
        '--query-forward-port=[query whether an IPv4 forward port has been added]:port\:proto\:toport\:toaddr:'

        # Forward (routing)
        '--add-forward[enable intra-zone forwarding for a zone]'
        '--remove-forward[disable intra-zone forwarding for a zone]'
        '--query-forward[return whether intra-zone forwarding is enabled]'

        # Masquerade management
        '--add-masquerade[enable IPv4 masquerade for a zone]'
        '--remove-masquerade[disable IPv4 masquerade for a zone]'
        '--query-masquerade[return whether IPv4 masquerading has been enabled]'

        # Rich rules
        '--list-rich-rules[list rich language rules added for a zone]'
        '--add-rich-rule=[add rich language rule for a zone]:rule:'
        '--remove-rich-rule=[remove rich language rule from a zone]:rule:'
        '--query-rich-rule=[return whether a rich language rule has been added]:rule:'

        # Interface management
        '--list-interfaces[list interfaces bound to a zone]'
        '--add-interface=[bind the interface to a zone]:interface:_net_interfaces'
        '--change-interface=[change zone the interface is bound to]:interface:_net_interfaces'
        '--query-interface=[query whether interface is bound to a zone]:interface:_net_interfaces'
        '--remove-interface=[remove binding of interface from a zone]:interface:_net_interfaces'

        # Source management
        '--list-sources[list sources bound to a zone]'
        '--add-source=[bind the source to a zone]:source (IP or MAC):'
        '--change-source=[change zone the source is bound to]:source:'
        '--query-source=[query whether the source is bound to a zone]:source:'
        '--remove-source=[remove binding of the source from a zone]:source:'
        '--get-zone-of-interface=[print name of the zone the interface is bound to]:interface:_net_interfaces'
        '--get-zone-of-source=[print name of the zone the source is bound to]:source:'

        # IPSet management
        '--get-ipset-types[print the supported ipset types]'
        '--get-ipsets[print predefined ipsets]'
        '--new-ipset=[add a new ipset (permanent only)]:ipset name:'
        '--type=[specify ipset type]:type:(hash\:ip hash\:ip,port hash\:ip,port,ip hash\:ip,port,net hash\:ip,mark hash\:net hash\:net,net hash\:net,port hash\:net,port,net hash\:net,iface hash\:mac)'
        '--option=[specify ipset option]:option:'
        '--new-ipset-from-file=[add a new ipset from file (permanent only)]:file:_files'
        '--delete-ipset=[delete an existing ipset (permanent only)]:ipset:'
        '--load-ipset-defaults=[load ipset default settings (permanent only)]:ipset:'
        '--info-ipset=[print information about an ipset]:ipset:'
        '--path-ipset=[print file path of an ipset (permanent only)]:ipset:'
        '--ipset=[specify ipset for entry operations]:ipset:'
        '--add-entry=[add an entry to an ipset]:entry:'
        '--remove-entry=[remove an entry from an ipset]:entry:'
        '--query-entry=[return whether ipset has an entry]:entry:'
        '--get-entries[list entries of an ipset]'
        '--add-entries-from-file=[add entries to an ipset from file]:file:_files'
        '--remove-entries-from-file=[remove entries from an ipset from file]:file:_files'

        # Helper management
        '--get-helpers[print predefined helpers]'
        '--new-helper=[add a new helper (permanent only)]:helper name:'
        '--module=[specify kernel module for helper]:module:'
        '--family=[specify protocol family for helper]:family:(ipv4 ipv6)'
        '--new-helper-from-file=[add a new helper from file (permanent only)]:file:_files'
        '--delete-helper=[delete an existing helper (permanent only)]:helper:'
        '--load-helper-defaults=[load helper default settings (permanent only)]:helper:'
        '--info-helper=[print information about a helper]:helper:'
        '--path-helper=[print file path of a helper (permanent only)]:helper:'
        '--helper=[specify helper for operations]:helper:'

        # Policy management
        '--get-policies[print predefined policies]'
        '--list-all-policies[list everything added for or enabled in all policies]'
        '--new-policy=[add a new policy (permanent only)]:policy name:'
        '--new-policy-from-file=[add a new policy from file (permanent only)]:file:_files'
        '--delete-policy=[delete an existing policy (permanent only)]:policy:'
        '--load-policy-defaults=[load policy default settings (permanent only)]:policy:'
        '--info-policy=[print information about a policy]:policy:_firewall-cmd_policies'
        '--path-policy=[print file path of a policy (permanent only)]:policy:'
        '--set-priority=[set the priority for a policy]:priority:'
        '--get-priority[get the priority for a policy]'
        '--add-ingress-zone=[add an ingress zone for a policy]:zone:'
        '--remove-ingress-zone=[remove an ingress zone from a policy]:zone:'
        '--query-ingress-zone=[query whether an ingress zone has been added]:zone:'
        '--list-ingress-zones[list ingress zones for a policy]'
        '--add-egress-zone=[add an egress zone for a policy]:zone:'
        '--remove-egress-zone=[remove an egress zone from a policy]:zone:'
        '--query-egress-zone=[query whether an egress zone has been added]:zone:'
        '--list-egress-zones[list egress zones for a policy]'

        # Direct interface (deprecated)
        '--direct[first option for all direct options]'
        '--get-all-chains[get all chains]'
        '--get-chains=[get all chains added to the table]:ipv table:'
        '--add-chain=[add a new chain to the table]:ipv table chain:'
        '--remove-chain=[remove a chain from the table]:ipv table chain:'
        '--query-chain=[return whether a chain has been added]:ipv table chain:'
        '--get-all-rules[get all rules]'
        '--get-rules=[get all rules added to chain in table]:ipv table chain:'
        '--add-rule=[add a rule to chain in table with priority]:ipv table chain priority args:'
        '--remove-rule=[remove a rule from chain in table]:ipv table chain args:'
        '--remove-rules=[remove all rules from chain in table]:ipv table chain:'
        '--query-rule=[return whether a rule has been added]:ipv table chain priority args:'
        '--passthrough=[pass a command through to the firewall backend]:ipv args:'
        '--get-all-passthroughs[get all tracked passthrough rules]'
        '--get-passthroughs=[get tracked passthrough rules for ipv value]:ipv:(ipv4 ipv6 eb)'
        '--add-passthrough=[add a passthrough rule]:ipv args:'
        '--remove-passthrough=[remove a passthrough rule]:ipv args:'
        '--query-passthrough=[return whether a passthrough rule has been added]:ipv args:'

        # Lockdown
        '--lockdown-on[enable lockdown]'
        '--lockdown-off[disable lockdown]'
        '--query-lockdown[query whether lockdown is enabled]'

        # Lockdown whitelist - commands
        '--list-lockdown-whitelist-commands[list all command lines that are on the whitelist]'
        '--add-lockdown-whitelist-command=[add the command to the whitelist]:command:'
        '--remove-lockdown-whitelist-command=[remove the command from the whitelist]:command:'
        '--query-lockdown-whitelist-command=[query whether the command is on the whitelist]:command:'

        # Lockdown whitelist - contexts
        '--list-lockdown-whitelist-contexts[list all contexts that are on the whitelist]'
        '--add-lockdown-whitelist-context=[add the context to the whitelist]:context:'
        '--remove-lockdown-whitelist-context=[remove the context from the whitelist]:context:'
        '--query-lockdown-whitelist-context=[query whether the context is on the whitelist]:context:'

        # Lockdown whitelist - UIDs
        '--list-lockdown-whitelist-uids[list all user IDs that are on the whitelist]'
        '--add-lockdown-whitelist-uid=[add the user ID to the whitelist]:uid:'
        '--remove-lockdown-whitelist-uid=[remove the user ID from the whitelist]:uid:'
        '--query-lockdown-whitelist-uid=[query whether the user ID is on the whitelist]:uid:'

        # Lockdown whitelist - users
        '--list-lockdown-whitelist-users[list all user names that are on the whitelist]'
        '--add-lockdown-whitelist-user=[add the user name to the whitelist]:user:_users'
        '--remove-lockdown-whitelist-user=[remove the user name from the whitelist]:user:_users'
        '--query-lockdown-whitelist-user=[query whether the user name is on the whitelist]:user:_users'

        # Panic mode
        '--panic-on[enable panic mode (drop all packets)]'
        '--panic-off[disable panic mode]'
        '--query-panic[query whether panic mode is enabled]'
    )

    _arguments -s -S $arguments
}

_firewall-cmd "$@"
