#compdef foot

# Zsh completion for foot (Wayland terminal emulator)

_arguments -s \
  '(-c --config)'{-c,--config}'[configuration file]:file:_files' \
  '(-C --check-config)'{-C,--check-config}'[check configuration and exit]' \
  '(-f --font)'{-f,--font}'[font specification]:font' \
  '--fontconfig-custom-order[use custom fontconfig order]' \
  '(-t --term)'{-t,--term}'[terminfo entry]:terminfo' \
  '(-T --title)'{-T,--title}'[window title]:title' \
  '(-a --app-id)'{-a,--app-id}'[application ID]:id' \
  '(-m --maximized)'{-m,--maximized}'[start maximized]' \
  '(-F --fullscreen)'{-F,--fullscreen}'[start fullscreen]' \
  '(-L --login-shell)'{-L,--login-shell}'[start as login shell]' \
  '(-D --working-directory)'{-D,--working-directory}'[working directory]:directory:_files -/' \
  '(-w --window-size-pixels)'{-w,--window-size-pixels}'[window size in pixels (WxH)]:size' \
  '(-W --window-size-chars)'{-W,--window-size-chars}'[window size in characters (WxH)]:size' \
  '(-s --server)'{-s,--server}'[server socket path]:socket:_files' \
  '(-H --hold)'{-H,--hold}'[hold terminal open after exit]' \
  '(-N --no-hold)'{-N,--no-hold}'[do not hold terminal open]' \
  '(-p --print-pid)'{-p,--print-pid}'[print PID to file descriptor]:fd' \
  '(-d --log-level)'{-d,--log-level}'[log level]:level:(info warning error none)' \
  '--log-colorize[colorize log output]:mode:(auto always never)' \
  '--log-no-syslog[disable syslog logging]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*'{-e,--override}'[override setting]:setting' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:command:_command_names -e'
