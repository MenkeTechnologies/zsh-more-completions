#compdef zdb

local -a arguments

arguments=(
  '-b[display block statistics]'
  '-c[verify all metadata (twice for all data) blocks]'
  '-C[display configuration (or cachefile if alone)]'
  '-d[display dataset(s)]'
  '-D[display dedup statistics]'
  '-E[decode and display block from an embedded block pointer]'
  '-h[display pool history]'
  '-i[display intent logs]'
  '-l[display label contents]'
  '-k[examine the checkpointed state of the pool]'
  '-L[disable leak tracking (do not load spacemaps)]'
  '-m[display metaslab info]'
  '-M[display metaslab groups]'
  '-O[perform object lookups by path]'
  '-R[read and display block from a device]'
  '-s[report stats on zdbs I/O]'
  '-S[simulate dedup to measure effect]'
  '-v[verbose (applies to all others)]'
  '-A[ignore assertions (-A), enable panic recovery (-AA) or both (-AAA)]'
  '-e[pool is exported/destroyed/has altroot/not in a cachefile]'
  '-F[attempt automatic rewind within safe range of transaction groups]'
  '-G[dump zfs_dbgmsg buffer before exiting]'
  '-I[specify the maximum number of checksumming I/Os \[default is 200\]]:max-inflight:'
  '-o[set global variable to an unsigned 32-bit integer value]:var=value:'
  '-p[specify path to vdev dir (one or more with -e)]:path:_directories'
  '-P[print numbers in parseable form]'
  '-q[quiet, do not print label contents]'
  '-t[txg to use when searching for uberblocks]:txg:'
  '-u[display uberblock info]'
  '-U[specify alternate cachefile]:cachefile:_files'
  '-V[do verbatim import]'
  '-x[dump all read blocks into specified directory]:dir:_directories'
  '-X[attempt extreme rewind (does not work with dataset)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
