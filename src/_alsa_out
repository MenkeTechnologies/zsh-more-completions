#compdef alsa_out

local -a arguments

arguments=(
  '-j[name> - client name]'
  '-d[delete or directory]'
  '-c[configuration file]'
  '-p[prefix or port]'
  '-n[number of periods]'
  '-r[reverse or recursive]'
  '-q[quality \[0..4\]]'
  '-m[mode or machine]'
  '-t[type or time]'
  '-i[turns on instrumentation]'
  '-v[turns on printouts]'
  '*:filename:_files'
)

_arguments -s -S $arguments
