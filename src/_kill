#compdef kill

# Zsh completion for kill - terminate or signal a process
# Supports both BSD/macOS and GNU/Linux (util-linux) variants

local -a signals
signals=(
  'HUP:hangup'
  'INT:interrupt'
  'QUIT:quit'
  'ILL:illegal instruction'
  'TRAP:trace trap'
  'ABRT:abort'
  'EMT:emulate instruction executed'
  'FPE:floating point exception'
  'KILL:kill (cannot be caught or ignored)'
  'BUS:bus error'
  'SEGV:segmentation fault'
  'SYS:bad system call'
  'PIPE:broken pipe'
  'ALRM:alarm clock'
  'TERM:software termination signal'
  'URG:urgent condition on IO channel'
  'STOP:stop (cannot be caught or ignored)'
  'TSTP:terminal stop signal'
  'CONT:continue'
  'CHLD:child status changed'
  'TTIN:background read from control terminal'
  'TTOU:background write to control terminal'
  'IO:I/O possible'
  'XCPU:CPU time limit exceeded'
  'XFSZ:file size limit exceeded'
  'VTALRM:virtual timer expired'
  'PROF:profiling timer expired'
  'WINCH:window size change'
  'INFO:information request'
  'USR1:user-defined signal 1'
  'USR2:user-defined signal 2'
)

_kill_signals() {
  _describe -t signals 'signal' signals
}

local arguments

arguments=(
  # Common POSIX / BSD options
  '-s[send specified signal instead of SIGTERM]:signal:_kill_signals'
  '-l[list signal names, or convert signal number to name]::exit status:'

  # GNU/Linux (util-linux) long options
  '(-s --signal)'{-s,--signal}'[send specified signal instead of SIGTERM]:signal:_kill_signals'
  '(-l --list)'{-l,--list}'[list signal names, or convert signal number to name]::exit status:'
  {-L,--table}'[list signal names and numbers in a table]'
  {-a,--all}'[do not restrict name-to-PID conversion to processes with same UID]'
  {-p,--pid}'[print PIDs without sending a signal]'
  '(-q --queue)'{-q,--queue}'[send signal using sigqueue with specified value]:value:'
  '--verbose[print PIDs that will be signaled]'
  '--timeout[wait specified milliseconds before sending follow-up signal]:timeout (ms): :signal:_kill_signals'
  '(- *)'{-h,--help}'[display help]'
  '(- *)'{-V,--version}'[display version]'

  '*:process ID or name:_pids'
)

_arguments -s -S $arguments
