#compdef subfinder

# Zsh completion for subfinder - subdomain discovery tool

_arguments -s -S \
  '(-d --domain)'{-d,--domain}'[domain to find subdomains for]:domain:' \
  '(-dL --list)'{-dL,--list}'[file containing list of domains]:file:_files' \
  '(-s --sources)'{-s,--sources}'[specific sources to use]:sources:' \
  '(-recursive --recursive)--recursive[use only recursive sources]' \
  '(-all --all)--all[use all sources (slow)]' \
  '(-es --exclude-sources)'{-es,--exclude-sources}'[sources to exclude from enumeration]:sources:' \
  '(-m --match)'{-m,--match}'[subdomain or list of subdomains to match]:subdomain:' \
  '(-f --filter)'{-f,--filter}'[subdomain or list of subdomains to filter]:subdomain:' \
  '(-rl --rate-limit)'{-rl,--rate-limit}'[maximum number of HTTP requests per second]:rate:' \
  '(-t --timeout)'{-t,--timeout}'[seconds to wait before timing out]:seconds:' \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '(-oJ --json)'{-oJ,--json}'[write output in JSONL format]' \
  '(-oD --output-dir)'{-oD,--output-dir}'[output directory]:dir:_files -/' \
  '(-cs --collect-sources)'{-cs,--collect-sources}'[include all sources in the output]' \
  '(-oI --ip)'{-oI,--ip}'[include host IP in output]' \
  '(-config --config)--config[flag config file]:file:_files' \
  '(-pc --provider-config)'{-pc,--provider-config}'[provider config file]:file:_files' \
  '(-r --resolvers)'{-r,--resolvers}'[list of resolvers to use]:resolvers:' \
  '(-rL --resolver-list)'{-rL,--resolver-list}'[file containing list of resolvers]:file:_files' \
  '(-nW --active)'{-nW,--active}'[display active subdomains only]' \
  '(-proxy --proxy)--proxy[HTTP proxy to use with subfinder]:proxy:' \
  '(-ei --exclude-ip)'{-ei,--exclude-ip}'[exclude IPs from the domain list]' \
  '(-silent --silent)--silent[show only subdomains in output]' \
  '(-version --version)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[show verbose output]' \
  '(-nc --no-color)'{-nc,--no-color}'[disable color in output]' \
  '(-ls --list-sources)'{-ls,--list-sources}'[list all available sources]' \
  '(-h --help)'{-h,--help}'[show help]'
