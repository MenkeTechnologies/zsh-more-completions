#compdef ibv_asyncwatch
# Documentation: https://man.archlinux.org/search?q=ibv_asyncwatch
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-d,--ib-dev}'[use IB device <dev> (default first device found)]'
  {-h,--help}'[print a help text and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
