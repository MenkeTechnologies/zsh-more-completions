#compdef nmixer
# Documentation: https://man.archlinux.org/search?q=nmixer
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-d[device Mixer hardware device (default = /dev/mixer)]'
  '-q[quit program (combine with -s)]'
  '-s[dev=vol Set volume for mixer device]'
  '*:filename:_files'
)

_arguments -s -S $arguments
