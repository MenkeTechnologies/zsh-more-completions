#compdef tiff2pdf

local -a arguments

arguments=(
  '-o[output to file name]:file:_files'
  '-j[compress with JPEG]'
  '-z[compress with Zip/Deflate]'
  '-q[compression quality]:quality:'
  '-n[no compressed data passthrough]'
  '-d[do not compress (decompress)]'
  '-i[invert colors]'
  '-u[set distance unit, i for inch, m for centimeter]:unit:(i m)'
  '-x[set x resolution default in dots per unit]:resolution:'
  '-y[set y resolution default in dots per unit]:resolution:'
  '-w[width in units]:width:'
  '-l[length in units]:length:'
  '-r[d for resolution default, o for resolution override]:mode:(d o)'
  '-p[paper size, eg "letter", "legal", "A4"]:size:'
  '-F[make the tiff fill the PDF page]'
  '-f[set PDF "Fit Window" user preference]'
  '-e[date, overrides image or current date/time default]:date:'
  '-c[sets document creator, overrides image software default]:creator:'
  '-a[sets document author, overrides image artist default]:author:'
  '-t[sets document title, overrides image document name default]:title:'
  '-s[sets document subject, overrides image description default]:subject:'
  '-k[sets document keywords]:keywords:'
  '-b[set PDF "Interpolate" user preference]'
  '-h[usage]'
  '*:filename:_files'
)

_arguments -s -S $arguments
