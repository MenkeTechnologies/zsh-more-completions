#compdef rtx

# Zsh completion for rtx (runtime executor, now mise)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'activate:initialize rtx in the shell'
  'alias:manage aliases'
  'bin-paths:list all bin paths'
  'cache:manage the cache'
  'completion:generate shell completions'
  'current:show current active versions'
  'deactivate:disable rtx'
  'direnv:interact with direnv'
  'doctor:check rtx installation for problems'
  'env:export environment variables'
  'exec:execute a command with rtx environment'
  'global:set global tool version'
  'hook-env:called by shell hook to update env vars'
  'implode:remove all rtx data'
  'install:install a tool version (alias: i)'
  'latest:get the latest version of a plugin'
  'link:symlink a tool version'
  'local:set local tool version'
  'ls:list installed and active tool versions'
  'ls-remote:list available versions for a plugin'
  'plugins:manage plugins'
  'prune:remove unused tool versions'
  'reshim:rebuilds shims'
  'self-update:update rtx itself'
  'settings:manage settings'
  'shell:set tool version in current shell'
  'sync:sync tools with other version managers'
  'trust:marks a config file as trusted'
  'uninstall:uninstall a tool version'
  'upgrade:upgrade installed tool versions'
  'use:set active tool version'
  'version:print rtx version'
  'where:show install path of a version'
  'which:show the path that a command resolves to'
)

_arguments -s -S \
  '(-C --cd)'{-C,--cd}'[change directory]:dir:_files -/' \
  '(-q --quiet)'{-q,--quiet}'[suppress non-error output]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-y --yes)'{-y,--yes}'[answer yes to all prompts]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--log-level[log level]:level:(error warn info debug trace)' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'rtx command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (install|i)
        _arguments \
          '(-f --force)'{-f,--force}'[force reinstall]' \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '*:tool@version:' && ret=0
        ;;
      (use)
        _arguments \
          '(-g --global)'{-g,--global}'[use globally]' \
          '(-f --force)'{-f,--force}'[force install if needed]' \
          '--pin[pin the version]' \
          '--fuzzy[use fuzzy matching]' \
          '--remove[remove the tool]' \
          '--path[specify a path to a .tool-versions file]:file:_files' \
          '*:tool@version:' && ret=0
        ;;
      (uninstall)
        _arguments \
          '--all[uninstall all versions]' \
          '*:tool@version:' && ret=0
        ;;
      (ls)
        _arguments \
          '--current[only show current versions]' \
          '--installed[only show installed versions]' \
          '--json[output as JSON]' \
          '--missing[only show missing versions]' \
          '--prefix[filter by prefix]:prefix:' \
          '*:plugin:' && ret=0
        ;;
      (plugins)
        local -a plugin_cmds=('install:install a plugin' 'link:symlink a plugin' 'ls:list plugins' 'ls-remote:list available plugins' 'uninstall:uninstall a plugin' 'update:update plugins')
        _arguments '1:plugins command:((${(j: :)${plugin_cmds// /\\:}}))' '*:args:' && ret=0
        ;;
      (exec)
        _arguments \
          '(-c --command)'{-c,--command}'[command to run]:command:' \
          '*:tool@version:' \
          '--:command and args:_command_names -e' && ret=0
        ;;
      (global|local|shell)
        _arguments \
          '--pin[pin the version]' \
          '--fuzzy[use fuzzy matching]' \
          '--remove[remove the tool]' \
          '*:tool@version:' && ret=0
        ;;
    esac
    ;;
esac

return ret
