#compdef devio
# Documentation: https://man.archlinux.org/search?q=devio
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-v[do not write, just verify a previous write]'
  '-p[output a progress indicator on write]'
  '-h[output this help]'
  '-h[output command help]'
  '-h[output help for command <command>]'
  '*:filename:_files'
)

_arguments -s -S $arguments
