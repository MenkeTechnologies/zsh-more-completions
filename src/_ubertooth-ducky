#compdef ubertooth-ducky
# Documentation: https://man.archlinux.org/search?q=ubertooth-ducky
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-q[quack!]'
  '-b[uberducky to enter bootloader]'
  '-A[advertising channel index (default: 38)]'
  '-a[Bluetooth address (default: random)]:address:'
  '-h[help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
