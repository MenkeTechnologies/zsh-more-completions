#compdef lint

local -a arguments

arguments=(
    '(- * :)--help[show this message]'
    '--list[list the available issue ids and exit]'
    '--version[output version information and exit]'
    '--exitcode[set the exit code to 1 if errors are found]'
    '--show[list available issues along with full explanations]'
    '--disable[disable the list of categories or specific issue ids]:ids:'
    '--enable[enable the specific list of issues]:ids:'
    '--check[only check the specific list of issues]:ids:'
    {-w,--nowarn}'[only check for errors (ignore warnings)]'
    '-Wall[check all warnings, including those off by default]'
    '-Werror[treat all warnings as errors]'
    '--config[use the given configuration file to determine active issues]:file:_files'
    '--baseline[use (or create) the given baseline file to filter out known issues]:file:_files'
    '--quiet[dont show progress]'
    '--fullpath[use full paths in the error output]'
    '--showall[do not truncate long messages or lists of alternates]'
    '--nolines[do not include the source file lines with error messages]'
    '--html[create an HTML report instead]:file:_files'
    '--url[add links to HTML report, replacing local path prefixes with url prefix]:url:'
    '--simplehtml[create a simple HTML report]'
    '--xml[create an XML report instead]'
    '--project[use the given project layout descriptor file]:file:_files'
    '--resources[add the given folder (or path) as a resource directory]:dir:_files -/'
    '--sources[add the given folder (or path) as a source directory]:dir:_files -/'
    '--classpath[add the given folder (or jar file, or path) as a class path entry]:path:_files'
    '--libraries[add the given folder (or jar file, or path) as a library]:path:_files'
    '--compile-sdk-version[use the given compileSdkVersion to pick an API database]:version:'
    '--sdk-home[use the given SDK instead of attempting to find it automatically]:dir:_files -/'
    '*:filename:_files'
)

_arguments -s -S $arguments
