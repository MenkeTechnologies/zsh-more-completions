#compdef pcsc_scan
# Documentation: https://man.archlinux.org/search?q=pcsc_scan
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[this help]'
  '-V[print version number]'
  '-n[no ATR analysis]'
  '-r[only lists readers]'
  '-s[stress mode]'
  '-q[quiet mode]'
  '-v[verbose mode (default)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
