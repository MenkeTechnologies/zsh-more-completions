#compdef xev
# Documentation: https://man.archlinux.org/search?q=xev
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-display[X server to contact]'
  '-geometry[size and location of window]'
  '-bw[border width in pixels]'
  '-bs[whenMapped,Always} backingstore attribute]'
  '-id[use existing window]'
  '-root[use root window]'
  '-s[set save-unders attribute]'
  '-name[window name]'
  '-rv[reverse video]'
  '-event[select event_mask events]'
  '*:filename:_files'
)

_arguments -s -S $arguments
