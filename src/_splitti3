#compdef splitti3
# Documentation: https://man.archlinux.org/search?q=splitti3
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-v[verbose - print each patch value]'
  '-n[put no sets in first file, and balance in second file.]'
  '-p[put percent% sets in first file, and balance in second file. (def. 50%)]'
  '-w[put white patches in both files.]'
  '-r[use given random seed.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
