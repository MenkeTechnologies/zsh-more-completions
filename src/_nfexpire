#compdef nfexpire
# Documentation: https://raw.githubusercontent.com/phaag/nfdump/master/man/nfexpire.1
# Reference accessed: 2026-05-30
# nfexpire — expire and manage nfdump flow files by size/age/watermark.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)-h[print help and exit]' \
  '-l+[directory to list stats from]:dir:_directories' \
  '-r+[directory to rescan]:dir:_directories' \
  '-e+[directory to expire data in]:dir:_directories' \
  '-s+[max size (b/k/m/g/t suffixes for bytes/kilo/mega/giga/tera)]:maxsize:' \
  '-t+[max lifetime (w/d/H/M for weeks/days/hours/minutes)]:maxlife:' \
  '-w+[low watermark (% for expire)]:percent:' \
  '-T+[expected runtime (limits how long to spend expiring)]:runtime:' \
  '-u+[update expire params from collector log at PATH]:path:_directories' \
  '-p[print profile statistics]' \
  '-Y[answer yes to all confirmations]' \
  && ret=0

return ret
