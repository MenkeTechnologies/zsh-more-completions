#compdef hald

local -a arguments

arguments=(
  '--daemon[become a daemon]'
  '--verbose[print out debug (overrides HALD_VERBOSE)]'
  '--retain-privileges[retain privileges (for debugging)]'
  '--child-timeout[set the timeout for the child prober]:timeout:'
  '--use-syslog[print out debug messages to syslog instead of stderr]'
  '--help[show this information and exit]'
  '--version[output version information and exit]'
  '--exit-after-probing[exit when probing is complete]'
  '*:filename:_files'
)

_arguments -s -S $arguments
