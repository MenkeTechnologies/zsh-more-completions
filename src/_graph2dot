#compdef graph2dot
# Documentation: https://man.archlinux.org/search?q=graph2dot
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-i[set INFILE as input file, stdin if omitted]'
  '-o[set OUTFILE as output file, stdout if omitted]'
  '-h[print this help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
