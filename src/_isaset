#compdef isaset
# Documentation: https://man.archlinux.org/search?q=isaset
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-f[enable flat address space mode]'
  '-y[assume affirmative answer to all questions]'
  '-W[write a word (16-bit) value]'
  '-L[write a long (32-bit) value]'
  '*:filename:_files'
)

_arguments -s -S $arguments
