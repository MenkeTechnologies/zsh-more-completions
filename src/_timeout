#compdef timeout

# Zsh completion for timeout (GNU coreutils)

_timeout() {
  local -a arguments

  arguments=(
    '(-f --foreground)'{-f,--foreground}'[when not running timeout directly from a shell prompt, allow COMMAND to read from the TTY and get TTY signals]'
    '(-k --kill-after)'{-k,--kill-after}'[also send a KILL signal if COMMAND is still running this long after the initial signal]:duration:'
    '(-p --preserve-status)'{-p,--preserve-status}'[exit with the same status as COMMAND, even when the command times out]'
    '(-s --signal)'{-s,--signal}'[specify the signal to be sent on timeout]:signal:_signals'
    '(-v --verbose)'{-v,--verbose}'[diagnose to standard error any signal sent upon timeout]'
    '(- *)--help[display help and exit]'
    '(- *)--version[output version information and exit]'
    '1:duration (number with optional suffix s/m/h/d):'
    '*:command:_normal'
  )

  _arguments -s -S $arguments
}

_timeout "$@"
