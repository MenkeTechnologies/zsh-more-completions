#compdef gacutil2
# Documentation: https://man.archlinux.org/search?q=gacutil2
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-i[\[-check_refs\] \[-package NAME\] \[-root ROOTDIR\] \[-gacdir GACDIR\]]'
  '-il[\[-check_refs\] \[-package NAME\] \[-root ROOTDIR\] \[-gacdir GACDIR\]]'
  '-u[\[-package NAME\] \[-root ROOTDIR\] \[-gacdir GACDIR\]]'
  '-ul[\[-package NAME\] \[-root ROOTDIR\] \[-gacdir GACDIR\]]'
  '-us[\[-package NAME\] \[-root ROOTDIR\] \[-gacdir GACDIR\]]'
  '-l[\[-root ROOTDIR\] \[-gacdir GACDIR\]]'
  '-package[create a directory in prefix/lib/mono with the given name]:name'
  '-gacdir[specify the GACs base directory]:directory:_directories'
  '-root[specify root directory for packaging tools]:directory:_directories'
  '-check_refs[check assembly references before installing]'
  '-f[force installation (ignored for compatibility)]'
  '-r[<description>]:reference_id:'
  '*:filename:_files'
)

_arguments -s -S $arguments
