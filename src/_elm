#compdef elm

# Zsh completion for elm (Elm programming language)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:start an Elm project'
  'repl:open up an interactive programming session'
  'reactor:start a development server (alias: make --output=...)'
  'make:compile an Elm file'
  'install:install an Elm package'
  'diff:get diffs between package versions'
  'bump:bump Elm package version'
  'publish:publish an Elm package'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'elm command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (make)
        _arguments \
          '--output[output file]:file:_files' \
          '--optimize[turn on optimizations]' \
          '--debug[turn on time-traveling debugger]' \
          '--docs[generate JSON docs]:file:_files' \
          '--report[error reporting format]:format:(normal json)' \
          '*:elm file:_files -g "*.elm"' && ret=0
        ;;
      (install)
        _arguments '1:package:' && ret=0
        ;;
      (diff)
        _arguments '1:package:' '2:version:' '3:version:' && ret=0
        ;;
      (repl)
        _arguments \
          '--interpreter[path to node]:path:_files' \
          '--no-colors[turn off colors]' && ret=0
        ;;
    esac
    ;;
esac

return ret
