#compdef plookup

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[this help message]'
  {-v,--verbose}'[enable typical debug options]'
  {-V,--version}'[print version and exit]'
  '--pmixmca[set MCA parameter value]:param:value'
  '--pid[PID of the daemon to connect to]:pid'
  '--tmpdir[set the root for the session directory tree]:dir:_directories'
  '--timeout[max number of seconds to wait for data to become available]:seconds'
  '--wait[wait for data to be available]'
  '*:filename:_files'
)

_arguments -s -S $arguments
