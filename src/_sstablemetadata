#compdef sstablemetadata
# Documentation: https://man.archlinux.org/search?q=sstablemetadata
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--gc_grace_seconds[the gc_grace_seconds to use when calculating tombstone purgeability]:seconds'
  '*:filename:_files'
)

_arguments -s -S $arguments
