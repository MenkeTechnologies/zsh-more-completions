#compdef comedi_soft_calibrate
# Documentation: https://man.archlinux.org/search?q=comedi_soft_calibrate
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--help[produce this help message and exit]'
  {-f,--file}'[arg (=/dev/comedi0) device file]'
  {-S,--save-file}'[arg calibration save file]'
  '*:filename:_files'
)

_arguments -s -S $arguments
