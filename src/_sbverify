#compdef sbverify
# Documentation: https://man.archlinux.org/search?q=sbverify
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--cert[certificate (x509 certificate)]'
  '--no-verify[dont perform certificate verification]'
  '--detached[read signature from <file>, instead of]'
  '*:filename:_files'
)

_arguments -s -S $arguments
