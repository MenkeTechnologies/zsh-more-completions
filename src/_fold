#compdef fold gfold
# Documentation: https://man.archlinux.org/search?q=fold
# Reference accessed: 2026-05-16

# Zsh completion for fold (GNU coreutils and BSD)

_fold() {
  local -a args

  args=(
    {-b,--bytes}'[count bytes rather than columns]'
    {-c,--characters}'[count characters rather than columns]'
    {-s,--spaces}'[break at spaces]'
    {-w+,--width=}'[use WIDTH columns instead of 80]:width'
    '(- *)--help[display help and exit]'
    '(- *)--version[output version information and exit]'
    '*:file:_files'
  )

  _arguments -s -S $args
}

_fold "$@"
