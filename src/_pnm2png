#compdef pnm2png
# Documentation: https://man.archlinux.org/search?q=pnm2png
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-i[write png-file with interlacing on]'
  '-a[<file>.pgm read PNG alpha channel as pgm-file]'
  '-h[-\?  print this help-information]'
  '*:filename:_files'
)

_arguments -s -S $arguments
