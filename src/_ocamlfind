#compdef ocamlfind

local curcontext="$curcontext" state state_descr line
typeset -A opt_args

local -a subcommands
subcommands=(
    'list:list installed packages'
    'query:query package properties'
    'ocamlc:invoke ocamlc with package options'
    'ocamlopt:invoke ocamlopt with package options'
    'ocamldep:invoke ocamldep with package options'
    'ocamldoc:invoke ocamldoc with package options'
    'ocamlmktop:invoke ocamlmktop with package options'
    'ocamlcp:invoke ocamlcp with package options'
    'install:install a package'
    'remove:remove a package'
    'printconf:print configuration'
    'pkg:print package directory'
)

_arguments -s -S \
    '1:subcommand:->subcmd' \
    '*::arguments:->args'

case $state in
    subcmd)
        _describe -t subcommands 'ocamlfind subcommand' subcommands
        ;;
    args)
        case $words[1] in
            query)
                _arguments \
                    '-package[query package]:package' \
                    '-predicates[set predicates]:predicates' \
                    '-format[output format]:format' \
                    '-recursive[include dependencies]' \
                    '-long-format[long output format]' \
                    '-i-format[print include flags]' \
                    '-l-format[print link flags]' \
                    '-a-format[print archive flags]' \
                    '-o-format[print linker options]' \
                    '-p-format[print preprocessor flags]' \
                    '-d[list direct dependencies only]' \
                    '-descendants[list descendants]' \
                    '*:package name:'
                ;;
            list)
                _arguments \
                    '-describe[show descriptions]'
                ;;
            ocamlc|ocamlopt|ocamldep|ocamldoc|ocamlmktop)
                _arguments \
                    '-package[use package]:package' \
                    '-linkpkg[link packages into output]' \
                    '-predicates[add predicates]:predicates' \
                    '-syntax[use syntax extension]:syntax:(camlp4o camlp4r camlp5o camlp5r)' \
                    '-ppopt[preprocessor option]:option' \
                    '-dontlink[do not link package]:package' \
                    '-verbose[verbose output]' \
                    '*:source file:_files -g "*.{ml,mli,cmo,cma,cmx,cmxa,o,a}"'
                ;;
            install)
                _arguments \
                    '-destdir[destination directory]:directory:_directories' \
                    '-metadir[META directory]:directory:_directories' \
                    '-ldconf[ldconf file]:file:_files' \
                    '-dont-add-directory-to-ldconf[skip ldconf update]' \
                    '-patch-version[patch version]:version' \
                    '-dll[install DLL]' \
                    '-nodll[do not install DLL]' \
                    '-optional[mark files as optional]' \
                    '1:package name:' \
                    '*:files:_files'
                ;;
            remove)
                _arguments \
                    '-destdir[destination directory]:directory:_directories' \
                    '1:package name:'
                ;;
            printconf)
                _arguments \
                    '1:variable:(conf destdir metadir path stdlib ldconf)'
                ;;
            *)
                _default
                ;;
        esac
        ;;
esac
