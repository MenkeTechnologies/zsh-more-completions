#compdef shellcheck

# Zsh completion for ShellCheck - shell script analysis tool
# https://www.shellcheck.net/

local -a arguments

arguments=(
  {-a,--check-sourced}'[include warnings from sourced files]'
  {-C,--color=}'[use color]:when:(auto always never)'
  '*'{-e,--exclude=}'[exclude specific warning codes]:code:'
  '*--enable=[enable optional checks or check groups]:check:(all add-default-case avoid-nullary-conditions check-extra-masked-returns check-set-e-suppressed check-unassigned-uppercase deprecate-which quote-safe-variables require-double-brackets require-variable-braces)'
  {-f,--format=}'[output format]:format:(checkstyle diff gcc json json1 quiet tty)'
  '--list-optional[list available optional checks]'
  {-o,--enable=}'[enable optional check]:check:'
  {-P,--source-path=}'[specify path to search for sourced files]:path:_directories'
  {-s,--shell=}'[specify dialect]:dialect:(sh bash dash ksh)'
  {-S,--severity=}'[minimum severity of errors to report]:severity:(error warning info style)'
  '--source-path=[specify path to search for sourced files]:path:_directories'
  {-W,--wiki-link-count=}'[number of wiki links to show at the bottom of the output]:count:'
  '(- *)'{-V,--version}'[print version information]'
  {-x,--external-sources}'[allow source statements to access files outside the script directory]'
  '--norc[do not look for .shellcheckrc files]'
  '--rcfile=[specify path to a .shellcheckrc file]:file:_files'
  '*:script file:_files'
)

_arguments -s -S $arguments
