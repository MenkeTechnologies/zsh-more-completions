#compdef uv

# Zsh completion for uv - Python package and project manager
# Covers uv 0.5+ commands and options

_uv() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    local -a commands
    commands=(
        'run:Run a command or script'
        'init:Create a new project'
        'add:Add dependencies to the project'
        'remove:Remove dependencies from the project'
        'sync:Update the project'\''s environment'
        'lock:Update the project'\''s lockfile'
        'export:Export the project'\''s lockfile to an alternate format'
        'tree:Display the project'\''s dependency tree'
        'tool:Run and install commands provided by Python packages'
        'python:Manage Python versions'
        'pip:Manage Python packages with a pip-compatible interface'
        'venv:Create a virtual environment'
        'build:Build Python packages into source distributions and wheels'
        'publish:Upload distributions to an index'
        'cache:Manage uv'\''s cache'
        'self:Manage the uv installation'
        'version:Display uv'\''s version'
        'generate-shell-completion:Generate shell completion scripts'
        'help:Display documentation for a command'
    )

    local -a global_flags
    global_flags=(
        '--cache-dir=[Path to the cache directory]:dir:_directories'
        '--python-preference=[Whether to prefer managed or system Python installations]:pref:(only-managed managed system only-system)'
        '--python-fetch=[Whether to automatically download Python when needed]:mode:(automatic manual never)'
        '(-n --no-cache)'{-n,--no-cache}'[Avoid reading from or writing to the cache]'
        '--color=[Control colors in output]:when:(auto always never)'
        '--native-tls[Use the system TLS certificates]'
        '--no-native-tls[Do not use the system TLS certificates]'
        '--offline[Disable network access]'
        '--no-offline[Do not disable network access]'
        '--preview[Enable preview mode]'
        '--no-preview[Disable preview mode]'
        '--no-progress[Hide all progress outputs]'
        '--directory=[Change to the given directory]:dir:_directories'
        '--project=[Run within the given project directory]:dir:_directories'
        '--config-file=[Path to a uv.toml configuration file]:file:_files'
        '--no-config[Avoid reading configuration files]'
        '(-q --quiet)'{-q,--quiet}'[Do not print any output]'
        '(-v --verbose)'{-v,--verbose}'[Use verbose output]'
        '(-h --help)'{-h,--help}'[Display help information]'
        '(-V --version)'{-V,--version}'[Display the uv version]'
    )

    _arguments -C \
        $global_flags \
        '1:command:->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'uv command' commands
            ;;
        args)
            case $words[1] in
                run)
                    _arguments -s \
                        '*--with=[Run with the given packages installed]:package:' \
                        '*--with-requirements=[Run with packages from the given requirements file]:file:_files' \
                        '--with-editable=[Run with the given editable package installed]:package:' \
                        '(-p --python)'{-p,--python}'[The Python interpreter to use]:python:' \
                        '*--extra=[Include optional dependency group]:extra:' \
                        '--all-extras[Include all optional dependency groups]' \
                        '--no-extras[Exclude all optional dependency groups]' \
                        '*--no-extra=[Exclude optional dependency group]:extra:' \
                        '*--group=[Include a dependency group]:group:' \
                        '--all-groups[Include all dependency groups]' \
                        '*--no-group=[Exclude a dependency group]:group:' \
                        '--only-group=[Only include the given dependency group]:group:' \
                        '--package=[Run the command in a specific package]:package:' \
                        '--all-packages[Run the command in all packages in the workspace]' \
                        '--no-project[Avoid discovering the project or workspace]' \
                        '--isolated[Run the command in an isolated virtual environment]' \
                        '--locked[Assert that the uv.lock will remain unchanged]' \
                        '--frozen[Run without updating the uv.lock file]' \
                        '--env-file=[Load environment variables from a .env file]:file:_files' \
                        '--no-env-file[Avoid reading .env files]' \
                        '--script=[Run the given path as a Python script]:file:_files' \
                        '--gui-script=[Run the given path as a Python GUI script]:file:_files' \
                        '--module[Run the given Python module]' \
                        '--no-sync[Avoid syncing the virtual environment]' \
                        '--reinstall[Reinstall all packages]' \
                        '*--reinstall-package=[Reinstall specific packages]:package:' \
                        '--no-build-isolation[Disable build isolation]' \
                        '--no-sources[Ignore the tool.uv.sources table]' \
                        '--active[Only modify the active virtual environment]' \
                        '*:command:_command_names'
                    ;;
                init)
                    _arguments -s \
                        '--name=[The name of the project]:name:' \
                        '--package[Set up the project to be built as a Python package]' \
                        '--no-package[Do not set up the project to be built as a Python package]' \
                        '--app[Create a project for an application]' \
                        '--lib[Create a project for a library]' \
                        '--script[Create a script]' \
                        '(-p --python)'{-p,--python}'[The Python interpreter to use]:python:' \
                        '--no-readme[Do not create a README.md file]' \
                        '--no-pin-python[Do not pin a Python version in .python-version]' \
                        '--vcs=[Initialize a version control system]:vcs:(git none)' \
                        '--build-backend=[Set the build backend]:backend:(hatch flit pdm setuptools maturin scikit)' \
                        '--author-from=[Set the author information source]:source:(auto git none)' \
                        '--no-workspace[Avoid discovering a workspace]' \
                        '--description=[Set the project description]:description:' \
                        '1:path:_directories'
                    ;;
                add)
                    _arguments -s \
                        '--dev[Add as a development dependency]' \
                        '--no-dev[Do not add as a development dependency]' \
                        '--optional=[Add as an optional dependency]:group:' \
                        '--group=[Add to a specific dependency group]:group:' \
                        '*--requirements=[Add all packages listed in the given requirements file]:file:_files' \
                        '--editable[Add as an editable package]' \
                        '--no-editable[Do not add as an editable package]' \
                        '--raw-sources[Add source to project table as is]' \
                        '--rev=[Specific commit to use for Git dependency]:rev:' \
                        '--tag=[Tag to use for Git dependency]:tag:' \
                        '--branch=[Branch to use for Git dependency]:branch:' \
                        '--no-sync[Avoid syncing the virtual environment]' \
                        '--locked[Assert that the uv.lock will remain unchanged]' \
                        '--frozen[Add without updating the uv.lock file]' \
                        '(-p --python)'{-p,--python}'[The Python interpreter to use]:python:' \
                        '*--extra=[Include optional dependency group]:extra:' \
                        '--all-extras[Include all optional dependency groups]' \
                        '--pin=[Pin strategy for added dependencies]:strategy:(compatible exact no-pin latest)' \
                        '--package=[Add to a specific package in the workspace]:package:' \
                        '--script=[Add to a PEP 723 script]:file:_files' \
                        '--no-build-isolation[Disable build isolation]' \
                        '--no-sources[Ignore the tool.uv.sources table]' \
                        '--reinstall[Reinstall all packages]' \
                        '*--reinstall-package=[Reinstall specific packages]:package:' \
                        '--active[Only modify the active virtual environment]' \
                        '*:packages:'
                    ;;
                remove)
                    _arguments -s \
                        '--dev[Remove as a development dependency]' \
                        '--no-dev[Do not treat as a development dependency]' \
                        '--optional=[Remove from an optional dependency group]:group:' \
                        '--group=[Remove from a specific dependency group]:group:' \
                        '--no-sync[Avoid syncing the virtual environment]' \
                        '--locked[Assert that the uv.lock will remain unchanged]' \
                        '--frozen[Remove without updating the uv.lock file]' \
                        '(-p --python)'{-p,--python}'[The Python interpreter to use]:python:' \
                        '--package=[Remove from a specific package in the workspace]:package:' \
                        '--script=[Remove from a PEP 723 script]:file:_files' \
                        '--no-build-isolation[Disable build isolation]' \
                        '--active[Only modify the active virtual environment]' \
                        '*:packages:'
                    ;;
                sync)
                    _arguments -s \
                        '*--extra=[Include optional dependency group]:extra:' \
                        '--all-extras[Include all optional dependency groups]' \
                        '--no-extras[Exclude all optional dependency groups]' \
                        '*--no-extra=[Exclude optional dependency group]:extra:' \
                        '*--group=[Include a dependency group]:group:' \
                        '--all-groups[Include all dependency groups]' \
                        '*--no-group=[Exclude a dependency group]:group:' \
                        '--only-group=[Only include the given dependency group]:group:' \
                        '--no-default-groups[Ignore the default dependency groups]' \
                        '--no-install-project[Do not install the current project]' \
                        '--no-install-workspace[Do not install any workspace members]' \
                        '*--no-install-package=[Do not install a specific package]:package:' \
                        '--inexact[Do not remove extraneous packages]' \
                        '--exact[Remove extraneous packages (default)]' \
                        '--reinstall[Reinstall all packages]' \
                        '*--reinstall-package=[Reinstall specific packages]:package:' \
                        '(-p --python)'{-p,--python}'[The Python interpreter to use]:python:' \
                        '--locked[Assert that the uv.lock will remain unchanged]' \
                        '--frozen[Sync without updating the uv.lock file]' \
                        '--dry-run[Perform a dry run]' \
                        '--package=[Sync a specific package in the workspace]:package:' \
                        '--all-packages[Sync all packages in the workspace]' \
                        '--no-build-isolation[Disable build isolation]' \
                        '--no-sources[Ignore the tool.uv.sources table]' \
                        '--active[Only modify the active virtual environment]'
                    ;;
                lock)
                    _arguments -s \
                        '(-p --python)'{-p,--python}'[The Python interpreter to use]:python:' \
                        '--locked[Assert that the uv.lock will remain unchanged]' \
                        '--frozen[Lock without updating the uv.lock file]' \
                        '--dry-run[Perform a dry run]' \
                        '--check[Check that the lockfile is up-to-date]' \
                        '--no-build-isolation[Disable build isolation]' \
                        '--no-sources[Ignore the tool.uv.sources table]'
                    ;;
                export)
                    _arguments -s \
                        '--format=[Export format]:format:(requirements-txt pylock-toml)' \
                        '(-p --python)'{-p,--python}'[The Python interpreter to use]:python:' \
                        '--locked[Assert that the uv.lock will remain unchanged]' \
                        '--frozen[Export without updating the uv.lock file]' \
                        '--package=[Export a specific package]:package:' \
                        '--all-packages[Export all packages in the workspace]' \
                        '*--extra=[Include optional dependency group]:extra:' \
                        '--all-extras[Include all optional dependency groups]' \
                        '--no-extras[Exclude all optional dependency groups]' \
                        '*--no-extra=[Exclude optional dependency group]:extra:' \
                        '*--group=[Include a dependency group]:group:' \
                        '--all-groups[Include all dependency groups]' \
                        '*--no-group=[Exclude a dependency group]:group:' \
                        '--only-group=[Only include the given dependency group]:group:' \
                        '--no-default-groups[Ignore the default dependency groups]' \
                        '--no-hashes[Omit hashes in the generated output]' \
                        '--hashes[Include hashes in the generated output]' \
                        '(-o --output-file)'{-o,--output-file}'=[Write output to the given file]:file:_files' \
                        '--no-emit-project[Do not emit the current project]' \
                        '--no-emit-workspace[Do not emit any workspace members]' \
                        '*--no-emit-package=[Do not emit a specific package]:package:' \
                        '--no-annotate[Do not include comments in the output]' \
                        '--no-header[Do not include the header comment]' \
                        '--no-build-isolation[Disable build isolation]' \
                        '--no-sources[Ignore the tool.uv.sources table]'
                    ;;
                tree)
                    _arguments -s \
                        '(-p --python)'{-p,--python}'[The Python interpreter to use]:python:' \
                        '--locked[Assert that the uv.lock will remain unchanged]' \
                        '--frozen[Display without updating the uv.lock file]' \
                        '--package=[Show a specific package]:package:' \
                        '--depth=[Maximum display depth of the dependency tree]:depth:' \
                        '*--prune=[Prune the given package from the display]:package:' \
                        '--no-dedupe[Do not de-duplicate repeated dependencies]' \
                        '--invert[Show the reverse dependencies]' \
                        '--outdated[Show the latest available version of each package]' \
                        '*--group=[Include a dependency group]:group:' \
                        '--all-groups[Include all dependency groups]' \
                        '*--no-group=[Exclude a dependency group]:group:' \
                        '--only-group=[Only include the given dependency group]:group:' \
                        '*--extra=[Include optional dependency group]:extra:' \
                        '--all-extras[Include all optional dependency groups]' \
                        '--no-extras[Exclude all optional dependency groups]' \
                        '--no-build-isolation[Disable build isolation]' \
                        '--no-sources[Ignore the tool.uv.sources table]'
                    ;;
                tool)
                    local -a tool_commands
                    tool_commands=(
                        'install:Install a tool'
                        'upgrade:Upgrade installed tools'
                        'list:List installed tools'
                        'uninstall:Uninstall a tool'
                        'update-shell:Ensure that the tool bin directory is on the PATH'
                        'run:Run a tool'
                        'dir:Show the tools directory'
                    )
                    _arguments -C \
                        '1:tool command:->toolcmd' \
                        '*::arg:->toolargs'
                    case $state in
                        toolcmd)
                            _describe -t tool_commands 'tool command' tool_commands
                            ;;
                        toolargs)
                            case $line[1] in
                                run)
                                    _arguments -s \
                                        '*--with=[Run with the given packages installed]:package:' \
                                        '--from=[Use the given package to provide the command]:package:' \
                                        '(-p --python)'{-p,--python}'[The Python interpreter to use]:python:' \
                                        '--isolated[Run in an isolated virtual environment]' \
                                        '--reinstall[Reinstall all packages]' \
                                        '*--reinstall-package=[Reinstall specific packages]:package:' \
                                        '--no-build-isolation[Disable build isolation]' \
                                        '--no-sources[Ignore the tool.uv.sources table]' \
                                        '*:command:_command_names'
                                    ;;
                                install)
                                    _arguments -s \
                                        '--editable[Install as an editable package]' \
                                        '--no-editable[Do not install as an editable package]' \
                                        '*--with=[Include additional packages]:package:' \
                                        '--from=[Use the given package to provide the command]:package:' \
                                        '(-p --python)'{-p,--python}'[The Python interpreter to use]:python:' \
                                        '--reinstall[Reinstall all packages]' \
                                        '--force[Force installation even if already installed]' \
                                        '--no-build-isolation[Disable build isolation]' \
                                        '--no-sources[Ignore the tool.uv.sources table]' \
                                        '*:package:'
                                    ;;
                                upgrade)
                                    _arguments -s \
                                        '--all[Upgrade all installed tools]' \
                                        '(-p --python)'{-p,--python}'[The Python interpreter to use]:python:' \
                                        '--reinstall[Reinstall all packages]' \
                                        '*:tool:'
                                    ;;
                                list)
                                    _arguments -s \
                                        '--show-paths[Show the paths to each tool environment and its packages]' \
                                        '--show-version-specifiers[Show the version specifiers]'
                                    ;;
                                uninstall)
                                    _arguments -s \
                                        '--all[Uninstall all tools]' \
                                        '*:tool:'
                                    ;;
                                dir)
                                    _arguments -s \
                                        '--bin[Show the tools bin directory]'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                python)
                    local -a python_commands
                    python_commands=(
                        'find:Search for a Python installation'
                        'install:Download and install Python versions'
                        'list:List the available Python installations'
                        'pin:Pin to a specific Python version'
                        'uninstall:Uninstall Python versions'
                        'dir:Show the uv Python installation directory'
                    )
                    _arguments -C \
                        '1:python command:->pycmd' \
                        '*::arg:->pyargs'
                    case $state in
                        pycmd)
                            _describe -t python_commands 'python command' python_commands
                            ;;
                        pyargs)
                            case $line[1] in
                                find)
                                    _arguments -s \
                                        '--system[Only find system Python installations]' \
                                        '--no-project[Avoid discovering the project or workspace]' \
                                        '1:request:'
                                    ;;
                                install)
                                    _arguments -s \
                                        '--reinstall[Reinstall the requested Python version]' \
                                        '--default[Use as the default Python version]' \
                                        '*:version:'
                                    ;;
                                list)
                                    _arguments -s \
                                        '--all-versions[List all available Python versions, including old patch versions]' \
                                        '--all-platforms[List Python installations for all platforms]' \
                                        '--only-installed[Only show installed Python versions]'
                                    ;;
                                pin)
                                    _arguments -s \
                                        '--resolved[Write the resolved Python interpreter path]' \
                                        '--no-resolved[Do not write the resolved Python interpreter path]' \
                                        '--no-project[Avoid discovering the project or workspace]' \
                                        '1:request:'
                                    ;;
                                uninstall)
                                    _arguments -s \
                                        '--all[Uninstall all managed Python versions]' \
                                        '*:version:'
                                    ;;
                                dir)
                                    _arguments -s
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                pip)
                    local -a pip_commands
                    pip_commands=(
                        'install:Install packages into an environment'
                        'uninstall:Uninstall packages from an environment'
                        'freeze:List installed packages in requirements format'
                        'list:List installed packages'
                        'show:Show information about installed packages'
                        'check:Verify installed packages have compatible dependencies'
                        'compile:Compile a requirements.in file to a requirements.txt file'
                        'sync:Sync an environment with a requirements.txt file'
                        'tree:Display the dependency tree for an environment'
                    )
                    _arguments -C \
                        '1:pip command:->pipcmd' \
                        '*::arg:->pipargs'
                    case $state in
                        pipcmd)
                            _describe -t pip_commands 'pip command' pip_commands
                            ;;
                        pipargs)
                            case $line[1] in
                                install)
                                    _arguments -s \
                                        '*-r[Install from the given requirements file]:file:_files' \
                                        '*-c[Constrain versions using the given requirements file]:file:_files' \
                                        '*-e[Install the editable package]:package:_directories' \
                                        '--no-deps[Don'\''t install package dependencies]' \
                                        '--no-build-isolation[Disable build isolation]' \
                                        '--strict[Validate the virtual environment]' \
                                        '--reinstall[Reinstall all packages]' \
                                        '*--reinstall-package=[Reinstall specific packages]:package:' \
                                        '--prefix=[Install packages into the given directory]:dir:_directories' \
                                        '--index-url=[The URL of the Python package index]:url:' \
                                        '*--extra-index-url=[Extra URLs of package indexes]:url:' \
                                        '*--find-links=[Locations to search for candidate distributions]:url:' \
                                        '--no-index[Ignore package index]' \
                                        '--system[Install into the system Python environment]' \
                                        '--break-system-packages[Allow modifying packages in system environment]' \
                                        '--target=[Install packages into the target directory]:dir:_directories' \
                                        '(-p --python)'{-p,--python}'[The Python interpreter to use]:python:' \
                                        '--upgrade[Allow package upgrades]' \
                                        '*--upgrade-package=[Allow upgrades for a specific package]:package:' \
                                        '--resolution=[The strategy for resolving against pre-installed packages]:strategy:(highest lowest)' \
                                        '--prerelease=[The strategy for pre-release versions]:strategy:(disallow allow if-necessary-or-explicit explicit necessary)' \
                                        '--dry-run[Perform a dry run]' \
                                        '*:package:'
                                    ;;
                                uninstall)
                                    _arguments -s \
                                        '*-r[Uninstall packages listed in the given requirements file]:file:_files' \
                                        '--system[Use the system Python environment]' \
                                        '--break-system-packages[Allow modifying packages in system environment]' \
                                        '(-p --python)'{-p,--python}'[The Python interpreter to use]:python:' \
                                        '--keyring-provider=[The keyring provider to use]:provider:' \
                                        '*:package:'
                                    ;;
                                freeze)
                                    _arguments -s \
                                        '--system[Use the system Python environment]' \
                                        '(-p --python)'{-p,--python}'[The Python interpreter to use]:python:' \
                                        '--strict[Validate the virtual environment]' \
                                        '*--exclude=[Exclude these packages from output]:package:'
                                    ;;
                                list)
                                    _arguments -s \
                                        '--system[Use the system Python environment]' \
                                        '(-p --python)'{-p,--python}'[The Python interpreter to use]:python:' \
                                        '--strict[Validate the virtual environment]' \
                                        '--editable[Only show editable packages]' \
                                        '--exclude-editable[Exclude editable packages]' \
                                        '*--exclude=[Exclude these packages from output]:package:' \
                                        '--format=[Select the output format]:format:(columns freeze json)'
                                    ;;
                                show)
                                    _arguments -s \
                                        '--system[Use the system Python environment]' \
                                        '(-p --python)'{-p,--python}'[The Python interpreter to use]:python:' \
                                        '--strict[Validate the virtual environment]' \
                                        '*:package:'
                                    ;;
                                check)
                                    _arguments -s \
                                        '--system[Use the system Python environment]' \
                                        '(-p --python)'{-p,--python}'[The Python interpreter to use]:python:'
                                    ;;
                                compile)
                                    _arguments -s \
                                        '*-c[Constrain versions using the given requirements file]:file:_files' \
                                        '*--override=[Override versions from the given requirements file]:file:_files' \
                                        '--no-strip-extras[Include extras in the output file]' \
                                        '--no-strip-markers[Include environment markers in the output file]' \
                                        '--no-annotate[Do not include comments in the output]' \
                                        '--no-header[Do not include the header comment]' \
                                        '--system[Use the system Python environment]' \
                                        '(-p --python)'{-p,--python}'[The Python interpreter to use]:python:' \
                                        '--emit-index-url[Include --index-url and --extra-index-url entries]' \
                                        '--emit-find-links[Include --find-links entries]' \
                                        '--no-emit-package=[Do not emit a specific package]:package:' \
                                        '--emit-index-annotation[Include package index annotations]' \
                                        '--resolution=[The strategy for selecting package versions]:strategy:(highest lowest)' \
                                        '--prerelease=[The strategy for pre-release versions]:strategy:(disallow allow if-necessary-or-explicit explicit necessary)' \
                                        '--index-url=[The URL of the Python package index]:url:' \
                                        '*--extra-index-url=[Extra URLs of package indexes]:url:' \
                                        '*--find-links=[Locations to search for candidate distributions]:url:' \
                                        '--no-index[Ignore package index]' \
                                        '--generate-hashes[Include distribution hashes]' \
                                        '--no-build-isolation[Disable build isolation]' \
                                        '--no-build[Don'\''t build source distributions]' \
                                        '--no-binary[Don'\''t install pre-built wheels]' \
                                        '--universal[Generate a universal requirements file]' \
                                        '(-o --output-file)'{-o,--output-file}'=[Write output to the given file]:file:_files' \
                                        '--all-extras[Include all optional dependency groups]' \
                                        '*--extra=[Include optional dependency group]:extra:' \
                                        '*:source file:_files'
                                    ;;
                                sync)
                                    _arguments -s \
                                        '*-c[Constrain versions using the given requirements file]:file:_files' \
                                        '--reinstall[Reinstall all packages]' \
                                        '*--reinstall-package=[Reinstall specific packages]:package:' \
                                        '--system[Use the system Python environment]' \
                                        '(-p --python)'{-p,--python}'[The Python interpreter to use]:python:' \
                                        '--strict[Validate the virtual environment]' \
                                        '--no-build-isolation[Disable build isolation]' \
                                        '--dry-run[Perform a dry run]' \
                                        '--no-build[Don'\''t build source distributions]' \
                                        '--no-binary[Don'\''t install pre-built wheels]' \
                                        '--index-url=[The URL of the Python package index]:url:' \
                                        '*--extra-index-url=[Extra URLs of package indexes]:url:' \
                                        '*--find-links=[Locations to search for candidate distributions]:url:' \
                                        '--no-index[Ignore package index]' \
                                        '--ask[Ask user for confirmation before making changes]' \
                                        '*:source file:_files'
                                    ;;
                                tree)
                                    _arguments -s \
                                        '--system[Use the system Python environment]' \
                                        '(-p --python)'{-p,--python}'[The Python interpreter to use]:python:' \
                                        '--strict[Validate the virtual environment]' \
                                        '--depth=[Maximum display depth of the dependency tree]:depth:' \
                                        '--no-dedupe[Do not de-duplicate repeated dependencies]' \
                                        '--invert[Show the reverse dependencies]' \
                                        '*--prune=[Prune the given package from the display]:package:' \
                                        '--show-version-specifiers[Show the version specifiers]'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                venv)
                    _arguments -s \
                        '(-p --python)'{-p,--python}'[The Python interpreter to use]:python:' \
                        '--prompt=[Provide an alternative prompt prefix for the virtual environment]:prompt:' \
                        '--system-site-packages[Give the virtual environment access to system site-packages]' \
                        '--allow-existing[Allow creating over an existing virtual environment]' \
                        '--seed[Install seed packages into the virtual environment]' \
                        '--relocatable[Make the virtual environment relocatable]' \
                        '--index-url=[The URL of the Python package index]:url:' \
                        '*--extra-index-url=[Extra URLs of package indexes]:url:' \
                        '--exclude-newer=[Limit candidate packages to those uploaded before the given date]:date:' \
                        '1:path:_directories'
                    ;;
                build)
                    _arguments -s \
                        '--sdist[Build a source distribution]' \
                        '--wheel[Build a binary distribution (wheel)]' \
                        '--no-build-logs[Hide build logs]' \
                        '(-o --out-dir)'{-o,--out-dir}'=[The output directory for the built distributions]:dir:_directories' \
                        '--package=[Build a specific package in the workspace]:package:' \
                        '--all-packages[Build all packages in the workspace]' \
                        '(-p --python)'{-p,--python}'[The Python interpreter to use]:python:' \
                        '--no-build-isolation[Disable build isolation]' \
                        '--no-sources[Ignore the tool.uv.sources table]' \
                        '--locked[Assert that the uv.lock will remain unchanged]' \
                        '--frozen[Build without updating the uv.lock file]' \
                        '--verify-hashes[Verify package hashes]' \
                        '--index-url=[The URL of the Python package index]:url:' \
                        '*--extra-index-url=[Extra URLs of package indexes]:url:' \
                        '*:src:_files -/'
                    ;;
                publish)
                    _arguments -s \
                        '(-t --token)'{-t,--token}'=[The token to use for authentication]:token:' \
                        '(-u --username)'{-u,--username}'=[The username to use for authentication]:username:' \
                        '--password=[The password to use for authentication]:password:' \
                        '--publish-url=[The URL of the upload endpoint]:url:' \
                        '--trusted-publishing=[Configure trusted publishing]:mode:(always automatic never)' \
                        '--keyring-provider=[The keyring provider to use]:provider:(subprocess disabled)' \
                        '--check-url=[The URL to check for existing uploads]:url:' \
                        '--index=[The index to use for publishing]:index:' \
                        '*:dist:_files'
                    ;;
                cache)
                    local -a cache_commands
                    cache_commands=(
                        'clean:Clear the cache'
                        'prune:Prune all unreachable objects from the cache'
                        'dir:Show the cache directory'
                    )
                    _arguments -C \
                        '1:cache command:->cachecmd' \
                        '*::arg:->cacheargs'
                    case $state in
                        cachecmd)
                            _describe -t cache_commands 'cache command' cache_commands
                            ;;
                        cacheargs)
                            case $line[1] in
                                clean)
                                    _arguments -s \
                                        '*:package:'
                                    ;;
                                prune)
                                    _arguments -s \
                                        '--ci[Optimize for a CI environment]'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                self)
                    local -a self_commands
                    self_commands=(
                        'update:Update uv'
                    )
                    _arguments -C \
                        '1:self command:->selfcmd' \
                        '*::arg:->selfargs'
                    case $state in
                        selfcmd)
                            _describe -t self_commands 'self command' self_commands
                            ;;
                        selfargs)
                            case $line[1] in
                                update)
                                    _arguments -s \
                                        '--token=[A GitHub token for authentication]:token:' \
                                        '--target-version=[Update to the given version]:version:'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                version)
                    _arguments -s \
                        '--output-format=[Output format]:format:(text json)' \
                        '--short[Print only the version number]' \
                        '--bump=[Bump the project version]:level:(major minor patch)' \
                        '--dry-run[Do not write the version back to the pyproject.toml]'
                    ;;
                generate-shell-completion)
                    _arguments -s \
                        '1:shell:(bash elvish fish nushell powershell zsh)'
                    ;;
            esac
            ;;
    esac
}

_uv "$@"
