#compdef gpm

local -a arguments

arguments=(
  '-a[sets the acceleration (default 2)]'
  '-A[start with selection disabled (`aged)]'
  '-b[sets the baud rate (default 1200)]'
  '-B[allows changing the buttons (default 123)]'
  '-d[sets the delta value (default 25) (must be 2 or more)]'
  '-D[debug mode: dont auto-background]'
  '-g[sets the button (1-3) that is emulated by tapping on]'
  '-i[max time interval for multiple clicks (default 250)]'
  '-k[kill a running gpm, to start X with a busmouse]'
