#compdef scsi_satl
# Documentation: https://man.archlinux.org/search?q=scsi_satl
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-L,--log}'[append stderr to scsi_satl.err]'
  {-q,--quiet}'[suppress some output]'
  {-v,--verbose}'[more verbose output]'
  '*:filename:_files'
)

_arguments -s -S $arguments
