#compdef enchant
# Documentation: https://man.archlinux.org/search?q=enchant
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-a[suggestions in ispell pipe mode format.]'
  '-d[uses dictionary <dict>.]'
  '-h[this help message.]'
  '-l[misspellings.]'
  '-m[ignored.]'
  '-L[line numbers.]'
  '-v[program version.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
