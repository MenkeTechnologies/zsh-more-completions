#compdef cassandra

local -a arguments

arguments=(
    '-f[Run in foreground]'
    '-p[Log PID to file]:pid file:_files'
    '-v[Print version]'
    '-R[Allow root to run]'
    '-H[Disable JMX local host only]'
    '-D-[Define system property]:property'
    '-E[Enable assertions]'
    '-e[Enable assertions in packages and classes]'
    '-Xms-[Minimum heap size]:size'
    '-Xmx-[Maximum heap size]:size'
    '-Xss-[Thread stack size]:size'
    '-Xmn-[Young generation size]:size'
)

_arguments -s -S $arguments
