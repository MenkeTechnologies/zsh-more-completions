#compdef xvfb-run

local -a arguments

arguments=(
  {-a,--auto-servernum}'[try to get a free server number, starting at --server-num]'
  {-e,--error-file}'[file used to store xauth errors and Xvfb output]:file:_files'
  {-f,--auth-file}'[file used to store auth cookie]'
  '(- * :)'{-h,--help}'[display this usage message and exit]'
  {-n,--server-num}'[server number to use (default: 99)]'
  {-l,--listen-tcp}'[enable TCP port listening in the X server]'
  {-p,--xauth-protocol}'[X authority protocol name to use]'
  {-s,--server-args}'[arguments to pass to Xvfb]:args:'
  '*:filename:_files'
)

_arguments -s -S $arguments
