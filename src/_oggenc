#compdef oggenc

local -a arguments

arguments=(
  {-Q,--quiet}'[produce no output to stderr]'
  '(- * :)'{-h,--help}'[print this help text]'
  {-V,--version}'[print the version number]'
  {-k,--skeleton}'[adds an Ogg Skeleton bitstream]'
  {-r,--raw}'[raw mode. Input files are read directly as PCM data]'
  {-B,--raw-bits}'[set bits/sample for raw input; default is 16]'
  {-C,--raw-chan}'[set number of channels for raw input; default is 2]'
  {-R,--raw-rate}'[set samples/sec for raw input; default is 44100]'
  '--raw-endianness[1 for bigendian, 0 for little (defaults to 0)]'
  {-b,--bitrate}'[choose a nominal bitrate to encode at]:bitrate:'
  '--managed[enable the bitrate management engine]'
  {-m,--min-bitrate}'[specify a minimum bitrate in kbps]:bitrate:'
  {-M,--max-bitrate}'[specify a maximum bitrate in kbps]:bitrate:'
  '--advanced-encode-option[set advanced encoder option]:option:'
  {-q,--quality}'[specify quality, between -1 (very low) and 10 (very high)]:quality:'
  '--resample[resample input data to sampling rate n (Hz)]:rate:'
  '--downmix[downmix stereo to mono]'
  {-s,--serial}'[specify a serial number for the stream]:serial:'
  '--discard-comments[prevents comments in FLAC files from being copied]'
  '--ignorelength[ignore the datalength in Wave headers]'
  {-o,--output}'[write file to fn (only valid in single-file mode)]'
  {-n,--names}'[produce filenames as this string, with %a, %t, %l]'
  {-X,--name-remove}'[remove the specified characters from filenames]:chars:'
  {-P,--name-replace}'[replace characters removed by --name-remove]:char:'
  '--utf8[interpret command line parameters as UTF-8]'
  {-c,--comment}'[add the given string as an extra comment]:comment:'
  {-d,--date}'[date for track (usually date of performance)]'
  {-N,--tracknum}'[track number for this track]'
  {-t,--title}'[title for this track]'
  {-l,--album}'[name of album]'
  {-a,--artist}'[name of artist]'
  {-G,--genre}'[genre of track]'
  {-L,--lyrics}'[include lyrics from given file (.srt or .lrc format)]'
  {-Y,--lyrics-language}'[sets the language for the lyrics]'
  '*:filename:_files'
)

_arguments -s -S $arguments
