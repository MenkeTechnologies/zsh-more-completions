#compdef circleci

# Zsh completion for circleci (CircleCI CLI)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a global_opts=(
  '--host[URL to your CircleCI host]:url:'
  '--token[your CircleCI API token]:token:'
  '(-h --help)'{-h,--help}'[show help]'
  '--debug[enable debug logging]'
  '--endpoint[URI to your CircleCI GraphQL API endpoint]:endpoint:'
)

local -a subcommands=(
  'config:operate on build config files'
  'context:manage contexts'
  'diagnostic:check the status of your CircleCI CLI'
  'follow:attempt to follow the project for the current git repository'
  'local:execute jobs locally'
  'namespace:operate on namespaces'
  'open:open the current project in the browser'
  'orb:operate on orbs'
  'policy:manage security policies'
  'runner:operate on runners'
  'setup:setup the CLI with your credentials'
  'update:update the tool and its build agent'
  'version:display version information'
)

_arguments -s -S -C \
  $global_opts \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t subcommands 'circleci command' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      config)
        local -a config_commands=(
          'validate:check that the config file is well formed'
          'process:validate and display the expanded configuration'
          'migrate:migrate a CircleCI config to a newer version'
          'pack:pack a config directory into a single config file'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->config_cmd' \
          '*::arg:->config_args' && ret=0
        case $state in
          config_cmd)
            _describe -t commands 'config subcommand' config_commands && ret=0
            ;;
          config_args)
            case $line[1] in
              validate)
                _arguments -s -S \
                  $global_opts \
                  '--config[path to config file]:file:_files' \
                  '--org-slug[organization slug]:slug:' \
                  '--org-id[organization ID]:id:' \
                  '*--pipeline-parameters[pipeline parameter key=value pairs]:key=value:' \
                  ':config file:_files' && ret=0
                ;;
              process)
                _arguments -s -S \
                  $global_opts \
                  '--org-slug[organization slug]:slug:' \
                  '--org-id[organization ID]:id:' \
                  '*--pipeline-parameters[pipeline parameter key=value pairs]:key=value:' \
                  ':config file:_files' && ret=0
                ;;
              migrate)
                _arguments -s -S \
                  $global_opts \
                  '--config[path to config file]:file:_files' \
                  ':config file:_files' && ret=0
                ;;
              pack)
                _arguments -s -S $global_opts ':source directory:_directories' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      context)
        local -a context_commands=(
          'create:create a new context'
          'delete:delete a context'
          'list:list contexts'
          'remove-secret:remove a secret from a context'
          'show:show a context'
          'store-secret:store a secret in a context'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->context_cmd' \
          '*::arg:->context_args' && ret=0
        case $state in
          context_cmd)
            _describe -t commands 'context subcommand' context_commands && ret=0
            ;;
          context_args)
            case $line[1] in
              create)
                _arguments -s -S $global_opts ':vcs type:(github bitbucket)' ':org name:' ':context name:' && ret=0
                ;;
              delete)
                _arguments -s -S $global_opts ':vcs type:(github bitbucket)' ':org name:' ':context name:' && ret=0
                ;;
              list)
                _arguments -s -S $global_opts ':vcs type:(github bitbucket)' ':org name:' && ret=0
                ;;
              remove-secret)
                _arguments -s -S $global_opts ':vcs type:(github bitbucket)' ':org name:' ':context name:' ':secret name:' && ret=0
                ;;
              show)
                _arguments -s -S $global_opts ':vcs type:(github bitbucket)' ':org name:' ':context name:' && ret=0
                ;;
              store-secret)
                _arguments -s -S $global_opts ':vcs type:(github bitbucket)' ':org name:' ':context name:' ':secret name:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      local)
        local -a local_commands=(
          'execute:run a job in a container on the local machine'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->local_cmd' \
          '*::arg:->local_args' && ret=0
        case $state in
          local_cmd)
            _describe -t commands 'local subcommand' local_commands && ret=0
            ;;
          local_args)
            case $line[1] in
              execute)
                _arguments -s -S \
                  $global_opts \
                  '--branch[git branch]:branch:' \
                  '--build-config-file[use a specific build config file]:file:_files' \
                  '--checkout-key[git checkout key]:key:' \
                  '*'{-e,--env}'[set environment variable]:key=value:' \
                  '--job[job to be executed]:job:' \
                  '--node-total[total number of parallel nodes]:num:' \
                  '--node-index[index of current node]:num:' \
                  '--repo-url[git URL]:url:' \
                  '--revision[use a specific git revision]:revision:' \
                  '--skip-checkout[skip the git checkout step]' \
                  '*--volume[volume bind mount]:volume:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      namespace)
        local -a namespace_commands=(
          'create:create a namespace'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->ns_cmd' \
          '*::arg:->ns_args' && ret=0
        case $state in
          ns_cmd)
            _describe -t commands 'namespace subcommand' namespace_commands && ret=0
            ;;
          ns_args)
            _arguments -s -S $global_opts ':name:' ':vcs type:(github bitbucket)' ':org name:' && ret=0
            ;;
        esac
        ;;
      orb)
        local -a orb_commands=(
          'create:create an orb'
          'diff:show diff of an orb'
          'info:show metadata of an orb'
          'init:initialize a new orb'
          'list:list orbs'
          'pack:pack an orb source'
          'process:validate and process an orb'
          'publish:publish an orb'
          'source:show the source of an orb'
          'unlist:unlist an orb from the registry'
          'validate:validate an orb source'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->orb_cmd' \
          '*::arg:->orb_args' && ret=0
        case $state in
          orb_cmd)
            _describe -t commands 'orb subcommand' orb_commands && ret=0
            ;;
          orb_args)
            case $line[1] in
              create)
                _arguments -s -S $global_opts '--private[create a private orb]' ':namespace/name:' && ret=0
                ;;
              publish)
                _arguments -s -S $global_opts ':path:_files' ':namespace/name@version:' && ret=0
                ;;
              validate|process)
                _arguments -s -S $global_opts ':path:_files' && ret=0
                ;;
              pack)
                _arguments -s -S $global_opts ':directory:_directories' && ret=0
                ;;
              init)
                _arguments -s -S $global_opts ':directory:_directories' && ret=0
                ;;
              list)
                _arguments -s -S $global_opts '--uncertified[include uncertified orbs]' '--private[include private orbs]' '--sort[sort order]:sort:(builds projects orgs)' ':namespace:' && ret=0
                ;;
              info|source|diff|unlist)
                _arguments -s -S $global_opts ':orb name:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      policy)
        local -a policy_commands=(
          'decide:make a decision for the given input'
          'diff:show diff against active policy bundle'
          'eval:evaluate a policy against an input'
          'fetch:fetch policy bundle'
          'push:push a policy bundle'
          'settings:manage policy settings'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->policy_cmd' \
          '*::arg:->policy_args' && ret=0
        case $state in
          policy_cmd)
            _describe -t commands 'policy subcommand' policy_commands && ret=0
            ;;
          policy_args)
            case $line[1] in
              decide|eval)
                _arguments -s -S $global_opts '--input[path to input file]:file:_files' '--owner-id[owner ID]:id:' ':policy path:_files' && ret=0
                ;;
              push|diff)
                _arguments -s -S $global_opts '--owner-id[owner ID]:id:' ':policy path:_directories' && ret=0
                ;;
              fetch)
                _arguments -s -S $global_opts '--owner-id[owner ID]:id:' && ret=0
                ;;
              settings)
                _arguments -s -S $global_opts '--owner-id[owner ID]:id:' '--enabled[enable or disable policies]:bool:(true false)' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      runner)
        local -a runner_commands=(
          'instance:manage runner instances'
          'resource-class:manage runner resource classes'
          'token:manage runner tokens'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->runner_cmd' \
          '*::arg:->runner_args' && ret=0
        case $state in
          runner_cmd)
            _describe -t commands 'runner subcommand' runner_commands && ret=0
            ;;
          runner_args)
            _arguments -s -S $global_opts ':resource class:' && ret=0
            ;;
        esac
        ;;
      update)
        local -a update_commands=(
          'build-agent:update the build agent to the latest version'
          'check:check if there are any updates available'
          'install:update the tool to the latest version'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->update_cmd' \
          '*::arg:->update_args' && ret=0
        case $state in
          update_cmd)
            _describe -t commands 'update subcommand' update_commands && ret=0
            ;;
          update_args)
            _arguments -s -S $global_opts && ret=0
            ;;
        esac
        ;;
      diagnostic|follow|open|setup|version)
        _arguments -s -S $global_opts && ret=0
        ;;
    esac
    ;;
esac

return ret
