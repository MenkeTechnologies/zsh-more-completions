#compdef groupmod

# Completion for groupmod (shadow-utils)
# https://github.com/shadow-maint/shadow

_groupmod() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a arguments

    arguments=(
        {-a,--append}'[append the users to the current group member list, use only with -U]'
        {-g,--gid}'[change the group ID to GID]:GID:'
        '(- * :)'{-h,--help}'[display help message and exit]'
        {-n,--new-name}'[change the name to NEW_GROUP]:new group name:'
        {-o,--non-unique}'[allow using a duplicate (non-unique) GID]'
        {-p,--password}'[change the password to this encrypted value]:encrypted password:'
        {-P,--prefix}'[directory prefix for etc files]:prefix directory:_directories'
        {-R,--root}'[directory to chroot into]:chroot directory:_directories'
        {-U,--users}'[set list of user members of this group]:users:_sequence _users'
        '1:group name:_groups'
    )

    _arguments -s -S $arguments && ret=0
    return ret
}

_groupmod "$@"
