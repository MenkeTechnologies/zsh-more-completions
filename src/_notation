#compdef notation

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'sign:sign an artifact'
      'verify:verify an artifact'
      'certificate:manage certificates'
      'key:manage keys'
      'login:log in to a registry'
      'logout:log out from a registry'
      'list:list signatures'
      'inspect:inspect signatures'
      'blob:sign and verify blobs'
      'plugin:manage plugins'
      'policy:manage trust policies'
      'version:print version'
    )
    _describe -t commands 'notation command' commands && ret=0
    ;;
  args)
    case $words[1] in
      sign)
        _arguments -s -S \
          {-k,--key}'=[signing key name]:key' \
          '--signature-format=[signature format]:format:(cose jws)' \
          {-e,--expiry}'=[signature expiry]:expiry' \
          '*--plugin-config=[plugin config]:key=value' \
          '*--user-metadata=[user metadata]:key=value' \
          '--id=[key ID]:key id' \
          '1:reference' \
          && ret=0
        ;;
      verify)
        _arguments -s -S \
          '--policy-scope=[trust policy scope]:scope' \
          '--allow-referrers-api[allow referrers API]' \
          '1:reference' \
          && ret=0
        ;;
      login)
        _arguments -s -S \
          {-u,--username}'=[username]:username' \
          {-p,--password}'=[password]:password' \
          '--password-stdin[read password from stdin]' \
          '1:server' \
          && ret=0
        ;;
      logout)
        _arguments -s -S \
          '1:server' \
          && ret=0
        ;;
      list|inspect)
        _arguments -s -S \
          '1:reference' \
          && ret=0
        ;;
      key)
        _arguments -s -S -C \
          '1:subcommand:(add delete list update)' \
          && ret=0
        ;;
      certificate)
        _arguments -s -S -C \
          '1:subcommand:(add delete list show generate-test)' \
          && ret=0
        ;;
      plugin)
        _arguments -s -S -C \
          '1:subcommand:(install list uninstall)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
