#compdef contacts
# Documentation: https://man.archlinux.org/search?q=contacts
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[help (this)]'
  '-H[header]'
  '-s[list]'
  '-m[me]'
  '-n[note below each record]'
  '-l[formatting (doesnt truncate record values)]'
  '-S[formatting (doesnt add space between columns)]'
  '-c[as calendar(1) file format]'
  '-f[a format string (see man page)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
