#compdef airserv-ng
# Documentation: https://man.archlinux.org/search?q=airserv-ng
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[This help screen]'
  '-p[TCP port to listen on (default:666)]:port:'
  '-d[Wifi interface to use]'
  '-c[Channel to use]:chan:'
  '-v[Debug level (1 to 3; default: 1)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
