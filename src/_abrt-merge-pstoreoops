#compdef abrt-merge-pstoreoops
# Documentation: https://man.archlinux.org/search?q=abrt-merge-pstoreoops
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-v,--verbose}'[be verbose]'
  '-o[print found oopses]'
  '-d[delete files with found oopses]'
  '*:filename:_files'
)

_arguments -s -S $arguments
