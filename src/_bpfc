#compdef bpfc

local -a arguments

arguments=(
  {-i,--input}'[Berkeley Packet Filter file or stdin]:file:_files'
  {-p,--cpp}'[run bpf program through C preprocessor]'
  {-D,--define}'[add macro/define for C preprocessor]:macro:'
  {-f,--format}'[output format]:format:(C netsniff-ng xt_bpf tcpdump)'
  {-b,--bypass}'[bypass filter validation (e.g. for bug testing)]'
  {-V,--verbose}'[be more verbose]'
  {-d,--dump}'[dump supported instruction table]'
  {-v,--version}'[print version and exit]'
  {-h,--help}'[print this help and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
