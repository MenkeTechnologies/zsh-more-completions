#compdef jupyter-execute

local -a arguments

arguments=(
  '--allow-errors[errors are ignored and execution is continued until the end of the notebook.]'
  '--timeout[the time to wait (in seconds) for output from executions]:seconds:'
  '--startup_timeout[the time to wait (in seconds) for the kernel to start]:seconds:'
  '--kernel_name[name of the kernel to use for execution]:name:'
  '*:filename:_files'
)

_arguments -s -S $arguments
