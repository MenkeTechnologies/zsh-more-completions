#compdef objcopy llvm-objcopy

# Zsh completion for objcopy / llvm-objcopy

_objcopy() {
  local -a arguments

  arguments=(
    '(- *)'{-h,--help}'[display help information]'
    '(- *)'{-V,--version}'[display version information]'

    # Input/output format
    {-I,--input-target}'[assume input file is in specified format]:bfdname:'
    {-O,--output-target}'[create output file in specified format]:bfdname:(binary ihex srec elf32-i386 elf64-x86-64 elf32-littlearm elf64-littleaarch64 pe-i386 pe-x86-64 mach-o-x86-64 mach-o-arm64)'
    {-B,--binary-architecture}'[set output architecture for arch-less input]:architecture:(i386 x86_64 arm aarch64 mips powerpc sparc)'
    {-F,--target}'[set both input and output format]:bfdname:'

    # Stripping options
    {-S,--strip-all}'[remove all symbol and relocation information]'
    {-g,--strip-debug}'[remove all debugging symbols and sections]'
    '--strip-dwo[remove all DWO sections]'
    '--strip-unneeded[remove all symbols not needed by relocations]'
    '*'{-N,--strip-symbol}'[do not copy specified symbol]:symbol name:'
    '*--strip-unneeded-symbol[do not copy symbol unless needed by relocations]:symbol name:'
    '--only-keep-debug[strip everything but debug information]'
    '--extract-dwo[copy only DWO sections]'
    '--extract-symbol[remove section contents but keep symbols]'

    # Symbol manipulation
    '*'{-K,--keep-symbol}'[do not strip specified symbol]:symbol name:'
    '--keep-file-symbols[do not strip file symbols]'
    '--keep-section[do not strip specified section]:section name:'
    '--keep-symbols[do not strip symbols listed in file]:file:_files'
    '--localize-hidden[turn all ELF hidden symbols into locals]'
    '*'{-L,--localize-symbol}'[force symbol to be marked as local]:symbol name:'
    '*--localize-symbols[force all symbols in file to be local]:file:_files'
    '*--globalize-symbol[force symbol to be marked as global]:symbol name:'
    '*--globalize-symbols[force all symbols in file to be global]:file:_files'
    '*'{-G,--keep-global-symbol}'[localize all symbols except specified]:symbol name:'
    '*--keep-global-symbols[localize all except symbols in file]:file:_files'
    '*'{-W,--weaken-symbol}'[force symbol to be marked as weak]:symbol name:'
    '*--weaken-symbols[force all symbols in file to be weak]:file:_files'
    '--weaken[force all global symbols to be marked as weak]'
    {-w,--wildcard}'[permit wildcard in symbol comparison]'

    # Section manipulation
    '*'{-j,--only-section}'[only copy specified section to output]:section name:'
    '*'{-R,--remove-section}'[remove specified section from output]:section name:'
    '*--remove-relocations[remove relocations from specified section]:section name:'
    '*--add-section[add section from file to output]:name=file:'
    '*--update-section[update section contents from file]:name=file:'
    '*--dump-section[dump section contents to file]:name=file:'
    '--rename-section[rename section]:old=new\[,flags\]:'
    '--set-section-flags[set section flags]:name=flags:'
    '--set-section-alignment[set section alignment]:name=alignment:'
    '--add-gnu-debuglink[add .gnu_debuglink section linking to file]:file:_files'

    # Discard options
    {-x,--discard-all}'[remove all non-global symbols]'
    {-X,--discard-locals}'[remove any compiler-generated symbols]'

    # Address manipulation
    '--change-start[add offset to start address]:offset:'
    '--adjust-start[alias for --change-start]:offset:'
    '--set-start[set the start address]:address:'
    '--change-addresses[add offset to all addresses]:offset:'
    '--adjust-vma[alias for --change-addresses]:offset:'
    '--change-section-address[change section address]:section{=|+|-}val:'
    '--adjust-section-vma[alias for --change-section-address]:section{=|+|-}val:'
    '--change-section-lma[change section LMA]:section{=|+|-}val:'
    '--change-section-vma[change section VMA]:section{=|+|-}val:'

    # Interleave options
    {-i,--interleave}'[only copy N out of every <number> bytes]:number:'
    '--interleave-width[set N for --interleave]:width:'
    {-b,--byte}'[select byte in every interleaved block]:byte number:'

    # Padding and fill
    '--gap-fill[fill gaps between sections with value]:value:'
    '--pad-to[pad the last section up to address]:address:'

    # Symbol redefine
    '--redefine-sym[redefine symbol name]:old=new:'
    '--redefine-syms[redefine all symbol pairs listed in file]:file:_files'

    # Prefix options
    '--prefix-symbols[add prefix to every symbol name]:prefix:'
    '--prefix-sections[add prefix to every section name]:prefix:'
    '--prefix-alloc-sections[add prefix to every allocatable section name]:prefix:'

    # Debug options
    '--debugging[convert debugging information if possible]'
    '--compress-debug-sections[compress DWARF debug sections]:type:(none zlib zlib-gnu zlib-gabi zstd)'
    '--decompress-debug-sections[decompress DWARF debug sections using zlib]'
    {-p,--preserve-dates}'[copy modified/access timestamps to output]'
    {-D,--enable-deterministic-archives}'[produce deterministic output when stripping archives]'
    {-U,--disable-deterministic-archives}'[disable -D behavior]'

    # Format options
    '--change-leading-char[force output format leading character style]'
    '--remove-leading-char[remove leading character from global symbols]'
    '--reverse-bytes[reverse bytes at a time in output sections]:num:'
    '--srec-len[restrict length of generated S-records]:length:'
    '--srec-forceS3[restrict generated S-records to type S3]'
    '--long-section-names[enable or disable long section names in COFF]:mode:(enable disable)'
    '--elf-stt-common[generate ELF common symbols with specified type]:type:(yes no)'

    # PE options
    '--file-alignment[set PE file alignment]:num:'
    '--heap[set PE heap reserve/commit size]:reserve\[,commit\]:'
    '--image-base[set PE image base address]:address:'
    '--section-alignment[set PE section alignment]:num:'
    '--stack[set PE stack reserve/commit size]:reserve\[,commit\]:'
    '--subsystem[set PE subsystem]:name\[,version\]:'

    # Miscellaneous
    '--alt-machine-code[use target alternative machine code]:index:'
    '--writable-text[mark output text as writable]'
    '--readonly-text[make output text write-protected]'
    '--pure[mark output file as demand paged]'
    '--impure[mark output file as impure]'
    '--add-symbol[add a symbol to the output]:name=\[section:\]value\[,flags\]:'
    '--strip-symbols[strip all symbols listed in file]:file:_files'
    '--strip-unneeded-symbols[strip unneeded symbols listed in file]:file:_files'
    '--info[list supported object formats and architectures]'
    {-v,--verbose}'[list all object files modified]'

    # Input and output files
    '1:input file:_files'
    '2::output file:_files'
  )

  _arguments -s -S $arguments
}

_objcopy "$@"
