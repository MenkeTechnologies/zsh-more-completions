#compdef bless

local -a arguments

arguments=(
  '--help[show usage statement]'
  '--info[print blessing information for a specific volume]'
  '--getBoot[print the active boot volume]'
  '--version[print bless version number]'
  '--plist[use a plist representation for output]'
  '--verbose[verbose output]'
  '--file[set file as the blessed boot file]:file:_files'
  '--folder[set directory as the blessed directory]:directory:_files -/'
  '--bootinfo[use file to create a "BootX" file]:file:_files'
  '--bootefi[use file to create a "boot.efi" file]:file:_files'
  '--setBoot[set firmware to boot from this volume]'
  '--openfolder[set directory to be the visible Finder directory]:directory:_files -/'
  '--mount[use this mountpoint in conjunction with --setBoot]:mountpoint:_files -/'
  '--device[use this block device in conjunction with --setBoot]:device:_files'
  '--netboot[set firmware to boot from the network]'
  '--server[use BDSP to fetch boot parameters from url]:url:'
  '*:filename:_files'
)

_arguments -s -S $arguments
