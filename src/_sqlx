#compdef sqlx

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-D --database-url)'{-D,--database-url}'[database URL]:url' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a cmds=(
      'database:manage the database'
      'migrate:manage database migrations'
      'prepare:generate query metadata for offline mode'
    )
    _describe -t commands 'sqlx command' cmds && ret=0
    ;;
  args)
    case "${words[1]}" in
      database)
        local -a db_cmds=(
          'create:create the database'
          'drop:drop the database'
          'reset:drop and recreate the database'
        )
        _arguments -s -S \
          '(-D --database-url)'{-D,--database-url}'[database URL]:url' \
          '--connect-timeout[connection timeout in seconds]:seconds' \
          '1:subcommand:->db_sub' && ret=0
        [[ "$state" == db_sub ]] && _describe -t commands 'sqlx database command' db_cmds && ret=0
        ;;
      migrate)
        local -a mig_cmds=(
          'add:create a new migration'
          'run:run pending migrations'
          'revert:revert the latest migration'
          'info:show migration status'
          'build-script:generate a migration build script'
        )
        _arguments -s -S \
          '(-D --database-url)'{-D,--database-url}'[database URL]:url' \
          '--source[migrations directory]:directory:_files -/' \
          '--connect-timeout[connection timeout in seconds]:seconds' \
          '1:subcommand:->mig_sub' && ret=0
        [[ "$state" == mig_sub ]] && _describe -t commands 'sqlx migrate command' mig_cmds && ret=0
        ;;
      prepare)
        _arguments -s -S \
          '(-D --database-url)'{-D,--database-url}'[database URL]:url' \
          '--connect-timeout[connection timeout in seconds]:seconds' && ret=0
        ;;
    esac
    ;;
esac
return ret
