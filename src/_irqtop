#compdef irqtop


local -a arguments

arguments=(
    {-o,--output}'[Specify which output columns to print.]'
    {-d,--delay}'[Update interrupt output every seconds intervals.]'
    {-s,--sort}'[Specify sort criteria by column name.]'
    {-V,--version}'[Display version information and exit.]'
    '--help[to get a list of all supported columns.]'
    '-h[Display help text and exit.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
