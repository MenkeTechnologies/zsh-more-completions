#compdef tailf

local -a arguments

arguments=(
    {-n,--lines}'[output the last NUMBER lines]:number:'
    '-NUMBER[same as `-n NUMBER`]'
    {-V,--version}'[output version information and exit]'
    '(- * :)'{-h,--help}'[display this help and exit]'
    '*:filename:_files'
)

_arguments -s -S $arguments
