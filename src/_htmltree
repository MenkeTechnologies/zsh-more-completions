#compdef htmltree
# Documentation: https://man.archlinux.org/search?q=htmltree
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-D[sets HTML::TreeBuilder::Debug to that figure.]'
  '-w[turns on $tree->warn(1) for the new tree]'
  '-h[help message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
