#compdef dbiprof

local -a arguments

arguments=(
  '-number[show top N, defaults to 10]'
  '-sort[sort by S, defaults to total]'
  '-reverse[reverse the sort]'
  '-match[key=value for filtering, see docs]'
  '-exclude[key=value for filtering, see docs]'
  '-case_sensitive[enable case sensitivity for -match and -exclude]'
  '-delete[rename files before reading then delete afterwards]'
  '-version[print version number and exit]'
  '-help[print this help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
