#compdef tload

local -a arguments

arguments=(
  {-d,--delay}'[update delay in seconds]:seconds:'
  {-s,--scale}'[vertical scale]:scale:'
  '(- * :)'{-h,--help}'[display this help and exit]'
  {-V,--version}'[output version information and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
