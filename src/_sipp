#compdef sipp

local -a arguments

arguments=(
  '-v[Display version and copyright information.]'
  '-aa[Enable automatic 200 OK answer for INFO, UPDATE and NOTIFY messages.]'
  '-auth_uri[Force the value of the URI for authentication.]'
  '-au[Set authorization username for authentication challenges.]'
  '-ap[Set the password for authentication challenges.]'
  '-base_cseq[Start value of \[cseq\] for each call.]'
  '-bg[Launch SIPp in background mode.]'
  '-bind_local[Bind socket to local IP address.]'
  '-buff_size[Set the send and receive buffer size.]'
  '-calldebug_file[Set the name of the call debug file.]'
  '-calldebug_overwrite[Overwrite the call debug file (default true).]'
  '-cid_str[Call ID string (default %u-%p@%s).]'
  '-ci[Set the local control IP address.]'
  '-cp[Set the local control port number. Default is 8888.]'
  '-d[Controls the length of calls.]'
  '-deadcall_wait[How long the Call-ID and final status of calls should be kept.]'
  '-default_behaviors[Set the default behaviors that SIPp will use.]'
  '-error_file[Set the name of the error log file.]'
  '-error_overwrite[Overwrite the error log file (default true).]'
  '-f[Set the statistics report frequency on screen.]'
  '-fd[Set the statistics dump log report frequency.]'
  '-i[Set the local IP address for Contact:, Via:, and From headers.]'
  '-inf[Inject values from an external CSV file during calls.]'
  '-infindex[Create an index of file using field.]'
  '-ip_field[Set which field from the injection file contains the IP.]'
  '-l[Set the maximum number of simultaneous calls.]'
  '-log_file[Set the name of the log actions log file.]'
  '-log_overwrite[Overwrite the log actions log file (default true).]'
  '-lost[Set the number of packets to lose by default.]'
  '-rtcheck[Select the retransmission detection method: full or loose.]'
  '-m[Stop the test and exit when calls are processed.]'
  '-mi[Set the local media IP address.]'
  '-master[3pcc extended mode: indicates the master number.]'
  '-max_recv_loops[Set the maximum number of messages received per cycle.]'
  '-max_sched_loops[Set the maximum number of calls run per event loop.]'
  '-max_reconnect[Set the maximum number of reconnections.]'
  '-max_retrans[Maximum number of UDP retransmissions before call ends.]'
  '-max_invite_retrans[Maximum number of UDP retransmissions for invite transactions.]'
  '-max_non_invite_retrans[Maximum number of UDP retransmissions for non-invite transactions.]'
  '-max_log_size[Set the limit for error and message log file sizes.]'
  '-max_socket[Set the max number of sockets to open simultaneously.]'
  '-mb[Set the RTP echo buffer size (default: 2048).]'
  '-message_file[Set the name of the message log file.]'
  '-message_overwrite[Overwrite the message log file (default true).]'
  '-mp[Set the local RTP echo port number. Default is 6000.]'
  '-nd[No Default. Disable all default behavior of SIPp.]'
  '-nr[Disable retransmission in UDP mode.]'
  '-nostdin[Disable stdin.]'
  '-p[Set the local port number.]'
  '-pause_msg_ign[Ignore the messages received during a pause.]'
  '-periodic_rtd[Reset response time partition counters each logging period.]'
  '-plugin[Load a plugin.]'
  '-r[Set the call rate (in calls per seconds).]'
  '-rp[Specify the rate period for the call rate.]'
  '-rate_scale[Control the units for the +, -, *, and / keys.]'
  '-rate_increase[Specify the rate increase every -fd units.]'
  '-rate_max[If -rate_increase is set, quit after the rate is reached.]'
  '-no_rate_quit[If -rate_increase is set, do not quit after the rate is reached.]'
  '-recv_timeout[Global receive timeout in milliseconds.]'
  '-send_timeout[Global send timeout in milliseconds.]'
  '-sleep[How long to sleep for at startup.]'
  '-reconnect_close[Should calls be closed on reconnect?]'
  '-reconnect_sleep[How long (in milliseconds) to sleep between close and reconnect.]'
  '-ringbuffer_files[How many error/message files should be kept after rotation.]'
  '-ringbuffer_size[How large should error/message files be before rotation.]'
  '-rsa[Set the remote sending address to host:port.]'
  '-rtp_echo[Enable RTP echo.]'
  '-rtt_freq[Dump response times every freq calls.]'
  '-s[Set the username part of the request URI.]'
  '-sd[Dumps a default scenario (embedded in the sipp executable).]'
  '-sf[Loads an alternate xml scenario file.]'
  '-shortmessage_file[Set the name of the short message log file.]'
  '-shortmessage_overwrite[Overwrite the short message log file (default true).]'
  '-oocsf[Load out-of-call scenario.]'
  '-oocsn[Load out-of-call scenario.]'
  '-skip_rlimit[Do not perform rlimit tuning of file descriptor limits.]'
  '-slave[3pcc extended mode: indicates the slave number.]'
  '-slave_cfg[3pcc extended mode: indicates the file where the master is defined.]'
  '-sn[Use a default scenario (embedded in the sipp executable).]'
  '-stat_delimiter[Set the delimiter for the statistics file.]'
  '-stf[Set the file name to use to dump statistics.]'
  '-t[Set the transport mode.]'
  '-timeout[Global timeout. Default unit is seconds.]'
  '-timeout_error[SIPp fails if the global timeout is reached.]'
  '-timer_resol[Set the timer resolution in milliseconds.]'
  '-T2[Global T2-timer in milliseconds.]'
  '-sendbuffer_warn[Produce warnings instead of errors on SendBuffer failures.]'
  '-trace_msg[Displays sent and received SIP messages.]'
  '-trace_shortmsg[Displays sent and received SIP messages as CSV.]'
  '-trace_screen[Dump statistic screens to file.]'
  '-trace_err[Trace all unexpected messages.]'
  '-trace_calldebug[Dumps debugging information about aborted calls.]'
  '-trace_stat[Dumps all statistics to CSV file.]'
  '-trace_counts[Dumps individual message counts in a CSV file.]'
  '-trace_rtt[Allow tracing of all response times.]'
  '-trace_logs[Allow tracing of log actions.]'
  '-users[Instead of starting calls at a fixed rate, begin users.]'
  '-watchdog_interval[Set gap between watchdog timer firings. Default is 400.]'
  '-watchdog_reset[If the watchdog timer has not fired in more than this time, reset.]'
  '-watchdog_minor_threshold[Minor watchdog timer threshold.]'
  '-watchdog_major_threshold[Major watchdog timer threshold.]'
  '-watchdog_major_maxtriggers[How many times the major watchdog timer can be tripped.]'
  '-watchdog_minor_maxtriggers[How many times the minor watchdog timer can be tripped.]'
  '-3pcc[Launch the tool in 3pcc mode (Third Party call control).]'
  '-tdmmap[Generate and handle a table of TDM circuits.]'
  '-key[Set a keyword value.]'
  '-set[Set a variable value.]'
  '-dynamicStart[Set dynamic start variable value.]'
  '-dynamicMax[Set dynamic max variable value.]'
  '-dynamicStep[Set dynamic step variable value.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
