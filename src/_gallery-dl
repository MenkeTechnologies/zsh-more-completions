#compdef gallery-dl

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-d --dest)'{-d,--dest}'[destination directory]:dir:_directories' \
  '(-D --directory)'{-D,--directory}'[format string for subdirectories]:format' \
  '(-f --filename)'{-f,--filename}'[format string for filenames]:format' \
  '(-i --input-file)'{-i,--input-file}'[download URLs from file]:file:_files' \
  '(-I --input-file-comment)'{-I,--input-file-comment}'[download URLs from file (skip comments)]:file:_files' \
  '(-I --input-file-delete)--input-file-delete[delete URLs from file after download]:file:_files' \
  '--no-skip[do not skip already downloaded files]' \
  '(-o --option)'{-o,--option}'[set option]:key=value' \
  '(-c --config)'{-c,--config}'[config file]:file:_files -g "*.{json,conf}"' \
  '--config-create[create a default config file]' \
  '--config-toml[load TOML config file]:file:_files -g "*.toml"' \
  '--config-yaml[load YAML config file]:file:_files -g "*.{yml,yaml}"' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-g --get-urls)'{-g,--get-urls}'[print URLs instead of downloading]' \
  '(-G --resolve-urls)'{-G,--resolve-urls}'[resolve URLs and print]' \
  '(-j --dump-json)'{-j,--dump-json}'[dump metadata as JSON]' \
  '(-s --simulate)'{-s,--simulate}'[simulate downloads]' \
  '(-E --extractor-info)'{-E,--extractor-info}'[print extractor info]' \
  '--list-extractors[list available extractors]' \
  '--list-keywords[list available keywords]' \
  '--list-modules[list available modules]' \
  '(-K --keywords)'{-K,--keywords}'[print available metadata keywords]' \
  '(-r --limit-rate)'{-r,--limit-rate}'[download rate limit]:rate' \
  '(-R --retries)'{-R,--retries}'[number of retries]:count' \
  '--sleep[sleep between requests]:seconds' \
  '--sleep-request[sleep between requests]:seconds' \
  '--sleep-extractor[sleep between extractors]:seconds' \
  '--proxy[use proxy]:url' \
  '--source-address[client-side IP address]:address' \
  '--user-agent[custom user agent]:string' \
  '--clear-cache[clear cache]' \
  '(-u --username)'{-u,--username}'[username]:username' \
  '(-p --password)'{-p,--password}'[password]:password' \
  '--netrc[use .netrc for authentication]' \
  '--cookies[cookies file]:file:_files' \
  '--cookies-from-browser[load cookies from browser]:browser' \
  '--no-colors[disable colored output]' \
  '--no-check-certificate[disable certificate verification]' \
  '--range[download specific file range]:range' \
  '--chapter-range[download specific chapter range]:range' \
  '--filter[filter expression]:expression' \
  '--chapter-filter[chapter filter expression]:expression' \
  '--archive[archive database file]:file:_files' \
  '--archive-format[archive ID format]:format' \
  '--write-metadata[write metadata files]' \
  '--write-tags[write tag files]' \
  '--write-infojson[write info JSON]' \
  '--zip[store files in ZIP archive]' \
  '--ugoira-conv[convert ugoira to webm]' \
  '--mtime-from-date[set file mtime from metadata date]' \
  '--exec[execute command for each file]:command' \
  '--exec-after[execute command after all files]:command' \
  '*:URL' && ret=0

return ret
