#compdef vim gvim rvim rview vimdiff

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-v[vi mode (like "vi")]' \
  '-e[ex mode (like "ex")]' \
  '-E[improved Ex mode]' \
  '-s[silent (batch) mode (only for "ex")]' \
  '-d[diff mode (like "vimdiff")]' \
  '-y[easy mode (like "evim", modeless)]' \
  '-R[readonly mode (like "view")]' \
  '-Z[restricted mode (like "rvim")]' \
  '-m[modifications (writing files) not allowed]' \
  '-M[modifications in text not allowed]' \
  '-b[binary mode]' \
  '-l[lisp mode]' \
  '-C[compatible with Vi: '\''compatible'\'']' \
  '-N[not fully Vi compatible: '\''nocompatible'\'']' \
  '-V-[be verbose (level N, log to fname)]:verbosity:' \
  '-D[debugging mode]' \
  '-n[no swap file, use memory only]' \
  '-r[list swap files and exit / recover crashed session]' \
  '-L[same as -r]' \
  '-A[start in Arabic mode]' \
  '-H[start in Hebrew mode]' \
  '-T[set terminal type]:terminal:_terminals' \
  '--not-a-term[skip warning for input/output not being a terminal]' \
  '--ttyfail[exit if input or output is not a terminal]' \
  '-u[use specified vimrc instead of any .vimrc]:vimrc file:_files' \
  '--noplugin[do not load plugin scripts]' \
  '-p-[open N tab pages (default: one for each file)]:number of tabs:' \
  '-o-[open N windows (default: one for each file)]:number of windows:' \
  '-O-[like -o but split vertically]:number of windows:' \
  '+[start at end of file]' \
  '+[start at specified line number]:line number:' \
  '--cmd[execute command before loading any vimrc file]:command:' \
  '-c[execute command after loading the first file]:command:' \
  '-S[source file after loading the first file]:session file:_files' \
  '-s[read Normal mode commands from file]:script input file:_files' \
  '-w[append all typed commands to file]:script output file:_files' \
  '-W[write all typed commands to file]:script output file:_files' \
  '-x[edit encrypted files]' \
  '-i[use specified viminfo instead of .viminfo]:viminfo file:_files' \
  '--remote[edit files in a Vim server if possible]:*:files:_files' \
  '--remote-silent[same as --remote but do not complain if no server]:*:files:_files' \
  '--remote-wait[as --remote but wait for files to have been edited]:*:files:_files' \
  '--remote-wait-silent[same as --remote-wait, no complain if no server]:*:files:_files' \
  '--remote-tab[as --remote but use tab page per file]:*:files:_files' \
  '--remote-tab-wait[as --remote-tab but wait for files to be edited]:*:files:_files' \
  '--remote-tab-silent[as --remote-tab, no complain if no server]:*:files:_files' \
  '--remote-tab-wait-silent[as --remote-tab-wait, no complain if no server]:*:files:_files' \
  '--remote-send[send keys to a Vim server and exit]:keys:' \
  '--remote-expr[evaluate expression in a Vim server and print result]:expression:' \
  '--serverlist[list available Vim server names and exit]' \
  '--servername[send to/become the Vim server with specified name]:server name:' \
  '--startuptime[write startup timing messages to file]:timing file:_files' \
  '--log[start logging to file early]:log file:_files' \
  '--clean[nocompatible, Vim defaults, no plugins, no viminfo]' \
  '(- * :)'{-h,--help}'[print help message and exit]' \
  '(- * :)--version[print version information and exit]' \
  '*:file:_files' && ret=0

return ret
