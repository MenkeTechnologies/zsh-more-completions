#compdef pcdindex
# Documentation: https://man.archlinux.org/search?q=pcdindex
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-n[F = font to be used for annotation     ]'
  '-b[/-w = black/white background color    (default: -black)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
