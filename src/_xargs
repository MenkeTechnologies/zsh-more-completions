#compdef xargs

# Zsh completion for xargs - construct argument list(s) and execute utility
# Supports both BSD/macOS and GNU/Linux (findutils) variants

local -a arguments

arguments=(
  # Common options (POSIX / BSD / GNU)
  '(-0 --null)'{-0,--null}'[expect NUL characters as separators instead of spaces/newlines]'
  '-E[use specified string as logical EOF marker]:eof string:'
  '(-I --replace)'{-I,--replace=}'[replace occurrences of replstr in arguments with input line]:replace string:'
  '-J[replace first occurrence of replstr with input data (BSD)]:replace string:'
  '(-L --max-lines)'{-L,--max-lines=}'[call utility for every N non-empty input lines]:number of lines:'
  '(-n --max-args)'{-n,--max-args=}'[maximum number of arguments per invocation]:number of arguments:'
  '(-o --open-tty)'{-o,--open-tty}'[reopen stdin as /dev/tty in child process before executing]'
  '(-P --max-procs)'{-P,--max-procs=}'[run at most N invocations in parallel (0 = as many as possible)]:max processes:'
  '(-p --interactive)'{-p,--interactive}'[prompt before executing each command]'
  '(-r --no-run-if-empty)'{-r,--no-run-if-empty}'[do not run command if input is empty]'
  '-R[maximum number of replacements per argument (use with -I, BSD)]:replacements:'
  '(-s --max-chars)'{-s,--max-chars=}'[maximum number of bytes per command line]:size in bytes:'
  '-S[maximum size of each replacement string (use with -I, BSD)]:replacement size:'
  '(-t --verbose)'{-t,--verbose}'[print each command line to stderr before executing]'
  '(-x --exit)'{-x,--exit}'[exit if command line size exceeds -s limit]'

  # GNU-specific options
  '(-a --arg-file)'{-a,--arg-file=}'[read arguments from file instead of stdin]:input file:_files'
  '(-d --delimiter)'{-d,--delimiter=}'[use specified character as input delimiter]:delimiter character:'
  '--process-slot-var=[set environment variable to unique slot number for parallel jobs]:variable name:'
  '--show-limits[show OS-imposed limits on command line length]'

  '(- *)--help[display help and exit]'
  '(- *)--version[output version information and exit]'

  '*:utility and arguments:_command_names -e'
)

_arguments -s -S $arguments
