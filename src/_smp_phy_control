#compdef smp_phy_control

local -a arguments

arguments=(
  '--attached[ADN attached device name \[a decimal number]'
  '--expected[EX set expected expander change count to EX]'
  {--help,-h}'[print out usage message]'
  {--hex,-H}'[print response in hexadecimal]'
  '--interface[PARAMS specify or override interface]'
  '--max[MA programmable maximum physical link speed]'
  '--min[MI programmable minimum physical link speed]'
  '--op[OP OP (operation) is a number or abbreviation.]'
  '--phy[ID phy identifier (def: 0)]'
  '--pptv[TI partial pathway timeout value (microseconds)]'
  '--pwrdis[PDC sets power disable control field (def: 0)]'
  {--raw,-r}'[output response in binary]'
  '--sa[SAS_ADDR SAS address of SMP target (use leading]'
  {--sas_pa,-q}'[enable SAS Partial field; CO: 0->leave (def)]'
  {--sas_sl,-l}'[enable Slumber Partial field]'
  {--sata_pa,-Q}'[enable SATA Partial field]'
  {--sata_sl,-L}'[enable SATA Slumber field]'
  {--verbose,-v}'[increase verbosity]'
  {--version,-V}'[print version string and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
