#compdef set_unicharset_properties

local -a arguments

arguments=(
  '--debug_level[level of trainer debugging (default: 0)]:int'
  '--load_images[load images with tr files (default: 0)]:int'
  '--clusterconfig_min_samples_fraction[min number of samples per proto as % of total (default: 0.625)]:double'
  '--clusterconfig_max_illegal[max percentage of samples in a cluster with more than 1 feature (default: 0.05)]:double'
  '--clusterconfig_independence[desired independence between dimensions (default: 1)]:double'
  '--clusterconfig_confidence[desired confidence in prototypes created (default: 1e-06)]:double'
  '--script_dir[directory name for input script unicharsets/xheights]:directory:_directories'
  '--configfile[file to load more configs from]:file:_files'
  '--D[directory to write output files to]:directory:_directories'
  '--F[file listing font properties (default: font_properties)]:file:_files'
  '--X[file listing font xheights]:file:_files'
  '--U[file to load unicharset from (default: unicharset)]:file:_files'
  '--O[file to write unicharset to]:file:_files'
  '--output_trainer[file to write trainer to]:file:_files'
  '--test_ch[UTF8 test character string]:string'
  '--fonts_dir[fonts directory]:directory:_directories'
  '--fontconfig_tmpdir[fontconfig temp directory]:directory:_directories'
  '*:filename:_files'
)

_arguments -s -S $arguments
