#compdef lapce

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-n --new)'{-n,--new}'[open in a new window]' \
  '--wait[wait for the files to be closed before returning]' \
  '*:file:_files' && ret=0

return ret
