#compdef abrt-action-generate-backtrace
# Documentation: https://man.archlinux.org/search?q=abrt-action-generate-backtrace
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-v,--verbose}'[be verbose]'
  '-d[problem directory]'
  '-i[1\[Additional debuginfo directories]:DIR2\]...:'
  '-t[kill gdb if it runs for more than NUM seconds]'
  '*:filename:_files'
)

_arguments -s -S $arguments
