#compdef gr_constellation_plot
# Documentation: https://man.archlinux.org/search?q=gr_constellation_plot
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-N,--nsamples}'[set the number of samples to display \[default=1000000\]]'
  {-S,--start}'[starting sample number \[default=0\]]'
  '*:filename:_files'
)

_arguments -s -S $arguments
