#compdef uptime

# Zsh completion for uptime (show how long system has been running)
# Supports both BSD (macOS/FreeBSD) and GNU/Linux versions

local curcontext="$curcontext" ret=1

if [[ "$OSTYPE" == linux* ]]; then
  # GNU procps-ng uptime
  _arguments -s -S \
    {-p,--pretty}'[show uptime in pretty format]' \
    {-s,--since}'[system up since, in yyyy-mm-dd HH:MM:SS format]' \
    '(- *)'{-h,--help}'[display help and exit]' \
    '(- *)'{-V,--version}'[output version information and exit]' && ret=0
else
  # BSD uptime (macOS/FreeBSD)
  _arguments -s -S \
    '--libxo[generate output via libxo in various formats]' && ret=0
fi

return ret
