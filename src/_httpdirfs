#compdef httpdirfs

# Zsh completion for httpdirfs (HTTP directory as filesystem)

_arguments -s -S \
  '--cache[enable local cache]' \
  '--cache-location[cache directory]:dir:_files -/' \
  '--dl-seg-size[download segment size]:size:' \
  '--max-seg-count[max segment count]:count:' \
  '--retry-wait[retry wait time in seconds]:seconds:' \
  '--max-conns[max connections]:connections:' \
  '--user-agent[user agent string]:user agent:' \
  '--username[HTTP basic auth username]:username:' \
  '--password[HTTP basic auth password]:password:' \
  '--proxy[proxy URL]:url:_urls' \
  '--proxy-username[proxy username]:username:' \
  '--proxy-password[proxy password]:password:' \
  '--no-range-check[disable partial transfer check]' \
  '--insecure-tls[skip TLS verification]' \
  '(-f)-f[stay in foreground]' \
  '(-d)-d[enable debug output]' \
  '(-s)-s[single-threaded]' \
  '(-o)-o[FUSE mount options]:options:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:URL:_urls' \
  '2:mountpoint:_files -/' && return 0
