#compdef dust

# Zsh completion for dust (du + rust) - disk usage analyzer
# https://github.com/bootandy/dust

_dust() {
    local -a arguments

    arguments=(
        # Display options
        {-d,--depth}'[depth to show]:depth:'
        {-n,--number-of-lines}'[number of lines of output to show]:lines:'
        {-p,--full-paths}'[subdirectories will not have their path shortened]'
        {-r,--reverse}'[print tree upside down (largest entries at bottom)]'
        {-c,--no-colors}'[no colors will be printed (normally directory size is colored)]'
        {-C,--force-colors}'[force colors to be printed even when output is not a terminal]'
        {-b,--no-percent-bars}'[no percent bars or percentages will be displayed]'
        {-B,--bars-on-right}'[percent bars moved to right side of output]'
        {-R,--screen-reader}'[remove bars and add a depth level column for screen readers]'
        {-w,--terminal-width}'[specify width of output overriding the auto-detection]:width:'
        {-j,--output-json}'[output the directory tree as JSON]'
        {-o,--output-format}'[changes output display size format]:format:(si b k m g t ki mi gi ti)'

        # Filtering options
        {-e,--filter}'[only include filepaths matching this regex]:pattern:'
        {-v,--invert-filter}'[exclude filepaths matching this regex]:pattern:'
        {-t,--file-types}'[show only these file types]:types:'
        {-X,--ignore-directory}'[exclude any file or directory with this name]:directory:_files -/'
        {-I,--ignore-all-in-file}'[exclude files/directories matching regexes found in this file]:file:_files'
        {-i,--ignore-hidden}'[do not display hidden files]'
        {-z,--min-size}'[minimum size file to include in output]:size:'
        {-D,--only-dir}'[only directories will be displayed]'
        {-F,--only-file}'[only files will be displayed]'
        '*--collapse[keep these directories collapsed]:directory:_files -/'

        # Sizing options
        {-s,--apparent-size}'[use file length instead of blocks]'
        {-f,--filecount}'[directory size is number of child files/directories instead of disk size]'
        {-m,--filetime}'[directory size shown is max filetime of children]'

        # Time filter options
        {-M,--mtime}'[only include files modified within n days ago (+n older, -n newer)]:days:'
        {-A,--atime}'[only include files accessed within n days ago (+n older, -n newer)]:days:'
        {-y,--ctime}'[only include files changed within n days ago (+n older, -n newer)]:days:'

        # Filesystem options
        {-x,--limit-filesystem}'[only count the files and directories on the same filesystem]'
        {-L,--dereference-links}'[dereference symbolic links]'

        # Input options
        '--files0-from[read NUL-terminated file paths from file]:file:_files'
        '--files-from[read newline-terminated file paths from file]:file:_files'

        # Performance options
        {-T,--threads}'[number of threads to use]:threads:'
        {-S,--stack-size}'[specify memory to use as stack size (use if getting stack overflow)]:size:'

        # Misc options
        '--config[specify a config file to use]:config file:_files'
        '--skip-total[no total row will be displayed]'
        '--print-errors[print filesystem errors to stderr]'
        {-P,--no-progress}'[disable the progress indication]'
        {-h,--help}'[print help information]'
        {-V,--version}'[print version information]'

        # Positional arguments
        '*:path:_files -/'
    )

    _arguments -s -S $arguments
}

_dust "$@"
