#compdef festival_server_control
# Documentation: https://man.archlinux.org/search?q=festival_server_control
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-p[port server is listening on, defaults to 1314]'
  '-l[server put its logfile into LOGDIR, defaults to .]'
  '*:filename:_files'
)

_arguments -s -S $arguments
