#compdef httpd

local -a arguments

arguments=(
  '-D[define a name for use in <IfDefine name> directives]'
  '-d[specify an alternate initial ServerRoot]'
  '-f[specify an alternate ServerConfigFile]'
  '-C[process directive before reading config files]:directive:'
  '-c[process directive after reading config files]:directive:'
  '-e[show startup errors of level (see LogLevel)]'
  '-E[log startup errors to file]'
  '-v[show version number]'
  '-V[show compile settings]'
  '-h[list available command line options (this page)]'
  '-l[list compiled in modules]'
  '-L[list available configuration directives]'
  '-S[show parsed vhost settings (synonym for -t -D DUMP_VHOSTS -D DUMP_RUN_CFG)]'
  '-M[show all loaded modules (synonym for -t -D DUMP_MODULES)]'
  '-t[run syntax check for config files]'
  '-T[start without DocumentRoot(s) check]'
  '-X[debug mode (only one worker, do not detach)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
