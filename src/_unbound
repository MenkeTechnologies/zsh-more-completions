#compdef unbound
# Documentation: https://man.archlinux.org/search?q=unbound
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[this help]'
  '-c[config file to read instead of /var/unbound/unbound.conf]'
  '-d[do not fork into the background.]'
  '-v[verbose (more times to increase verbosity)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
