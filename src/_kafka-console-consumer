#compdef kafka-console-consumer

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--topic[Topic to consume from]:topic:'
    '--group[Consumer group ID]:group:'
    '--consumer-property[User-defined properties as key=value pairs]:property:'
    '--consumer.config[Consumer config properties file]:file:_files'
    '--formatter[Message formatter class]:class:'
    '--property[Properties for the message formatter]:property:'
    '--from-beginning[Start with earliest message]'
    '--max-messages[Maximum number of messages to consume]:count:'
    '--partition[Partition to consume from]:partition:'
    '--offset[Offset to consume from]:offset:(earliest latest)'
    '--skip-message-on-error[Skip messages with errors]'
    '--key-deserializer[Key deserializer class]:class:'
    '--value-deserializer[Value deserializer class]:class:'
    '--timeout-ms[Exit if no message available for specified time]:ms:'
    '--whitelist[Regex of topics to include]:regex:'
    '--include[Regex of topics to include]:regex:'
    '--isolation-level[Isolation level]:level:(read_committed read_uncommitted)'
    '--enable-systest-events[Enable system test lifecycle events logging]'
)

_arguments -s -S $arguments
