#compdef festival_server
# Documentation: https://man.archlinux.org/search?q=festival_server
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-p[port to listen on, defaults to 1314]'
  '-l[record what is happening in the given directory]'
  '-c[file of Scheme code to be loaded by festival]'
  '-show[print the configuration file which would have]'
  '*:filename:_files'
)

_arguments -s -S $arguments
