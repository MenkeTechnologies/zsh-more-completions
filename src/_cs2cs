#compdef cs2cs invcs2cs
# Documentation: https://proj.org/en/stable/apps/cs2cs.html
# Source: OSGeo/PROJ src/apps/cs2cs.cpp — convert coordinates between two CRS (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--area+[area of interest name]:area:_default' \
    '--bbox+[bounding box west,south,east,north]:bbox:_default' \
    '--accuracy+[required accuracy in metres]:value:_default' \
    '--authority+[restrict authorities]:auth:(EPSG ESRI IGNF OGC PROJ)' \
    '--no-ballpark[disable ballpark transformations]' \
    '--only-best[use only best available transformation]' \
    '-d+[decimal places for output]:n:_default' \
    '-D+[debug level]:level:_default' \
    '-e+[alternative error line]:value:_default' \
    '-E[echo ASCII input to ASCII output]' \
    '-f+[output format (printf-style)]:format:_default' \
    '-I[swap source/target CRS (inverse)]' \
    '-l-[list info]:type:(=ellps =units =meridians =datums =projections)' \
    '-r[reverse input order]' \
    '-s[reverse output order]' \
    '-t+[column-1 marker character]:char:_default' \
    '-v[monitor PROJ initialization]' \
    '-w+[output precision (constant field width)]:n:_default' \
    '-W+[output precision (seconds)]:n:_default' \
    '*:input file:_files' \
    && ret=0

return ret
