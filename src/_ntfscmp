#compdef ntfscmp
# Documentation: https://man.archlinux.org/search?q=ntfscmp
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-P,--no-progress-bar}'[dont show progress bar]'
  {-v,--verbose}'[more output]'
  '(- * :)'{-h,--help}'[display this help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
