#compdef qemu-img

local -a arguments

arguments=(
    {-h,--help}'[Display this help and exit.]'
    {-V,--version}'[Display version information and exit.]'
    {-T,--trace}'[specify tracing options]:pattern: '
    '--object[QEMU user creatable object definition]:objectdef: '
    '--image-opts[interpret source filename as a full option string]'
    '--target-image-opts[interpret output filename as a full option string]'
    {--force-share,-U}'[open the image in shared mode]'
    '--backing-chain[Will enumerate information about backing files in a disk image chain.]'
    '-c[Indicates that target image must be compressed (qcow format only).]'
    '-p[Display progress bar (compare, convert and rebase commands only).]'
    '-q[Quiet mode - do not print any output (except errors).]'
    '-S[consecutive number of bytes of zeros for sparse output]:size: '
    '-t[cache mode for the destination file]:cache: '
    '-f[first image format]:format: '
    '-F[second image format]:format: '
    '-s[Strict mode - fail on different image size or sector allocation.]'
    '--bitmaps[Additionally copy all persistent bitmaps from the top layer of the source.]'
    '-n[Skip the creation of the target volume.]'
    '-m[number of parallel coroutines for the convert process]:num: '
    '-W[Allow out-of-order writes to the destination.]'
    '-C[Try to use copy offloading to move data from source image to target.]'
    '-r[rate limit for the convert process]:rate: '
    '--salvage[Try to ignore I/O errors when reading.]'
    '--target-is-zero[Assume that reading the destination image will always return zeros.]'
    '-a[Applies a snapshot (revert disk to saved state).]'
    '-d[Deletes a snapshot.]'
    '-l[Lists all snapshots in the given image.]'
    '-o[image format specific options]:options: '
    '-i[flush interval for benchmarking]:interval: '
    '--pattern[pattern for benchmarking]:pattern: '
    '--flush-interval[flush interval for benchmarking]:interval: '
    '--merge[merge bitmaps]'
    '--add[add a bitmap]'
    '--remove[remove a bitmap]'
    '--clear[clear a bitmap]'
    '--enable[enable a bitmap]'
    '--disable[disable a bitmap]'
    '-b[backing file]:file:_files'
    '-g[granularity for bitmaps]:granularity: '
    '--output[output format for check or info]:format:(human json)'
    '-O[output image format]:format: '
    '-B[backing file for output image]:file:_files'
    '--start-offset[start offset for map]:offset: '
    '--max-length[max length for map]:length: '
    '--size[calculate file size required for a new image]:size: '
    '--preallocation[preallocation mode]:mode:(off metadata falloc full)'
    '--force[force dangerous operations]'
    '--no-drain[do not drain requests before snapshot]'
    '*:filename:_files'
)
_arguments -s -S $arguments
