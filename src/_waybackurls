#compdef waybackurls

# Zsh completion for waybackurls - fetch known URLs from Wayback Machine

_arguments -s -S \
  '--dates[show date of fetch in the first column]' \
  '--get-versions[list URLs for every version of a URL]' \
  '--no-subs[do not include subdomains of the target domain]' \
  '*:domain:_hosts'
