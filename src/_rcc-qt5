#compdef rcc-qt5

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[displays help on commandline options.]'
  '--help-all[displays help including Qt specific options]'
  {-v,--version}'[displays version information]'
  {-o,--output}'[write output to file rather than stdout]'
  {-t,--temp}'[use temporary file for big resources]'
  '--name[create an external initialization function with name]'
  '--root[prefix resource access path with root path]'
  '--compress-algo[compress input files using specified algorithm]'
  '--compress[compress input files by level]'
  '--no-compress[disable all compression]'
  '--threshold[threshold to consider compressing files]'
  '--binary[output a binary file for use as a dynamic resource]'
  {-g,--generator}'[select generator]'
  '--pass[pass number for big resources]'
  '--namespace[turn off namespace macros]'
  '--verbose[enable verbose mode]'
  '--list[only list .qrc file entries, do not generate code]'
  '--list-mapping[only output a mapping of resource paths to file system paths]'
  {-d,--depfile}'[write a depfile with the .qrc dependencies]'
  '--project[output a resource file containing all files in the directory]'
  '--format-version[the RCC format version to write]'
  '*:filename:_files'
)

_arguments -s -S $arguments
