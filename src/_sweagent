#compdef sweagent swe-agent

# Zsh completion for sweagent (Software Engineering Agent)

local -a commands
commands=(
  'run:Run the agent on a single issue'
  'run-batch:Run the agent on a batch of issues'
  'run-replay:Replay a previous trajectory file'
  'inspect:Open the command-line trajectory inspector'
  'inspector:Open the web-based trajectory inspector'
  'quick-stats:Display a summary of exit statuses'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[Show help message]' \
  '1: :_describe -t commands "command" commands' \
  '*:: :->args'

case $words[1] in
  run|run-batch)
    _arguments \
      '--agent.model.name=[Model name]:model:(gpt-4o claude-3-5-sonnet-latest)' \
      '--env.repo.github_url=[GitHub URL]:url:' \
      '--env.repo.path=[Local repo path]:path:_files -/' \
      '--problem_statement.github_url=[Issue URL]:url:' \
      '--problem_statement.text=[Problem description]:text:' \
      '--actions.open_pr[Automatically open a PR]' \
      '--actions.apply_patch_locally[Apply fix locally]'
    ;;
  run-replay)
    _arguments \
      '1:trajectory file:_files'
    ;;
esac
