#compdef mwaw2text
# Documentation: https://man.archlinux.org/search?q=mwaw2text
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-i[display document metadata instead of the text]'
  '-h[shows this help message]'
  '-o[.txt       Define the output\[default stdout\]]'
  '-v[Output mwaw2text version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
