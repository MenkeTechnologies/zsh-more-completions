#compdef bsnmpd
# Documentation: https://man.archlinux.org/search?q=bsnmpd
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-d[dont daemonize]'
  '-h[print this info]'
  '-c[specify configuration file]'
  '-D[debugging options]'
  '-e[specify engine id file]'
  '-I[system include path]'
  '-l[default basename for pid and config file]'
  '-m[val define variable]'
  '-p[specify pid file]'
  '*:filename:_files'
)

_arguments -s -S $arguments
