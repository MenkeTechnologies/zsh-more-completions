#compdef rwsnoop
# Documentation: https://man.archlinux.org/search?q=rwsnoop
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-j[# print project ID]'
  '-P[# print parent process ID]'
  '-t[# print timestamp, us]'
  '-v[# print time, string]'
  '-Z[# print zone ID]'
  '-n[# this process name only]'
  '-p[# this PID only]'
  '*:filename:_files'
)

_arguments -s -S $arguments
