#compdef clamdtop
# Documentation: https://man.archlinux.org/search?q=clamdtop
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {--help,-h}'[show this help]'
  {--version,-V}'[show version]'
  {--config-file,-c}'[read clamds configuration files from FILE]'
  {--defaultcolors,-d}'[use default terminal colors]'
  '*:filename:_files'
)

_arguments -s -S $arguments
