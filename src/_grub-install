#compdef grub-install

# Completion for grub-install (GRUB bootloader installer)

_grub-install_targets() {
  local -a targets
  targets=(
    'i386-pc:BIOS-based x86 systems'
    'i386-efi:UEFI-based 32-bit x86 systems'
    'x86_64-efi:UEFI-based 64-bit x86 systems'
    'i386-qemu:QEMU 32-bit x86 emulation'
    'i386-coreboot:Coreboot 32-bit x86 firmware'
    'i386-multiboot:Multiboot 32-bit x86'
    'i386-ieee1275:Open Firmware 32-bit x86'
    'mipsel-loongson:Loongson MIPS'
    'mips-arc:ARC MIPS'
    'mipsel-arc:ARC MIPS (little-endian)'
    'mipsel-qemu_mips:QEMU MIPS (little-endian)'
    'mips-qemu_mips:QEMU MIPS'
    'arm-uboot:ARM U-Boot'
    'arm-efi:ARM UEFI'
    'arm64-efi:ARM64 UEFI (aarch64)'
    'powerpc-ieee1275:PowerPC Open Firmware'
    'sparc64-ieee1275:SPARC64 Open Firmware'
    'ia64-efi:IA-64 UEFI (Itanium)'
    'riscv32-efi:RISC-V 32-bit UEFI'
    'riscv64-efi:RISC-V 64-bit UEFI'
  )
  _describe -t targets 'target platform' targets
}

_grub-install_compressions() {
  local -a compressions
  compressions=(
    'no:no compression'
    'xz:XZ compression'
    'gz:gzip compression'
    'lzo:LZO compression'
  )
  _describe -t compressions 'compression type' compressions
}

_grub-install_core_compressions() {
  local -a compressions
  compressions=(
    'xz:XZ compression'
    'none:no compression'
    'auto:automatic compression selection'
  )
  _describe -t compressions 'core image compression' compressions
}

_grub-install_disk_modules() {
  local -a modules
  modules=(
    'biosdisk:BIOS disk access module'
    'native:native disk access module'
  )
  _describe -t modules 'disk module' modules
}

local arguments

arguments=(
  '(- *)'{-\?,--help}'[display help message and exit]'
  '(- *)--usage[display brief usage message and exit]'
  '(- *)'{-V,--version}'[print program version and exit]'

  '--compress=[compress GRUB files]:compression:_grub-install_compressions'
  {-d+,--directory=}'[use images and modules under specified directory]:directory:_directories'
  '--fonts=[install specified fonts (default\: unicode)]:fonts'
  '--install-modules=[install only specified modules and their dependencies]:modules'
  {-k+,--pubkey=}'[embed file as public key for signature checking]:public key file:_files'
  '--locale-directory=[use translations under specified directory]:locale directory:_directories'
  '--locales=[install only specified locales (default\: all)]:locales'
  '--modules=[pre-load specified modules]:modules'
  '--themes=[install specified themes (default\: starfield)]:themes'
  {-v,--verbose}'[print verbose messages]'

  '--allow-floppy[make the drive also bootable as floppy]'
  '--boot-directory=[install GRUB images under DIR/grub instead of /boot/grub]:boot directory:_directories'
  '--bootloader-id=[set the bootloader identifier for EFI/removable installs]:bootloader ID'
  '--core-compress=[choose compression for core image]:core compression:_grub-install_core_compressions'
  '--disable-shim-lock[disable shim_lock verifier]'
  '--disk-module=[disk module to use]:disk module:_grub-install_disk_modules'
  '--dtb=[embed a specific device tree blob]:DTB file:_files -g "*.dtb"'
  '--efi-directory=[use directory as the EFI System Partition root]:EFI directory:_directories'
  '--force[install even if problems are detected]'
  '--force-extra-removable[force installation to the removable media path also]'
  '--force-file-id[use identifier file even if UUID is available]'
  '--label-bgcolor=[use specified color for label background]:color'
  '--label-color=[use specified color for label text]:color'
  '--label-font=[use specified file as font for label]:font file:_files'
  '--macppc-directory=[use directory for PPC Mac install]:directory:_directories'
  '--no-bootsector[do not install bootsector]'
  '--no-nvram[do not update the boot-device/Boot* NVRAM variables]'
  '--no-rs-codes[do not apply reed-solomon codes when embedding core image]'
  '--no-uefi-secure-boot[do not install an image usable with UEFI Secure Boot]'
  '--product-version=[use specified string as product version]:version string'
  '--recheck[delete device map if it already exists and regenerate]'
  '--removable[the installation device is removable]'
  '--sbat=[SBAT metadata file]:SBAT file:_files'
  {-s,--skip-fs-probe}'[do not probe for filesystems in DEVICE]'
  '--target=[install GRUB for specified target platform]:target platform:_grub-install_targets'
  '--uefi-secure-boot[install an image usable with UEFI Secure Boot]'

  '*:install device:_files -g "*(-%b)"'
)

_arguments -s -S $arguments
