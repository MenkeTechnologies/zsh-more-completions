#compdef wlanhcx2essid
# Documentation: https://man.archlinux.org/search?q=wlanhcx2essid
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-i[input hccapx file]'
  '-s[input second hccapx file]'
  '-o[output hccapx file (merged by essid)]'
  '-I[show info about hccapx file]'
  '*:filename:_files'
)

_arguments -s -S $arguments
