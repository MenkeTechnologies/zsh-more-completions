#compdef d2j-smali

local -a arguments

arguments=(
  {-a,--api-level}'[\[not impl\] The numeric api-level of the file to generate]'
  '(- * :)'{-h,--help}'[print this help message]'
  {-o,--output}'[the name of the dex file that will be written]:file:_files'
  {-v,--version}'[prints the version then exits]'
  {-x,--allow-odex-instructions}'[\[not impl\] allow odex instructions to be compiled]'
  '*:filename:_files'
)

_arguments -s -S $arguments
