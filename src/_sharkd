#compdef sharkd
# Documentation: https://man.archlinux.org/search?q=sharkd
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-a,--api}'[listen on this socket]'
  {-h,--help}'[show this help information]'
  {-v,--version}'[show version information]'
  '-C[profile>, --config-profile <config profile>]'
  '*:filename:_files'
)

_arguments -s -S $arguments
