#compdef mifare-desfire-read-ndef
# Documentation: https://man.archlinux.org/search?q=mifare-desfire-read-ndef
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-y[do not ask for confirmation]'
  '-o[extract NDEF message if available in FILE]'
  '-k[provide another NDEF Tag Application key than the default one]'
  '*:filename:_files'
)

_arguments -s -S $arguments
