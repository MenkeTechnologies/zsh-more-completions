#compdef atk6-implementation6
# Documentation: https://man.archlinux.org/search?q=atk6-implementation6
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-s[6 use the specified source IPv6 address]'
  '-p[do not perform an alive check at the beginning and end]'
  '*:filename:_files'
)

_arguments -s -S $arguments
