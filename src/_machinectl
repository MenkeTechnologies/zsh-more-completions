#compdef machinectl

# zsh completions for 'machinectl'

_machinectl_commands() {
  local -a machine_cmds image_cmds
  machine_cmds=(
    'list:list running virtual machines and containers'
    'status:show runtime status of machines'
    'show:show properties of machines'
    'start:start a container as a system service'
    'login:open an interactive terminal login session in a container'
    'shell:open an interactive shell session in a container'
    'enable:enable container to start at boot'
    'disable:disable container from starting at boot'
    'poweroff:power off containers'
    'reboot:reboot containers'
    'terminate:immediately terminate machines'
    'kill:send signal to processes in a machine'
    'bind:mount a file or directory from the host into a container'
    'copy-to:copy files from the host into a container'
    'copy-from:copy files from a container to the host'
  )
  image_cmds=(
    'list-images:show list of locally installed container and VM images'
    'image-status:show terse status of images'
    'show-image:show properties of images'
    'edit:edit machine settings file'
    'cat:display machine settings file'
    'clone:clone a container or VM image'
    'rename:rename a container or VM image'
    'read-only:mark or unmark an image as read-only'
    'remove:remove container or VM images'
    'set-limit:set maximum disk size for images'
    'clean:remove hidden VM or container images'
  )
  _describe -t machine-commands 'machine command' machine_cmds
  _describe -t image-commands 'image command' image_cmds
}

_machinectl() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -s \
    '(- *)'{-h,--help}'[show help message and exit]' \
    '(- *)--version[show package version]' \
    '--no-pager[do not pipe output into a pager]' \
    '--no-legend[do not show the headers and footers]' \
    '--no-ask-password[do not query the user for authentication]' \
    {-H+,--host=}'[execute the operation on a remote host]:user@host:_hosts' \
    {-M+,--machine=}'[execute operation on a local container]:machine name' \
    '*'{-p+,--property=}'[show only properties by this name]:property name' \
    '--value[show only property values without names]' \
    '-P+[shorthand for --value --property=]:property name' \
    {-a,--all}'[show all properties, including empty or hidden ones]' \
    {-l,--full}'[do not ellipsize output]' \
    '--kill-whom=[whom to send signal to]:whom:(leader supervisor all)' \
    {-s+,--signal=}'[which signal to send]:signal:_signals' \
    '--uid=[user ID for shell command]:user:_users' \
    '*'{-E+,--setenv=}'[set environment variable for shell]:NAME=VALUE' \
    '--mkdir[create destination directory before bind mount]' \
    '--read-only[create read-only bind mount or image]' \
    {-n+,--lines=}'[number of journal lines to show]:number of lines' \
    {-o+,--output=}'[change journal output mode]:output mode:(short short-precise short-iso short-iso-precise short-full short-monotonic short-unix verbose export json json-pretty json-sse json-seq cat with-unit)' \
    '--runner=[select runner for starting machines]:runner:(nspawn vmspawn)' \
    '-V[shorthand for --runner=vmspawn]' \
    '--now[start/poweroff container when enabling/disabling]' \
    '--force[replace target file when copying]' \
    '--max-addresses=[limit number of IP addresses shown]:number' \
    {-q,--quiet}'[suppress extra informational output]' \
    '--json=[format output as JSON]:mode:(short pretty off)' \
    '-j[JSON output (pretty on tty, short otherwise)]' \
    '(-): :_machinectl_commands' \
    '(-)*:: :->args'

  case $state in
    args)
      case ${line[1]} in
        list|list-images|clean)
          ;;
        status|show|start|enable|disable|poweroff|reboot|terminate|kill|login)
          _arguments '*:machine name'
          ;;
        shell)
          _arguments \
            ':name[@user]:' \
            '::command path:_command_names -e' \
            '*::arguments'
          ;;
        bind)
          _arguments \
            ':machine name' \
            ':host path:_files' \
            '::container path:_files'
          ;;
        copy-to)
          _arguments \
            ':machine name' \
            ':host path:_files' \
            '::container path'
          ;;
        copy-from)
          _arguments \
            ':machine name' \
            ':container path' \
            '::host path:_files'
          ;;
        image-status|show-image|remove)
          _arguments '*:image name'
          ;;
        edit|cat)
          _arguments '*:machine name or settings file:_files'
          ;;
        clone)
          _arguments \
            ':source image name' \
            ':destination image name'
          ;;
        rename)
          _arguments \
            ':old image name' \
            ':new image name'
          ;;
        read-only)
          _arguments \
            ':image name' \
            '::read-only:(yes no)'
          ;;
        set-limit)
          _arguments \
            '::image name' \
            ':size in bytes'
          ;;
      esac
      ;;
  esac
}

_machinectl "$@"
