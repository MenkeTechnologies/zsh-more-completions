#compdef pg_conftool
# Documentation: https://man.archlinux.org/search?q=pg_conftool
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-b,--boolean}'[format output as boolean]'
  {-s,--short}'[print only value]'
  {-v,--verbose}'[verbose output]'
  '--help[this help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
