#compdef oldfind

local -a arguments

arguments=(
  '-depth[process directory contents before the directory itself]'
  '--help[display help]'
  '-maxdepth[descend at most N levels]:levels:'
  '-mindepth[do not apply tests at levels less than N]:levels:'
  '-mount[do not descend into other filesystems]'
  '-noleaf[do not optimize by assuming directories contain 2 fewer subdirectories]'
  '--version[display version]'
  '-xautofs[do not descend into autofs filesystems]'
  '-xdev[do not descend into other filesystems]'
  '-name[match file name pattern]:pattern:'
  '-iname[match file name pattern case-insensitively]:pattern:'
  '-type[match file type]:type:(b c d f l p s)'
  '-size[match file size]:size:'
  '-mtime[match modification time]:days:'
  '-ctime[match change time]:days:'
  '-mmin[match modification time in minutes]:minutes:'
  '-newer[match files newer than given file]:file:_files'
  '-user[match file owner]:user:_users'
  '-group[match file group]:group:'
  '-perm[match file permissions]:mode:'
  '-empty[match empty files and directories]'
  '-exec[execute command]:command:'
  '-execdir[execute command in file directory]:command:'
  '-print[print file name]'
  '-print0[print file name with null terminator]'
  '-ls[list current file in ls -dils format]'
  '-prune[do not descend into directory]'
  '-quit[exit immediately]'
  '-delete[delete files]'
  '-readable[match readable files]'
  '-writable[match writable files]'
  '-executable[match executable files]'
  '*:filename:_files'
)

_arguments -s -S $arguments
