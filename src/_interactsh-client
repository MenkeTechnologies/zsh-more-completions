#compdef interactsh-client

# Zsh completion for interactsh-client - open-source solution for out-of-band data extraction

_arguments -s -S \
  '(-s --server)'{-s,--server}'[interactsh server(s) to use]:server:' \
  '(-t --token)'{-t,--token}'[token to authenticate with the server]:token:' \
  '(-n --number)'{-n,--number}'[number of interactsh payload to generate]:N:' \
  '(-p --poll-interval)'{-p,--poll-interval}'[poll interval in seconds]:seconds:' \
  '(-v --verbose)'{-v,--verbose}'[show verbose interaction]' \
  '(-o --output)'{-o,--output}'[store interaction data to file]:file:_files' \
  '--json[store interaction data as JSON to file]' \
  '--env-payload[enable environment payload variables]' \
  '(-nc --no-color)'{-nc,--no-color}'[disable color in cli output]' \
  '--dns-only[display only DNS interaction in CLI output]' \
  '--http-only[display only HTTP interaction in CLI output]' \
  '--smtp-only[display only SMTP interaction in CLI output]' \
  '-payload-store-file[payload store file path]:file:_files' \
  '-payload-store-strategy[payload store strategy]:strategy:(default random)' \
  '-keepalive-interval[keep-alive interval in seconds]:seconds:' \
  '--disable-httpserver[disable HTTP server]' \
  '--disale-dnserver[disable DNS server]' \
  '--disable-smtpserver[disable SMTP server]' \
  '--correlate-id[correlate interaction for specific id]:id:' \
  '-skip-waf-check[skip WAF detection check]' \
  '--skip-waf-check[skip WAF detection check]' \
  '(-version --version)--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]'
