#compdef activate-global-python-argcomplete3
# Documentation: https://man.archlinux.org/search?q=activate-global-python-argcomplete3
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  '--dest[specify the bash completion modules directory to]'
  '--user[install into user directory (~/.bash_completion.d/)]'
  '--no-defaults[when no matches are generated, do not fallback to]'
  '--complete-arguments'
  '*:filename:_files'
)

_arguments -s -S $arguments
