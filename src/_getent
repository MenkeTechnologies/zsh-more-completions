#compdef getent
# Documentation: https://man.archlinux.org/search?q=getent
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    {-i,--no-idn}'[disable IDN encoding]'
    {-s,--service}'[Service configuration to be used]'
    '--usage[Give a short usage message]'
    {-V,--version}'[Print program version]'
    '*:filename:_files'
)

_arguments -s -S $arguments
