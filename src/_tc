#compdef tc

local -a arguments

arguments=(
  '-o[output traffic control objects]'
  '-j[output in JSON format]'
  '-p[output in pretty format]'
  '-c[use color output]'
  '-b[batch mode, read commands from file]:filename:_files'
  '-n[use network namespace]:name:'
  '-nm[resolve names]'
  '-nam[resolve names]'
  '-cf[specify configuration file]:path:_files'
  '-conf[specify configuration file]:path:_files'
  '*:filename:_files'
)

_arguments -s -S $arguments
