#compdef caja-actions-config-tool
# Documentation: https://man.archlinux.org/search?q=caja-actions-config-tool
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  '--help-all[show all help options]'
  '--help-gtk[show GTK+ Options]'
  {-n,--non-unique}'[set it to run multiple instances of the program \[unique\]]'
  {-v,--version}'[output the version number, and exit gracefully \[no\]]'
  '--display[X display to use]:display:'
  '*:filename:_files'
)

_arguments -s -S $arguments
