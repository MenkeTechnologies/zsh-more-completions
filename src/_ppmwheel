#compdef ppmwheel
# Documentation: https://man.archlinux.org/search?q=ppmwheel
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '--huevalue[ This selects a hue-value color wheel.]'
    '--huesaturation[ This selects a hue-saturation color wheel.]'
    '--maxval[ This selects the maxval for the image. The default is 255.]:N'
    '*:filename:_files'
)
_arguments -s -S $arguments
