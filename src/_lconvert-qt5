#compdef lconvert-qt5

local -a arguments

arguments=(
  '(-help)-h[display this information and exit]'
  '(-h)-help[display this information and exit]'
  '-input-file[specify input file]:file:_files'
  '-output-file[specify output file]:file:_files'
  '-input-format[specify input format for subsequent infiles]:format:'
  '-output-format[specify output format]:format:'
  '-drop-tags[drop named extra tags when writing TS or XLIFF files]'
  '-drop-translations[drop existing translations and reset the status to unfinished]'
  '-source-language[specify/override the language of the source strings]:language:'
  '-target-language[specify/override the language of the translation]:language:'
  '-no-obsolete[drop obsolete messages]'
  '-no-finished[drop finished messages]'
  '-no-untranslated[drop untranslated messages]'
  '-sort-contexts[sort contexts in output TS file alphabetically]'
  '-locations[override how source code references are saved]:type:(none relative absolute)'
  '-no-ui-lines[drop line numbers from references to UI files]'
  '-verbose[be a bit more verbose]'
  '*:filename:_files'
)

_arguments -s -S $arguments
