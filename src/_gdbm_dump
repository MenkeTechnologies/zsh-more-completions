#compdef gdbm_dump
# Documentation: https://man.archlinux.org/search?q=gdbm_dump
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-H,--format}'[0|1]'
  {-V,--version}'[print program version]'
  '(- * :)'{-h,--help}'[give this help list]'
  '--usage[give a short usage message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
