#compdef mate-session-inhibit
# Documentation: https://man.archlinux.org/search?q=mate-session-inhibit
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help]'
  '--version[show program version]'
  '--app-id[the application id to use]'
  '--reason[the reason for inhibiting (optional)]'
  '--inhibit[things to inhibit, colon-separated list]'
  '*:filename:_files'
)

_arguments -s -S $arguments
