#compdef devpod

# Zsh completion for DevPod (dev environments)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:build a workspace'
  'completion:generate shell completions'
  'context:manage contexts'
  'delete:delete a workspace'
  'ide:manage IDEs'
  'list:list workspaces'
  'logs:show workspace logs'
  'machine:manage machines'
  'provider:manage providers'
  'pro:manage DevPod Pro'
  'ssh:SSH into a workspace'
  'status:show workspace status'
  'stop:stop a workspace'
  'up:start a workspace'
  'version:print CLI version'
)

_arguments -s -S \
  '--context[DevPod context]:context:' \
  '--debug[enable debug logging]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'devpod command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (up)
        _arguments \
          '--id[workspace ID]:id:' \
          '--ide[IDE to use]:ide:(vscode openvscode fleet jupyternotebook cursor)' \
          '--provider[provider to use]:provider:' \
          '--devcontainer-path[path to devcontainer.json]:file:_files' \
          '--dotfiles[dotfiles repository URL]:url:' \
          '--git-branch[git branch]:branch:' \
          '--open-ide[open IDE after creation]' \
          '--recreate[recreate the workspace]' \
          '1:workspace source:' && ret=0
        ;;
      (ssh)
        _arguments \
          '--command[command to execute]:command:' \
          '--agent-forwarding[enable SSH agent forwarding]' \
          '--gpg-agent-forwarding[enable GPG agent forwarding]' \
          '--stdio[use stdin/stdout]' \
          '--user[SSH user]:user:' \
          '1:workspace:' && ret=0
        ;;
      (delete)
        _arguments \
          '--force[force deletion]' \
          '--grace-period[grace period]:duration:' \
          '1:workspace:' && ret=0
        ;;
      (stop)
        _arguments '1:workspace:' && ret=0
        ;;
      (status)
        _arguments \
          '--output[output format]:format:(json plain)' \
          '1:workspace:' && ret=0
        ;;
      (provider)
        local -a prov_cmds=('add:add a provider' 'delete:delete a provider' 'list:list providers' 'update:update a provider' 'use:set default provider')
        _arguments '1:provider command:((${(j: :)${prov_cmds// /\\:}}))' '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
