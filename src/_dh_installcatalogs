#compdef dh_installcatalogs
# Documentation: https://man.archlinux.org/search?q=dh_installcatalogs
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '-n[scripts and the triggers file by dh_installdeb; see dh_installdeb(1) for an e]'
    '--no-scripts'
    '*:filename:_files'
)
_arguments -s -S $arguments
