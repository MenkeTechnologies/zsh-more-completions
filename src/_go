#compdef go

# Zsh completion for Go toolchain
# Updated with all commands and flags for Go 1.22+

_go_packages() {
  local -a packages
  packages=(${(f)"$(go list ./... 2>/dev/null)"})
  if [[ ${#packages} -eq 0 ]]; then
    _files -g '*.go'
  else
    _describe 'packages' packages
  fi
}

# Shared build flags used by build, clean, get, install, list, run, and test
_go_build_flags=(
  '-C[change to dir before running the command]:dir:_directories'
  '-a[force rebuilding of packages that are already up-to-date]'
  '-n[print the commands but do not run them]'
  '-p[the number of programs to run in parallel]:parallelism:'
  '-race[enable data race detection]'
  '-msan[enable interoperation with memory sanitizer]'
  '-asan[enable interoperation with address sanitizer]'
  '-cover[enable code coverage instrumentation]'
  '-covermode[set the mode for coverage analysis]:mode:(set count atomic)'
  '-coverpkg[apply coverage analysis to matching packages]:patterns:'
  '-v[print the names of packages as they are compiled]'
  '-work[print the name of the temporary work directory]'
  '-x[print the commands as they are executed]'
  '-asmflags[arguments to pass on each go tool asm invocation]:flags:'
  '-buildmode[set build mode]:mode:(default c-archive c-shared archive exe pie plugin shared)'
  '-buildvcs[stamp binaries with version control information]:mode:(true false auto)'
  '-compiler[name of compiler to use]:compiler:(gc gccgo)'
  '-gccgoflags[arguments to pass on each gccgo compiler/linker invocation]:flags:'
  '-gcflags[arguments to pass on each go tool compile invocation]:flags:'
  '-installsuffix[suffix for package installation directory]:suffix:'
  '-json[emit build output in JSON format]'
  '-ldflags[arguments to pass on each go tool link invocation]:flags:'
  '-linkshared[build code that will be linked against shared libraries]'
  '-mod[module download mode to use]:mode:(readonly vendor mod)'
  '-modcacherw[leave newly-created directories in the module cache read-write]'
  '-modfile[read and write an alternate go.mod file]:file:_files -g "*.mod"'
  '-overlay[read a JSON config file that provides an overlay for build operations]:file:_files'
  '-pgo[specify the file path of a profile for profile-guided optimization]:file:_files'
  '-pkgdir[install and load all packages from dir]:dir:_directories'
  '-tags[comma-separated list of additional build tags]:tags:'
  '-trimpath[remove all file system paths from the resulting executable]'
  '-toolexec[a program to use to invoke toolchain programs]:cmd:'
)

_go_test_only_flags=(
  '-bench[run only those benchmarks matching a regular expression]:regexp:'
  '-benchmem[print memory allocation statistics for benchmarks]'
  '-benchtime[run enough iterations of each benchmark to take t]:duration:'
  '-blockprofile[write a goroutine blocking profile to the specified file]:file:_files'
  '-blockprofilerate[control the detail provided in goroutine blocking profiles]:rate:'
  '-count[run each test, benchmark, and fuzz seed n times]:n:'
  '-coverprofile[write a coverage profile to the file]:file:_files'
  '-cpuprofile[write a CPU profile to the specified file]:file:_files'
  '-failfast[do not start new tests after the first test failure]'
  '-fullpath[show full file names in the error messages]'
  '-fuzz[run the fuzz test matching the regular expression]:regexp:'
  '-fuzzminimizetime[run fuzz minimization for at most t]:duration:'
  '-fuzztime[run enough iterations of the fuzz target to take t]:duration:'
  '-list[list tests, benchmarks, fuzz tests, or examples matching the regular expression]:regexp:'
  '-memprofile[write an allocation profile to file]:file:_files'
  '-memprofilerate[enable more precise memory allocation profiles]:rate:'
  '-mutexprofile[write a mutex contention profile to the specified file]:file:_files'
  '-mutexprofilefraction[sample 1 in n stack traces of goroutines holding a mutex]:n:'
  '-outputdir[place output files from profiling in the specified directory]:dir:_directories'
  '-parallel[allow parallel execution of test functions that call t.Parallel]:n:'
  '-run[run only those tests, examples, and fuzz tests matching the regular expression]:regexp:'
  '-short[tell long-running tests to shorten their run time]'
  '-shuffle[randomize the execution order of tests and benchmarks]:mode:(off on)'
  '-skip[run only those tests, examples, fuzz tests, and benchmarks not matching the regular expression]:regexp:'
  '-timeout[if a test binary runs longer than duration t the test is killed]:duration:'
  '-trace[write an execution trace to the specified file]:file:_files'
  '-vet[configure the invocation of go vet during go test]:flags:'
)

_go_mod_commands() {
  local -a cmds
  cmds=(
    'download:download modules to local cache'
    'edit:edit go.mod from tools or scripts'
    'graph:print module requirement graph'
    'init:initialize new module in current directory'
    'tidy:add missing and remove unused modules'
    'vendor:make vendored copy of dependencies'
    'verify:verify dependencies have expected content'
    'why:explain why packages or modules are needed'
  )
  _describe 'mod command' cmds
}

_go_work_commands() {
  local -a cmds
  cmds=(
    'edit:edit go.work from tools or scripts'
    'init:initialize workspace file'
    'sync:sync workspace build list to modules'
    'use:add modules to workspace file'
    'vendor:make vendored copy of dependencies'
  )
  _describe 'work command' cmds
}

_go_tool_commands() {
  local -a cmds
  if cmds=(${(f)"$(go tool -n 2>/dev/null)"}); then
    local -a described
    described=()
    local tool
    for tool in $cmds; do
      described+=("$tool:go tool $tool")
    done
    _describe 'tool' described
  else
    cmds=(
      'asm:assembler'
      'cgo:cgo tool'
      'compile:compiler'
      'cover:coverage tool'
      'fix:fix tool'
      'link:linker'
      'preprofile:preprofile tool'
      'vet:vet tool'
    )
    _describe 'tool' cmds
  fi
}

_go_env_vars() {
  local -a vars
  vars=(
    'GOARCH:target architecture'
    'GOBIN:directory for installed binaries'
    'GOCACHE:directory for build cache'
    'GOENV:location of the go environment config file'
    'GOFLAGS:default go command line flags'
    'GOMODCACHE:module cache directory'
    'GONOPROXY:module prefixes that should not use proxy'
    'GONOSUMDB:module prefixes that should not use sumdb'
    'GOOS:target operating system'
    'GOPATH:path for resolving import statements'
    'GOPRIVATE:module prefixes that are private'
    'GOPROXY:URL of Go module proxy'
    'GOROOT:root of the Go tree'
    'GOSUMDB:name of checksum database'
    'GOTMPDIR:directory for temporary files'
    'GOTOOLCHAIN:go toolchain to use'
    'GOWORK:go.work file to use'
    'GOEXPERIMENT:comma-separated list of toolchain experiments'
    'GOFLAGS:a space-separated list of -flag=value settings'
    'GOINSECURE:module prefixes that may always be fetched insecurely'
    'GO111MODULE:controls module mode'
    'GODEBUG:comma-separated list of key=value debug settings'
    'GONOSUMCHECK:module prefixes not to validate with checksum database'
    'GOVCS:version control systems to use with go get'
    'CGO_ENABLED:whether cgo is enabled'
    'CGO_CFLAGS:flags for the C compiler'
    'CGO_CPPFLAGS:flags for the C preprocessor'
    'CGO_CXXFLAGS:flags for the C++ compiler'
    'CGO_FFLAGS:flags for the Fortran compiler'
    'CGO_LDFLAGS:flags for the linker'
    'CC:the C compiler to use'
    'CXX:the C++ compiler to use'
    'AR:the archive tool to use'
    'PKG_CONFIG:path to pkg-config tool'
  )
  _describe 'env variable' vars
}

_go() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '1:command:->command' \
    '*::arg:->args' && return 0

  case $state in
    command)
      local -a commands
      commands=(
        'bug:start a bug report'
        'build:compile packages and dependencies'
        'clean:remove object files and cached files'
        'doc:show documentation for package or symbol'
        'env:print Go environment information'
        'fix:apply fixes suggested by static checkers'
        'fmt:gofmt (reformat) package sources'
        'generate:generate Go files by processing source'
        'get:add dependencies to current module and install them'
        'help:get help on a topic'
        'install:compile and install packages and dependencies'
        'list:list packages or modules'
        'mod:module maintenance'
        'work:workspace maintenance'
        'run:compile and run Go program'
        'telemetry:manage telemetry data and settings'
        'test:test packages'
        'tool:run specified go tool'
        'vet:report likely mistakes in packages'
        'version:print Go version'
      )
      _describe 'go command' commands
      ;;

    args)
      case $line[1] in
        build)
          _arguments -s \
            '-o[set output file or directory]:output:_files' \
            $_go_build_flags \
            '*:packages:_go_packages'
          ;;

        run)
          _arguments -s \
            '-exec[invoke the binary using xprog]:xprog:' \
            $_go_build_flags \
            '*:go files or packages:_files -g "*.go"'
          ;;

        test)
          _arguments -s \
            '-o[compile the test binary to the named file]:file:_files' \
            '-c[compile the test binary but do not run it]' \
            '-exec[run the test binary using xprog]:xprog:' \
            $_go_build_flags \
            $_go_test_only_flags \
            '*:packages:_go_packages'
          ;;

        get)
          _arguments -s \
            '-t[also download packages required to build tests]' \
            '-u[use the network to update packages and their dependencies]' \
            '-d[only download, do not install]' \
            '-tool[add a matching tool line to go.mod]' \
            '-x[print commands as they are executed]' \
            '-insecure[permit fetching from insecure origins]' \
            $_go_build_flags \
            '*:packages:'
          ;;

        install)
          _arguments -s \
            $_go_build_flags \
            '*:packages:_go_packages'
          ;;

        mod)
          _arguments -C \
            '1:mod command:_go_mod_commands' \
            '*::mod arg:->mod_args' && return 0

          case $line[1] in
            download)
              _arguments -s \
                '-json[print a sequence of JSON objects to stdout]' \
                '-x[print the commands download executes]' \
                '*:modules:'
              ;;
            edit)
              _arguments -s \
                '-fmt[reformat the go.mod file without making other changes]' \
                '-module[change the module'\''s path]:module path:' \
                '-go[set the expected Go language version]:version:' \
                '-toolchain[set the Go toolchain to use]:toolchain:' \
                '-require[add a requirement]:module@version:' \
                '-droprequire[drop a requirement]:module:' \
                '-exclude[add an exclusion]:module@version:' \
                '-dropexclude[drop an exclusion]:module@version:' \
                '-retract[add a retraction]:version:' \
                '-dropretract[drop a retraction]:version:' \
                '-replace[add a replacement]:old@v=new@v:' \
                '-dropreplace[drop a replacement]:old@v:' \
                '-godebug[add a godebug setting]:key=value:' \
                '-dropgodebug[drop a godebug setting]:key:' \
                '-tool[add a tool directive]:package:' \
                '-droptool[drop a tool directive]:package:' \
                '-print[print the final go.mod in its text format]' \
                '-json[print the final go.mod in JSON format]'
              ;;
            tidy)
              _arguments -s \
                '-v[print information about removed modules]' \
                '-e[attempt to proceed despite errors]' \
                '-go[update the go directive in go.mod to the given version]:version:' \
                '-compat[preserve additional checksums needed for the given version]:version:' \
                '-diff[do not modify go.mod or go.sum but instead print the diffs]'
              ;;
            vendor)
              _arguments -s \
                '-v[print the names of vendored modules and packages]' \
                '-e[attempt to proceed despite errors]' \
                '-o[create the vendor directory at the given path]:path:_directories'
              ;;
            init)
              _arguments '1:module path:'
              ;;
            graph)
              _arguments -s \
                '-go[report the module graph as loaded by the given Go version]:version:'
              ;;
            verify)
              ;;
            why)
              _arguments -s \
                '-m[treat arguments as a list of modules]' \
                '-vendor[exclude tests of dependencies]' \
                '*:packages:'
              ;;
          esac
          ;;

        work)
          _arguments -C \
            '1:work command:_go_work_commands' \
            '*::work arg:->work_args' && return 0

          case $line[1] in
            edit)
              _arguments -s \
                '-fmt[reformat the go.work file]' \
                '-go[set the go directive]:version:' \
                '-toolchain[set the toolchain directive]:toolchain:' \
                '-use[add a use directive]:dir:_directories' \
                '-dropuse[drop a use directive]:dir:_directories' \
                '-replace[add a replacement]:old@v=new@v:' \
                '-dropreplace[drop a replacement]:old@v:' \
                '-godebug[add a godebug setting]:key=value:' \
                '-dropgodebug[drop a godebug setting]:key:' \
                '-print[print the final go.work in text format]' \
                '-json[print the final go.work in JSON format]'
              ;;
            init)
              _arguments '*:module directories:_directories'
              ;;
            sync)
              ;;
            use)
              _arguments \
                '-r[recursively search for Go modules in the argument directories]' \
                '*:module directories:_directories'
              ;;
            vendor)
              _arguments -s \
                '-v[print the names of vendored modules and packages]' \
                '-e[attempt to proceed despite errors]' \
                '-o[create the vendor directory at the given path]:path:_directories'
              ;;
          esac
          ;;

        env)
          _arguments -s \
            '-json[print the environment in JSON format]' \
            '-changed[print only settings whose effective value differs from default]' \
            '-w[write env vars to the go env config file]:name=value:' \
            '-u[unset env vars from the go env config file]:name:' \
            '*:variable:_go_env_vars'
          ;;

        vet)
          _arguments -s \
            '-C[change to dir before running the command]:dir:_directories' \
            '-n[print commands that would be executed]' \
            '-x[print commands as they are executed]' \
            '-v[verbose output]' \
            '-vettool[alternative vet tool]:tool:_files' \
            '-json[emit vet output in JSON]' \
            '-tags[comma-separated list of build tags]:tags:' \
            '*:packages:_go_packages'
          ;;

        fmt)
          _arguments -s \
            '-n[print commands that would be executed]' \
            '-x[print commands as they are executed]' \
            '-mod[set module download mode]:mode:(readonly vendor mod)' \
            '*:packages:_go_packages'
          ;;

        clean)
          _arguments -s \
            '-cache[remove the entire go build cache]' \
            '-testcache[expire all test results in the go build cache]' \
            '-modcache[remove the entire module download cache]' \
            '-fuzzcache[remove files stored in the Go build cache only for fuzz testing]' \
            '-i[remove the corresponding installed archive or binary]' \
            '-r[apply recursively to all the dependencies]' \
            '-n[print the remove commands it would execute]' \
            '-x[print remove commands as it executes them]' \
            '*:packages:_go_packages'
          ;;

        doc)
          _arguments -s \
            '-all[show all the documentation for the package]' \
            '-cmd[treat a command as a regular package]' \
            '-short[one-line representation for each symbol]' \
            '-src[show the full source code for the symbol]' \
            '-u[show documentation for unexported as well as exported symbols]' \
            '-C[change to dir before running the command]:dir:_directories' \
            '*:packages:_go_packages'
          ;;

        fix)
          _arguments -s \
            '-diff[print the patch as a unified diff instead of applying]' \
            '-fixtool[use an alternative analysis tool]:prog:_files' \
            '-C[change to dir before running the command]:dir:_directories' \
            '-n[print commands that would be executed]' \
            '-x[print commands as they are executed]' \
            '-v[verbose output]' \
            '-tags[comma-separated list of build tags]:tags:' \
            '*:packages:_go_packages'
          ;;

        generate)
          _arguments -s \
            '-run[specify a regular expression to select generate directives]:regexp:' \
            '-skip[specify a regular expression to suppress generate directives]:regexp:' \
            '-n[print commands that would be executed]' \
            '-v[print the names of packages and files as they are processed]' \
            '-x[print commands as they are executed]' \
            '*:packages:_go_packages'
          ;;

        list)
          _arguments -s \
            '-f[specify an alternate format for the list]:format:' \
            '-json[print package data in JSON format]' \
            '-m[list modules instead of packages]' \
            '-u[add information about available upgrades]' \
            '-versions[list all known versions of modules]' \
            '-retracted[report retracted versions of modules]' \
            '-reuse[reuse module download information from file]:file:_files' \
            '-e[change the handling of erroneous packages]' \
            '-compiled[set CompiledGoFiles to the Go files presented to the compiler]' \
            '-deps[iterate over dependencies of the named packages]' \
            '-export[set the Export field to file containing export data]' \
            '-find[identify the named packages but not resolve their dependencies]' \
            '-test[report test binaries and packages]' \
            $_go_build_flags \
            '*:packages:_go_packages'
          ;;

        tool)
          _arguments -C \
            '-n[print the command that would be executed but do not execute it]' \
            '-modfile[use an alternate go.mod file]:file:_files -g "*.mod"' \
            '-C[change to dir before running the command]:dir:_directories' \
            '-overlay[read a JSON config file for build overlay]:file:_files' \
            '-modcacherw[leave newly-created directories in the module cache read-write]' \
            '1:tool:_go_tool_commands' \
            '*:args:'
          ;;

        version)
          _arguments -s \
            '-m[print each executable'\''s module version information]' \
            '-v[report unrecognized files]' \
            '*:files:_files'
          ;;

        telemetry)
          _arguments '1:mode:(off local on)'
          ;;

        help)
          local -a topics
          topics=(
            'bug' 'build' 'clean' 'doc' 'env' 'fix' 'fmt' 'generate'
            'get' 'install' 'list' 'mod' 'work' 'run' 'telemetry'
            'test' 'tool' 'vet' 'version'
            'buildconstraint' 'buildjson' 'buildmode' 'c' 'cache'
            'environment' 'filetype' 'goauth' 'go.mod' 'gopath'
            'goproxy' 'importpath' 'modules' 'module-auth' 'packages'
            'private' 'testflag' 'testfunc' 'vcs'
          )
          _describe 'help topic' topics
          ;;

        bug)
          ;;

        *)
          _default
          ;;
      esac
      ;;
  esac
}

_go "$@"
