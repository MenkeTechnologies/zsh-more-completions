#compdef kafka-console-producer

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--topic[Topic to produce to]:topic:'
    '--broker-list[DEPRECATED - Use --bootstrap-server]:host\:port:'
    '--sync[Send messages synchronously]'
    '--compression-codec[Compression codec]:codec:(none gzip snappy lz4 zstd)'
    '--batch-size[Number of messages to send in a single batch]:size:'
    '--message-send-max-retries[Max retries for failed send]:retries:'
    '--retry-backoff-ms[Retry backoff in ms]:ms:'
    '--timeout[Message send timeout in ms]:ms:'
    '--max-block-ms[Max time to block waiting for metadata]:ms:'
    '--max-memory-bytes[Max memory for buffering]:bytes:'
    '--max-partition-memory-bytes[Max memory per partition for buffering]:bytes:'
    '--metadata-expiry-ms[Metadata max age in ms]:ms:'
    '--producer-property[User-defined properties as key=value pairs]:property:'
    '--producer.config[Producer config properties file]:file:_files'
    '--property[Properties for the message reader]:property:'
    '--reader-config[Reader config properties file]:file:_files'
    '--line-reader[Line reader class]:class:'
    '--request-required-acks[Required acks]:acks:(0 1 -1 all)'
    '--request-timeout-ms[Ack timeout of the producer]:ms:'
)

_arguments -s -S $arguments
