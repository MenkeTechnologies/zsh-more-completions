#compdef keytool

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  '-certreq:generate a certificate request'
  '-changealias:change an entry alias'
  '-delete:delete an entry'
  '-exportcert:export certificate'
  '-genkeypair:generate a key pair'
  '-genseckey:generate a secret key'
  '-gencert:generate certificate from a certificate request'
  '-importcert:import a certificate or certificate chain'
  '-importkeystore:import entries from another keystore'
  '-importpass:import a password'
  '-keypasswd:change the key password of an entry'
  '-list:list entries in a keystore'
  '-printcert:print the content of a certificate'
  '-printcertreq:print the content of a certificate request'
  '-printcrl:print the content of a CRL file'
  '-storepasswd:change the store password of a keystore'
)

local -a common_args=(
  '-alias[alias name of the entry]:alias:'
  '-keyalg[key algorithm name]:algorithm:(RSA DSA EC EdDSA)'
  '-keysize[key bit size]:size:'
  '-sigalg[signature algorithm name]:algorithm:'
  '-dname[distinguished name]:dname:'
  '-keypass[key password]:password:'
  '-validity[validity number of days]:days:'
  '-storetype[keystore type]:type:(JKS JCEKS PKCS12 PKCS11 DKS)'
  '-keystore[keystore name]:keystore file:_files'
  '-storepass[keystore password]:password:'
  '-providername[provider name]:provider:'
  '-addprovider[add security provider by name]:provider:'
  '-providerclass[add security provider by fully qualified class name]:class:'
  '-providerpath[provider classpath]:path:_files -/'
  '-v[verbose output]'
  '-protected[password through protected mechanism]'
  '*-J+[pass option directly to the Java runtime]:JVM option:'
)

_arguments -s -S \
  '1:subcommand:->subcommand' \
  '*::: :->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (-genkeypair)
        _arguments -s -S \
          $common_args \
          '-groupname[group name]:group name:' \
          '*-ext[X.509 extension]:extension:' && ret=0
        ;;
      (-list)
        _arguments -s -S \
          $common_args \
          '-rfc[output in RFC style]' && ret=0
        ;;
      (-importcert)
        _arguments -s -S \
          $common_args \
          '-trustcacerts[trust certificates from cacerts]' \
          '-noprompt[do not prompt]' \
          '-file[input file name]:file:_files' && ret=0
        ;;
      (-exportcert)
        _arguments -s -S \
          $common_args \
          '-rfc[output in RFC style]' \
          '-file[output file name]:file:_files' && ret=0
        ;;
      (-importkeystore)
        _arguments -s -S \
          $common_args \
          '-srckeystore[source keystore name]:keystore file:_files' \
          '-destkeystore[destination keystore name]:keystore file:_files' \
          '-srcstoretype[source keystore type]:type:(JKS JCEKS PKCS12 PKCS11 DKS)' \
          '-deststoretype[destination keystore type]:type:(JKS JCEKS PKCS12 PKCS11 DKS)' \
          '-srcstorepass[source keystore password]:password:' \
          '-deststorepass[destination keystore password]:password:' \
          '-srcalias[source alias]:alias:' \
          '-destalias[destination alias]:alias:' \
          '-srckeypass[source key password]:password:' \
          '-destkeypass[destination key password]:password:' \
          '-srcprovidername[source provider name]:provider:' \
          '-destprovidername[destination provider name]:provider:' && ret=0
        ;;
      (-certreq|-changealias|-delete|-genseckey|-gencert|-importpass|-keypasswd|-storepasswd)
        _arguments -s -S \
          $common_args && ret=0
        ;;
      (-printcert|-printcertreq|-printcrl)
        _arguments -s -S \
          '-v[verbose output]' \
          '-file[input file name]:file:_files' \
          '*-J+[pass option directly to the Java runtime]:JVM option:' && ret=0
        ;;
    esac
    ;;
esac

return ret
