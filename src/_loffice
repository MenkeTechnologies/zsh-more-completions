#compdef loffice

local -a arguments

arguments=(
  '(- * :)'{--help,-h,-\?}'[shows this help and quits]'
  '--helpwriter[opens built-in or online Help on Writer]'
  '--helpcalc[opens built-in or online Help on Calc]'
  '--helpdraw[opens built-in or online Help on Draw]'
  '--helpimpress[opens built-in or online Help on Impress]'
  '--helpbase[opens built-in or online Help on Base]'
  '--helpbasic[opens built-in or online Help on Basic scripting]'
  '--helpmath[opens built-in or online Help on Math]'
  '--version[shows the version and quits]'
  '--nstemporarydirectory[returns path of the temporary directory (MacOS X sandbox only)]'
  '--quickstart[activates the Quickstarter service]'
  '--nolockcheck[disables check for remote instances using one installation]'
  '--infilter[force an input filter type]:filter:'
  '--pidfile[store soffice.bin pid to file]:file:_files'
  '--display[sets the DISPLAY environment variable]:display:'
  '--nologo[disables the splash screen at program start]'
  '--minimized[starts minimized]'
  '--nodefault[starts without displaying anything except the splash screen]'
  '--invisible[starts in invisible mode]'
  '--headless[starts in headless mode for command line operations]'
  '--norestore[disables restart and file recovery after a system crash]'
  '--safe-mode[starts in a safe mode with a fresh user profile]'
  '--accept[specifies a UNO connect-string to create an UNO acceptor]:connect-string:'
  '--unaccept[closes an acceptor created with --accept]:connect-string:'
  '--language[uses specified language]:language:'
  '--terminate_after_init[exit after initialization]'
  '--eventtesting[exit after loading documents]'
  '--writer[creates an empty Writer document]'
  '--calc[creates an empty Calc document]'
  '--draw[creates an empty Draw document]'
  '--impress[creates an empty Impress document]'
  '--base[creates a new database]'
  '--global[creates an empty Writer master (global) document]'
  '--math[creates an empty Math document (formula)]'
  '--web[creates an empty HTML document]'
  '-n[treats following files as templates for creation of new documents]'
  '-o[opens following files for editing]'
  '--pt[prints following files to the specified printer]:printer:'
  '--print-to-file[prints following files to file]'
  '-p[prints following files to the default printer]'
  '--view[opens following files in viewer mode (read-only)]'
  '--show[opens and starts the following presentation documents]'
  '--convert-to[convert documents to specified format]:format:'
  '--outdir[specify output directory for conversion]:dir:_files -/'
  '--cat[dump text content of the following files to console]'
  '--script-cat[dump text content of any scripts embedded in the files to console]'
  '--nofirststartwizard[accepted only for backward compatibility]'
  '*:filename:_files'
)

_arguments -s -S $arguments
