#compdef csvstack

# Zsh completion for csvstack (csvkit) - stack up rows from multiple CSV files

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-d --delimiter)'{-d,--delimiter}'[delimiting character]:delimiter:' \
  '(-t --tabs)'{-t,--tabs}'[specify that input is tab-delimited]' \
  '(-q --quotechar)'{-q,--quotechar}'[character used to quote strings]:char:' \
  '(-u --quoting)'{-u,--quoting}'[quoting style]:style:(0 1 2 3)' \
  '(-b --no-doublequote)'{-b,--no-doublequote}'[no double quoting]' \
  '(-p --escapechar)'{-p,--escapechar}'[escape character]:char:' \
  '(-z --maxfieldsize)'{-z,--maxfieldsize}'[maximum field size]:size:' \
  '(-e --encoding)'{-e,--encoding}'[specify input encoding]:encoding:(utf-8 latin-1 ascii utf-16)' \
  '(-S --skipinitialspace)'{-S,--skipinitialspace}'[ignore whitespace after delimiter]' \
  '(-H --no-header-row)'{-H,--no-header-row}'[no header row in input]' \
  '(-K --no-inference)'{-K,--no-inference}'[disable type inference]' \
  '--snifflimit[limit CSV dialect sniffing]:rows:' \
  '(-n --names)'{-n,--names}'[add a column with the file name as group]' \
  '(-g --groups)'{-g,--groups}'[group names for each input file]:names:' \
  '--group-name[column name for groups]:name:' \
  '--filenames[use filenames as group names]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:CSV files:_files -g "*.csv *.tsv"' && return 0
