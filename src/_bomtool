#compdef bomtool
# Documentation: https://man.archlinux.org/search?q=bomtool
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--help[this message]'
  '--about[print bomtool version and license to stdout]'
  '--version[print bomtool version to stdout]'
  '*:filename:_files'
)

_arguments -s -S $arguments
