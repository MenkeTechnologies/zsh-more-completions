#compdef fdp

local -a arguments

arguments=(
  '-V[Print version and exit]'
  '-v[Enable verbose mode]'
  '-G[set graph attribute name=val]:name=val:'
  '-N[set node attribute name=val]:name=val:'
  '-E[set edge attribute name=val]:name=val:'
  '-T[set output format]:format:'
  '-K[set layout engine (overrides default based on command name)]:engine:'
  '-l[use external library]:library:'
  '-o[write output to file]:file:_files'
  '-O[Automatically generate an output filename based on the input filename with a .format appended. (Causes all -ofile options to be ignored.)]'
  '-P[Internally generate a graph of the current plugins.]'
  '-q[set level of message suppression (default 1)]:level:'
  '-s[scale input (default 72)]:scale:'
  '-y[Invert y coordinate in output]'
  '-n[no layout mode (default 1)]:level:'
  '-x[Reduce graph]'
  '-Lg[do not use grid]'
  '-LO[use old attractive force]'
  '-Ln[Set number of iterations to i]:i:'
  '-LU[Set unscaled factor to i]:i:'
  '-LC[Set overlap expansion factor to v]:v:'
  '-LT[set temperature factor]:value:'
  '-m[memory test]:iterations:'
  '-c[configure plugins]'
  '*:filename:_files'
)

_arguments -s -S $arguments
