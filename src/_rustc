_rustc_lints() {
  local -a lints
  lints=( ${${(f)"$(rustc -W help 2>/dev/null)"}/(#b)[[:space:]]##([a-z][-a-z0-9_]##)*/$match[1]} )
  lints=( ${(M)lints:#[a-z]*} )
  (( ${#lints} )) && _describe -t lints 'lint' lints
}

_rustc_cap_lints() {
  local -a levels=(
    'allow:Allow all lints'
    'warn:Cap at warn level'
    'deny:Cap at deny level'
    'forbid:Cap at forbid level'
  )
  _describe -t lint-levels 'lint level' levels
}

_rustc_targets() {
  local -a targets
  targets=( ${(f)"$(rustc --print target-list 2>/dev/null)"} )
  if (( ${#targets} )); then
    _describe -t targets 'target' targets
  fi
}

_rustc() {
  _arguments -s -S \
    '(- *)'{-h,--help}'[display help message]' \
    '(- *)'{-V,--version}'[print version info and exit]' \
    '*--cfg=[configure the compilation environment]:spec: ' \
    '*--check-cfg=[provide list of expected cfgs for checking]:spec: ' \
    '*-L+[add a directory to the library search path]: :_directories' \
    '*-l+[link to a native library]:library name: ' \
    '--crate-type=[comma separated list of crate types]:crate type:_rustc_crate_types' \
    '--crate-name=[specify the name of the crate being built]:name: ' \
    '--edition=[specify which edition of the compiler to use]:edition:_rustc_editions' \
    '--emit=[comma separated list of types of output to emit]:emit type:_rustc_emit_types' \
    '--print=[compiler information to print on stdout]:info:_rustc_print_types' \
    '-g[equivalent to -C debuginfo=2]' \
    '-O[equivalent to -C opt-level=3]' \
    '-o+[write output to filename]:output file:_files' \
    '--out-dir=[write output to compiler-chosen filename in dir]:output directory:_directories' \
    '--explain=[provide a detailed explanation of an error message]:error code: ' \
    '--test[build a test harness]' \
    '--target=[target tuple for which the code is compiled]:target:_rustc_targets' \
    '*'{-A,--allow}'=[set lint allowed]:lint:_rustc_lints' \
    '*'{-W,--warn}'=[set lint warnings]:lint:_rustc_lints' \
    '*--force-warn=[set lint force-warn]:lint:_rustc_lints' \
    '*'{-D,--deny}'=[set lint denied]:lint:_rustc_lints' \
    '*'{-F,--forbid}'=[set lint forbidden]:lint:_rustc_lints' \
    '--cap-lints=[set the most restrictive lint level]:level:_rustc_cap_lints' \
    '*'{-C,--codegen}'=[set a codegen option]:option:_rustc_codegen_opts' \
    '*--extern=[specify location of an external library]:name=path: ' \
    '--sysroot=[override the system root]:path:_directories' \
    '--error-format=[how errors and messages are produced]:format:_rustc_error_format' \
    '--json=[configure the JSON output of the compiler]:config:(diagnostic-short diagnostic-rendered-ansi artifacts future-incompat)' \
    '--color=[configure coloring of output]:color:_rustc_color' \
    '--diagnostic-width=[inform rustc of the output width]:width: ' \
    '*--remap-path-prefix=[remap source names in all output]:from=to: ' \
    {-v,--verbose}'[use verbose output]' \
    '*:input file:_files -g "*.rs"'
}

_rustc "$@"
