#compdef rustc

# Zsh completion for rustc - The Rust compiler

_rustc_crate_types() {
  local -a types=(
    'bin:Binary executable'
    'lib:Compiler-chosen library kind'
    'rlib:Rust library'
    'dylib:Dynamic Rust library'
    'cdylib:C-compatible dynamic library'
    'staticlib:Static library'
    'proc-macro:Procedural macro library'
  )
  _describe -t crate-types 'crate type' types
}

_rustc_editions() {
  local -a editions=(
    '2015:Rust 2015 edition (default)'
    '2018:Rust 2018 edition'
    '2021:Rust 2021 edition'
    '2024:Rust 2024 edition (latest stable)'
    'future:Future edition (unstable)'
  )
  _describe -t editions 'edition' editions
}

