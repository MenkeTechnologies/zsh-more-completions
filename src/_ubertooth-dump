#compdef ubertooth-dump

local -a arguments

arguments=(
  '-h[help]'
  '-b[dump received bitstream (GnuRadio style)]'
  '-c[constant modulation]'
  '-l[linear modulation]'
  '-U[set ubertooth device to use]:device:(0 1 2 3 4 5 6 7)'
  '-d[debug output]'
  '*:filename:_files'
)

_arguments -s -S $arguments
