#compdef raidutil

local -a arguments

arguments=(
  {--number,-n}'[specify event number]:event-number: '
  {--name,-n}'[specify name]:name: '
  {--drives,-d}'[specify list of drive bays]:drive-bays: '
  {--RAIDlevel,-r}'[specify RAID level]:raid-level: '
  {--force,-f}'[force operation]'
  {--yes,-Y}'[answer yes to prompts]'
  {--no,-N}'[answer no to prompts]'
  {--raidset,-r}'[specify RAID set name]:raid-set: '
  {--size,-s}'[specify size of the volume]:size: '
  {--unmount,-u}'[unmount before operation]'
  {--count,-c}'[specify number of lines]:count: '
  {--writeCacheBattery,-B}'[write cache battery setting]'
  {--writeCacheEnable,-E}'[enable write cache]'
  {--adopt,-s}'[adopt drives]:drives: '
  {--addglobalspare,-A}'[add global spare drives]'
  {--removeglobalspare,-X}'[remove global spare drives]'
  {--addlocalspare,-a}'[add local spare drives]'
  '--raidsets[specify RAID sets]:raid-sets: '
  {--removelocalspare,-x}'[remove local spare drives]'
  {--addcapacity,-c}'[add capacity to RAID set]'
  {--waitfortask,-W}'[wait for task to complete]'
  {--addmirror,-m}'[add mirror to RAID set]'
  {--migratetoraid5,-M}'[migrate RAID set to RAID 5]'
  {--verify,-v}'[verify RAID set or volume]'
  '--priority[specify service priority]:priority: '
  {--expand,-e}'[expand volume]'
  '--names[specify list of volumes]:volumes: '
  '--targetraidset[specify target RAID set]:raid-set: '
  {--move,-m}'[move volumes between RAID sets]'
  {--rewrite,-w}'[rewrite volume]'
  '*:filename:_files'
)

_arguments -s -S $arguments
