#compdef muesli-cli

# Zsh completion for muesli-cli (Wispr Flow CLI)

local -a commands
commands=(
  'spec:Inspect the command contract (JSON schema)'
  'info:Get system and app information'
  'meetings:Manage meeting transcripts'
  'dictations:Manage dictations'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[Print help message]' \
  '(- *)'{-V,--version}'[Show version information]' \
  '1: :_describe -t commands "command" commands' \
  '*:: :->args'

case $words[1] in
  meetings)
    local -a meeting_cmds
    meeting_cmds=(
      'list:List recent meeting transcripts'
      'get:Fetch a specific meeting record'
      'update-notes:Write updated notes back to a meeting record'
    )
    _arguments \
      '1: :_describe -t meeting_cmds "meeting command" meeting_cmds' \
      '--limit=[Limit the number of results]:limit:' \
      '--file=[Path to the notes file]:file:_files'
    ;;
  dictations)
    local -a dictation_cmds
    dictation_cmds=(
      'list:List recent dictations'
    )
    _arguments \
      '1: :_describe -t dictation_cmds "dictation command" dictation_cmds'
    ;;
esac
