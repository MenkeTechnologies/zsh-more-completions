#compdef http-server

_arguments \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-p --port)'{-p,--port}'[port to listen on]:port' \
  '-a[address to bind to]:address' \
  '-d[show directory listings]:toggle:(true false)' \
  '-i[display autoIndex]:toggle:(true false)' \
  '(-g --gzip)'{-g,--gzip}'[serve gzip compressed files]' \
  '(-b --brotli)'{-b,--brotli}'[serve brotli compressed files]' \
  '(-e --ext)'{-e,--ext}'[default file extension]:extension' \
  '(-s --silent)'{-s,--silent}'[suppress log messages]' \
  '--cors[enable CORS via Access-Control-Allow-Origin header]' \
  '-o[open browser after starting]' \
  '-c[cache time in seconds]:seconds' \
  '(-U --utc)'{-U,--utc}'[use UTC time format in log messages]' \
  '--log-ip[enable logging of client IP address]' \
  '(-P --proxy)'{-P,--proxy}'[proxy unhandled requests to URL]:url' \
  '--proxy-options[pass proxy options]' \
  '(-S --tls --ssl)'{-S,--tls,--ssl}'[enable HTTPS]' \
  '(-C --cert)'{-C,--cert}'[SSL certificate file]:file:_files' \
  '(-K --key)'{-K,--key}'[SSL key file]:file:_files' \
  '(-r --robots)'{-r,--robots}'[provide a robots.txt]' \
  '--no-dotfiles[do not show dotfiles]' \
  '--mimetypes[custom mime types file]:file:_files' \
  '--username[username for basic auth]:username' \
  '--password[password for basic auth]:password' \
  '*:directory:_directories'
