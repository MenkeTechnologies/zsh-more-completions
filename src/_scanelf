#compdef scanelf

# Completion for scanelf (pax-utils ELF scanner)

_scanelf() {
  local arguments

  arguments=(
    '(- *)'{-h,--help}'[print help and exit]'
    '(- *)'{-V,--version}'[print version and exit]'

    # Scan paths
    {-p,--path}'[scan all directories in PATH environment]'
    {-l,--ldpath}'[scan all directories in /etc/ld.so.conf]'
    '--ldcache[use alternate ld.so.cache file]:cache file:_files'
    '--use-ldpath[use ld.so.conf to show full path (use with -r/-n)]'
    '--root[set root directory for scanning]:root directory:_directories'

    # Traversal options
    {-R,--recursive}'[scan directories recursively]'
    {-m,--mount}'[do not recursively cross mount points]'
    {-y,--symlink}'[do not scan symlinks]'
    {-A,--archives}'[scan archives (.a files)]'
    {-L,--ldcache}'[use ld.so.cache to show full path (use with -r/-n)]'

    # Fix/modify options
    {-X,--fix}'[try to fix bad things (use with -r/-e)]'
    {-z,--setpax}'[set EI_PAX/PT_PAX_FLAGS to specified value]:pax flags'

    # Information display options
    {-x,--pax}'[print PaX markings]'
    {-e,--header}'[print GNU_STACK/PT_LOAD markings]'
    {-t,--textrel}'[print TEXTREL information]'
    {-r,--rpath}'[print RPATH information]'
    {-n,--needed}'[print NEEDED information]'
    {-i,--interp}'[print INTERP information]'
    {-b,--bind}'[print BIND information]'
    {-S,--soname}'[print SONAME information]'
    {-T,--textrels}'[locate cause of TEXTREL]'
    {-D,--endian}'[print endianness]'
    {-I,--osabi}'[print OSABI]'
    {-Y,--eabi}'[print EABI (EM_ARM only)]'
    {-Z,--size}'[print ELF file size]'
    {-a,--all}'[print all useful/simple info]'

    # Search/filter options
    {-s,--symbol}'[find a specified symbol]:symbol name'
    {-k,--section}'[find a specified section]:section name'
    {-N,--lib}'[find a specified library]:library name'
    {-g,--gmatch}'[use regex matching (with -s); specify twice for case insensitive]'
    {-E,--etype}'[print only ELF files matching etype]:elf type (comma-separated):(ET_DYN ET_EXEC ET_REL ET_CORE ET_NONE)'
    {-M,--bits}'[print only ELF files matching numeric bits]:bits:(32 64)'
    {-O,--perms}'[print only ELF files matching octal permissions]:octal permissions'

    # Output options
    {-q,--quiet}'[only output bad things]'
    {-v,--verbose}'[be verbose (can be specified more than once)]'
    {-F,--format}'[use specified format for output]:format string'
    {-f,--from}'[read input stream from a file]:input file:_files'
    {-o,--file}'[write output stream to a file]:output file:_files'
    {-C,--nocolor}'[do not emit color in output]'
    {-B,--nobanner}'[do not display the header]'

    '*:file or directory:_files'
  )

  _arguments -s -S $arguments
}

_scanelf "$@"
