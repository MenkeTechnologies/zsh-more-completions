#compdef yt-dlp

# Zsh completion for yt-dlp - a youtube-dl fork with additional features and patches

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help text]' \
  '--version[print program version]' \
  '(-U --update)'{-U,--update}'[update this program to the latest version]' \
  '--update-to[update to a specific version]:version:' \
  '--no-update[do not check for updates]' \
  '(-i --ignore-errors)'{-i,--ignore-errors}'[continue on download errors]' \
  '--abort-on-error[abort downloading of further videos if an error occurs]' \
  '--dump-user-agent[display the current user-agent]' \
  '--list-extractors[list all supported extractors]' \
  '--extractor-descriptions[output descriptions of all supported extractors]' \
  '--force-generic-extractor[force extraction to use generic extractor]' \
  '--default-search[use this prefix for unqualified URLs]:prefix:' \
  '--ignore-config[do not read config file]' \
  '--config-location[location of the config file]:file:_files' \
  '--flat-playlist[do not extract videos of a playlist, only list them]' \
  '--live-from-start[download livestreams from the start]' \
  '--no-live-from-start[download livestreams from the current time]' \
  '--wait-for-video[wait for scheduled streams]:range:' \
  '--no-wait-for-video[do not wait for scheduled streams]' \
  '--mark-watched[mark videos watched (YouTube only)]' \
  '--no-mark-watched[do not mark videos watched]' \
  '--no-colors[do not emit color codes in output]' \
  '--compat-options[options that can help compatibility with yt-dlp and youtube-dl]:opts:' \
  \
  '--proxy[use specified HTTP/HTTPS/SOCKS proxy]:proxy:' \
  '--socket-timeout[time to wait before giving up]:seconds:' \
  '--source-address[client-side IP address to bind to]:IP:' \
  '--force-ipv4[make all connections via IPv4]' \
  '--force-ipv6[make all connections via IPv6]' \
  '--geo-verification-proxy[use this proxy to verify geo restriction]:proxy:' \
  '--geo-bypass[bypass geographic restriction via faking X-Forwarded-For HTTP header]' \
  '--no-geo-bypass[do not bypass geographic restriction]' \
  '--geo-bypass-country[force bypass geographic restriction with explicitly provided 2-letter ISO country code]:CC:' \
  '--geo-bypass-ip-block[force bypass geographic restriction with explicitly provided IP block in CIDR notation]:IP_BLOCK:' \
  \
  '(-R --retries)'{-R,--retries}'[number of retries]:N:' \
  '--file-access-retries[number of times to retry on file access error]:N:' \
  '--fragment-retries[number of retries for fragment downloads]:N:' \
  '--retry-sleep[sleep between retries]:expr:' \
  '--skip-unavailable-fragments[skip unavailable fragments]' \
  '--abort-on-unavailable-fragment[abort downloading of the fragment if unavailable]' \
  '--keep-fragments[keep downloaded fragments after download]' \
  '--no-keep-fragments[delete downloaded fragments after download]' \
  '--buffer-size[size of download buffer]:SIZE:' \
  '--no-resize-buffer[do not automatically adjust buffer size]' \
  '--http-chunk-size[size of a chunk for chunk-based HTTP downloading]:SIZE:' \
  '--playlist-reverse[download playlist videos in reverse order]' \
  '--playlist-random[download playlist videos in random order]' \
  '--xattr-set-filesize[set file xattribute ytdl.filesize with expected file size]' \
  '--hls-use-mpegts[use mpegts container for HLS videos]' \
  '--no-hls-use-mpegts[do not use mpegts container for HLS videos]' \
  '--downloader[name or path of external downloader to use]:downloader:(native aria2c httpie wget curl ffmpeg axel)' \
  '--downloader-args[give these arguments to the external downloader]:args:' \
  \
  '(-x --extract-audio)'{-x,--extract-audio}'[convert video files to audio-only files]' \
  '--audio-format[specify audio format to use]:format:(best aac flac mp3 m4a opus vorbis wav)' \
  '--audio-quality[specify audio quality]:quality:(0 5 9 128K 192K)' \
  '--remux-video[remux video into another container]:format:' \
  '--recode-video[re-encode video into another format]:format:(mp4 flv ogg webm mkv avi)' \
  '--postprocessor-args[give these arguments to a postprocessor]:args:' \
  '-k[keep the intermediate video file on disk after post-processing]' \
  '--keep-video[keep the intermediate video file on disk after post-processing]' \
  '--no-post-overwrites[do not overwrite post-processed files]' \
  '--embed-subs[embed subtitles in the video]' \
  '--embed-thumbnail[embed thumbnail in the video as cover art]' \
  '--embed-metadata[embed metadata to the video file]' \
  '--embed-chapters[add chapter markers to the video file]' \
  '--embed-info-json[embed the infojson as an attachment to the video file]' \
  '--parse-metadata[parse additional metadata like title/artist]:FROM\:TO:' \
  '--replace-in-metadata[replace text in a metadata field]:FIELDS REGEX REPLACE:' \
  '--xattrs[write metadata to the video file'\''s xattrs]' \
  '--concat-playlist[concatenate videos in a playlist]:policy:(never always multi_video)' \
  '--fixup[automatically correct known faults of the file]:policy:(never warn detect_or_warn force)' \
  '--ffmpeg-location[location of ffmpeg binary]:path:_files' \
  '--exec[execute a command on the file after downloading]:cmd:' \
  '--exec-before-download[execute a command before the download starts]:cmd:' \
  '--convert-subs[convert the subtitles to another format]:format:(srt ass vtt lrc)' \
  '--convert-thumbnails[convert the thumbnails to another format]:format:(jpg png webp)' \
  '--split-chapters[split video into multiple files based on internal chapters]' \
  '--no-split-chapters[do not split video based on chapters]' \
  \
  '(-o --output)'{-o,--output}'[output filename template]:template:' \
  '--output-na-placeholder[placeholder for NA in --output]:placeholder:' \
  '--restrict-filenames[restrict filenames to only ASCII characters]' \
  '--no-restrict-filenames[allow Unicode characters in filenames]' \
  '--windows-filenames[force filenames to be Windows-compatible]' \
  '--no-windows-filenames[make filenames Windows-compatible only if using Windows]' \
  '--trim-filenames[limit the filename length]:length:' \
  '--no-overwrites[do not overwrite any files]' \
  '(-w --no-overwrites)'{-w,--no-overwrites}'[do not overwrite files]' \
  '--force-overwrites[overwrite all video and metadata files]' \
  '--continue[force resume of partially downloaded files]' \
  '--no-continue[do not resume partially downloaded fragments]' \
  '--part[use .part files instead of overwriting]' \
  '--no-part[do not use .part files]' \
  '--mtime[use Last-modified header to set the file modification time]' \
  '--no-mtime[do not use Last-modified header to set the file modification time]' \
  '--write-description[write video description to .description file]' \
  '--write-info-json[write video metadata to .info.json file]' \
  '--no-write-info-json[do not write video metadata]' \
  '--write-playlist-metafiles[write playlist metadata in addition to the video metadata]' \
  '--no-clean-info-json[write original info json and original thumbnail in the .info.json]' \
  '--write-comments[retrieve video comments to be placed in info-json]' \
  '--no-write-comments[do not retrieve video comments unless the extraction is known to be quick]' \
  '--load-info-json[load info from a .info.json file]:file:_files -g "*.json"' \
  '--cookies[file to read cookies from]:file:_files' \
  '--no-cookies[do not use a cookies file]' \
  '--cookies-from-browser[the name of the browser to load cookies from]:BROWSER_SPEC:' \
  '--no-cookies-from-browser[do not load cookies from browser]' \
  '--cache-dir[location in filesystem where youtube-dl can store some downloaded information]:dir:_files -/' \
  '--no-cache-dir[disable filesystem caching]' \
  '--rm-cache-dir[delete all filesystem cache files]' \
  \
  '--write-thumbnail[write thumbnail image to disk]' \
  '--no-write-thumbnail[do not write thumbnail image to disk]' \
  '--write-all-thumbnails[write all thumbnail image formats to disk]' \
  '--list-thumbnails[list available thumbnails of each video]' \
  \
  '--write-subs[write subtitle file]' \
  '--no-write-subs[do not write subtitle file]' \
  '--write-auto-subs[write automatically generated subtitle file]' \
  '--no-write-auto-subs[do not write auto-generated subtitles]' \
  '--all-subs[download all the available subtitles of the video]' \
  '--list-subs[list all available subtitles for the video]' \
  '--sub-format[subtitle format, accepts formats preference]:format:(srt ass vtt lrc)' \
  '--sub-langs[languages of the subtitles to download]:langs:' \
  \
  '(-u --username)'{-u,--username}'[username]:username:' \
  '(-p --password)'{-p,--password}'[account password]:password:' \
  '(-2 --twofactor)'{-2,--twofactor}'[two-factor authentication code]:code:' \
  '(-n --netrc)'{-n,--netrc}'[use .netrc authentication data]' \
  '--netrc-location[.netrc locations]:path:_files' \
  '--video-password[video password]:password:' \
  '--ap-mso[Adobe Pass MSO]:MSO:' \
  '--ap-username[multiple system operator account login]:username:' \
  '--ap-password[multiple system operator account password]:password:' \
  '--client-certificate[path to client certificate in PEM format]:file:_files' \
  '--client-certificate-key[path to private key file for client certificate]:file:_files' \
  '--client-certificate-password[password for client certificate private key]:password:' \
  \
  '(-f --format)'{-f,--format}'[video format code]:format:(bestvideo+bestaudio best bestvideo bestaudio worst worstvideo worstaudio)' \
  '(-S --format-sort)'{-S,--format-sort}'[sort formats by specified field]:fields:' \
  '--format-sort-force[force user specified sort order to have priority over all fields]' \
  '--no-format-sort-force[some fields have priority over the user specified sort order]' \
  '--video-multistreams[allow multiple video streams to be merged into a single file]' \
  '--no-video-multistreams[only one video stream is downloaded for each output file]' \
  '--audio-multistreams[allow multiple audio streams to be merged into a single file]' \
  '--no-audio-multistreams[only one audio stream is downloaded for each output file]' \
  '--prefer-free-formats[prefer video formats with free containers over non-free ones]' \
  '--no-prefer-free-formats[do not give any special preference to free containers]' \
  '--check-formats[make sure formats are selected only from those that are actually downloadable]' \
  '--check-all-formats[check all formats for whether they are actually downloadable]' \
  '--no-check-formats[do not check that the formats are actually downloadable]' \
  '--list-formats[list all available formats of requested videos]' \
  '--merge-output-format[if merge required, output to given container format]:format:(mkv mp4 ogg webm flv)' \
  \
  '--playlist-start[playlist video to start at]:N:' \
  '--playlist-end[playlist video to end at]:N:' \
  '--playlist-items[playlist video items to download]:ITEM_SPEC:' \
  '--match-title[download only matching titles]:regex:' \
  '--reject-title[skip download for matching titles]:regex:' \
  '--max-downloads[abort after downloading NUMBER files]:N:' \
  '--min-filesize[do not download smaller files]:SIZE:' \
  '--max-filesize[do not download larger files]:SIZE:' \
  '--date[download only videos uploaded on this date]:DATE:' \
  '--datebefore[download only videos uploaded on or before this date]:DATE:' \
  '--dateafter[download only videos uploaded on or after this date]:DATE:' \
  '--match-filters[generic video filter]:FILTER:' \
  '--break-match-filters[same as --match-filters but stops the download process]:FILTER:' \
  '--no-match-filter[do not use generic video filter]' \
  '--no-playlist[download only the video, if the URL refers to both]' \
  '--yes-playlist[download the playlist if the URL refers to both a video and a playlist]' \
  '--age-limit[download only videos suitable for the given age]:YEARS:' \
  '--download-archive[download only videos not listed in archive file]:file:_files' \
  '--no-download-archive[do not use archive file]' \
  '--max-filesize[do not download files larger than SIZE]:SIZE:' \
  '--break-on-existing[stop the download process when encountering a file that is in the archive]' \
  '--break-per-input[alters --max-downloads, --break-on-existing, etc.]' \
  '--no-break-per-input[--break-on-existing and similar options terminate the whole queue]' \
  '--skip-playlist-after-errors[number of allowed failures until the rest of the playlist is skipped]:N:' \
  \
  '(-q --quiet)'{-q,--quiet}'[activate quiet mode]' \
  '--no-quiet[deactivate quiet mode]' \
  '--no-warnings[ignore warnings]' \
  '(-s --simulate)'{-s,--simulate}'[do not download the video and do not write anything to disk]' \
  '--no-simulate[download the video even if printing/listing options are used]' \
  '--ignore-no-formats-error[ignore "No video formats" error]' \
  '--no-ignore-no-formats-error[throw error when no downloadable video formats are found]' \
  '--skip-download[do not download the video but write all related files]' \
  '(-O --print)'{-O,--print}'[field name or output template to print to screen]:TEMPLATE:' \
  '--print-to-file[append given template to the file]:TEMPLATE\:FILE:' \
  '(-j --dump-json)'{-j,--dump-json}'[quiet but print JSON information for each video]' \
  '(-J --dump-single-json)'{-J,--dump-single-json}'[quiet but print JSON information for each URL or infojson passed]' \
  '--force-write-archive[force download archive entries to be written even if not actually downloaded]' \
  '--newline[output progress bar as new lines]' \
  '--no-progress[do not print progress bar]' \
  '--progress[show progress bar even in quiet mode]' \
  '--console-title[display progress in console titlebar]' \
  '--progress-template[template for progress outputs]:TEMPLATE:' \
  '(-v --verbose)'{-v,--verbose}'[print various debugging information]' \
  '--dump-pages[print downloaded pages encoded using base64 to debug problems]' \
  '--write-pages[write downloaded intermediary pages to files in current directory]' \
  '--print-traffic[display sent and read HTTP traffic]' \
  \
  '--ap-list-mso[list all supported multiple system operators]' \
  '--sponsorblock-mark[SponsorBlock categories to create chapters for]:CATS:' \
  '--sponsorblock-remove[SponsorBlock categories to be removed from the video file]:CATS:' \
  '--sponsorblock-chapter-title[title template for SponsorBlock chapters]:TEMPLATE:' \
  '--no-sponsorblock[disable SponsorBlock]' \
  '--sponsorblock-api[SponsorBlock API location]:URL:' \
  '*:URL:_urls'
