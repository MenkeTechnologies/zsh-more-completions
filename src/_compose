#compdef run-mailcap compose


local -a arguments

arguments=(
    '--action[Performs the specified action on the files.]:action'
    '--debug[Turns on extra information to find out what is happening.]'
    '--nopager[Ignores any "copiousoutput" directive and sends output to STDOUT.]'
    '--norun[Displays the found command without actually executing it.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
