#compdef scan-build12

local -a arguments

arguments=(
  '-analyze-headers[also analyze functions in #included files]'
  '--force-analyze-debug-code[analyze code with debug flag enabled]'
  '-o[target directory for HTML report output]:directory:_directories'
  '(- *)'{-h,--help}'[display help]'
  '-k[add a "keep on going" option to the build command]'
  '--keep-going[add a "keep on going" option to the build command]'
  '--keep-cc[do not override CC and CXX make variables]'
  '--html-title[specify the title used on generated HTML pages]:title'
  '--show-description[display the description of defects in the list]'
  '-sarif[output analysis results in SARIF format]'
  '-plist[output analysis results in Plist format]'
  '-plist-html[output analysis results in HTML and Plist format]'
  '--status-bugs[set exit status based on reported bugs]'
  '--exclude[do not run static analyzer against these directories]:path:_directories'
  '--use-cc[specify the compiler used for compilation]:compiler path:_files'
  '--use-c++[specify the C++ compiler used for compilation]:compiler path:_files'
  '--analyzer-target[specify target triple for cross-compilation analysis]:triple'
  '-v[verbose output]'
  '-V[view analysis results in a web browser]'
  '--view[view analysis results in a web browser]'
  '--generate-index-only[only regenerate the index for an existing report]:directory:_directories'
  '-no-failure-reports[do not create a crash analysis file on failure]'
  '-stats[generate visitation statistics]'
  '-maxloop[specify the number of times a block can be visited]:count'
  '-internal-stats[generate internal analyzer statistics]'
  '--use-analyzer[specify the path to the analyzer]:analyzer path:_files'
  '--keep-empty[do not remove empty report directories]'
  '--override-compiler[always resort to the ccc-analyzer for interposition]'
  '-analyzer-config[provide analyzer configuration options]:config'
  '-enable-checker[enable specific checker]:checker name'
  '-disable-checker[disable specific checker]:checker name'
  '-load-plugin[load specified analyzer plugin library]:library:_files'
  '*:filename:_files'
)

_arguments -s -S $arguments
