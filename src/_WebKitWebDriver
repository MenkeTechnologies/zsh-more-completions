#compdef WebKitWebDriver
# Documentation: https://man.archlinux.org/search?q=WebKitWebDriver
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[prints this help message]'
  {-p,--port}'[port number the driver will use]'
  '*:filename:_files'
)

_arguments -s -S $arguments
