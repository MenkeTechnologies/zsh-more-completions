#compdef atopcat
# Documentation: https://man.archlinux.org/search?q=atopcat
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '-d[dry-run: read logfile(s) but do not generate output on stdout.]'
    '-v[verbose: print one line per sample containing date/time, interval length in s]'
    '*:filename:_files'
)
_arguments -s -S $arguments
