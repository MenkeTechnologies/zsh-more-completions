#compdef wc gwc

# Completion for wc (BSD and GNU coreutils)

local arguments

if _pick_variant gnu='Free Soft' unix --version 2>/dev/null; then
  # GNU coreutils wc
  arguments=(
    {-c,--bytes}'[print the byte counts]'
    {-m,--chars}'[print the character counts]'
    {-l,--lines}'[print the newline counts]'
    {-w,--words}'[print the word counts]'
    {-L,--max-line-length}'[print the maximum display width]'
    '--debug[indicate what line count acceleration is used]'
    '--files0-from=[read input from NUL-terminated names in specified file]:file:_files'
    '--total=[when to print a line with total counts]:when:(auto always only never)'
    '(- *)--help[display help and exit]'
    '(- *)--version[output version information and exit]'
    '*:file:_files'
  )
else
  # BSD wc (macOS / FreeBSD)
  arguments=(
    '-c[print the byte counts]'
    '-l[print the line counts]'
    '-m[print the character counts]'
    '-w[print the word counts]'
    '-L[print the length of the longest line]'
    '--libxo[generate output via libxo in various formats]'
    '*:file:_files'
  )
fi

_arguments -s -S $arguments
