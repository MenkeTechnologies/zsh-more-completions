#compdef blueman-assistant
# Documentation: https://man.archlinux.org/search?q=blueman-assistant
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-d,--device}'[start configuration assistant for this device]'
  '*:filename:_files'
)

_arguments -s -S $arguments
