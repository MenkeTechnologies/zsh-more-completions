#compdef cjet
# Documentation: https://man.archlinux.org/search?q=cjet
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-f[full paint mode]'
  '-p[ignore paper size commands]'
  '-q[quiet mode]'
  '-x[shift output horizontally by <d> dots]'
  '-y[shift output vertically by <d> dots]'
  '*:filename:_files'
)

_arguments -s -S $arguments
