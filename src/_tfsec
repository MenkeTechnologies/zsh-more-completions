#compdef tfsec

# Zsh completion for tfsec (Terraform security scanner)

_arguments -s -S \
  '--config-file[config file]:file:_files' \
  '--custom-check-dir[custom checks directory]:dir:_files -/' \
  '--debug[enable debug logging]' \
  '--exclude[exclude rules]:rules:' \
  '--exclude-downloaded-modules[exclude downloaded modules]' \
  '--exclude-path[exclude paths]:path:_files' \
  '--filter-results[filter results by severity]:severity:' \
  '--force-all-dirs[scan all directories]' \
  '(-f --format)'{-f,--format}'[output format]:format:(default json csv checkstyle junit sarif gif lovely)' \
  '--ignore-hcl-errors[ignore HCL parse errors]' \
  '--include-ignored[include ignored checks]' \
  '--include-passed[include passed checks]' \
  '--minimum-severity[minimum severity to report]:severity:(LOW MEDIUM HIGH CRITICAL)' \
  '--no-color[disable color output]' \
  '--no-module-downloads[do not download remote modules]' \
  '--out[output file]:file:_files' \
  '--print-rego-input[print Rego input]' \
  '--rego-policy-dir[Rego policy directory]:dir:_files -/' \
  '--run-statistics[show run statistics]' \
  '(-s --soft-fail)'{-s,--soft-fail}'[run but do not return error code on findings]' \
  '--tfvars-file[terraform.tfvars file]:file:_files' \
  '--update[update tfsec]' \
  '--verbose[enable verbose logging]' \
  '--version[show version]' \
  '--workspace[terraform workspace]:workspace:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:directory:_files -/' && return 0
