#compdef xmlcatmgr
# Documentation: https://man.archlinux.org/search?q=xmlcatmgr
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-c[use `catalog as the catalog file.]'
  '-h[show this help message.]'
  '-p[prepend new entries instead of append (add mode only).]'
  '-s[switch to SGML mode.]'
  '-v[show version information and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
