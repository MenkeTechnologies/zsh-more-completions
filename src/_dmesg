#compdef dmesg

# Comprehensive zsh completion for dmesg (util-linux 2.40+)

_dmesg() {
  local curcontext="$curcontext" state lstate line
  typeset -A opt_args

  local -a _dmesg_facilities=(
    kern user mail daemon auth syslog lpr news
  )

  local -a _dmesg_levels=(
    emerg alert crit err warn notice info debug
  )

  local -a _dmesg_time_formats=(
    ctime reltime delta iso raw
  )

  _arguments -s -S \
    '(- *)'{-h,--help}'[Display help text and exit]' \
    '(- *)'{-V,--version}'[Display version information and exit]' \
    {-C,--clear}'[Clear the kernel ring buffer]' \
    {-c,--read-clear}'[Read and clear all messages from kernel ring buffer]' \
    {-D,--console-off}'[Disable printing messages to console]' \
    {-E,--console-on}'[Enable printing messages to console]' \
    {-d,--show-delta}'[Show time delta between printed messages]' \
    {-e,--reltime}'[Show local time and time delta in human-readable format]' \
    {-F+,--file=}'[Read log from file instead of kernel log buffer]:log file:_files' \
    {-K+,--kmsg-file=}'[Read /dev/kmsg messages from the given file]:kmsg file:_files' \
    '*'{-f+,--facility=}'[Restrict output to defined facilities]:facility:_sequence compadd - ${_dmesg_facilities[@]}' \
    {-H,--human}'[Enable human-readable output]' \
    {-J,--json}'[Use JSON output format]' \
    {-k,--kernel}'[Print kernel messages]' \
    {-L,--color=}'[Colorize messages]:when:(auto never always)' \
    '*'{-l+,--level=}'[Restrict output to defined levels]:level:_sequence compadd - ${_dmesg_levels[@]}' \
    {-n+,--console-level=}'[Set level of messages printed to console]:level:(1 2 3 4 5 6 7 8)' \
    {-P,--nopager}'[Do not pipe output into a pager]' \
    {-p,--force-prefix}'[Add facility, level or timestamp to each line of multi-line messages]' \
    {-r,--raw}'[Print the raw message buffer]' \
    {-S,--syslog}'[Force to use syslog(2) rather than /dev/kmsg]' \
    {-s+,--buffer-size=}'[Buffer size to query the kernel ring buffer]:size (bytes)' \
    {-T,--ctime}'[Print human-readable timestamps]' \
    {-t,--notime}"[Don't print kernel's timestamps]" \
    '--time-format=[Print timestamps using the given format]:format:(${_dmesg_time_formats[@]})' \
    {-u,--userspace}'[Print userspace messages]' \
    {-w,--follow}'[Wait for new messages]' \
    {-W,--follow-new}'[Wait and print only new messages]' \
    {-x,--decode}'[Decode facility and level to readable string]' \
    '--since=[Display records since the specified time]:time' \
    '--until=[Display records until the specified time]:time' \
    '--noescape[Disable escaping of unprintable and potentially unsafe characters]'
}

_dmesg "$@"
