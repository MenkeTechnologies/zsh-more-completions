#compdef ipcalc

# Zsh completion for ipcalc (IP subnet calculator)
# Supports both the Perl-based (jodies.de) and C-based (Red Hat/Fedora) variants

_arguments -s -S \
  '(- *)'{-h,--help}'[display help and exit]' \
  '(- *)'{-v,--version}'[display version and exit]' \
  '(- *)--usage[display brief usage message]' \
  {-4,--ipv4}'[IPv4 address family (default)]' \
  {-6,--ipv6}'[IPv6 address family]' \
  {-b,--broadcast}'[display calculated broadcast address]' \
  {-c,--check}'[validate IP address for specified address family]' \
  {-d,--dns}'[display DNS reverse name]' \
  {-g,--geoinfo}'[display geographic information about the IP]' \
  {-h,--hostname}'[show hostname determined via DNS]' \
  {-i,--info}'[print information on the provided IP address]' \
  {-m,--netmask}'[display default netmask for IP (class A, B, or C)]' \
  {-n,--network}'[display network address]' \
  {-o,--lookup}'[show country of IP using geoip lookup]' \
  {-p,--prefix}'[display network prefix]' \
  {-r,--random-private}'[generate a random private address for given prefix]:prefix' \
  {-s,--silent}'[don'\''t ever display error messages]' \
  '--all-info[display all available information]' \
  '--class-prefix[assign classful prefix to provided address]' \
  '--minaddr[display the minimum address in the network]' \
  '--maxaddr[display the maximum address in the network]' \
  '--addresses[display the number of addresses in the network]' \
  '--addrspace[display the address space the address belongs to]' \
  '--reverse-dns[display the reverse DNS for the address]' \
  '--no-decorate[print output without text decorations]' \
  '--json[print output as JSON]' \
  '--split[split the network into subnets of specified prefix]:prefix sizes' \
  '--deaggregate[deaggregate the provided address range]:address range' \
  '*:IP address or network'
