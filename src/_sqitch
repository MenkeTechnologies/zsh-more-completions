#compdef sqitch

# Zsh completion for sqitch (database change management)

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'init:create a new Sqitch project'
  'add:add a new change to the plan'
  'deploy:deploy changes to a database'
  'revert:revert changes from a database'
  'verify:verify deployed changes'
  'status:show current deployment status'
  'log:show deployment log'
  'tag:add a tag to the latest change'
  'config:get and set local, user, or system options'
  'bundle:bundle a Sqitch project for distribution'
  'checkout:revert and deploy changes for a VCS checkout'
  'engine:manage engine configuration'
  'help:display help for a command'
  'plan:show the contents of the plan'
  'rebase:revert and redeploy changes'
  'show:show information about changes and tags'
  'target:manage target database configuration'
  'upgrade:upgrade the registry'
)

_arguments -s -S \
  '(- *)--help[show help message]' \
  '--plan-file+[path to the deployment plan file]:plan file:_files' \
  '--top-dir+[path to the project top directory]:directory:_directories' \
  '--engine+[database engine]:engine:(pg sqlite mysql oracle firebird vertica exasol snowflake)' \
  '--registry+[registry schema or database name]:registry:' \
  '--client+[path to the engine client]:client:_files' \
  '--db-name+[database name]:database:' \
  '--db-host+[database host]:host:_hosts' \
  '--db-port+[database port]:port:' \
  '--db-user+[database user]:user:' \
  '*:: :->subcmd' && ret=0

case $state in
  subcmd)
    if (( CURRENT == 1 )); then
      _describe -t commands 'sqitch command' subcommands && ret=0
    fi
    ;;
esac

return ret
