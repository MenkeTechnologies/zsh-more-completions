#compdef ack

local -a arguments

arguments=(
    {-i,--ignore-case}'[Ignore case distinctions in PATTERN]'
    {-v,--invert-match}'[Invert match: select non-matching lines]'
    {-w,--word-regexp}'[Force PATTERN to match only whole words]'
    {-Q,--literal}'[Quote all metacharacters; PATTERN is literal]'
    '--lines[Only print line(s) NUM of each file]:line number: '
    {-l,--files-with-matches}'[Only print filenames containing matches]'
    {-L,--files-without-matches}'[Only print filenames with no matches]'
    '--output[Output the evaluation of expr for each line]:expr: '
    '-o[Show only the part of a line matching PATTERN]'
    '--passthru[Print all lines, whether matching or not]'
    '--match[Specify PATTERN explicitly]:pattern: '
    {-m,--max-count}'[Stop searching in each file after NUM matches]:number: '
    '-1[Stop searching after one match of any kind]'
    {-H,--with-filename}'[Print the filename for each match]'
    {-h,--no-filename}'[Suppress the prefixing filename on output]'
    {-c,--count}'[Show number of lines matching per file]'
    {-A,--after-context}'[Print NUM lines of trailing context after matching lines]:number: '
    {-B,--before-context}'[Print NUM lines of leading context before matching lines]:number: '
    {-C,--context}'[Print NUM lines (default 2) of output context]:number: '
    '--print0[Print null byte as separator between filenames]'
    '-s[Suppress error messages about nonexistent or unreadable files]'
    '--pager[Pipes all ack output through COMMAND]:command:_command_names'
    '--nopager[Do not send output through a pager]'
    '--group[Same as --heading --break]'
    '--nogroup[Same as --noheading --nobreak]'
    '--color-filename[Set the color for filenames]:color: '
    '--color-match[Set the color for matches]:color: '
    '--color-lineno[Set the color for line numbers]:color: '
    '--flush[Flush output immediately, even when ack is used non-interactively]'
    '-f[Only print the files selected, without searching]'
    '-g[Same as -f, but only select files matching PATTERN]:pattern: '
    '--sort-files[Sort the found files lexically]'
    '--show-types[Show which types each file has]'
    '--files-from[Read the list of files to search from FILE]:file:_files'
    '-x[Read the list of files to search from STDIN]'
    '--ignore-file[Add filter for ignoring files]:filter: '
    {-r,-R,--recurse}'[Recurse into subdirectories (default: on)]'
    {-n,--no-recurse}'[No descending into subdirectories]'
    {-k,--known-types}'[Include only files of types that ack recognizes]'
    '--type-set[Define a new file type]:type definition: '
    '--type-add[Add filters to an existing file type]:type definition: '
    '--type-del[Removes all filters associated with TYPE]:type: '
    '--ackrc[Specify an ackrc file to use]:file:_files'
    '--ignore-ack-defaults[Ignore default definitions included with ack]'
    '--create-ackrc[Outputs a default ackrc for your customization]'
    '(- * :)--help[This help]'
    '--help-types[Display all known types]'
    '--dump[Dump information on which options are loaded]'
    '--man[Man page]'
    '--version[Display version & copyright]'
    '--thpppt[Bill the Cat]'
    '--bar[The warning admiral]'
    '--cathy[Chocolate! Chocolate! Chocolate!]'
    '*:filename:_files'
)

_arguments -s -S $arguments
