#compdef gau

# Zsh completion for gau (getallurls) - fetch known URLs from AlienVault OTX, Wayback Machine, and Common Crawl

_arguments -s -S \
  '--threads[number of workers to spawn]:N:' \
  '--verbose[show verbose output]' \
  '--retries[number of times to retry request]:N:' \
  '--providers[providers to fetch URLs from]:providers:(wayback commoncrawl otx urlscan)' \
  '--blacklist[filter out extensions]:extensions:' \
  '--whitelist[include only specified extensions]:extensions:' \
  '--mime[filter results by MIME type]:mime-types:' \
  '--from[fetch URLs from a specific date (YYYYMM)]:date:' \
  '--to[fetch URLs to a specific date (YYYYMM)]:date:' \
  '--fp[remove ports 80/443 from URLs]' \
  '--json[write output as JSON]' \
  '--output[output file]:file:_files' \
  '--subs[include subdomains of target domain]' \
  '--proxy[HTTP proxy]:proxy:' \
  '--rate-limit[limit requests per second]:rate:' \
  '*:domain:_hosts'
