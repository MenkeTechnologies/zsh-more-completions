#compdef varlinkctl
# Documentation: https://man.archlinux.org/search?q=varlinkctl
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '--more'
    '--collect'
    '--oneway'
    '--json:MODE'
    '-j'
    '--no-pager'
    {-h,--help}'[show help message]'
    '--version'
    '*:filename:_files'
)
_arguments -s -S $arguments
