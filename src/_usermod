#compdef usermod

# Completion for usermod (shadow-utils)
# https://github.com/shadow-maint/shadow

_usermod() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a arguments

    arguments=(
        {-a,--append}'[append the user to the supplementary group(s), use only with -G]'
        {-c,--comment}'[new value of the GECOS field]:comment:'
        {-d,--home}'[new home directory for the user account]:home directory:_directories'
        {-e,--expiredate}'[set account expiration date (YYYY-MM-DD)]:expiration date:'
        {-f,--inactive}'[set password inactive after expiration to INACTIVE days]:inactive days:'
        {-g,--gid}'[force use GROUP as new primary group]:primary group:_groups'
        {-G,--groups}'[new list of supplementary groups]:supplementary groups:_sequence _groups'
        '(- * :)'{-h,--help}'[display help message and exit]'
        {-l,--login}'[new value of the login name]:new login name:'
        {-L,--lock}'[lock the user account]'
        {-m,--move-home}'[move contents of the home directory to the new location, use only with -d]'
        {-o,--non-unique}'[allow using duplicate (non-unique) UID]'
        {-p,--password}'[use encrypted password for the new password]:encrypted password:'
        {-P,--prefix}'[directory prefix for etc files]:prefix directory:_directories'
        {-r,--remove}'[remove the user from supplementary group(s), use only with -G]'
        {-R,--root}'[directory to chroot into]:chroot directory:_directories'
        {-s,--shell}'[new login shell for the user account]:login shell:_files -g "*(*)"'
        {-u,--uid}'[new UID for the user account]:UID:'
        {-U,--unlock}'[unlock the user account]'
        {-v,--add-subuids}'[add range of subordinate UIDs]:UID range (FIRST-LAST):'
        {-V,--del-subuids}'[remove range of subordinate UIDs]:UID range (FIRST-LAST):'
        {-w,--add-subgids}'[add range of subordinate GIDs]:GID range (FIRST-LAST):'
        {-W,--del-subgids}'[remove range of subordinate GIDs]:GID range (FIRST-LAST):'
        {-Z,--selinux-user}'[new SELinux user mapping for the user account]:SELinux user:'
        '1:username:_users'
    )

    _arguments -s -S $arguments && ret=0
    return ret
}

_usermod "$@"
