#compdef tuptime
# Zsh completion for tuptime
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  {-t,--table}'[show table of system startups]' \
  {-l,--list}'[show list of system startups]' \
  {-s,--seconds}'[output time in seconds]' \
  '--csv[output in CSV format]' \
  '--tsv[output in TSV format]' \
  {-n,--order}'[order by]:key:((e\:end\ date r\:runtime s\:startup\ date u\:uptime d\:downtime))' \
  {-r,--reverse}'[reverse sort order]' \
  '--silent[suppress normal output]' \
  {-e,--end}'[restrict to last N entries]:number:' \
  {-S,--since}'[restrict from date]:date:' \
  {-U,--until}'[restrict until date]:date:' \
  '--decp[set decimal precision]:digits:' \
  {-c,--kernel}'[show kernel version]' \
  '--no-pint[do not use pint for time formatting]' \
  {-p,--power}'[show power events]' \
  {-g,--graph}'[show graph]' \
  {-v,--verbose}'[verbose output]' \
  {-V,--version}'[show version]' \
  {-h,--help}'[show help]' && ret=0
return ret
