#compdef update-java-alternatives
# Documentation: https://man.archlinux.org/search?q=update-java-alternatives
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-l,--list}'[list available Java alternatives]:jname:'
  {-s,--set}'[set Java alternative]:jname:'
  {-a,--auto}'[auto mode]'
  '(- * :)'{-h,--help}'[display help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
