#compdef aqua

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:create a configuration file if it does not exist'
  'install:install tools'
  'generate:search packages and add to configuration'
  'which:show the file path of the command'
  'exec:execute the command'
  'list:list packages'
  'update:update packages'
  'completion:output shell completion'
  'version:show version'
  'cp:copy executables'
  'policy:manage policies'
  'remove:remove packages'
  'info:show package info'
  'update-aqua:update aqua itself'
  'root-dir:show aqua root directory'
  'allow:allow a policy file'
  'deny:deny a policy file'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'=[configuration file path]:config:_files' \
  '(-l --log-level)'{-l,--log-level}'=[log level]:level:(debug info warn error)' \
  '--log-color=[log color]:color:(auto always never)' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'aqua command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (install|i)
        _arguments -s -S \
          '(-a --all)'{-a,--all}'[install all tools]' \
          '--only-link[create only links]' \
          '--test[test configuration]' \
          '--tags=[filter by tags]:tags' && ret=0
        ;;
      (generate|g)
        _arguments -s -S \
          '(-i --insert)'{-i,--insert}'=[insert index]:index' \
          '--pin[pin version]' \
          '-o+[output file]:file:_files' \
          '--output=[output file]:file:_files' \
          '--select-version[select version interactively]' \
          '*:package name' && ret=0
        ;;
      (update|up)
        _arguments -s -S \
          '(-s --select)'{-s,--select}'[select packages interactively]' \
          '--only-registry[update only registry]' \
          '--only-package[update only packages]' && ret=0
        ;;
      (list)
        _arguments -s -S \
          '--installed[show only installed packages]' && ret=0
        ;;
      (which)
        _arguments '1:command name' && ret=0
        ;;
      (cp)
        _arguments -s -S \
          '-o+[output directory]:directory:_directories' \
          '--output=[output directory]:directory:_directories' \
          '*:command name' && ret=0
        ;;
      (remove)
        _arguments -s -S \
          '--all[remove all packages]' \
          '--mode=[removal mode]:mode:(link)' \
          '*:package name' && ret=0
        ;;
    esac
    ;;
esac

return ret
