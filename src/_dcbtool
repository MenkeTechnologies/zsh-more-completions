#compdef dcbtool
# Documentation: https://man.archlinux.org/search?q=dcbtool
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[help (show this usage text)]'
  '-v[shown version information]'
  '-r[show raw messages]'
  '-R[show only raw messages]'
  '*:filename:_files'
)

_arguments -s -S $arguments
