#compdef l2control
# Documentation: https://man.archlinux.org/search?q=l2control
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-a[specify local device to connect to]'
  '-h[display this message]'
  '-n[show addresses as numbers]'
  '*:filename:_files'
)

_arguments -s -S $arguments
