#compdef a2enconf a2disconf
# Documentation: https://man.archlinux.org/search?q=a2enconf
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    {-q,--quiet}'[Don\t show informative messages.]'
    {-m,--maintmode}'[Enables the maintainer mode, that is the program invocation is effectuated au]'
    {-p,--purge}'[When disabling a module, purge all traces of the module in the internal state]'
    '*:filename:_files'
)
_arguments -s -S $arguments
