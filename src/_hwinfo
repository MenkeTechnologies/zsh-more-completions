#compdef hwinfo

local -a arguments

arguments=(
  '--short[show only a summary]'
  '--listmd[also report RAID devices]'
  '--only[show only entries matching the specified device]:device:'
  '--save-config[store config for a particular device below /var/lib/hardware.]'
  '--show-config[show saved config data for a particular device.]'
  '--map[remap disk names if they have changed]'
  '--debug[set debug level to N]:level:'
  '--verbose[increase verbosity. Only together with --map.]'
  '--log[write log info to FILE.]'
  '--dump-db[dump hardware data base]:N:'
  '--version[print libhd version.]'
  '--help[print usage.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
