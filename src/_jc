#compdef jc

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-a --about)'{-a,--about}'[show parser info]' \
  '(-C --force-color)'{-C,--force-color}'[force color output]' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '(-m --monochrome)'{-m,--monochrome}'[monochrome output]' \
  '(-p --pretty)'{-p,--pretty}'[pretty print JSON]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-r --raw)'{-r,--raw}'[raw output]' \
  '(-u --unbuffer)'{-u,--unbuffer}'[unbuffer output]' \
  '(-B --bash-comp)'{-B,--bash-comp}'[generate bash completion]' \
  '(-Z --zsh-comp)'{-Z,--zsh-comp}'[generate zsh completion]' \
  '(-y --yaml-out)'{-y,--yaml-out}'[YAML output]' \
  '1:parser:->parsers' \
  '*:command arguments' && ret=0

case "$state" in
  parsers)
    local -a parsers=(
      '--acpi:ACPI parser'
      '--airport:airport -I parser'
      '--airport-s:airport -s parser'
      '--arp:arp parser'
      '--blkid:blkid parser'
      '--certbot:certbot parser'
      '--chage:chage --list parser'
      '--cksum:cksum parser'
      '--crontab:crontab parser'
      '--crontab-u:crontab with user parser'
      '--csv:CSV parser'
      '--csv-s:CSV streaming parser'
      '--date:date parser'
      '--df:df parser'
      '--dig:dig parser'
      '--dmidecode:dmidecode parser'
      '--dpkg-l:dpkg -l parser'
      '--du:du parser'
      '--env:env parser'
      '--file:file parser'
      '--find:find parser'
      '--findmnt:findmnt parser'
      '--finger:finger parser'
      '--free:free parser'
      '--fstab:fstab parser'
      '--group:group parser'
      '--gshadow:gshadow parser'
      '--hash:hash parser'
      '--hashsum:hashsum parser'
      '--hciconfig:hciconfig parser'
      '--history:history parser'
      '--host:host parser'
      '--hosts:hosts file parser'
      '--id:id parser'
      '--ifconfig:ifconfig parser'
      '--ini:INI parser'
      '--iostat:iostat parser'
      '--ip-address:ip address parser'
      '--iptables:iptables parser'
      '--iw-scan:iw scan parser'
      '--jar-manifest:JAR manifest parser'
      '--jobs:jobs parser'
      '--kv:key/value parser'
      '--last:last parser'
      '--ls:ls parser'
      '--ls-s:ls streaming parser'
      '--lsblk:lsblk parser'
      '--lsmod:lsmod parser'
      '--lsof:lsof parser'
      '--lsusb:lsusb parser'
      '--mount:mount parser'
      '--mpstat:mpstat parser'
      '--netstat:netstat parser'
      '--nmcli:nmcli parser'
      '--nsd-control:nsd-control parser'
      '--ntpq:ntpq parser'
      '--passwd:passwd parser'
      '--pidstat:pidstat parser'
      '--ping:ping parser'
      '--ping-s:ping streaming parser'
      '--pip-list:pip list parser'
      '--pip-show:pip show parser'
      '--plist:plist parser'
      '--postconf:postconf parser'
      '--ps:ps parser'
      '--route:route parser'
      '--rpm-qi:rpm -qi parser'
      '--rsync:rsync parser'
      '--rsync-s:rsync streaming parser'
      '--sfdisk:sfdisk parser'
      '--shadow:shadow parser'
      '--ss:ss parser'
      '--stat:stat parser'
      '--stat-s:stat streaming parser'
      '--sysctl:sysctl parser'
      '--syslog:syslog parser'
      '--syslog-s:syslog streaming parser'
      '--systemctl:systemctl parser'
      '--systemctl-lj:systemctl list-jobs parser'
      '--systemctl-ls:systemctl list-sockets parser'
      '--systemctl-luf:systemctl list-unit-files parser'
      '--systeminfo:systeminfo parser'
      '--time:time parser'
      '--timedatectl:timedatectl parser'
      '--toml:TOML parser'
      '--top:top parser'
      '--top-s:top streaming parser'
      '--tracepath:tracepath parser'
      '--traceroute:traceroute parser'
      '--ufw:ufw parser'
      '--ufw-appinfo:ufw app info parser'
      '--uname:uname parser'
      '--update-alt-gs:update-alternatives --get-selections parser'
      '--update-alt-q:update-alternatives --query parser'
      '--upower:upower parser'
      '--uptime:uptime parser'
      '--vmstat:vmstat parser'
      '--vmstat-s:vmstat streaming parser'
      '--w:w parser'
      '--wc:wc parser'
      '--who:who parser'
      '--xml:XML parser'
      '--xrandr:xrandr parser'
      '--yaml:YAML parser'
      '--zipinfo:zipinfo parser'
    )
    _describe -t parsers 'parser' parsers && ret=0
    ;;
esac

return ret
