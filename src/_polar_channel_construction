#compdef polar_channel_construction
# Documentation: https://man.archlinux.org/search?q=polar_channel_construction
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[displays this help message.]'
  {-c,--channel}'[specify channel, currently BEC or AWGN (default=BEC)]'
  {-b,--blocksize}'[specify block size of polar code (default=16)]'
  {-s,--desgin-snr}'[specify design SNR of polar code (default=0.0)]'
  {-k,--mu}'[specify block size of polar code (default=2)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
