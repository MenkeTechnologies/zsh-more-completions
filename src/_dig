#compdef dig

# Zsh completion for dig - DNS lookup utility

_dig_query_types() {
  local -a types
  types=(
    'A:IPv4 address record'
    'AAAA:IPv6 address record'
    'AFSDB:AFS database record'
    'ANY:any type (wildcard)'
    'APL:address prefix list'
    'AXFR:full zone transfer'
    'CAA:certification authority authorization'
    'CDNSKEY:child DNSKEY'
    'CDS:child DS'
    'CERT:certificate record'
    'CNAME:canonical name'
    'CSYNC:child-to-parent synchronization'
    'DHCID:DHCP identifier'
    'DLV:DNSSEC lookaside validation'
    'DNAME:delegation name'
    'DNSKEY:DNS key record'
    'DS:delegation signer'
    'EUI48:EUI-48 address'
    'EUI64:EUI-64 address'
    'HINFO:host information'
    'HIP:host identity protocol'
    'HTTPS:HTTPS service binding'
    'IPSECKEY:IPsec key'
    'IXFR:incremental zone transfer'
    'KEY:key record'
    'KX:key exchanger'
    'LOC:location record'
    'MX:mail exchange'
    'NAPTR:naming authority pointer'
    'NS:name server'
    'NSEC:next secure record'
    'NSEC3:next secure record v3'
    'NSEC3PARAM:NSEC3 parameters'
    'OPENPGPKEY:OpenPGP public key'
    'PTR:pointer record'
    'RP:responsible person'
    'RRSIG:DNSSEC signature'
    'SIG:signature record'
    'SMIMEA:S/MIME cert association'
    'SOA:start of authority'
    'SPF:sender policy framework'
    'SRV:service locator'
    'SSHFP:SSH public key fingerprint'
    'SVCB:service binding'
    'TLSA:TLSA certificate association'
    'TXT:text record'
    'URI:uniform resource identifier'
    'ZONEMD:message digest for DNS zones'
  )
  _describe -t query-types 'query type' types
}

_dig_query_classes() {
  local -a classes
  classes=(
    'IN:Internet'
    'HS:Hesiod'
    'CH:Chaos'
    'ANY:any class'
  )
  _describe -t query-classes 'query class' classes
}

_dig_plus_options() {
  local -a plus_options
  plus_options=(
    '+aaonly:set AA flag in query'
    '+noaaonly:clear AA flag in query'
    '+aaflag:set AA flag in query'
    '+noaaflag:clear AA flag in query'
    '+additional:display additional section'
    '+noadditional:suppress additional section'
    '+adflag:set AD flag in query'
    '+noadflag:clear AD flag in query'
    '+all:set all display flags'
    '+noall:clear all display flags'
    '+answer:display answer section'
    '+noanswer:suppress answer section'
    '+authority:display authority section'
    '+noauthority:suppress authority section'
    '+besteffort:try to parse even illegal messages'
    '+nobesteffort:do not parse illegal messages'
    '+bufsize:set EDNS0 max UDP packet size'
    '+cdflag:set checking disabled flag'
    '+nocdflag:clear checking disabled flag'
    '+cl:display class in records'
    '+nocl:suppress class in records'
    '+cmd:display command line'
    '+nocmd:suppress command line'
    '+comments:display comment lines'
    '+nocomments:suppress comment lines'
    '+crypto:display cryptographic fields'
    '+nocrypto:suppress cryptographic fields'
    '+defname:use search list'
    '+nodefname:do not use search list'
    '+dnssec:request DNSSEC records'
    '+nodnssec:do not request DNSSEC records'
    '+domain:set default domain name'
    '+edns:set EDNS version'
    '+noedns:disable EDNS'
    '+ednsflags:set EDNS flag bits'
    '+ednsnegotiation:set EDNS version negotiation'
    '+noednsnegotiation:disable EDNS version negotiation'
    '+ednsopt:send specified EDNS option'
    '+noednsopt:clear EDNS options'
    '+expire:request time to expire'
    '+noexpire:do not request time to expire'
    '+fail:do not try next server on SERVFAIL'
    '+nofail:try next server on SERVFAIL'
    '+identify:identify responders in short answers'
    '+noidentify:do not identify responders'
    '+idnout:convert IDN response'
    '+noidnout:do not convert IDN response'
    '+ignore:do not revert to TCP for TC responses'
    '+noignore:revert to TCP for TC responses'
    '+keepopen:keep TCP socket open between queries'
    '+nokeepopen:close TCP socket between queries'
    '+multiline:print records in expanded format'
    '+nomultiline:print records in single-line format'
    '+ndots:set search NDOTS value'
    '+nsid:request name server ID'
    '+nonsid:do not request name server ID'
    '+nssearch:search all authoritative nameservers'
    '+nonssearch:do not search all authoritative nameservers'
    '+onesoa:AXFR prints only one SOA record'
    '+noonesoa:AXFR prints all SOA records'
    '+opcode:set the opcode of the request'
    '+noopcode:clear the opcode'
    '+qr:print question before sending'
    '+noqr:do not print question before sending'
    '+question:display question section'
    '+noquestion:suppress question section'
    '+recurse:set recursive mode'
    '+norecurse:clear recursive mode'
    '+retry:set number of UDP retries'
    '+rrcomments:display per-record comments'
    '+norrcomments:suppress per-record comments'
    '+search:use search list'
    '+nosearch:do not use search list'
    '+short:display short form of answer only'
    '+noshort:display full answer'
    '+showsearch:show intermediate search results'
    '+noshowsearch:hide intermediate search results'
    '+split:split hex/base64 fields into chunks'
    '+nosplit:do not split fields'
    '+stats:display statistics'
    '+nostats:suppress statistics'
    '+subnet:set edns-client-subnet option'
    '+tcp:use TCP mode'
    '+notcp:use UDP mode'
    '+time:set query timeout in seconds'
    '+trace:trace delegation down from root'
    '+notrace:do not trace delegation'
    '+tries:set number of UDP attempts'
    '+ttlid:display TTLs in records'
    '+nottlid:suppress TTLs in records'
    '+vc:use TCP mode (virtual circuit)'
    '+novc:use UDP mode'
  )
  _describe -t plus-options 'dig query option' plus_options
}

_dig() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  # Handle +options specially
  if [[ "$PREFIX" = +* ]]; then
    _dig_plus_options
    return
  fi

  # Handle @server
  if [[ "$PREFIX" = @* ]]; then
    _message 'DNS server (@server)'
    return
  fi

  _arguments -s -S \
    '(- *)-h[print help and exit]' \
    '(- *)-v[print version and exit]' \
    '-4[use IPv4 query transport only]' \
    '-6[use IPv6 query transport only]' \
    '-b[bind to source address/port]:address\[#port\]:' \
    '-c[specify query class]:query class:_dig_query_classes' \
    '-f[batch mode - read queries from file]:batch file:_files' \
    '-i[use IP6.INT for IPv6 reverse lookups]' \
    '-k[specify TSIG key file]:key file:_files' \
    '-m[enable memory usage debugging]' \
    '-p[specify port number]:port:' \
    '-q[specify query name]:query name:_hosts' \
    '-t[specify query type]:query type:_dig_query_types' \
    '-u[display times in usec instead of msec]' \
    '-x[shortcut for reverse lookups]:IP address:' \
    '-y[specify named base64 TSIG key]:\[hmac\:\]name\:key:' \
    '*:query name or +option:_hosts'
}

_dig "$@"
