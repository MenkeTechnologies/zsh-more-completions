#compdef card

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[display this help and exit]'
  {-v,--version}'[display version information and exit]'
  {-o,--output}'[save the output in FILE]:file:_files'
  {-l,--language}'[print the help in the language LL (default: English)]:language:'
  '--command[perform pretty-printing on the output of CMD]:command:'
  '*:filename:_files'
)

_arguments -s -S $arguments
