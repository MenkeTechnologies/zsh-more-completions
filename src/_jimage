#compdef jimage
# Documentation: https://man.archlinux.org/search?q=jimage
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--verbose[list will also print entry size and offset attributes.]'
  '--dir[target directory for extract directive]'
  '--include[pattern list for filtering entries.]'
  '--verbose[listing prints entry size and offset]'
  '--version[print version information]'
  '*:filename:_files'
)

_arguments -s -S $arguments
