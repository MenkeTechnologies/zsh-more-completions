#compdef virt-login-shell
# Documentation: https://man.archlinux.org/search?q=virt-login-shell
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '-c:CMD'
    {-h,--help}'[show help message]'
    {-V,--version}'[show version information]'
    '*:filename:_files'
)
_arguments -s -S $arguments
