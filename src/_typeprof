#compdef typeprof

local -a arguments

arguments=(
  '-o[output to OUTFILE instead of stdout]:file:_files'
  {-q,--quiet}'[do not display progress indicator]'
  {-v,--verbose}'[alias to --show-errors]'
  '--version[display typeprof version]'
  '-I[add DIR to the load/require path]:directory:_directories'
  '-r[require RBS of the FEATURE gem]:feature:'
  '--collection[file path of collection configuration]:file:_files'
  '--no-collection[ignore collection configuration]'
  '--lsp[LSP mode]'
  '--include-dir[include the analysis result of .rb file in DIR]:directory:_directories'
  '--exclude-dir[exclude the analysis result of .rb file in DIR]:directory:_directories'
  '--exclude-untyped[exclude (comment out) all entries including untyped]'
  '--max-second[limit the maximum time of analysis (in seconds)]:seconds:'
  '--max-iteration[limit the maximum instruction count of analysis]:count:'
  '--type-depth-limit[limit the maximum depth of nested types]:depth:'
  '--union-width-limit[limit the maximum count of class instances in one union type]:width:'
  '--debug[display analysis log (for debugging purpose)]'
  '--port[specify a port number to listen for requests on]:port:'
  '--stdio[use stdio for LSP transport]'
  '*:filename:_files'
)

_arguments -s -S $arguments
