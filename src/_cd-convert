#compdef cd-convert
# Documentation: https://man.archlinux.org/search?q=cd-convert
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  '--help-all[show all help options]'
  '--help-gtk[show GTK+ Options]'
  '--device[use this device for profiling]'
  '--sensor[use this sensor for profiling]'
  '--xid[make the window modal to this XID]'
  '--display[X display to use]'
  '*:filename:_files'
)

_arguments -s -S $arguments
