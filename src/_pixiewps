#compdef pixiewps

local -a arguments

arguments=(
  {-e,--pke}'[specify enrollee public key]'
  {-r,--pkr}'[specify registrar public key]'
  {-s,--e-hash1}'[specify first enrollee hash]'
  {-z,--e-hash2}'[specify second enrollee hash]'
  {-a,--authkey}'[specify authentication key]'
  {-n,--e-nonce}'[specify enrollee nonce]'
  {-m,--r-nonce}'[specify registrar nonce]'
  {-b,--e-bssid}'[specify enrollee BSSID]'
  {-S,--dh-small}'[)]'
  '--mode[... N\]]'
  '--start[/\]yyyy]'
  '--end[\[mm/\]yyyy]'
  {-7,--m7-enc}'[specify M7 encrypted data]'
  {-5,--m5-enc}'[specify M5 encrypted data]'
  '*:filename:_files'
)

_arguments -s -S $arguments
