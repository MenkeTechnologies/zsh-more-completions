#compdef saquery

local -a arguments

arguments=(
    '-p[get PathRecord info.]'
    '-N[get NodeRecord info.]'
    {-D,--list}'[get NodeDescriptions of CAs only.]'
    '-S[get ServiceRecord info.]'
    '-I[get InformInfoRecord (subscription) info.]'
    '-L[return the Lids of the name specified.]'
    '-l[return the unique Lid of the name specified.]'
    '-G[return the Guids of the name specified.]'
    '-O[return the name for the Lid specified.]'
    '-U[return the name for the Guid specified.]'
    '-c[get the SA class port info]'
    '-s[return the PortInfoRecords with isSM or isSMdisabled capability mask bit on.]'
    '-g[get multicast group info.]'
    '-m[get multicast member info.]'
    '-x[get LinkRecord info.]'
    '--src-to-dst[get a PathRecord for <src:dst> by node name or LID]:src:dst'
    '--sgid-to-dgid[get a PathRecord for sgid to dgid in IPv6 format]:sgid:dgid'
    '--smkey[use SM_Key value for the query. Will be used only with "trusted" queries.]:val'
    {-K,--show_keys}'[show security keys (mkey, smkey, etc. ) associated with the request.]'
    '--pkey[is specified then saquery will prompt for a value.]'
    '--qkey[then saquery will prompt for a value.]'
    '-d[raise the IB debugging level. May be used several times (-ddd or -d -d -d).]'
    '-e[show send and receive errors (timeouts and others).]'
    {-v,--verbose}'[increase the application verbosity level.]'
    {--outstanding_smps,-o}'[specify the number of outstanding SMPs to issue]:val'
    '--slid'
    '--dlid'
    '--mlid'
    '--sgid'
    '--dgid'
    '--gid'
    '--mgid'
    '--reversible'
    '--numb_path'
    '--qos_class'
    '--sl'
    '--mtu'
    '--rate'
    '--pkt_lifetime'
    '--tclass'
    '--flow_label'
    '--hop_limit'
    '--scope:(MCMemberRecord)'
    '--join_state'
    '--proxy_join'
    '--service_id:(PathRecord)'
    {-C,--Ca}'[specify CA name]'
    {-P,--Port}'[Local port Selection.]'
    {-h,--help}'[show help message]'
    {-V,--version}'[Configuration flags.]'
    {-t,--timeout}'[specify timeout value]'
    '--node-name-map[This file maps GUIDs to more user friendly names. See]'
    {--config,-z}'[Default: /etc/infiniband-diags/ibdiag. conf COMMON]'
    '*:filename:_files'
)
_arguments -s -S $arguments
