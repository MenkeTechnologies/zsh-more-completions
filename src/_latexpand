#compdef latexpand

local -a arguments

arguments=(
  '--verbose[show whats going on]'
  '--keep-comments[dont strip comments (comments are lines starting with %)]'
  '--empty-comments[empty comments (i.e. % at end of lines) for clarity]'
  '--keep-includes[dont expand \input and \include directives]'
  '--expand-usepackage[expand \usepackage{...} directives if the corresponding .sty file is found]'
  '--expand-bbl[expand the bibliography by inlining FILE]:file:_files'
  '--help[this help message]'
  {--output,-o}'[generate output in <file>]'
  '--explain[generate explanatory comments in output]'
  '--show-graphics[show included graphics]'
  '--graphics_extensions[set list of graphics extensions]:extensions:'
  '--fatal[die in case a file cant be found.]'
  '--makeatletter[insert a \makeatletter in the preamble]'
  '--in-encoding[file encoding used by input files]:encoding:'
  '--out-encoding[file encoding used by output files]:encoding:'
  '*:filename:_files'
)

_arguments -s -S $arguments
