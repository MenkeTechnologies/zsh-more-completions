#compdef ccmake3

local -a arguments

arguments=(
  '-C[pre-load a script to populate the cache]:script:_files'
  '-D[= Create a cmake cache entry.]:value:'
  '-U[remove matching entries from CMake cache]:pattern:'
  '-G[specify a build system generator]:generator:'
  '-T[specify toolset name if supported by generator]:toolset:'
  '-A[specify platform name if supported by generator]:platform:'
  '-Wdev[enable developer warnings.]'
  '-Wno-dev[suppress developer warnings.]'
  '-Werror[make developer warnings errors.]'
  '-Wno-error[make developer warnings not errors.]'
  '-Wdeprecated[enable deprecation warnings.]'
  '-Wno-deprecated[suppress deprecation warnings.]'
  '-Werror[make deprecated macro and function warnings]'
  '-Wno-error[make deprecated macro and function warnings]'
  {--help,-help,-usage,-h,-H}'[print usage information and exit]'
  {--version,-version}'[print version number and exit]'
  '--help-full[print all help manuals and exit.]'
  '--help-manual[print one help manual and exit]:manual:'
  '--help-manual-list[list help manuals available and exit.]'
  '--help-command[print help for one command and exit]:command:'
  '--help-command-list[list commands with help available and exit.]'
  '--help-commands[print cmake-commands manual and exit.]'
  '--help-module[print help for one module and exit]:module:'
  '--help-module-list[list modules with help available and exit.]'
  '--help-modules[print cmake-modules manual and exit.]'
  '--help-policy[print help for one policy and exit]:policy:'
  '--help-policy-list[list policies with help available and exit.]'
  '--help-policies[print cmake-policies manual and exit.]'
  '--help-property[print help for one property and exit]:property:'
  '--help-property-list[list properties with help available and exit]'
  '--help-properties[print cmake-properties manual and exit.]'
  '--help-variable[print help for one variable and exit]:variable:'
  '--help-variable-list[list variables with help available and exit.]'
  '--help-variables[print cmake-variables manual and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
