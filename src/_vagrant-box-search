#compdef vagrant-box-search

local -a arguments

arguments=(
    '--provider=[filter by provider]:provider:(virtualbox vmware_desktop hyperv docker libvirt parallels)'
    '-p[filter by provider]:provider:(virtualbox vmware_desktop hyperv docker libvirt parallels)'
    '--sort-by=[sort results]:(downloads created updated)' \
    '-s[sort results]:(downloads created updated)'
    '--order=[sort order]:(asc desc)'
    '-o[sort order]:(asc desc)'
    '--limit=[number of results]:count'
    '-l[number of results]:count'
    '--page=[results page]:page number'
    '--json[output as JSON]'
    '--short[short output]'
    '--help[show help]'
    '-h[show help]'
    '*:search query:'
)

_arguments -s -S $arguments
