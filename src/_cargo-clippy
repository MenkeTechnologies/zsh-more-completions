#compdef cargo-clippy

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[print this message]'
  {-V,--version}'[print version info and exit]'
  {-W,--warn}'[set lint warnings]:lint:'
  {-A,--allow}'[set lint allowed]:lint:'
  {-D,--deny}'[set lint denied]:lint:'
  {-F,--forbid}'[set lint forbidden]:lint:'
  '*:filename:_files'
)

_arguments -s -S $arguments
