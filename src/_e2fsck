#compdef e2fsck fsck.ext2 fsck.ext3 fsck.ext4

# Completion for e2fsck (ext2/3/4 filesystem checker)

_e2fsck() {
  local arguments

  arguments=(
    '(-p -n -y)-p[automatic repair (no questions)]'
    '(-p -n -y)-a[automatic repair (no questions, alias for -p)]'
    '(-p -n -y -a)-n[open the filesystem read-only and assume no to all questions]'
    '(-p -n -y -a)-y[assume yes to all questions]'
    '-c[check for bad blocks and add them to the bad block list]'
    '-C+[write completion info to specified file descriptor]:file descriptor'
    '-d[print debugging output]'
    '-D[optimize directories in filesystem]'
    '-E+[set extended options]:extended options (comma-separated):_values -s , "extended option" \
      "ea_ver[set extended attribute version]" \
      "journal_only[only replay the journal]" \
      "fragcheck[report fragmentation]" \
      "discard[discard unused blocks after check]" \
      "nodiscard[do not discard unused blocks]" \
      "readahead_kb[set readahead buffer size in KB]" \
      "bmap2extent[convert block-mapped files to extents]" \
      "fixes_only[only fix damaged metadata]" \
      "unshare_blocks[unshare blocks shared by multiple files]" \
      "clone[set cloning method (dup or zero)]"'
    '-f[force checking even if filesystem is marked clean]'
    '-F[flush filesystem device buffer caches before beginning]'
    '-j+[set location of the external journal]:journal device:_files'
    '-k[used with -c, preserves existing bad blocks list]'
    '-l+[add to bad blocks list from file]:bad blocks file:_files'
    '-L+[set bad blocks list from file (clears existing list)]:bad blocks file:_files'
    '-b+[use alternative superblock]:superblock number'
    '-B+[force blocksize when looking for superblock]:block size (bytes)'
    '-t[print timing stats]'
    '-tt[print additional timing stats]'
    '-v[be verbose]'
    '-V[print version information and exit]'
    '-z+[create an undo file]:undo file:_files'
    '*:device:_files -g "*(-%b)"'
  )

  _arguments -s -S $arguments
}

_e2fsck "$@"
