#compdef NetworkManager

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  {-V,--version}'[print NetworkManager version and exit]'
  {-n,--no-daemon}'[dont become a daemon]'
  '--log-level[log level: one of \[TRACE,DEBUG,INFO,WARN,ERR,OFF,KEEP\]]'
  '--log-domains[log domains separated by comma]:domains:'
  '--g-fatal-warnings[make all warnings fatal]'
  {-p,--pid-file}'[specify the location of a PID file]:file:_files'
  '--run-from-build-dir[run from build directory]'
  '--print-config[print NetworkManager configuration and exit]'
  '--config[config file location]:file:_files'
  '--config-dir[config directory location]:dir:_directories'
  '--system-config-dir[system config directory location]:dir:_directories'
  '--intern-config[internal config file location]:file:_files'
  '--state-file[state file location]:file:_files'
  '--plugins[list of plugins separated by comma]:plugins:'
  '--configure-and-quit[quit after initial configuration]'
  {-d,--debug}'[dont become a daemon, and log to stderr]'
  '*:filename:_files'
)

_arguments -s -S $arguments
