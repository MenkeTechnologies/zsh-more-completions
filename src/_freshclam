#compdef freshclam

local -a arguments

arguments=(
    {--help,-h}'[Show this help]'
    {--version,-V}'[Print version number and exit]'
    {--verbose,-v}'[Be verbose]'
    '--debug[Enable debug messages]'
    '--quiet[Only output error messages]'
    '--no-warnings[Dont print and log warnings]'
    '--stdout[Write to stdout instead of stderr]'
    '--show-progress[Show download progress percentage]'
    '--config-file[Read configuration from FILE]:file:_files'
    {--log,-l}'[Log into FILE]:file:_files'
    {--daemon,-d}'[Run in daemon mode]'
    {--pid,-p}'[Save daemons pid in FILE]:file:_files'
    {--user,-u}'[Run as USER]:user:_users'
    '--no-dns[Force old non-DNS verification method]'
    {--checks,-c}'[Number of checks per day, 1 <= n <= 50]:number:'
    '--datadir[Download new databases into DIRECTORY]:directory:_files -/'
    '--daemon-notify[Send RELOAD command to clamd]:config:_files'
    {--local-address,-a}'[Bind to IP for HTTP downloads]:address:'
    '--on-update-execute[Execute COMMAND after successful update]:command:'
    '--on-error-execute[Execute COMMAND if errors occurred]:command:'
    '--on-outdated-execute[Execute COMMAND when software is outdated]:command:'
    '--list-mirrors[Print mirrors from mirrors.dat]'
    '--update-db[Only update database DBNAME]:dbname:'
    '*:filename:_files'
)

_arguments -s -S $arguments
