#compdef etcdutl
# Documentation: https://man.archlinux.org/search?q=etcdutl
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[help for etcdutl]'
  {-w,--write-out}'[set the output format (fields, json, protobuf, simple, table) (default "simple")]'
  '*:filename:_files'
)

_arguments -s -S $arguments
