#compdef groupadd

# Completion for groupadd (shadow-utils)
# https://github.com/shadow-maint/shadow

_groupadd() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a arguments

    arguments=(
        {-f,--force}'[exit successfully if the group already exists, and cancel -g if GID is already used]'
        {-g,--gid}'[use GID for the new group]:GID:'
        '(- * :)'{-h,--help}'[display help message and exit]'
        {-K,--key}'[override /etc/login.defs defaults (KEY=VALUE)]:key=value:'
        {-o,--non-unique}'[allow creating groups with duplicate (non-unique) GID]'
        {-p,--password}'[use this encrypted password for the new group]:encrypted password:'
        {-P,--prefix}'[directory prefix for etc files]:prefix directory:_directories'
        {-r,--system}'[create a system group]'
        {-R,--root}'[directory to chroot into]:chroot directory:_directories'
        {-U,--users}'[list of user members of this group]:users:_sequence _users'
        '1:group name:'
    )

    _arguments -s -S $arguments && ret=0
    return ret
}

_groupadd "$@"
