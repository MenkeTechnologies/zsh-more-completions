#compdef alien

local -a arguments

arguments=(
  {-d,--to-deb}'[generate a Debian deb package (default)]'
  '--patch[specify patch file to use instead of automatically looking for one]:patch file:_files'
  '--nopatch[do not use patches]'
  '--anypatch[use even old version of patches]'
  {-s,--single}'[like --generate, but do not create .orig directory]'
  '--fixperms[munge/fix permissions and owners]'
  '--test[test generated packages with lintian]'
  {-r,--to-rpm}'[generate a Red Hat rpm package]'
  '--to-slp[generate a Stampede slp package]'
  {-l,--to-lsb}'[generate a LSB package]'
  {-t,--to-tgz}'[generate a Slackware tgz package]'
  '--description[specify package description]:description: '
  '--version[specify package version]:version: '
  {-p,--to-pkg}'[generate a Solaris pkg package]'
  {-i,--install}'[install generated package]'
  {-g,--generate}'[generate build tree, but do not build package]'
  {-c,--scripts}'[include scripts in package]'
  '--target[set architecture of the generated package]:architecture: '
  {-v,--verbose}'[display each command alien runs]'
  '--veryverbose[be verbose, and also display output of run commands]'
  {-k,--keep-version}'[do not change version of generated package]'
  '--bump[increment package version by this number]:number: '
  '(- * :)'{-h,--help}'[display this help message]'
  {-V,--version}'[display aliens version number]'
  '*:filename:_files'
)

_arguments -s -S $arguments
