#compdef mkfs

# Zsh completion for mkfs (util-linux)

_mkfs() {
  local -a fs_types
  fs_types=(
    'bfs' 'btrfs' 'cramfs' 'exfat' 'ext2' 'ext3' 'ext4'
    'f2fs' 'fat' 'hfsplus' 'jfs' 'minix'
    'msdos' 'nilfs2' 'ntfs' 'reiserfs'
    'udf' 'vfat' 'xfs'
  )

  _arguments -s \
    '(- *)'{-h,--help}'[display help text and exit]' \
    '(- *)--version[display version information and exit]' \
    {-t,--type}'=[filesystem type (default: ext2)]:filesystem type:'"(${fs_types[*]})" \
    '*'{-V,--verbose}'[explain what is being done; specify more than once for a dry-run]' \
    '1:device:_files' \
    '*:: :->fs-options'

  if [[ "$state" == fs-options ]]; then
    _message 'filesystem-specific options'
  fi
}

_mkfs "$@"
