#compdef ecryptfs-migrate-home
# Documentation: https://man.archlinux.org/search?q=ecryptfs-migrate-home
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-u,--user}'[migrate USERs home directory to an encrypted home directory]'
  '*:filename:_files'
)

_arguments -s -S $arguments
