#compdef readline-editor

local -a arguments

arguments=(
  '-a[prompt\] --always-readline\[=password prompt\]]'
  {-A,--ansi-colour-aware}'[enable ANSI colour-aware line editing]'
  '-b[break-chars=<chars>]:chars:'
  {-c,--complete-filenames}'[complete filenames]'
  '-C[command-name=<name|N>]:name|N:'
  '-D[history-no-dupes=<0|1|2>]:0|1|2:'
  '-e[extra-char-after-completion=<char|>]:char|:'
  '-f[file=<completion list>]:completion list:'
  '-g[forget-matching=<regexp>]:regexp:'
  '(- * :)'{-h,--help}'[display help information]'
  '-H[history-filename=<file>]:file:'
  {-i,--case-insensitive}'[case-insensitive completion]'
  {-I,--pass-sigint-as-sigterm}'[pass SIGINT to command as SIGTERM]'
  '-l[logfile=<file>]:file:'
  '-m[substitute\] --multi-line\[=newline substitute\]]'
  '-M[multi-line-ext=<.ext>]:.ext:'
  {-n,--no-warnings}'[suppress warnings]'
  {-N,--no-children}'[do not rlwrap command children]'
  {-o,--one-shot}'[send EOF to command after first line of input]'
  '-O[only-cook=<regexp>]:regexp:'
  {-p,--prompt-colour}'[colour the prompt]'
  '-P[pre-given=<input>]:input:'
  '-q[quote-characters=<chars>]:chars:'
  {-r,--remember}'[remember input between sessions]'
  {-R,--renice}'[renice rlwrap to a lower priority]'
  '-s[histsize=<N> (negative: readonly)]:N:'
  '-S[substitute-prompt=<prompt>]:prompt:'
  '-t[set-term-name=<name>]:name:'
  {-U,--mirror-arguments}'[mirror arguments]'
  {-v,--version}'[display version information]'
  '-w[wait-before-prompt=<N> (msec, <0 : patient mode)]:N:'
  {-W,--polling}'[use polling to detect slave terminal changes]'
  '-z[filter=<filter command> (rlwrap -z listing writes a list of installed filters)]:filter command:'
  '*:filename:_files'
)

_arguments -s -S $arguments
