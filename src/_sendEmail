#compdef sendEmail

local -a arguments

arguments=(
  '-f[from (sender) email address]'
  '-t[\[ADDR ...\] to email address(es)]'
  '-u[message subject]'
  '-m[message body]'
  '-s[smtp mail relay, default is localhost:25]'
  '-S[use local sendmail utility (default: /usr/bin/sendmail) instead of network MTA]'
  '-a[FILE \[FILE ...\] file attachment(s)]'
  '-cc[ADDRESS \[ADDR ...\] cc email address(es)]'
  '-bcc[\[ADDR ...\] bcc email address(es)]'
  '-xu[USERNAME username for SMTP authentication]'
  '-xp[PASSWORD password for SMTP authentication]'
  '-b[local host bind address]'
  '-l[log to the specified file]'
  '-v[verbosity, use multiple times for greater effect]'
  '-q[be quiet (i.e. no STDOUT output)]'
  '-o[advanced options (message-content-type, message-file, message-header, etc.)]:option'
  '--help[display help information]:topic:(overview addressing message networking output misc)'
  '*:filename:_files'
)

_arguments -s -S $arguments
