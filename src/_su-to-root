#compdef su-to-root
# Documentation: https://man.archlinux.org/search?q=su-to-root
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-c[command to execute as a string (mandatory)]'
  '-p[user to switch to (default: root)]'
  '-X[command is a X11 program]'
  '*:filename:_files'
)

_arguments -s -S $arguments
