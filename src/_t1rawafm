#compdef t1rawafm
# Documentation: https://man.archlinux.org/search?q=t1rawafm
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-o,--output}'[write output to FILE instead of standard output.]:file:_files'
  '(- * :)'{-h,--help}'[print this message and exit.]'
  '--version[print version number and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
