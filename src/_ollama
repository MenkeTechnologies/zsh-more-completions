#compdef ollama

# Zsh completion for ollama - AI model runner

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'serve:start ollama server'
  'create:create a model from a Modelfile'
  'show:show information for a model'
  'run:run a model'
  'pull:pull a model from a registry'
  'push:push a model to a registry'
  'list:list models'
  'ps:list running models'
  'cp:copy a model'
  'rm:remove a model'
  'help:help about any command'
)

_arguments -s -S \
  '1:command:->command' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'ollama command' commands && ret=0
    ;;
  (args)
    local -a models
    case $words[1] in
      (run|show|push|rm|cp)
        models=("${(@f)$(ollama list 2>/dev/null | tail -n +2 | awk '{print $1}')}")
        case $words[1] in
          (run)
            _arguments -s -S \
              '--model[model name]' \
              '--format[response format (e.g. json)]' \
              '--verbose[show timings]' \
              '--nowordwrap[disable word wrap]' \
              '--insecure[use an insecure registry]' \
              '--keepalive[duration to keep model loaded]:duration' \
              '1:model:compadd -a models' && ret=0
            ;;
          (show)
            _arguments -s -S \
              '--license[show license]' \
              '--modelfile[show Modelfile]' \
              '--parameters[show parameters]' \
              '--system[show system message]' \
              '--template[show template]' \
              '--verbose[show detailed information]' \
              '1:model:compadd -a models' && ret=0
            ;;
          (rm)
            _arguments '1:model:compadd -a models' && ret=0
            ;;
          (cp)
            _arguments '1:source model:compadd -a models' '2:destination model' && ret=0
            ;;
          (push)
            _arguments -s -S \
              '--insecure[use an insecure registry]' \
              '1:model:compadd -a models' && ret=0
            ;;
        esac
        ;;
      (pull)
        _arguments -s -S \
          '--insecure[use an insecure registry]' \
          '1:model name' && ret=0
        ;;
      (create)
        _arguments -s -S \
          '(-f --file)'{-f,--file}'[name of the Modelfile]:file:_files' \
          '--quantize[quantize model to a given type]:type:(q4_0 q4_1 q5_0 q5_1 q8_0)' \
          '1:model name' && ret=0
        ;;
      (serve)
        _arguments -s -S && ret=0
        ;;
      (help)
        _describe -t commands 'ollama command' commands && ret=0
        ;;
    esac
    ;;
esac

return ret
