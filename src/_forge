#compdef forge

# Zsh completion for forge (Foundry - Ethereum development)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'bind:generate Rust bindings for smart contracts'
  'build:build the project (alias: b, compile)'
  'cache:manage the cache'
  'clean:remove build artifacts'
  'completions:generate shell completions'
  'config:display the current config'
  'coverage:generate coverage report'
  'create:deploy a smart contract'
  'debug:debugs a single smart contract as a script'
  'doc:generate documentation for Solidity source files'
  'flatten:flatten a source file'
  'fmt:format Solidity source files'
  'geiger:detect usage of unsafe cheat codes'
  'init:create a new Forge project'
  'inspect:get specialized information about a contract'
  'install:install one or more dependencies'
  'remappings:get the automatically inferred remappings'
  'remove:remove one or more dependencies'
  'script:run a smart contract as a script'
  'selectors:manage function selectors'
  'snapshot:create a snapshot of each test gas usage'
  'test:run the project tests (alias: t)'
  'tree:display the project dependency tree'
  'update:update one or more dependencies'
  'verify-check:check verification status on a block explorer'
  'verify-contract:verify a contract on a block explorer'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'forge command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (build|b|compile)
        _arguments \
          '--force[force rebuild]' \
          '--optimize[enable optimization]' \
          '--optimizer-runs[optimizer runs]:runs:' \
          '--via-ir[use the Yul IR compilation pipeline]' \
          '--sizes[print contract sizes]' \
          '--out[output directory]:dir:_files -/' \
          '--root[project root]:dir:_files -/' && ret=0
        ;;
      (test|t)
        _arguments \
          '(-m --match-test)'{-m,--match-test}'[only run tests matching regex]:pattern:' \
          '--match-contract[only run tests in contracts matching regex]:pattern:' \
          '--match-path[only run tests in files matching glob]:glob:' \
          '--no-match-test[skip tests matching regex]:pattern:' \
          '--no-match-contract[skip contracts matching regex]:pattern:' \
          '--no-match-path[skip files matching glob]:glob:' \
          '(-v --verbosity)'{-v,--verbosity}'[verbosity level]:level:(1 2 3 4 5)' \
          '--gas-report[print gas report]' \
          '--fuzz-runs[number of fuzz runs]:runs:' \
          '--fuzz-seed[fuzz seed]:seed:' \
          '-f[fork URL]:url:' \
          '--fork-url[fork URL]:url:' \
          '--fork-block-number[fork at block number]:block:' \
          '--debug[run a single test in debug mode]' && ret=0
        ;;
      (create)
        _arguments \
          '--constructor-args[constructor arguments]:args:' \
          '--rpc-url[RPC URL]:url:' \
          '--private-key[private key]:key:' \
          '--verify[verify on block explorer]' \
          '--etherscan-api-key[API key for verification]:key:' \
          '--chain[chain name or ID]:chain:' \
          '*:contract:_files -g "*.sol"' && ret=0
        ;;
      (init)
        _arguments \
          '--template[template to use]:template:' \
          '--force[force init even in non-empty directory]' \
          '--no-git[do not create a git repository]' \
          '--no-commit[do not create initial commit]' \
          '1:directory:_files -/' && ret=0
        ;;
      (fmt)
        _arguments \
          '--root[project root]:dir:_files -/' \
          '--check[check formatting without changing files]' \
          '--raw[format raw Solidity from stdin]' \
          '*:file:_files -g "*.sol"' && ret=0
        ;;
      (snapshot)
        _arguments \
          '--diff[diff against snapshot]:file:_files' \
          '--check[compare against snapshot]:file:_files' \
          '--snap[output file]:file:_files' \
          '--asc[sort by gas ascending]' \
          '--desc[sort by gas descending]' && ret=0
        ;;
    esac
    ;;
esac

return ret
