#compdef pipewire
# Documentation: https://man.archlinux.org/search?q=pipewire
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help]'
  {-v,--version}'[show version]'
  {-n,--name}'[daemon name (Default pipewire-0)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
