#compdef luametatex
# Documentation: https://man.archlinux.org/search?q=luametatex
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--credits[display credits and exit]'
  '--fmt[load the format file FORMAT]'
  '--help[display help and exit]'
  '--ini[be iniluametatex, for dumping formats]'
  '--jobname[set the job name to STRING]'
  '--lua[load and execute a lua initialization script]'
  '--version[display version and exit]'
  '--luaonly[run a lua file, then exit]'
  '--permitloadlib[permit loading of external libraries (coming)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
