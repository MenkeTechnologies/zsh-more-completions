#compdef kismet_cap_kismetdb
# Documentation: https://man.archlinux.org/search?q=kismet_cap_kismetdb
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--connect[connect to remote Kismet server on \[host\]]'
  '--host[listen for incoming remote connections on specified host]:host:'
  '--source[specify a source to send to the remote server]:source:'
  '--disable-retry[do not attempt to reconnect to a remote server]'
  '--fixed-gps[lon,alt\] Set a fixed location for this capture (remote only)]'
  '--gps-name[set an alternate GPS name for this source]'
  '--daemonize[background the capture tool and enter daemon mode]'
  '--list[list supported devices detected]'
  '*:filename:_files'
)

_arguments -s -S $arguments
