#compdef capsh

local -a arguments

arguments=(
  '--help[this message (or try man capsh)]'
  '--print[display capability relevant state]'
  '--decode[decode a hex string to a list of caps]:hex:'
  '--supports[exit 1 if capability xxx unsupported]:capability:'
  '--drop[remove capabilities from bset]:capabilities:'
  '--caps[set caps as per cap_from_text()]:caps:'
  '--inh[set inheritable set]:capabilities:'
  '--secbits[write a new value for securebits]:value:'
  '--keep[set keep-capability bit]:n:(0 1)'
  '--uid[set uid]:uid:'
  '--gid[set gid]:gid:'
  '--groups[set the supplemental groups]:groups:'
  '--user[set uid,gid and groups to that of user]:user:_users'
  '--chroot[chroot(2) to this path]:path:_files -/'
  '--killit[send signal(n) to child]:signal:'
  '--forkfor[fork and make child sleep for n sec]:seconds:'
  '*:filename:_files'
)

_arguments -s -S $arguments
