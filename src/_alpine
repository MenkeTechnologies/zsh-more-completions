#compdef alpine

local -a arguments

arguments=(
    '-attach[go directly into composer with given file]:file:_files'
    '-attachlist[go directly into composer with given files]:file:_files'
    '-attach_and_delete[go directly into composer, strstrdelete file after]:file:_files'
    '-bail[exit if pinerc file does not already exist]'
    '-f[folder - give folder name to open]:folder name:'
    '-c[context - which context to apply to -f arg]:context number:'
    '-F[file - give file name to open and page through]:file:_files'
    '-h[help - give this list of options]'
    '-k[keys - force use of function keys]'
    '-z[suspend - allow use of ^Z suspension]'
    '-r[restricted - can only send mail to oneself]'
    '-sort[sort - specify sort order of folder]:sort order:'
    '-i[index - go directly to index, bypassing main menu]'
    '-I[initial keystrokes to be executed]:keystrokes:'
    '-n[entry in index to begin on]:entry number:'
    '-o[read-only - open first folder read-only]'
    '-conf[print out fresh global configuration]'
    '-pinerc[put fresh pinerc configuration in file]:file:_files'
    '-p[use alternate .pinerc file]:pinerc file:_files'
    '-P[use alternate pine.conf file]:pine.conf file:_files'
    '-smimedir[directory where smime personal certificates are saved]:directory:_directories'
    '-passfile[set the password file to something other than default]:file:_files'
    '-pwdcertdir[set the directory to store a personal certificate]:directory:_directories'
    '-nowrite_password_cache[read from password cache but never write to it]'
    '-x[use configuration exceptions in config]:config file:_files'
    '-v[version - show version information]'
    '-version[version - show version information]'
    '-supported[list supported options]'
    '-url[open the given URL]:url:'
    '-copy_pinerc[copy local pinerc to remote]'
    '-copy_abook[copy local addressbook to remote]'
    '-convert_sigs[convert signatures to literal signatures]'
    '*:filename:_files'
)

_arguments -s -S $arguments
