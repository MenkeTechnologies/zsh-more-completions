#compdef ogonkify
# Documentation: https://man.archlinux.org/search?q=ogonkify
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-a,-c,-h,-t,-A,-C,-H,-T,-AT,-CT,-ATH,-CTH,-E}'[select output encoding]'
  {-N,-M,-mp,-SO,-AX,-F,-RS}'[-- file ...]'
  '*:filename:_files'
)

_arguments -s -S $arguments
