#compdef samba_downgrade_db
# Documentation: https://man.archlinux.org/search?q=samba_downgrade_db
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-H,--URL}'[LDB URL for database]'
  {-V,--version}'[display version number]'
  '*:filename:_files'
)

_arguments -s -S $arguments
