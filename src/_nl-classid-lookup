#compdef nl-classid-lookup
# Documentation: https://man.archlinux.org/search?q=nl-classid-lookup
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help text.]'
  {-v,--version}'[show versioning information.]'
  {-r,--reverse}'[do a reverse lookup, i.e. classid to name.]'
  '--raw[print the raw classid, not pretty printed.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
