#compdef mate-mouse-properties
# Documentation: https://man.archlinux.org/search?q=mate-mouse-properties
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  '--help-all[show all help options]'
  '--help-gtk[show GTK+ Options]'
  {-p,--show-page}'[specify the name of the page to show (general)]'
  '--display[X display to use]'
  '*:filename:_files'
)

_arguments -s -S $arguments
