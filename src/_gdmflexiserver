#compdef gdmflexiserver
# Documentation: https://man.archlinux.org/search?q=gdmflexiserver
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  {-c,--command}'[only the VERSION command is supported]'
  {-n,--xnest}'[ignored - retained for compatibility]'
  {-l,--no-lock}'[ignored - retained for compatibility]'
  {-d,--debug}'[debugging output]'
  {-a,--authenticate}'[ignored - retained for compatibility]'
  {-s,--startnew}'[ignored - retained for compatibility]'
  '--monte-carlo-pi[compute pi using Monte Carlo method]'
  '--version[version of this application]'
  '*:filename:_files'
)

_arguments -s -S $arguments
