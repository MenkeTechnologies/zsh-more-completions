#compdef infisical

# Zsh completion for infisical - secret management platform CLI

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'init:initialize Infisical for a project'
  'login:login to Infisical'
  'run:run a command with secrets injected'
  'secrets:manage secrets'
  'export:export secrets to a file'
  'vault:manage vault'
  'user:manage user'
  'service-token:manage service tokens'
  'reset:reset Infisical credentials'
  'scan:scan for secret leaks'
  'agent:run the Infisical agent'
  'gateway:run the Infisical gateway'
  'dynamic-secrets:manage dynamic secrets'
  'ssh:manage SSH certificates'
  'completion:generate shell completions'
)

local -a global_args=(
  '(-h --help)'{-h,--help}'[show help]'
  '--domain[set the Infisical domain]:domain:'
  '--log-level[set log level]:level:(info debug warn error fatal)'
  '--telemetry[enable telemetry]'
  '(-v --version)'{-v,--version}'[show version]'
)

_arguments -s -S \
  ${global_args[@]} \
  '1:command:->command' \
  '*:option:->options' && ret=0

case $state in
  (command)
    _describe -t commands 'infisical command' subcommands && ret=0
    ;;
  (options)
    case ${line[1]} in
      (run)
        _arguments -s -S \
          ${global_args[@]} \
          '--env[set environment]:environment:' \
          '--projectId[set project ID]:project ID:' \
          '--path[set secrets path]:path:' \
          '--tags[filter secrets by tags]:tags:' \
          '(-c --command)'{-c,--command}'[command to run]:command:' \
          '--token[set authentication token]:token:' \
          '--expand[expand secret references]' \
          '--include-imports[include imported secrets]' \
          '--recursive[fetch secrets recursively]' \
          '--secret-overriding[enable secret overriding]' \
          '--' \
          '*:command:_command_names' && ret=0
        ;;
      (secrets)
        _arguments -s -S \
          ${global_args[@]} \
          '--env[set environment]:environment:' \
          '--projectId[set project ID]:project ID:' \
          '--path[set secrets path]:path:' \
          '--token[set authentication token]:token:' \
          '--expand[expand secret references]' \
          '--include-imports[include imported secrets]' \
          '--recursive[fetch secrets recursively]' \
          '1:sub-command:((
            get\:"get a secret"
            set\:"set a secret"
            delete\:"delete a secret"
            generate-example-env\:"generate example .env file"
          ))' && ret=0
        ;;
      (export)
        _arguments -s -S \
          ${global_args[@]} \
          '--env[set environment]:environment:' \
          '--projectId[set project ID]:project ID:' \
          '--path[set secrets path]:path:' \
          '--token[set authentication token]:token:' \
          '--format[output format]:format:(json csv yaml dotenv dotenv-export)' \
          '--expand[expand secret references]' \
          '--include-imports[include imported secrets]' \
          '--recursive[fetch secrets recursively]' && ret=0
        ;;
      (scan)
        _arguments -s -S \
          ${global_args[@]} \
          '1:sub-command:((
            git-changes\:"scan git changes for secrets"
            install\:"install git pre-commit hook"
          ))' && ret=0
        ;;
      (dynamic-secrets)
        _arguments -s -S \
          ${global_args[@]} \
          '1:sub-command:((
            create\:"create a dynamic secret"
            delete\:"delete a dynamic secret"
            lease\:"manage leases"
            list\:"list dynamic secrets"
          ))' && ret=0
        ;;
      (ssh)
        _arguments -s -S \
          ${global_args[@]} \
          '1:sub-command:((
            sign-key\:"sign an SSH public key"
            issue-credentials\:"issue SSH credentials"
            add-host\:"add an SSH host"
            connect\:"connect to an SSH host"
          ))' && ret=0
        ;;
      (completion)
        _arguments -s -S \
          ${global_args[@]} \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      (*)
        _arguments -s -S ${global_args[@]} && ret=0
        ;;
    esac
    ;;
esac

return ret
