#compdef grilo-test-ui-0.3
# Documentation: https://man.archlinux.org/search?q=grilo-test-ui-0.3
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  '--help-all[show all help options]'
  '--help-grl[show Grilo Options]'
  '*:filename:_files'
)

_arguments -s -S $arguments
