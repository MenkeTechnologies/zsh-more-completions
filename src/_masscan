#compdef masscan
# Documentation: https://man.archlinux.org/search?q=masscan
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--adapter-ip[specify source IP address]:ip: '
  '--adapter-mac[specify source MAC address]:mac: '
  '--router-mac[specify router MAC address for gateway]:mac: '
  '*:filename:_files'
)

_arguments -s -S $arguments
