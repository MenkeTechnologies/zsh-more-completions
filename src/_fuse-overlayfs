#compdef fuse-overlayfs
# Documentation: https://man.archlinux.org/search?q=fuse-overlayfs
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '--debug[Enable debugging mode, can be very noisy.]'
    '-o[mount options (lowerdir, upperdir, workdir)]:options:'
    '*:filename:_files'
)
_arguments -s -S $arguments
