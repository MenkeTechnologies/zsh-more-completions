#compdef rad_counter
# Documentation: https://man.archlinux.org/search?q=rad_counter
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--file[counter DB filename.]'
  '--user[information for specific user.]'
  '--match[information for matching users.]'
  '--reset[reset counter to <number>.]'
  '--help[show this help screen.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
