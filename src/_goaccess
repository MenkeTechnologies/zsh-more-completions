#compdef goaccess

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-f --log-file)'{-f,--log-file}'[input log file]:file:_files' \
  '(-l --log-format)'{-l,--log-format}'[log format string]:format' \
  '(-p --config-file)'{-p,--config-file}'[config file]:file:_files' \
  '--date-format[date format]:format' \
  '--time-format[time format]:format' \
  '--datetime-format[combined date/time format]:format' \
  '(-a --agent-list)'{-a,--agent-list}'[enable user agent list]' \
  '(-c --config-dialog)'{-c,--config-dialog}'[prompt log/date configuration]' \
  '(-d --with-output-resolver)'{-d,--with-output-resolver}'[enable IP resolver on HTML output]' \
  '(-e --exclude-ip)'{-e,--exclude-ip}'[exclude IP from stats]:ip' \
  '(-g --std-geoip)'{-g,--std-geoip}'[standard GeoIP database]' \
  '(-H --http-protocol)'{-H,--http-protocol}'[set/unset HTTP request protocol]:yes/no:(yes no)' \
  '(-M --http-method)'{-M,--http-method}'[set/unset HTTP request method]:yes/no:(yes no)' \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '(-q --no-query-string)'{-q,--no-query-string}'[ignore query string]' \
  '(-r --no-term-resolver)'{-r,--no-term-resolver}'[disable IP resolver on terminal]' \
  '--no-color[disable colored output]' \
  '--no-column-names[disable column name header]' \
  '--no-csv-summary[disable CSV summary]' \
  '--no-global-config[do not load global config]' \
  '--no-progress[disable progress metrics]' \
  '--no-tab-scroll[disable tab scroll]' \
  '(-s --storage)'{-s,--storage}'[storage backend]' \
  '--geoip-database[GeoIP database file]:file:_files -g "*.mmdb"' \
  '--db-path[database path]:dir:_directories' \
  '--persist[persist data to disk]' \
  '--restore[restore data from disk]' \
  '--real-time-html[enable real-time HTML output]' \
  '--ws-url[WebSocket URL]:url' \
  '--port[server port]:port' \
  '--addr[server address]:address' \
  '--origin[WebSocket origin]:url' \
  '--ssl-cert[SSL certificate file]:file:_files -g "*.{pem,crt}"' \
  '--ssl-key[SSL key file]:file:_files -g "*.{pem,key}"' \
  '--fifo-in[FIFO reader path]:file:_files' \
  '--fifo-out[FIFO writer path]:file:_files' \
  '--json-pretty-print[pretty print JSON output]' \
  '--max-items[max items per panel]:count' \
  '--enable-panel[enable specified panel]:panel' \
  '--disable-panel[disable specified panel]:panel' \
  '--sort-panel[sort panel]:panel,field,order' \
  '--static-file[add static file extension]:ext' \
  '--ignore-crawlers[ignore crawlers]' \
  '--crawlers-only[only show crawlers]' \
  '--ignore-panel[ignore specified panel]:panel' \
  '--ignore-referer[ignore specified referer]:referer' \
  '--ignore-status[ignore specified status code]:code' \
  '--keep-last[keep last N days]:days' \
  '--4xx-to-unique-count[add 4xx to unique visitors count]' \
  '--anonymize-ip[anonymize IP addresses]' \
  '--all-static-files[include all static files]' \
  '--double-decode[decode double-encoded values]' \
  '--hour-spec[hour specification]:spec:(min10 hr)' \
  '*:log file:_files' && ret=0

return ret
