#compdef doppler

_doppler() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a global_opts
    global_opts=(
        '--token[Set the token to use for API requests]:token:'
        '--api-host[Set the API host]:host:'
        '--dashboard-host[Set the dashboard host]:host:'
        '--no-check-version[Disable version checking]'
        '--no-verify-tls[Do not verify TLS certificates]'
        '--no-timeout[Disable HTTP timeout]'
        '--timeout[Set HTTP timeout in seconds]:seconds:'
        '--no-read-env[Do not read config from environment]'
        '--enable-dns-resolver[Enable DNS resolver]'
        '--dns-resolver-address[Set DNS resolver address]:address:'
        '--no-interactive[Disable interactive prompts]'
        '--no-analytics[Disable anonymous analytics]'
        '--json[Output in JSON format]'
        '--scope[Scope of the config]:scope:'
        '--silent[Disable all output]'
        {-p,--project}'[Project to use]:project:'
        {-c,--config}'[Config to use]:config:'
        {-e,--environment}'[Environment to use]:environment:'
    )

    _arguments -C \
        $global_opts \
        '(-): :->command' \
        '(-)*:: :->option-or-argument' && ret=0

    case $state in
        (command)
            local -a commands
            commands=(
                'login:Authenticate to Doppler'
                'logout:Log out of Doppler'
                'setup:Setup the Doppler CLI for a project'
                'run:Run a command with secrets injected'
                'secrets:Manage secrets'
                'projects:Manage projects'
                'environments:Manage environments'
                'configs:Manage configs'
                'activity-logs:View activity logs'
                'enclave:Enclave commands'
                'changelog:View the changelog'
                'update:Update the Doppler CLI'
                'analytics:Manage anonymous analytics'
                'completion:Generate shell completion scripts'
                'configure:Manage CLI configuration'
                'me:Get info about the current user'
                'groups:Manage groups'
                'open:Open the Doppler dashboard'
            )
            _describe -t commands 'doppler command' commands && ret=0
            ;;
        (option-or-argument)
            curcontext=${curcontext%:*:*}:doppler-$words[1]:
            case $words[1] in
                (run)
                    _arguments -s -S \
                        $global_opts \
                        '--command[Command to run]:command:' \
                        '--mount[Mount secrets to a file]:file:_files' \
                        '--mount-format[Format for mounted secrets]:format:(json env yaml dotnet-json)' \
                        '--mount-template[Template for mounted secrets]:template:_files' \
                        '--mount-max-reads[Max number of reads for mounted file]:reads:' \
                        '--no-read-env[Do not read config from environment]' \
                        '--forward-signals[Forward signals to the child process]' \
                        '--no-exit-on-missing-secret[Do not exit on missing secrets]' \
                        '--passphrase[Passphrase for encrypted secrets]:passphrase:' \
                        '--no-interactive[Disable interactive prompts]' \
                        '--name-transformer[Transform secret names]:transformer:(camel upper-camel lower-camel tf-var dotnet-env lower-snake)' \
                        '*:command arguments:' && ret=0
                    ;;
                (secrets)
                    _arguments -C \
                        $global_opts \
                        '--plain[Display secret values in plain text]' \
                        '--copy[Copy the secret value to clipboard]' \
                        '--no-file[Do not read from file]' \
                        '--only-names[Only show secret names]' \
                        '--raw[Print raw secret values]' \
                        '--visibility[Show secret visibility]' \
                        '(-): :->secrets_command' \
                        '(-)*:: :->secrets_args' && ret=0
                    case $state in
                        (secrets_command)
                            local -a secrets_commands
                            secrets_commands=(
                                'get:Get a secret value'
                                'set:Set a secret value'
                                'delete:Delete a secret'
                                'download:Download secrets'
                                'upload:Upload secrets'
                            )
                            _describe -t commands 'secrets command' secrets_commands && ret=0
                            ;;
                        (secrets_args)
                            case $words[1] in
                                (get|set|delete|download|upload)
                                    _arguments -s -S \
                                        $global_opts \
                                        '--plain[Display secret values in plain text]' \
                                        '--copy[Copy the secret value to clipboard]' \
                                        '--no-file[Do not read from file]' \
                                        '--only-names[Only show secret names]' \
                                        '--raw[Print raw secret values]' \
                                        '--visibility[Show secret visibility]' \
                                        '*:secret name:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                (projects)
                    _arguments -C \
                        $global_opts \
                        '(-): :->projects_command' \
                        '(-)*:: :->projects_args' && ret=0
                    case $state in
                        (projects_command)
                            local -a projects_commands
                            projects_commands=(
                                'create:Create a project'
                                'delete:Delete a project'
                                'get:Get a project'
                                'list:List projects'
                                'update:Update a project'
                            )
                            _describe -t commands 'projects command' projects_commands && ret=0
                            ;;
                        (projects_args)
                            _arguments -s -S $global_opts '*:project:' && ret=0
                            ;;
                    esac
                    ;;
                (environments)
                    _arguments -C \
                        $global_opts \
                        '(-): :->environments_command' \
                        '(-)*:: :->environments_args' && ret=0
                    case $state in
                        (environments_command)
                            local -a environments_commands
                            environments_commands=(
                                'create:Create an environment'
                                'delete:Delete an environment'
                                'get:Get an environment'
                                'list:List environments'
                                'rename:Rename an environment'
                            )
                            _describe -t commands 'environments command' environments_commands && ret=0
                            ;;
                        (environments_args)
                            _arguments -s -S $global_opts '*:environment:' && ret=0
                            ;;
                    esac
                    ;;
                (configs)
                    _arguments -C \
                        $global_opts \
                        '(-): :->configs_command' \
                        '(-)*:: :->configs_args' && ret=0
                    case $state in
                        (configs_command)
                            local -a configs_commands
                            configs_commands=(
                                'create:Create a config'
                                'clone:Clone a config'
                                'delete:Delete a config'
                                'get:Get a config'
                                'list:List configs'
                                'lock:Lock a config'
                                'unlock:Unlock a config'
                                'update:Update a config'
                                'logs:View config logs'
                            )
                            _describe -t commands 'configs command' configs_commands && ret=0
                            ;;
                        (configs_args)
                            _arguments -s -S $global_opts '*:config:' && ret=0
                            ;;
                    esac
                    ;;
                (configure)
                    _arguments -C \
                        $global_opts \
                        '(-): :->configure_command' \
                        '(-)*:: :->configure_args' && ret=0
                    case $state in
                        (configure_command)
                            local -a configure_commands
                            configure_commands=(
                                'get:Get a configuration value'
                                'set:Set a configuration value'
                                'reset:Reset configuration to defaults'
                                'flags:Manage feature flags'
                            )
                            _describe -t commands 'configure command' configure_commands && ret=0
                            ;;
                        (configure_args)
                            _arguments -s -S $global_opts '*:key:' && ret=0
                            ;;
                    esac
                    ;;
                (login|logout|setup|me|open|update|changelog|analytics|completion|activity-logs|enclave|groups)
                    _arguments -s -S $global_opts && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_doppler "$@"
