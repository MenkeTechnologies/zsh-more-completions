#compdef kafka-share-groups

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--command-config[Property file with configs to pass to Admin Client]:file:_files'
    '--list[List all share groups]'
    '--describe[Describe share group]'
    '--delete[Delete share group]'
    '--group[Share group ID]:group:'
    '--all-groups[Apply to all share groups]'
    '--members[Describe members of the group]'
    '--offsets[Describe the group offsets]'
    '--state[Filter by group state]:state:'
    '--verbose[Provide additional information if available]'
    '--topic[Topic name]:topic:'
)

_arguments -s -S $arguments
