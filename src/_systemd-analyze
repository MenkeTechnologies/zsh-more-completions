#compdef systemd-analyze

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help text]'
  '--version[show package version]'
  '--no-pager[do not pipe output into a pager]'
  '--system[operate on system systemd instance]'
  '--user[operate on user systemd instance]'
  '--global[operate on system-wide user configuration]'
  {-H,--host=}'[operate on remote host]:hostname:_hosts'
  {-M,--machine=}'[operate on local container]:machine name'
  {-q,--quiet}'[suppress hints and non-essential output]'
  '--order[show only After=/Before= dependencies in dot output]'
  '--require[show only Requires=/Wants= dependencies in dot output]'
  '--from-pattern=[match left-hand nodes in dependency graph]:pattern'
  '--to-pattern=[match right-hand nodes in dependency graph]:pattern'
  '--fuzz=[also print services which finished TIMESPAN earlier]:timespan'
  '--man=[check for existence of man pages (yes/no)]:bool:(yes no)'
  '--generators[invoke unit generators]'
  '--instance=[set fallback instance name for template units]:instance name'
  '--recursive-errors=[control verification error handling]:mode:(yes no one)'
  '--root=[operate on files under specified root path]:root directory:_directories'
  '--image=[operate on files inside disk image]:image file:_files'
  '--image-policy=[enforce image policy for --image]:policy string'
  '--offline=[perform offline security review]:bool:(yes no)'
  '--profile=[use portable profile for security assessment]:profile:_files'
  '--threshold=[set custom exposure level threshold]:number'
  '--security-policy=[define custom security requirements]:json file:_files'
  '--json=[output in JSON format]:mode:(off pretty short)'
  '--iterations=[number of iterations for calendar command]:number'
  '--base-time=[reference timestamp for calendar iterations]:timestamp'
  '--unit=[evaluate conditions in specified unit file]:unit'
  '--table[output raw time data as table with plot]'
  '--no-legend[omit legends and hints from output]'
  '--tldr[show only interesting configuration file parts]'
  '--scale-svg=[stretch x-axis in SVG plot]:factor'
  '--detailed[show activation timestamp details in SVG]'
  '--drm-device=[specify DRM device sysfs path for chid]:path:_files'
  '--debugger=[specify debugger for unit-gdb]:debugger:_command_names'
  {-A,--debugger-arguments=}'[pass arguments to debugger]:arguments'
  '1:verb:(time blame critical-chain dump plot dot unit-files unit-gdb
           unit-paths unit-shell exit-status capability condition
           syscall-filter filesystems calendar timestamp timespan
           cat-config compare-versions verify security inspect-elf
           malloc fdstore image-policy has-tpm2 identify-tpm2
           pcrs nvpcrs srk architectures smbios11 chid
           transient-settings)'
  '*:filename:_files'
)

_arguments -s -S $arguments
