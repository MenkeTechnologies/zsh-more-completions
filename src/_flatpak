#compdef flatpak

# Zsh completion for Flatpak

_flatpak() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a global_opts
    global_opts=(
        '(- *)'{-h,--help}'[Show help options]'
        {-v,--verbose}'[Show debug information during command processing]'
        '--ostree-verbose[Show OSTree debug information during command processing]'
        '--version[Print version information and exit]'
        '--default-arch[Print default arch and exit]'
        '--supported-arches[Print supported arches in priority order and exit]'
        '--gl-drivers[Print active GL drivers and exit]'
        '--installations[Print paths of system installations and exit]'
        '--print-updated-env[Print the set of environment variables needed to use flatpaks]'
        '--print-system-only[Only include the system installation with --print-updated-env]'
    )

    _arguments -C \
        $global_opts \
        '(-): :->command' \
        '(-)*:: :->option-or-argument' && ret=0

    case $state in
        (command)
            local -a manage_commands find_commands run_commands remote_commands
            local -a build_commands document_commands permission_commands
            manage_commands=(
                'install:Install an application or runtime from a remote or bundle'
                'update:Update an installed application or runtime'
                'uninstall:Uninstall an installed application or runtime'
                'mask:Mask out updates and automatic installation'
                'pin:Pin runtimes to prevent automatic removal'
                'list:List installed applications and/or runtimes'
                'info:Show information for an installed application or runtime'
                'history:Show history'
                'config:Manage configuration'
                'repair:Repair a flatpak installation'
                'create-usb:Copy apps and/or runtimes onto removable media'
            )
            find_commands=(
                'search:Search for applications and runtimes'
            )
            run_commands=(
                'run:Run an application'
                'kill:Stop a running application'
                'override:Override application requirements'
                'make-current:Specify default version to run'
                'enter:Enter the namespace of a running application'
                'ps:Enumerate running instances'
            )
            remote_commands=(
                'remotes:List all configured remote repositories'
                'remote-add:Add a new remote repository'
                'remote-modify:Modify properties of a configured remote repository'
                'remote-delete:Delete a configured remote repository'
                'remote-ls:List contents of a configured remote repository'
                'remote-info:Show information about a remote application or runtime'
            )
            build_commands=(
                'build-init:Initialize a directory for building'
                'build:Run a build command inside a build directory'
                'build-finish:Finish a build directory for export'
                'build-export:Export a build directory to a repository'
                'build-bundle:Create a bundle file from a ref in a local repository'
                'build-import-bundle:Import a bundle file'
                'build-sign:Sign an application or runtime'
                'build-update-repo:Update repository summary'
                'build-commit-from:Create new commit based on existing ref'
                'repo:Show information about a repo'
            )
            document_commands=(
                'document-export:Grant an application access to a specific file'
                'document-unexport:Revoke access to a specific file'
                'document-info:Show information about a specific file'
                'documents:List exported files'
            )
            permission_commands=(
                'permissions:List permissions'
                'permission-show:Show app permissions'
                'permission-reset:Reset app permissions'
                'permission-set:Set app permissions'
                'permission-remove:Remove item from permission store'
            )
            _describe -t manage-commands 'manage command' manage_commands && ret=0
            _describe -t find-commands 'find command' find_commands && ret=0
            _describe -t run-commands 'run command' run_commands && ret=0
            _describe -t remote-commands 'remote command' remote_commands && ret=0
            _describe -t build-commands 'build command' build_commands && ret=0
            _describe -t document-commands 'document command' document_commands && ret=0
            _describe -t permission-commands 'permission command' permission_commands && ret=0
            ;;
        (option-or-argument)
            curcontext=${curcontext%:*:*}:flatpak-$words[1]:
            local -a common_install_opts
            common_install_opts=(
                '--user[Work on the user installation]'
                '--system[Work on the default system-wide installation]'
                '--installation[Work on a specific system-wide installation]:name'
                '--arch[Arch to use]:arch'
            )
            case $words[1] in
                (install)
                    _arguments -s \
                        $common_install_opts \
                        '--no-pull[Do not pull, only install from local cache]' \
                        '--no-deploy[Only pull, do not deploy]' \
                        '--no-related[Do not download related extensions]' \
                        '--no-deps[Do not verify/install runtime dependencies]' \
                        '--or-update[Update if already installed]' \
                        '--reinstall[Uninstall first if already installed]' \
                        '--app[Only look for an app with the given name]' \
                        '--runtime[Only look for a runtime with the given name]' \
                        '--bundle[Treat LOCATION as a bundle file]' \
                        '--from[Treat LOCATION as an application description file]' \
                        '--gpg-import[Import gpg keys from FILE]:file:_files' \
                        '--no-auto-pin[Do not automatically pin runtimes when installing]' \
                        '--no-static-deltas[Do not use static deltas]' \
                        '--assumeyes[Automatically answer yes to all questions]' \
                        '--noninteractive[Produce minimal output and do not ask questions]' \
                        '--sideload-repo[Add a local repository as a sideload source]:path:_directories' \
                        '--include-sdk[Also install the SDK used to build the application]' \
                        '--include-debug[Also install debug info]' \
                        '-y[Automatically answer yes to all questions]' \
                        '*:remote and ref:' \
                        && ret=0
                    ;;
                (update)
                    _arguments -s \
                        $common_install_opts \
                        '--no-pull[Do not pull, only deploy updates from local cache]' \
                        '--no-deploy[Only pull, do not deploy]' \
                        '--no-related[Do not download related extensions]' \
                        '--no-deps[Do not verify/install runtime dependencies]' \
                        '--app[Only update applications]' \
                        '--runtime[Only update runtimes]' \
                        '--appstream[Update appstream for remote]' \
                        '--commit[Update to this specific commit]:commit' \
                        '--force-remove[Remove old files even if running]' \
                        '--no-static-deltas[Do not use static deltas]' \
                        '--assumeyes[Automatically answer yes to all questions]' \
                        '--noninteractive[Produce minimal output and do not ask questions]' \
                        '--sideload-repo[Add a local repository as a sideload source]:path:_directories' \
                        '-y[Automatically answer yes to all questions]' \
                        '*:ref:' \
                        && ret=0
                    ;;
                (uninstall)
                    _arguments -s \
                        $common_install_opts \
                        '--keep-ref[Keep ref in local repository]' \
                        '--no-related[Do not uninstall related extensions]' \
                        '--force-remove[Remove files even if running]' \
                        '--runtime[Only look for a runtime with the given name]' \
                        '--app[Only look for an app with the given name]' \
                        '--all[Uninstall all]' \
                        '--unused[Uninstall unused]' \
                        '--delete-data[Delete app data]' \
                        '--assumeyes[Automatically answer yes to all questions]' \
                        '--noninteractive[Produce minimal output and do not ask questions]' \
                        '-y[Automatically answer yes to all questions]' \
                        '*:ref:' \
                        && ret=0
                    ;;
                (list)
                    _arguments -s \
                        $common_install_opts \
                        '--app[Only show applications]' \
                        '--runtime[Only show runtimes]' \
                        '--all[Also show ref that match the current arch]' \
                        {-d,--show-details}'[Show extra information]' \
                        '--columns[Specify which info to show]:columns' \
                        '--app-runtime[List apps using this runtime]:runtime' \
                        && ret=0
                    ;;
                (info)
                    _arguments -s \
                        $common_install_opts \
                        '--app[Only look for an app with the given name]' \
                        '--runtime[Only look for a runtime with the given name]' \
                        {-r,--show-ref}'[Show ref]' \
                        {-c,--show-commit}'[Show commit]' \
                        {-o,--show-origin}'[Show origin]' \
                        {-s,--show-size}'[Show size]' \
                        {-m,--show-metadata}'[Show metadata]' \
                        {-M,--show-permissions}'[Show permissions]' \
                        {-e,--show-extensions}'[Show extensions]' \
                        {-l,--show-location}'[Show location]' \
                        '--file-access[Show file access]' \
                        '*:name:' \
                        && ret=0
                    ;;
                (run)
                    _arguments -s \
                        '--user[Work on the user installation]' \
                        '--system[Work on the system installation]' \
                        '--installation[Work on a specific installation]:name' \
                        '--arch[Arch to use]:arch' \
                        '--command[Command to run]:command' \
                        '--branch[Branch to run]:branch' \
                        '--cwd[Working directory inside sandbox]:dir' \
                        '--commit[Run a specific commit]:commit' \
                        '--runtime[Specify runtime to use]:runtime' \
                        '--runtime-version[Specify runtime version to use]:version' \
                        {-d,--devel}'[Use development runtime]' \
                        '--log-session-bus[Log session bus calls]' \
                        '--log-system-bus[Log system bus calls]' \
                        '--log-a11y-bus[Log a11y bus calls]' \
                        '--no-a11y-bus[Do not proxy a11y bus]' \
                        '--no-session-bus[Do not proxy session bus]' \
                        '--no-documents-portal[Do not start the document portal]' \
                        '--file-forwarding[Enable file forwarding]' \
                        '--die-with-parent[Kill child process when parent dies]' \
                        '--sandbox[Run fully sandboxed]' \
                        '--talk-name[Allow app to talk to the well known name]:name' \
                        '--own-name[Allow app to own the well known name]:name' \
                        {-p,--parent-pid}'[Run in parent pid namespace]:pid' \
                        '--parent-expose-pids[Make process ids visible in parent namespace]' \
                        '--parent-share-pids[Share pid namespace with parent]' \
                        '--device[Expose device to app]:device:(dri kvm shm all)' \
                        '--nosocket[Deny sandbox access to socket]:socket:(x11 wayland fallback-x11 pulseaudio session-bus system-bus ssh-auth pcsc cups gpg-agent inherit-wayland-socket)' \
                        '--socket[Grant sandbox access to socket]:socket:(x11 wayland fallback-x11 pulseaudio session-bus system-bus ssh-auth pcsc cups gpg-agent inherit-wayland-socket)' \
                        '--nodevice[Deny sandbox access to device]:device:(dri kvm shm all)' \
                        '--filesystem[Grant sandbox access to filesystem]:filesystem' \
                        '--nofilesystem[Deny sandbox access to filesystem]:filesystem' \
                        '--share[Grant sandbox access to resource]:resource:(network ipc)' \
                        '--unshare[Deny sandbox access to resource]:resource:(network ipc)' \
                        '--env[Set environment variable]:KEY=VALUE' \
                        '--env-fd[Read environment variables from FD]:fd' \
                        '--unset-env[Unset environment variable]:VAR' \
                        '--allow[Allow feature]:feature:(devel multiarch bluetooth canbus per-app-dev-shm)' \
                        '--disallow[Disallow feature]:feature:(devel multiarch bluetooth canbus per-app-dev-shm)' \
                        '*:app:' \
                        && ret=0
                    ;;
                (search)
                    _arguments -s \
                        '--user[Work on the user installation]' \
                        '--system[Work on the system installation]' \
                        '--installation[Work on a specific installation]:name' \
                        '--arch[Arch to search for]:arch' \
                        '--columns[Specify which info to show]:columns' \
                        '*:search terms:' \
                        && ret=0
                    ;;
                (remote-add)
                    _arguments -s \
                        '--user[Work on the user installation]' \
                        '--system[Work on the system installation]' \
                        '--installation[Work on a specific installation]:name' \
                        '--if-not-exists[Do nothing if the remote already exists]' \
                        '--no-gpg-verify[Disable GPG verification]' \
                        '--no-enumerate[Mark the remote as not enumerated]' \
                        '--no-use-for-deps[Mark the remote as not to be used for automatic dep resolving]' \
                        '--prio[Set priority (default 1)]:priority' \
                        '--title[A nice name to use for this remote]:title' \
                        '--comment[A one-line comment for this remote]:comment' \
                        '--description[A full-paragraph description for this remote]:description' \
                        '--homepage[URL for a website for this remote]:url' \
                        '--icon[URL for an icon for this remote]:url' \
                        '--default-branch[Set the default branch]:branch' \
                        '--collection-id[Collection ID]:id' \
                        '--gpg-import[Import gpg keys from FILE]:file:_files' \
                        '--filter[Add a local filter file]:file:_files' \
                        '--from[Use the URI as a flatpakref/flatpakrepo file]' \
                        '--subset[Limit the remote to a named subset]:subset' \
                        '*:name and url:' \
                        && ret=0
                    ;;
                (remote-modify)
                    _arguments -s \
                        '--user[Work on the user installation]' \
                        '--system[Work on the system installation]' \
                        '--installation[Work on a specific installation]:name' \
                        '--no-gpg-verify[Disable GPG verification]' \
                        '--gpg-verify[Enable GPG verification]' \
                        '--no-enumerate[Mark the remote as not enumerated]' \
                        '--enumerate[Mark the remote as enumerated]' \
                        '--no-use-for-deps[Mark the remote as not to be used for deps]' \
                        '--use-for-deps[Mark the remote as to be used for deps]' \
                        '--no-filter[Remove filter from remote]' \
                        '--prio[Set priority]:priority' \
                        '--title[A nice name to use for this remote]:title' \
                        '--comment[A one-line comment for this remote]:comment' \
                        '--description[A full-paragraph description for this remote]:description' \
                        '--homepage[URL for a website for this remote]:url' \
                        '--icon[URL for an icon for this remote]:url' \
                        '--default-branch[Set the default branch]:branch' \
                        '--collection-id[Collection ID]:id' \
                        '--gpg-import[Import gpg keys from FILE]:file:_files' \
                        '--url[Set URL]:url' \
                        '--filter[Set local filter file]:file:_files' \
                        '--subset[Limit the remote to a named subset]:subset' \
                        '*:remote name:' \
                        && ret=0
                    ;;
                (remote-delete)
                    _arguments -s \
                        '--user[Work on the user installation]' \
                        '--system[Work on the system installation]' \
                        '--installation[Work on a specific installation]:name' \
                        '--force[Remove remote even if its in use]' \
                        '*:remote name:' \
                        && ret=0
                    ;;
                (remote-ls)
                    _arguments -s \
                        '--user[Work on the user installation]' \
                        '--system[Work on the system installation]' \
                        '--installation[Work on a specific installation]:name' \
                        '--arch[Arch to show]:arch' \
                        '--app[Only show applications]' \
                        '--runtime[Only show runtimes]' \
                        '--all[Show all refs]' \
                        '--updates[Show only updates]' \
                        '--cached[Use locally cached data]' \
                        {-d,--show-details}'[Show extra information]' \
                        '--columns[Specify which info to show]:columns' \
                        '*:remote name:' \
                        && ret=0
                    ;;
                (remotes)
                    _arguments -s \
                        '--user[Work on the user installation]' \
                        '--system[Work on the system installation]' \
                        '--installation[Work on a specific installation]:name' \
                        {-d,--show-details}'[Show extra information]' \
                        '--show-disabled[Show disabled remotes]' \
                        '--columns[Specify which info to show]:columns' \
                        && ret=0
                    ;;
                (override)
                    _arguments -s \
                        '--user[Work on the user installation]' \
                        '--system[Work on the system installation]' \
                        '--installation[Work on a specific installation]:name' \
                        '--reset[Remove overrides]' \
                        '--show[Show overrides]' \
                        '--socket[Grant sandbox access to socket]:socket:(x11 wayland fallback-x11 pulseaudio session-bus system-bus ssh-auth pcsc cups gpg-agent)' \
                        '--nosocket[Deny sandbox access to socket]:socket:(x11 wayland fallback-x11 pulseaudio session-bus system-bus ssh-auth pcsc cups gpg-agent)' \
                        '--device[Grant sandbox access to device]:device:(dri kvm shm all)' \
                        '--nodevice[Deny sandbox access to device]:device:(dri kvm shm all)' \
                        '--filesystem[Grant sandbox access to filesystem]:filesystem' \
                        '--nofilesystem[Deny sandbox access to filesystem]:filesystem' \
                        '--share[Grant sandbox access to resource]:resource:(network ipc)' \
                        '--unshare[Deny sandbox access to resource]:resource:(network ipc)' \
                        '--env[Set environment variable]:KEY=VALUE' \
                        '--unset-env[Unset environment variable]:VAR' \
                        '--allow[Allow feature]:feature:(devel multiarch bluetooth canbus per-app-dev-shm)' \
                        '--disallow[Disallow feature]:feature:(devel multiarch bluetooth canbus per-app-dev-shm)' \
                        '--talk-name[Allow app to talk to the well known name]:name' \
                        '--own-name[Allow app to own the well known name]:name' \
                        '*:app:' \
                        && ret=0
                    ;;
                (enter)
                    _arguments -s \
                        '--command[Command to run]:command' \
                        '*:instance:' \
                        && ret=0
                    ;;
                (config)
                    _arguments -s \
                        '--user[Work on the user installation]' \
                        '--system[Work on the system installation]' \
                        '--installation[Work on a specific installation]:name' \
                        '--set[Set key to value]:KEY=VALUE' \
                        '--get[Get value of key]:key' \
                        '--unset[Unset key]:key' \
                        '--list[List all keys and values]' \
                        && ret=0
                    ;;
                (repair)
                    _arguments -s \
                        '--user[Work on the user installation]' \
                        '--system[Work on the system installation]' \
                        '--installation[Work on a specific installation]:name' \
                        '--dry-run[Do not make changes]' \
                        '--reinstall-all[Reinstall all refs]' \
                        && ret=0
                    ;;
                (history)
                    _arguments -s \
                        '--user[Work on the user installation]' \
                        '--system[Work on the system installation]' \
                        '--installation[Work on a specific installation]:name' \
                        '--since[Only show changes after this time]:date' \
                        '--until[Only show changes before this time]:date' \
                        '--reverse[Show newest first]' \
                        '--columns[Specify which info to show]:columns' \
                        && ret=0
                    ;;
                (*)
                    _arguments -s \
                        '*:filename:_files' \
                        && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_flatpak "$@"
