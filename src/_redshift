#compdef redshift

local -a arguments

arguments=(
  '-h[display this help message]'
  '-v[verbose output]'
  '-V[show program version]'
  '-b[screen brightness to apply (between 0.1 and 1.0)]:brightness: '
  '-c[load settings from specified configuration file]:file:_files'
  '-g[additional gamma correction to apply]:gamma: '
  '-l[your current location or location provider]:location: '
  '-m[method to use to set color temperature]:method: '
  '-o[one shot mode (do not continuously adjust color temperature)]'
  '-O[one shot manual mode (set color temperature)]:temperature: '
  '-p[print mode (only print parameters and exit)]'
  '-P[reset existing gamma ramps before applying new color effect]'
  '-x[reset mode (remove adjustment from screen)]'
  '-r[disable fading between color temperatures]'
  '-t[color temperature to set at daytime/night]:temperature: '
  '*:filename:_files'
)

_arguments -s -S $arguments
