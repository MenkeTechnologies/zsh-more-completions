#compdef cpio

# Completion for cpio (bsdcpio / GNU cpio compatible)
# Reference: man cpio, cpio --help

_arguments -s -S \
  '(-o -p)-i[input mode: extract files from an archive]' \
  '(-i -p)-o[output mode: create a new archive]' \
  '(-i -o)-p[pass-through mode: copy files to a directory]' \
  '(-o -p)--extract[input mode: extract files from an archive]' \
  '(-i -p)--create[output mode: create a new archive]' \
  '(-i -o)--pass-through[pass-through mode: copy files to a directory]' \
  {-0,--null}'[read filenames separated by NUL characters instead of newlines]' \
  {-6,--pwb}'[use the PWB binary format (6th Edition UNIX)]' \
  {-7,--binary}'[use the newer non-PWB binary format when writing]' \
  '-A[append to an existing archive]' \
  '-a[reset access times on files after reading them]' \
  '-B[block output to records of 5120 bytes]' \
  '-C[block output to records of specified size]:block size (bytes):' \
  '-c[use the old POSIX portable character format (odc)]' \
  {-d,--make-directories}'[create leading directories where needed]' \
  '-E[read list of filename patterns from file]:pattern file:_files' \
  {-F,--file}'[read archive from or write archive to file]:archive file:_files' \
  '-f[ignore files that match pattern]:pattern:' \
  {-H,--format}'[produce output archive in specified format]:format:(cpio newc odc pax ustar pwb bin)' \
  {-h,--help}'[print usage information]' \
  '-I[read archive from file]:archive file:_files' \
  '--insecure[disable security checks during extraction or copying]' \
  {-J,--xz}'[compress the archive with xz]' \
  '-j[compress the archive with bzip2 (synonym for -y)]' \
  '-L[follow symbolic links, archive/copy the target]' \
  {-l,--link}'[create hard links instead of copying (pass-through mode)]' \
  '--lrzip[compress the resulting archive with lrzip]' \
  '--lz4[compress the archive with lz4]' \
  '--lzma[compress the archive with lzma]' \
  '--lzop[compress the resulting archive with lzop]' \
  '--zstd[compress the archive with zstd]' \
  {-m,--preserve-modification-time}'[preserve file modification times]' \
  {-n,--numeric-uid-gid}'[display numeric uid and gid in listings]' \
  '--no-preserve-owner[do not attempt to restore file ownership]' \
  '--preserve-owner[restore file ownership (default for root)]' \
  '-O[write archive to file]:archive file:_files' \
  '--passphrase[passphrase for encrypted archive]:passphrase:' \
  '--quiet[suppress unnecessary messages]' \
  {-R,--owner}'[set the owner and/or group on files in the output]:[user][\:]group:' \
  '-r[rename files interactively]' \
  {-t,--list}'[list the contents of the archive]' \
  {-u,--unconditional}'[unconditionally overwrite existing files]' \
  {-V,--dot}'[print a dot to stderr for each file processed]' \
  {-v,--verbose}'[print the name of each file to stderr as it is processed]' \
  '--version[print the program version information and exit]' \
  '-y[compress the archive with bzip2]' \
  '-Z[compress the archive with compress]' \
  '-z[compress the archive with gzip]' \
  '*:filename:_files'
