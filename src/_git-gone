#compdef git-gone

# Zsh completion for git gone (list/remove gone branches)

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'list:list gone branches'
  'prune:remove gone branches'
)

_arguments -s -S \
  '(-f --fetch)'{-f,--fetch}'[fetch before listing]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:subcommand:->subcommand' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'git-gone subcommand' subcommands && ret=0
    ;;
esac

return ret
