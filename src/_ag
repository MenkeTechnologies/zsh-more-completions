#compdef ag

# Zsh completion for ag (The Silver Searcher)

_ag_file_types() {
  local -a types
  types=(${${(f)"$(ag --list-file-types 2>/dev/null)"}:#  *})
  types=(${types//[[:space:]]/})
  types=(${types:#})
  _describe -t file-types 'file type' types
}

_arguments -s -S \
  '(- *)'{-h,--help}'[display help information]' \
  '(- *)--version[display version information]' \
  '(- *)--list-file-types[list supported file types]' \
  '--ackmate[print results in AckMate-parseable format]' \
  {-A,--after}'[print NUM lines after match]:lines (default 2):' \
  {-B,--before}'[print NUM lines before match]:lines (default 2):' \
  '--break[print newlines between matches in different files]' \
  '--nobreak[do not print newlines between matches in different files]' \
  {-c,--count}'[only print the number of matches in each file]' \
  '--color[print color codes in results]' \
  '--nocolor[do not print color codes in results]' \
  '--color-line-number[color code for line numbers]:ANSI color code (default 1;33):' \
  '--color-match[color code for result matches]:ANSI color code (default 30;43):' \
  '--color-path[color code for path names]:ANSI color code (default 1;32):' \
  '--column[print column numbers in results]' \
  '--filename[print file names before matches]' \
  '--nofilename[do not print file names before matches]' \
  {-H,--heading}'[print file names before each file'\''s matches]' \
  '--noheading[do not print file names before each file'\''s matches]' \
  {-C,--context}'[print NUM lines before and after matches]:lines (default 2):' \
  '--group[same as --break --heading]' \
  '--nogroup[same as --nobreak --noheading]' \
  {-g,--filename-pattern}'[print filenames matching PATTERN]:pattern:' \
  {-l,--files-with-matches}'[only print filenames that contain matches]' \
  {-L,--files-without-matches}'[only print filenames that don'\''t contain matches]' \
  '--print-all-files[print headings for all files searched, even those without matches]' \
  '--numbers[print line numbers]' \
  '--nonumbers[do not print line numbers]' \
  {-o,--only-matching}'[print only the matching part of lines]' \
  '--print-long-lines[print matches on very long lines (default >2k chars)]' \
  '--passthrough[when searching a stream, print all lines even if they don'\''t match]' \
  '--silent[suppress all log messages, including errors]' \
  '--stats[print stats (files scanned, time taken, etc.)]' \
  '--stats-only[print stats and nothing else]' \
  '--vimgrep[print results in vim :vimgrep-compatible format]' \
  {-0,--null,--print0}'[separate filenames with null (for xargs -0)]' \
  {-a,--all-types}'[search all files (excludes hidden files and patterns from ignore files)]' \
  {-D,--debug}'[enable ridiculous debugging output]' \
  '--depth[search up to NUM directories deep]:depth (default 25):' \
  {-f,--follow}'[follow symlinks]' \
  {-F,--fixed-strings}'[alias for --literal for compatibility with grep]' \
  {-G,--file-search-regex}'[limit search to filenames matching PATTERN]:pattern:' \
  '--hidden[search hidden files (obeys .*ignore files)]' \
  {-i,--ignore-case}'[match case insensitively]' \
  '*--ignore[ignore files/directories matching PATTERN]:pattern:' \
  '*--ignore-dir[alias for --ignore for compatibility with ack]:directory name:_directories' \
  {-m,--max-count}'[skip the rest of a file after NUM matches]:max matches (default 10000):' \
  '--one-device[don'\''t follow links to other devices]' \
  {-p,--path-to-ignore}'[use .ignore file at STRING]:ignore file:_files' \
  {-Q,--literal}'[don'\''t parse PATTERN as a regular expression]' \
  {-s,--case-sensitive}'[match case sensitively]' \
  {-S,--smart-case}'[match case insensitively unless PATTERN contains uppercase characters]' \
  '--search-binary[search binary files for matches]' \
  {-t,--all-text}'[search all text files (excludes hidden files)]' \
  {-u,--unrestricted}'[search all files (ignore .ignore, .gitignore, etc.; includes binary and hidden)]' \
  {-U,--skip-vcs-ignores}'[ignore VCS ignore files (.gitignore, .hgignore; still obey .ignore)]' \
  {-v,--invert-match}'[invert match]' \
  {-w,--word-regexp}'[only match whole words]' \
  {-W,--width}'[truncate match lines after NUM characters]:max width:' \
  {-z,--search-zip}'[search contents of compressed (e.g., gzip) files]' \
  '1:search pattern:' \
  '*:path:_files'
