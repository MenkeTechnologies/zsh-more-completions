#compdef mysql_config_editor
# Documentation: https://man.archlinux.org/search?q=mysql_config_editor
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-v,--verbose}'[write more information.]'
  {-V,--version}'[output version information and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
