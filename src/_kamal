#compdef kamal

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-P --skip-push)'{-P,--skip-push}'[skip image push]' \
  '(-d --destination)'{-d,--destination}'[destination]:destination' \
  '(-v --version)'{-v,--version}'[version to deploy]:version' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a cmds=(
      'setup:set up a new application on servers'
      'deploy:deploy the application'
      'redeploy:redeploy the application'
      'rollback:rollback to a previous version'
      'details:show details about the application'
      'audit:show audit log'
      'config:show configuration'
      'init:initialize a new Kamal project'
      'env:manage environment variables'
      'lock:acquire deploy lock'
      'unlock:release deploy lock'
      'remove:remove the application from servers'
      'app:manage the application'
      'accessory:manage accessories'
      'traefik:manage Traefik'
      'prune:prune old images and containers'
      'registry:manage registry'
      'server:manage servers'
      'version:show Kamal version'
    )
    _describe -t commands 'kamal command' cmds && ret=0
    ;;
esac
return ret
