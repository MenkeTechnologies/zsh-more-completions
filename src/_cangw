#compdef cangw

local -a arguments

arguments=(
  '-A[add a new rule]'
  '-D[delete a rule]'
  '-F[flush / delete all rules]'
  '-L[list all rules]'
  '-s[source netdevice]:device:'
  '-d[destination netdevice]:device:'
  '-t[preserve src_dev rx timestamp]'
  '-e[echo sent frames - recommended on vcanx]'
  '-i[allow to route to incoming interface]'
  '-u[user defined modification identifier]:id:'
  '-l[limit the number of frame hops / routings]:limit:'
  '-f[set CAN filter]:filter:'
  '-m[set frame modifications]:modification:'
  '-x[XOR checksum]:checksum:'
  '-c[CRC8 checksum]:checksum:'
  '-p[CRC8 checksum profile and parameters]:profile:'
  '*:filename:_files'
)

_arguments -s -S $arguments
