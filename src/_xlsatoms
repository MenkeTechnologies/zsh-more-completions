#compdef xlsatoms
# Documentation: https://man.archlinux.org/search?q=xlsatoms
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-display[X server to which to connect]'
  '-format[printf-style format to use]'
  '-range[atom values to list]'
  '-name[name of single atom to print]'
  '-version[print program version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
