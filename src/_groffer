#compdef groffer

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[print this usage message.]'
  {-T,--device}'[pass to groff using output device "name".]'
  {-v,--version}'[print version information.]'
  '-V[display the groff execution pipe instead of formatting.]'
  '-X[display with "gxditview" using groff -X.]'
  {-Z,--ditroff,--intermediate-output}'[generate groff intermediate output without postprocessing]'
  '--apropos[start mans "apropos" program for "name".]'
  '--apropos-data["apropos" for "name" in mans data sections 4, 5, 7.]'
  '--apropos-devel["apropos" for "name" in development sections 2, 3, 9.]'
  '--apropos-progs["apropos" for "name" in mans program sections 1, 6, 8.]'
  '--auto[choose mode automatically from the default mode list.]'
  '--default[reset all options to the default value.]'
  '--default-modes[set default mode list]:modes:'
  '--dvi[display in a viewer for TeX device independent format.]'
  '--groff[process like groff, disable viewing features.]'
  '--help[display this helping output.]'
  '--html[display in a web browser.]'
  '--man[check file parameters first whether they are man pages.]'
  '--mode[set display mode]:mode:(dvi groff html pdf ps text tty www x X)'
  '--no-man[disable man-page facility.]'
  '--no-special[disable --all, --apropos*, and --whatis]'
  '--pager[preset the paging program for tty mode.]'
  '--pdf[display in a PDF viewer.]'
  '--ps[display in a Postscript viewer.]'
  '--source[output as roff source.]'
  '--text[output in a text device without a pager.]'
  '--to-stdout[output the content of the mode file without display.]'
  '--tty[display with a pager on text terminal even when in X.]'
  '--utf8[unicode text mode]'
  '--viewer[choose a viewer for the actual device mode]'
  '--whatis[display the file name and description of man pages]'
  '--www[same as --html.]'
  {--x,--X}'[display with "gxditview" using an X* device.]'
  '--background[set background color]:color:'
  '--bd[set border color]:color:'
  '--bg[set background color]:color:'
  '--bordercolor[set border color]:color:'
  '--borderwidth[set border width]:width:'
  '--bw[set border width]:width:'
  '--display[set X display]:display:'
  '--fg[set foreground color]:color:'
  '--fn[set font]:font:'
  '--font[set font]:font:'
  '--foreground[set foreground color]:color:'
  '--geometry[set window geometry]:geometry:'
  '--iconic[start iconified]'
  '--resolution[set resolution]:resolution:'
  '--rv[reverse video]'
  '--title[set window title]:title:'
  '--xrm[set X resource]:resource:'
  '--all[process all found man pages]'
  '--ascii[use ASCII text device]'
  '--ditroff[generate ditroff output]'
  '--extension[set man page extension]:extension:'
  '--locale[set locale]:locale:'
  '--local-file[treat arguments as local files]'
  '--location[print file locations]'
  '--manpath[set man page search path]:path:_directories'
  '--sections[set man page sections to search]:sections:'
  '--debug[enable debugging output]'
  '--debug-filenames[debug file names]'
  '--debug-grog[debug grog output]'
  '--debug-keep[keep temporary files]'
  '--debug-params[debug parameters]'
  '--debug-tmpdir[debug temporary directory]'
  '--do-nothing[do not display, only show commands]'
  '--print[print the file name to stdout]'
  '*:filename:_files'
)

_arguments -s -S $arguments
