#compdef unflatten
# Documentation: https://man.archlinux.org/search?q=unflatten
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-o[put output in file]:file:_files'
  '-f[adjust immediate fanout chains]'
  '-l[stagger length of leaf edges between \[1,l\]]'
  '-c[put disconnected nodes in chains of length l]'
  '*:filename:_files'
)

_arguments -s -S $arguments
