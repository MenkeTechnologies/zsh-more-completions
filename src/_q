#compdef q

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-H[input file has header]' \
  '-d[input delimiter]:delimiter' \
  '-D[output delimiter]:delimiter' \
  '-t[input is tab delimited]' \
  '-T[output is tab delimited]' \
  '-O[output header]' \
  '-b[beautify output]' \
  '-f[output format]:format' \
  '-e[encoding]:encoding' \
  '-z[gzip compressed input]' \
  '-C[caching mode]:mode:(none read readwrite)' \
  '-A[analyze table structure]' \
  '-q[quoting character]:character' \
  '-Q[run query]:query' \
  '-W[input quoting mode]:mode:(minimal all nonnumeric none)' \
  '-w[output quoting mode]:mode:(minimal all nonnumeric none)' \
  '*:query or file:_files' && ret=0
return ret
