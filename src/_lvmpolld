#compdef lvmpolld

local -a arguments

arguments=(
  {-V,--version}'[show version info]'
  '(- * :)'{-h,--help}'[show this help information]'
  {-f,--foreground}'[dont fork, run in the foreground]'
  '--dump[dump full lvmpolld state]'
  {-l,--log}'[logging message level]:level:(all wire debug)'
  {-p,--pidfile}'[set path to the pidfile]:file:_files'
  {-s,--socket}'[set path to the communication socket]:path:_files'
  {-B,--binary}'[path to lvm2 binary]:path:_files'
  {-t,--timeout}'[time to wait in seconds before shutdown on idle]:seconds:'
  '*:filename:_files'
)

_arguments -s -S $arguments
