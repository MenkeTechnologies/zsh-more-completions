#compdef sourcekit-lsp

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[show help information]'
  '--version[display version]'
  '--configuration[build configuration]:configuration:(debug release)'
  '--build-path[specify build directory]:directory:_directories'
  '--Xcc[extra argument to pass to the C compiler]:arg:'
  '--Xcxx[extra argument to pass to the C++ compiler]:arg:'
  '--Xlinker[extra argument to pass to the linker]:arg:'
  '--Xswiftc[extra argument to pass to the Swift compiler]:arg:'
  '--Xclangd[extra argument to pass to clangd]:arg:'
  '--index-store-path[override the index store path]:path:_directories'
  '--index-db-path[override the index database path]:path:_directories'
  '--index-prefix-map[remap paths in the index]:mapping:'
  '--compilation-db-search-path[additional path to search for compilation databases]:path:_directories'
  '--default-workspaces-path[default workspace root for non-workspace files]:path:_directories'
  '--log-level[set logging level]:level:(debug info warning error)'
  '--completion-max-results[maximum number of completion results]:count:'
  '--server-path[server binary path]:path:_files'
  '--clangd-path[path to clangd binary]:path:_files'
  '-j[number of parallel build jobs]:jobs:'
  '--jobs[number of parallel build jobs]:jobs:'
  '--scratch-path[path for scratch space]:path:_directories'
  '--package-path[path to the package root]:path:_directories'
)

_arguments -s -S $arguments
