#compdef couchjs
# Documentation: https://man.archlinux.org/search?q=couchjs
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[display a short help message and exit]'
  '-V[display version information and exit]'
  '-H[enable couchjs cURL bindings (only available]'
  '-S[specify that the runtime should allow at]'
  '-u[path to a .uri file containing the address]'
  '*:filename:_files'
)

_arguments -s -S $arguments
