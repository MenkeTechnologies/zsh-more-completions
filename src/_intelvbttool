#compdef intelvbttool


local -a arguments

arguments=(
    {-h,--help}'[show help]'
    {-d,--outdump}'[dump VBT to file]:path:_files'
    {-l,--inlegacy}'[input legacy VBIOS]:path:_files'
    {-f,--invbt}'[input VBT file]:path:_files'
    {-o,--inoprom}'[input OpROM file]:path:_files'
    {-v,--outvbt}'[output VBT file]:path:_files'
    {-p,--patchoprom}'[patch OpROM file]:path:_files'
    '*:filename:_files'
)
_arguments -s -S $arguments
