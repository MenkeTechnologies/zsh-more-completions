#compdef bd_list_titles
# Documentation: https://man.archlinux.org/search?q=bd_list_titles
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-s[filter out titles shorter than specified seconds]:seconds:'
  '-a[list all titles]'
  '-l[show language codes]'
  '-h[show help message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
