#compdef findrule

local -a arguments

arguments=(
    '-name[Match filename]:pattern:'
    '-iname[Match filename case-insensitive]:pattern:'
    '-type[File type]:type:(f d l)'
    '-size[File size]:size:'
    '-mtime[Modification time]:days:'
    '-atime[Access time]:days:'
    '-ctime[Change time]:days:'
    '-maxdepth[Maximum depth]:depth:'
    '-mindepth[Minimum depth]:depth:'
    '-empty[Match empty files/dirs]'
    '-readable[Match readable files]'
    '-writable[Match writable files]'
    '-executable[Match executable files]'
    '-symlink[Match symlinks]'
    '-directory[Match directories]'
    '-file[Match regular files]'
    '-not[Negate next rule]'
    '-or[Boolean OR]'
    '-and[Boolean AND]'
    '-any[Match any file]'
    '-exec[Execute command]:command:'
    '-print[Print matching files]'
    '-perl[Perl expression]:expression:'
    '*:directory:_directories'
)

_arguments -s -S $arguments
