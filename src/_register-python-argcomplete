#compdef register-python-argcomplete

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  '--no-defaults[when no matches are generated, do not fallback to readline defaults]'
  '--complete-arguments'
  {-s,--shell}'[tcsh,bash]'
  '*:filename:_files'
)

_arguments -s -S $arguments
