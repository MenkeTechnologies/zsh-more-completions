#compdef mdb-json
# Documentation: https://man.archlinux.org/search?q=mdb-json
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    {-D,--date-format}'[Set the date format (see strftime(3) for details).]':fmt
    {-T,--time-format}'[Set the date/time format (see strftime(3) for details).]':fmt
    {-U,--no-unprintable}'[Change unprintable characters to spaces (otherwise escaped as \\u00XX)]'
    '*:filename:_files'
)
_arguments -s -S $arguments
