#compdef as gas

# Zsh completion for as (GNU/LLVM assembler)

_as() {
  local -a arguments

  arguments=(
    '(- *)--help[display help information]'
    '(- *)--version[print assembler version]'
    '(- *)--target-help[show target specific options]'

    # Output options
    {-o,--output}'[name the output file]:output file:_files'
    {-a,--alternate}'[enable alternate macro syntax or listing options]'
    '-ac[omit false conditionals from listing]'
    '-ad[omit debugging directives from listing]'
    '-ag[include general information in listing]'
    '-ah[include high-level source in listing]'
    '-al[include assembly in listing]'
    '-am[include macro expansions in listing]'
    '-an[omit forms processing from listing]'
    '-as[include symbols in listing]'
    '==[set listing output file]:listing file:_files'

    # General options
    '-D[produce assembler debugging messages]'
    '--defsym[define symbol SYM to given value]:sym=value:'
    '--execstack[require executable stack for this object]'
    '--noexecstack[do not require executable stack for this object]'
    '-f[skip whitespace and comment preprocessing]'
    '-g[generate debugging information]'
    '--gstabs[generate STABS debugging information]'
    '--gstabs\+[generate STABS debugging information with GNU extensions]'
    '--gdwarf-2[generate DWARF2 debugging information]'
    '--gdwarf-3[generate DWARF3 debugging information]'
    '--gdwarf-4[generate DWARF4 debugging information]'
    '--gdwarf-5[generate DWARF5 debugging information]'
    '--gdwarf-sections[generate per-function section names for DWARF line information]'
    '--hash-size[set the hash table size close to specified value]:size:'
    '-I[add directory to search list for .include directives]:directory:_directories'
    '-J[do not warn about signed overflow]'
    '-K[issue warnings when difference tables altered for long displacements]'
    '-L[keep local symbols (starting with L)]'
    '--listing-lhs-width[set the maximum width in words of the listing output data column]:width:'
    '--listing-lhs-width2[set the maximum width in words of the continuation lines for output data column]:width:'
    '--listing-rhs-width[set the maximum width in characters of the listing lines]:width:'
    '--listing-cont-lines[set the maximum number of continuation lines for output data]:lines:'
    '-M[assemble in MRI compatibility mode]'
    '--MD[write dependency information in FILE]:dependency file:_files'
    '-n[do not optimize code alignment]'
    '--no-pad-sections[do not pad the end of sections to alignment boundaries]'
    '-R[fold data section into text section]'
    '--reduce-memory-overheads[use smaller hash tables to reduce memory usage]'
    '--statistics[print various measured statistics from execution]'
    '--strip-local-absolute[strip local absolute symbols]'
    '-v[print assembler version]'
    '-W[suppress warnings]'
    '--warn[enable warnings]'
    '--fatal-warnings[treat warnings as errors]'
    '-w[ignored for compatibility]'
    '-X[ignored for compatibility]'
    '-Z[generate object file even after errors]'

    # Architecture options
    '-march=[specify architecture]:architecture:'
    '-mtune=[specify CPU for scheduling]:cpu:'
    '-msse2avx[encode SSE instructions with VEX prefix]'
    '-msse-check=[check SSE instructions]:check:(error warning none)'
    '-moperand-check=[check operand sizes]:check:(error warning none)'
    '-mavxscalar=[encode AVX scalar instructions]:encoding:(128 256)'
    '-mevexlig=[encode EVEX LIG instructions]:encoding:(128 256 512)'
    '-mevexwig=[encode EVEX WIG instructions]:encoding:(0 1)'
    '-mnaked-reg[do not require % prefix for registers]'
    '-msyntax=[set assembly syntax]:syntax:(att intel)'
    '-mmnemonic=[set assembly mnemonics]:mnemonics:(att intel)'
    '-madd-bnd-prefix[add BND prefix for all valid repne-prefixed instructions]'
    '-mno-shared[disable branch optimization for shared code]'
    '-mbig-obj[generate big object files]'
    '-momit-lock-prefix=[omit lock prefix]:mode:(yes no)'
    '-mx86-used-note=[generate x86 GNU property note]:mode:(yes no)'

    # macOS-specific / Clang integrated assembler options
    '-arch[specify target architecture]:architecture:(arm64 arm64e x86_64 armv7 armv7s armv7k i386)'
    '-static[assemble for static linking]'
    '-dynamic[assemble for dynamic linking]'
    '-force_cpusubtype_ALL[set CPU subtype to ALL]'
    '-q[use clang integrated assembler (macOS default)]'
    '-Q[use GNU based assembler]'

    # Preprocessor options
    '--MD[write dependency information]:dependency file:_files'

    # Input files
    '*:assembly file:_files -g "*.([sS]|asm)(-.)"'
  )

  _arguments -s -S $arguments
}

_as "$@"
