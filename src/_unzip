#compdef unzip

_arguments -s -S \
  '(-p -f -l -t -u -z -v)-p[extract files to pipe (stdout), no messages]' \
  '(-p -f -l -t -u -z -v)-l[list files in short format]' \
  '(-p -f -l -t -u -z -v)-f[freshen existing files only, create none]' \
  '(-p -f -l -t -u -z -v)-t[test compressed archive data]' \
  '(-p -f -l -t -u -z -v)-u[update files, create if necessary]' \
  '(-p -f -l -t -u -z -v)-z[display archive comment only]' \
  '(-p -f -l -t -u -z -v)-v[list verbosely or show version info]' \
  '-Z[switch to zipinfo mode (must be first option)]' \
  '-T[set timestamp of archive to newest file]' \
  '-x[exclude files that follow]:*:exclude files:_files' \
  '-d[extract files into specified directory]:directory:_directories' \
  '-n[never overwrite existing files]' \
  '-q[quiet mode (-qq for even quieter)]' \
  '-o[overwrite files without prompting]' \
  '-a[auto-convert text files to local OS format]' \
  '-j[junk paths (do not make directories)]' \
  '-aa[treat ALL files as text]' \
  '-b[treat all files as binary]' \
  '-B[save backup copy of each overwritten file]' \
  '-c[extract files to stdout/screen with filenames]' \
  '-C[match filenames case-insensitively]' \
  '-D[skip restoration of timestamps for extracted directories]' \
  '-DD[skip restoration of timestamps for all entries]' \
  '-K[keep setuid/setgid/sticky permissions]' \
  '-L[convert filenames to lowercase]' \
  '-LL[convert all filenames to lowercase]' \
  '-M[pipe output through internal pager (like more)]' \
  '-P[use password to decrypt encrypted entries]:password:' \
  '-U[use escapes for all non-ASCII Unicode characters]' \
  '-UU[ignore any Unicode fields]' \
  '-V[retain VMS version numbers]' \
  '-W[use wildcard matching for filenames]' \
  '-X[restore UID/GID info]' \
  '*:zip file:_files -g "*(-.)"'
