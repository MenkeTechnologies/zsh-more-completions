#compdef kdig

local -a query_options
query_options=(
  '+multiline[print records in multiline format]'
  '+noall[clear all display flags]'
  '+answer[display answer section]'
  '+authority[display authority section]'
  '+additional[display additional section]'
  '+question[display question section]'
  '+stats[display query statistics]'
  '+short[display short output]'
  '+time[set query timeout]:timeout:'
  '+retry[set number of retries]:retries:'
  '+bufsize[set UDP buffer size]:size:'
  '+edns[set EDNS version]:version:'
  '+tcp[use TCP]'
  '+notcp[use UDP]'
  '+tls[use DNS over TLS]'
  '+https[use DNS over HTTPS]'
  '+quic[use DNS over QUIC]'
  '+nsid[request NSID]'
  '+cookie[send EDNS cookie]'
  '+dnssec[request DNSSEC records]'
  '+json[output in JSON format]'
)

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-4[use IPv4 only]' \
  '-6[use IPv6 only]' \
  {-b,--source}'[set source address]:address:' \
  {-c,--class}'[set query class]:class:(IN CH HS ANY)' \
  {-d,--debug}'[enable debug output]' \
  {-k,--tsig-file}'[specify TSIG key file]:file:_files' \
  {-p,--port}'[specify port]:port:' \
  {-q,--name}'[specify query name]:name:' \
  {-s,--server}'[specify server]:server:_hosts' \
  {-t,--type}'[specify query type]:type:(A AAAA CNAME MX NS PTR SOA SRV TXT ANY AXFR)' \
  {-v,--verbose}'[enable verbose output]' \
  {-x,--reverse}'[reverse lookup]:address:' \
  {-y,--tsig}'[specify TSIG key]:key:' \
  '*::query name or option:' \
  && return 0
