#compdef grub2-glue-efi
# Documentation: https://man.archlinux.org/search?q=grub2-glue-efi
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-3,--input32}'[set input filename for 32-bit part.]'
  {-6,--input64}'[set input filename for 64-bit part.]'
  {-o,--output}'[set output filename. Default is STDOUT]'
  {-v,--verbose}'[print verbose messages.]'
  '--usage[give a short usage message]'
  {-V,--version}'[print program version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
