#compdef flit

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:prepare the source tree for flit'
  'build:build wheel and sdist'
  'publish:upload wheel and sdist to PyPI'
  'install:install the package locally'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-f --ini-path)'{-f,--ini-path}'=[path to pyproject.toml]:config:_files' \
  '--debug[show debug logging]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'flit command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (init)
        _arguments -s -S \
          '--author=[package author name]:author' \
          '--author-email=[package author email]:email' \
          '--homepage=[package homepage URL]:url' \
          '--description=[short description of package]:description' \
          '--license=[license for the package]:license:(MIT BSD-3-Clause Apache-2.0 GPL-3.0-only)' && ret=0
        ;;
      (build)
        _arguments -s -S \
          '--format=[format to build]:format:(wheel sdist)' \
          '--setup-py[include a setup.py shim]' \
          '--no-setup-py[do not include a setup.py shim]' && ret=0
        ;;
      (publish)
        _arguments -s -S \
          '--format=[format to publish]:format:(wheel sdist)' \
          '--repository=[PyPI repository to upload to]:repo:(pypi testpypi)' \
          '--setup-py[include a setup.py shim]' \
          '--no-setup-py[do not include a setup.py shim]' && ret=0
        ;;
      (install)
        _arguments -s -S \
          '(-s --symlink)'{-s,--symlink}'[symlink instead of copy]' \
          '--pth-file[install via .pth file]' \
          '--user[install to the user site-packages]' \
          '--env[install into current virtual environment]' \
          '--extras=[extras to install]:extras' \
          '--deps=[dependency handling]:deps:(all production develop none)' \
          '--python=[target Python executable]:python:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
