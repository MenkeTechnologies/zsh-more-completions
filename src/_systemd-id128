#compdef systemd-id128
# Documentation: https://man.archlinux.org/search?q=systemd-id128
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help]'
  {-p,--pretty}'[generate samples of program code]'
  {-a,--app-specific}'[generate app-specific IDs]'
  '*:filename:_files'
)

_arguments -s -S $arguments
