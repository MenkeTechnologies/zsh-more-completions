#compdef cadence

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'workflow:operate on workflow'
  'activity:operate on activity'
  'tasklist:operate on task list'
  'domain:operate on domain'
  'admin:operate on admin'
  'cluster:operate on cluster'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--address=[host:port for Cadence frontend]:address' \
  '--domain=[Cadence domain]:domain' \
  '--context-timeout=[context timeout in seconds]:seconds' \
  '--tls[enable TLS]' \
  '--tls-ca-path=[path to TLS CA certificate]:file:_files' \
  '--tls-cert-path=[path to TLS client certificate]:file:_files' \
  '--tls-key-path=[path to TLS client key]:file:_files' \
  '--tls-server-name=[TLS server name override]:name' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'cadence command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (workflow)
        local -a wf_cmds=(
          'start:start a new workflow execution'
          'run:start a new workflow and show progress'
          'cancel:cancel a workflow execution'
          'signal:signal a workflow execution'
          'terminate:terminate a workflow execution'
          'show:show workflow history'
          'showid:show workflow history by ID'
          'query:query a workflow execution'
          'stack:query a workflow with __stack_trace'
          'describe:show information about workflow execution'
          'describeid:show info by workflow ID'
          'observe:show workflow history and progress'
          'observeid:show history and progress by ID'
          'list:list open or closed workflow executions'
          'listall:list all workflows'
          'listarchived:list archived workflows'
          'scan:list workflow executions with scan'
          'count:count workflow executions'
          'reset:reset the workflow'
          'reset-batch:reset batch of workflows'
        )
        _arguments \
          '1:subcommand:_describe -t wf-commands "workflow command" wf_cmds' \
          '*:args' && ret=0
        ;;
      (domain)
        local -a domain_cmds=(
          'register:register a new domain'
          'describe:describe a domain'
          'update:update a domain'
        )
        _arguments \
          '1:subcommand:_describe -t domain-commands "domain command" domain_cmds' \
          '*:args' && ret=0
        ;;
      (activity)
        local -a act_cmds=(
          'complete:complete an activity'
          'fail:fail an activity'
        )
        _arguments \
          '1:subcommand:_describe -t act-commands "activity command" act_cmds' \
          '*:args' && ret=0
        ;;
      (tasklist)
        local -a tl_cmds=(
          'describe:describe task list'
          'list-partition:list task list partitions'
        )
        _arguments \
          '1:subcommand:_describe -t tl-commands "tasklist command" tl_cmds' \
          '*:args' && ret=0
        ;;
    esac
    ;;
esac

return ret
