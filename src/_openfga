#compdef fga

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'model:manage authorization models'
  'store:manage stores'
  'tuple:manage relationship tuples'
  'query:query authorization data'
  'completion:generate shell completions'
  'version:show version information'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--api-url=[FGA API URL]:url' \
  '--api-token=[FGA API token]:token' \
  '--store-id=[store ID]:store id' \
  '--model-id=[model ID]:model id' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'fga command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (model)
        local -a model_cmds=(
          'get:get an authorization model'
          'list:list authorization models'
          'write:write an authorization model'
          'validate:validate an authorization model'
          'transform:transform a model between formats'
          'test:test a model with tuples and assertions'
        )
        _arguments \
          '1:subcommand:_describe -t model-commands "model command" model_cmds' \
          '*:args' && ret=0
        ;;
      (store)
        local -a store_cmds=(
          'create:create a store'
          'delete:delete a store'
          'get:get store information'
          'list:list stores'
          'import:import store data'
          'export:export store data'
        )
        _arguments \
          '1:subcommand:_describe -t store-commands "store command" store_cmds' \
          '*:args' && ret=0
        ;;
      (tuple)
        local -a tuple_cmds=(
          'write:write relationship tuples'
          'delete:delete relationship tuples'
          'read:read relationship tuples'
          'changes:list tuple changes'
          'import:import relationship tuples'
        )
        _arguments \
          '1:subcommand:_describe -t tuple-commands "tuple command" tuple_cmds' \
          '*:args' && ret=0
        ;;
      (query)
        local -a query_cmds=(
          'check:check if a user has a relation'
          'expand:expand the relations of a type'
          'list-objects:list objects a user has access to'
          'list-relations:list relations a user has on an object'
          'list-users:list users who have a relation'
        )
        _arguments \
          '1:subcommand:_describe -t query-commands "query command" query_cmds' \
          '*:args' && ret=0
        ;;
    esac
    ;;
esac

return ret
