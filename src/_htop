#compdef htop

local -a arguments

# Sort columns from htop --sort-key=help (htop 3.4.x)
local -a sort_columns
sort_columns=(
  PID Command STATE PPID PGRP SESSION TTY TPGID
  MINFLT MAJFLT PRIORITY NICE STARTTIME PROCESSOR
  M_VIRT M_RESIDENT ST_UID PERCENT_CPU PERCENT_MEM
  USER TIME NLWP TGID PERCENT_NORM_CPU ELAPSED
  TRANSLATED EXE CWD
)

arguments=(
  {-C,--no-color}'[use a monochrome color scheme]'
  {-d,--delay=}'[set the delay between updates, in tenths of seconds]:delay (tenths of seconds)'
  {-F,--filter=}'[show only the commands matching the given filter]:filter string'
  '(- *)'{-h,--help}'[print this help screen]'
  {-H,--highlight-changes}'[highlight new and old processes]'
  {-M,--no-mouse}'[disable the mouse]'
  {-n,--max-iterations=}'[exit htop after NUMBER iterations/frame updates]:number of iterations'
  {-p,--pid=}'[show only the given PIDs]:PIDs (comma-separated)'
  '--readonly[disable all system and process changing features]'
  {-s,--sort-key=}'[sort by the specified column in list view]:sort column:'"(${(j: :)sort_columns})"
  {-t,--tree}'[show the tree view (can be combined with -s)]'
  {-u,--user=}'[show only processes for a given user (or \$USER)]:user:_users'
  {-U,--no-unicode}'[do not use unicode but plain ASCII]'
  '(- *)'{-V,--version}'[print version info]'
)

_arguments -s -S $arguments
