#compdef nsenter

_nsenter() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -S -s \
        {-a,--all}'[enter all namespaces of the target process]' \
        {-t+,--target=}'[target process to get namespaces from]:pid:_pids' \
        {-m,--mount}'[enter mount namespace]::file:_files' \
        {-u,--uts}'[enter UTS namespace (hostname etc)]::file:_files' \
        {-i,--ipc}'[enter System V IPC namespace]::file:_files' \
        {-n,--net}'[enter network namespace]::file:_files' \
        {-p,--pid}'[enter pid namespace]::file:_files' \
        {-C,--cgroup}'[enter cgroup namespace]::file:_files' \
        {-U,--user}'[enter user namespace]::file:_files' \
        {-T,--time}'[enter time namespace]::file:_files' \
        {-S+,--setuid=}'[set uid in entered namespace]:uid:_users' \
        {-G+,--setgid=}'[set gid in entered namespace]:gid:_groups' \
        '--preserve-credentials[do not touch uids or gids]' \
        {-r,--root}'[set the root directory]:directory:_directories' \
        {-w,--wd}'[set the working directory]:directory:_directories' \
        '--wdns=[set working directory to namespace root]:directory:_directories' \
        {-e,--env}'[pass environment variables]' \
        {-F,--no-fork}'[do not fork before exec'\''ing the specified program]' \
        {-Z,--follow-context}'[set SELinux context according to --target PID]' \
        '--no-default[do not use default namespace when no namespace is specified]' \
        '(- *)'{-h,--help}'[display help text and exit]' \
        '(- *)'{-V,--version}'[display version information and exit]' \
        '(-):command:_command_names -e' \
        '*::arguments:_normal' && ret=0

    return ret
}

_nsenter "$@"
