#compdef gnome-session-quit
# Documentation: https://man.archlinux.org/search?q=gnome-session-quit
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  '--logout[log out]'
  '--power-off[power off]'
  '--reboot[reboot]'
  '--force[ignoring any existing inhibitors]'
  '--no-prompt[dont prompt for user confirmation]'
  '*:filename:_files'
)

_arguments -s -S $arguments
