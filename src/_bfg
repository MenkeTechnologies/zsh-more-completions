#compdef bfg

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '--strip-blobs-bigger-than[strip blobs bigger than size]:size' \
  '--strip-biggest-blobs[strip the N biggest blobs]:count' \
  '--delete-files[delete files matching glob]:glob' \
  '--delete-folders[delete folders matching glob]:glob' \
  '--replace-text[replace text using expressions file]:file:_files' \
  '--filter-content-including[only filter files matching glob]:glob' \
  '--filter-content-excluding[exclude files matching glob]:glob' \
  '--no-blob-protection[disable blob protection]' \
  '--private[treat as private repo]' \
  '--massive-non-file-objects-sized-up-to[allow massive non-file objects up to size]:size' \
  '*:repository:_directories' && ret=0
return ret
