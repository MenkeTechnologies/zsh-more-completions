#compdef h5import
# Documentation: https://man.archlinux.org/search?q=h5import
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[prints this summary of usage, and exits.]'
  '-c[specify configuration file]:configfile:_files'
  '-o[specify output file]:outfile:_files'
  '-1[any dimension implies UNLIMITED]'
  '*:filename:_files'
)

_arguments -s -S $arguments
