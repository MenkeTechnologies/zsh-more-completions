#compdef mysql_find_rows
# Documentation: https://man.archlinux.org/search?q=mysql_find_rows
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {--help,--Information}'[shows this help]'
  '--regexp[print queries that matches this.]'
  '--start_row=[start from this row number]:row number: '
  '--skip-use-db[dont include use database commands in the output.]'
  '--rows[quit after this many rows.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
