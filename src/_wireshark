#compdef wireshark

_arguments -s -S \
  {-i,--interface}'[name or index of interface to capture on]:interface:_net_interfaces' \
  '-f[packet filter in libpcap filter syntax]:capture filter:' \
  {-s,--snapshot-length}'[packet snapshot length (default: appropriate maximum)]:snapshot length:' \
  {-p,--no-promiscuous-mode}'[do not capture in promiscuous mode]' \
  '-k[start capturing immediately]' \
  '-S[update packet display when new packets are captured]' \
  '-l[turn on automatic scrolling while -S is in use]' \
  {-I,--monitor-mode}'[capture in monitor mode, if available]' \
  {-B,--buffer-size}'[size of kernel buffer in MiB]:buffer size (MiB):' \
  {-y,--linktype}'[link layer type]:link type:' \
  '--time-stamp-type[timestamp method for interface]:timestamp type:' \
  {-D,--list-interfaces}'[print list of interfaces and exit]' \
  {-L,--list-data-link-types}'[print list of link-layer types for interface and exit]' \
  '--list-time-stamp-types[print list of timestamp types for interface and exit]' \
  '-c[stop after n packets]:packet count:' \
  {-a,--autostop}'[specify autostop condition]:autostop condition:' \
  {-b,--ring-buffer}'[specify ring buffer option]:ring buffer option:' \
  {-r,--read-file}'[set the filename to read from]:capture file:_files' \
  {-R,--read-filter}'[packet read filter in Wireshark display filter syntax]:read filter:' \
  '-n[disable all name resolutions]' \
  '-N[enable specific name resolution(s)]:resolve flags:' \
  '-d[specify layer type dissection]:selector,decode_as_protocol:' \
  '--enable-protocol[enable dissection of specified protocol]:protocol name:' \
  '--disable-protocol[disable dissection of specified protocol]:protocol name:' \
  '--enable-heuristic[enable dissection of heuristic protocol]:heuristic name:' \
  '--disable-heuristic[disable dissection of heuristic protocol]:heuristic name:' \
  '-C[start with specified configuration profile]:profile name:' \
  '-H[hide the capture info dialog during packet capture]' \
  {-Y,--display-filter}'[display filter]:display filter:' \
  '-g[go to specified packet number after "-r"]:packet number:' \
  '-J[jump to first packet matching display filter]:jump filter:' \
  '-j[search backwards for a matching packet after "-J"]' \
  '-t[format of time stamps]:time format:((a\:"absolute" ad\:"absolute with date" adoy\:"absolute with date (day of year)" d\:"delta" dd\:"delta displayed" e\:"epoch" r\:"relative" u\:"absolute UTC" ud\:"absolute UTC with date" udoy\:"absolute UTC with date (day of year)"))' \
  '-u[output format of seconds]:seconds format:((s\:seconds hms\:"hours\:minutes\:seconds"))' \
  '-X[eXtension options]:extension option:' \
  '-z[show various statistics]:statistics:' \
  '-w[set the output filename]:output file:_files' \
  '--capture-comment[add a capture file comment]:comment:' \
  '--temp-dir[write temporary files to specified directory]:directory:_directories' \
  '--log-level[set the active log level]:log level:(critical warning message info debug noisy)' \
  '--log-fatal[set level to abort the program]:fatal level:(critical warning)' \
  '--log-domains[comma-separated list of active log domains]:log domains:' \
  '--log-debug[comma-separated list of domains with debug level]:debug domains:' \
  '--log-noisy[comma-separated list of domains with noisy level]:noisy domains:' \
  '--log-file[file to output messages to (in addition to stderr)]:log file:_files' \
  {-h,--help}'[display help and exit]' \
  {-v,--version}'[display version info and exit]' \
  '-P[personal configuration files path]:path type\:path:' \
  '-o[override preference or recent setting]:preference setting:' \
  '-K[keytab file to use for kerberos decryption]:keytab file:_files' \
  '--display[X display to use]:display:' \
  '--fullscreen[start Wireshark in full screen]' \
  '*:capture file:_files'
