#compdef xcam
# Documentation: https://man.archlinux.org/search?q=xcam
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[display this help message and exit]'
  {-B,--buffersize}'[set buffersize 1024 * 1024]'
  {-V,--version}'[print version information]'
  '*:filename:_files'
)

_arguments -s -S $arguments
