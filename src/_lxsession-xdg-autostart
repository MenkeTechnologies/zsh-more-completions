#compdef lxsession-xdg-autostart
# Documentation: https://man.archlinux.org/search?q=lxsession-xdg-autostart
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  {-d,--desktop}'[_environnement=NAME     Desktop environment to use for desktop files, like LXDE, KDE ... Default to LXDE]'
  '*:filename:_files'
)

_arguments -s -S $arguments
