#compdef derdump
# Documentation: https://man.archlinux.org/search?q=derdump
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-r[for formatted items, dump raw bytes as well]'
  '-i[define an input file to use (default is stdin)]'
  '-o[define an output file to use (default is stdout)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
