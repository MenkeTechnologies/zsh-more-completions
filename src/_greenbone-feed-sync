#compdef greenbone-feed-sync
# Documentation: https://man.archlinux.org/search?q=greenbone-feed-sync
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '--describe[display current feed info.]'
    '--feedversion[display version of this feed.]'
    '--help[display this help.]'
    '--identify[display information.]'
    '--selftest[perform self-test.]'
    '--type[choose type of data to sync (CERT, SCAP or GVMD_DATA).]:TYPE'
    '--version[display version]'
    '*:filename:_files'
)
_arguments -s -S $arguments
