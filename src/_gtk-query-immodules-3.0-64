#compdef gtk-query-immodules-3 gtk-query-immodules-3.0-64
# Documentation: https://man.archlinux.org/search?q=gtk-query-immodules-3
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '--update-cache[Write the output to the default cache location instead of stdout.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
