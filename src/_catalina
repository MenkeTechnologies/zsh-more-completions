#compdef catalina catalina.sh

_commands=(
"debug:Start Catalina in a debugger"
"jpda:Start Catalina under JPDA debugger"
"run:Start Catalina in the current window"
"start:Start Catalina in a separate window"
"stop:Stop Catalina"
"configtest:Run a basic syntax check on server.xml"
"version:Print the Tomcat version"
)

_catalina_stop_args() {
  _arguments \
    '1:timeout (seconds):' \
    '-force[use kill -KILL if still running after timeout]'
}

if (( CURRENT == 2 )); then
  _describe -t commands "catalina commands" _commands
else
  case "${words[2]}" in
    debug|run|start)
      _arguments '-security[start with a security manager]'
      ;;
    jpda)
      _wanted commands expl "jpda subcommand" compadd start
      ;;
    stop)
      _catalina_stop_args
      ;;
  esac
fi
