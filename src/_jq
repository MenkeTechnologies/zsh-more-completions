#compdef jq

# Zsh completion for jq - commandline JSON processor
# Covers jq 1.6+ including 1.7/1.8 options

local -a arguments

arguments=(
  # Output format options
  {-c,--compact-output}'[compact instead of pretty-printed output]'
  {-r,--raw-output}'[output raw strings, not JSON texts]'
  '--raw-output0[output raw strings delimited by NUL characters (implies -r)]'
  {-j,--join-output}'[like -r but do not print a newline after each output]'
  {-a,--ascii-output}'[restrict output to ASCII by escaping non-ASCII characters]'
  {-C,--color-output}'[colorize JSON output]'
  {-M,--monochrome-output}'[disable colored output]'
  {-S,--sort-keys}'[sort keys of each object on output]'
  '--tab[use tabs for indentation]'
  '--indent[set indentation level]:indentation level:(0 1 2 3 4 5 6 7)'

  # Input options
  {-R,--raw-input}'[read each line as a string instead of JSON]'
  {-n,--null-input}'[use null as the single input value]'
  {-s,--slurp}'[read all inputs into an array and use it as single input]'

  # Streaming
  '--stream[parse the input value in streaming fashion]'
  '--stream-errors[implies --stream and report parse errors as arrays]'
  '--seq[use application/json-seq MIME type scheme for input/output]'

  # Output behavior
  {-e,--exit-status}'[set exit status code based on the output]'
  '--unbuffered[flush output stream after each output]'

  # Variable binding
  '*--arg[set variable \$name to string value]: :_guard "^-*" name: :_guard "^-*" value'
  '*--argjson[set variable \$name to JSON value]: :_guard "^-*" name: :_guard "^-*" value'
  '*--slurpfile[set variable to array of JSON values read from file]: :_guard "^-*" name:file:_files'
  '*--rawfile[set variable to string contents of file]: :_guard "^-*" name:file:_files'
  '--args[remaining arguments are string values, available as \$ARGS.positional]'
  '--jsonargs[remaining arguments are JSON values, available as \$ARGS.positional]'

  # Filter source
  {-f,--from-file}'[read filter from file]:filter file:_files'

  # Module system
  '*'{-L,--library-path}'[add directory to module search list]:directory:_directories'

  # Testing and debugging
  '--run-tests[run tests from file]:test file:_files'

  # Information
  {-V,--version}'[show the version and exit]'
  {-h,--help}'[show help message]'
  '--build-configuration[show jq build configuration]'

  # Filter and input files
  '1:jq filter:'
  '*:input file:_files'
)

_arguments -s -S $arguments
