#compdef ast-grep sg

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'run:run one time search or rewrite in command line'
  'scan:scan and rewrite code by configuration'
  'test:test ast-grep rules'
  'new:create new ast-grep project or rule'
  'completions:generate shell completions'
  'docs:open ast-grep documentation'
  'lsp:start language server'
)

local -a languages=(
  c cpp csharp css dart elixir go html java javascript json
  kotlin lua python ruby rust scala swift tsx typescript yaml
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:subcommand:->subcommand' \
  '*::: :->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (run)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-p --pattern)'{-p,--pattern}'[AST pattern to match]:pattern:' \
          '--selector[AST kind selector]:selector:' \
          '--rewrite[rewrite matched AST node]:rewrite pattern:' \
          '(-l --lang)'{-l,--lang}'[language of the pattern]:language:('"${languages[*]}"')' \
          '--json[output results as JSON]' \
          '--color[controls color output]:when:(auto always ansi never)' \
          '--heading[controls heading output]:when:(auto always never)' \
          '(-i --interactive)'{-i,--interactive}'[start interactive editing]' \
          '(-U --update-all)'{-U,--update-all}'[apply all rewrite without confirmation]' \
          '--debug-query[debug query information]:mode:(ast cst pattern)' \
          '*:path:_files' && ret=0
        ;;
      (scan)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-r --rule)'{-r,--rule}'[path to rule file]:rule file:_files' \
          '(-c --config)'{-c,--config}'[path to sgconfig.yml]:config file:_files' \
          '--json[output results as JSON]' \
          '--format[output format]:format:(github json short)' \
          '--inline-rules[inline rule string]:rules:' \
          '--filter[filter rules by id]:filter:' \
          '--error[set error severity rules]:rules:' \
          '--warning[set warning severity rules]:rules:' \
          '--info[set info severity rules]:rules:' \
          '--hint[set hint severity rules]:rules:' \
          '--report-style[report style]:style:(rich medium short)' \
          '--color[controls color output]:when:(auto always ansi never)' \
          '--heading[controls heading output]:when:(auto always never)' \
          '*:path:_files' && ret=0
        ;;
      (test)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-c --config)'{-c,--config}'[path to sgconfig.yml]:config file:_files' \
          '--test-dir[path to test directory]:directory:_files -/' \
          '--snapshot-dir[path to snapshot directory]:directory:_files -/' \
          '(-U --update-all)'{-U,--update-all}'[update all snapshots]' \
          '(-i --interactive)'{-i,--interactive}'[start interactive mode]' && ret=0
        ;;
      (new)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-l --lang)'{-l,--lang}'[language]:language:('"${languages[*]}"')' \
          '(-y --yes)'{-y,--yes}'[accept all default options]' \
          '1:what to create:(project rule test util)' && ret=0
        ;;
      (completions)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:shell:(bash zsh fish powershell elvish)' && ret=0
        ;;
      (docs|lsp)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
