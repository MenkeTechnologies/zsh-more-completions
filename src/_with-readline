#compdef with-readline
# Documentation: https://man.archlinux.org/search?q=with-readline
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {--application,-a}'[set application name]'
  {--history,-H}'[maximum history to retain]'
  {--help,-h}'[display usage message]'
  {--version,-V}'[display version number]'
  '*:filename:_files'
)

_arguments -s -S $arguments
