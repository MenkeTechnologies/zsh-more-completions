#compdef fd2c
# Documentation: https://man.archlinux.org/search?q=fd2c
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-o,--output}'[set output file name]'
  '--help[print this help and exit]'
  '--version[print version number and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
