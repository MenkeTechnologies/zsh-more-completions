#compdef networkctl

# Zsh completion for networkctl (systemd-networkd management)

_networkctl() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a global_opts
    global_opts=(
        '(- *)'{-h,--help}'[show help message]'
        '(- *)--version[show package version]'
        '--no-pager[do not pipe output into a pager]'
        '--no-legend[do not show the headers and footers]'
        {-a,--all}'[show status for all links]'
        {-s,--stats}'[show detailed link statistics]'
        {-l,--full}'[do not ellipsize output]'
        {-n,--lines}'[number of journal entries to show]:number'
        '--json[show output formatted as JSON]:mode:(short pretty off)'
        '--no-reload[do not reload the daemon after performing operations]'
        '(-): :->command'
        '(-)*:: :->option-or-argument'
    )

    _arguments -s -C $global_opts && ret=0

    case $state in
        (command)
            local -a commands
            commands=(
                'list:list existing links'
                'status:show link status'
                'lldp:show LLDP neighbors'
                'label:show current address label entries in the kernel'
                'delete:delete virtual netdevs'
                'up:bring devices up'
                'down:bring devices down'
                'renew:renew dynamic configurations (e.g. addresses received from DHCP)'
                'forcerenew:trigger DHCP reconfiguration of all connected clients'
                'reconfigure:reconfigure interfaces'
                'reload:reload .netdev and .network files'
                'edit:edit network configuration files'
                'cat:show network configuration files'
                'mask:mask network configuration files'
                'unmask:unmask network configuration files'
                'persistent-storage:manage persistent storage for network data'
            )
            _describe -t commands 'networkctl command' commands && ret=0
            ;;
        (option-or-argument)
            case $words[1] in
                status|lldp|up|down|delete|renew|forcerenew|reconfigure|show)
                    _net_interfaces && ret=0
                    ;;
                edit|cat|mask|unmask)
                    _files && ret=0
                    ;;
                *)
                    _net_interfaces && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_networkctl "$@"
