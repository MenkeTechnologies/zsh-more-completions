#compdef py3rsa-sign
# Documentation: https://man.archlinux.org/search?q=py3rsa-sign
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    {-h,--help}'[show help message and exit.]'
    {-i,--input}'[name of the file to sign. read from stdin if not specified.]'
    '--output[name of the file to write the signature to.]'
    '--keyform[key format of the private key - default PEM]:KEYFORM'
    '*:filename:_files'
)
_arguments -s -S $arguments
