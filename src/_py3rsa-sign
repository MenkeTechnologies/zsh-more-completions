#compdef py3rsa-sign


local -a arguments

arguments=(
    {-h,--help}'[show help message and exit.]'
    {-i,--input}'[name of the file to sign. read from stdin if not specified.]'
    '--output[name of the file to write the signature to.]'
    '--keyform[key format of the private key - default PEM AUTHOR ,py3rsa-sign was written b…]:KEYFORM'
    '*:filename:_files'
)
_arguments -s -S $arguments
