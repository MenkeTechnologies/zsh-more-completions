#compdef abrt-watch-log
# Documentation: https://man.archlinux.org/search?q=abrt-watch-log
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-v,--verbose}'[be verbose]'
  '-s[log to syslog]'
  '-F[dont run PROG if STRs arent found]'
  '*:filename:_files'
)

_arguments -s -S $arguments
