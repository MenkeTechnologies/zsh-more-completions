#compdef dc3dd
# Documentation: https://man.archlinux.org/search?q=dc3dd
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-DDEFAULT[_OUTPUT_FILE_SIZE followed by the desired]'
  '-DDEFAULT[_HASH_SHA256, and -DDEFAULT_HASH_SHA512.]'
  '--help[display this help and exit]'
  '--version[output version information and exit]'
  '--flags[display compile-time flags and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
