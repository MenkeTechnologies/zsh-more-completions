#compdef sg_prevent
# Documentation: https://man.archlinux.org/search?q=sg_prevent
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {--allow,-a}'[allow media removal]'
  {--help,-h}'[print usage message then exit]'
  '--prevent[PC prevent code value (def: 1 -> prevent)]'
  {--verbose,-v}'[increase verbosity]'
  {--version,-V}'[print version string and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
