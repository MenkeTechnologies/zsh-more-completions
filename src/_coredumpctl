#compdef coredumpctl

_coredumpctl_commands() {
  local -a commands=(
    'list:list core dumps captured in the journal'
    'info:show detailed information about core dumps'
    'dump:extract the last core dump matching characteristics'
    'debug:invoke a debugger on the last core dump'
  )
  _describe -t commands 'coredumpctl command' commands
}

_coredumpctl() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a options=(
    '(- *)'{-h,--help}'[print a short help text and exit]'
    '(- *)--version[print a short version string and exit]'
    '--no-pager[do not pipe output into a pager]'
    '--no-legend[do not print column headers and footer]'
    '--json=[output as JSON]:mode:(short pretty off)'
    '-1[show information of the most recent core dump only]'
    '-n+[show at most the specified number of entries]:number'
    {-S,--since=}'[only print entries since the specified date]:date'
    {-U,--until=}'[only print entries until the specified date]:date'
    {-r,--reverse}'[reverse output so newest entries are displayed first]'
    {-F,--field=}'[print all possible data values the specified field takes]:field'
    {-o,--output=}'[write the core to FILE]:file:_files'
    '--debugger=[use the given debugger for the debug command]:debugger:_command_names'
    {-A,--debugger-arguments=}'[pass extra command line arguments to the debugger]:args'
    '--file=[operate on specified journal files matching GLOB]:glob'
    {-D,--directory=}'[use the journal files in the specified directory]:directory:_directories'
    '--root=[use root directory when searching for coredumps]:root:_directories'
    '--image=[apply operations to file system in the indicated disk image]:image:_files'
    '--image-policy=[enforce image policy string when operating on disk image]:policy'
    {-q,--quiet}'[suppress informational messages about journal file access]'
    '--all[look at all available journal files in /var/log/journal/]'
  )

  _arguments -s -S : \
    $options \
    '1:command:_coredumpctl_commands' \
    '*:match'
}

_coredumpctl "$@"
