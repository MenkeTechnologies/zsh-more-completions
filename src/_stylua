#compdef stylua

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-V,--version}'[display version]' \
  '--check[check if files are formatted]' \
  '--verify[verify AST validity after formatting]' \
  '(-f --config-path)'{-f,--config-path}'[path to configuration file]:config file:_files -g "*.toml"' \
  '--search-parent-directories[search parent directories for config]' \
  '--no-editorconfig[do not use .editorconfig]' \
  '--color[when to use color]:when:(auto always never)' \
  '--output-format[output format]:format:(summary unified)' \
  '--column-width[maximum column width]:width' \
  '--line-endings[line ending style]:style:(Unix Windows)' \
  '--indent-type[indentation type]:type:(Tabs Spaces)' \
  '--indent-width[indentation width]:width' \
  '--quote-style[string quote style]:style:(AutoPreferDouble AutoPreferSingle ForceDouble ForceSingle)' \
  '--call-parentheses[call parentheses style]:style:(Always NoSingleString NoSingleTable None Input)' \
  '--collapse-simple-statement[collapse simple statements]:option:(Never FunctionOnly ConditionalOnly Always)' \
  '--sort-requires[sort require statements]' \
  '--no-sort-requires[do not sort require statements]' \
  '(-g --glob)'{-g,--glob}'[glob pattern for files]:pattern' \
  '--allow-hidden[allow formatting hidden files]' \
  '--respect-ignores[respect .styluaignore files]' \
  '--stdin-filepath[path to use for stdin]:path:_files' \
  '*:file or directory:_files' \
  && ret=0

return ret
