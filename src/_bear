#compdef bear

# Zsh completion for Bear (Build EAR) - compilation database generator

_arguments \
  '--help[show help message]' \
  '--version[show version]' \
  '--verbose[run in verbose mode]' \
  '--output[specify output file]:output file:_files' \
  '--append[append to existing output file]' \
  '--config[specify config file]:config file:_files' \
  '--force-preload[force preload method]' \
  '--force-wrapper[force wrapper method]' \
  '--citnames[specify citnames file]:citnames file:_files' \
  '*::build command:_command_names -e'
