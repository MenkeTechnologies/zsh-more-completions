#compdef nuclei

# Zsh completion for nuclei - fast and customizable vulnerability scanner

_arguments -s -S \
  '(-u --target)'{-u,--target}'[target URL/host to scan]:URL:' \
  '(-l --list)'{-l,--list}'[path to file containing a list of target URLs]:file:_files' \
  '(-resume --resume)--resume[resume scan using resume.cfg]:file:_files' \
  '(-t --templates)'{-t,--templates}'[templates or directory to run]:template:_files' \
  '(-turl --template-url)'{-turl,--template-url}'[template URL to run]:URL:' \
  '(-w --workflows)'{-w,--workflows}'[workflow file to run]:file:_files' \
  '(-wurl --workflow-url)'{-wurl,--workflow-url}'[workflow URL to run]:URL:' \
  '(-validate --validate)--validate[validate templates before running]' \
  '(-nt --new-templates)'{-nt,--new-templates}'[run only new templates added in latest nuclei-templates release]' \
  '(-ntv --new-templates-version)'{-ntv,--new-templates-version}'[run new templates added in specific version]:version:' \
  '(-as --automatic-scan)'{-as,--automatic-scan}'[automatic web scan using wappalyzer tech detection]' \
  '(-tags --tags)'{-tags,--tags}'[run templates with specified tags]:tags:' \
  '(-etags --exclude-tags)'{-etags,--exclude-tags}'[exclude templates with specified tags]:tags:' \
  '(-itags --include-tags)'{-itags,--include-tags}'[do not filter templates with specified tags]:tags:' \
  '(-id --template-id)'{-id,--template-id}'[run templates with specified ID]:IDs:' \
  '(-eid --exclude-id)'{-eid,--exclude-id}'[exclude templates with specified ID]:IDs:' \
  '(-s --severity)'{-s,--severity}'[run only templates with specified severity]:severity:(info low medium high critical unknown)' \
  '(-es --exclude-severity)'{-es,--exclude-severity}'[exclude templates with specified severity]:severity:(info low medium high critical unknown)' \
  '(-cs --condition)'{-cs,--condition}'[template condition query]:query:' \
  '(-p --proxy)'{-p,--proxy}'[list of HTTP/SOCKS5 proxy URLs]:proxy:' \
  '(-pi --proxy-internal)'{-pi,--proxy-internal}'[proxy all internal requests]' \
  '(-fr --follow-redirects)'{-fr,--follow-redirects}'[enable following redirects for HTTP templates]' \
  '(-fhr --follow-host-redirects)'{-fhr,--follow-host-redirects}'[follow redirects on same host]' \
  '(-mhr --max-host-error)'{-mhr,--max-host-error}'[max errors for a host before skipping]:N:' \
  '(-retries --retries)--retries[number of retries]:N:' \
  '(-timeout --timeout)--timeout[timeout in seconds]:seconds:' \
  '(-rl --rate-limit)'{-rl,--rate-limit}'[maximum requests per second]:rate:' \
  '(-rlm --rate-limit-minute)'{-rlm,--rate-limit-minute}'[maximum requests per minute]:rate:' \
  '(-bs --bulk-size)'{-bs,--bulk-size}'[maximum number of hosts to be analyzed in parallel]:size:' \
  '(-c --concurrency)'{-c,--concurrency}'[number of template executions to be performed in parallel]:N:' \
  '(-hbs --headless-bulk-size)'{-hbs,--headless-bulk-size}'[number of headless hosts to be analyzed in parallel]:size:' \
  '(-headc --headless-concurrency)'{-headc,--headless-concurrency}'[number of headless template executions to be performed in parallel]:N:' \
  '(-o --output)'{-o,--output}'[output file to write results]:file:_files' \
  '(-sresp --store-resp)'{-sresp,--store-resp}'[store HTTP request/response to output directory]' \
  '(-srd --store-resp-dir)'{-srd,--store-resp-dir}'[store HTTP request/response to output directory]:dir:_files -/' \
  '(-j --jsonl)'{-j,--jsonl}'[write output in JSONL format]' \
  '(-irm --include-rr)'{-irm,--include-rr}'[include request/response pairs in JSONL output]' \
  '(-nm --no-meta)'{-nm,--no-meta}'[disable printing result metadata in cli output]' \
  '(-nts --no-timestamp)'{-nts,--no-timestamp}'[disable printing timestamp in cli output]' \
  '(-rdb --report-db)'{-rdb,--report-db}'[nuclei reporting database]:file:_files' \
  '(-me --markdown-export)'{-me,--markdown-export}'[directory to export results in markdown format]:dir:_files -/' \
  '(-se --sarif-export)'{-se,--sarif-export}'[file to export results in SARIF format]:file:_files' \
  '(-ss --scan-strategy)'{-ss,--scan-strategy}'[strategy for scan execution]:strategy:(auto host-spray template-spray)' \
  '(-env-vars --env-vars)--env-vars[enable environment variables support in templates]' \
  '(-ah --allow-local-file-access)'{-ah,--allow-local-file-access}'[allow file (file://) triggered templates]' \
  '(-rsr --restrict-local-network-access)'{-rsr,--restrict-local-network-access}'[block connections to localhost/private IPs]' \
  '(-debug --debug)--debug[show all requests and responses]' \
  '(-dreq --debug-req)'{-dreq,--debug-req}'[show all sent requests]' \
  '(-dresp --debug-resp)'{-dresp,--debug-resp}'[show all received responses]' \
  '(-silent --silent)--silent[display findings only]' \
  '(-nc --no-color)'{-nc,--no-color}'[disable output content coloring]' \
  '(-v --verbose)'{-v,--verbose}'[show verbose output]' \
  '(-svd --show-var-dump)'{-svd,--show-var-dump}'[show variables dump for debugging]' \
  '(-vv --verbose-verbose)'{-vv,--verbose-verbose}'[display extra verbose information]' \
  '(-ep --error-page)'{-ep,--error-page}'[optional file for error page]:file:_files' \
  '(-ud --update-directory)'{-ud,--update-directory}'[directory to store nuclei-templates]:dir:_files -/' \
  '(-duc --disable-update-check)'{-duc,--disable-update-check}'[disable automatic nuclei/templates update check]' \
  '(-up --update)'{-up,--update}'[update nuclei engine to the latest release]' \
  '(-ut --update-templates)'{-ut,--update-templates}'[update nuclei-templates to latest release]' \
  '(-un --update-template-dir)'{-un,--update-template-dir}'[custom directory to install/update nuclei-templates]:dir:_files -/' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-version --version)--version[show version]'
