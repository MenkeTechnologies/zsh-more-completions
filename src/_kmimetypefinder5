#compdef kmimetypefinder5

local -a arguments

arguments=(
  {-v,--version}'[displays version information.]'
  '(- * :)'{-h,--help}'[displays this help.]'
  '--author[show author information.]'
  '--license[show license information.]'
  '--desktopfile[the base file name of the desktop entry for this application]:name:'
  {-c,--content}'[use only the file content for determining the MIME type]'
  {-f,--filename-only}'[use only the file name for determining the MIME type]'
  '*:filename:_files'
)

_arguments -s -S $arguments
