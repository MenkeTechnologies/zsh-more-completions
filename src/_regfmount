#compdef regfmount
# Documentation: https://man.archlinux.org/search?q=regfmount
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-c[codepage of ASCII strings]'
  '-h[shows this help]'
  '-v[verbose output to stderr]'
  '-V[print version]'
  '-X[extended options to pass to sub system]'
  '*:filename:_files'
)

_arguments -s -S $arguments
