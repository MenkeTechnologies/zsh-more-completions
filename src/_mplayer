  '-audio-demuxer[select audio demuxer type]:type:' \
  '-autoq[automatically adjust quality]:quality:' \
  '-autosub[automatically load subtitle file with same name]' \
  '-benchmark[benchmark mode]' \
  '-bitexact[use only bit exact algorithms]' \
  '-brightness[adjust brightness]:value:(-100 -50 -25 0 25 50 100)' \
