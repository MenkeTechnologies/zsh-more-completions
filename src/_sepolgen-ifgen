#compdef sepolgen-ifgen

local -a arguments

arguments=(
  '--version[show programs version number and exit]'
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-o,--output}'[filename to store output]'
  {-i,--interfaces}'[location of the interface header files]'
  {-a,--attribute_info}'[location of attribute info file]:file:_files'
  {-p,--policy}'[policy file to use]:file:_files'
  {-v,--verbose}'[print debugging output]'
  {-d,--debug}'[extra debugging output]'
  '--no_attrs[do not retrieve attribute access from kernel policy]'
  '*:filename:_files'
)

_arguments -s -S $arguments
