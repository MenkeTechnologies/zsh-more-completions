#compdef qemu-nbd

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[display this help and exit]'
  {-V,--version}'[output version information and exit]'
  {-p,--port}'[port to listen on (default 10809)]:port: '
  {-b,--bind}'[interface to bind to (default 0.0.0.0)]:interface: '
  {-k,--socket}'[path to the unix socket]:path:_files'
  {-e,--shared}'[device can be shared by NUM clients (default 1)]:num: '
  {-t,--persistent}'[dont exit on the last connection]'
  {-v,--verbose}'[display extra debugging information]'
  {-o,--offset}'[offset into the image]:offset: '
  {-P,--partition}'[only expose partition NUM]:partition: '
  {-c,--connect}'[connect FILE to the local NBD device DEV]:device:_files'
  {-d,--disconnect}'[disconnect the specified device]:device:_files'
  {-r,--read-only}'[export read-only]'
  {-s,--snapshot}'[use snapshot file]'
  {-n,--nocache}'[disable host cache]'
  '--cache[set cache mode]:mode:(none writeback writethrough unsafe)'
  '--aio[set AIO mode]:mode:(native threads)'
  '*:filename:_files'
)

_arguments -s -S $arguments
