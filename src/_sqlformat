#compdef sqlformat

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-o,--outfile}'[write output to FILE (defaults to stdout)]'
  '--version[show programs version number and exit]'
  {-k,--keywords}'[change case of keywords, CHOICE is one of "upper"]'
  {-i,--identifiers}'[change case of identifiers, CHOICE is one of "upper"]'
  {-l,--language}'[output a snippet in programming language LANG, choices]'
  '--strip-comments[remove comments]'
  {-r,--reindent}'[reindent statements]'
  '--indent_width[indentation width (default: 2)]:width'
  {-a,--reindent_aligned}'[reindent statements to aligned format]'
  {-s,--use_space_around_operators}'[place spaces around mathematical operators]'
  '--wrap_after[column limit for wrapping (default: 0, no wrapping)]:width'
  '--comma_first[insert a newline before, not after, each comma in column lists]'
  '--encoding[specify the input encoding (default utf-8)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
