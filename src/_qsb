#compdef qsb

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[displays help on commandline options.]'
  '--help-all[displays help including Qt specific options.]'
  {-v,--version}'[displays version information.]'
  {-b,--batchable}'[also generates rewritten vertex shader for Qt]'
  '--zorder-loc[the extra vertex input location when rewriting]'
  '--glsl[comma separated list of GLSL versions to generate]'
  '--hlsl[comma separated list of HLSL (Shader Model) versions to generate]'
  '--msl[comma separated list of Metal Shading Language versions to generate]'
  '-g[generate full debug info for SPIR-V and DXBC]'
  '-O[invoke spirv-opt to optimize SPIR-V for performance]'
  {-o,--output}'[output file for the shader pack.]'
  {-c,--fxc}'[in combination with --hlsl invokes fxc to store]'
  {-t,--metallib}'[in combination with --msl builds a Metal library]'
  {-D,--define}'[value\]>  Define macro]'
  {-p,--per-target}'[enable per-target compilation (instead of combined)]'
  {-d,--dump}'[switches to dump mode. Input file is expected to be a .qsb file]'
  {-x,--extract}'[switches to extract mode. Input file is expected to be a .qsb file]'
  {-s,--silent}'[enables silent mode. Only fatal errors will be printed]'
  '*:filename:_files'
)

_arguments -s -S $arguments
