    'failover:start a coordinated failover'
    'flushall:remove all keys from all databases'
    'flushdb:remove all keys from the current database'
    'function:manage functions'
    'geoadd:add one or more geospatial items'
    'geodist:returns the distance between two members'
    'geohash:returns geohash strings'
    'geopos:returns longitude and latitude of members'
    'georadius:query a sorted set representing a geospatial index'
    'georadiusbymember:query a sorted set representing a geospatial index'
    'geosearch:query a sorted set representing a geospatial index'
    'geosearchstore:query and store geospatial results'
    'get:get the value of a key'
    'getbit:returns the bit value at offset in the string value stored at key'
    'getdel:get the value of a key and delete it'
    'getex:get the value of a key and optionally set its expiration'
    'getrange:get a substring of the string stored at a key'
    'getset:set the string value of a key and return its old value'
    'hdel:delete one or more hash fields'
    'hello:handshake with Redis'
    'hexists:determine if a hash field exists'
    'hget:get the value of a hash field'
    'hgetall:get all the fields and values in a hash'
    'hincrby:increment the integer value of a hash field by the given number'
    'hincrbyfloat:increment the float value of a hash field by the given amount'
    'hkeys:get all the fields in a hash'
    'hlen:get the number of fields in a hash'
    'hmget:get the values of all the given hash fields'
    'hmset:set multiple hash fields to multiple values'
    'hrandfield:get one or more random fields from a hash'
    'hscan:iterate hash fields'
    'hset:set the string value of a hash field'
    'hsetnx:set the value of a hash field, only if the field does not exist'
    'hvals:get all the values in a hash'
    'incr:increment the integer value of a key by one'
    'incrby:increment the integer value of a key by the given number'
    'incrbyfloat:increment the float value of a key by the given amount'
    'info:get information and statistics about the server'
    'json.get:get JSON value'
    'json.set:set JSON value'
    'keys:find all keys matching the given pattern'
    'lastsave:get the UNIX timestamp of the last successful save to disk'
    'latency:manage latency data'
    'lcs:find longest common substring'
    'lindex:get an element from a list by its index'
    'linsert:insert an element before or after another element in a list'
    'llen:get the length of a list'
    'lmove:pop an element from a list and push to another list'
    'lmpop:pop elements from list'
    'lpop:remove and get the first element in a list'
    'lpos:get position of element in list'
    'lpush:prepend one or more values to a list'
    'lpushx:prepend a value to a list, only if the list exists'
    'lrange:get a range of elements from a list'
    'lrem:remove elements from a list'
    'lset:set the value of an element in a list by its index'
    'ltrim:trim a list to the specified range'
    'memory:memory management commands'
    'mget:get the values of all the given keys'
    'module:manage modules'
    'monitor:listen for all requests received by the server in real time'
    'move:move a key to another database'
    'mset:set multiple keys to multiple values'
    'msetnx:set multiple keys to multiple values, only if none of the keys exist'
    'multi:mark the start of a transaction block'
    'object:inspect Redis object internals'
    'persist:remove the expiration from a key'
    'pexpire:set the time to live for a key, in milliseconds'
    'pexpireat:set the expiration for a key as a UNIX timestamp in milliseconds'
    'pexpiretime:get the expiration Unix timestamp in milliseconds for a key'
    'pfadd:add elements to a HyperLogLog'
    'pfcount:return the approximated cardinality of the set(s)'
    'pfmerge:merge multiple HyperLogLog values into a single one'
    'ping:ping the server'
    'psetex:set the value and expiration in milliseconds of a key'
    'psubscribe:listen for messages published to channels matching the given patterns'
    'pttl:get the time to live for a key in milliseconds'
    'publish:post a message to a channel'
    'pubsub:inspect the state of the Pub/Sub subsystem'
    'punsubscribe:stop listening for messages posted to channels matching the given patterns'
    'quit:close the connection'
    'randomkey:return a random key from the keyspace'
    'readonly:enable read queries for a connection to a cluster replica'
    'readwrite:disable read queries for a connection to a cluster replica'
    'rename:rename a key'
    'renamenx:rename a key, only if the new key does not exist'
    'replicaof:make the server a replica of another instance'
    'reset:reset the connection'
    'restore:create a key using a serialized value'
    'role:return the role of the server'
    'rpop:remove and get the last element in a list'
    'rpoplpush:remove the last element in a list, append it to another list and return it'
    'rpush:append one or more values to a list'
    'rpushx:append a value to a list, only if the list exists'
    'sadd:add one or more members to a set'
    'save:synchronously save the dataset to disk'
    'scan:incrementally iterate the keys space'
    'scard:get the number of members in a set'
    'script:manage Lua scripts'
    'sdiff:subtract multiple sets'
    'sdiffstore:subtract multiple sets and store the resulting set in a key'
    'select:change the selected database for the current connection'
    'sentinel:manage Redis Sentinel'
    'set:set the string value of a key'
    'setbit:sets or clears the bit at offset in the string value stored at key'
    'setex:set the value and expiration of a key'
    'setnx:set the value of a key, only if the key does not exist'
    'setrange:overwrite part of a string at key starting at the specified offset'
    'shutdown:synchronously save the dataset to disk and then shut down the server'
    'sinter:intersect multiple sets'
    'sintercard:return the number of members of the intersect of multiple sets'
    'sinterstore:intersect multiple sets and store the resulting set in a key'
    'sismember:determine if a given value is a member of a set'
    'slaveof:make the server a slave of another instance, or promote it as master'
    'slowlog:manage the slow log'
    'smembers:get all the members in a set'
    'smismember:determine if multiple values are members of a set'
    'smove:move a member from one set to another'
    'sort:sort the elements in a list, set or sorted set'
    'sort_ro:read-only variant of SORT'
    'spop:remove and return one or more random members from a set'
    'srandmember:get one or more random members from a set'
    'srem:remove one or more members from a set'
    'sscan:iterate set members'
    'strlen:get the length of the value stored in a key'
    'subscribe:listen for messages published to the given channels'
    'substr:get a substring of the string stored at a key'
    'sunion:add multiple sets'
    'sunionstore:add multiple sets and store the resulting set in a key'
    'swapdb:swap two databases'
    'time:return the current server time'
    'touch:alter the last access time of a key'
    'ttl:get the time to live for a key'
    'type:determine the type stored at key'
    'unlink:delete keys asynchronously'
    'unsubscribe:stop listening for messages posted to the given channels'
    'unwatch:forget about all watched keys'
    'wait:wait for replication'
    'waitaof:wait for AOF sync'
    'watch:watch the given keys to determine execution of the MULTI/EXEC block'
    'xack:acknowledge messages in a stream consumer group'
    'xadd:append a new entry to a stream'
    'xautoclaim:automatically transfer ownership of pending stream entries'
    'xclaim:change ownership of a pending stream entry'
    'xdel:delete entries from a stream'
    'xgroup:manage stream consumer groups'
    'xinfo:get information about streams and consumer groups'
    'xlen:get the number of entries in a stream'
    'xpending:get information about pending messages in a consumer group'
    'xrange:get a range of entries from a stream'
    'xread:read entries from one or more streams'
    'xreadgroup:read entries from a stream via a consumer group'
    'xrevrange:get a range of entries from a stream in reverse order'
    'xsetid:set the last delivered ID for a stream'
    'xtrim:trim a stream to a given number of entries'
    'zadd:add one or more members to a sorted set, or update scores'
    'zcard:get the number of members in a sorted set'
    'zcount:count the members in a sorted set with scores within the given values'
    'zdiff:subtract multiple sorted sets'
    'zdiffstore:subtract multiple sorted sets and store the resulting sorted set'
    'zincrby:increment the score of a member in a sorted set'
    'zinter:intersect multiple sorted sets'
    'zintercard:return the number of members of the intersect of multiple sorted sets'
    'zinterstore:intersect multiple sorted sets and store the resulting sorted set in a new key'
    'zlexcount:count the members in a sorted set between a given lexicographical range'
    'zmpop:pop elements from sorted set'
    'zmscore:get the scores of multiple members in a sorted set'
    'zpopmax:remove and return members with the highest scores in a sorted set'
    'zpopmin:remove and return members with the lowest scores in a sorted set'
    'zrandmember:get one or more random members from a sorted set'
    'zrange:return a range of members in a sorted set'
    'zrangebylex:return a range of members in a sorted set, by lexicographical range'
    'zrangebyscore:return a range of members in a sorted set, by score'
    'zrangestore:store a range of members from sorted set into another key'
    'zrank:determine the index of a member in a sorted set'
    'zrem:remove one or more members from a sorted set'
    'zremrangebylex:remove all members in a sorted set between the given lexicographical range'
    'zremrangebyrank:remove all members in a sorted set within the given indexes'
    'zremrangebyscore:remove all members in a sorted set within the given scores'
    'zrevrange:return a range of members in a sorted set, by index, scores high to low'
    'zrevrangebylex:return a range of members in a sorted set, by lexicographical range, reversed'
    'zrevrangebyscore:return a range of members in a sorted set, by score, scores high to low'
    'zrevrank:determine the index of a member in a sorted set, scores high to low'
    'zscan:iterate sorted set members'
    'zscore:get the score associated with the given member in a sorted set'
    'zunion:add multiple sorted sets'
    'zunionstore:add multiple sorted sets and store the resulting sorted set in a new key'
)

_arguments -s -S \
    '-h+[server hostname (default: 127.0.0.1)]:hostname:_hosts' \
    '-p+[server port (default: 6379)]:port' \
    '-t+[server connection timeout in seconds]:timeout (seconds)' \
    '-s+[server socket (overrides hostname and port)]:socket:_files' \
    '-a+[password to use when connecting to the server]:password' \
    '--user+[ACL username for authentication (needs -a)]:username' \
    '--pass+[alias of -a for consistency with --user]:password' \
    '--askpass[force user to input password with mask from STDIN]' \
    '-u+[server URI (redis://user\:password@host\:port/dbnum)]:URI' \
    '-r+[execute specified command N times]:repeat count' \
    '-i+[interval in seconds between commands when -r is used]:interval (seconds)' \
    '-n+[database number]:database number' \
    '--name+[set the client name]:client name' \
    '-2[start session in RESP2 protocol mode]' \
    '-3[start session in RESP3 protocol mode]' \
    '-x[read last argument from STDIN]' \
    '-X+[read tag argument from STDIN]:tag' \
    '-d+[delimiter between response bulks for raw formatting (default: \\n)]:delimiter' \
    '-D+[delimiter between responses for raw formatting (default: \\n)]:delimiter' \
    '-c[enable cluster mode (follow -ASK and -MOVED redirections)]' \
    '-e[return exit error code when command execution fails]' \
    '-4[prefer IPv4 over IPv6 on DNS lookup]' \
    '-6[prefer IPv6 over IPv4 on DNS lookup]' \
    '--tls[establish a secure TLS connection]' \
    '--sni+[server name indication for TLS]:hostname:_hosts' \
    '--cacert+[CA certificate file to verify with]:CA cert file:_files' \
    '--cacertdir+[directory where trusted CA certificates are stored]:CA cert dir:_directories' \
    '--insecure[allow insecure TLS connection by skipping cert validation]' \
    '--cert+[client certificate to authenticate with]:cert file:_files' \
    '--key+[private key file to authenticate with]:key file:_files' \
    '--tls-ciphers+[list of preferred ciphers for TLSv1.2 and below]:cipher list' \
    '--tls-ciphersuites+[list of preferred ciphersuites for TLSv1.3]:ciphersuite list' \
    '--raw[use raw formatting for replies (default when STDOUT is not a tty)]' \
    '--no-raw[force formatted output even when STDOUT is not a tty]' \
    '--quoted-input[force input to be handled as quoted strings]' \
    '--csv[output in CSV format]' \
    '--json[output in JSON format (default RESP3)]' \
    '--quoted-json[output in JSON format with ASCII-safe quoted strings]' \
    '--show-pushes+[whether to print RESP3 PUSH messages]:enabled:(yes no)' \
    '--stat[print rolling stats about server: mem, clients, ...]' \
    '--latency[enter a special mode continuously sampling latency]' \
    '--latency-history[like --latency but tracking latency changes over time]' \
    '--latency-dist[shows latency as a spectrum, requires xterm 256 colors]' \
    '--vset-recall+[enable VSIM recall test mode for a vector set key]:key' \
    '--vset-recall-count+[how many top elements to fetch per query]:count' \
    '--vset-recall-ef+[HNSW EF (search effort) to use (default: 500)]:ef' \
    '--vset-recall-ele+[number of elements used to compose query vectors (default: 1)]:count' \
    '--lru-test+[simulate a cache workload with an 80-20 distribution]:keys' \
    '--replica[simulate a replica showing commands received from the master]' \
    '--rdb+[transfer an RDB dump from remote server to local file]:filename:_files' \
    '--functions-rdb+[like --rdb but only get functions (not keys)]:filename:_files' \
    '--pipe[transfer raw Redis protocol from stdin to server]' \
    '--pipe-timeout+[in --pipe mode, abort with error after timeout (default: 30)]:timeout (seconds)' \
    '--bigkeys[sample Redis keys looking for keys with many elements]' \
    '--memkeys[sample Redis keys looking for keys consuming a lot of memory]' \
    '--memkeys-samples+[like --memkeys with custom number of samples]:sample count' \
    '--keystats[sample Redis keys for memory size and length (combine bigkeys and memkeys)]' \
    '--keystats-samples+[like --keystats with custom number of samples]:sample count' \
    '--cursor+[start the scan at the specified cursor]:cursor' \
    '--top+[display N top key sizes (default: 10)]:count' \
    '--hotkeys[sample Redis keys looking for hot keys (requires *lfu policy)]' \
    '--scan[list all keys using the SCAN command]' \
    '--pattern+[keys pattern for --scan, --bigkeys, --memkeys, --keystats, --hotkeys]:pattern' \
    '--count+[count option for --scan, --bigkeys, --memkeys, --keystats, --hotkeys (default: 10)]:count' \
    '--quoted-pattern+[same as --pattern but with quoted string support]:pattern' \
    '--intrinsic-latency+[run a test to measure intrinsic system latency]:duration (seconds)' \
    '--eval+[send an EVAL command using the Lua script at file]:script file:_files' \
    '--ldb[used with --eval to enable the Redis Lua debugger]' \
    '--ldb-sync-mode[like --ldb but uses the synchronous Lua debugger]' \
    '--cluster+[cluster manager command and arguments]:cluster command' \
    '--verbose[verbose mode]' \
    "--no-auth-warning[don't show warning when using password on command line]" \
    '(- *)--help[output help and exit]' \
    '(- *)--version[output version and exit]' \
    '*:: :->subcmds' && return

if (( CURRENT == 1 )); then
    _describe -t commands "redis-cli command" _1st_arguments
    return
fi
