#compdef p7zip

local -a arguments

arguments=(
  {-c,--stdout,--to-stdout}'[output data to stdout]'
  {-d,--decompress,--uncompress}'[file]'
  {-f,--force}'[do not ask questions]'
  {-k,--keep}'[keep original file]'
  '(- * :)'{-h,--help}'[print this help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
