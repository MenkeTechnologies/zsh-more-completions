#compdef neonctl

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'projects:manage Neon projects'
  'branches:manage branches'
  'databases:manage databases'
  'roles:manage roles'
  'operations:manage operations'
  'connection-string:get connection string'
  'cs:get connection string (alias)'
  'set-context:set project context'
  'completion:generate shell completion'
  'me:show current user'
  'orgs:manage organizations'
  'auth:authenticate with Neon'
  'ip-allow:manage IP allow list'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--api-key=[Neon API key]:key' \
  '--project-id=[project ID]:project id' \
  '--config-dir=[config directory]:directory:_directories' \
  '--output=[output format]:format:(json yaml table)' \
  '--no-color[disable color output]' \
  '--analytics[enable analytics]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'neonctl command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (projects)
        local -a proj_cmds=(
          'create:create a project'
          'list:list projects'
          'get:get project details'
          'update:update a project'
          'delete:delete a project'
        )
        _arguments \
          '1:subcommand:_describe -t proj-commands "project command" proj_cmds' \
          '*:args' && ret=0
        ;;
      (branches)
        local -a branch_cmds=(
          'create:create a branch'
          'list:list branches'
          'get:get branch details'
          'delete:delete a branch'
          'rename:rename a branch'
          'set-default:set default branch'
          'set-primary:set primary branch'
          'add-compute:add compute to a branch'
          'reset:reset a branch'
          'restore:restore a branch'
        )
        _arguments \
          '1:subcommand:_describe -t branch-commands "branch command" branch_cmds' \
          '*:args' && ret=0
        ;;
      (databases)
        local -a db_cmds=(
          'create:create a database'
          'list:list databases'
          'delete:delete a database'
        )
        _arguments \
          '1:subcommand:_describe -t db-commands "database command" db_cmds' \
          '*:args' && ret=0
        ;;
      (roles)
        local -a role_cmds=(
          'create:create a role'
          'list:list roles'
          'delete:delete a role'
        )
        _arguments \
          '1:subcommand:_describe -t role-commands "role command" role_cmds' \
          '*:args' && ret=0
        ;;
      (connection-string|cs)
        _arguments -s -S \
          '--branch=[branch name]:branch' \
          '--role-name=[role name]:role' \
          '--database-name=[database name]:database' \
          '--pooled[use pooled connection]' \
          '--prisma[generate Prisma connection string]' \
          '--extended[show extended connection details]' \
          '1:project id' && ret=0
        ;;
      (auth)
        _arguments '1:action:(login logout)' && ret=0
        ;;
    esac
    ;;
esac

return ret
