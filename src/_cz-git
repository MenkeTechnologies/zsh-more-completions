#compdef czg cz-git

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--retry[retry last failed commit]' \
  '--alias=[use a commit alias]:alias' \
  '--ai[generate AI commit message]' \
  '--hook[use in git hook mode]' \
  '--emoji[use emoji in commit message]' \
  '--no-emoji[do not use emoji]' \
  '--breaking-prompt[show breaking change prompt]' \
  '--issues-prompt[show issues prompt]' && ret=0

return ret
