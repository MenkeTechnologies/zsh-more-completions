#compdef rage

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-V,--version}'[display version]' \
  '(-d --decrypt -e --encrypt)'{-e,--encrypt}'[encrypt the input]' \
  '(-e --encrypt -d --decrypt)'{-d,--decrypt}'[decrypt the input]' \
  '(-p --passphrase)'{-p,--passphrase}'[encrypt with a passphrase]' \
  '*'{-r,--recipient}'[encrypt to specified recipient]:recipient' \
  '*'{-R,--recipients-file}'[encrypt to recipients listed in file]:recipients file:_files' \
  '(-i --identity)'{-i,--identity}'[use identity file for decryption]:identity file:_files' \
  '(-o --output)'{-o,--output}'[write output to file]:output file:_files' \
  '--armor[create ASCII armored output]' \
  '*:input file:_files' \
  && ret=0

return ret
