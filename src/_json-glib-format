#compdef json-glib-format
# Documentation: https://man.archlinux.org/search?q=json-glib-format
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  {-p,--prettify}'[prettify output]'
  {-i,--indent-spaces}'[indentation spaces]'
  '*:filename:_files'
)

_arguments -s -S $arguments
