#compdef kak

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '(- *)-l[list existing sessions]' \
  '(- *)-clear[clear dead sessions]' \
  '-c+[connect to given session]:session:->sessions' \
  '-s+[set the session name]:session name' \
  '-e+[execute argument on client startup]:command' \
  '-E+[execute argument on server startup]:command' \
  '-f+[enter filter mode and execute keys on selections]:keys' \
  '-i+[enter filter mode and execute keys on each input line]:keys' \
  '-q[in filter mode, be quiet about errors]' \
  '-p+[send command to given session]:session:->sessions' \
  '-d[run as a headless session (daemon)]' \
  '-n[do not source kakrc on startup]' \
  '-ro[enter in readonly mode]' \
  '-ui+[select user interface]:ui:(ncurses dummy json)' \
  '*:file:_files' && ret=0

case $state in
  (sessions)
    local -a sessions
    sessions=(${(f)"$(kak -l 2>/dev/null)"})
    _describe -t sessions 'session' sessions && ret=0
    ;;
esac

return ret
