#compdef idf2vrml
# Documentation: https://man.archlinux.org/search?q=idf2vrml
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-f[:<str> input file name]'
  '-s[:<double> scale factor]'
  '-k[produce KiCad-friendly VRML output; default is compact VRML]'
  '-d[suppress substitution of default outlines]'
  '-z[suppress rendering of zero-height outlines]'
  '-m[print object mapping to stdout for debugging]'
  '-h[display this message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
