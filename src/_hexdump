#compdef hexdump hd

local arguments

arguments=(
  '-b[one-byte octal display]'
  '-c[one-byte character display]'
  '-C[canonical hex+ASCII display]'
  '-d[two-byte decimal display]'
  '-o[two-byte octal display]'
  '-x[two-byte hexadecimal display]'
  '*-e+[format string to be used for displaying data]:format string:'
  '-f+[file that contains one or more format strings]:format file:_files'
  '-n+[interpret only specified number of bytes of input]:length:'
  '-s+[skip specified number of bytes from the beginning]:offset:'
  '-v[display all input data without squeezing identical lines]'
  '-V[output version information and exit]'
  '(- *)--help[display help information]'
  '(- *)--version[output version information and exit]'
  '*:file:_files'
)

_arguments -s $arguments
