#compdef onig-config
# Documentation: https://man.archlinux.org/search?q=onig-config
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--prefix[change prefix to DIR]'
  '--prefix[print prefix]'
  '--exec-prefix[change exec_prefix to DIR]'
  '--exec-prefix[print exec_prefix]'
  '--cflags[print C compiler flags]'
  '--libs[print library information]'
  '--version[print oniguruma version]'
  '--help[print this help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
