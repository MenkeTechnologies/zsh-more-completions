#compdef eslint

# Zsh completion for ESLint (v9+/flat config compatible)
# https://eslint.org/docs/latest/use/command-line-interface

_eslint() {
  local -a arguments

  arguments=(
    # Basic configuration
    '--no-config-lookup[Disable look up for eslint.config.js]'
    {-c,--config}'=[Use this configuration instead of eslint.config.js]:config file:_files'
    '--inspect-config[Open the config inspector with the current configuration]'
    '*--ext=[Specify additional file extensions to lint]:extension:'
    '*--global=[Define global variables]:variable:'
    '--parser=[Specify the parser to be used]:parser:'
    '--parser-options=[Specify parser options]:options:'
    '*--plugin=[Specify plugins]:plugin:'
    '--rule=[Specify rules]:rule:'

    # Deprecated v8 options (kept for backward compat)
    '--no-eslintrc[Disable use of configuration from .eslintrc.* (legacy)]'
    '*--env=[Specify environments (legacy)]:environment:'
    '--resolve-plugins-relative-to=[Folder where plugins should be resolved from]:dir:_directories'
    '*--rulesdir=[Use additional rules from this directory (legacy)]:dir:_directories'

    # Fix problems
    '--fix[Automatically fix problems]'
    '--fix-dry-run[Automatically fix problems without saving changes to the file system]'
    '--fix-type=[Specify the types of fixes to apply]:type:(directive problem suggestion layout)'

    # Ignore files
    '--no-ignore[Disable use of ignore files and patterns]'
    '*--ignore-pattern=[Pattern of files to ignore]:pattern:'
    '--ignore-path=[Specify path of ignore file (legacy)]:path:_files'

    # Stdin
    '--stdin[Lint code provided on <STDIN>]'
    '--stdin-filename=[Specify filename to process STDIN as]:filename:_files'

    # Handle warnings
    '--quiet[Report errors only]'
    '--max-warnings=[Number of warnings to trigger nonzero exit code]:count:'

    # Output
    {-o,--output-file}'=[Specify file to write report to]:output file:_files'
    {-f,--format}'=[Use a specific output format]:format:(checkstyle compact html jslint-xml json json-with-metadata junit stylish tap unix visualstudio)'
    '--color[Force enabling of color]'
    '--no-color[Force disabling of color]'

    # Inline configuration comments
    '--no-inline-config[Prevent comments from changing config or rules]'
    '--report-unused-disable-directives[Report errors for unused eslint-disable directives]'
    '--report-unused-disable-directives-severity=[Severity for unused eslint-disable directives]:severity:(off warn error 0 1 2)'
    '--report-unused-inline-configs=[Report errors for unused eslint inline config comments]:severity:(off warn error 0 1 2)'

    # Caching
    '--cache[Only check changed files]'
    '--cache-file=[Path to the cache file (deprecated, use --cache-location)]:path:_files'
    '--cache-location=[Path to the cache file or directory]:path:_files'
    '--cache-strategy=[Strategy for detecting changed files in the cache]:strategy:(metadata content)'

    # Suppressing violations
    '--suppress-all[Suppress all violations]'
    '*--suppress-rule=[Suppress specific rules]:rule:'
    '--suppressions-location=[Specify the location of the suppressions file]:path:_files'
    '--prune-suppressions[Prune unused suppressions]'
    '--pass-on-unpruned-suppressions[Ignore unused suppressions]'

    # Miscellaneous
    '--init[Run config initialization wizard]'
    '--env-info[Output execution environment information]'
    '--no-error-on-unmatched-pattern[Prevent errors when pattern is unmatched]'
    '--exit-on-fatal-error[Exit with exit code 2 in case of fatal error]'
    '--no-warn-ignored[Suppress warnings when the file list includes ignored files]'
    '--pass-on-no-patterns[Exit with exit code 0 in case no file patterns are passed]'
    '--debug[Output debugging information]'
    '--print-config=[Print the configuration for the given file]:file:_files'
    '--stats[Add statistics to the lint report]'
    '*--flag=[Enable a feature flag]:flag:'
    '--mcp[Start the ESLint MCP server]'
    '--concurrency=[Number of linting threads]:value:(auto off)'

    # Help/version
    '(- *)'{-h,--help}'[Show help]'
    '(- *)'{-v,--version}'[Output the version number]'

    '*:file or directory:_files'
  )

  _arguments -s -S $arguments
}

_eslint "$@"
