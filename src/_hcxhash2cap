#compdef hcxhash2cap
# Documentation: https://man.archlinux.org/search?q=hcxhash2cap
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-c[output cap file]'
  '--pmkid[input PMKID hash file]'
  '--hccapx[input hashcat hccapx file]'
  '--hccap[input hashcat hccap file]'
  '--john[input John the Ripper WPAPSK hash file]'
  '--help[show this help]'
  '--version[show version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
