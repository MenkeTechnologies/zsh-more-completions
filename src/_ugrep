#compdef ugrep

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[display help]' \
  '(- *)'{-V,--version}'[display version]' \
  {-A,--after-context}'[show N lines after match]:lines' \
  {-B,--before-context}'[show N lines before match]:lines' \
  {-C,--context}'[show N lines around match]:lines' \
  {-c,--count}'[only show count of matches]' \
  '--color[when to use color]:when:(auto always never)' \
  '--colours[when to use color]:when:(auto always never)' \
  '--config[use configuration file]:config file:_files' \
  '--confirm[confirm actions in -Q query UI]' \
  '--cpp[search C/C++ source files]' \
  '--csv[search CSV files]' \
  {-D,--devices}'[how to handle devices]:action:(read skip)' \
  {-d,--directories}'[how to handle directories]:action:(read recurse skip)' \
  {-e,--regexp}'[specify pattern]:pattern' \
  {-F,--fixed-strings}'[treat patterns as fixed strings]' \
  {-f,--file}'[read patterns from file]:file:_files' \
  '--filter[filter files through command]:command' \
  {-G,--basic-regexp}'[use basic regular expressions]' \
  {-g,--glob}'[search files matching glob]:glob pattern' \
  '--glob-ignore-case[case insensitive globbing]' \
  {-H,--with-filename}'[print filename for each match]' \
  {-h,--no-filename}'[suppress filename prefix]' \
  '--heading[group matches by file]' \
  '--hidden[search hidden files and directories]' \
  '--hyperlink[hyperlinks are enabled]' \
  {-I,--binary-without-match}'[assume binary files do not match]' \
  {-i,--ignore-case}'[case insensitive search]' \
  '--ignore-files[respect ignore files]:file name' \
  {-J,--jobs}'[number of threads]:threads' \
  {-j,--smart-case}'[smart case search]' \
  '--json[output in JSON format]' \
  {-K,--range}'[search only lines in range]:range (from,to)' \
  {-k,--column-number}'[show column number of match]' \
  {-L,--files-without-match}'[print names of files without matches]' \
  {-l,--files-with-matches}'[print names of files with matches]' \
  '--label[set filename label for stdin]:label' \
  {-M,--file-magic}'[restrict search by file magic]:magic' \
  {-m,--max-count}'[stop after N matches]:count' \
  '--match[match all input]' \
  '--max-depth[max directory depth]:depth' \
  '--min-depth[min directory depth]:depth' \
  {-N,--neg-regexp}'[specify negative pattern]:pattern' \
  {-n,--line-number}'[show line numbers]' \
  '--no-bool[disable Boolean query]' \
  '--no-confirm[do not confirm actions in query UI]' \
  '--no-hidden[do not search hidden files]' \
  '--no-ignore[do not respect ignore files]' \
  {-O,--file-extension}'[search files with extension]:extension' \
  {-o,--only-matching}'[show only matching part]' \
  '--only-line-number[only print line numbers]' \
  {-P,--perl-regexp}'[use Perl-compatible regex]' \
  {-p,--no-dereference}'[do not follow symbolic links]' \
  '--pager[pipe output through pager]:pager:_command_names -e' \
  {-Q,--query}'[interactive query UI]:delay (ms)' \
  {-q,--quiet}'[suppress all output]' \
  {-R,--dereference-recursive}'[recursively search, following symlinks]' \
  {-r,--recursive}'[recursively search directories]' \
  {-S,--dereference}'[follow symbolic links]' \
  {-s,--no-messages}'[suppress error messages]' \
  '--separator[set field separator]:separator' \
  '--sort[sort output]:key:(name best size changed created)' \
  '--stats[display search statistics]' \
  {-T,--initial-tab}'[align content with tab]' \
  {-t,--file-type}'[search files of specified type]:type' \
  '--tabs[set tab size]:size' \
  {-U,--binary}'[search binary files]' \
  {-u,--ungroup}'[do not group matches]' \
  {-W,--with-hex}'[output matches in hex]' \
  {-w,--word-regexp}'[match whole words only]' \
  {-X,--hex}'[output all in hex]' \
  {-x,--line-regexp}'[match whole lines only]' \
  '--xml[output in XML format]' \
  {-Y,--empty}'[match empty patterns]' \
  {-y,--any-line}'[any line matches]' \
  {-Z,--fuzzy}'[fuzzy matching]:max errors' \
  {-z,--decompress}'[search compressed files]' \
  '--zmax[max nested archive depth]:depth' \
  '(-):pattern' \
  '*:file or directory:_files' \
  && ret=0

return ret
