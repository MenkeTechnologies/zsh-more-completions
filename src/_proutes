#compdef proutes
# Documentation: https://man.archlinux.org/search?q=proutes
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-g,--glob}'[display routes matching glob pattern]'
  {-f,--format}'[choose which columns to display, this will override]'
  '*:filename:_files'
)

_arguments -s -S $arguments
