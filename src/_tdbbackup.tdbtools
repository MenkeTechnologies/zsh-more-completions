#compdef tdbbackup.tdbtools
# Documentation: https://man.archlinux.org/search?q=tdbbackup.tdbtools
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[this help message]'
  '-s[set the backup suffix]:suffix:'
  '-v[verify mode (restore if corrupt)]'
  '-n[set the new hash size for the backup]:size:'
  '-l[open without locking to back up mutex dbs]'
  '*:filename:_files'
)

_arguments -s -S $arguments
