#compdef tightvncserver
# Documentation: https://man.archlinux.org/search?q=tightvncserver
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-name[specify desktop name]:name:'
  '-depth[specify color depth in bits per pixel]:depth:'
  '-geometry[specify screen geometry]:geometry:'
  '-httpport[specify HTTP port number]:port:'
  '-basehttpport[specify base HTTP port number]:port:'
  '-alwaysshared[always treat new connections as shared]'
  '-nevershared[never treat new connections as shared]'
  '-pixelformat[specify pixel format (e.g. rgb888)]:format:'
  '*:filename:_files'
)

_arguments -s -S $arguments
