#compdef lychee

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config}'[config file]:file:_files -g "*.toml"' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-n --no-progress)'{-n,--no-progress}'[do not show progress bar]' \
  '--cache[use request cache]' \
  '--max-cache-age[max cache age]:duration' \
  '--dump[dump all found links]' \
  '--dump-inputs[dump all input sources]' \
  '--archive[suggest link replacements from Wayback Machine]' \
  '--suggest[suggest link replacements]' \
  '(-E --exclude)'{-E,--exclude}'[exclude URLs matching regex]:pattern' \
  '*--exclude-path[exclude file path matching glob]:pattern' \
  '--exclude-all-private[exclude all private network addresses]' \
  '--exclude-private[exclude private network addresses]' \
  '--exclude-link-local[exclude link-local addresses]' \
  '--exclude-loopback[exclude loopback addresses]' \
  '--exclude-mail[exclude email addresses]' \
  '*--include[include URL pattern]:pattern' \
  '*--remap[remap URL pattern]:pattern' \
  '--header[custom request header]:header' \
  '(-a --accept)'{-a,--accept}'[accepted status codes]:codes' \
  '(-t --timeout)'{-t,--timeout}'[request timeout]:seconds' \
  '(-r --retry-wait-time)'{-r,--retry-wait-time}'[retry wait time]:seconds' \
  '--max-retries[max retries]:count' \
  '--max-redirects[max redirects]:count' \
  '--max-concurrency[max concurrent requests]:count' \
  '(-T --threads)'{-T,--threads}'[number of threads]:count' \
  '(-u --user-agent)'{-u,--user-agent}'[custom user agent]:agent' \
  '--insecure[skip TLS verification]' \
  '(-s --scheme)'{-s,--scheme}'[only check specified schemes]:scheme' \
  '--offline[only check local files]' \
  '(-b --base)'{-b,--base}'[base URL]:url' \
  '--basic-auth[basic auth credentials]:user\:pass' \
  '--github-token[GitHub API token]:token' \
  '--skip-missing[skip missing input files]' \
  '--glob-ignore-case[case-insensitive globbing]' \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '(-f --format)'{-f,--format}'[output format]:format:(compact detailed json markdown)' \
  '--require-https[require HTTPS links]' \
  '--cookie-jar[cookie jar file]:file:_files' \
  '*:inputs:_files' && ret=0

return ret
