#compdef ar

# Zsh completion for ar (archive utility)

_ar() {
  local -a operations modifiers

  operations=(
    '-d[delete the specified archive files]'
    '-m[move the specified archive files within the archive]'
    '-p[write the contents of the specified archive files to stdout]'
    '-q[quickly append the specified files to the archive]'
    '-r[replace or add the specified files to the archive]'
    '-t[list the specified files in the archive]'
    '-x[extract the specified archive members into files]'
  )

  modifiers=(
    '-a[position files after the archive member position]'
    '-b[position files before the archive member position]'
    '-c[create the archive silently without informational message]'
    '-i[identical to the -b option]'
    '-l[place temporary files in the current directory]'
    '-o[preserve original access and modification times on extraction]'
    '-s[write an object-file index into the archive or update existing one]'
    '-S[do not generate an archive symbol table]'
    '-T[truncate archive member names to 15 characters]'
    '-L[use extended format to allow long archive member names]'
    '-u[only replace files with newer modification time]'
    '-v[provide verbose output]'
    '-V[display version information]'
    '--target[specify the target object format as BFDNAME]:bfdname:'
    '--plugin[load the specified plugin]:plugin:'
    '--output[specify the output directory for extraction]:directory:_directories'
    '--record-libdeps[specify library dependencies]:deps:'
    '--thin[create a thin archive]'
    '(- *)--help[display help information]'
    '(- *)--version[display version information]'
  )

  _arguments -s \
    $operations \
    $modifiers \
    '*:file:_files'
}

_ar "$@"
