#compdef k8sgpt

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'analyze:analyze Kubernetes resources'
      'auth:authenticate with AI backends'
      'cache:manage cache'
      'filters:manage filters'
      'generate:generate reports'
      'integration:manage integrations'
      'serve:start gRPC server'
      'version:print version'
      'completion:generate shell completion'
    )
    _describe -t commands 'k8sgpt command' commands && ret=0
    ;;
  args)
    case $words[1] in
      analyze)
        _arguments -s -S \
          '--explain[explain results using AI]' \
          {-b,--backend}'=[AI backend]:backend:(openai localai azureopenai cohere amazonbedrock amazonsagemaker google noopai)' \
          {-o,--output}'=[output format]:format:(text json)' \
          {-f,--filter}'=[filter]:filter' \
          {-n,--namespace}'=[namespace]:namespace' \
          {-l,--language}'=[language]:language' \
          '--anonymize[anonymize data]' \
          '--max-concurrency=[max concurrency]:concurrency' \
          '--with-doc[include documentation link]' \
          && ret=0
        ;;
      auth)
        _arguments -s -S -C \
          '1:subcommand:(add remove list update)' \
          && ret=0
        ;;
      cache)
        _arguments -s -S -C \
          '1:subcommand:(list remove)' \
          && ret=0
        ;;
      filters)
        _arguments -s -S -C \
          '1:subcommand:(list add remove)' \
          && ret=0
        ;;
      completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish powershell)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
