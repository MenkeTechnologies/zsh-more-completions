#compdef lbu_commit
# Documentation: https://man.archlinux.org/search?q=lbu_commit
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-d[remove old apk overlay files.]'
  '-e[protect configuration with a password.]'
  '-n[dont commit, just show what would have been commited.]'
  '-p[give encryption password on the command-line]'
  '-v[verbose mode.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
