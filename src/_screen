#compdef screen

# Completion for GNU Screen

_screen_sessions() {
  local -a sessions
  sessions=(${${(f)"$(screen -ls 2>/dev/null | sed -n 's/^\t\([^\t]*\).*/\1/p')"}})
  if (( ${#sessions} )); then
    _describe -t sessions 'screen session' sessions
  fi
}

_screen() {
  local curcontext="$curcontext" ret=1

  _arguments -s -S \
    '-4[resolve hostnames only to IPv4 addresses]' \
    '-6[resolve hostnames only to IPv6 addresses]' \
    '-a[force all capabilities into each window'\''s termcap]' \
    '-A[adapt all windows to the new display width and height]' \
    '-c[read specified configuration file instead of .screenrc]:config file:_files' \
    '-d[detach the elsewhere running screen (and reattach here)]:session:_screen_sessions' \
    '-D[detach and logout remote (and reattach here)]:session:_screen_sessions' \
    '-e[change command characters (default: Ctrl-A)]:command characters (xy)' \
    '-f[flow control on]' \
    '-fn[flow control off]' \
    '-fa[flow control automatic]' \
    '-h[set the size of the scrollback history buffer]:lines' \
    '-i[interrupt output sooner when flow control is on]' \
    '(-list -ls)'{-ls,-list}'[list existing screen sessions]' \
    '-L[turn on output logging]' \
    '-Logfile[set logfile name]:logfile:_files' \
    '-m[ignore $STY variable, do create a new screen session]' \
    '-O[choose optimal output rather than exact vt100 emulation]' \
    '-p[preselect the named window if it exists]:window name or number' \
    '-q[quiet startup, exit with non-zero return code if unsuccessful]' \
    '-Q[commands will send the response to the stdout of the querying process]' \
    '-r[reattach to a detached screen process]:session:_screen_sessions' \
    '-R[reattach if possible, otherwise start a new session]:session:_screen_sessions' \
    '-RR[do whatever is needed to get a screen session]:session:_screen_sessions' \
    '-s[shell to execute rather than $SHELL]:shell:_command_names' \
    '-S[name this session (used as <pid>.sockname)]:session name' \
    '-t[set title (window'\''s name)]:title' \
    '-T[use specified term as $TERM for windows, rather than "screen"]:terminal type:_terminals' \
    '-U[tell screen to use UTF-8 encoding]' \
    '(- *)-v[print Screen version]' \
    '-wipe[do nothing, just clean up SockDir]:session:_screen_sessions' \
    '-x[attach to a not detached screen (multi display mode)]:session:_screen_sessions' \
    '-X[execute command as a screen command in the specified session]:screen command' \
    '-dmS[start as daemon: screen session in detached mode]:session name' \
    '*:: :_files' \
    && ret=0

  return ret
}

_screen "$@"
