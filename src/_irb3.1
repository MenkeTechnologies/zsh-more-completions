#compdef irb3 irb3.1

local -a arguments

arguments=(
    '--version[print the version of irb]'
    '-E[set encoding]:encoding'
    '--encoding[same as ruby -E, set encoding]:encoding'
    '-I[specify $LOAD_PATH directory]:directory:_directories'
    '-U[same as ruby -U, set internal encoding to UTF-8]'
    '-d[set $DEBUG to true]'
    '-f[suppress read of ~/.irbrc]'
    '-w[same as ruby -w, enable warnings]'
    '-W[same as ruby -W, set warning level]:level'
    '-h[show help]'
    '--help[print a summary of the options]'
    '-r[load the library using require]:library'
    '--inspect[use inspect for output (default except for bc mode)]'
    '--noinspect[do not use inspect for output]'
    '--multiline[use multiline editor module]'
    '--nomultiline[do not use multiline editor module]'
    '--singleline[use singleline editor module]'
    '--nosingleline[do not use singleline editor module]'
    '--extra-doc-dir[add an extra doc dir for the doc dialog]:directory:_directories'
    '--echo[show result (default)]'
    '--noecho[do not show result]'
    '--echo-on-assignment[show result on assignment]'
    '--noecho-on-assignment[do not show result on assignment]'
    '--truncate-echo-on-assignment[show truncated result on assignment (default)]'
    '--colorize[use colorization]'
    '--nocolorize[do not use colorization]'
    '--autocomplete[use autocompletion]'
    '--noautocomplete[do not use autocompletion]'
    '--verbose[show details]'
    '--noverbose[do not show details]'
    '--prompt[switch prompt mode]:mode'
    '--prompt-mode[switch prompt mode]:mode'
    '--inf-ruby-mode[use prompt appropriate for inf-ruby-mode on emacs]'
    '--simple-prompt[make prompts simple]'
    '--noprompt[no prompt mode]'
    '--tracer[display trace for each execution of commands]'
    '--back-trace-limit[display backtrace top n and tail n, default 16]:n'
    '*:filename:_files'
)
_arguments -s -S $arguments
