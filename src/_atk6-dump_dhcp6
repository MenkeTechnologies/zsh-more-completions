#compdef atk6-dump_dhcp6
# Documentation: https://man.archlinux.org/search?q=atk6-dump_dhcp6
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-V[send vendorid number,string (e.g. 11,test)]'
  '-N[use fe80:: as source]'
  '-n[use empty mac as source]'
  '*:filename:_files'
)

_arguments -s -S $arguments
