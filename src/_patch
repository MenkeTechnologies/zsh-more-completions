#compdef patch

_arguments -s -S \
  {-p+,--strip=}'[strip NUM leading components from file names]:strip count' \
  {-F+,--fuzz=}'[set the fuzz factor to LINES for inexact matching]:lines' \
  {-l,--ignore-whitespace}'[ignore white space changes between patch and input]' \
  '(-e --ed -n --normal -u --unified)'{-c,--context}'[interpret the patch as a context difference]' \
  '(-c --context -n --normal -u --unified)'{-e,--ed}'[interpret the patch as an ed script]' \
  '(-c --context -e --ed -u --unified)'{-n,--normal}'[interpret the patch as a normal difference]' \
  '(-c --context -e --ed -n --normal)'{-u,--unified}'[interpret the patch as a unified difference]' \
  {-N,--forward}'[ignore patches that appear to be reversed or already applied]' \
  {-R,--reverse}'[assume patches were created with old and new files swapped]' \
  {-i+,--input=}'[read patch from PATCHFILE instead of stdin]:patch file:_files' \
  {-o+,--output=}'[output patched files to FILE]:output file:_files' \
  {-r+,--reject-file=}'[output rejects to FILE]:reject file:_files' \
  {-D+,--ifdef=}'[make merged if-then-else output using NAME]:symbol' \
  '--merge[merge using conflict markers instead of creating reject files]' \
  {-E,--remove-empty-files}'[remove output files that are empty after patching]' \
  '(-T --set-time)'{-Z,--set-utc}'[set times of patched files, assuming diff uses UTC]' \
  '(-Z --set-utc)'{-T,--set-time}'[set times of patched files, assuming local time]' \
  '--quoting-style=[output file names using quoting style]:style:(literal shell shell-always c escape)' \
  {-b,--backup}'[back up the original contents of each file]' \
  '--backup-if-mismatch[back up if the patch does not match exactly]' \
  '--no-backup-if-mismatch[do not back up mismatches unless otherwise requested]' \
  {-V+,--version-control=}'[use STYLE version control]:style:(t numbered nil existing never simple none)' \
  {-B+,--prefix=}'[prepend PREFIX to backup file names]:prefix' \
  {-Y+,--basename-prefix=}'[prepend PREFIX to backup file basenames]:prefix' \
  {-z+,--suffix=}'[append SUFFIX to backup file names]:suffix' \
  {-g+,--get=}'[get files from RCS etc.]:vcs option' \
  {-t,--batch}'[ask no questions; skip bad-Prereq patches; assume reversed]' \
  {-f,--force}'[assume user knows what they are doing; do not ask questions]' \
  {-s,--quiet,--silent}'[work silently unless an error occurs]' \
  '--verbose[output extra information about the work being done]' \
  '(-C --check --dry-run)'{-C,--check,--dry-run}'[do not actually change any files; just print what would happen]' \
  '--posix[conform to the POSIX standard]' \
  {-d+,--directory=}'[change the working directory to DIR first]:directory:_directories' \
  '--reject-format=[create context or unified rejects]:format:(context unified)' \
  '--binary[read and write data in binary mode]' \
  '--read-only=[how to handle read-only input files]:behavior:(warn fail ignore)' \
  {-x+,--debug=}'[set internal debugging flags]:number' \
  '(- *)'{-v,--version}'[output version info]' \
  '(- *)--help[output help]' \
  '*:file:_files'
