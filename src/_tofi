#compdef tofi tofi-run tofi-drun

# Zsh completion for tofi (Wayland launcher)

_arguments -s \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--config[configuration file]:file:_files' \
  '--prompt-text[prompt text]:string' \
  '--placeholder-text[placeholder text]:string' \
  '--font[font name or path]:font' \
  '--font-size[font size]:size' \
  '--background-color[background color]:color' \
  '--outline-width[outline width in pixels]:px' \
  '--outline-color[outline color]:color' \
  '--border-width[border width in pixels]:px' \
  '--border-color[border color]:color' \
  '--text-color[text color]:color' \
  '--prompt-color[prompt color]:color' \
  '--prompt-background[prompt background color]:color' \
  '--placeholder-color[placeholder color]:color' \
  '--input-color[input text color]:color' \
  '--input-background[input background color]:color' \
  '--default-result-color[default result color]:color' \
  '--default-result-background[default result background color]:color' \
  '--alternate-result-color[alternate result color]:color' \
  '--alternate-result-background[alternate result background color]:color' \
  '--selection-color[selection color]:color' \
  '--selection-background[selection background color]:color' \
  '--selection-match-color[selection match highlight color]:color' \
  '--width[window width]:size' \
  '--height[window height]:size' \
  '--corner-radius[corner radius in pixels]:px' \
  '--anchor[window anchor position]:position:(top bottom left right center top-left top-right bottom-left bottom-right)' \
  '--output[output/monitor name]:name' \
  '--margin-top[top margin]:px' \
  '--margin-bottom[bottom margin]:px' \
  '--margin-left[left margin]:px' \
  '--margin-right[right margin]:px' \
  '--padding-top[top padding]:px' \
  '--padding-bottom[bottom padding]:px' \
  '--padding-left[left padding]:px' \
  '--padding-right[right padding]:px' \
  '--result-spacing[spacing between results]:px' \
  '--num-results[number of results to show]:number' \
  '--horizontal[horizontal layout]:bool:(true false)' \
  '--min-input-width[minimum input width]:px' \
  '--hide-cursor[hide mouse cursor]:bool:(true false)' \
  '--text-cursor[show text cursor]:bool:(true false)' \
  '--history[enable history]:bool:(true false)' \
  '--history-file[history file path]:file:_files' \
  '--fuzzy-match[enable fuzzy matching]:bool:(true false)' \
  '--require-match[require match from list]:bool:(true false)' \
  '--auto-accept-single[auto-accept single match]:bool:(true false)' \
  '--print-index[print index of selection]:bool:(true false)' \
  '--drun-launch[launch desktop applications]:bool:(true false)' \
  '--terminal[terminal command for terminal apps]:command:_command_names' \
  '--hint-font[use font hinting]:bool:(true false)' \
  '--multi-instance[allow multiple instances]:bool:(true false)' \
  '--ascii-input[ASCII-only input]:bool:(true false)' \
  '--password-character[password mask character]:char' \
  '--clip-to-padding[clip to padding area]:bool:(true false)' \
  '--exclusive-zone[exclusive zone size]:size' \
  '--scale[enable scaling]:bool:(true false)' \
  '--late-keyboard-init[delay keyboard initialization]'
