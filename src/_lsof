#compdef lsof

local arguments

arguments=(
  '-a[AND selection conditions instead of OR]'
  '-b[avoid kernel functions that might block]'
  '-c[select processes by command name]:command name pattern'
  '+c[set the COMMAND column width]:width'
  '-d[select by file descriptor set]:FD set'
  '+d[search for open files in directory (non-recursive)]:directory:_directories'
  '+D[search for open files in directory tree (recursive)]:directory:_directories'
  '-E[display endpoint info for pipes and sockets]'
  '+E[display endpoint info and associated file(s)]'
  '*-f[control file system and file name interpretation]:flags:((c\:"file structure use count" g\:"file flag abbreviations" G\:"file flags in hex"))'
  '*+f[control file system and file name interpretation]:flags:((c\:"file structure use count" g\:"file flag abbreviations" G\:"file flags in hex"))'
  '-F[produce output for another program]:field identifiers'
  '-g[select by process group ID (exclude with ^)]:PGID set'
  '(- *)-h[display help]'
  '-i[select files by IPv4 or IPv6 address]:address specification'
  '-K[select tasks (threads)]:task selection'
  '-l[list UID numbers instead of login names]'
  '-L[list/suppress link counts]:link count'
  '+L[list files with link count less than specified]:link count'
  '+M[enable portmap registration reporting]'
  '-M[disable portmap registration reporting]'
  '-n[do not convert network numbers to host names]'
  '-N[select NFS files]'
  '-o[list file offset]:offset digits'
  '-O[do not avoid overhead of potentially blocking operations]'
  '-p[select by PID (exclude with ^)]:PID set'
  '-P[do not convert port numbers to port names]'
  '-R[list the Parent PID column]'
  '-r[repeat listing every t seconds (forever)]:interval (seconds)'
  '+r[repeat listing until no open files found]:interval (seconds)'
  '-s[list file size or select by protocol and state]:protocol\:state'
  '-S[set stat/lstat/readlink timeout]:timeout (seconds)'
  '-t[produce terse output with PID only]'
  '-T[control TCP/TPI information reporting]:info selection:((f\:"socket options and values" q\:"queue lengths" s\:"connection state"))'
  '-u[select by login name or UID (exclude with ^)]:user:_users'
  '-U[select UNIX domain socket files]'
  '(- *)-v[display version information]'
  '-V[indicate unsuccessfully searched-for items]'
  '-w[suppress warning messages]'
  '+w[enable warning messages]'
  '-x[cross over +d/+D symlinks or file systems]:crossover type:((f\:"file systems" l\:"symbolic links"))'
  '-X[skip reporting of TCP, UDP, and UDPLITE files]'
  '-z[specify SELinux security context]:context'
  '-Z[display SELinux security contexts]'
  '--[end option scan]'
  '*:file or name:_files'
)

_arguments -s -S $arguments
