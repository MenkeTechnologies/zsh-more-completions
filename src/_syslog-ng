#compdef syslog-ng

local arguments

arguments=(
  '(- *)'{-h,--help}'[display a brief help message]'
  '(- *)'{-V,--version}'[display version number and compilation information]'
  '--caps[run process with specified POSIX capability flags]:capability flags:'
  {-f,--cfgfile}'[set config file name]:config file:_files'
  {-C,--chroot}'[change root to specified directory]:chroot directory:_directories'
  '--check-startup[perform complete configuration initialization and exit]'
  {-c,--control}'[set syslog-ng control socket path]:control socket:_files'
  {-d,--debug}'[start in debug mode]'
  '--default-modules[comma-separated list of modules loaded automatically]:modules:'
  '--enable-core[enable writing core files in case of a crash]'
  {-e,--stderr}'[log internal messages to stderr]'
  '--fd-limit[set minimal number of required file descriptors]:fd limit:'
  {-F,--foreground}'[do not daemonize, run in the foreground]'
  {-g,--group}'[switch to specified group after initializing]:group:_groups'
  {-i,--interactive}'[enable interactive mode]'
  '--module-path[set colon-separated directories to search for modules]:module path:_dir_list'
  '--module-registry[display list and description of available modules]'
  '--no-caps[run as root without capability-support]'
  '--no-module-discovery[disable module auto-discovery]'
  {-R,--persist-file}'[set path of the persistent configuration file]:persist file:_files'
  {-p,--pidfile}'[set path to PID file]:pid file:_files'
  '--preprocess-into[write preprocessed configuration to file and quit]:output file:_files'
  '--process-mode[set how to run syslog-ng]:process mode:(foreground background safe-background)'
  {-S,--seed}'[does nothing, random generator seeding is autodetected]'
  {-s,--syntax-only}'[only read and parse config file, then exit]'
  '--config-id[parse config file, print configuration ID, and quit]'
  {-u,--user}'[switch to specified user after initializing]:user:_users'
  {-v,--verbose}'[enable verbose logging for troubleshooting]'
  '--worker-threads[set the number of worker threads]:number:'
  {-y,--yydebug}'[enable configuration parser debugging]'
)

_arguments -s $arguments
