#compdef mf2pt1

local -a arguments

arguments=(
  '--help[provide help on mf2pt1s command-line options.]'
  '--version[output the mf2pt1 version number, copyright, and license.]'
  '--comment[include a font comment, usually a copyright notice.]'
  '--designsize[specify the font design size in points.]'
  '--encoding[designate the font encoding]'
  '--family[specify the font family.]'
  {--fixedpitch,--nofixedpitch}'[assert that the font uses either monospaced or proportional spacing]'
  '--fontversion[specify the font version number]'
  '--fullname[designate the full font name (family plus modifiers).]'
  '--italicangle[designate the italic angle in degrees counterclockwise from the vertical]'
  '--name[provide the font name.]'
  '--underpos[specify the vertical position of the underline in thousandths of the font size]'
  '--underthick[specify the thickness of the underline in thousandths of the font size]'
  '--uniqueid[specify a globally unique font identifier.]'
  '--weight[provide a description of the font weight (e.g., Heavy)]'
  '--rounding[specify the fraction of a font unit to which coordinates are rounded]'
  '--bpppix[redefine the number of big points per pixel from 0.02 to number.]'
  '--ffscript[specify a FontForge script to execute]'
  '*:filename:_files'
)

_arguments -s -S $arguments
