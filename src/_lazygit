#compdef lazygit

# Zsh completion for lazygit - a simple terminal UI for git commands
# https://github.com/jesseduffield/lazygit

_lazygit() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -s -S \
    '(-f --filter)'{-f,--filter}'[comma-separated list of path filters]:path filter:_files' \
    '(-p --path)'{-p,--path}'[path of git repo]:repo path:_files -/' \
    '(-w --work-tree)'{-w,--work-tree}'[equivalent to the --work-tree git argument]:work tree path:_files -/' \
    '(-g --git-dir)'{-g,--git-dir}'[equivalent to the --git-dir git argument]:git dir path:_files -/' \
    '(-v --version)'{-v,--version}'[print the current version]' \
    '(-d --debug)'{-d,--debug}'[run in debug mode with logging]' \
    '(-l --log)'{-l,--log}'[enable file logging]' \
    '--use-config-dir[override the default config directory]:config dir:_files -/' \
    '(-ucf --use-config-file)'{-ucf,--use-config-file}'[comma-separated list of config files to use]:config files:_files' \
    '--print-config-dir[print the config directory and exit]' \
    '--print-default-config[print the default config to stdout]' \
    '(-h --help)'{-h,--help}'[display help information]' \
    '--tail[tail lazygit log and exit]' \
    '(-c --config)'{-c,--config}'[print the default config (deprecated, use --print-default-config)]' \
    '*:git file:_files'
}

_lazygit "$@"
