#compdef tzselect
# Documentation: https://man.archlinux.org/search?q=tzselect
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-c[instead of asking for continent and then country and then city]'
  '-n[display at most LIMIT locations when -c is used (default 10).]'
  '--version[output version information.]'
  '--help[output this help.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
