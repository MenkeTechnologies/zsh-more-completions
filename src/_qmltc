#compdef qmltc
# Documentation: https://man.archlinux.org/search?q=qmltc
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[displays help on commandline options.]'
  '--help-all[displays help including Qt specific options.]'
  {-v,--version}'[displays version information.]'
  '-I[look for QML modules in specified directory]'
  '-i[include extra qmldir files]'
  '--impl[generated C++ source file path]'
  '--header[generated C++ header file path]'
  '--resource-path[Qt resource file path corresponding to the file being compiled]'
  '--resource[Qt resource file that might later contain compiled output]'
  '--namespace[namespace of the generated C++ code]'
  '*:filename:_files'
)

_arguments -s -S $arguments
