#compdef rpm

# Completion for RPM Package Manager

_rpm_query_format() {
  local -a tags
  tags=(${${(f)"$(rpm --querytags 2>/dev/null)"}})
  _describe -t tags 'query tag' tags
}

_rpm() {
  local curcontext="$curcontext" ret=1

  # Main mode options (mutually exclusive)
  local -a mode_options
  mode_options=(
    '(-q --query -i --install -U --upgrade -F --freshen -e --erase --reinstall -V --verify --import --checksig --initdb --rebuilddb --showrc --querytags)'{-q,--query}'[query packages]'
    '(-q --query -i --install -U --upgrade -F --freshen -e --erase --reinstall -V --verify --import --checksig --initdb --rebuilddb --showrc --querytags)'{-i,--install}'[install package(s)]'
    '(-q --query -i --install -U --upgrade -F --freshen -e --erase --reinstall -V --verify --import --checksig --initdb --rebuilddb --showrc --querytags)'{-U,--upgrade}'[upgrade package(s)]'
    '(-q --query -i --install -U --upgrade -F --freshen -e --erase --reinstall -V --verify --import --checksig --initdb --rebuilddb --showrc --querytags)'{-F,--freshen}'[upgrade package(s) if already installed]'
    '(-q --query -i --install -U --upgrade -F --freshen -e --erase --reinstall -V --verify --import --checksig --initdb --rebuilddb --showrc --querytags)'{-e,--erase}'[erase (uninstall) package]'
    '(-q --query -i --install -U --upgrade -F --freshen -e --erase --reinstall -V --verify --import --checksig --initdb --rebuilddb --showrc --querytags)--reinstall[reinstall package(s)]'
    '(-q --query -i --install -U --upgrade -F --freshen -e --erase --reinstall -V --verify --import --checksig --initdb --rebuilddb --showrc --querytags)'{-V,--verify}'[verify installed packages]'
    '(-q --query -i --install -U --upgrade -F --freshen -e --erase --reinstall -V --verify --import --checksig --initdb --rebuilddb --showrc --querytags)--import[import an armored public key]'
    '(-q --query -i --install -U --upgrade -F --freshen -e --erase --reinstall -V --verify --import --checksig --initdb --rebuilddb --showrc --querytags)--checksig[verify a package signature]'
    '(-q --query -i --install -U --upgrade -F --freshen -e --erase --reinstall -V --verify --import --checksig --initdb --rebuilddb --showrc --querytags)--initdb[create a new RPM database]'
    '(-q --query -i --install -U --upgrade -F --freshen -e --erase --reinstall -V --verify --import --checksig --initdb --rebuilddb --showrc --querytags)--rebuilddb[rebuild RPM database from installed package headers]'
    '(- *)--showrc[display final rpmrc and macro configuration]'
    '(- *)--querytags[display known query tags]'
  )

  # Package selection options (for query/verify)
  local -a select_options
  select_options=(
    {-a,--all}'[query/verify all packages]'
    {-f,--file}'[query/verify package(s) owning file]:file:_files'
    {-g,--group}'[query/verify package(s) in group]:group'
    {-p,--package}'[query/verify an uninstalled package file]:package file:_files -g "*.rpm(-.)"'
    '--pkgid[query/verify package(s) with package identifier]:package id'
    '--hdrid[query/verify package(s) with header identifier]:header id'
    '--tid[query/verify package(s) with transaction identifier]:transaction id'
    '--triggeredby[query packages triggered by package]:package'
    '--whatrequires[query packages that require a capability]:capability'
    '--whatprovides[query packages that provide a capability]:capability'
    '--whatrecommends[query packages that recommend a capability]:capability'
    '--whatsuggests[query packages that suggest a capability]:capability'
    '--whatsupplements[query packages that supplement a capability]:capability'
    '--whatenhances[query packages that enhance a capability]:capability'
    '--whatobsoletes[query packages that obsolete a capability]:capability'
    '--whatconflicts[query packages that conflict with a capability]:capability'
    '--nomanifest[do not process non-package files as manifests]'
  )

  # Query output options
  local -a query_options
  query_options=(
    {-c,--configfiles}'[list all configuration files]'
    {-d,--docfiles}'[list all documentation files]'
    {-L,--licensefiles}'[list all license files]'
    {-A,--artifactfiles}'[list all artifact files]'
    '--dump[dump basic file information]'
    {-l,--list}'[list files in package]'
    '--queryformat=[use the specified query format]:format string'
    '--qf=[use the specified query format (alias for --queryformat)]:format string'
    {-s,--state}'[display the states of the listed files]'
    '--scripts[list install/erase scriptlets from package(s)]'
    '--setperms[set permissions of files in a package]'
    '--setugids[set user/group ownership of files in a package]'
    '--setcaps[set capabilities of files in a package]'
    '--conflicts[list capabilities this package conflicts with]'
    '--obsoletes[list other packages removed by installing this package]'
    '--provides[list capabilities that this package provides]'
    {-R,--requires}'[list capabilities required by package(s)]'
    '--recommends[list capabilities recommended by package(s)]'
    '--suggests[list capabilities suggested by package(s)]'
    '--supplements[list capabilities supplemented by package(s)]'
    '--enhances[list capabilities enhanced by package(s)]'
    '--info[list descriptive information from package(s)]'
    '--changelog[list change logs for this package]'
    '--changes[list changes for this package with full timestamps]'
    '--xml[list metadata in XML]'
    '--triggers[list trigger scriptlets from package(s)]'
    '--filetriggers[list filetrigger scriptlets from package(s)]'
    '--last[list package(s) by install time, most recent first]'
    '--dupes[list duplicated packages]'
    '--filesbypkg[list all files from each package]'
    '--fileclass[list file names with their classes]'
    '--filecolor[list file names with their colors]'
    '--fileprovide[list file names with their provides]'
    '--filerequire[list file names with their requires]'
    '--filecaps[list file names with their POSIX1.e capabilities]'
  )

  # Verify options
  local -a verify_options
  verify_options=(
    '--nofiledigest[do not verify digest of files]'
    '--nofiles[do not verify files in package]'
    '--nodeps[do not verify package dependencies]'
    '--noscript[do not execute verify script(s)]'
    '--nosize[do not verify file size]'
    '--nomode[do not verify file mode]'
    '--nomtime[do not verify file modification time]'
    '--nordev[do not verify device type]'
    '--nouser[do not verify file owner]'
    '--nogroup[do not verify file group]'
    '--nolinks[do not verify file hardlinks]'
    '--nolinkto[do not verify symlink target]'
  )

  # Install/upgrade/erase options
  local -a install_options
  install_options=(
    '--allfiles[install all files, even configurations which might be skipped]'
    '--allmatches[remove all packages which match (normally an error if multiple)]'
    '--badreloc[relocate files in non-relocatable package]'
    '--excludedocs[do not install documentation]'
    '--excludepath=[skip files with leading component]:path:_files -/'
    '--force[short hand for --replacepkgs --replacefiles]'
    {-h,--hash}'[print hash marks as package installs (good with -v)]'
    '--ignorearch[do not verify package architecture]'
    '--ignoreos[do not verify package operating system]'
    '--ignoresize[do not check disk space before installing]'
    '--justdb[update the database, but do not modify the filesystem]'
    '--nocontexts[do not install file security contexts]'
    '--nocaps[do not install file capabilities]'
    '--nodeps[do not verify package dependencies]'
    '--nodigest[do not verify package digest(s)]'
    '--noorder[do not reorder package installation to satisfy dependencies]'
    '--noscripts[do not execute package scriptlet(s)]'
    '--nosignature[do not verify package signature(s)]'
    '--notriggers[do not execute any scriptlet(s) triggered by this package]'
    '--oldpackage[upgrade to an old version of the package (--force on upgrades does this)]'
    '--percent[print percentages as package installs]'
    '--prefix=[relocate the package to directory]:directory:_files -/'
    '--relocate=[relocate files from path old to new]:old=new'
    '--replacefiles[ignore file conflicts between packages]'
    '--replacepkgs[reinstall if the package is already present]'
    '--test[do not install, but tell if it would work or not]'
    '--noplugins[do not enable any plugins]'
  )

  # General/global options
  local -a general_options
  general_options=(
    '(- *)--version[print the version of rpm being used]'
    '(- *)--usage[display brief usage message]'
    {-D,--define}'=[define MACRO with value EXPR]:macro expression'
    '--undefine=[undefine MACRO]:macro name'
    {-E,--eval}'=[print macro expansion of expression]:expression'
    '--target=[specify target platform]:platform'
    '--macros=[read specified macro file(s) instead of default]:macro file:_files'
    '--noplugins[do not enable any plugins]'
    '--nodigest[do not verify package digest(s)]'
    '--nosignature[do not verify package signature(s)]'
    '--rcfile=[read specified file(s) instead of default rpmrc]:rc file:_files'
    {-r,--root}'=[use ROOT as top level directory]:root directory:_files -/'
    '--dbpath=[use database in specified directory]:database directory:_files -/'
    '--quiet[provide less detailed output]'
    {-v,--verbose}'[provide more detailed output]'
    '-vv[provide debug-level output]'
    '--pipe=[send stdout to specified command]:command:_command_names'
  )

  _arguments -s -S \
    $mode_options \
    $select_options \
    $query_options \
    $verify_options \
    $install_options \
    $general_options \
    '*:package or file:_files' \
    && ret=0

  return ret
}

_rpm "$@"
