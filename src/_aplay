#compdef aplay

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[help]'
  '--version[print current version]'
  {-l,--list-devices}'[list all soundcards and digital audio devices]'
  {-L,--list-pcms}'[list device names]'
  {-D,--device}'[select PCM by name]:device name: '
  {-q,--quiet}'[quiet mode]'
  {-t,--file-type}'[file type (voc, wav, raw or au)]:type:(voc wav raw au)'
  {-c,--channels}'[channels]:number: '
  {-f,--format}'[sample format (case insensitive)]:format: '
  {-r,--rate}'[sample rate]:rate: '
  {-d,--duration}'[interrupt after # seconds]:seconds: '
  {-M,--mmap}'[mmap stream]'
  {-N,--nonblock}'[nonblocking mode]'
  {-F,--period-time}'[distance between interrupts is # microseconds]:microseconds: '
  {-B,--buffer-time}'[buffer duration is # microseconds]:microseconds: '
  '--period-size[distance between interrupts is # frames]:frames: '
  '--buffer-size[buffer duration is # frames]:frames: '
  {-A,--avail-min}'[min available space for wakeup is # microseconds]:microseconds: '
  {-R,--start-delay}'[delay for automatic PCM start is # microseconds]:microseconds: '
  {-T,--stop-delay}'[delay for automatic PCM stop is # microseconds from xrun]:microseconds: '
  {-v,--verbose}'[show PCM structure and setup (accumulative)]'
  {-V,--vumeter}'[enable VU meter]:type:(mono stereo)'
  {-I,--separate-channels}'[file for each channel]'
  {-i,--interactive}'[allow interactive operation from stdin]'
  {-m,--chmap}'[give the channel map to override or follow]:channel map: '
  '--disable-resample[disable automatic rate resample]'
  '--disable-channels[disable automatic channel conversions]'
  '--disable-format[disable automatic format conversions]'
  '--disable-softvol[disable software volume control (softvol)]'
  '--test-position[test ring buffer position]'
  '--test-coef[test coefficient for ring buffer position (default 8)]:coefficient: '
  '--test-nowait[do not wait for ring buffer - eats whole CPU]'
  '--max-file-time[start another output file when the old file has recorded for this duration]:seconds: '
  '--process-id-file[write the process ID here]:file:_files'
  '--use-strftime[apply the strftime facility to the output file name]'
  '--dump-hw-params[dump hw_params of the device]'
  '--fatal-errors[treat all errors as fatal]'
  '*:filename:_files'
)

_arguments -s -S $arguments
