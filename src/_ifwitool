#compdef ifwitool
# Documentation: https://man.archlinux.org/search?q=ifwitool
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '-f[specify input file]:filename:_files'
    '-s[use the second Logical Boot Partition]'
    '-d[perform directory operation]'
    '-e[extract partition]'
    '-v[verbose level]'
    '-h[show help]'
    '-n[dry run, do not write changes]'
    '*:filename:_files'
)
_arguments -s -S $arguments
