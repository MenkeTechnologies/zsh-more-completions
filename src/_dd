#compdef dd

# Completion for dd
# Reference: man dd (macOS/BSD and GNU coreutils)

# Helper function for conv values (comma-separated)
local -a conv_values iflag_values oflag_values

conv_values=(
  'ascii:convert EBCDIC to ASCII'
  'oldascii:convert EBCDIC to ASCII (historic mapping)'
  'ebcdic:convert ASCII to EBCDIC'
  'oldebcdic:convert ASCII to EBCDIC (historic mapping)'
  'ibm:convert ASCII to IBM EBCDIC'
  'oldibm:convert ASCII to IBM EBCDIC (historic mapping)'
  'block:pad newline-terminated records to cbs-size'
  'unblock:replace trailing spaces in cbs-sized records with newline'
  'lcase:transform uppercase to lowercase'
  'ucase:transform lowercase to uppercase'
  'sparse:try to seek rather than write NUL output blocks'
  'swab:swap every pair of input bytes'
  'sync:pad every input block to ibs with NULs'
  'excl:fail if the output file already exists (GNU)'
  'nocreat:do not create the output file (GNU)'
  'notrunc:do not truncate the output file'
  'noerror:continue after read errors'
  'fdatasync:physically write output file data before finishing (GNU)'
  'fsync:physically write output data and metadata before finishing'
  'osync:pad the final output block to obs size'
  'pareven:set output parity to even'
  'parodd:set output parity to odd'
  'parset:set output parity bit'
  'parnone:strip parity bit on output'
)

iflag_values=(
  'fullblock:accumulate full blocks of input'
  'direct:bypass local caching for input'
  'append:append mode (GNU)'
  'directory:fail unless a directory (GNU)'
  'dsync:use synchronized I/O for data (GNU)'
  'sync:use synchronized I/O for data and metadata (GNU)'
  'nonblock:use non-blocking I/O (GNU)'
  'noatime:do not update access time (GNU)'
  'nocache:request to drop cache (GNU)'
  'noctty:do not assign controlling terminal (GNU)'
  'nofollow:do not follow symbolic links (GNU)'
  'count_bytes:treat count as a byte count (GNU)'
  'skip_bytes:treat skip as a byte count (GNU)'
)

oflag_values=(
  'fsync:use synchronized I/O for data and metadata'
  'sync:use synchronized I/O (synonym for fsync)'
  'direct:bypass local caching for output'
  'append:append mode (GNU)'
  'directory:fail unless a directory (GNU)'
  'dsync:use synchronized I/O for data (GNU)'
  'nonblock:use non-blocking I/O (GNU)'
  'noatime:do not update access time (GNU)'
  'nocache:request to drop cache (GNU)'
  'noctty:do not assign controlling terminal (GNU)'
  'nofollow:do not follow symbolic links (GNU)'
  'count_bytes:treat count as a byte count (GNU)'
  'seek_bytes:treat seek as a byte count (GNU)'
)

_arguments -s -S \
  'bs=[set both input and output block size]:block size (bytes):' \
  'cbs=[set conversion record size]:record size (bytes):' \
  'conv=[convert the file as per comma-separated keyword list]: :_values -s , "conversion" ${conv_values}' \
  'count=[copy only N input blocks]:number of blocks:' \
  'files=[copy N input files before terminating (tape)]:number of files:' \
  'fillchar=[fill character for padding]:ASCII character:' \
  'ibs=[set input block size]:input block size (bytes):' \
  'if=[read from file instead of stdin]:input file:_files' \
  'iflag=[read as per comma-separated flag list]: :_values -s , "input flag" ${iflag_values}' \
  'iseek=[seek on input file N blocks (synonym for skip)]:blocks:' \
  'obs=[set output block size]:output block size (bytes):' \
  'of=[write to file instead of stdout]:output file:_files' \
  'oflag=[write as per comma-separated flag list]: :_values -s , "output flag" ${oflag_values}' \
  'oseek=[seek on output file N blocks (synonym for seek)]:blocks:' \
  'seek=[skip N obs-sized output blocks at start of output]:blocks:' \
  'skip=[skip N ibs-sized input blocks at start of input]:blocks:' \
  'speed=[limit copying speed]:bytes per second:' \
  'status=[level of information to print to stderr]:level:(none noxfer progress)'
