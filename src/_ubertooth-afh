#compdef ubertooth-afh

local -a arguments

arguments=(
  '-l[LAP of target piconet (3 bytes / 6 hex digits)]'
  '-u[UAP of target piconet (1 byte / 2 hex digits)]'
  '-m[threshold for channel removal (default: 5)]'
  '-r[AFH channel map once every second (default: print on update)]'
  '-t[timeout for initial AFH map detection (not required)]'
  '-e[access code errors (default: 2, range: 0-4)]'
  '-V[version information]'
  '-U[set ubertooth device to use]:device:(0 1 2 3 4 5 6 7)'
  '*:filename:_files'
)

_arguments -s -S $arguments
