#compdef geod


local -a arguments

arguments=(
    '-I[Specifies that the inverse geodesic computation is to be performed.]'
    '-a[specify semi-major axis of ellipsoid]:value'
    '-le[list all available ellipsoids]'
    '-lu[list all available units]'
    '-f[printf format string for geodesic output]:format'
    '-F[printf format string for distance output]:format'
    '-p[output azimuthal values as unsigned DMS numbers]'
    '*:filename:_files'
)
_arguments -s -S $arguments
