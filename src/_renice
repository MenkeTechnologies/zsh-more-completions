#compdef renice
# Documentation: https://man.archlinux.org/search?q=renice
# Reference accessed: 2026-05-16

# renice - alter priority of running processes
# Part of util-linux

_arguments -s -S \
  {-n,--priority}'[specify the nice increment value]:priority' \
  '(-g --pgrp -u --user)'{-p,--pid}'[interpret arguments as process IDs (default)]:*:pid:_pids' \
  '(-p --pid -u --user)'{-g,--pgrp}'[interpret arguments as process group IDs]:*:pgid:' \
  '(-p --pid -g --pgrp)'{-u,--user}'[interpret arguments as usernames or user IDs]:*:user:_users' \
  '(- *)'{-h,--help}'[display help text and exit]' \
  '(- *)'{-V,--version}'[display version information and exit]'
