#compdef bridge
# Documentation: https://man.archlinux.org/search?q=bridge
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-o[output each record on a single line]'
  '-t[display current time when using monitor option]'
  '-n[switch to the specified network namespace]:netns:'
  '-c[use color output]'
  '-p[produce pretty output]'
  '-j[produce JSON output]'
  '*:filename:_files'
)

_arguments -s -S $arguments
