#compdef ifittool


local -a arguments

arguments=(
    '--add-entry[Add a CBFS file as new entry to FIT.]'
    '--add-region[Add region as new entry to FIT (for microcodes).]'
    '--del-entry[Delete existing <number> entry.]::'
    '--set-fit-pointer[Set the FIT pointer to a CBFS file.]'
    '--fit-type[Type of new entry.]'
    '--name[the CBFS filename or region to add to table]:name'
    '--help[Display this text.]'
    '--header-offset[Do not search for header, use this offset.]'
    '--verbose[Be verbose.]'
    '--dump[Dump FIT table (at end of operation).]'
    '--clear-table[Remove all existing entries (do not update).]'
    '--topswap-size[use second FIT table if non-zero]:size'
    '--file[The file containing the CBFS.]:name'
    '--max-table-size[The number of possible FIT entries in table.]'
    '--region[the FMAP region to operate on]:region'
    '-a[Add a CBFS file as new entry to FIT.]'
    '-A[Add region as new entry to FIT (for microcodes).]'
    '-d[Delete existing <number> entry.]::'
    '-F[Set the FIT pointer to a CBFS file.]'
    '-t[Type of new entry.]'
    '-n[the CBFS filename or region to add to table]:name'
    '-h[Display this text.]'
    '-H[Do not search for header, use this offset.]'
    '-v[Be verbose.]'
    '-D[Dump FIT table (at end of operation).]'
    '-c[Remove all existing entries (do not update).]'
    '-j[use second FIT table if non-zero]:size'
    '-f[The file containing the CBFS.]:name'
    '-s[The number of possible FIT entries in table.]'
    '-r[The FMAP region to operate on.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
