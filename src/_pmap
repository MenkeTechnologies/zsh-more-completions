#compdef pmap

# Zsh completion for pmap (procps-ng / procps)
# pmap reports the memory map of a process

_pmap() {
  _arguments -s -S \
    '(-x --extended -X -XX)'{-x,--extended}'[show the extended format]' \
    '(-x --extended -X -XX)-X[show even more details than -x]' \
    '(-x --extended -X -XX)-XX[show everything the kernel provides]' \
    {-c,--read-rc}'[read the default rc]' \
    {-C,--read-rc-from=}'[read the rc from file]:rc file:_files' \
    {-n,--create-rc}'[create new default rc]' \
    {-N,--create-rc-to=}'[create new rc to file]:rc file:_files' \
    {-d,--device}'[show the device format]' \
    {-q,--quiet}'[do not display header and footer]' \
    {-p,--show-path}'[show path in the mapping]' \
    {-A,--range=}'[limit results to the given range low,high]:address range (low,high):' \
    '(- *)'{-h,--help}'[display this help and exit]' \
    '(- *)'{-V,--version}'[output version information and exit]' \
    '*:process ID:_pids'
}

_pmap "$@"
