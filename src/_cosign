#compdef cosign

# Zsh completion for Cosign - container signing, verification, and storage

local curcontext="$curcontext" state line ret=1

_cosign_commands() {
  local -a commands=(
    'attach:attach signatures to images'
    'attest:attest an image, creating an attestation'
    'blob:interact with blobs'
    'clean:remove cosign signatures from an image'
    'completion:generate shell completion'
    'copy:copy the supplied container image and signatures'
    'dockerfile:interact with Dockerfiles'
    'download:download artifacts from images'
    'env:print cosign environment variables'
    'generate:generate the payload to sign'
    'generate-key-pair:generate a key pair'
    'import-key-pair:import a PEM-encoded RSA or EC key pair'
    'initialize:initializes SigStore root to retrieve targets'
    'load:load a signed image on disk to a remote registry'
    'login:log in to a registry'
    'manifest:interact with manifests'
    'piv-tool:interact with a PIV token'
    'pkcs11-tool:interact with a PKCS11 token'
    'policy:interact with in-toto policies'
    'public-key:get public key from the given private key or KMS'
    'save:save the container image and signatures to disk'
    'sign:sign supplied container image'
    'sign-blob:sign the supplied blob'
    'tree:display the supply chain security related artifacts'
    'triangulate:find the cosign tag for an image'
    'upload:upload artifacts to a registry'
    'verify:verify a signature on the supplied container image'
    'verify-attestation:verify an attestation on the supplied image'
    'verify-blob:verify a blob signature'
    'verify-blob-attestation:verify a blob attestation'
    'version:print version'
  )
  _describe -t commands 'cosign command' commands
}

_cosign_sign() {
  _arguments -s -S \
    '--key[path to the private key file, KMS URI, or Kubernetes Secret]:key' \
    '--cert[path to the X.509 certificate]:file:_files' \
    '--cert-chain[path to certificate chain]:file:_files' \
    '(-a --annotations)'{-a,--annotations}'[annotations to add]:key=value' \
    '--attachment[attachment to sign]:attachment:(sbom)' \
    '--identity-token[identity token to use for signing]:token' \
    '--oidc-client-id[OIDC client ID]:id' \
    '--oidc-client-secret[OIDC client secret]:secret' \
    '--oidc-disable-ambient-credentials[disable ambient OIDC credentials]' \
    '--oidc-issuer[OIDC issuer URL]:url' \
    '--oidc-provider[OIDC provider to use for ambient credentials]:provider:(google github spiffe filesystem buildkite)' \
    '--oidc-redirect-url[OIDC redirect URL]:url' \
    '--output-certificate[write the certificate to a file]:file:_files' \
    '--output-payload[write the signed payload to a file]:file:_files' \
    '--output-signature[write the signature to a file]:file:_files' \
    '--payload[payload to sign]:file:_files' \
    '--recursive[sign all images in a multi-platform image index]' \
    '--registry-password[registry basic auth password]:password' \
    '--registry-username[registry basic auth username]:username' \
    '--registry-token[registry bearer auth token]:token' \
    '--rekor-url[address of Rekor STL server]:url' \
    '--sk[use a hardware token to sign]' \
    '--slot[slot on the hardware token]:slot:(authentication signature card-authentication key-management)' \
    '--fulcio-url[address of Fulcio server]:url' \
    '--timeout[HTTP timeout]:duration' \
    '--timestamp-server-url[timestamp server URL]:url' \
    '--tlog-upload[upload to the transparency log]' \
    '(-f --force)'{-f,--force}'[force overwrite of existing signature]' \
    '(-y --yes)'{-y,--yes}'[skip confirmation prompts]' \
    '--upload[upload the signature to the registry]' \
    '(-r --recursive)'{-r,--recursive}'[sign recursively]' \
    '*:image:' && ret=0
}

_cosign_verify() {
  _arguments -s -S \
    '--key[path to the public key file, KMS URI, or Kubernetes Secret]:key' \
    '--cert[path to the X.509 certificate]:file:_files' \
    '--cert-chain[path to certificate chain]:file:_files' \
    '--cert-email[the email expected in a valid Fulcio certificate]:email' \
    '--cert-identity[the identity expected in a valid Fulcio certificate]:identity' \
    '--cert-identity-regexp[regexp for the identity expected]:regexp' \
    '--cert-oidc-issuer[the OIDC issuer expected]:issuer' \
    '--cert-oidc-issuer-regexp[regexp for the OIDC issuer expected]:regexp' \
    '--cert-github-workflow-name[the GitHub workflow name expected]:name' \
    '--cert-github-workflow-ref[the GitHub workflow ref expected]:ref' \
    '--cert-github-workflow-repository[the GitHub workflow repository expected]:repo' \
    '--cert-github-workflow-sha[the GitHub workflow sha expected]:sha' \
    '--cert-github-workflow-trigger[the GitHub workflow trigger expected]:trigger' \
    '(-a --annotations)'{-a,--annotations}'[annotations to verify]:key=value' \
    '--attachment[attachment to verify]:attachment:(sbom)' \
    '--check-claims[check the claims found in the image]' \
    '(-o --output)'{-o,--output}'[output format]:format:(text json)' \
    '--rekor-url[address of Rekor STL server]:url' \
    '--sk[use a hardware token to verify]' \
    '--slot[slot on the hardware token]:slot' \
    '--offline[run verification in offline mode]' \
    '--insecure-ignore-tlog[skip transparency log verification]' \
    '--insecure-ignore-sct[skip SCT verification]' \
    '--registry-password[registry basic auth password]:password' \
    '--registry-username[registry basic auth username]:username' \
    '--timestamp-certificate-chain[path to timestamp certificate chain]:file:_files' \
    '*:image:' && ret=0
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-d --verbose)'{-d,--verbose}'[log debug output]' \
  '--output-file[log output to a file]:file:_files' \
  '1: :_cosign_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      sign)             _cosign_sign ;;
      verify)           _cosign_verify ;;
      sign-blob)
        _arguments -s -S \
          '--key[path to the private key file]:key' \
          '--output-signature[write the signature to a file]:file:_files' \
          '--output-certificate[write the certificate to a file]:file:_files' \
          '--bundle[write everything to a bundle file]:file:_files' \
          '--rekor-url[address of Rekor STL server]:url' \
          '--sk[use a hardware token to sign]' \
          '--oidc-issuer[OIDC issuer URL]:url' \
          '--oidc-client-id[OIDC client ID]:id' \
          '--fulcio-url[address of Fulcio server]:url' \
          '--tlog-upload[upload to the transparency log]' \
          '(-y --yes)'{-y,--yes}'[skip confirmation prompts]' \
          '1:blob:_files' && ret=0
        ;;
      verify-blob)
        _arguments -s -S \
          '--key[path to the public key file]:key' \
          '--cert[path to the X.509 certificate]:file:_files' \
          '--cert-chain[path to certificate chain]:file:_files' \
          '--cert-email[expected email in certificate]:email' \
          '--cert-identity[expected identity in certificate]:identity' \
          '--cert-identity-regexp[regexp for expected identity]:regexp' \
          '--cert-oidc-issuer[expected OIDC issuer]:issuer' \
          '--cert-oidc-issuer-regexp[regexp for OIDC issuer]:regexp' \
          '--signature[path to the signature]:file:_files' \
          '--bundle[path to the bundle]:file:_files' \
          '--rekor-url[address of Rekor STL server]:url' \
          '--sk[use a hardware token]' \
          '--offline[offline mode]' \
          '--insecure-ignore-tlog[skip transparency log]' \
          '1:blob:_files' && ret=0
        ;;
      verify-attestation) _cosign_verify ;;
      generate-key-pair)
        _arguments -s -S \
          '--kms[KMS provider URI]:uri' \
          '--output-key-prefix[prefix for key pair files]:prefix' && ret=0
        ;;
      import-key-pair)
        _arguments -s -S \
          '--key[path to key pair PEM file]:file:_files' \
          '--output-key-prefix[prefix for key pair files]:prefix' && ret=0
        ;;
      copy)
        _arguments -s -S \
          '--sig-only[only copy the signature]' \
          '--force[overwrite existing signatures]' \
          '--platform[only copy images for specific platform]:platform' \
          '--only[only copy specific media types]:type:(sig sbom att)' \
          '1:source image:' '2:dest image:' && ret=0
        ;;
      save)
        _arguments -s -S \
          '--dir[path to dir where image will be stored]:dir:_directories' \
          '1:image:' && ret=0
        ;;
      load)
        _arguments -s -S \
          '--dir[path to dir where image is stored]:dir:_directories' \
          '1:image:' && ret=0
        ;;
      tree)
        _arguments -s -S \
          '--type[type of refs]:type:(sigs sboms atts all)' \
          '1:image:' && ret=0
        ;;
      clean)
        _arguments -s -S \
          '--force[do not prompt for confirmation]' \
          '--type[type of refs to delete]:type:(signature sbom attestation all)' \
          '1:image:' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      login)
        _arguments -s -S \
          '(-u --username)'{-u,--username}'[username]:username' \
          '(-p --password)'{-p,--password}'[password]:password' \
          '--password-stdin[read password from stdin]' \
          '1:registry:' && ret=0
        ;;
      attest)
        _arguments -s -S \
          '--key[path to the private key]:key' \
          '--predicate[path to the predicate file]:file:_files' \
          '--type[predicate type]:type:(custom slsaprovenance spdx spdxjson cyclonedx link vuln)' \
          '--rekor-url[address of Rekor STL server]:url' \
          '--fulcio-url[address of Fulcio server]:url' \
          '--sk[use a hardware token]' \
          '--oidc-issuer[OIDC issuer URL]:url' \
          '--oidc-client-id[OIDC client ID]:id' \
          '(-y --yes)'{-y,--yes}'[skip confirmation prompts]' \
          '--tlog-upload[upload to the transparency log]' \
          '(-f --force)'{-f,--force}'[force overwrite]' \
          '--recursive[sign recursively for multi-arch]' \
          '1:image:' && ret=0
        ;;
    esac
    ;;
esac

return ret
