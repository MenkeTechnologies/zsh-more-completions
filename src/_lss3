#compdef lss3
# Documentation: https://man.archlinux.org/search?q=lss3
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[show this help message and exit]'
  {-m,--marker}'[the S3 key where the listing starts after it.]'
  {-t,--tags}'[display tags when listing all buckets.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
