#compdef hv_vss_daemon
# Documentation: https://man.archlinux.org/search?q=hv_vss_daemon
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-d[enable debug log printing. Default is disabled.]'
  '-n[run as a regular process instead of a daemon. Default is a daemon.]'
  '-h[print usage.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
