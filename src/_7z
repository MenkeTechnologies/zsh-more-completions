#compdef 7z 7za 7zr

# Zsh completion for 7-Zip (p7zip)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'a:add files to archive'
  'b:benchmark'
  'd:delete files from archive'
  'e:extract files from archive (without directory names)'
  'h:calculate hash values for files'
  'i:show information about supported formats'
  'l:list contents of archive'
  'rn:rename files in archive'
  't:test integrity of archive'
  'u:update files to archive'
  'x:extract files with full paths'
)

local -a archive_types=(
  '7z:7z archive'
  'zip:ZIP archive'
  'gzip:GZIP archive'
  'bzip2:BZIP2 archive'
  'xz:XZ archive'
  'lzma:LZMA archive'
  'tar:TAR archive'
  'cab:CAB archive'
  'iso:ISO image'
  'wim:WIM image'
)

local -a overwrite_modes=(
  'a:overwrite all existing files without prompt'
  's:skip extracting of existing files'
  't:auto rename existing file'
  'u:auto rename extracting file'
)

_arguments -s -S \
  '1:command:->command' \
  '-ai+[include archives]:archive filter:' \
  '-ax+[exclude archives]:archive filter:' \
  '-ao+[set overwrite mode]:overwrite mode:((${(j: :)${archive_types// /\\:}}))' \
  '-an[disable archive_name field]' \
  '-bb+[set output log level (0-3)]:log level:(0 1 2 3)' \
  '-bd[disable progress indicator]' \
  '-bs+[set output stream for output/error/progress]:stream config:' \
  '-bt[show execution time statistics]' \
  '-i+[include filenames]:filename filter:' \
  '-l[do not store symlinks - store targets instead]' \
  '-m+[set compression method parameters]:method parameters:' \
  '-mmt+[set number of CPU threads]:number of threads:' \
  '-mx+[set compression level]:compression level:(0 1 3 5 7 9)' \
  '-mfb+[set number of fast bytes]:fast bytes:' \
  '-md+[set dictionary size]:dictionary size:' \
  '-ms+[set solid mode]:solid mode:(on off)' \
  '-mhe+[enable archive header encryption (7z only)]:header encryption:(on off)' \
  '-o+[set output directory]:output directory:_files -/' \
  '-p+[set password]:password:' \
  '-r-[recurse subdirectories]:recurse mode:(- 0)' \
  '-sa+[set archive name mode]:name mode:(a e s)' \
  '-scc+[set charset for console input/output]:charset:(UTF-8 WIN DOS)' \
  '-scs+[set charset for list files]:charset:(UTF-8 UTF-16LE UTF-16BE WIN DOS)' \
  '-scrc+[set hash function]:hash function:(CRC32 CRC64 SHA1 SHA256 \*)' \
  '-sdel[delete files after compression]' \
  '-seml+[send archive by email]:email address:' \
  '-sfx+[create SFX archive]:SFX module:_files' \
  '-si+[read data from stdin]:stream name:' \
  '-slp[set large pages mode]' \
  '-slt[show technical information for list command]' \
  '-snh[store hard links as links]' \
  '-snl[store symbolic links as links]' \
  '-sni[store NT security information]' \
  '-sns-[store NTFS alternate streams]:alternate streams:(- "")' \
  '-so[write data to stdout]' \
  '-spd[disable wildcard matching for file names]' \
  '-spe[eliminate duplication of root folder for extract]' \
  '-spf[use fully qualified file paths]' \
  '-ssc-[set sensitive case mode]:case mode:(- "")' \
  '-ssw[compress shared files]' \
  '-stl[set archive timestamp from most recently modified file]' \
  '-stm+[set CPU thread affinity mask]:hex mask:' \
  '-stx+[exclude archive type]:archive type:' \
  '-t+[set type of archive]:archive type:(7z zip gzip bzip2 xz lzma tar cab iso wim)' \
  '-u+[update options]:update options:' \
  '-v+[create volumes]:volume size:' \
  '-w+[assign work directory]:work directory:_files -/' \
  '-x+[exclude filenames]:filename filter:' \
  '-y[assume Yes on all queries]' \
  '*:file:_files' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
esac

return ret
