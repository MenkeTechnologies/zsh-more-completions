#compdef pyright

# zsh completions for 'pyright'
local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help message and exit]'
  '(- *)'{-V,--version}'[show version and exit]'
  '--createstub[create type stub file for import]:import name:'
  '--dependencies[emit import dependency information]'
  '--ignoreexternal[ignore external imports for --verifytypes]'
  '--lib[use library code to infer type information]'
  '--level[minimum diagnostic level]:level:(basic standard strict)'
  '--outputjson[output results in JSON format]'
  {-p,--project}'[use the source file or directory for configuration]:project:_files'
  '--pythonpath[path to the Python interpreter]:python path:_files -g "*"'
  '--pythonplatform[target platform for Python execution]:platform:(Darwin Linux Windows)'
  '--pythonversion[target Python version for analysis]:version:'
  '--skipunannotated[skip analysis of functions with no type annotations]'
  '--stats[print detailed performance stats]'
  '--typeshedpath[use typeshed type stubs at this path]:path:_directories'
  '--venvpath[path to folder with subdirectories for virtual environments]:path:_directories'
  '(-v --verbose)'{-v,--verbose}'[emit verbose diagnostics]'
  '--verifytypes[verify type completeness of a package]:package name:'
  '--warnings[use exit code of 1 if warnings are reported]'
  '(-w --watch)'{-w,--watch}'[continue to run and watch for changes]'
  '--threads[use worker threads to parallelize analysis]'
  '*:file or directory:_files'
)

_arguments -s -S $arguments
