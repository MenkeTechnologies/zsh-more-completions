#compdef corepack

# Zsh completion for corepack (Node.js package manager manager)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'disable:remove the shims for a package manager'
  'enable:add shims for a package manager'
  'install:install a package manager'
  'pack:download a package manager for offline use'
  'up:upgrade the package manager in the project'
  'use:define which package manager to use'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'corepack command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (enable|disable)
        _arguments '*:package manager:(npm pnpm yarn)' && ret=0
        ;;
      (install)
        _arguments \
          '-g[install globally]' \
          '--global[install globally]' \
          '*:package manager spec:' && ret=0
        ;;
      (use)
        _arguments '1:package manager spec:' && ret=0
        ;;
    esac
    ;;
esac

return ret
