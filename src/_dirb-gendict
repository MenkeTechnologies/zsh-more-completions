#compdef dirb-gendict
# Documentation: https://man.archlinux.org/search?q=dirb-gendict
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-c[\[a-z\]]'
  '-C[character \[A-Z\]]'
  '-h[\[0-f\]]'
  '-a[\[0-9a-z\]]'
  '-s[sensitive alfanumeric \[0-9a-zA-Z\]]'
  '*:filename:_files'
)

_arguments -s -S $arguments
