#compdef hal-device
# Documentation: https://man.archlinux.org/search?q=hal-device
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-a,--add}'[add new device.]'
  {-r,--remove}'[remove device.]'
  '(- * :)'{-h,--help}'[show this text.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
