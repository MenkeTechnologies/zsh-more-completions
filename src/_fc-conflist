#compdef fc-conflist
# Documentation: https://man.archlinux.org/search?q=fc-conflist
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-V,--version}'[display font config version and exit]'
  '(- * :)'{-h,--help}'[display this help and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
