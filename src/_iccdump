#compdef iccdump
# Documentation: https://man.archlinux.org/search?q=iccdump
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-v[verbose level 1-3 (default 2)]'
  '-t[dump this tag only (can be used multiple times)]'
  '-s[search for embedded profile]'
  '-i[check V4 ID value]'
  '*:filename:_files'
)

_arguments -s -S $arguments
