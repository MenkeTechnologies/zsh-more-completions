#compdef tcpdchk
# Documentation: https://man.archlinux.org/search?q=tcpdchk
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-a[report rules with implicit "ALLOW" at end]'
  '-d[use allow/deny files in current directory]'
  '-i[location of inetd.conf file]'
  '-v[list all rules]'
  '*:filename:_files'
)

_arguments -s -S $arguments
