#compdef h2load

local -a arguments

arguments=(
  {-n,--requests}'[number of requests across all clients]:number:'
  {-c,--clients}'[number of concurrent clients]:number:'
  {-t,--threads}'[number of native threads]:number:'
  {-i,--input-file}'[path of a file with multiple URIs separated by EOLs]:file:_files'
  {-m,--max-concurrent-streams}'[max concurrent streams to issue per session]:number:'
  {-w,--window-bits}'[sets the stream level initial window size to (2**N)-1]:bits:'
  {-W,--connection-window-bits}'[sets the connection level initial window size]:bits:'
  {-H,--header}'[add/override a header to the requests]:header:'
  '--ciphers[set allowed cipher list]:cipher list:'
  {-p,--no-tls-proto}'[specify ALPN identifier of the protocol to be used]:protocol:'
  {-d,--data}'[post FILE to server, request method changed to POST]:file:_files'
  {-r,--rate}'[specifies the fixed rate at which connections are created]:rate:'
  '--rate-period[specifies the time period between creating connections]:period:'
  {-D,--duration}'[specifies the main duration for the measurements]:duration:'
  '--warm-up-time[specifies the time period before starting the actual measurements]:time:'
  {-T,--connection-active-timeout}'[specifies the maximum active time for a connection]:timeout:'
  {-N,--connection-inactivity-timeout}'[specifies the inactivity timeout for a connection]:timeout:'
  '--timing-script-file[path of a file containing request timing data]:file:_files'
  {-B,--base-uri}'[specify base URI to use for resolving relative URIs]:URI:'
  '--npn-list[comma delimited list of ALPN protocol identifiers]:list:'
  '--h1[short hand for --npn-list=http/1.1]'
  '--header-table-size[specify decoder header table size]:size:'
  '--encoder-header-table-size[specify encoder header table size]:size:'
  {-v,--verbose}'[output debug information.]'
  '--version[display version information and exit.]'
  '(- * :)'{-h,--help}'[display this help and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
