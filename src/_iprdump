#compdef iprdump
# Documentation: https://man.archlinux.org/search?q=iprdump
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--daemon[run as a daemon]'
  '--debug[print extra debugging information]'
  '-d[delete or directory]'
  '*:filename:_files'
)

_arguments -s -S $arguments
