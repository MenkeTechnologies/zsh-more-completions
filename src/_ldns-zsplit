#compdef ldns-zsplit
# Documentation: https://man.archlinux.org/search?q=ldns-zsplit
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-n[split after this many RRs]'
  '-o[use this as initial origin, for zones starting with @]'
  '-z[sort the zone prior to splitting. The current ldns zone]'
  '-v[show version number and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
