#compdef expect_multixterm


local -a arguments

arguments=(
    '--xa[The optional -xa argument indicates arguments to pass to xterm.]'
    '--xc[The optional -xc argument indicates a command to be run in each named xterm]'
    '--xd[The optional -xd argument indicates a directory to search for files]'
    '--xf[The optional -xf argument indicates a file to be read at startup.]'
    '--xn[The optional -xn argument indicates a name for each xterm.]'
    '--xv[The optional -xv flag puts multixterm into a verbose mode where it will]'
    '--name[make them easy to remember, all the multixterm flags begin with -x.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
