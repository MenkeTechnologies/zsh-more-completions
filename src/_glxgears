#compdef glxgears
# Documentation: https://man.archlinux.org/search?q=glxgears
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-display[set the display to run on]'
  '-stereo[run in stereo mode]'
  '-samples[run in multisample mode with at least N samples]'
  '-fullscreen[run in fullscreen mode]'
  '-info[display OpenGL renderer info]'
  '-geometry[+X+Y window geometry]'
  '*:filename:_files'
)

_arguments -s -S $arguments
