#compdef gdbgui

# Zsh completion for gdbgui - browser-based frontend to gdb

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-p --port)'{-p,--port}'[port to run server on]:port:' \
  '(-g --gdb)'{-g,--gdb}'[path to gdb binary]:gdb binary:_files' \
  '--gdb-args[arguments to pass to gdb]:args:' \
  '--rr[use rr replay instead of gdb]' \
  '(-r --remote)'{-r,--remote}'[allow remote connections]' \
  '--host[host to listen on]:host:' \
  '-n[do not open browser automatically]' \
  '--no-browser[do not open browser automatically]' \
  '-b[open browser automatically]' \
  '--browser[open browser automatically]' \
  '--debug[enable debug mode]' \
  '--project[set working directory to project root]:directory:_files -/' \
  '1:executable:_files' && return 0
