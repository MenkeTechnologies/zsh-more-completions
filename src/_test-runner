#compdef test-runner
# Documentation: https://man.archlinux.org/search?q=test-runner
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-a,--auto}'[find tests and run them]'
  {-d,--dbus}'[start D-Bus daemon]'
  {-u,--unix}'[provide serial device]:device:_files'
  {-q,--qemu}'[QEMU binary]:binary:_files'
  {-k,--kernel}'[kernel image (bzImage)]:image:_files'
  '(- * :)'{-h,--help}'[show help options]'
  '*:filename:_files'
)

_arguments -s -S $arguments
