#compdef ndmetis

local -a arguments

arguments=(
  '-ctype[specifies the scheme to be used to match the vertices of the graph]'
  '-iptype[specifies the initial partitioning type]'
  '-rtype[specifies the scheme to be used for refinement.]'
  '-ufactor[specifies the maximum allowed load imbalance]'
  '-pfactor[specifies the minimum degree of vertices that will be ordered last]'
  '-no2hop[specifies that the coarsening will not perform any 2-hop matchings]'
  '-nocompress[specifies that the graph should not be compressed]'
  '-ccorder[specifies if the connected components should be ordered separately]'
  '-niter[specifies the maximum number of iterations for the refinement]'
  '-nseps[specifies the number of different separators to compute at each level]'
  '-nooutput[specifies that no ordering file should be generated.]'
  '-seed[selects the seed of the random number generator.]'
  '-dbglvl[selects the debug level]'
  '-help[prints this message.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
