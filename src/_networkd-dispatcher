#compdef networkd-dispatcher

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-S,--script-dir}'[location under which to look for scripts]:dir:_directories'
  {-T,--run-startup-triggers}'[generate events reflecting preexisting state and run triggers]'
  {-v,--verbose}'[increment verbosity level once per call]'
  {-q,--quiet}'[decrement verbosity level once per call]'
  '*:filename:_files'
)

_arguments -s -S $arguments
