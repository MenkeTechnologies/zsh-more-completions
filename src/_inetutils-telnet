#compdef inetutils-telnet


local -a arguments

arguments=(
    '-4[Use IPv4 to connect to hosts.]'
    '-6[Use IPv6 to connect to hosts.]'
    '-8[Specifies an 8-bit data path.]'
    '-L[Specifies an 8-bit data path on output.]'
    '-e[Sets the initial inetutils-telnet telnet escape character to escape-char.]'
    '-E[Stops any character from being recognized as an escape character.]'
    '-a[Attempt automatic login.]'
    '-K[Specifies no automatic login to the remote system.]'
    '-l[specify user for remote login]:user'
    '-n[Opens tracefile for recording trace information.]'
    '-r[Specifies a user interface similar to rlogin 1.]'
    '-c[Disables the reading of the .telnetrc file.]'
    '-d[Sets the initial value of the debug toggle to TRUE.]'
    '-x[Turns on encryption of the data stream if possible.]'
    '-X[Disables the atype type of authentication.]'
    '-k[request Kerberos tickets for the specified realm]:realm'
    '*:filename:_files'
)
_arguments -s -S $arguments
