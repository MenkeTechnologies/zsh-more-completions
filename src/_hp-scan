#compdef hp-scan
# Documentation: https://man.archlinux.org/search?q=hp-scan
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {--duplex,--dup}'[duplex scanning using ADF.]'
  '--area[set scan area as tlx,tly,brx,bry]:area:'
  {-t,--units}'[set measurement units (default is mm)]:units:(mm cm in pt px)'
  '*:filename:_files'
)

_arguments -s -S $arguments
