#compdef agent-memory agentmemory

# Zsh completion for agent-memory / agentmemory (AI persistent memory layer)

local -a commands
commands=(
  'init:Initialize the memory directory'
  'status:Check the current state of memory and indexing'
  'search:Perform a semantic/keyword search'
  'write:Manually add a new memory entry'
  'read:Read a specific memory file'
  'scratchpad:Access or update the persistent scratchpad'
  'install-skills:Install integration files for specific agents'
  'list:List all memory categories (Python)'
  'wipe:Delete all memories in a category (Python)'
  'wipe-all:Clear the entire database (Python)'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[Print help message]' \
  '1: :_describe -t commands "command" commands' \
  '*:: :->args'

case $words[1] in
  search)
    _arguments \
      '1:Category (Python/Category Search):' \
      '2:Query:'
    ;;
  read)
    _arguments \
      '1:File:_files'
    ;;
  wipe)
    _arguments \
      '1:Category:'
    ;;
esac
