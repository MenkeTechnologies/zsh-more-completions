#compdef kt
# Documentation: https://man.archlinux.org/search?q=kt
# Reference accessed: 2026-05-16

# Zsh completion for kt (klingon_tools)

local -a commands
commands=(
  'update:Update klingon tools'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[Show help message]' \
  '1: :_describe -t commands "command" commands'
