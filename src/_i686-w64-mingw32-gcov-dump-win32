#compdef i686-w64-mingw32-gcov-dump-win32
# Documentation: https://man.archlinux.org/search?q=i686-w64-mingw32-gcov-dump-win32
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[print this help]'
  {-l,--long}'[dump record contents too]'
  {-p,--positions}'[dump record positions]'
  {-v,--version}'[print version number]'
  {-w,--working-sets}'[dump working set computed from summary]'
  '*:filename:_files'
)

_arguments -s -S $arguments
