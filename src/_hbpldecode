#compdef hbpldecode
# Documentation: https://man.archlinux.org/search?q=hbpldecode
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-d[basename of .pbm file for saving decompressed planes]'
  '-r[basename of .jbg file for saving raw planes]'
  '-o[print file offsets]'
  '-h[print hex file offsets]'
  '-D[set Debug level \[0\]]'
  '*:filename:_files'
)

_arguments -s -S $arguments
