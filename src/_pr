#compdef pr

# Zsh completion for pr - print/paginate files
# Supports both GNU coreutils pr and BSD/macOS pr

local ret=1

# Detect GNU vs BSD pr
local is_gnu=false
if pr --version &>/dev/null 2>&1; then
  is_gnu=true
fi

if $is_gnu; then
  _arguments -s -S \
    '(-a --across)'{-a,--across}'[print columns across rather than down]' \
    '(-c --show-control-chars)'{-c,--show-control-chars}'[use hat (^G) and octal backslash notation for control chars]' \
    '(-d --double-space)'{-d,--double-space}'[double space the output]' \
    '(-D --date-format)'{-D,--date-format}'=[use FORMAT for the header date]:date format' \
    '(-e --expand-tabs)'{-e,--expand-tabs}'=-[expand input tabs to tab width]::char and width' \
    '(-F -f --form-feed)'{-F,-f,--form-feed}'[use form feeds instead of newlines to separate pages]' \
    '(-h --header)'{-h,--header}'=[use centered HEADER instead of filename in page header]:header string' \
    '(-i --output-tabs)'{-i,--output-tabs}'=-[replace spaces with tabs in output]::char and width' \
    '(-J --join-lines)'{-J,--join-lines}'[merge full lines, turns off -W line truncation]' \
    '(-l --length)'{-l,--length}'=[set page length]:page length (lines) [66]' \
    '(-m --merge)'{-m,--merge}'[print all files in parallel, one in each column]' \
    '(-n --number-lines)'{-n,--number-lines}'=-[number lines]::char and width' \
    '(-N --first-line-number)'{-N,--first-line-number}'=[start counting with NUMBER at 1st line]:first line number' \
    '(-o --indent)'{-o,--indent}'=[offset each line with MARGIN spaces]:margin [0]' \
    '(-r --no-file-warnings)'{-r,--no-file-warnings}'[omit warning when a file cannot be opened]' \
    '(-s --separator)'{-s,--separator}'=-[separate columns by single character]:separator char' \
    '(-S --sep-string)'{-S,--sep-string}'=-[separate columns by STRING]:separator string' \
    '(-t --omit-header)'{-t,--omit-header}'[omit page headers and trailers]' \
    '(-T --omit-pagination)'{-T,--omit-pagination}'[omit page headers and trailers, eliminate pagination]' \
    '(-v --show-nonprinting)'{-v,--show-nonprinting}'[use octal backslash notation for non-printing chars]' \
    '(-w --width)'{-w,--width}'=[set page width for multi-column output]:page width [72]' \
    '(-W --page-width)'{-W,--page-width}'=[set page width always]:page width [72]' \
    '--columns=[produce output with specified number of columns]:number of columns' \
    '(- *)--help[display help and exit]' \
    '(- *)--version[output version information and exit]' \
    '*:file:_files' && ret=0
else
  # BSD/macOS pr
  _arguments -s -S \
    '-a[print columns across rather than down (use with -COLUMN)]' \
    '-d[double space the output]' \
    '-e-[expand input tabs]::char and gap' \
    '-F[use form feeds instead of newlines to separate pages]' \
    '-f[same as -F but pause before first page on terminal]' \
    '-h[use header string instead of filename]:header string' \
    '-i-[replace output spaces with tabs]::char and gap' \
    '-L[use specified locale]:locale' \
    '-l[set page length]:lines [66]' \
    '-m[merge files, print side by side]' \
    '-n-[number lines]::char and width' \
    '-o[offset each line with spaces]:offset [0]' \
    '-p[pause before each page on terminal output]' \
    '-r[suppress diagnostic on failure to open a file]' \
    '-s-[separate columns by character]:separator char' \
    '-t[omit page headers and trailers]' \
    '-w[set line width for multi-column output]:width [72]' \
    '*:file:_files' && ret=0
fi

return ret
