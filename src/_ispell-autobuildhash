#compdef ispell-autobuildhash
# Documentation: https://man.archlinux.org/search?q=ispell-autobuildhash
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--debug[show ispell-autobuildhash debugging information.]'
  '--dry-run[show what would be done, but do nothing real.]'
  '--force[do the job regardless of versions comparisons.]'
  '--triggered[tell the script that is run in the triggers stage.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
