#compdef linkerd

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '--api-addr=[API address]:address' \
  '--context=[Kubernetes context]:context' \
  '--kubeconfig=[kubeconfig path]:kubeconfig:_files' \
  {-L,--linkerd-namespace}'=[Linkerd namespace]:namespace' \
  '--verbose[verbose output]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'check:check the Linkerd installation'
      'dashboard:open the Linkerd dashboard'
      'diagnostics:diagnostics commands'
      'identity:display identity info'
      'inject:inject Linkerd proxy'
      'install:install Linkerd'
      'multicluster:manage multicluster'
      'profile:generate service profiles'
      'uninject:remove Linkerd proxy'
      'uninstall:uninstall Linkerd'
      'upgrade:upgrade Linkerd'
      'version:print version'
      'viz:visualization commands'
      'completion:generate shell completion'
      'jaeger:Jaeger extension'
    )
    _describe -t commands 'linkerd command' commands && ret=0
    ;;
  args)
    case $words[1] in
      install)
        _arguments -s -S \
          '*--set=[set a Helm value]:key=value' \
          '*--values=[values file]:values:_files' \
          '--ignore-cluster[ignore cluster connectivity]' \
          '--crds[install CRDs]' \
          '--ha[enable high availability]' \
          '--disable-heartbeat[disable heartbeat]' \
          '--addon-config=[addon config file]:config:_files' \
          && ret=0
        ;;
      inject)
        _arguments -s -S \
          '--manual[output YAML only]' \
          '--proxy-version=[proxy version]:version' \
          '*:file:_files' \
          && ret=0
        ;;
      check)
        _arguments -s -S \
          '--pre[run pre-install checks]' \
          '--proxy[run proxy checks]' \
          {-o,--output}'=[output format]:format:(table json short)' \
          '--wait=[wait time]:duration' \
          && ret=0
        ;;
      completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish)' \
          && ret=0
        ;;
      viz)
        _arguments -s -S -C \
          '1:subcommand:(install stat top tap routes dashboard profile)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
