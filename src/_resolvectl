#compdef resolvectl

_resolvectl_commands() {
    local -a commands
    commands=(
        'query:resolve domain names, IPv4 and IPv6 addresses'
        'service:resolve DNS-SD and SRV services'
        'openpgp:retrieve OpenPGP keys for an email address'
        'tlsa:retrieve TLS server certificates'
        'status:show resolver settings'
        'statistics:show resolver statistics'
        'reset-statistics:reset resolver statistics'
        'flush-caches:flush all local DNS caches'
        'reset-server-features:forget learned DNS server feature levels'
        'dns:get/set per-interface DNS server address'
        'domain:get/set per-interface search domain'
        'default-route:get/set per-interface default route flag'
        'llmnr:get/set per-interface LLMNR setting'
        'mdns:get/set per-interface MulticastDNS setting'
        'dnstls:get/set per-interface DNS-over-TLS setting'
        'dnsovertls:get/set per-interface DNS-over-TLS setting'
        'scsi:get/set per-interface DNSSEC setting'
        'dnssec:get/set per-interface DNSSEC setting'
        'nta:get/set per-interface DNSSEC NTA'
        'revert:revert per-interface DNS settings'
        'log-level:get/set logging threshold for the manager'
        'monitor:monitor DNS queries and responses'
        'show-cache:show current cache contents'
        'show-server-state:show DNS server state'
    )
    _describe -t commands 'resolvectl command' commands
}

_resolvectl_interfaces() {
    _net_interfaces
}

_resolvectl() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show package version]' \
        '--no-pager[do not pipe output into a pager]' \
        '-4[resolve IPv4 addresses only]' \
        '-6[resolve IPv6 addresses only]' \
        {-i+,--interface=}'[look on specified interface]:interface:_resolvectl_interfaces' \
        {-p+,--protocol=}'[look via specified protocol]:protocol:(dns llmnr mdns)' \
        {-t+,--type=}'[query RR with specified DNS type]:type:(A AAAA ANY AXFR CAA CNAME DNSKEY DS HINFO HTTPS LOC MX NAPTR NS NSEC NSEC3 OPENPGPKEY PTR RP SOA SRV SSHFP SVCB TLSA TXT URI)' \
        {-c+,--class=}'[query RR with specified DNS class]:class:(IN CS CH HS ANY)' \
        '--service-address=[resolve address for services]:bool:(yes no)' \
        '--service-txt=[resolve TXT records for services]:bool:(yes no)' \
        '--cname=[follow CNAME redirects]:bool:(yes no)' \
        '--validate=[validate resource records]:bool:(yes no)' \
        '--search=[use search domains for single-label names]:bool:(yes no)' \
        '--raw=[dump the answer as binary data]:raw type:(payload packet)' \
        '--legend=[print headers and additional info]:bool:(yes no)' \
        '--json=[generate JSON output]:mode:(short pretty off)' \
        {-j,--json}'[generate JSON output (short)]' \
        '--no-legend[do not print headers and additional info]' \
        '--stale-data=[allow response from cache even if expired]:bool:(yes no)' \
        '(-): :->command' \
        '(-)*:: :->arguments' && ret=0

    case $state in
        (command)
            _resolvectl_commands && ret=0
            ;;
        (arguments)
            case ${line[1]} in
                query)
                    _arguments '*:hostname:_hosts' && ret=0
                    ;;
                service)
                    _arguments '*:service:' && ret=0
                    ;;
                dns|domain|default-route|llmnr|mdns|dnstls|dnsovertls|dnssec|nta|revert|status)
                    _arguments '*:interface:_resolvectl_interfaces' && ret=0
                    ;;
                log-level)
                    _arguments ':log level:(emerg alert crit err warning notice info debug)' && ret=0
                    ;;
                *)
                    _arguments '*:argument:' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_resolvectl "$@"
