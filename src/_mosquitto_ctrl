#compdef mosquitto_ctrl


local -a arguments

arguments=(
    '--cafile[specify CA certificate file]:file:_files'
    '--capath[specify CA certificate directory]:dir:_directories'
    '--psk[specify pre-shared key]:key: '
    '--psk-identity[specify pre-shared key identity]:identity: '
    '-o[specify config option]:config-file:_files'
    '--option[specify option as key=value]:value: '
    '-A[specify bind address]:address: '
    '--cert[specify client certificate file]:file:_files'
    '--key[specify client private key file]:file:_files'
    '--ciphers[specify TLS ciphers]:ciphers: '
    {-d,--debug}'[enable debug mode]'
    {-D,--property}'[specify MQTT property]:property: '
    '--help[display help information]'
    {-h,--host}'[specify broker host]:host:_hosts'
    {-i,--id}'[specify client ID]:id: '
    '--id-prefix[specify client ID prefix]:prefix: '
    '--insecure[disable server certificate verification]'
    '--keyform[specify key format]:format:(pem engine)'
    '--tls-engine[specify TLS engine]:engine: '
    {-L,--url}'[specify broker URL]:url: '
    '--nodelay[disable Nagle algorithm]'
    {-p,--port}'[specify broker port]:port: '
    {-P,--pw}'[specify password]:password: '
    '--username[specify username]:username: '
    '--proxy[specify SOCKS5 proxy URL]:url: '
    {-q,--qos}'[specify QoS level]:qos:(0 1 2)'
    '--quiet[suppress output]'
    '--tls-alpn[specify TLS ALPN protocol]:protocol: '
    '--tls-engine-kpass-sha1[specify TLS engine key password SHA1]:hash: '
    '--tls-version[specify TLS version]:version: '
    '-u[specify username]:username: '
    '--unix[specify Unix socket path]:path:_files'
    {-V,--protocol-version}'[specify MQTT protocol version]:version:(31 311 5)'
    '*:filename:_files'
)
_arguments -s -S $arguments
