#compdef honcho

# Zsh completion for honcho (Python Procfile-based process manager)

_honcho_start() {
  _arguments -s -S \
    {-f,--procfile}'[path to Procfile]:file:_files' \
    {-e,--env}'[environment file]:file:_files' \
    {-d,--directory}'[working directory]:directory:_files -/' \
    {-p,--port}'[base port number]:port:' \
    {-c,--concurrency}'[process concurrency (process=num,...)]:concurrency:' \
    '*:process name:'
}

_honcho_run() {
  _arguments -s -S \
    {-e,--env}'[environment file]:file:_files' \
    '*:command:_command_names -e'
}

_honcho_export() {
  _arguments -s -S \
    {-f,--procfile}'[path to Procfile]:file:_files' \
    {-a,--app}'[application name]:name:' \
    {-l,--log}'[log directory]:directory:_files -/' \
    {-p,--port}'[base port number]:port:' \
    {-s,--shell}'[shell path]:shell:_files' \
    '1:format:(upstart supervisord)' \
    '2:location:_files -/'
}

_honcho() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help message]' \
    '(- *)--version[show version]' \
    '1:command:->cmds' \
    '*::arg:->args'

  case $state in
    cmds)
      local -a commands
      commands=(
        'start:start all or specified processes'
        'run:run a command with environment from .env'
        'export:export Procfile to another format'
        'check:validate a Procfile'
        'help:show help'
        'version:show version'
      )
      _describe -t commands 'honcho command' commands
      ;;
    args)
      case $line[1] in
        start) _honcho_start ;;
        run) _honcho_run ;;
        export) _honcho_export ;;
      esac
      ;;
  esac
}

_honcho "$@"
