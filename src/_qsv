#compdef qsv

# Zsh completion for qsv - ultrafast CSV data-wrangling toolkit

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'apply:Apply series of transformations to a CSV column'
  'cat:Concatenate CSV files by row or column'
  'count:Count records'
  'dedup:Remove redundant rows'
  'describegpt:Use LLM to describe CSV data'
  'diff:Find the difference between two CSVs'
  'enum:Add a new column enumerating CSV lines'
  'excel:Convert Excel/ODS files to CSV'
  'exclude:Exclude rows of one CSV based on another'
  'explode:Explode rows based on some column separator'
  'extdedup:Remove duplicate rows across multiple CSVs'
  'extsort:Sort arbitrarily large CSV files'
  'fetch:Fetch data from a URL for each row'
  'fetchpost:Fetch data from a URL using POST for each row'
  'fill:Fill empty fields in a CSV'
  'fixlengths:Make CSV have equal-length rows'
  'flatten:Show one field per line'
  'fmt:Format CSV output'
  'foreach:Execute commands based on CSV data'
  'frequency:Show frequency tables'
  'geocode:Geocode columns using local lookups'
  'headers:Show column headers'
  'index:Create an index of the given CSV'
  'input:Read CSV data with special quoting rules'
  'join:Join CSV files'
  'joinp:Join CSV files using the Pola.rs engine'
  'jsonl:Convert newline-delimited JSON to CSV'
  'luau:Execute Luau script on CSV data'
  'partition:Partition CSV data based on a column value'
  'pseudo:Replace values in a column with incrementing integers'
  'py:Execute a Python expression on CSV data'
  'rename:Rename the columns of a CSV'
  'replace:Replace CSV data using a regex'
  'reverse:Reverse rows of CSV data'
  'safenames:Avoid invalid field names in a CSV'
  'sample:Randomly sample CSV data'
  'schema:Generate JSON Schema from CSV data'
  'search:Search CSV data with a regex'
  'searchset:Search CSV data with a set of regexes'
  'select:Select, re-order, duplicate or drop columns'
  'slice:Slice records from CSV'
  'snappy:Compress/decompress data using Snappy codec'
  'sniff:Quickly sniff CSV metadata'
  'sort:Sort CSV data'
  'sortcheck:Check if CSV is already sorted'
  'split:Split CSV data into many files'
  'sqlp:Run a SQL query against a CSV using Polars'
  'stats:Compute descriptive statistics'
  'table:Align CSV data into columns'
  'to:Convert CSVs to other formats'
  'tojsonl:Convert CSV to newline-delimited JSON'
  'transpose:Transpose rows/columns of CSV data'
  'validate:Validate CSV data'
  'help:Print help'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--list[list available commands]' \
  '(-V --version)'{-V,--version}'[show version]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    _arguments \
      '(-d --delimiter)'{-d,--delimiter}'[field delimiter]:delimiter:' \
      '(-n --no-headers)'{-n,--no-headers}'[treat first row as data, not headers]' \
      '(-o --output)'{-o,--output}'[output file]:file:_files' \
      '--envlist[list environment variables used by qsv]' \
      '*:CSV file:_files -g "*.csv"' && ret=0
    ;;
esac

return ret
