#compdef omxregister-bellagio
# Documentation: https://man.archlinux.org/search?q=omxregister-bellagio
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-v[display a verbose output, listing all the components registered]'
  '-l[list only the components already registered. If -l is specified]'
  '-h[display this message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
