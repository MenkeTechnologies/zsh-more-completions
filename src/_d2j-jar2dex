#compdef d2j-jar2dex
# Documentation: https://man.archlinux.org/search?q=d2j-jar2dex
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-f,--force}'[force overwrite]'
  '(- * :)'{-h,--help}'[print this help message]'
  {-o,--output}'[output .dex file, default is $current_dir/\[jar-name\]-jar2dex.dex]:file:_files'
  '*:filename:_files'
)

_arguments -s -S $arguments
