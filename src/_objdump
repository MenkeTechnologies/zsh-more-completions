#compdef objdump llvm-objdump

# Zsh completion for objdump / llvm-objdump

_objdump() {
  local -a general_opts disasm_opts display_opts macho_opts

  general_opts=(
    '(- *)--help[display available options]'
    '(- *)'{-v,--version}'[display the version of this program]'
    {-a,--archive-headers}'[display archive header information]'
    {-f,--file-headers}'[display the contents of the overall file header]'
    {-p,--private-headers}'[display format specific file headers]'
    {-h,--headers,--section-headers}'[display summaries of the headers for each section]'
    {-x,--all-headers}'[display all available header information, relocation entries and the symbol table]'
    {-t,--syms}'[display the symbol table]'
    {-T,--dynamic-syms}'[display the contents of the dynamic symbol table]'
    {-r,--reloc}'[display the relocation entries in the file]'
    {-R,--dynamic-reloc}'[display the dynamic relocation entries in the file]'
    {-s,--full-contents}'[display the content of each section]'
    '--fault-map-section[display the content of the fault map section]'
    '--offloading[display the content of the offloading section]'
    '--raw-clang-ast[dump the raw binary contents of the clang AST section]'
    {-u,--unwind-info}'[display unwind information]'
  )

  disasm_opts=(
    {-d,--disassemble}'[disassemble all executable sections found in the input files]'
    {-D,--disassemble-all}'[disassemble all sections found in the input files]'
    {-S,--source}'[display source interleaved with disassembly (implies --disassemble)]'
    {-l,--line-numbers}'[display source line numbers when disassembling (implies --disassemble)]'
    {-C,--demangle}'[demangle symbol names]'
    {-z,--disassemble-zeroes}'[do not skip blocks of zeroes when disassembling]'
    '--disassemble-symbols=[list of symbols to disassemble]:symbols:'
    {-M,--disassembler-options=}'[pass target specific disassembler options]:options:'
    '--disassembler-color=[enable or disable disassembler color output]:mode:(on off terminal)'
    '--symbolize-operands[symbolize instruction operands when disassembling]'
    '--show-all-symbols[show all symbols during disassembly, even if multiple at same location]'
    '--no-leading-addr[do not print leading addresses for instructions or inline relocations]'
    '--no-addresses[alias for --no-leading-addr]'
    '--no-show-raw-insn[do not print the instruction bytes when disassembling]'
    '--print-imm-hex[use hex format for immediate values (default)]'
    '--no-print-imm-hex[do not use hex format for immediate values]'
    '--x86-asm-syntax=[select x86 disassembly syntax]:syntax:(att intel)'
    '--debug-vars=[print source-level variable locations alongside disassembly]:format:(ascii unicode)'
    '--debug-vars-indent=[distance to indent source-level variable display]:indent:'
    '--prefix-addresses[print complete address alongside disassembly]'
    '--symbol-description[add symbol description for disassembly (XCOFF only)]'
    '--traceback-table[decode traceback table in disassembly (XCOFF only, implies --disassemble)]'
    '--pretty-pgo-analysis-map[display PGO analysis values with formatting rather than raw numbers]'
  )

  display_opts=(
    {-j,--section=}'[operate on the specified sections only]:section name:'
    '--adjust-vma=[increase the displayed address by the specified offset]:offset:'
    '--start-address=[set the start address for disassembling/printing]:address:'
    '--stop-address=[set the stop address for disassembling/printing]:address:'
    '--arch-name=[target arch to disassemble for]:arch:'
    '--triple=[target triple to disassemble for]:triple:'
    '--mcpu=[target a specific cpu type]:cpu name:'
    '--mattr=[target specific attributes]:attributes:'
    '--build-id=[build ID to look up]:hex build ID:'
    '--debug-file-directory=[path to directory for debug files]:directory:_directories'
    '--debuginfod[use debuginfod to find debug files]'
    '--no-debuginfod[do not use debuginfod to find debug files]'
    '--dsym=[use .dSYM file for debug info]:dSYM file:_files'
    '--dwarf=[dump the specified DWARF debug sections]:value:(frames)'
    '--prefix=[add prefix to absolute paths]:prefix:'
    '--prefix-strip=[strip initial directories from absolute paths]:prefix:'
    '--show-lma[display LMA column when dumping ELF section headers]'
    '--file-start-context[include context from start of file (with -S)]'
    {-w,--wide}'[format output for more than 80 columns]'
    '--insn-width=[display specified bytes on a single line for -d]:width:'
    '-mllvm[specify an argument to forward to LLVM'\''s CommandLine library]:argument:'
  )

  macho_opts=(
    {-m,--macho}'[use MachO specific object file parser]'
    '--arch=[architecture(s) from a Mach-O file to dump]:architecture:'
    '--archive-member-offsets[print the offset to each archive member for Mach-O archives]'
    '--bind[display mach-o binding info]'
    '--chained-fixups[print chained fixup information (requires --macho)]'
    '--data-in-code[print the data in code table for Mach-O objects]'
    '--dis-symname[disassemble just this symbol'\''s instructions (requires --macho)]:symbol:'
    '--dyld-info[print bind and rebase information used by dyld]'
    '--dylib-id[print the shared library'\''s id for the dylib Mach-O file]'
    '--dylibs-used[print the shared libraries used for linked Mach-O files]'
    '--exports-trie[display mach-o exported symbols]'
    '--full-leading-addr[print full leading address]'
    '--function-starts=[print the function starts table for Mach-O objects]:format:(addrs names both)'
    '-g[print line information from debug info if available]'
    '--indirect-symbols[print indirect symbol table for Mach-O objects]'
    '--info-plist[print the info plist section as strings for Mach-O objects]'
    '--lazy-bind[display mach-o lazy binding info]'
    '--link-opt-hints[print the linker optimization hints for Mach-O objects]'
    '--no-leading-headers[print no leading headers]'
    '--no-symbolic-operands[do not symbolic operands when disassembling (requires --macho)]'
    '--non-verbose[print info for Mach-O objects in non-verbose or numeric form]'
    '--objc-meta-data[print the Objective-C runtime meta data for Mach-O files]'
    '--private-header[display only the first format specific file header]'
    '--rebase[display mach-o rebasing info]'
    '--rpaths[print the runtime search paths for the Mach-O file]'
    '--universal-headers[print Mach-O universal headers]'
    '--weak-bind[display mach-o weak binding info]'
  )

  _arguments -s -S \
    $general_opts \
    $disasm_opts \
    $display_opts \
    $macho_opts \
    '*:object file:_files'
}

_objdump "$@"
