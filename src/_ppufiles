#compdef ppufiles
# Documentation: https://man.archlinux.org/search?q=ppufiles
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-A[show all files (dont remove duplicates)]'
  '-L[show only shared libraries]'
  '-S[show only static libraries]'
  '-O[show only object files]'
  '-H[this helpscreen]'
  '*:filename:_files'
)

_arguments -s -S $arguments
