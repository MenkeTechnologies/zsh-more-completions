#compdef xxh

# Zsh completion for xxh - SSH with local environment

_arguments \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '+s[specify shell]' \
  '++shell[specify shell]:shell:(xonsh zsh bash fish osquery)' \
  '+i[install xxh on host]' \
  '++install[install xxh on host]' \
  '+if[force install xxh on host]' \
  '++install-force[force install xxh on host]' \
  '+iff[force full install xxh on host]' \
  '++install-force-full[force full install xxh on host]' \
  '+hh[set host xxh home directory]' \
  '++host-xxh-home[set host xxh home directory]:directory:_directories' \
  '+he[execute file on host]' \
  '++host-execute-file[execute file on host]:file:_files' \
  '+lh[set local xxh home directory]' \
  '++local-xxh-home[set local xxh home directory]:directory:_directories' \
  '*+e[set environment variable]:key=value:' \
  '*++env[set environment variable]:key=value:' \
  '*+eb[set base64-encoded environment variable]:key=value_base64:' \
  '*++envb[set base64-encoded environment variable]:key=value_base64:' \
  '+v[enable verbose output]' \
  '++verbose[enable verbose output]' \
  '+vv[enable very verbose output]' \
  '++vverbose[enable very verbose output]' \
  '+q[suppress output]' \
  '++quiet[suppress output]' \
  '+sc[use short connections]' \
  '++short-connections[use short connections]' \
  '+P[use password authentication]' \
  '++password[use password authentication]' \
  '+I[disable password authentication]' \
  '++no-password-auth[disable password authentication]' \
  '*:hostname:_hosts'
