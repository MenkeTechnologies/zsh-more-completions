#compdef py3rsa-verify


local -a arguments

arguments=(
    {-h,--help}'[show help message and exit.]'
    {-i,--input}'[name of the signed file to verify. Read from stdin if not specified.]'
    '--keyform[key format of the public key - default PEM EXIT STATUS 0 if signature can be …]:KEYFORM'
    '*:filename:_files'
)
_arguments -s -S $arguments
