#compdef py3rsa-verify
# Documentation: https://man.archlinux.org/search?q=py3rsa-verify
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    {-h,--help}'[show help message and exit.]'
    {-i,--input}'[name of the signed file to verify. Read from stdin if not specified.]'
    '--keyform[key format of the public key - default PEM]:KEYFORM'
    '*:filename:_files'
)
_arguments -s -S $arguments
