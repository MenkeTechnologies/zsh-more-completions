#compdef bpftrace

# Zsh completion for bpftrace - eBPF tracing language

_arguments \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--version[show version]' \
  '-B[set output buffering mode]:mode:(full line none)' \
  '-d[enable debug mode]' \
  '-dd[enable verbose debug mode]' \
  '-e[execute program string]:program:' \
  '-f[set output format]:format:(json text)' \
  '-I[add include directory]:directory:_directories' \
  '-k[use kernel headers from running kernel]' \
  '-l[list probes matching pattern]:pattern:' \
  '-o[redirect output to file]:output file:_files' \
  '-p[attach to PID]:pid:_pids' \
  '-q[quiet mode]' \
  '-v[verbose mode]' \
  '-c[run command and attach]:command:_command_names -e' \
  '--unsafe[allow unsafe probes]' \
  '--usdt-file-activation[activate USDT semaphores]' \
  '--no-warnings[suppress warnings]' \
  '--info[show build info]' \
  '*:script file:_files -g "*.bt"'
