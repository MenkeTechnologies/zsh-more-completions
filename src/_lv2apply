local -a arguments

arguments=(
    '-i[Input file.]:IN_FILE'
    '-o[Output file.]:OUT_FILE'
    '-c[Set control port SYM to VAL.]:VAL'
    '--help[Display help and exit.]'
    '--version[Display version information and exit.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
