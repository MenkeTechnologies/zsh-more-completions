#compdef lldb60

local -a arguments

arguments=(
    '(- * :)'{-h,--help}'[prints out the usage information for the LLDB debugger.]'
    {-v,--version}'[prints out the current version number of the LLDB debugger.]'
    {-a,--arch}'[tells the debugger to use the specified architecture when starting]'
    {-f,--file}'[tells the debugger to use the file <filename> as the program to be]'
    {-c,--core}'[tells the debugger to use the fullpath to <path> as the core file.]'
    {-p,--attach-pid}'[tells the debugger to attach to a process with the given pid.]'
    {-n,--attach-name}'[tells the debugger to attach to a process with the given name.]'
    {-w,--wait-for}'[tells the debugger to wait for a process with the given pid or name]'
    {-s,--source}'[tells the debugger to read in and execute the lldb commands in the given file]'
    {-o,--one-line}'[tells the debugger to execute this one-line lldb command after any file has been loaded]'
    '--source-before-file[tells the debugger to read in and execute the lldb commands in the given file before loading a file]'
    {-O,--one-line-before-file}'[tells the debugger to execute this one-line lldb command before any file has been loaded]'
    {-k,--one-line-on-crash}'[when in batch mode, tells the debugger to execute this one-line lldb command if the target crashes]'
    {-K,--source-on-crash}'[when in batch mode, tells the debugger to source this file of lldb commands if the target crashes]'
    {-Q,--source-quietly}'[tells the debugger to execute this one-line lldb command before any file has been loaded, suppressing output]'
    {-b,--batch}'[tells the debugger to run the commands from -s, -S, -o & -O, and then quit]'
    {-e,--editor}'[tells the debugger to open source files using the hosts external editor]'
    {-x,--no-lldbinit}'[do not automatically parse any .lldbinit files.]'
    {-X,--no-use-colors}'[do not use colors.]'
    {-P,--python-path}'[prints out the path to the lldb.py file for this version of lldb.]'
    {-l,--script-language}'[tells the debugger to use the specified scripting language for user-defined scripts]'
    {-d,--debug}'[tells the debugger to print out extra information for debugging itself]'
    {-r,--repl}'[runs lldb in REPL mode with a stub process.]'
    {-R,--repl-language}'[chooses the language for the REPL.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
