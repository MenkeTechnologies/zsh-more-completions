#compdef podchecker5.34
# Documentation: https://man.archlinux.org/search?q=podchecker5.34
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-help[print a brief help message and exit.]'
  '-man[print the manual page and exit.]'
  {-warnings,-nowarnings}'[turn on/off printing of warnings. Repeating -warnings increases]'
  '*:filename:_files'
)

_arguments -s -S $arguments
