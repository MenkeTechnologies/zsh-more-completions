#compdef radzap
# Documentation: https://man.archlinux.org/search?q=radzap
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[usage help information.]'
  '-d[directory where radiusd.conf is located.]'
  '-D[directory where the dictionaries are located.]'
  '-N[IP address of the NAS to zap.]'
  '-P[NAS port that the user is logged into.]'
  '-u[name of user to zap (case insensitive).]'
  '-U[like -u, but case-sensitive.]'
  '-x[debugging output.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
