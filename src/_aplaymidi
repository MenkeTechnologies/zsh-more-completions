#compdef aplaymidi
# Documentation: https://man.archlinux.org/search?q=aplaymidi
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[this help]'
  {-V,--version}'[print current version]'
  {-l,--list}'[list all possible output ports]'
  {-p,--port}'[... set port(s) to play to]'
  {-d,--delay}'[delay after song ends]'
  '*:filename:_files'
)

_arguments -s -S $arguments
