#compdef qml

local -a arguments

arguments=(
  '(- * :)'{-h,-help}'[print usage information and exit]'
  {-v,-version}'[print version information and exit]'
  '-apptype[select which application class to use (default: gui)]:type: '
  '-quiet[suppress all output]'
  '-I[prepend the given path to the import paths]:path:_directories'
  '-f[load the given file as a QML file]:file:_files'
  '-config[load the given file as the configuration file]:file:_files'
  '-desktop[force use of desktop GL (AA_UseDesktopOpenGL)]'
  '-gles[force use of GLES (AA_UseOpenGLES)]'
  '-software[force use of software rendering]'
  '-scaling[enable High DPI scaling (AA_EnableHighDpiScaling)]'
  '-no-scaling[disable High DPI scaling (AA_DisableHighDpiScaling)]'
  '-verbose[print information about what qml is doing]'
  '-translation[load the given file as the translations file]:file:_files'
  '-dummy-data[load QML files from the given directory as context properties]:dir:_directories'
  '-slow-animations[run all animations in slow motion]'
  '-fixed-animations[run animations off animation tick rather than wall time]'
  '*:filename:_files'
)

_arguments -s -S $arguments
