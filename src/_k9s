#compdef k9s

# Zsh completion for k9s - Kubernetes TUI

local curcontext="$curcontext" state line ret=1

_k9s_commands() {
  local -a commands=(
    'completion:generate the autocompletion script for the specified shell'
    'help:help about any command'
    'info:print configuration info'
    'version:print version/build info'
  )
  _describe -t commands 'k9s command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[launch k9s in all-namespace mode]' \
  '--as[username to impersonate]:username' \
  '--as-group[group to impersonate]:group' \
  '--certificate-authority[path to a cert file for the CA]:file:_files' \
  '--client-certificate[path to a client cert file]:file:_files' \
  '--client-key[path to a client key file]:file:_files' \
  '--cluster[the name of the kubeconfig cluster]:cluster' \
  '(-c --command)'{-c,--command}'[overrides the default resource to load]:resource' \
  '--context[the name of the kubeconfig context]:context' \
  '--crumbsless[turn off breadcrumbs]' \
  '--headless[turn off header]' \
  '--insecure-skip-tls-verify[skip TLS certificate verification]' \
  '--kubeconfig[path to the kubeconfig file]:file:_files' \
  '(-l --logLevel)'{-l,--logLevel}'[set log level]:level:(trace debug info warn error fatal)' \
  '--logoless[turn off the logo]' \
  '(-n --namespace)'{-n,--namespace}'[specify the initial namespace]:namespace' \
  '--readonly[set to readonly mode]' \
  '--request-timeout[wait time before giving up on a server request]:timeout' \
  '(-r --refresh)'{-r,--refresh}'[specify the default refresh rate]:seconds' \
  '--screen-dump-dir[set a path to a dir for screen dumps]:dir:_directories' \
  '--server[address and port of the Kubernetes API server]:server' \
  '--tls-server-name[server name to use for TLS validation]:name' \
  '--token[bearer token for authentication]:token' \
  '--user[the name of the kubeconfig user]:user' \
  '(-v --version)'{-v,--version}'[print version]' \
  '--write[set general write mode (when not readonly)]' \
  '1: :_k9s_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      completion)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      info)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      version)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-s --short)'{-s,--short}'[print short version]' && ret=0
        ;;
    esac
    ;;
esac

return ret
