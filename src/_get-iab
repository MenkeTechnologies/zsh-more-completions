#compdef get-iab
# Documentation: https://man.archlinux.org/search?q=get-iab
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[this usage message.]'
  '-f[specify the output IAB file. Default=ieee-iab.txt]'
  '-u[specify the URL to fetch the IAB data from.]'
  '-v[verbose progress messages.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
