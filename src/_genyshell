#compdef genyshell
# Documentation: https://man.archlinux.org/search?q=genyshell
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[Display this help]'
  '-r[Use Genymotion virtual device specified with your IP address]'
  '-c[Launch command and display result in terminal host]'
  '-f[Launch all commands listed into file]'
  '*:filename:_files'
)

_arguments -s -S $arguments
