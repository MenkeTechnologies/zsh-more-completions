#compdef encguess
# Documentation: https://man.archlinux.org/search?q=encguess
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[show this message and exit.]'
  '-s[specify a list of "suspect encoding types" to test, seperated by]'
  '-S[output a list of all acceptable encoding types that can be used with]'
  '-u[suppress display of unidentified types]'
  '*:filename:_files'
)

_arguments -s -S $arguments
