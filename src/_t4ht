#compdef t4ht

local -a arguments

arguments=(
  '-b[ignore -d -m -M for bitmaps]'
  '-c[choose named segment in env file]:segment:'
  '-d[directory for output files (default: current)]:directory:_directories'
  '-e[location of tex4ht.env]:file:_files'
  '-i[debugging info]'
  '-g[ignore errors in system calls]'
  '-m[chmod of new output files (reused bitmaps excluded)]:mode:'
  '-p[dont convert pictures (default: convert)]'
  '-r[replace bitmaps of all glyphs (default: reuse old ones)]'
  '-M[chmod of all output files]:mode:'
  '-Q[quit, if tex4ht.c had problems]'
  '-S[permission for system calls: *-always, filter]:permission:'
  '-X[content for field %%3 in X scripts]:content:'
  '*:filename:_files'
)

_arguments -s -S $arguments
