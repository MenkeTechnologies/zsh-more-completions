#compdef promtail

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,-help}'[show help]' \
  '(- *)-version[show version]' \
  '-config.file=[YAML config file path]:config file:_files' \
  '-config.expand-env[expand environment variables in config]' \
  '-server.http-listen-address=[HTTP server listen address]:address' \
  '-server.http-listen-port=[HTTP server listen port]:port' \
  '-server.grpc-listen-address=[gRPC server listen address]:address' \
  '-server.grpc-listen-port=[gRPC server listen port]:port' \
  '-server.log-level=[log level]:level:(debug info warn error)' \
  '-server.log-format=[log format]:format:(logfmt json)' \
  '-client.url=[URL of log server]:url' \
  '-client.batch-size-bytes=[maximum batch size bytes]:bytes' \
  '-client.batch-wait=[maximum time to wait before sending a batch]:duration' \
  '-client.external-labels=[list of external labels]:labels' \
  '-client.tenant-id=[tenant ID for multi-tenancy]:tenant id' \
  '-print-config-stderr[dump the whole config to stderr]' \
  '-log-config-reverse-order[reverse config list order in logs]' \
  '-dry-run[dry run, log entries without sending]' \
  '-inspect[print parsed log entries instead of sending]' \
  '-stdin[read log from stdin]' && ret=0

return ret
