#compdef tune.exfat
# Documentation: https://man.archlinux.org/search?q=tune.exfat
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-l,--print-label}'[print volume label]'
  {-L,--set-label}'[set volume label]'
  {-i,--print-serial}'[print volume serial]'
  {-I,--set-serial}'[set volume serial]'
  {-V,--version}'[show version]'
  {-v,--verbose}'[print debug]'
  {-h,--help}'[show help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
