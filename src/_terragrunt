#compdef terragrunt

# Zsh completion for terragrunt - Terraform wrapper

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'plan:generate and show an execution plan'
  'apply:build or change infrastructure'
  'destroy:destroy managed infrastructure'
  'init:initialize a working directory'
  'validate:validate the configuration files'
  'output:show output values'
  'show:inspect state or plan'
  'refresh:update local state file'
  'import:import existing infrastructure'
  'state:advanced state management'
  'taint:mark a resource for recreation'
  'untaint:remove the taint from a resource'
  'graph:create a visual graph of resources'
  'providers:show the providers required'
  'run-all:run a terraform command against a stack of modules'
  'hclfmt:reformat HCL files'
  'render-json:render the final merged terragrunt config as JSON'
  'validate-inputs:validate the inputs against the defined variables'
  'aws-provider-patch:overwrite settings on nested AWS provider blocks'
  'catalog:launch the user interface for searching and managing a catalog'
  'scaffold:scaffold a new terragrunt module'
  'graph-dependencies:output the dependency graph'
)

local -a tg_flags=(
  '--terragrunt-config[path to terragrunt config file]:file:_files'
  '--terragrunt-working-dir[working directory for terragrunt]:dir:_directories'
  '--terragrunt-source[download Terraform source from this URL]:url'
  '--terragrunt-source-map[source map entry]:source=dest'
  '--terragrunt-source-update[delete the Terraform source folder and re-download]'
  '--terragrunt-non-interactive[assume yes for all prompts]'
  '--terragrunt-log-level[set the log level]:level:(trace debug info warn error)'
  '--terragrunt-parallelism[limit the number of parallel executions]:number'
  '--terragrunt-include-external-dependencies[include external dependencies]'
  '--terragrunt-exclude-dir[directory to exclude]:dir:_directories'
  '--terragrunt-include-dir[directory to include]:dir:_directories'
  '--terragrunt-ignore-dependency-errors[continue even if a dependency has errors]'
  '--terragrunt-ignore-dependency-order[ignore dependency order]'
  '--terragrunt-ignore-external-dependencies[ignore external dependencies]'
  '--terragrunt-iam-role[assume this IAM role]:role'
  '--terragrunt-iam-assume-role-duration[session duration for IAM role]:seconds'
  '--terragrunt-download-dir[download dir for remote Terraform source]:dir:_directories'
  '--terragrunt-no-auto-init[do not automatically run terraform init]'
  '--terragrunt-no-auto-retry[do not automatically retry on retryable errors]'
  '--terragrunt-no-auto-approve[do not automatically approve terraform apply]'
  '(-h --help)'{-h,--help}'[show help]'
  '--version[show version]'
)

_arguments -s -S \
  '1:command:->command' \
  $tg_flags \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'terragrunt command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (plan)
        _arguments -s -S $tg_flags \
          '-destroy[create a plan to destroy all resources]' \
          '-out[save plan to file]:file:_files' \
          '*-var[set a variable]:key=value' \
          '-var-file[set variables from a file]:file:_files' \
          '-target[resource to target]:resource' \
          '-refresh-only[only refresh state]' \
          '-no-color[disable color output]' \
          '-compact-warnings[compact warning messages]' \
          '-parallelism[limit the number of concurrent operations]:number' && ret=0
        ;;
      (apply)
        _arguments -s -S $tg_flags \
          '-auto-approve[skip interactive approval]' \
          '*-var[set a variable]:key=value' \
          '-var-file[set variables from a file]:file:_files' \
          '-target[resource to target]:resource' \
          '-no-color[disable color output]' \
          '-compact-warnings[compact warning messages]' \
          '-parallelism[limit the number of concurrent operations]:number' \
          '1:plan file:_files' && ret=0
        ;;
      (destroy)
        _arguments -s -S $tg_flags \
          '-auto-approve[skip interactive approval]' \
          '*-var[set a variable]:key=value' \
          '-var-file[set variables from a file]:file:_files' \
          '-target[resource to target]:resource' \
          '-no-color[disable color output]' \
          '-parallelism[limit the number of concurrent operations]:number' && ret=0
        ;;
      (init)
        _arguments -s -S $tg_flags \
          '-backend[configure the backend]:bool:(true false)' \
          '-backend-config[backend configuration]:key=value' \
          '-reconfigure[reconfigure the backend]' \
          '-migrate-state[migrate state to new backend]' \
          '-upgrade[install the latest module and provider versions]' \
          '-no-color[disable color output]' && ret=0
        ;;
      (run-all)
        _arguments -s -S $tg_flags \
          '1:terraform command:(plan apply destroy init validate output)' \
          '*:args' && ret=0
        ;;
      (hclfmt)
        _arguments -s -S $tg_flags \
          '--terragrunt-check[check if files are formatted]' \
          '--terragrunt-diff[show diff of formatting changes]' \
          '--terragrunt-hclfmt-file[format a single file]:file:_files' && ret=0
        ;;
      (*)
        _arguments -s -S $tg_flags '*:args' && ret=0
        ;;
    esac
    ;;
esac

return ret
