#compdef tgenv

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'install:install a specific version of Terragrunt'
  'use:switch to a specific version of Terragrunt'
  'uninstall:uninstall a specific version of Terragrunt'
  'list:list all installed versions'
  'list-remote:list all installable versions'
)

_tgenv_installed_versions() {
  local -a versions
  versions=(${(f)"$(tgenv list 2>/dev/null | sed 's/^[* ]*//')"})
  _describe -t versions 'version' versions
}

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'tgenv command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (install)
        _arguments '1:version' && ret=0
        ;;
      (use|uninstall)
        _arguments '1:version:_tgenv_installed_versions' && ret=0
        ;;
    esac
    ;;
esac

return ret
