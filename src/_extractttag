#compdef extractttag
# Documentation: https://man.archlinux.org/search?q=extractttag
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-v[verbose]'
  '-t[extract this tag rather than default targ]'
  '-c[extract calibration file from targ tag]'
  '*:filename:_files'
)

_arguments -s -S $arguments
