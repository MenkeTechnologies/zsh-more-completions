#compdef borg

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:initialize an empty repository'
  'create:create new archive'
  'extract:extract archive contents'
  'check:verify repository'
  'rename:rename an existing archive'
  'list:list archive or repository contents'
  'diff:find differences between archives'
  'delete:delete an existing archive or repository'
  'prune:prune repository archives'
  'compact:free repository space'
  'info:show repository or archive information'
  'mount:mount repository or archive as FUSE filesystem'
  'umount:unmount a FUSE filesystem'
  'key:manage repository key'
  'serve:start in server mode'
  'config:get and set configuration values'
  'with-lock:run a command with the repository lock held'
  'break-lock:break the repository lock'
  'benchmark:run benchmarks'
  'export-tar:create a tarball from an archive'
  'import-tar:create an archive from a tarball'
  'recreate:recreate contents of existing archives'
  'transfer:transfer archives between repositories'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'borg command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (init)
        _arguments -s -S \
          '(-e --encryption)'{-e,--encryption}'=[select encryption key mode]:mode:(none repokey keyfile repokey-blake2 keyfile-blake2 authenticated authenticated-blake2)' \
          '--append-only[create append-only mode repository]' \
          '--storage-quota=[set storage quota]:quota' \
          '--make-parent-dirs[create parent directories]' \
          '1:repository path' && ret=0
        ;;
      (create)
        _arguments -s -S \
          '(-n --dry-run)'{-n,--dry-run}'[do not create a backup archive]' \
          '(-s --stats)'{-s,--stats}'[print statistics]' \
          '(-p --progress)'{-p,--progress}'[show progress]' \
          '--list[output verbose list of items]' \
          '--filter=[only display items matching filter]:filter' \
          '--json[format output as JSON]' \
          '--no-cache-sync[do not synchronize cache]' \
          '--stdin-name=[use name for stdin data]:name' \
          '--stdin-user=[set user for stdin data]:user' \
          '--stdin-group=[set group for stdin data]:group' \
          '--stdin-mode=[set mode for stdin data]:mode' \
          '--content-from-command[interpret path as command and store its output]' \
          '--paths-from-stdin[read paths from stdin]' \
          '--paths-from-command[interpret paths from stdin as commands]' \
          '-e+[exclude a pattern]:pattern' \
          '--exclude=[exclude a pattern]:pattern' \
          '--exclude-from=[read exclude patterns from file]:file:_files' \
          '--exclude-caches[exclude directories tagged as cache]' \
          '--exclude-if-present=[exclude if file is present]:filename' \
          '--keep-exclude-tags[keep exclude tag files]' \
          '--pattern=[include/exclude paths]:pattern' \
          '--patterns-from=[read patterns from file]:file:_files' \
          '(-C --compression)'{-C,--compression}'=[select compression algorithm]:algo:(none lz4 zstd zlib lzma auto)' \
          '--chunker-params=[specify chunker parameters]:params' \
          '--comment=[add comment to archive]:comment' \
          '--timestamp=[set archive timestamp]:timestamp' \
          '--checkpoint-interval=[write checkpoint every N seconds]:seconds' \
          '--one-file-system[stay in the same file system]' \
          '--numeric-ids[only store numeric user and group IDs]' \
          '--noatime[do not store atime]' \
          '--noctime[do not store ctime]' \
          '--nobirthtime[do not store birthtime]' \
          '--nobsdflags[do not store bsdflags]' \
          '--noacls[do not read and store ACLs]' \
          '--noxattrs[do not read and store xattrs]' \
          '--sparse[detect sparse holes in input files]' \
          '--files-cache=[operate files cache in given mode]:mode:(ctime,size mtime,size rechunk,ctime rechunk,mtime disabled)' \
          '--read-special[open and read block and char device files]' \
          '1:archive name (repo\:\:name)' \
          '*:paths:_files' && ret=0
        ;;
      (extract)
        _arguments -s -S \
          '(-n --dry-run)'{-n,--dry-run}'[do not actually extract]' \
          '--list[output verbose list of items]' \
          '--numeric-ids[only obey numeric user and group IDs]' \
          '--noflags[do not extract file flags]' \
          '--noacls[do not extract ACLs]' \
          '--noxattrs[do not extract xattrs]' \
          '--stdout[write all extracted data to stdout]' \
          '--sparse[create holes in output sparse file]' \
          '-e+[exclude a pattern]:pattern' \
          '--exclude=[exclude a pattern]:pattern' \
          '--exclude-from=[read exclude patterns from file]:file:_files' \
          '--pattern=[include/exclude paths]:pattern' \
          '--patterns-from=[read patterns from file]:file:_files' \
          '--strip-components=[remove specified number of leading path elements]:number' \
          '--progress[show progress]' \
          '1:archive name (repo\:\:name)' \
          '*:paths' && ret=0
        ;;
      (list)
        _arguments -s -S \
          '--short[only print file/directory names]' \
          '--format=[specify format for file listing]:format' \
          '--json[format output as JSON]' \
          '--json-lines[format output as JSON lines]' \
          '-e+[exclude a pattern]:pattern' \
          '--exclude=[exclude a pattern]:pattern' \
          '--exclude-from=[read exclude patterns from file]:file:_files' \
          '--pattern=[include/exclude paths]:pattern' \
          '--patterns-from=[read patterns from file]:file:_files' \
          '--sort-by=[sort output]:key:(name size csize)' \
          '--first=[limit to first N entries]:count' \
          '--last=[limit to last N entries]:count' \
          '1:repository or archive' && ret=0
        ;;
      (prune)
        _arguments -s -S \
          '(-n --dry-run)'{-n,--dry-run}'[do not change repository]' \
          '--force[force pruning of corrupted archives]' \
          '(-s --stats)'{-s,--stats}'[print statistics]' \
          '--list[output verbose list of archives]' \
          '--keep-within=[keep all archives within time interval]:interval' \
          '(-H --keep-hourly)'{-H,--keep-hourly}'=[number of hourly archives to keep]:count' \
          '(-d --keep-daily)'{-d,--keep-daily}'=[number of daily archives to keep]:count' \
          '(-w --keep-weekly)'{-w,--keep-weekly}'=[number of weekly archives to keep]:count' \
          '(-m --keep-monthly)'{-m,--keep-monthly}'=[number of monthly archives to keep]:count' \
          '(-y --keep-yearly)'{-y,--keep-yearly}'=[number of yearly archives to keep]:count' \
          '--keep-last=[number of archives to keep]:count' \
          '--save-space[work slower but use less space]' \
          '-a+[only consider archive names matching glob]:glob' \
          '--glob-archives=[only consider archive names matching glob]:glob' \
          '1:repository' && ret=0
        ;;
      (info)
        _arguments -s -S \
          '--json[format output as JSON]' \
          '1:repository or archive' && ret=0
        ;;
      (mount)
        _arguments -s -S \
          '--foreground[stay in foreground]' \
          '-o+[extra mount options]:options' \
          '--first=[limit to first N entries]:count' \
          '--last=[limit to last N entries]:count' \
          '--sort-by=[sort output]:key:(name size csize)' \
          '-e+[exclude a pattern]:pattern' \
          '--exclude=[exclude a pattern]:pattern' \
          '1:repository or archive' \
          '2:mountpoint:_directories' && ret=0
        ;;
      (delete)
        _arguments -s -S \
          '(-n --dry-run)'{-n,--dry-run}'[do not change repository]' \
          '(-s --stats)'{-s,--stats}'[print statistics]' \
          '--cache-only[delete only the local cache]' \
          '--force[force deletion of corrupted archives]' \
          '--keep-security-info[keep security info even when deleting repo]' \
          '--save-space[work slower but use less space]' \
          '1:repository or archive' && ret=0
        ;;
      (key)
        local -a key_cmds=(
          'change-passphrase:change passphrase'
          'export:export repository key'
          'import:import repository key'
          'migrate-to-repokey:migrate to repokey'
        )
        _arguments \
          '1:subcommand:_describe -t key-commands "key command" key_cmds' \
          '*:args' && ret=0
        ;;
      (check)
        _arguments -s -S \
          '--repository-only[only check repository]' \
          '--archives-only[only check archives]' \
          '--verify-data[perform cryptographic archive data integrity verification]' \
          '--repair[attempt to repair any inconsistencies]' \
          '--first=[check first N archives]:count' \
          '--last=[check last N archives]:count' \
          '--save-space[work slower but use less space]' \
          '-a+[only consider archive names matching glob]:glob' \
          '--glob-archives=[only consider archive names matching glob]:glob' \
          '1:repository' && ret=0
        ;;
    esac
    ;;
esac

return ret
