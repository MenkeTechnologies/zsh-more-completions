#compdef nx

local curcontext="$curcontext" state line ret=1

_nx_projects() {
  local -a projects
  if [[ -f workspace.json ]]; then
    projects=(${(f)"$(node -e "Object.keys(require('./workspace.json').projects).forEach(p=>console.log(p))" 2>/dev/null)"})
  elif [[ -f nx.json ]]; then
    projects=(${(f)"$(find . -name 'project.json' -not -path '*/node_modules/*' 2>/dev/null | sed 's|^\./||;s|/project.json$||;s|.*/||')"})
  fi
  _describe -t projects 'project' projects
}

local -a commands=(
  'build:build a project'
  'serve:serve a project'
  'test:test a project'
  'e2e:run e2e tests'
  'lint:lint a project'
  'run:run a target for a project'
  'generate:generate code'
  'affected:run target for affected projects'
  'graph:graph dependencies'
  'migrate:update workspace to latest versions'
  'report:report useful version numbers'
  'list:list installed plugins'
  'connect:connect to Nx Cloud'
  'reset:clear cached results'
  'daemon:manage the Nx daemon'
  'format\:check:check formatted files'
  'format\:write:overwrite un-formatted files'
  'run-many:run target for multiple projects'
  'show:show information about the workspace'
  'watch:watch for changes and run commands'
  'release:manage releases'
  'repair:repair configuration files'
  'exec:execute any command within the project'
  'init:initialize Nx in a workspace'
  'add:install a plugin and initialize it'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'nx command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (build|serve|test|e2e|lint)
        _arguments -s -S \
          '1:project:_nx_projects' \
          '--configuration=[specify configuration]:config' \
          '--parallel=[max parallel processes]:count' \
          '--skip-nx-cache[skip the Nx cache]' \
          '--verbose[print additional output]' \
          '--nx-bail[stop running after a project fails]' \
          '--output-style=[output style]:style:(dynamic static stream stream-without-prefixes)' && ret=0
        ;;
      (run)
        _arguments -s -S \
          '1:target (project\:target\:config)' \
          '--configuration=[specify configuration]:config' \
          '--skip-nx-cache[skip the Nx cache]' && ret=0
        ;;
      (run-many)
        _arguments -s -S \
          '--target=[target to run]:target:(build test lint e2e serve)' \
          '--projects=[projects to run]:projects' \
          '--all[run for all projects]' \
          '--parallel=[max parallel processes]:count' \
          '--skip-nx-cache[skip the Nx cache]' \
          '--nx-bail[stop running after a project fails]' \
          '--output-style=[output style]:style:(dynamic static stream stream-without-prefixes)' \
          '--exclude=[exclude projects]:projects' && ret=0
        ;;
      (affected)
        _arguments -s -S \
          '--target=[target to run]:target:(build test lint e2e)' \
          '--base=[base branch or commit]:ref' \
          '--head=[head branch or commit]:ref' \
          '--parallel=[max parallel processes]:count' \
          '--skip-nx-cache[skip the Nx cache]' \
          '--files=[change only specified files]:files:_files' \
          '--exclude=[exclude projects]:projects' \
          '--nx-bail[stop running after a project fails]' && ret=0
        ;;
      (generate|g)
        _arguments -s -S \
          '1:generator (collection\:generator)' \
          '--dry-run[preview changes without applying]' \
          '*:args' && ret=0
        ;;
      (graph|dep-graph)
        _arguments -s -S \
          '--file=[output file]:file:_files' \
          '--focus=[focus on a project]:project:_nx_projects' \
          '--exclude=[exclude projects]:projects' \
          '--host=[host to bind]:host' \
          '--port=[port to bind]:port' \
          '--open[open browser]' \
          '--watch[watch for changes]' && ret=0
        ;;
      (migrate)
        _arguments -s -S \
          '--run-migrations=[run migrations from file]:file:_files' \
          '--from=[use the provided versions for packages]:from' \
          '--to=[use the provided versions for packages]:to' \
          '--create-commits[create a git commit after each migration]' \
          '--interactive[enable interactive mode]' \
          '*:package' && ret=0
        ;;
      (reset)
        _arguments && ret=0
        ;;
    esac
    ;;
esac

return ret
