#compdef predict
# Documentation: https://man.archlinux.org/search?q=predict
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-b[whether to output probability estimates, 0 or 1 (default 0); currently for logistic regression only]'
  '-q[quiet mode (no outputs)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
