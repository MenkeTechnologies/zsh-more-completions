#compdef f2py3.6

local -a arguments

arguments=(
  '--2d-numpy[use numpy.f2py tool with NumPy support. \[DEFAULT\]]'
  '--2d-numeric[use f2py2e tool with Numeric support.]'
  '--2d-numarray[use f2py2e tool with Numarray support.]'
  '--g3-numpy[use 3rd generation f2py from the separate f2py package.]'
  '-h[write signatures of the fortran routines to file]:filename:_files'
  '-m[name of the module for Python/C API generation]:module name:'
  '--lower[do not preserve case in fortran routines]'
  '--build-dir[directory for generated files]:dirname:_files -/'
  '--overwrite-signature[overwrite existing signature file.]'
  '--short-latex[create short LaTeX document]'
  '--debug-capi[create C/API code that reports wrapper state]'
  '--include-paths[search include files from given directories]:paths:'
  '--help-link[list system resources found by system_info.py]'
  '--quiet[run quietly.]'
  '--verbose[run with extra verbosity.]'
  '-v[print f2py version ID and exit.]'
  '--fcompiler[specify Fortran compiler type by vendor]:compiler:'
  '--compiler[specify C compiler type (as defined by distutils)]:compiler:'
  '--help-fcompiler[list available Fortran compilers and exit]'
  '--f77exec[specify the path to F77 compiler]:path:_files'
  '--f90exec[specify the path to F90 compiler]:path:_files'
  '--f77flags[specify F77 compiler flags]:flags:'
  '--f90flags[specify F90 compiler flags]:flags:'
  '--opt[specify optimization flags]:flags:'
  '--arch[specify architecture specific optimization flags]:flags:'
  '--noopt[compile without optimization]'
  '--noarch[compile without arch-dependent optimization]'
  '--debug[compile with debugging information]'
  '-L[add library search path]:path:_files -/'
  '-D[define macro]:define:'
  '-I[add include search path]:path:_files -/'
  '*:filename:_files'
)

_arguments -s -S $arguments
