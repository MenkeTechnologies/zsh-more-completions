#compdef asdf

local curcontext="$curcontext" state line ret=1

_asdf_plugins() {
  local -a plugins
  plugins=(${(f)"$(asdf plugin list 2>/dev/null)"})
  _describe -t plugins 'plugin' plugins
}

_asdf_installed_versions() {
  local plugin="$words[3]"
  local -a versions
  versions=(${(f)"$(asdf list "$plugin" 2>/dev/null | sed 's/^[* ]*//')"})
  _describe -t versions 'version' versions
}

local -a commands=(
  'plugin:manage plugins'
  'install:install a runtime version'
  'uninstall:uninstall a runtime version'
  'current:display current version set or being used'
  'where:display install path for an installed version'
  'which:display the path to an executable'
  'global:set the package global version'
  'local:set the package local version'
  'shell:set the package version in the current shell'
  'latest:show latest stable version of a package'
  'list:list installed versions of a package'
  'help:output documentation for plugin and tool'
  'exec:executes the command shim for the current version'
  'env:print or run under modified environment'
  'info:print os, shell and asdf debug info'
  'reshim:recreate shims for version of a package'
  'shim-versions:list the plugins and versions that provide a command'
  'update:update asdf to the latest stable release'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'asdf command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (plugin)
        local -a plugin_cmds=(
          'add:add a plugin from the plugin repo or a custom URL'
          'list:list installed plugins'
          'remove:remove plugin and package versions'
          'update:update a plugin or all plugins'
        )
        _arguments \
          '1:subcommand:_describe -t plugin-commands "plugin command" plugin_cmds' \
          '2:plugin name' \
          '3:git url' && ret=0
        ;;
      (install)
        _arguments \
          '1:plugin:_asdf_plugins' \
          '2:version' && ret=0
        ;;
      (uninstall|where|list)
        _arguments \
          '1:plugin:_asdf_plugins' \
          '2:version:_asdf_installed_versions' && ret=0
        ;;
      (global|local|shell)
        _arguments \
          '1:plugin:_asdf_plugins' \
          '2:version:_asdf_installed_versions' && ret=0
        ;;
      (current|latest|reshim)
        _arguments '1:plugin:_asdf_plugins' && ret=0
        ;;
      (which|shim-versions)
        _arguments '1:command' && ret=0
        ;;
      (exec)
        _arguments \
          '1:command' \
          '*:arguments' && ret=0
        ;;
    esac
    ;;
esac

return ret
