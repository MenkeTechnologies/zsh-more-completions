#compdef perl

_perl() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '-0-[specify record separator as octal/hex value (\0 if no argument)]' \
    '-a[autosplit mode with -n or -p (splits $_ into @F)]' \
    '-C-[enable the listed Unicode features (number or list of letters)]' \
    '-c[check syntax only (runs BEGIN and CHECK blocks)]' \
    '-d-[run program under debugger or module Devel::MOD]:debugger module:' \
    '-D-[set debugging flags (bit mask or alphabets)]:debug flags:' \
    '*-e+[one line of program (several -e'\''s allowed, omit programfile)]:perl code:' \
    '*-E+[like -e, but enables all optional features]:perl code:' \
    '-f[do not do $sitelib/sitecustomize.pl at startup]' \
    '-F+[split() pattern for -a switch]:split pattern:' \
    '-g[read all input in one go (slurp) rather than line-by-line (alias for -0777)]' \
    '-h[print summary of options]' \
    '-i-[edit <> files in place (makes backup if extension supplied)]:backup extension:' \
    '*-I+[specify @INC/#include directory]:include directory:_directories' \
    '-l-[enable line ending processing, specify line terminator as octal]:output record separator:' \
    '*-m+[execute "use module..." before executing program]:module:' \
    '*-M+[execute "use module..." before executing program (with import)]:module:' \
    '-n[assume "while (<>) { ... }" loop around program]' \
    '-p[assume loop like -n but print line also, like sed]' \
    '-s[enable rudimentary parsing for switches after programfile]' \
    '-S[look for programfile using PATH environment variable]' \
    '-t[enable tainting warnings]' \
    '-T[enable tainting checks]' \
    '-u[dump core after parsing program]' \
    '-U[allow unsafe operations]' \
    '-v[print version, patchlevel and license]' \
    '-V-[print configuration summary or a single Config.pm variable]:config variable:' \
    '-w[enable many useful warnings]' \
    '-W[enable all warnings]' \
    '-x-[ignore text before #!perl line (optionally cd to directory)]:directory:_directories' \
    '-X[disable all warnings]' \
    '1:Perl script:_files -g "*.pl(|x)(-.)"' \
    '*:script arguments:_files' && ret=0

  return ret
}

_perl "$@"
