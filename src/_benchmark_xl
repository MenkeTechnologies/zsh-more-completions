#compdef benchmark_xl

local -a arguments

arguments=(
  '--input[file or file pattern matching input files]:pattern:'
  '--codec[comma separated list of image codec descriptions to benchmark]:codecs:'
  '--print_details[print details]'
  '--noprint_details[do not print details]'
  '--print_details_csv[print details as CSV]'
  '--noprint_details_csv[do not print details as CSV]'
  '--extra_metrics[extra metrics to compute]:metrics:'
  '--print_more_stats[print more statistics]'
  '--noprint_more_stats[do not print more statistics]'
  '--print_distance_percentiles[print distance percentiles]'
  '--noprint_distance_percentiles[do not print distance percentiles]'
  '--silent_errors[silence errors]'
  '--nosilent_errors[do not silence errors]'
  '--save_compressed[save compressed output]'
  '--nosave_compressed[do not save compressed output]'
  '--save_decompressed[save decompressed output]'
  '--nosave_decompressed[do not save decompressed output]'
  '--output_extension[output file extension]:extension:'
  '--output_description[output description]:description:'
  '--intensity_target[intensity target]:target:'
  '--dec-hints[color encoding hints for input images]:hints:'
  '--override_bitdepth[override bit depth]:bits:'
  '--mul_output[multiply output by scalar]:scalar:'
  '--heatmap_good[heatmap good threshold]:scalar:'
  '--heatmap_bad[heatmap bad threshold]:scalar:'
  '--write_html_report[write HTML report]'
  '--nowrite_html_report[do not write HTML report]'
  '--html_report_self_contained[make HTML report self-contained]'
  '--nohtml_report_self_contained[do not make HTML report self-contained]'
  '--markdown[add Markdown formatting around ASCII table]'
  '--nomarkdown[do not add Markdown formatting]'
  '--more_columns[show more columns]'
  '--nomore_columns[do not show more columns]'
  '--originals_url[URL for original images]:url:'
  '--output_dir[output directory]:directory:_files -/'
  '--num_threads[number of threads]:threads:'
  '--inner_threads[number of inner threads]:threads:'
  '--encode_reps[encode repetitions]:reps:'
  '--decode_reps[decode repetitions]:reps:'
  '--sample_tmp_dir[temporary directory for samples]:directory:_files -/'
  '--num_samples[number of samples]:samples:'
  '--sample_dimensions[sample dimensions]:dimensions:'
  '--error_pnorm[error p-norm]:scalar:'
  '--hf_asymmetry[HF asymmetry]:scalar:'
  '--profiler[enable profiler]'
  '--noprofiler[disable profiler]'
  '--show_progress[show progress]'
  '--noshow_progress[do not show progress]'
  '--skip_butteraugli[skip Butteraugli metric]'
  '--noskip_butteraugli[do not skip Butteraugli metric]'
  '--decode_only[only decode, do not encode]'
  '--nodecode_only[do not decode only]'
  '--xmul[multiplier for X channel difference in Butteraugli]:multiplier:'
  '--quant_bias[quantization bias]:scalar:'
  '--use_ac_strategy[use AC strategy]'
  '--nouse_ac_strategy[do not use AC strategy]'
  '--qprogressive[enable quantized progressive mode for AC]'
  '--noqprogressive[disable quantized progressive mode for AC]'
  '--progressive[enable progressive mode for AC]'
  '--noprogressive[disable progressive mode for AC]'
  '--progressive_dc[progressive DC level]:level:'
  '--noise[enable noise]'
  '--dots[enable dots]'
  '--patches[enable patches]'
  '--debug_image_dir[directory for debug images]:directory:_files -/'
  '--chroma_subsampling[chroma subsampling mode]:mode:(444 422 420 411)'
  {-h,--help}'[print this help message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
