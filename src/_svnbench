#compdef svnbench

local -a subcommands
subcommands=(
    'null-export:Benchmark export without writing to disk'
    'null-list:Benchmark list without output'
    'null-log:Benchmark log without output'
    'null-info:Benchmark info without output'
    'help:Show help'
)

_arguments -C \
    '1:subcommand:->subcmd' \
    '*:: :->args'

case $state in
    subcmd)
        _describe -t subcommands 'svnbench subcommand' subcommands
        ;;
    args)
        _arguments \
            '-r[Revision range]:revision range' \
            '--revision[Revision range]:revision range' \
            '-q[Quiet mode]' \
            '--quiet[Quiet mode]' \
            '-v[Verbose mode]' \
            '--verbose[Verbose mode]' \
            '--depth[Operation depth]:depth:(empty files immediates infinity)' \
            '--username[Username]:username' \
            '--password[Password]:password' \
            '--config-dir[Config directory]:dir:_directories' \
            '--config-option[Config option]:option' \
            '--no-auth-cache[Do not cache authentication]' \
            '--non-interactive[Non-interactive mode]' \
            '--trust-server-cert[Trust server certificate]' \
            '--trust-server-cert-failures[Trust specific failures]:failures' \
            '--with-all-revprops[Retrieve all revision properties]' \
            '--with-no-revprops[Retrieve no revision properties]' \
            '--with-revprop[Retrieve specific revision property]:prop' \
            '-l[Limit number of log entries]:limit' \
            '--limit[Limit number of log entries]:limit' \
            '*:URL or path'
        ;;
esac
