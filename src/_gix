#compdef gix gitoxide

# Zsh completion for gitoxide (gix)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'archive:create an archive from a git tree'
  'clean:remove untracked files'
  'clone:clone a repository'
  'commit:show commit information'
  'completions:generate shell completions'
  'config:show or manage git configuration'
  'credential:interact with credentials'
  'diff:show changes between commits'
  'exclude:show exclude patterns'
  'fetch:fetch changes from a remote'
  'free:commands that do not need a repository'
  'index:interact with the index/staging area'
  'init:initialize a new repository'
  'is:check conditions'
  'log:show commit log'
  'mailmap:show mailmap entries'
  'merge-base:find merge base between commits'
  'odb:interact with the object database'
  'progress:show progress of operations'
  'remote:interact with remotes'
  'revision:show information about revisions'
  'status:show working tree status'
  'submodule:interact with submodules'
  'tree:show tree information'
  'verify:verify repository integrity'
)

_arguments -s -S \
  '--repository[repository path]:path:_files -/' \
  '(-t --threads)'{-t,--threads}'[number of threads]:threads:' \
  '--format[output format]:format:(human json)' \
  '--verbose[enable verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'gix command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (clone)
        _arguments \
          '--bare[create a bare clone]' \
          '--depth[shallow clone depth]:depth:' \
          '--ref[ref to checkout]:ref:' \
          '--no-tags[do not fetch tags]' \
          '1:url:_urls' \
          '2:directory:_files -/' && ret=0
        ;;
      (fetch)
        _arguments \
          '--depth[shallow fetch depth]:depth:' \
          '--deepen[deepen shallow clone by N]:commits:' \
          '--dry-run[do not actually fetch]' \
          '--prune[remove stale remote-tracking refs]' \
          '--no-tags[do not fetch tags]' \
          '1:remote:' && ret=0
        ;;
    esac
    ;;
esac

return ret
