#compdef mkroot
# Documentation: https://man.archlinux.org/search?q=mkroot
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-p[permissions for directories in chmod suitable format]'
  '-m[make directories in the current directory]'
  '-c[clean out empty directories]'
  '*:filename:_files'
)

_arguments -s -S $arguments
