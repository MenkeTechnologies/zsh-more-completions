#compdef ffsend

# Zsh completion for ffsend - Easily and securely share files from the command line (Firefox Send client)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'upload:upload a file (aliases: u, up)'
  'download:download a shared file (aliases: d, down)'
  'delete:delete a shared file (aliases: del, rm)'
  'exists:check whether a remote file exists'
  'info:fetch info about a shared file'
  'params:change parameters of a shared file'
  'password:change the password of a shared file'
  'history:view file history (aliases: h)'
  'version:show application version'
  'help:show help for a command'
  'generate:generate shell completions'
  'debug:view debug information'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-f --force)'{-f,--force}'[force the action]' \
  '--no-interact[do not prompt]' \
  '(-y --yes)'{-y,--yes}'[assume yes for prompts]' \
  '(-I --incognito)'{-I,--incognito}'[do not save history]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--transfer-timeout=[transfer timeout in seconds]:seconds:' \
  '--api=[server API version]:version:(2 3)' \
  '--history=[history file to use]:file:_files' \
  '--host=[server to upload to]:url:_urls' \
  '1:command:->command' \
  '*:file:_files' && ret=0

case $state in
  (command)
    _describe -t commands 'ffsend command' commands && ret=0
    ;;
esac

return ret
