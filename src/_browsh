#compdef browsh

# Zsh completion for browsh (text-based browser)

_arguments -s -S \
  '--firefox.path[path to Firefox binary]:path:_files' \
  '--firefox.with-gui[run with Firefox GUI visible]' \
  '--firefox.use-existing[use existing Firefox session]' \
  '--startup-url[URL to open on startup]:url:_urls' \
  '--http-server-mode[run as HTTP server]' \
  '--http-server-port[HTTP server port]:port:' \
  '--https-server-port[HTTPS server port]:port:' \
  '--monochrome[display in monochrome]' \
  '--debug[enable debug logging]' \
  '--time-limit[time limit in seconds]:seconds:' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:url:_urls' && return 0
