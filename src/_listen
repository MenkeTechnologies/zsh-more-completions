#compdef listen
# Documentation: https://man.archlinux.org/search?q=listen
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-v[\[--verbose=Verbose\], \[--no-verbose\]]'
  '-d[\[--directory=The directory to listen to\]]'
  '-r[\[--relative=Convert paths relative to current directory\], \[--no-relative\]]'
  '*:filename:_files'
)

_arguments -s -S $arguments
