#compdef aumvdown

local -a arguments

arguments=(
  {-b,--lower-branch-id}'[specify lower branch ID]'
  {-B,--upper-branch-id}'[specify upper branch ID]'
  {-i,--interactive}'[prompt before each operation]'
  {-k,--keep-upper}'[keep the upper branch]'
  {-o,--overwrite-lower}'[overwrite lower branch files]'
  {-r,--allow-ro-lower}'[allow read-only lower branch]'
  {-R,--allow-ro-upper}'[allow read-only upper branch]'
  {-v,--verbose}'[enable verbose output]'
  {-V,--version}'[aufs-util for aufs4.9 20170918]'
  '*:filename:_files'
)

_arguments -s -S $arguments
