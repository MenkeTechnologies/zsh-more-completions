#compdef libgtop_daemon2

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  {-d,--debug}'[enable debugging]'
  {-v,--verbose}'[enable verbose output]'
  {-f,--no-daemon}'[don’t fork into background]'
  {-i,--inetd}'[invoked from inetd]'
  '*:filename:_files'
)

_arguments -s -S $arguments
