#compdef jql

# Zsh completion for jql (JSON query language)

_arguments -s -S \
  '(-r --raw-output)'{-r,--raw-output}'[raw string output]' \
  '(-i --inline)'{-i,--inline}'[inline JSON input]:json:' \
  '(-p --pretty)'{-p,--pretty}'[pretty print output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:query:' \
  '*:json file:_files -g "*.json"' && return 0
