#compdef sg_sat_set_features

local -a arguments

arguments=(
  {--count,-c}'[count field contents (def: 0)]'
  {--ck_cond,-C}'[set ck_cond field in pass-through (def: 0)]'
  '--feature[feature field contents]'
  {--help,-h}'[output this usage message]'
  {--lba,-L}'[LBA field contents (def: 0)]'
  {--len,-l}'[cdb length: 16 or 12 bytes (def: 16)]'
  {--verbose,-v}'[increase verbosity]'
  {--version,-V}'[print version string and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
