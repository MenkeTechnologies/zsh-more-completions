#compdef rlinetd
# Documentation: https://man.archlinux.org/search?q=rlinetd
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-p,--parser}'[alternative parser module]:file:_files'
  {-f,--config}'[alternative config file (default /etc/rlinetd.conf)]:file:_files'
  {-d,--debug}'[enable debugging]'
  '(- * :)'{-h,--help}'[display help message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
