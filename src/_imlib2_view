#compdef imlib2_view
# Documentation: https://man.archlinux.org/search?q=imlib2_view
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-g[set progress granularity to N% (default 10(%))]'
  '-l[introduce N ms delay in progress callback (default 0)]'
  '-p[Print info in progress callback (default no)]'
  '-s[set scaling factor to S (default 1.0)]'
  '-v[Increase verbosity]'
  '*:filename:_files'
)

_arguments -s -S $arguments
