#compdef wireplumber
# Documentation: https://man.archlinux.org/search?q=wireplumber
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[show help options]'
  {-v,--version}'[show version]'
  {-c,--config-file}'[the configuration file to use]'
  {-p,--profile}'[the profile to load]'
  '*:filename:_files'
)

_arguments -s -S $arguments
