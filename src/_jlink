#compdef jlink

local -a arguments

arguments=(
  '--add-modules[root modules to resolve]:modules:'
  '--bind-services[link in service provider modules and their dependencies]'
  {-c,--compress}'[enable compression of resources]:level:(0 1 2)'
  '--disable-plugin[disable the plugin mentioned]'
  '--endian[byte order of generated jimage]'
  '(- * :)'{-h,--help}'[print this help message]'
  '--ignore-signing-information[suppress a fatal error when signed modular JARs are linked in]'
  '--launcher[add a launcher command]:name=module:'
  '--limit-modules[limit the universe of observable modules]:modules:'
  '--list-plugins[list available plugins]'
  {-p,--module-path}'[module path]'
  '--no-header-files[exclude include header files]'
  '--no-man-pages[exclude man pages]'
  '--output[location of output path]'
  '--post-process-path[post process an existing image]'
  '--resources-last-sorter[the last plugin allowed to sort resources]'
  '--save-opts[save jlink options in the given file]'
  {-G,--strip-debug}'[strip debug information]'
  '--suggest-providers[suggest providers that implement the given service types]'
  {-v,--verbose}'[enable verbose tracing]'
  '--version[version information]'
  '*:filename:_files'
)

_arguments -s -S $arguments
