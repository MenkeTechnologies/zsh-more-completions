#compdef install

# Completion for install - install binaries
# Supports both BSD (macOS) and GNU coreutils options

local arguments

arguments=(
  # Backup options
  '--backup=-[make a backup of each existing destination file]::backup type:(none off numbered t existing nil simple never)'
  '-b[like --backup but does not accept an argument]'
  '-B[specify backup suffix]:backup suffix'

  # Copy behavior
  {-C,--compare}'[compare source and destination; do not modify if identical]'
  '-c[(ignored, copy is the default)]'

  # Directory handling
  {-d,--directory}'[create directories; missing parents created as required]'
  '-D[create all leading components of DEST except the last]'
  '--debug[explain how a file is copied, implies -v]'

  # Destination root
  '(--target-directory)-D[create leading directory components of DEST]:destdir:_directories'

  # File attributes
  '-f[specify target file flags]:file flags'
  {-g,--group}'[set group ownership]:group:_groups'
  {-m,--mode}'[set permission mode (as in chmod)]:mode'
  {-o,--owner}'[set ownership (super-user only)]:owner:_users'

  # Timestamps
  {-p,--preserve-timestamps}'[preserve access/modification times of source files]'

  # Stripping
  {-s,--strip}'[strip symbol tables]'
  '--strip-program=[program used to strip binaries]:strip program:_command_names -e'

  # Suffix
  {-S,--suffix}'[override the usual backup suffix]:suffix'

  # Target directory
  {-t,--target-directory}'[copy all SOURCE arguments into DIRECTORY]:target directory:_directories'
  {-T,--no-target-directory}'[treat DEST as a normal file]'

  # Verbose
  {-v,--verbose}'[print the name of each created file or directory]'

  # Linking (BSD)
  '-l[create link instead of copy]:link type:((a\:absolute r\:relative h\:hard s\:symbolic m\:mixed))'

  # Hashing (BSD)
  '-h[calculate digest when copying]:hash algorithm:(none sha1 sha256 sha512)'

  # Metalog (BSD)
  '-M[write metadata to metalog file]:metalog file:_files'

  # Tags (BSD)
  '-T[specify mtree tags for metalog]:tags'

  # Sync (BSD)
  '-S[flush each file to disk after copying]'

  # Unprivileged (BSD)
  '-U[run unprivileged; do not change owner/group/flags]'

  # SELinux (GNU)
  {-P,--preserve-context}'[preserve SELinux security context]'
  '-Z[set SELinux security context of destination to default type]'
  '--context=-[set SELinux or SMACK security context]::security context'

  '--help[display help and exit]'
  '--version[output version information and exit]'
  '*:file:_files'
)

_arguments -s -S $arguments
