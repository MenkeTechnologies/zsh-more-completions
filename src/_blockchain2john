local -a arguments

arguments=(
  {-h,--help}'[show this help message and exit]'
  '--json[The wallet using v2 format?]'
  '--base64[does the wallet contain only a base64 string?]'
  '*:filename:_files'
)

_arguments -s -S $arguments
