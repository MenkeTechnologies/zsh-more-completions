#compdef epstopdf

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  {-o+,--outfile=}'[write result to file]:file:_files -g "*.pdf"' \
  '--restricted[use restricted mode]' \
  '--debug[output debugging info]' \
  '--nodebug[disable debugging]' \
  '--exact[scan ExactBoundingBox]' \
  '--noexact[do not scan ExactBoundingBox]' \
  '--filter[read standard input]' \
  '--nofilter[do not read standard input]' \
  '--gs[run ghostscript]' \
  '--nogs[do not run ghostscript]' \
  '--hires[scan HiResBoundingBox]' \
  '--nohires[do not scan HiResBoundingBox]' \
  '--gscmd=[command to pipe output to]:cmd:_command_names -e' \
  '*--gsopt=[single option for gs]:opt:' \
  '--gsopts=[options for gs]:opts:' \
  '--autorotate=[set AutoRotatePages]:val:(None All PageByPage)' \
  '--compress[use compression]' \
  '--nocompress[disable compression]' \
  '--device=[use -sDEVICE=DEV]:device:' \
  '--embed[embed fonts]' \
  '--noembed[do not embed fonts]' \
  '--gray[grayscale output]' \
  '--nogray[disable grayscale output]' \
  '--pdfsettings=[use -dPDFSETTINGS]:setting:(screen ebook printer prepress default)' \
  '--quiet[use -q]' \
  '--noquiet[disable quiet]' \
  '--res=[set image resolution (DPI or DPIxDPI)]:dpi:' \
  '1::EPS file:_files -g "*.(eps|ps)"' \
  '2::PDF output file:_files -g "*.pdf"' && ret=0

return ret
