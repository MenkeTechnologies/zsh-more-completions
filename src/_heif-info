#compdef heif-info
# Documentation: https://man.archlinux.org/search?q=heif-info
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-d,--dump-boxes}'[show a low-level dump of all MP4 file boxes]'
  '(- * :)'{-h,--help}'[show help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
