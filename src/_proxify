#compdef proxify

# Zsh completion for proxify - Swiss Army knife proxy tool for HTTP/HTTPS traffic capture

_arguments -s -S \
  '(-addr --addr)'{-addr,--addr}'[proxify listening address]:addr:' \
  '(-config --config)'{-config,--config}'[path to the proxify configuration file]:file:_files' \
  '(-dns-addr --dns-addr)'{-dns-addr,--dns-addr}'[listen DNS address]:addr:' \
  '(-dns-mapping --dns-mapping)'{-dns-mapping,--dns-mapping}'[DNS A mapping (format host:ip)]:mapping:' \
  '(-dns-resolver --dns-resolver)'{-dns-resolver,--dns-resolver}'[custom DNS resolvers]:resolver:' \
  '(-http-proxy --http-proxy)'{-http-proxy,--http-proxy}'[Upstream HTTP proxies]:proxy:' \
  '(-socks5-proxy --socks5-proxy)'{-socks5-proxy,--socks5-proxy}'[Upstream SOCKS5 proxies]:proxy:' \
  '(-no-restriction --no-restriction)--no-restriction[disable proxy authentication restriction]' \
  '(-allow-ip --allow-ip)'{-allow-ip,--allow-ip}'[allow specific IP addresses]:IP:' \
  '(-deny-ip --deny-ip)'{-deny-ip,--deny-ip}'[deny specific IP addresses]:IP:' \
  '(-allow-domain --allow-domain)'{-allow-domain,--allow-domain}'[allow specific domains]:domain:' \
  '(-deny-domain --deny-domain)'{-deny-domain,--deny-domain}'[deny specific domains]:domain:' \
  '(-output --output)'{-output,--output}'[output file]:file:_files' \
  '(-dump-req --dump-req)--dump-req[dump requests to output directory]' \
  '(-dump-resp --dump-resp)--dump-resp[dump responses to output directory]' \
  '(-request-dsl --request-dsl)'{-request-dsl,--request-dsl}'[DSL expression to match request]:expr:' \
  '(-response-dsl --response-dsl)'{-response-dsl,--response-dsl}'[DSL expression to match response]:expr:' \
  '(-request-match-replace-dsl --request-match-replace-dsl)'{-request-match-replace-dsl,--request-match-replace-dsl}'[DSL match and replace expression for request]:expr:' \
  '(-response-match-replace-dsl --response-match-replace-dsl)'{-response-match-replace-dsl,--response-match-replace-dsl}'[DSL match and replace expression for response]:expr:' \
  '(-ca-cert --ca-cert)'{-ca-cert,--ca-cert}'[CA certificate file]:file:_files' \
  '(-ca-key --ca-key)'{-ca-key,--ca-key}'[CA private key file]:file:_files' \
  '(-silent --silent)--silent[make the runner quiet]' \
  '(-nc --no-color)'{-nc,--no-color}'[disable output content coloring]' \
  '(-verbose --verbose)--verbose[verbose output]' \
  '(-version --version)--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]'
