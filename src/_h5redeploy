#compdef h5redeploy

local -a arguments

arguments=(
  '-help[display this help message]'
  '-echo[show all the shell commands executed]'
  '-force[no prompt, just do it]'
  '-prefix[new directory to find HDF5 lib/ and include/]:directory:_directories'
  '-exec-prefix[new directory to find HDF5 lib/]:directory:_directories'
  '-libdir[new directory for the HDF5 lib directory]:directory:_directories'
  '-includedir[new directory for the HDF5 header files]:directory:_directories'
  '-tool[tool to update]:tool name:'
  '-show[show the commands without executing them]'
  '*:filename:_files'
)

_arguments -s -S $arguments
