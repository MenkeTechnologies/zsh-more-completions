#compdef racer
# Documentation: https://man.archlinux.org/search?q=racer
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[prints help information]'
  {-V,--version}'[prints version information]'
  {-i,--interface}'[interface mode \[possible values: text, tab-text\]]'
  '*:filename:_files'
)

_arguments -s -S $arguments
