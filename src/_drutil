#compdef drutil

local -a subcommands

subcommands=(
    'burn:Burn a disc from a folder'
    'eject:Eject a disc'
    'erase:Erase a disc'
    'filename:Print the device filename'
    'getconfig:Get device configuration'
    'info:Print drive information'
    'list:List attached burning devices'
    'poll:Poll for disc insertion'
    'size:Estimate burn size'
    'status:Print device status'
    'subchannel:Print subchannel information'
    'toc:Print table of contents'
    'tray:Control the disc tray'
    'trackverify:Verify track data'
    'cdtext:Print CD-Text information'
    'discinfo:Print disc information'
)

_arguments -s -S \
    '-drive[Select drive by number]:drive number' \
    '1:subcommand:->subcmd' \
    '*:: :->args' && return

case $state in
    subcmd)
        _describe 'drutil subcommand' subcommands
        ;;
    args)
        case $words[1] in
            burn)
                _arguments \
                    '-noverify[Don'\''t verify after burning]' \
                    '-eject[Eject when done]' \
                    '-speed[Set burn speed]:speed:(1 2 4 8 16 24 max)' \
                    '-append[Append to existing session]' \
                    '-audio[Burn as audio CD]' \
                    '1:folder to burn:_directories'
                ;;
            erase)
                _arguments \
                    '1:erase type:(quick full)'
                ;;
            tray)
                _arguments \
                    '1:tray action:(open close)'
                ;;
        esac
        ;;
esac
