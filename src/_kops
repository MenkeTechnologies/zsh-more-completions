#compdef kops

# Zsh completion for kops (Kubernetes Operations)

_kops() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    local -a global_flags
    global_flags=(
        '--name=[name of cluster]:cluster name'
        '--state=[location of state store]:state store (s3\://...)'
        '(-v --verbosity)'{-v,--verbosity}'=[set the log level verbosity]:verbosity'
    )

    local -a commands
    commands=(
        'create:create a resource'
        'delete:delete a resource'
        'edit:edit a resource'
        'export:export configuration'
        'get:get one or many resources'
        'replace:replace a resource'
        'rolling-update:rolling update a cluster'
        'set:set fields on a resource'
        'toolbox:miscellaneous tools'
        'update:update a cluster'
        'upgrade:upgrade a cluster'
        'validate:validate a cluster'
        'version:print the kops version'
        'completion:generate shell completion script'
    )

    _arguments -C \
        $global_flags \
        '1:command:->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'kops command' commands
            ;;
        args)
            case $words[1] in
                create)
                    local -a create_commands=(
                        'cluster:create a cluster'
                        'instancegroup:create an instance group'
                        'secret:create a secret'
                    )
                    _arguments -C \
                        $global_flags \
                        '1:create subcommand:->createcmd' \
                        '*::arg:->createargs'
                    case $state in
                        createcmd)
                            _describe -t create_commands 'create subcommand' create_commands
                            ;;
                        createargs)
                            case $line[1] in
                                cluster)
                                    _arguments -s -S \
                                        $global_flags \
                                        '--zones=[zones in which to run the cluster]:zones' \
                                        '--master-zones=[zones in which to run masters]:master zones' \
                                        '--master-size=[instance size for masters]:master size' \
                                        '--node-count=[total number of nodes]:count' \
                                        '--node-size=[instance size for nodes]:node size' \
                                        '--image=[machine image for instances]:image' \
                                        '--cloud=[cloud provider to use]:cloud:(aws gce azure openstack)' \
                                        '--networking=[networking mode to use]:networking' \
                                        '--topology=[type of network topology]:topology:(public private)' \
                                        '--dns-zone=[DNS hosted zone to use]:dns zone' \
                                        '--out=[path to write any local output]:output path:_directories' \
                                        '--target=[target for generated output]:target:(direct terraform cloudformation)' \
                                        '--ssh-public-key=[SSH public key to use]:ssh key file:_files' \
                                        '--kubernetes-version=[version of kubernetes to run]:version' \
                                        '--yes[immediately create the cluster]' \
                                        '--dry-run[only print the object that would be created]' \
                                        '1:cluster name:'
                                    ;;
                                instancegroup)
                                    _arguments -s -S \
                                        $global_flags \
                                        '--role=[role of the instance group]:role:(Master Node Bastion)' \
                                        '--subnet=[subnets for the instance group]:subnets' \
                                        '1:instance group name:'
                                    ;;
                                secret)
                                    _arguments -s -S \
                                        $global_flags \
                                        '1:secret type:(sshpublickey)' \
                                        '2:secret name:'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                delete)
                    local -a delete_commands=(
                        'cluster:delete a cluster'
                        'instancegroup:delete an instance group'
                        'secret:delete a secret'
                    )
                    _arguments -C \
                        $global_flags \
                        '1:delete subcommand:->deletecmd' \
                        '*::arg:->deleteargs'
                    case $state in
                        deletecmd)
                            _describe -t delete_commands 'delete subcommand' delete_commands
                            ;;
                        deleteargs)
                            case $line[1] in
                                cluster)
                                    _arguments -s -S \
                                        $global_flags \
                                        '--yes[immediately delete the cluster]' \
                                        '--unregister[only unregister the cluster, do not delete cloud resources]' \
                                        '--external[delete cluster without cloud resource cleanup]' \
                                        '1:cluster name:'
                                    ;;
                                instancegroup)
                                    _arguments -s -S \
                                        $global_flags \
                                        '--yes[immediately delete the instance group]' \
                                        '1:instance group name:'
                                    ;;
                                secret)
                                    _arguments -s -S \
                                        $global_flags \
                                        '1:secret name:'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                edit)
                    local -a edit_commands=(
                        'cluster:edit a cluster'
                        'instancegroup:edit an instance group'
                    )
                    _arguments -C \
                        $global_flags \
                        '1:edit subcommand:->editcmd' \
                        '*::arg:->editargs'
                    case $state in
                        editcmd)
                            _describe -t edit_commands 'edit subcommand' edit_commands
                            ;;
                        editargs)
                            case $line[1] in
                                cluster)
                                    _arguments -s -S $global_flags '1:cluster name:'
                                    ;;
                                instancegroup)
                                    _arguments -s -S $global_flags '1:instance group name:'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                export)
                    local -a export_commands=(
                        'kubecfg:export kubecfg file for a cluster'
                    )
                    _arguments -C \
                        $global_flags \
                        '1:export subcommand:->exportcmd' \
                        '*::arg:->exportargs'
                    case $state in
                        exportcmd)
                            _describe -t export_commands 'export subcommand' export_commands
                            ;;
                        exportargs)
                            case $line[1] in
                                kubecfg)
                                    _arguments -s -S \
                                        $global_flags \
                                        '--admin[export admin credentials]' \
                                        '--kubeconfig=[path to kubeconfig file]:kubeconfig file:_files' \
                                        '1:cluster name:'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                get)
                    local -a get_commands=(
                        'clusters:get one or many clusters'
                        'instancegroups:get one or many instance groups'
                        'secrets:get one or many secrets'
                    )
                    _arguments -C \
                        $global_flags \
                        '-o[output format]:format:(table json yaml)' \
                        '1:get subcommand:->getcmd' \
                        '*::arg:->getargs'
                    case $state in
                        getcmd)
                            _describe -t get_commands 'get subcommand' get_commands
                            ;;
                        getargs)
                            _arguments -s -S $global_flags '*:name:'
                            ;;
                    esac
                    ;;
                replace)
                    _arguments -s -S \
                        $global_flags \
                        '-f[filename to use to replace the resource]:file:_files' \
                        '--force[force replacement]'
                    ;;
                rolling-update)
                    local -a ru_commands=(
                        'cluster:rolling update a cluster'
                    )
                    _arguments -C \
                        $global_flags \
                        '1:rolling-update subcommand:->rucmd' \
                        '*::arg:->ruargs'
                    case $state in
                        rucmd)
                            _describe -t ru_commands 'rolling-update subcommand' ru_commands
                            ;;
                        ruargs)
                            case $line[1] in
                                cluster)
                                    _arguments -s -S \
                                        $global_flags \
                                        '--yes[immediately perform the rolling update]' \
                                        '--force[force rolling update]' \
                                        '--master-interval=[time between restarting masters]:duration' \
                                        '--node-interval=[time between restarting nodes]:duration' \
                                        '--bastion-interval=[time between restarting bastions]:duration' \
                                        '--fail-on-drain-error[fail if drain errors are encountered]' \
                                        '--fail-on-validate-error[fail if validation errors are encountered]' \
                                        '--cloudonly[perform rolling update without draining nodes]' \
                                        '1:cluster name:'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                set)
                    local -a set_commands=(
                        'cluster:set cluster fields'
                    )
                    _arguments -C \
                        $global_flags \
                        '1:set subcommand:->setcmd' \
                        '*::arg:->setargs'
                    case $state in
                        setcmd)
                            _describe -t set_commands 'set subcommand' set_commands
                            ;;
                        setargs)
                            _arguments -s -S $global_flags '*:field=value:'
                            ;;
                    esac
                    ;;
                update)
                    local -a update_commands=(
                        'cluster:update a cluster'
                    )
                    _arguments -C \
                        $global_flags \
                        '1:update subcommand:->updatecmd' \
                        '*::arg:->updateargs'
                    case $state in
                        updatecmd)
                            _describe -t update_commands 'update subcommand' update_commands
                            ;;
                        updateargs)
                            case $line[1] in
                                cluster)
                                    _arguments -s -S \
                                        $global_flags \
                                        '--yes[immediately apply changes]' \
                                        '--target=[target for output]:target:(direct terraform cloudformation)' \
                                        '--out=[path to write output]:output path:_directories' \
                                        '--create-kube-config[create a kubeconfig file for the cluster]' \
                                        '--lifecycle-overrides=[comma-separated list of overrides]:overrides' \
                                        '1:cluster name:'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                upgrade)
                    local -a upgrade_commands=(
                        'cluster:upgrade a cluster'
                    )
                    _arguments -C \
                        $global_flags \
                        '1:upgrade subcommand:->upgradecmd' \
                        '*::arg:->upgradeargs'
                    case $state in
                        upgradecmd)
                            _describe -t upgrade_commands 'upgrade subcommand' upgrade_commands
                            ;;
                        upgradeargs)
                            case $line[1] in
                                cluster)
                                    _arguments -s -S \
                                        $global_flags \
                                        '--yes[immediately apply the upgrade]' \
                                        '--channel=[channel to use for upgrade]:channel' \
                                        '--kubernetes-version=[kubernetes version to use]:version' \
                                        '1:cluster name:'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                validate)
                    local -a validate_commands=(
                        'cluster:validate a cluster'
                    )
                    _arguments -C \
                        $global_flags \
                        '1:validate subcommand:->validatecmd' \
                        '*::arg:->validateargs'
                    case $state in
                        validatecmd)
                            _describe -t validate_commands 'validate subcommand' validate_commands
                            ;;
                        validateargs)
                            case $line[1] in
                                cluster)
                                    _arguments -s -S \
                                        $global_flags \
                                        '--wait=[amount of time to wait for cluster to become ready]:duration' \
                                        '--count=[number of consecutive successful validations]:count' \
                                        '1:cluster name:'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                version)
                    _arguments -s -S '--short[only print the main version number]'
                    ;;
                completion)
                    _arguments -s -S '1:shell:(bash zsh fish)'
                    ;;
                toolbox)
                    local -a toolbox_commands=(
                        'dump:dump cluster state'
                        'template:render templates'
                    )
                    _arguments -C \
                        $global_flags \
                        '1:toolbox subcommand:->tbcmd' \
                        '*::arg:->tbargs'
                    case $state in
                        tbcmd)
                            _describe -t toolbox_commands 'toolbox subcommand' toolbox_commands
                            ;;
                    esac
                    ;;
            esac
            ;;
    esac
}

_kops "$@"
