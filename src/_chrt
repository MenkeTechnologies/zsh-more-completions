#compdef chrt

# chrt - manipulate the real-time attributes of a process
# Part of util-linux

_chrt_policies=(
  '(-b --batch -d --deadline -f --fifo -i --idle -o --other -r --rr)'{-b,--batch}'[set scheduling policy to SCHED_BATCH]'
  '(-b --batch -d --deadline -f --fifo -i --idle -o --other -r --rr)'{-d,--deadline}'[set scheduling policy to SCHED_DEADLINE]'
  '(-b --batch -d --deadline -f --fifo -i --idle -o --other -r --rr)'{-f,--fifo}'[set scheduling policy to SCHED_FIFO]'
  '(-b --batch -d --deadline -f --fifo -i --idle -o --other -r --rr)'{-i,--idle}'[set scheduling policy to SCHED_IDLE]'
  '(-b --batch -d --deadline -f --fifo -i --idle -o --other -r --rr)'{-o,--other}'[set scheduling policy to SCHED_OTHER]'
  '(-b --batch -d --deadline -f --fifo -i --idle -o --other -r --rr)'{-r,--rr}'[set scheduling policy to SCHED_RR (default)]'
)

_arguments -s -S \
  $_chrt_policies \
  {-a,--all-tasks}'[operate on all tasks (threads) for a given pid]' \
  {-m,--max}'[show min and max valid priorities and exit]' \
  {-p,--pid}'[operate on an existing pid and do not launch a new task]' \
  {-R,--reset-on-fork}'[set SCHED_RESET_ON_FORK for FIFO or RR]' \
  {-T,--sched-runtime}'[runtime parameter for DEADLINE in nanoseconds]:runtime (ns)' \
  {-P,--sched-period}'[period parameter for DEADLINE in nanoseconds]:period (ns)' \
  {-D,--sched-deadline}'[deadline parameter for DEADLINE in nanoseconds]:deadline (ns)' \
  {-v,--verbose}'[display status information]' \
  '(- *)'{-h,--help}'[display help text and exit]' \
  '(- *)'{-V,--version}'[display version information and exit]' \
  '1:priority' \
  '*:command or pid:_command_names -e'
