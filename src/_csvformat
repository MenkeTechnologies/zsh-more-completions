#compdef csvformat

# Zsh completion for csvformat (csvkit)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --delimiter)'{-d,--delimiter}'[input delimiting character]:delimiter:' \
  '(-t --tabs)'{-t,--tabs}'[input is tab-delimited]' \
  '(-q --quotechar)'{-q,--quotechar}'[input character for quoting]:char:' \
  '(-u --quoting)'{-u,--quoting}'[input quoting style]:style:(0 1 2 3)' \
  '(-b --no-doublequote)'{-b,--no-doublequote}'[do not double-quote]' \
  '(-p --escapechar)'{-p,--escapechar}'[escape character]:char:' \
  '(-e --encoding)'{-e,--encoding}'[input encoding]:encoding:' \
  '(-H --no-header-row)'{-H,--no-header-row}'[no header row]' \
  '(-K --no-inference)'{-K,--no-inference}'[disable type inference]' \
  '(-D --out-delimiter)'{-D,--out-delimiter}'[output delimiter]:delimiter:' \
  '(-T --out-tabs)'{-T,--out-tabs}'[output as tab-delimited]' \
  '(-A --out-asv)'{-A,--out-asv}'[output as ASCII separated values]' \
  '(-Q --out-quotechar)'{-Q,--out-quotechar}'[output quote character]:char:' \
  '(-U --out-quoting)'{-U,--out-quoting}'[output quoting style]:style:(0 1 2 3)' \
  '(-B --out-no-doublequote)'{-B,--out-no-doublequote}'[output without double-quoting]' \
  '(-P --out-escapechar)'{-P,--out-escapechar}'[output escape character]:char:' \
  '(-M --out-lineterminator)'{-M,--out-lineterminator}'[output line terminator]:terminator:' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:csv file:_files -g "*.csv *.tsv"' && return 0
