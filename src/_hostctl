#compdef hostctl
# Zsh completion for hostctl - Manage /etc/hosts from the command line
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--host-file[specify hosts file path]:path:_files' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '--raw[output in raw format]' \
  '(- *)--help[show help information]' \
  '(- *)--version[show version]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a commands=(
      'list:list profiles and domains'
      'add:add domains to a profile'
      'remove:remove domains from a profile'
      'enable:enable a profile'
      'disable:disable a profile'
      'backup:create a backup of the hosts file'
      'restore:restore hosts file from backup'
      'status:show profile status'
      'sync:sync hosts file'
      'set:set domains for a profile'
      'replace:replace domains in a profile'
      'info:show hostctl information'
    )
    _describe -t commands 'hostctl command' commands && ret=0
    ;;
  args)
    case $words[1] in
      add|set|replace)
        _arguments -s -S \
          '--host-file[specify hosts file path]:path:_files' \
          '(-q --quiet)'{-q,--quiet}'[suppress output]' \
          '--raw[output in raw format]' \
          '--from[add domains from file]:file:_files' \
          '(-p --profile)'{-p,--profile}'[profile name]:profile:' \
          '*:domain:' && ret=0
        ;;
      remove)
        _arguments -s -S \
          '--host-file[specify hosts file path]:path:_files' \
          '(-q --quiet)'{-q,--quiet}'[suppress output]' \
          '--raw[output in raw format]' \
          '(-p --profile)'{-p,--profile}'[profile name]:profile:' \
          '*:domain:' && ret=0
        ;;
      enable|disable)
        _arguments -s -S \
          '--host-file[specify hosts file path]:path:_files' \
          '(-q --quiet)'{-q,--quiet}'[suppress output]' \
          '--raw[output in raw format]' \
          '(-p --profile)'{-p,--profile}'[profile name]:profile:' && ret=0
        ;;
      list|status|info|backup|restore|sync)
        _arguments -s -S \
          '--host-file[specify hosts file path]:path:_files' \
          '(-q --quiet)'{-q,--quiet}'[suppress output]' \
          '--raw[output in raw format]' && ret=0
        ;;
    esac
    ;;
esac
return ret
