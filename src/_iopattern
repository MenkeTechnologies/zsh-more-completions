#compdef iopattern
# Documentation: https://man.archlinux.org/search?q=iopattern
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-v[# print timestamp]'
  '-d[# instance name to snoop]'
  '-f[# snoop this file only]'
  '-m[# this FS only]'
  '*:filename:_files'
)

_arguments -s -S $arguments
