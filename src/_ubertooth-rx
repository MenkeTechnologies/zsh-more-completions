#compdef ubertooth-rx

local -a arguments

arguments=(
  '-l[LAP to decode (6 hex) - if not specified sniff all LAPs]:lap:'
  '-u[UAP to decode (2 hex) - if not specified calculate UAP (requires LAP)]:uap:'
  '-z[survey mode - discover and list piconets (implies -s, interrupt with ctrl-C)]'
  '-i[input file - if not specified use Ubertooth for live capture]:filename:_files'
  '-c[set a fixed bluetooth channel \[Default: 39\]]:channel:'
  '-e[max access code errors (default: 2, range: 0-4)]:errors:'
  '-t[sniff timeout - 0 means no timeout \[Default: 0\]]'
  '-r[capture packets to PcapNG file]:filename:'
  '-q[capture packets to PCAP file]:filename:'
  '-d[dump packets to binary file]:filename:'
  '-V[version information]'
  '-U[set ubertooth device to use]:device:(0 1 2 3 4 5 6 7)'
  '*:filename:_files'
)

_arguments -s -S $arguments
