#compdef foremost

local -a arguments

arguments=(
  '-V[display copyright information and exit]'
  '-t[specify file type (e.g. jpeg,pdf)]:types:'
  '-d[turn on indirect block detection (for UNIX file-systems)]'
  '-i[specify input file (default is stdin)]:file:_files'
  '-a[Write all headers, perform no error detection (corrupted files)]'
  '-w[Only write the audit file, do not write any detected files to the disk]'
  '-o[set output directory (defaults to output)]:directory:_files -/'
  '-c[set configuration file to use (defaults to foremost.conf)]:file:_files'
  '-q[enables quick mode. Search are performed on 512 byte boundaries.]'
  '-Q[enables quiet mode. Suppress output messages.]'
  '-v[verbose mode. Logs all messages to screen]'
  '*:filename:_files'
)

_arguments -s -S $arguments
