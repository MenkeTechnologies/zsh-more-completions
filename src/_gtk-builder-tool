#compdef gtk-builder-tool
# Documentation: https://man.archlinux.org/search?q=gtk-builder-tool
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--replace[replace the file]'
  '--id[preview only the named object]'
  '--css[use style from CSS file]'
  '*:filename:_files'
)

_arguments -s -S $arguments
