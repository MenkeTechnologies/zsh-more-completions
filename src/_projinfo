local -a arguments

arguments=(
  '-o[formats is a comma separated combination of: all,default,PROJ,WKT_ALL,WKT2_2015,WKT2_2018,WKT1_GDAL,WKT1_ESRI,PROJJSON]'
  '*:filename:_files'
