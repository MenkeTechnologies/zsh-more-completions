#compdef duf

# Zsh completion for duf (Disk Usage/Free Utility)

_arguments -s -S \
  '-all[list all devices including pseudo, duplicate, and inaccessible]' \
  '-avail-threshold[YAML file with threshold values for available space]:file:_files' \
  '-hide[hide specific named devices]:devices:' \
  '-hide-fs[hide specific filesystems]:filesystems:(tmpfs devtmpfs squashfs overlay)' \
  '-hide-mp[hide specific mount points]:mount points:_files -/' \
  '-inodes[list inode information instead of block usage]' \
  '-json[output all device information as JSON]' \
  '-only[only show specific named devices]:devices:' \
  '-only-fs[only show specific filesystems]:filesystems:(ext4 xfs btrfs zfs ntfs apfs tmpfs)' \
  '-only-mp[only show specific mount points]:mount points:_files -/' \
  '-output[select fields to output]:fields:(mountpoint size used avail usage inodes inodes_used inodes_avail inodes_usage type filesystem)' \
  '-sort[sort by field]:field:(mountpoint size used avail usage inodes inodes_used inodes_avail inodes_usage type filesystem)' \
  '-style[style to use for output]:style:(unicode ascii)' \
  '-theme[theme to use for output]:theme:(dark light ansi)' \
  '-usage-threshold[YAML file with threshold values for usage]:file:_files' \
  '-warnings[list warnings]:warnings:' \
  '-width[max output width]:width:' \
  '(-version)-version[display version]' \
  '*:mount point or device:_files -/'
