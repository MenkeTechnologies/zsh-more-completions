#compdef remmina

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  '--help-all[show all help options]'
  '--help-gapplication[show GApplication options]'
  '--help-gtk[show GTK+ Options]'
  {-a,--about}'[show about dialog]'
  {-c,--connect}'[connect to a .remmina file]:file:_files'
  {-e,--edit}'[edit a .remmina file]:file:_files'
  {-n,--new}'[create a new connection profile]'
  {-p,--pref}'[show preferences dialog page]:page: '
  {-x,--plugin}'[execute the plugin]:plugin: '
  {-q,--quit}'[quit the application]'
  {-s,--server}'[use default server name (for --new)]:server: '
  {-t,--protocol}'[use default protocol (for --new)]:protocol: '
  {-i,--icon}'[start as tray icon]'
  {-v,--version}'[show the applications version]'
  {-V,--full-version}'[show the applications version, including the pulgin versions]'
  '--display[X display to use]:display: '
  '*:filename:_files'
)

_arguments -s -S $arguments
