#compdef resolvconf

local -a arguments

arguments=(
  '-a[add DNS information to the specified interface]:interface: '
  '-d[delete DNS information from the specified interface]:interface: '
  '-h[show this help cruft]'
  '-i[show interfaces that have supplied DNS information]:pattern: '
  '-l[show DNS information, optionally from matching interfaces]:pattern: '
  '-u[run updates from our current DNS information]'
  '--version[echo the resolvconf version]'
  '-f[ignore non existent interfaces]'
  '-m[give the added DNS information a metric]:metric: '
  '-p[mark the interface as private]'
  '-x[mark the interface as exclusive]'
  '-I[init the state dir]'
  '-r[restart the system service]'
  '-R[show the system service restart command]'
  '-v[echo NEWDOMAIN, NEWSEARCH and NEWNS variables to stdout]:pattern: '
  '-V[same as -v, but only uses configuration]:pattern: '
  '*:filename:_files'
)

_arguments -s -S $arguments
