#compdef test_be

local -a arguments

arguments=(
  {-l,--list-tests}'[list all/matching test cases]'
  {-t,--list-tags}'[list all/matching tags]'
  {-s,--success}'[include successful tests in output]'
  {-b,--break}'[break into debugger on failure]'
  {-e,--nothrow}'[skip exception tests]'
  {-i,--invisibles}'[show invisibles (tabs, newlines)]'
  {-o,--out}'[output filename]:file:_files'
  {-r,--reporter}'[reporter to use]:reporter:'
  {-n,--name}'[suite name]:name:'
  {-a,--abort}'[abort at first failure]'
  {-x,--abortx}'[abort after x failures]:failures:'
  {-w,--warn}'[enable warnings]:name:'
  {-d,--durations}'[show test durations]'
  {-D,--min-duration}'[show test durations for tests taking longer than given value]:duration:'
  {-f,--input-file}'[load test names to run from a file]:file:_files'
  {-c,--section}'[specify section to run]:name:'
  {-v,--verbosity}'[set output verbosity]:verbosity:'
  '--list-test-names-only[list all/matching test cases names only]'
  '--list-reporters[list all reporters]'
  '--order[test case order (defaults to declared)]:order:'
  '--rng-seed[set a specific seed for random number generator]:seed:'
  '--use-colour[should output be colourised]:enabled:(yes no)'
  '--libidentify[report name and version according to libidentify standard]'
  '--wait-for-keypress[waits for a keypress before exiting]:when:(start exit both)'
  '--benchmark-samples[number of samples to collect]:count:'
  '--benchmark-resamples[number of resamples for the bootstrap]:count:'
  '--benchmark-confidence-interval[confidence interval for the bootstrap]:interval:'
  '--benchmark-no-analysis[perform only measurements; do not perform analysis]'
  '--benchmark-warmup-time[amount of time in milliseconds for warmup]:milliseconds:'
  '*:filename:_files'
)

_arguments -s -S $arguments
