#compdef cargo-watch

# Zsh completion for cargo-watch - Watch Rust project for changes and run commands

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[Show help]' \
  '(- *)'{-V,--version}'[Show version]' \
  '*'{-x,--exec}'[Cargo command to execute on changes]:cargo command:(build check clippy doc fmt run test bench update clean)' \
  '*'{-s,--shell}'[Shell command to execute on changes]:shell command:' \
  '(-d --delay)'{-d,--delay}'[File updates debounce delay in seconds]:seconds:' \
  '*'{-w,--watch}'[Watch specific file or directory]:path:_files' \
  '*'{-i,--ignore}'[Ignore a glob pattern]:pattern:' \
  '(-c --clear)'{-c,--clear}'[Clear the screen before each run]' \
  '(-q --quiet)'{-q,--quiet}'[Suppress output from cargo-watch itself]' \
  '--debug[Show debug output]' \
  '--why[Show paths that changed]' \
  '--workdir[Set the working directory]:directory:_directories' \
  '-B[Inject RUST_BACKTRACE=value into the command]:value:(1 full)' \
  '*--features[Comma-separated list of features to pass to cargo]:features:' \
  '--all-features[Pass --all-features to cargo]' \
  '--no-default-features[Pass --no-default-features to cargo]' \
  '--use-shell[Use a different shell]:shell:_command_names' \
  '--poll[Force use of polling for file changes]' \
  '--postpone[Postpone first run until a file changes]' \
  '(-N --notify)'{-N,--notify}'[Send a desktop notification on command completion]' \
  '--no-process-group[Do not use a process group]' \
  '*:arguments:' && ret=0

return ret
