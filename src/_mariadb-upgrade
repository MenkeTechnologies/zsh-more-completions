#compdef mariadb-upgrade

local -a arguments

arguments=(
  '--print-defaults[print the program argument list and exit.]'
  '--no-defaults[dont read default options from any option file.]'
  '--defaults-file[only read default options from the given file #.]'
  '--defaults-extra-file[read this file after the global files are read.]'
  '--defaults-group-suffix[additionally read default groups with # appended as a suffix.]'
  {-b,--basedir}'[not used by mysql_upgrade. Only for backward compatibility]'
  '--character-sets-dir[not used by mysql_upgrade. Only for backward compatibility]'
  '--compress[not used by mysql_upgrade. Only for backward compatibility]'
  {-d,--datadir}'[not used by mysql_upgrade. Only for backward compatibility]'
  '--debug-check[check memory and open file usage at exit.]'
  {-T,--debug-info}'[print some debug info at exit.]'
  '--default-character-set[not used by mysql_upgrade. Only for backward compatibility]'
  '--default-auth[default authentication client-side plugin to use.]'
  '--check-if-upgrade-is-needed[exits with status 0 if an upgrade is required, 1 otherwise]'
  {-f,--force}'[force execution of mysqlcheck even if mysql_upgrade has already been run]'
  {-h,--host}'[connect to host.]'
  {-p,--password}'[password to use when connecting to server]'
  '--plugin-dir[directory for client-side plugins.]'
  {-P,--port}'[port number to use for connection]'
  '--protocol[the protocol to use for connection (tcp, socket, pipe).]'
  '--silent[print less information]'
  {-S,--socket}'[the socket file to use for connection.]'
  '--ssl[enable SSL for connection]'
  '--ssl-ca[CA file in PEM format (implies --ssl)]'
  '--ssl-capath[CA directory (check OpenSSL docs, implies --ssl).]'
  '--ssl-cert[X509 cert in PEM format (implies --ssl).]'
  '--ssl-cipher[SSL cipher to use (implies --ssl).]'
  '--ssl-key[X509 key in PEM format (implies --ssl).]'
  '--ssl-crl[certificate revocation list (implies --ssl).]'
  '--ssl-crlpath[certificate revocation list path (implies --ssl).]'
  '--tls-version[TLS protocol version for secure connection.]'
  '--ssl-verify-server-cert[verify servers Common Name in its cert against hostname]'
  {-t,--tmpdir}'[directory for temporary files.]'
  {-s,--upgrade-system-tables}'[only upgrade the system tables in the mysql database.]'
  {-u,--user}'[user for login.]'
  {-v,--verbose}'[display more output about the process]'
  {-V,--version}'[output version information and exit.]'
  {-k,--version-check}'[run this program only if its server version matches the version it was built for]'
  '--write-binlog[write all commands including those issued by mysqlcheck to the binary log]'
  '*:filename:_files'
)

_arguments -s -S $arguments
