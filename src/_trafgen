#compdef trafgen

local -a arguments

arguments=(
  {-i,-c,--in,--conf}'[packet configuration file/stdin]:config:_files'
  {-o,-d,--out,--dev}'[networking device or output file]:netdev:'
  {-p,--cpp}'[run packet config through C preprocessor]'
  {-D,--define}'[add macro/define for C preprocessor]:macro:'
  {-J,--jumbo-support}'[support 64KB super jumbo frames (def: 2048B)]'
  {-R,--rfraw}'[inject raw 802.11 frames]'
  {-s,--smoke-test}'[probe if machine survived fuzz-tested packet]:ipv4:'
  {-n,--num}'[number of packets until exit (def: 0)]:count:'
  {-r,--rand}'[randomize packet selection (def: round robin)]'
  {-P,--cpus}'[specify number of forks (<= CPUs)]:count:'
  {-t,--gap}'[set approx. interpacket gap (s/ms/us/ns)]:time:'
  {-b,--rate}'[send traffic at specified rate]:rate:'
  {-S,--ring-size}'[manually set mmap size (KiB/MiB/GiB)]:size:'
  {-E,--seed}'[manually set srand(3) seed]:seed:'
  {-u,--user}'[drop privileges and change to userid]:userid:'
  {-g,--group}'[drop privileges and change to groupid]:groupid:'
  {-H,--prio-high}'[make this high priority process]'
  {-A,--no-sock-mem}'[do not tune core socket memory]'
  {-Q,--notouch-irq}'[do not touch IRQ CPU affinity of NIC]'
  {-q,--qdisc-path}'[enable qdisc kernel path (default off since 3.14)]'
  {-V,--verbose}'[be more verbose]'
  {-C,--no-cpu-stats}'[do not print CPU time statistics on exit]'
  {-v,--version}'[show version and exit]'
  {-e,--example}'[show built-in packet config example]'
  '(- * :)'{-h,--help}'[show help and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
