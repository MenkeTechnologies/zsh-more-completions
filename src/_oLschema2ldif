#compdef oLschema2ldif

local -a arguments

arguments=(
  {-b,--basedn}'[base DN]'
  {-I,--input}'[inputfile of OpenLDAP style schema otherwise]'
  {-O,--output}'[outputfile otherwise STDOUT]'
  '--usage[display brief usage message]'
  {-V,--version}'[print version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
