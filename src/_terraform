#compdef terraform

# Zsh completion for HashiCorp Terraform
# Covers Terraform 1.5+ commands and options

_terraform() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    local -a commands
    commands=(
        'init:Prepare your working directory for other commands'
        'validate:Check whether the configuration is valid'
        'plan:Show changes required by the current configuration'
        'apply:Create or update infrastructure'
        'destroy:Destroy previously-created infrastructure'
        'output:Show output values from your root module'
        'show:Show the current state or a saved plan'
        'state:Advanced state management'
        'import:Associate existing infrastructure with a Terraform resource'
        'refresh:Update the state to match remote systems'
        'fmt:Reformat your configuration in the standard style'
        'taint:Mark a resource instance as not fully functional'
        'untaint:Remove the taint marker from a resource instance'
        'workspace:Workspace management'
        'graph:Generate a Graphviz graph of the steps in an operation'
        'providers:Show the providers required for this configuration'
        'force-unlock:Release a stuck lock on the current workspace'
        'login:Obtain and save credentials for a remote host'
        'logout:Remove locally-stored credentials for a remote host'
        'test:Execute integration tests for Terraform modules'
        'console:Try Terraform expressions at an interactive command prompt'
        'version:Show the current Terraform version'
        'metadata:Metadata related commands'
        'get:Install or update remote Terraform modules'
    )

    local -a global_flags
    global_flags=(
        '-help[Show help for a command]'
        '-version[Show the current Terraform version]'
        '-chdir=[Switch to a different working directory before executing]:dir:_directories'
    )

    _arguments -C \
        $global_flags \
        '1:command:->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'terraform command' commands
            ;;
        args)
            case $words[1] in
                init)
                    _arguments -s \
                        '-backend=[Enable or disable backend]:bool:(true false)' \
                        '*-backend-config=[Backend configuration]:config:_files' \
                        '-force-copy[Suppress prompts about copying state data]' \
                        '-from-module=[Copy the contents of the given module]:source:_directories' \
                        '-get=[Download any modules for this configuration]:bool:(true false)' \
                        '-input=[Ask for input for variables if not directly set]:bool:(true false)' \
                        '-lock=[Don'\''t hold a state lock during backend migration]:bool:(true false)' \
                        '-lock-timeout=[Duration to retry a state lock]:duration:' \
                        '-no-color[Disable color codes in command output]' \
                        '*-plugin-dir=[Directory containing plugin binaries]:dir:_directories' \
                        '-reconfigure[Reconfigure a backend, ignoring any saved configuration]' \
                        '-migrate-state[Reconfigure a backend and attempt to migrate any existing state]' \
                        '-upgrade[Install the latest module and provider versions]' \
                        '-lockfile=[Set a dependency lockfile mode]:mode:(readonly)' \
                        '-ignore-remote-version[Do not check the remote Terraform version]' \
                        '-test-directory=[Set the Terraform test directory]:dir:_directories' \
                        '-json[Produce output in a machine-readable JSON format]' \
                        '-compact-warnings[Show warnings in a more compact form]'
                    ;;
                validate)
                    _arguments -s \
                        '-json[Produce output in a machine-readable JSON format]' \
                        '-no-color[Disable color codes in command output]' \
                        '-no-tests[Do not validate test files]' \
                        '-test-directory=[Set the Terraform test directory]:dir:_directories'
                    ;;
                plan)
                    _arguments -s \
                        '-compact-warnings[Show warnings in a more compact form]' \
                        '-destroy[Select the destroy planning mode]' \
                        '-detailed-exitcode[Return detailed exit codes when the command exits]' \
                        '-input=[Ask for input for variables if not directly set]:bool:(true false)' \
                        '-json[Produce output in a machine-readable JSON format]' \
                        '-lock=[Don'\''t hold a state lock during the operation]:bool:(true false)' \
                        '-lock-timeout=[Duration to retry a state lock]:duration:' \
                        '-no-color[Disable color codes in command output]' \
                        '-out=[Write a plan file to the given path]:file:_files' \
                        '-parallelism=[Limit the number of concurrent operations]:number:' \
                        '-refresh-only[Select the refresh-only planning mode]' \
                        '*-replace=[Force replacement of a particular resource instance]:address:' \
                        '*-target=[Limit the planning operation to specific resources]:address:' \
                        '*-var=[Set a value for one of the input variables]:var:' \
                        '*-var-file=[Load variable values from the given file]:file:_files' \
                        '-generate-config-out=[Write generated configuration to the given path]:file:_files' \
                        '-concise[Show a more concise plan output]'
                    ;;
                apply)
                    _arguments -s \
                        '-auto-approve[Skip interactive approval of plan before applying]' \
                        '-backup=[Path to backup the existing state file before modifying]:file:_files' \
                        '-compact-warnings[Show warnings in a more compact form]' \
                        '-destroy[Select the destroy planning mode]' \
                        '-input=[Ask for input for variables if not directly set]:bool:(true false)' \
                        '-json[Produce output in a machine-readable JSON format]' \
                        '-lock=[Don'\''t hold a state lock during the operation]:bool:(true false)' \
                        '-lock-timeout=[Duration to retry a state lock]:duration:' \
                        '-no-color[Disable color codes in command output]' \
                        '-parallelism=[Limit the number of concurrent operations]:number:' \
                        '-refresh-only[Select the refresh-only planning mode]' \
                        '*-replace=[Force replacement of a particular resource instance]:address:' \
                        '*-target=[Limit the operation to specific resources]:address:' \
                        '*-var=[Set a value for one of the input variables]:var:' \
                        '*-var-file=[Load variable values from the given file]:file:_files' \
                        '-concise[Show a more concise plan output]' \
                        '1:plan file:_files'
                    ;;
                destroy)
                    _arguments -s \
                        '-auto-approve[Skip interactive approval before destroying]' \
                        '-backup=[Path to backup the existing state file before modifying]:file:_files' \
                        '-compact-warnings[Show warnings in a more compact form]' \
                        '-input=[Ask for input for variables if not directly set]:bool:(true false)' \
                        '-json[Produce output in a machine-readable JSON format]' \
                        '-lock=[Don'\''t hold a state lock during the operation]:bool:(true false)' \
                        '-lock-timeout=[Duration to retry a state lock]:duration:' \
                        '-no-color[Disable color codes in command output]' \
                        '-parallelism=[Limit the number of concurrent operations]:number:' \
                        '-refresh-only[Select the refresh-only planning mode]' \
                        '*-replace=[Force replacement of a particular resource instance]:address:' \
                        '*-target=[Limit the operation to specific resources]:address:' \
                        '*-var=[Set a value for one of the input variables]:var:' \
                        '*-var-file=[Load variable values from the given file]:file:_files'
                    ;;
                output)
                    _arguments -s \
                        '-json[Produce output in a machine-readable JSON format]' \
                        '-raw[Print the raw string value directly]' \
                        '-no-color[Disable color codes in command output]' \
                        '-state=[Path to the state file to read]:file:_files' \
                        '1:output name:'
                    ;;
                show)
                    _arguments -s \
                        '-json[Produce output in a machine-readable JSON format]' \
                        '-no-color[Disable color codes in command output]' \
                        '1:path:_files'
                    ;;
                state)
                    local -a state_commands
                    state_commands=(
                        'list:List resources in the state'
                        'mv:Move an item in the state'
                        'pull:Pull current state and output to stdout'
                        'push:Update remote state from a local state file'
                        'replace-provider:Replace provider in the state'
                        'rm:Remove instances from the state'
                        'show:Show a resource in the state'
                    )
                    _arguments -C \
                        '1:state command:->statecmd' \
                        '*::arg:->stateargs'
                    case $state in
                        statecmd)
                            _describe -t state_commands 'state command' state_commands
                            ;;
                        stateargs)
                            case $line[1] in
                                list)
                                    _arguments -s \
                                        '-state=[Path to state file]:file:_files' \
                                        '-id=[Filter output by resource id]:id:' \
                                        '1:address filter:'
                                    ;;
                                mv)
                                    _arguments -s \
                                        '-dry-run[Only print out what would be moved]' \
                                        '-lock=[Don'\''t hold a state lock]:bool:(true false)' \
                                        '-lock-timeout=[Duration to retry a state lock]:duration:' \
                                        '1:source:' \
                                        '2:destination:'
                                    ;;
                                pull)
                                    _arguments -s
                                    ;;
                                push)
                                    _arguments -s \
                                        '-force[Write the state even if lineages do not match]' \
                                        '-lock=[Don'\''t hold a state lock]:bool:(true false)' \
                                        '-lock-timeout=[Duration to retry a state lock]:duration:' \
                                        '1:path:_files'
                                    ;;
                                replace-provider)
                                    _arguments -s \
                                        '-auto-approve[Skip interactive approval]' \
                                        '-lock=[Don'\''t hold a state lock]:bool:(true false)' \
                                        '-lock-timeout=[Duration to retry a state lock]:duration:' \
                                        '1:from provider:' \
                                        '2:to provider:'
                                    ;;
                                rm)
                                    _arguments -s \
                                        '-dry-run[Only print out what would be removed]' \
                                        '-lock=[Don'\''t hold a state lock]:bool:(true false)' \
                                        '-lock-timeout=[Duration to retry a state lock]:duration:' \
                                        '*:address:'
                                    ;;
                                show)
                                    _arguments -s \
                                        '-state=[Path to state file]:file:_files' \
                                        '1:address:'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                import)
                    _arguments -s \
                        '-config=[Path to a directory of Terraform configuration files]:dir:_directories' \
                        '-input=[Ask for input for variables if not directly set]:bool:(true false)' \
                        '-lock=[Don'\''t hold a state lock during the operation]:bool:(true false)' \
                        '-lock-timeout=[Duration to retry a state lock]:duration:' \
                        '-no-color[Disable color codes in command output]' \
                        '*-var=[Set a value for one of the input variables]:var:' \
                        '*-var-file=[Load variable values from the given file]:file:_files' \
                        '-allow-missing-config[Allow import when no resource configuration block exists]' \
                        '1:address:' \
                        '2:id:'
                    ;;
                refresh)
                    _arguments -s \
                        '-compact-warnings[Show warnings in a more compact form]' \
                        '-input=[Ask for input for variables if not directly set]:bool:(true false)' \
                        '-lock=[Don'\''t hold a state lock during the operation]:bool:(true false)' \
                        '-lock-timeout=[Duration to retry a state lock]:duration:' \
                        '-no-color[Disable color codes in command output]' \
                        '-parallelism=[Limit the number of concurrent operations]:number:' \
                        '*-target=[Limit the operation to specific resources]:address:' \
                        '*-var=[Set a value for one of the input variables]:var:' \
                        '*-var-file=[Load variable values from the given file]:file:_files'
                    ;;
                fmt)
                    _arguments -s \
                        '-list=[List files whose formatting differs]:bool:(true false)' \
                        '-write=[Write result to source file]:bool:(true false)' \
                        '-diff[Display diffs of formatting changes]' \
                        '-check[Check if the input is formatted]' \
                        '-recursive[Also process files in subdirectories]' \
                        '-no-color[Disable color codes in command output]' \
                        '*:file:_files'
                    ;;
                taint)
                    _arguments -s \
                        '-allow-missing[Succeed even if the resource is missing]' \
                        '-lock=[Don'\''t hold a state lock during the operation]:bool:(true false)' \
                        '-lock-timeout=[Duration to retry a state lock]:duration:' \
                        '-no-color[Disable color codes in command output]' \
                        '-ignore-remote-version[Do not check the remote Terraform version]' \
                        '1:address:'
                    ;;
                untaint)
                    _arguments -s \
                        '-allow-missing[Succeed even if the resource is missing]' \
                        '-lock=[Don'\''t hold a state lock during the operation]:bool:(true false)' \
                        '-lock-timeout=[Duration to retry a state lock]:duration:' \
                        '-no-color[Disable color codes in command output]' \
                        '-ignore-remote-version[Do not check the remote Terraform version]' \
                        '1:address:'
                    ;;
                workspace)
                    local -a ws_commands
                    ws_commands=(
                        'delete:Delete a workspace'
                        'list:List workspaces'
                        'new:Create a new workspace'
                        'select:Select a workspace'
                        'show:Show the name of the current workspace'
                    )
                    _arguments -C \
                        '1:workspace command:->wscmd' \
                        '*::arg:->wsargs'
                    case $state in
                        wscmd)
                            _describe -t ws_commands 'workspace command' ws_commands
                            ;;
                        wsargs)
                            case $line[1] in
                                new)
                                    _arguments -s \
                                        '-lock=[Don'\''t hold a state lock]:bool:(true false)' \
                                        '-lock-timeout=[Duration to retry a state lock]:duration:' \
                                        '-state=[Copy an existing state file into the new workspace]:file:_files' \
                                        '1:name:'
                                    ;;
                                delete)
                                    _arguments -s \
                                        '-force[Remove a non-empty workspace]' \
                                        '-lock=[Don'\''t hold a state lock]:bool:(true false)' \
                                        '-lock-timeout=[Duration to retry a state lock]:duration:' \
                                        '1:name:'
                                    ;;
                                select)
                                    _arguments -s \
                                        '1:name:'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                graph)
                    _arguments -s \
                        '-draw-cycles[Highlight any cycles in the graph]' \
                        '-module-depth=[Specifies the depth of modules to show]:depth:' \
                        '-plan=[Render graph using the specified plan file]:file:_files' \
                        '-type=[Type of graph to output]:type:(plan plan-refresh-only plan-destroy apply)'
                    ;;
                providers)
                    local -a prov_commands
                    prov_commands=(
                        'lock:Write out dependency locks for the configured providers'
                        'mirror:Save local copies of all required provider plugins'
                        'schema:Show the schemas for the providers used in the configuration'
                    )
                    _arguments -C \
                        '1:providers command:->provcmd' \
                        '*::arg:->provargs'
                    case $state in
                        provcmd)
                            _describe -t prov_commands 'providers command' prov_commands
                            ;;
                        provargs)
                            case $line[1] in
                                lock)
                                    _arguments -s \
                                        '-fs-mirror=[A directory to use as a filesystem mirror]:dir:_directories' \
                                        '*-net-mirror=[A network mirror URL]:url:' \
                                        '*-platform=[Target platform to request packages for]:platform:' \
                                        '1:configuration directory:_directories'
                                    ;;
                                mirror)
                                    _arguments -s \
                                        '*-platform=[Target platform to request packages for]:platform:' \
                                        '1:target directory:_directories'
                                    ;;
                                schema)
                                    _arguments -s \
                                        '-json[Produce output in a machine-readable JSON format]'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                force-unlock)
                    _arguments -s \
                        '-force[Don'\''t ask for input for unlock confirmation]' \
                        '1:lock id:'
                    ;;
                login)
                    _arguments -s \
                        '1:hostname:'
                    ;;
                logout)
                    _arguments -s \
                        '1:hostname:'
                    ;;
                test)
                    _arguments -s \
                        '-cloud-run=[Set the source for any tests with a run block referencing a module]:source:' \
                        '*-filter=[Only run test files matching the given filter]:filter:' \
                        '-json[Produce output in a machine-readable JSON format]' \
                        '-no-color[Disable color codes in command output]' \
                        '-test-directory=[Set the test directory]:dir:_directories' \
                        '*-var=[Set a value for one of the input variables]:var:' \
                        '*-var-file=[Load variable values from the given file]:file:_files' \
                        '-verbose[Print the plan or state for each test step]' \
                        '-compact-warnings[Show warnings in a more compact form]'
                    ;;
                console)
                    _arguments -s \
                        '-state=[Path to a state file]:file:_files' \
                        '*-var=[Set a value for one of the input variables]:var:' \
                        '*-var-file=[Load variable values from the given file]:file:_files' \
                        '-plan=[Use the given plan file]:file:_files'
                    ;;
                metadata)
                    local -a meta_commands
                    meta_commands=(
                        'functions:Show signatures and descriptions for the available functions'
                    )
                    _arguments -C \
                        '1:metadata command:->metacmd' \
                        '*::arg:->metaargs'
                    case $state in
                        metacmd)
                            _describe -t meta_commands 'metadata command' meta_commands
                            ;;
                        metaargs)
                            case $line[1] in
                                functions)
                                    _arguments -s \
                                        '-json[Produce output in a machine-readable JSON format]' \
                                        '1:function name:'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                version)
                    _arguments -s \
                        '-json[Produce output in a machine-readable JSON format]'
                    ;;
                get)
                    _arguments -s \
                        '-update[Check already-downloaded modules for available updates]' \
                        '-no-color[Disable color codes in command output]' \
                        '-test-directory=[Set the test directory]:dir:_directories' \
                        '1:path:_directories'
                    ;;
            esac
            ;;
    esac
}

_terraform "$@"
