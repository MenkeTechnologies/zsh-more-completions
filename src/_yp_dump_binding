#compdef yp_dump_binding
# Documentation: https://man.archlinux.org/search?q=yp_dump_binding
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-d[use domain instead of the default domain]'
  '-p[use path instead of the default binding directory]'
  '-v[only dump binding information of this ypbind protocol version]'
  '--usage[give a short usage message]'
  '--version[print program version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
