#compdef foomatic-compiledb
# Documentation: https://man.archlinux.org/search?q=foomatic-compiledb
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-f[force: proceed even if the destination directory exists]'
  '-t[output file type: ppd or xml]'
  '-j[n==number of work processes to run at the same time]'
  '-d[put PPD files in this directory]'
  '*:filename:_files'
)

_arguments -s -S $arguments
