#compdef docker

_docker() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a global_opts
    global_opts=(
        '--config[Location of client config files]:path:_directories'
        {-c,--context}'[Name of the context to use to connect to the daemon]:context:'
        {-D,--debug}'[Enable debug mode]'
        {-H,--host}'[Daemon socket to connect to]:host:'
        {-l,--log-level}'[Set the logging level]:level:(debug info warn error fatal)'
        '--tls[Use TLS; implied by --tlsverify]'
        '--tlscacert[Trust certs signed only by this CA]:ca path:_files'
        '--tlscert[Path to TLS certificate file]:cert path:_files'
        '--tlskey[Path to TLS key file]:key path:_files'
        '--tlsverify[Use TLS and verify the remote]'
        {-v,--version}'[Print version information and quit]'
    )

    _arguments -C \
        $global_opts \
        '(-): :->command' \
        '(-)*:: :->option-or-argument' && ret=0

    case $state in
        (command)
            local -a management_commands shortcut_commands
            management_commands=(
                'builder:Manage builds'
                'buildx:Docker Buildx'
                'checkpoint:Manage checkpoints'
                'compose:Docker Compose'
                'config:Manage Swarm configs'
                'container:Manage containers'
                'context:Manage contexts'
                'image:Manage images'
                'manifest:Manage Docker image manifests and manifest lists'
                'network:Manage networks'
                'node:Manage Swarm nodes'
                'plugin:Manage plugins'
                'secret:Manage Swarm secrets'
                'service:Manage Swarm services'
                'stack:Manage Swarm stacks'
                'swarm:Manage Swarm'
                'system:Manage Docker'
                'trust:Manage trust on Docker images'
                'volume:Manage volumes'
            )
            shortcut_commands=(
                'attach:Attach local standard input, output, and error streams to a running container'
                'build:Build an image from a Dockerfile'
                'commit:Create a new image from a container changes'
                'cp:Copy files/folders between a container and the local filesystem'
                'create:Create a new container'
                'diff:Inspect changes to files or directories on a container filesystem'
                'events:Get real time events from the server'
                'exec:Execute a command in a running container'
                'export:Export a container filesystem as a tar archive'
                'history:Show the history of an image'
                'images:List images'
                'import:Import the contents from a tarball to create a filesystem image'
                'info:Display system-wide information'
                'inspect:Return low-level information on Docker objects'
                'kill:Kill one or more running containers'
                'load:Load an image from a tar archive or STDIN'
                'login:Log in to a registry'
                'logout:Log out from a registry'
                'logs:Fetch the logs of a container'
                'pause:Pause all processes within one or more containers'
                'port:List port mappings or a specific mapping for the container'
                'ps:List containers'
                'pull:Download an image from a registry'
                'push:Upload an image to a registry'
                'rename:Rename a container'
                'restart:Restart one or more containers'
                'rm:Remove one or more containers'
                'rmi:Remove one or more images'
                'run:Create and run a new container'
                'save:Save one or more images to a tar archive'
                'search:Search Docker Hub for images'
                'start:Start one or more stopped containers'
                'stats:Display a live stream of container resource usage statistics'
                'stop:Stop one or more running containers'
                'tag:Create a tag TARGET_IMAGE that refers to SOURCE_IMAGE'
                'top:Display the running processes of a container'
                'unpause:Unpause all processes within one or more containers'
                'update:Update configuration of one or more containers'
                'version:Show the Docker version information'
                'wait:Block until one or more containers stop, then print their exit codes'
            )
            _describe -t management-commands 'management command' management_commands && ret=0
            _describe -t shortcut-commands 'command' shortcut_commands && ret=0
            ;;
        (option-or-argument)
            curcontext=${curcontext%:*:*}:docker-$words[1]:
            case $words[1] in
                (run)
                    _arguments -s \
                        '*--add-host[Add a custom host-to-IP mapping (host\:ip)]:host\:ip:' \
                        '*--annotation[Add an annotation to the container]:annotation:' \
                        '*'{-a,--attach}'[Attach to STDIN, STDOUT or STDERR]:stream:(STDIN STDOUT STDERR)' \
                        '--blkio-weight[Block IO relative weight (10-1000)]:weight:' \
                        '*--blkio-weight-device[Block IO weight (relative device weight)]:device weight:' \
                        '*--cap-add[Add Linux capabilities]:capability:' \
                        '*--cap-drop[Drop Linux capabilities]:capability:' \
                        '--cgroup-parent[Optional parent cgroup for the container]:cgroup:' \
                        '--cgroupns[Cgroup namespace to use]:cgroup namespace:(host private)' \
                        '--cidfile[Write the container ID to the file]:file:_files' \
                        {-c,--cpu-shares}'[CPU shares (relative weight)]:shares:' \
                        '--cpu-count[CPU count (Windows only)]:count:' \
                        '--cpu-percent[CPU percent (Windows only)]:percent:' \
                        '--cpu-period[Limit CPU CFS period]:period:' \
                        '--cpu-quota[Limit CPU CFS quota]:quota:' \
                        '--cpu-rt-period[Limit CPU real-time period in microseconds]:period:' \
                        '--cpu-rt-runtime[Limit CPU real-time runtime in microseconds]:runtime:' \
                        '--cpus[Number of CPUs]:cpus:' \
                        '--cpuset-cpus[CPUs in which to allow execution (0-3, 0,1)]:cpus:' \
                        '--cpuset-mems[MEMs in which to allow execution (0-3, 0,1)]:mems:' \
                        {-d,--detach}'[Run container in background and print container ID]' \
                        '--detach-keys[Override the key sequence for detaching a container]:keys:' \
                        '*--device[Add a host device to the container]:device:_files' \
                        '*--device-cgroup-rule[Add a rule to the cgroup allowed devices list]:rule:' \
                        '*--device-read-bps[Limit read rate (bytes per second) from a device]:rate:' \
                        '*--device-read-iops[Limit read rate (IO per second) from a device]:rate:' \
                        '*--device-write-bps[Limit write rate (bytes per second) to a device]:rate:' \
                        '*--device-write-iops[Limit write rate (IO per second) to a device]:rate:' \
                        '*--dns[Set custom DNS servers]:dns:' \
                        '*--dns-option[Set DNS options]:option:' \
                        '*--dns-search[Set custom DNS search domains]:domain:' \
                        '--domainname[Container NIS domain name]:domain:' \
                        '--entrypoint[Overwrite the default ENTRYPOINT of the image]:entrypoint:' \
                        '*'{-e,--env}'[Set environment variables]:env:' \
                        '*--env-file[Read in a file of environment variables]:env file:_files' \
                        '*--expose[Expose a port or a range of ports]:port:' \
                        '--gpus[GPU devices to add to the container]:gpus:' \
                        '*--group-add[Add additional groups to join]:group:' \
                        '--health-cmd[Command to run to check health]:command:' \
                        '--health-interval[Time between running the check]:interval:' \
                        '--health-retries[Consecutive failures needed to report unhealthy]:retries:' \
                        '--health-start-interval[Time between running the check during the start period]:interval:' \
                        '--health-start-period[Start period for the container to initialize]:period:' \
                        '--health-timeout[Maximum time to allow one check to run]:timeout:' \
                        {-h,--hostname}'[Container host name]:hostname:' \
                        '--init[Run an init inside the container that forwards signals and reaps processes]' \
                        {-i,--interactive}'[Keep STDIN open even if not attached]' \
                        '--ip[IPv4 address]:ip:' \
                        '--ip6[IPv6 address]:ip:' \
                        '--ipc[IPC mode to use]:ipc mode:' \
                        '--isolation[Container isolation technology]:isolation:' \
                        '*'{-l,--label}'[Set meta data on a container]:label:' \
                        '*--label-file[Read in a line delimited file of labels]:file:_files' \
                        '*--link[Add link to another container]:container\:alias:' \
                        '*--link-local-ip[Container IPv4/IPv6 link-local addresses]:ip:' \
                        '--log-driver[Logging driver for the container]:log driver:' \
                        '*--log-opt[Log driver options]:log option:' \
                        '--mac-address[Container MAC address]:mac:' \
                        {-m,--memory}'[Memory limit]:memory:' \
                        '--memory-reservation[Memory soft limit]:memory:' \
                        '--memory-swap[Swap limit equal to memory plus swap (-1 for unlimited)]:swap:' \
                        '--memory-swappiness[Tune container memory swappiness (0 to 100)]:swappiness:' \
                        '*--mount[Attach a filesystem mount to the container]:mount:' \
                        '--name[Assign a name to the container]:name:' \
                        '--network[Connect a container to a network]:network:' \
                        '*--network-alias[Add network-scoped alias for the container]:alias:' \
                        '--no-healthcheck[Disable any container-specified HEALTHCHECK]' \
                        '--oom-kill-disable[Disable OOM Killer]' \
                        '--oom-score-adj[Tune host OOM preferences (-1000 to 1000)]:score:' \
                        '--pid[PID namespace to use]:pid namespace:' \
                        '--pids-limit[Tune container pids limit (-1 for unlimited)]:limit:' \
                        '--platform[Set platform if server is multi-platform capable]:platform:' \
                        '--privileged[Give extended privileges to this container]' \
                        '*'{-p,--publish}'[Publish a container port to the host]:port mapping:' \
                        {-P,--publish-all}'[Publish all exposed ports to random ports]' \
                        '--pull[Pull image before running]:when:(always missing never)' \
                        {-q,--quiet}'[Suppress the pull output]' \
                        '--read-only[Mount the container root filesystem as read only]' \
                        '--restart[Restart policy to apply when a container exits]:policy:(no on-failure always unless-stopped)' \
                        '--rm[Automatically remove the container when it exits]' \
                        '--runtime[Runtime to use for this container]:runtime:' \
                        '*--security-opt[Security options]:security option:' \
                        '--shm-size[Size of /dev/shm]:shm size:' \
                        '--sig-proxy[Proxy received signals to the process]' \
                        '--stop-signal[Signal to stop the container]:signal:' \
                        '--stop-timeout[Timeout (in seconds) to stop a container]:timeout:' \
                        '*--storage-opt[Storage driver options for the container]:storage option:' \
                        '*--sysctl[Sysctl options]:sysctl:' \
                        '*--tmpfs[Mount a tmpfs directory]:tmpfs:' \
                        {-t,--tty}'[Allocate a pseudo-TTY]' \
                        '*--ulimit[Ulimit options]:ulimit:' \
                        '--use-api-socket[Bind mount Docker API socket and required auth]' \
                        {-u,--user}'[Username or UID]:user:' \
                        '--userns[User namespace to use]:userns:' \
                        '--uts[UTS namespace to use]:uts namespace:' \
                        '*'{-v,--volume}'[Bind mount a volume]:volume:' \
                        '--volume-driver[Optional volume driver for the container]:driver:' \
                        '*--volumes-from[Mount volumes from the specified container(s)]:container:_docker_containers' \
                        {-w,--workdir}'[Working directory inside the container]:workdir:' \
                        '(-):image:_docker_images' \
                        '(-)*:command:_normal' && ret=0
                    ;;
                (exec)
                    _arguments -s \
                        {-d,--detach}'[Detached mode: run command in the background]' \
                        '--detach-keys[Override the key sequence for detaching a container]:keys:' \
                        '*'{-e,--env}'[Set environment variables]:env:' \
                        '*--env-file[Read in a file of environment variables]:env file:_files' \
                        {-i,--interactive}'[Keep STDIN open even if not attached]' \
                        '--privileged[Give extended privileges to the command]' \
                        {-t,--tty}'[Allocate a pseudo-TTY]' \
                        {-u,--user}'[Username or UID]:user:' \
                        {-w,--workdir}'[Working directory inside the container]:workdir:' \
                        '(-):container:_docker_containers_running' \
                        '(-)*:command:_normal' && ret=0
                    ;;
                (build)
                    _arguments -s \
                        '*--add-host[Add a custom host-to-IP mapping]:host\:ip:' \
                        '*--allow[Allow extra privileged entitlement]:entitlement:' \
                        '*--annotation[Add annotation to the image]:annotation:' \
                        '*--attest[Attestation parameters]:attest:' \
                        '*--build-arg[Set build-time variables]:variable=value:' \
                        '*--build-context[Additional build contexts]:name=path:' \
                        '--builder[Override the configured builder instance]:builder:' \
                        '*--cache-from[External cache sources]:cache source:' \
                        '*--cache-to[Cache export destinations]:cache destination:' \
                        '--call[Set method for evaluating build]:method:(build check outline targets)' \
                        '--cgroup-parent[Set the parent cgroup for RUN instructions]:cgroup:' \
                        '--check[Shorthand for --call=check]' \
                        {-D,--debug}'[Enable debug logging]' \
                        {-f,--file}'[Name of the Dockerfile]:Dockerfile:_files' \
                        '--iidfile[Write the image ID to a file]:file:_files' \
                        '*--label[Set metadata for an image]:label:' \
                        '--load[Shorthand for --output=type=docker]' \
                        '--metadata-file[Write build result metadata to a file]:file:_files' \
                        '--network[Set the networking mode for the RUN instructions]:network:' \
                        '--no-cache[Do not use cache when building the image]' \
                        '*--no-cache-filter[Do not cache specified stages]:stage:' \
                        '*'{-o,--output}'[Output destination]:output:' \
                        '--platform[Set target platform for build]:platform:' \
                        '--progress[Set type of progress output]:progress:(auto none plain quiet rawjson tty)' \
                        '--provenance[Shorthand for --attest=type=provenance]:provenance:' \
                        '--pull[Always attempt to pull all referenced images]' \
                        '--push[Shorthand for --output=type=registry]' \
                        {-q,--quiet}'[Suppress the build output and print image ID on success]' \
                        '--sbom[Shorthand for --attest=type=sbom]:sbom:' \
                        '*--secret[Secret to expose to the build]:secret:' \
                        '--shm-size[Shared memory size for build containers]:size:' \
                        '*--ssh[SSH agent socket or keys to expose to the build]:ssh:' \
                        '*'{-t,--tag}'[Name and optionally a tag in name\:tag format]:name\:tag:' \
                        '--target[Set the target build stage to build]:target:' \
                        '*--ulimit[Ulimit options]:ulimit:' \
                        '(-):path or URL:_directories' && ret=0
                    ;;
                (pull)
                    _arguments -s \
                        {-a,--all-tags}'[Download all tagged images in the repository]' \
                        '--platform[Set platform if server is multi-platform capable]:platform:' \
                        {-q,--quiet}'[Suppress verbose output]' \
                        '(-):image:' && ret=0
                    ;;
                (push)
                    _arguments -s \
                        {-a,--all-tags}'[Push all tags of an image to the repository]' \
                        '--platform[Push a platform-specific manifest as a single-platform image]:platform:' \
                        {-q,--quiet}'[Suppress verbose output]' \
                        '(-):image:_docker_images' && ret=0
                    ;;
                (ps)
                    _arguments -s \
                        {-a,--all}'[Show all containers (default shows just running)]' \
                        '*'{-f,--filter}'[Filter output based on conditions provided]:filter:' \
                        '--format[Format output using a custom template]:format:' \
                        {-n,--last}'[Show n last created containers]:number:' \
                        {-l,--latest}'[Show the latest created container]' \
                        '--no-trunc[Do not truncate output]' \
                        {-q,--quiet}'[Only display container IDs]' \
                        {-s,--size}'[Display total file sizes]' && ret=0
                    ;;
                (images)
                    _arguments -s \
                        {-a,--all}'[Show all images (default hides intermediate images)]' \
                        '--digests[Show digests]' \
                        '*'{-f,--filter}'[Filter output based on conditions provided]:filter:' \
                        '--format[Format output using a custom template]:format:' \
                        '--no-trunc[Do not truncate output]' \
                        {-q,--quiet}'[Only show image IDs]' \
                        '--tree[List multi-platform images as a tree (EXPERIMENTAL)]' \
                        '(-):repository:' && ret=0
                    ;;
                (logs)
                    _arguments -s \
                        '--details[Show extra details provided to logs]' \
                        {-f,--follow}'[Follow log output]' \
                        '--since[Show logs since timestamp or relative]:timestamp:' \
                        '--until[Show logs before a timestamp or relative]:timestamp:' \
                        {-n,--tail}'[Number of lines to show from the end of the logs]:lines:' \
                        {-t,--timestamps}'[Show timestamps]' \
                        '(-):container:_docker_containers' && ret=0
                    ;;
                (stop)
                    _arguments -s \
                        {-s,--signal}'[Signal to send to the container]:signal:' \
                        {-t,--timeout}'[Seconds to wait before killing the container]:seconds:' \
                        '(-)*:container:_docker_containers_running' && ret=0
                    ;;
                (rm)
                    _arguments -s \
                        {-f,--force}'[Force the removal of a running container]' \
                        {-l,--link}'[Remove the specified link]' \
                        {-v,--volumes}'[Remove anonymous volumes associated with the container]' \
                        '(-)*:container:_docker_containers' && ret=0
                    ;;
                (rmi)
                    _arguments -s \
                        {-f,--force}'[Force removal of the image]' \
                        '--no-prune[Do not delete untagged parents]' \
                        '(-)*:image:_docker_images' && ret=0
                    ;;
                (container)
                    local -a container_cmds
                    container_cmds=(
                        'attach:Attach local standard input, output, and error streams to a running container'
                        'commit:Create a new image from a container changes'
                        'cp:Copy files/folders between a container and the local filesystem'
                        'create:Create a new container'
                        'diff:Inspect changes to files or directories on a container filesystem'
                        'exec:Execute a command in a running container'
                        'export:Export a container filesystem as a tar archive'
                        'inspect:Display detailed information on one or more containers'
                        'kill:Kill one or more running containers'
                        'logs:Fetch the logs of a container'
                        'ls:List containers'
                        'pause:Pause all processes within one or more containers'
                        'port:List port mappings or a specific mapping for the container'
                        'prune:Remove all stopped containers'
                        'rename:Rename a container'
                        'restart:Restart one or more containers'
                        'rm:Remove one or more containers'
                        'run:Create and run a new container'
                        'start:Start one or more stopped containers'
                        'stats:Display a live stream of container resource usage statistics'
                        'stop:Stop one or more running containers'
                        'top:Display the running processes of a container'
                        'unpause:Unpause all processes within one or more containers'
                        'update:Update configuration of one or more containers'
                        'wait:Block until one or more containers stop, then print their exit codes'
                    )
                    _describe -t commands 'container command' container_cmds && ret=0
                    ;;
                (image)
                    local -a image_cmds
                    image_cmds=(
                        'build:Build an image from a Dockerfile'
                        'history:Show the history of an image'
                        'import:Import the contents from a tarball to create a filesystem image'
                        'inspect:Display detailed information on one or more images'
                        'load:Load an image from a tar archive or STDIN'
                        'ls:List images'
                        'prune:Remove unused images'
                        'pull:Download an image from a registry'
                        'push:Upload an image to a registry'
                        'rm:Remove one or more images'
                        'save:Save one or more images to a tar archive'
                        'tag:Create a tag TARGET_IMAGE that refers to SOURCE_IMAGE'
                    )
                    _describe -t commands 'image command' image_cmds && ret=0
                    ;;
                (network)
                    local -a network_cmds
                    network_cmds=(
                        'connect:Connect a container to a network'
                        'create:Create a network'
                        'disconnect:Disconnect a container from a network'
                        'inspect:Display detailed information on one or more networks'
                        'ls:List networks'
                        'prune:Remove all unused networks'
                        'rm:Remove one or more networks'
                    )
                    _describe -t commands 'network command' network_cmds && ret=0
                    ;;
                (volume)
                    local -a volume_cmds
                    volume_cmds=(
                        'create:Create a volume'
                        'inspect:Display detailed information on one or more volumes'
                        'ls:List volumes'
                        'prune:Remove unused local volumes'
                        'rm:Remove one or more volumes'
                        'update:Update a volume (cluster volumes only)'
                    )
                    _describe -t commands 'volume command' volume_cmds && ret=0
                    ;;
                (system)
                    local -a system_cmds
                    system_cmds=(
                        'df:Show docker disk usage'
                        'events:Get real time events from the server'
                        'info:Display system-wide information'
                        'prune:Remove unused data'
                    )
                    _describe -t commands 'system command' system_cmds && ret=0
                    ;;
                (compose)
                    local -a compose_cmds
                    compose_cmds=(
                        'attach:Attach local standard input, output, and error streams to a service container'
                        'build:Build or rebuild services'
                        'config:Parse, resolve and render compose file in canonical format'
                        'cp:Copy files/folders between a service container and the local filesystem'
                        'create:Creates containers for a service'
                        'down:Stop and remove containers, networks'
                        'events:Receive real time events from containers'
                        'exec:Execute a command in a running container'
                        'images:List images used by the created containers'
                        'kill:Force stop service containers'
                        'logs:View output from containers'
                        'ls:List running compose projects'
                        'pause:Pause services'
                        'port:Print the public port for a port binding'
                        'ps:List containers'
                        'pull:Pull service images'
                        'push:Push service images'
                        'restart:Restart service containers'
                        'rm:Removes stopped service containers'
                        'run:Run a one-off command on a service'
                        'scale:Scale services'
                        'start:Start services'
                        'stats:Display a live stream of container resource usage statistics'
                        'stop:Stop services'
                        'top:Display the running processes'
                        'unpause:Unpause services'
                        'up:Create and start containers'
                        'version:Show the Docker Compose version information'
                        'wait:Block until the first service container stops'
                        'watch:Watch build context for service and rebuild/refresh containers when files are updated'
                    )
                    _describe -t commands 'compose command' compose_cmds && ret=0
                    ;;
                (buildx)
                    local -a buildx_cmds
                    buildx_cmds=(
                        'bake:Build from a file'
                        'build:Start a build'
                        'create:Create a new builder instance'
                        'debug:Start debugger'
                        'du:Disk usage'
                        'imagetools:Commands to work on images in registry'
                        'inspect:Inspect current builder instance'
                        'ls:List builder instances'
                        'prune:Remove build cache'
                        'rm:Remove one or more builder instances'
                        'stop:Stop builder instance'
                        'use:Set the current builder instance'
                        'version:Show buildx version information'
                    )
                    _describe -t commands 'buildx command' buildx_cmds && ret=0
                    ;;
                (context)
                    local -a context_cmds
                    context_cmds=(
                        'create:Create a context'
                        'export:Export a context to a tar archive or kubeconfig file'
                        'import:Import a context from a tar or zip file'
                        'inspect:Display detailed information on one or more contexts'
                        'ls:List contexts'
                        'rm:Remove one or more contexts'
                        'show:Print the name of the current context'
                        'update:Update a context'
                        'use:Set the current docker context'
                    )
                    _describe -t commands 'context command' context_cmds && ret=0
                    ;;
                (manifest)
                    local -a manifest_cmds
                    manifest_cmds=(
                        'annotate:Add additional information to a local image manifest'
                        'create:Create a local manifest list for annotating and pushing to a repository'
                        'inspect:Display an image manifest, or manifest list'
                        'push:Push a manifest list to a registry'
                        'rm:Delete one or more manifest lists from local storage'
                    )
                    _describe -t commands 'manifest command' manifest_cmds && ret=0
                    ;;
                (builder|checkpoint|config|node|plugin|secret|service|stack|swarm|trust)
                    _message "docker $words[1] subcommand"
                    ;;
                (attach)
                    _arguments -s \
                        '--detach-keys[Override the key sequence for detaching a container]:keys:' \
                        '--no-stdin[Do not attach STDIN]' \
                        '--sig-proxy[Proxy received signals to the process]' \
                        '(-):container:_docker_containers_running' && ret=0
                    ;;
                (start)
                    _arguments -s \
                        {-a,--attach}'[Attach STDOUT/STDERR and forward signals]' \
                        '--detach-keys[Override the key sequence for detaching a container]:keys:' \
                        {-i,--interactive}'[Attach container STDIN]' \
                        '(-)*:container:_docker_containers_stopped' && ret=0
                    ;;
                (restart)
                    _arguments -s \
                        {-s,--signal}'[Signal to send to the container]:signal:' \
                        {-t,--timeout}'[Seconds to wait before killing the container]:seconds:' \
                        '(-)*:container:_docker_containers' && ret=0
                    ;;
                (pause|unpause)
                    _arguments '(-)*:container:_docker_containers_running' && ret=0
                    ;;
                (wait)
                    _arguments '(-)*:container:_docker_containers' && ret=0
                    ;;
                (port)
                    _arguments \
                        '(-):container:_docker_containers_running' \
                        '(-):port:' && ret=0
                    ;;
                (top)
                    _arguments \
                        '(-):container:_docker_containers_running' \
                        '(-)*:ps options:' && ret=0
                    ;;
                (rename)
                    _arguments \
                        '(-):container:_docker_containers' \
                        '(-):new name:' && ret=0
                    ;;
                (update)
                    _arguments -s \
                        '--blkio-weight[Block IO relative weight (10-1000)]:weight:' \
                        '--cpu-period[Limit CPU CFS period]:period:' \
                        '--cpu-quota[Limit CPU CFS quota]:quota:' \
                        '--cpu-rt-period[Limit CPU real-time period]:period:' \
                        '--cpu-rt-runtime[Limit CPU real-time runtime]:runtime:' \
                        {-c,--cpu-shares}'[CPU shares (relative weight)]:shares:' \
                        '--cpus[Number of CPUs]:cpus:' \
                        '--cpuset-cpus[CPUs in which to allow execution]:cpus:' \
                        '--cpuset-mems[MEMs in which to allow execution]:mems:' \
                        {-m,--memory}'[Memory limit]:memory:' \
                        '--memory-reservation[Memory soft limit]:memory:' \
                        '--memory-swap[Swap limit (-1 for unlimited)]:swap:' \
                        '--pids-limit[Tune container pids limit]:limit:' \
                        '--restart[Restart policy]:policy:(no on-failure always unless-stopped)' \
                        '(-)*:container:_docker_containers' && ret=0
                    ;;
                (stats)
                    _arguments -s \
                        {-a,--all}'[Show all containers (default shows just running)]' \
                        '--format[Format output using a custom template]:format:' \
                        '--no-stream[Disable streaming stats and only pull the first result]' \
                        '--no-trunc[Do not truncate output]' \
                        '(-)*:container:_docker_containers_running' && ret=0
                    ;;
                (kill)
                    _arguments -s \
                        {-s,--signal}'[Signal to send to the container]:signal:' \
                        '(-)*:container:_docker_containers_running' && ret=0
                    ;;
                (inspect)
                    _arguments -s \
                        {-f,--format}'[Format output using a custom template]:format:' \
                        {-s,--size}'[Display total file sizes if the type is container]' \
                        '--type[Return JSON for specified type]:type:(container image network node plugin secret service volume task)' \
                        '(-)*:object:' && ret=0
                    ;;
                (tag)
                    _arguments \
                        '(-):source image:_docker_images' \
                        '(-):target image:' && ret=0
                    ;;
                (commit)
                    _arguments -s \
                        {-a,--author}'[Author]:author:' \
                        '*'{-c,--change}'[Apply Dockerfile instruction to the created image]:instruction:' \
                        {-m,--message}'[Commit message]:message:' \
                        {-p,--pause}'[Pause container during commit]' \
                        '(-):container:_docker_containers' \
                        '(-):repository\:tag:' && ret=0
                    ;;
                (cp)
                    _arguments \
                        {-a,--archive}'[Archive mode (copy all uid/gid information)]' \
                        {-L,--follow-link}'[Always follow symbol link in SRC_PATH]' \
                        {-q,--quiet}'[Suppress progress output]' \
                        '(-):source:' \
                        '(-):destination:' && ret=0
                    ;;
                (create)
                    _arguments -s \
                        '*--add-host[Add a custom host-to-IP mapping]:host\:ip:' \
                        '*'{-a,--attach}'[Attach to STDIN, STDOUT or STDERR]:stream:(STDIN STDOUT STDERR)' \
                        '*--cap-add[Add Linux capabilities]:capability:' \
                        '*--cap-drop[Drop Linux capabilities]:capability:' \
                        '--cgroupns[Cgroup namespace to use]:cgroup namespace:(host private)' \
                        '--cidfile[Write the container ID to the file]:file:_files' \
                        '--cpus[Number of CPUs]:cpus:' \
                        {-d,--detach}'[Run container in background]' \
                        '*--device[Add a host device to the container]:device:_files' \
                        '*--dns[Set custom DNS servers]:dns:' \
                        '--entrypoint[Overwrite the default ENTRYPOINT]:entrypoint:' \
                        '*'{-e,--env}'[Set environment variables]:env:' \
                        '*--env-file[Read in a file of environment variables]:env file:_files' \
                        '*--expose[Expose a port or a range of ports]:port:' \
                        '--gpus[GPU devices to add]:gpus:' \
                        {-h,--hostname}'[Container host name]:hostname:' \
                        '--init[Run an init inside the container]' \
                        {-i,--interactive}'[Keep STDIN open]' \
                        '*'{-l,--label}'[Set meta data on a container]:label:' \
                        {-m,--memory}'[Memory limit]:memory:' \
                        '*--mount[Attach a filesystem mount]:mount:' \
                        '--name[Assign a name to the container]:name:' \
                        '--network[Connect a container to a network]:network:' \
                        '--platform[Set platform]:platform:' \
                        '--privileged[Give extended privileges]' \
                        '*'{-p,--publish}'[Publish a container port]:port mapping:' \
                        '--pull[Pull image before creating]:when:(always missing never)' \
                        '--read-only[Mount root filesystem as read only]' \
                        '--restart[Restart policy]:policy:(no on-failure always unless-stopped)' \
                        '--rm[Automatically remove the container when it exits]' \
                        '*--security-opt[Security options]:security option:' \
                        '--shm-size[Size of /dev/shm]:shm size:' \
                        '--stop-signal[Signal to stop the container]:signal:' \
                        {-t,--tty}'[Allocate a pseudo-TTY]' \
                        {-u,--user}'[Username or UID]:user:' \
                        '*'{-v,--volume}'[Bind mount a volume]:volume:' \
                        {-w,--workdir}'[Working directory inside the container]:workdir:' \
                        '(-):image:_docker_images' \
                        '(-)*:command:_normal' && ret=0
                    ;;
                (diff|export)
                    _arguments '(-):container:_docker_containers' && ret=0
                    ;;
                (events)
                    _arguments -s \
                        '*'{-f,--filter}'[Filter output based on conditions provided]:filter:' \
                        '--format[Format output using a custom template]:format:' \
                        '--since[Show all events created since timestamp]:timestamp:' \
                        '--until[Stream events until this timestamp]:timestamp:' && ret=0
                    ;;
                (history)
                    _arguments -s \
                        '--format[Format output using a custom template]:format:' \
                        {-H,--human}'[Print sizes and dates in human readable format]' \
                        '--no-trunc[Do not truncate output]' \
                        '--platform[Set platform]:platform:' \
                        {-q,--quiet}'[Only show image IDs]' \
                        '(-):image:_docker_images' && ret=0
                    ;;
                (import)
                    _arguments -s \
                        '*'{-c,--change}'[Apply Dockerfile instruction to the created image]:instruction:' \
                        {-m,--message}'[Set commit message for imported image]:message:' \
                        '--platform[Set platform if server is multi-platform capable]:platform:' \
                        '(-):file or URL:_files' \
                        '(-):repository\:tag:' && ret=0
                    ;;
                (info)
                    _arguments -s \
                        {-f,--format}'[Format output using a custom template]:format:' && ret=0
                    ;;
                (version)
                    _arguments -s \
                        {-f,--format}'[Format output using a custom template]:format:' && ret=0
                    ;;
                (load)
                    _arguments -s \
                        {-i,--input}'[Read from tar archive file]:file:_files' \
                        {-q,--quiet}'[Suppress the load output]' && ret=0
                    ;;
                (login)
                    _arguments -s \
                        {-p,--password}'[Password]:password:' \
                        '--password-stdin[Take the password from stdin]' \
                        {-u,--username}'[Username]:username:' \
                        '(-):server:' && ret=0
                    ;;
                (logout)
                    _arguments '(-):server:' && ret=0
                    ;;
                (save)
                    _arguments -s \
                        {-o,--output}'[Write to a file]:file:_files' \
                        '(-)*:image:_docker_images' && ret=0
                    ;;
                (search)
                    _arguments -s \
                        '*'{-f,--filter}'[Filter output based on conditions provided]:filter:' \
                        '--format[Format output using a custom template]:format:' \
                        '--limit[Max number of search results]:limit:' \
                        '--no-trunc[Do not truncate output]' \
                        '(-):term:' && ret=0
                    ;;
                *)
                    _message "unknown docker command: $words[1]"
                    ;;
            esac
            ;;
    esac

    return ret
}

# Helper: complete running docker container names
_docker_containers_running() {
    local -a containers
    containers=(${(f)"$(docker ps --format '{{.Names}}\t{{.Image}} ({{.Status}})' 2>/dev/null)"})
    if (( ${#containers} )); then
        _describe -t containers 'running container' containers
    fi
}

# Helper: complete stopped docker container names
_docker_containers_stopped() {
    local -a containers
    containers=(${(f)"$(docker ps -a --filter 'status=exited' --filter 'status=created' --format '{{.Names}}\t{{.Image}} ({{.Status}})' 2>/dev/null)"})
    if (( ${#containers} )); then
        _describe -t containers 'stopped container' containers
    fi
}

# Helper: complete all docker container names (running + stopped)
_docker_containers() {
    local -a containers
    containers=(${(f)"$(docker ps -a --format '{{.Names}}\t{{.Image}} ({{.Status}})' 2>/dev/null)"})
    if (( ${#containers} )); then
        _describe -t containers 'container' containers
    fi
}

# Helper: complete docker image names
_docker_images() {
    local -a images
    images=(${(f)"$(docker images --format '{{.Repository}}:{{.Tag}}\t{{.Size}}' 2>/dev/null | grep -v '<none>')"})
    if (( ${#images} )); then
        _describe -t images 'image' images
    fi
}

# Helper: complete docker network names
_docker_networks() {
    local -a networks
    networks=(${(f)"$(docker network ls --format '{{.Name}}\t{{.Driver}}' 2>/dev/null)"})
    if (( ${#networks} )); then
        _describe -t networks 'network' networks
    fi
}

# Helper: complete docker volume names
_docker_volumes() {
    local -a volumes
    volumes=(${(f)"$(docker volume ls --format '{{.Name}}\t{{.Driver}}' 2>/dev/null)"})
    if (( ${#volumes} )); then
        _describe -t volumes 'volume' volumes
    fi
}

_docker "$@"
