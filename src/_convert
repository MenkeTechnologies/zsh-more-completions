  '-depth[image depth]:value:'
  '-direction[render text right-to-left or left-to-right]:type:(right-to-left left-to-right undefined)'
  '-display[get image or font from this X server]:server:'
  '-dispose[layer disposal method]:method:(Undefined None Background Previous)'
  '-dither[apply error diffusion to image]:method:(None FloydSteinberg Riemersma)'
