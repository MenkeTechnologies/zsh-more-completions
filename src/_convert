  '-font[render text with this font]:name:_files'
  '-format[output formatted image characteristics]:string:'
  '-fuzz[colors within this distance are considered equal]:distance:'
  '-gravity[horizontal and vertical text placement]:type:(None Center East North NorthEast NorthWest South SouthEast SouthWest West)'
  '-green-primary[chromaticity green primary point]:point:'
  '-illuminant[reference illuminant]:type:(A B C D50 D55 D65 D75 E F2 F7 F11)'
  '-intensity[method to generate an intensity value from a pixel]:method:(Average Brightness Lightness Mean MS Rec601Luma Rec601Luminance Rec709Luma Rec709Luminance RMS)'
