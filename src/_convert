# Image Channel Operators
channel_ops=(
  '-channel-fx[exchange, extract, or transfer one or more image channels]:expression:'
  '-separate[separate an image channel into a grayscale image]'
)

# Image Sequence Operators
sequence_ops=(
  '-append[append an image sequence]'
  '-clut[apply a color lookup table to the image]'
  '-coalesce[merge a sequence of images]'
  '-combine[combine a sequence of images]'
  '-compare[mathematically and visually annotate the difference between images]'
  '-complex[perform complex mathematics on an image sequence]:operator:(Add Conjugate Divide MagnitudePhase Multiply RealImaginary Subtract)'
  '-composite[composite image]'
  '-copy[copy pixels from one area of an image to another]:geometry: :offset:'
  '-deconstruct[break down an image sequence into constituent parts]'
  '-evaluate-sequence[evaluate an arithmetic, relational, or logical expression]:operator:(Add And Max Mean Median Min Multiply Or RootMeanSquare Subtract)'
  '-flatten[flatten a sequence of images]'
  '-fx[apply mathematical expression to an image channel(s)]:expression:'
  '-hald-clut[apply a Hald color lookup table to the image]'
  '-layers[optimize, merge, or compare image layers]:method:(Coalesce CompareAny CompareClear CompareOverlay Composite Dispose Flatten Merge MergeLayer Mosaic Optimize OptimizeFrame OptimizePlus OptimizeTransparency RemoveDups RemoveZero TrimBounds)'
  '-morph[morph an image sequence]:value:'
  '-mosaic[create a mosaic from an image sequence]'
  '-poly[build a polynomial from the image sequence]:terms:'
  '-print[interpret string and print to console]:string:'
  '-process[process the image with a custom image filter]:arguments:'
  '-smush[smush an image sequence together]:geometry:'
  '-write[write images to this file]:filename:_files'
)

# Image Stack Operators
stack_ops=(
  '-clone[clone an image]:indexes:'
  '-delete[delete the image from the image sequence]:indexes:'
  '-duplicate[duplicate an image one or more times]:count,indexes:'
  '-insert[insert last image into the image sequence]:index:'
  '-reverse[reverse image sequence]'
  '-swap[swap two images in the image sequence]:indexes:'
)

# Miscellaneous Options
misc_ops=(
  '-debug[display copious debugging information]:events:(All Accelerate Annotate Blob Cache Coder Color Command Configure Deprecate Draw Exception Locale Module None Policy Resource Trace Transform Wand X11)'
  '-distribute-cache[distributed pixel cache spanning one or more servers]:port:'
  '-help[print program options]'
  '-list[print a list of supported option arguments]:type:(Coder Color Command Compose Configure Delegate Filter Font Format Gravity Intensity Interpolate Kernel List Locale Log Magic Module Morphology Policy Resource Stretch Style Threshold Type)'
  '-log[format of debugging information]:format:'
  '-version[print version information]'
)

_arguments -s -S \
  $settings \
  $operators \
  $channel_ops \
  $sequence_ops \
  $stack_ops \
  $misc_ops \
  '*:filename:_files'
