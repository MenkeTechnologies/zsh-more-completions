#compdef rg

# Completion for ripgrep (rg) v15.x

_rg_types() {
  local -a types
  types=(${${(f)"$(rg --type-list 2>/dev/null)"}/:/:})
  _describe -t types 'file type' types
}

_rg_encodings() {
  local -a encodings
  encodings=(
    'auto:automatic detection via BOM'
    'none:no BOM sniffing, search raw bytes'
    'utf-8:UTF-8'
    'ascii:ASCII'
    'utf-16le:UTF-16 Little Endian'
    'utf-16be:UTF-16 Big Endian'
    'euc-jp:EUC-JP (Japanese)'
    'shift_jis:Shift_JIS (Japanese)'
    'iso-2022-jp:ISO-2022-JP (Japanese)'
    'big5:Big5 (Traditional Chinese)'
    'gbk:GBK (Simplified Chinese)'
    'gb18030:GB18030 (Chinese)'
    'euc-kr:EUC-KR (Korean)'
    'iso-8859-1:Latin-1 Western European'
    'iso-8859-2:Latin-2 Central European'
    'iso-8859-3:Latin-3 South European'
    'iso-8859-4:Latin-4 North European'
    'iso-8859-5:Latin/Cyrillic'
    'iso-8859-6:Latin/Arabic'
    'iso-8859-7:Latin/Greek'
    'iso-8859-8:Latin/Hebrew'
    'iso-8859-9:Latin-5 Turkish'
    'iso-8859-10:Latin-6 Nordic'
    'iso-8859-13:Latin-7 Baltic Rim'
    'iso-8859-14:Latin-8 Celtic'
    'iso-8859-15:Latin-9'
    'iso-8859-16:Latin-10 South-Eastern European'
    'windows-1250:Windows Central European'
    'windows-1251:Windows Cyrillic'
    'windows-1252:Windows Western European'
    'windows-1253:Windows Greek'
    'windows-1254:Windows Turkish'
    'windows-1255:Windows Hebrew'
    'windows-1256:Windows Arabic'
    'windows-1257:Windows Baltic'
    'windows-1258:Windows Vietnamese'
    'koi8-r:KOI8-R (Russian)'
    'koi8-u:KOI8-U (Ukrainian)'
    'macintosh:macOS Roman'
    'x-mac-cyrillic:macOS Cyrillic'
  )
  _describe -t encodings 'encoding' encodings
}

_rg() {
  local curcontext="$curcontext" ret=1

  _arguments -s -S \
    '(-e --regexp -f --file)1:pattern: ' \
    '*:path:_files' \
    \
    '(- *)'{-h,--help}'[print help information (use --help for more detail)]' \
    '(- *)'{-V,--version}'[print version information]' \
    '(- *)--pcre2-version[print the version of PCRE2 in use]' \
    '(- *)--type-list[show all supported file types and their globs]' \
    '(- *)--generate=[generate man page, shell completions, etc.]:kind:(man complete-bash complete-zsh complete-fish complete-powershell)' \
    \
    '*'{-e,--regexp}'=[specify a pattern to search for]:pattern' \
    '*'{-f,--file}'=[read patterns from file, one per line]:pattern file:_files' \
    '--pre=[run a preprocessor on each input file before searching]:command:_command_names' \
    '*--pre-glob=[only run preprocessor on files matching glob]:glob pattern' \
    {-z,--search-zip}'[search in compressed files (gz, bz2, xz, lz4, lzma, brotli, zstd)]' \
    \
    {-s,--case-sensitive}'[search case sensitively (default)]' \
    '--crlf[treat CRLF (\\r\\n) as a line terminator]' \
    '--dfa-size-limit=[upper size limit of the regex DFA]:size (e.g. 10M)' \
    {-E,--encoding}'=[specify text encoding of files to search]:encoding:_rg_encodings' \
    '--engine=[specify which regex engine to use]:engine:(default pcre2 auto)' \
    {-F,--fixed-strings}'[treat patterns as literal strings, not regexes]' \
    {-i,--ignore-case}'[search case insensitively]' \
    {-v,--invert-match}'[invert matching: show non-matching lines]' \
    {-x,--line-regexp}'[only show matches where the entire line matches]' \
    {-m,--max-count}'=[limit the number of matching lines per file]:count' \
    '--mmap[search using memory maps when possible]' \
    '--no-mmap[never use memory maps]' \
    {-U,--multiline}'[enable matching across multiple lines]' \
    '--multiline-dotall[make dot match newlines when multiline is enabled]' \
    '--no-unicode[disable Unicode-aware matching]' \
    '--null-data[use NUL as a line terminator instead of newline]' \
    {-P,--pcre2}'[use the PCRE2 regex engine]' \
    '--regex-size-limit=[upper size limit of the compiled regex]:size (e.g. 10M)' \
    {-S,--smart-case}'[search case insensitively if pattern is all lowercase]' \
    '--stop-on-nonmatch[stop searching a file after a non-matching line]' \
    {-a,--text}'[search binary files as if they were text]' \
    {-j,--threads}'=[approximate number of threads to use]:threads' \
    {-w,--word-regexp}'[only show matches surrounded by word boundaries]' \
    '--auto-hybrid-regex[dynamically choose between regex engines]' \
    '--no-pcre2-unicode[disable Unicode mode for PCRE2]' \
    \
    '--binary[search binary files but do not print binary data]' \
    {-L,--follow}'[follow symbolic links while traversing directories]' \
    '*'{-g,--glob}'=[include or exclude files matching glob]:glob pattern' \
    '--glob-case-insensitive[process glob patterns case insensitively]' \
    '*--iglob=[like --glob but case insensitive]:glob pattern' \
    '*--ignore-file=[specify additional ignore file]:ignore file:_files' \
    '--ignore-file-case-insensitive[process ignore files case insensitively]' \
    {-d,--max-depth}'=[limit the depth of directory traversal]:depth' \
    '--max-filesize=[ignore files above a certain size]:size (e.g. 50K, 80M)' \
    '--no-ignore[do not respect ignore files (.gitignore, .ignore, etc.)]' \
    '--no-ignore-dot[do not respect .ignore files]' \
    '--no-ignore-exclude[do not respect local exclude files (e.g. .git/info/exclude)]' \
    '--no-ignore-files[do not respect --ignore-file flags]' \
    '--no-ignore-global[do not respect global git ignore rules]' \
    '--no-ignore-parent[do not respect ignore files in parent directories]' \
    '--no-ignore-vcs[do not respect version control ignore files]' \
    '--no-require-git[do not require a git repository to apply git-related rules]' \
    '--one-file-system[do not cross file system boundaries]' \
    {-t,--type}'=[only search files matching type]:type:_rg_types' \
    {-T,--type-not}'=[do not search files matching type]:type:_rg_types' \
    '*--type-add=[add a new glob for a file type]:type spec' \
    '--type-clear=[clear the file type globs for a type]:type:_rg_types' \
    {-u,--unrestricted}'[reduce the level of smart searching (repeat to reduce further)]' \
    \
    {-A,--after-context}'=[show NUM lines after each match]:lines' \
    {-B,--before-context}'=[show NUM lines before each match]:lines' \
    '--block-buffered[use block buffering for output]' \
    {-b,--byte-offset}'[print the 0-based byte offset for each matching line]' \
    '--color=[control when to use colors]:when:(auto always ansi never)' \
    '*--colors=[configure color settings and styles]:color spec' \
    '--column[show column numbers (1-based)]' \
    {-C,--context}'=[show NUM lines before and after each match]:lines' \
    '--context-separator=[string used to separate non-contiguous context lines]:separator' \
    '--no-context-separator[do not print context separators]' \
    '--field-context-separator=[set the field context separator]:separator' \
    '--field-match-separator=[set the field match separator]:separator' \
    '--heading[print the file path above clusters of matches from that file]' \
    '--no-heading[do not group matches by file name]' \
    '--hostname-bin=[run a program to get this systems hostname]:command:_command_names' \
    '--hyperlink-format=[set the format of hyperlinks]:format' \
    '--include-zero[include files with zero matches in output when used with --count]' \
    '--line-buffered[use line buffering for output]' \
    {-n,--line-number}'[show line numbers (1-based)]' \
    {-N,--no-line-number}'[suppress line numbers]' \
    {-M,--max-columns}'=[do not print lines longer than this limit]:columns' \
    '--max-columns-preview[show a preview for lines exceeding max-columns limit]' \
    {-0,--null}'[print a NUL byte after file paths]' \
    {-o,--only-matching}'[print only the matched parts of a matching line]' \
    '--path-separator=[set the path separator for printing file paths]:separator' \
    '--passthru[print both matching and non-matching lines]' \
    {-p,--pretty}'[alias for --color=always --heading --line-number]' \
    {-q,--quiet}'[do not print anything to stdout]' \
    {-r,--replace}'=[replace every match with the given text]:replacement text' \
    '--sort=[sort results in ascending order]:sort by:(path modified accessed created none)' \
    '--sortr=[sort results in descending order]:sort by:(path modified accessed created none)' \
    '--sort-files[DEPRECATED: sort results by file path (use --sort=path)]' \
    '--trim[trim ASCII whitespace at the beginning of each line]' \
    '--vimgrep[show results in vim-compatible format (file:line:column:match)]' \
    {-H,--with-filename}'[display the file path for matches]' \
    {-I,--no-filename}'[never print the file path with matched lines]' \
    \
    {-c,--count}'[show the number of matching lines for each file]' \
    '--count-matches[show the number of individual matches for each file]' \
    {-l,--files-with-matches}'[only print paths with at least one match]' \
    '--files-without-match[only print paths that contain zero matches]' \
    '--json[enable printing results in JSON Lines format]' \
    \
    '--debug[show debug messages]' \
    '--trace[show trace messages (even more verbose than --debug)]' \
    '--no-ignore-messages[suppress errors related to parsing ignore files]' \
    '--no-messages[suppress all error messages related to file I/O]' \
    '--stats[print aggregate statistics about the search]' \
    \
    '--files[print each file that would be searched without actually searching]' \
    '--no-config[never read configuration files]' \
    && ret=0

  return ret
}

_rg "$@"
