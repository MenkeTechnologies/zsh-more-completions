#compdef latitude lsh

# Zsh completion for Latitude.sh CLI (bare metal cloud platform)

local -a commands
commands=(
  'login:Authenticate the CLI with your API token'
  'status:Check the status of your projects and servers'
  'projects:Manage projects'
  'servers:Manage servers'
  'plans:List available hardware plans and pricing'
  'ssh-keys:Manage SSH keys'
  'vlan:Manage virtual networks'
  'api-keys:Manage account API keys'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[Print help message]' \
  '--json[Output in JSON format]' \
  '1: :_describe -t commands "command" commands' \
  '*:: :->args'

case $words[1] in
  projects|servers|plans|ssh-keys|vlan|api-keys)
    local -a subcommands
    subcommands=('list:List items' 'create:Create new item' 'delete:Delete item')
    _arguments \
      '1: :_describe -t subcommands "subcommand" subcommands'
    ;;
esac
