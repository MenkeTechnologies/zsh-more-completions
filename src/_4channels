#compdef 4channels
# Documentation: https://man.archlinux.org/search?q=4channels
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-s[select Nth image in file (default=0)]'
  '-g[use gamma correction with gamma 2.2]'
  '-A[autoscaling by integer factor]'
  '-B[no black subtraction]'
  '*:filename:_files'
)

_arguments -s -S $arguments
