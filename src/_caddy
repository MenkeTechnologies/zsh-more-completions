#compdef caddy

# Zsh completion for Caddy web server

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'adapt:adapt a configuration to native JSON'
  'add-package:add a package (module) to the Caddy build'
  'build-info:print build information'
  'environ:print the environment'
  'file-server:spin up a production-ready file server'
  'fmt:format a Caddyfile'
  'hash-password:hash a password and write base64'
  'list-modules:list installed modules'
  'manpage:generate manpages'
  'reload:change the config of a running Caddy instance'
  'remove-package:remove a package from the Caddy build'
  'reverse-proxy:a quick and production-ready reverse proxy'
  'run:start the Caddy process and block'
  'start:start the Caddy process in the background'
  'stop:stop a running Caddy process'
  'storage:manage Caddy storage resources'
  'trust:install root certificate into local trust store'
  'untrust:uninstall root certificate from local trust store'
  'upgrade:upgrade Caddy'
  'validate:test whether a config file is valid'
  'version:print the version'
)

_arguments -s -S \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'caddy command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (run|start)
        _arguments \
          '--config[config file to load]:file:_files' \
          '--adapter[config adapter to use]:adapter:(caddyfile json)' \
          '--envfile[load env file]:file:_files' \
          '--environ[print environment and exit]' \
          '--pidfile[write PID file]:file:_files' \
          '--resume[use saved config if available]' \
          '--watch[watch config file for changes]' && ret=0
        ;;
      (stop)
        _arguments \
          '--address[the address of the admin API]:address:' \
          '--config[config file]:file:_files' \
          '--adapter[config adapter]:adapter:(caddyfile json)' && ret=0
        ;;
      (reload)
        _arguments \
          '--address[address of admin API]:address:' \
          '--config[config file to load]:file:_files' \
          '--adapter[config adapter]:adapter:(caddyfile json)' \
          '--force[force config reload]' && ret=0
        ;;
      (adapt)
        _arguments \
          '--config[config file to adapt]:file:_files' \
          '--adapter[config adapter]:adapter:(caddyfile json)' \
          '--pretty[pretty print output]' \
          '--validate[validate adapted config]' && ret=0
        ;;
      (validate)
        _arguments \
          '--config[config file to validate]:file:_files' \
          '--adapter[config adapter]:adapter:(caddyfile json)' && ret=0
        ;;
      (fmt)
        _arguments \
          '--overwrite[overwrite the input file]' \
          '--diff[show diff instead of formatted output]' \
          '1:Caddyfile:_files' && ret=0
        ;;
      (reverse-proxy)
        _arguments \
          '--from[address to accept requests on]:address:' \
          '--to[upstream address to proxy to]:address:' \
          '--change-host-header[change Host header to upstream]' \
          '--internal-certs[use internal CA for certs]' \
          '--access-log[enable access logging]' && ret=0
        ;;
      (file-server)
        _arguments \
          '--root[root path]:path:_files -/' \
          '--listen[address to listen on]:address:' \
          '--domain[domain name]:domain:' \
          '--browse[enable directory browsing]' \
          '--access-log[enable access logging]' \
          '--templates[enable template rendering]' && ret=0
        ;;
      (hash-password)
        _arguments \
          '--algorithm[hashing algorithm]:algo:(bcrypt)' \
          '--salt[password salt]:salt:' \
          '--plaintext[plaintext password]:password:' && ret=0
        ;;
      (list-modules)
        _arguments \
          '--packages[also show package names]' \
          '--versions[also show versions]' && ret=0
        ;;
    esac
    ;;
esac

return ret
