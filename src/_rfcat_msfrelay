#compdef rfcat_msfrelay
# Documentation: https://man.archlinux.org/search?q=rfcat_msfrelay
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-i,--index}'[dongle index]:index: '
  {-u,--user}'[HTTP Username]'
  {-p,--password}'[HTTP Password]'
  {-P,--Port}'[HTTP port to listen on]:port: '
  '--noauth[do not require authentication]'
  '--localonly[listen on localhost only]'
  '*:filename:_files'
)

_arguments -s -S $arguments
