#compdef flashrom


local -a arguments

arguments=(
    {-r,--read}'[read flash ROM contents and save them into file]:file:_files'
    {-w,--write}'[write file into flash ROM]:file:_files'
    {-n,--noverify}'[Skip the automatic verification of flash ROM contents after writing.]'
    {-N,--noverify-all}'[Skip not included regions during automatic verification after writing (cf.]'
    {-v,--verify}'[verify the flash ROM contents against file]:file:_files'
    {-E,--erase}'[Erase the flash ROM chip.]'
    {-V,--verbose}'[more verbose output (can be supplied multiple times)]'
    {-c,--chip}'[probe only for the specified flash ROM chip]:chipname:'
    {-f,--force}'[Force one or more of the following actions: .]'
    {-l,--layout}'[read ROM layout from file]:file:_files'
    '--fmap[Read layout from fmap in flash chip.]'
    '--fmap-file[Read layout from a <file> containing binary fmap (e. g. coreboot roms).]:file'
    '--ifd[Read ROM layout from Intel Firmware Descriptor.]'
    {-i,--image}'[only flash region/image from flash layout]:imagename:'
    '--flash-name[Prints out the detected flash chips name.]'
    '--flash-size[Prints out the detected flash chips size.]'
    {-L,--list-supported}'[List the flash chips, chipsets, mainboards, and external programmers (includi]'
    {-z,--list-supported-wiki}'[Same as --list-supported , but outputs the supported hardware in MediaWiki s]'
    {-p,--programmer}'[specify the programmer device]:name:'
    '(- * :)'{-h,--help}'[show a help text and exit]'
    {-o,--output}'[save the full debug log to logfile]:logfile:_files'
    '-R[print version and exit]'
    '--version[show version information and exit]'
    '*:filename:_files'
)
_arguments -s -S $arguments
