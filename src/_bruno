#compdef bruno

# Zsh completion for Bruno - Open-source API client

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S -C \
  '(- *)--version[Show version number]' \
  '(- *)'{-h,--help}'[Show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'run:Run a collection or request'
      'init:Initialize a Bruno collection'
    )
    _describe -t commands 'bruno commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      run)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[Show help]' \
          '--env[Environment to use]:environment name:' \
          '--output[Output file path]:output file:_files' \
          '--format[Output format]:format:(json junit html)' \
          '--insecure[Skip SSL certificate verification]' \
          '--tests-only[Only run requests that have tests]' \
          '--bail[Stop execution on first failure]' \
          '--cacert[CA certificate file]:ca cert:_files' \
          '--timeout[Request timeout in milliseconds]:timeout:' \
          '(-r --recursive)'{-r,--recursive}'[Recursively run requests in subdirectories]' \
          '*:collection or request path:_files' && ret=0
        ;;
      init)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[Show help]' \
          '*:directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
