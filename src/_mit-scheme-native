#compdef mit-scheme-native

local -a arguments

arguments=(
  '--library[sets the library search path to PATH]'
  '--band[specifies the initial band to be loaded]'
  '--fasl[specifies that a cold load should be performed using FILENAME]'
  '--heap[specifies the size of the heap in 1024-word blocks]'
  '--constant[specifies the size of constant space in 1024-word blocks]'
  '--stack[specifies the size of the stack in 1024-word blocks]'
  '--option-summary[causes Scheme to write option values to standard error.]'
  '--help[causes Scheme to report the available command line options.]'
  '--version[causes Scheme to report versions and copyrights, then exit.]'
  {--batch-mode,--quiet,--silent}'[suppresses the startup report of versions and copyrights, and the command prompt]'
  '--emacs[specifies that Scheme is running as a subprocess of GNU Emacs.]'
  '--interactive[force interactive mode even when standard I/O is not a terminal]'
  '--nocore[specifies that Scheme should not generate a core dump under any circumstances]'
  '--macosx-application[specifies that Scheme is running as a Mac OS X application.]'
  '--prepend-library[adds DIRNAME to the front of the library search path]'
  '--args[...]'
  '--edit[causes Edwin to start immediately after Scheme.]'
  '--eval[...]'
  '--load[...]'
  '--no-init-file[inhibits automatic loading of the ~/.scheme.init file.]'
  '--no-suspend-file[inhibits automatic saving of bands to ~/scheme_suspend.]'
  '--suspend-file[if specified, Scheme saves a band to ~/scheme_suspend on suspension]'
  '*:filename:_files'
)

_arguments -s -S $arguments
