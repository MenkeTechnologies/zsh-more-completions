local -a arguments

arguments=(
  '--conflict-style[where STYLE can be:]'
  '--label[LABEL]'
  '--merge[ignored (present for compatibility)]'
  '--show-overlap[ignored (present for compatibility)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
