#compdef trash-put trash-list trash-restore trash-empty trash-rm

local curcontext="$curcontext" state line ret=1

case "$service" in
  trash-put)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)--version[show version]' \
      '-d[print debug messages]' \
      '--verbose[print debug messages]' \
      '-v[verbose mode]' \
      '-f[ignore nonexistent files]' \
      '-i[prompt before every removal]' \
      '-r[ignored (for compatibility with rm)]' \
      '-R[ignored (for compatibility with rm)]' \
      '*:file:_files' && ret=0
    ;;
  trash-list)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)--version[show version]' && ret=0
    ;;
  trash-restore)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)--version[show version]' \
      '--sort=[sort method]:sort:(date path none)' && ret=0
    ;;
  trash-empty)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)--version[show version]' \
      '--print-completion=[generate shell completion]:shell:(bash zsh)' \
      ':days old:' && ret=0
    ;;
  trash-rm)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)--version[show version]' \
      '*:trashed file pattern' && ret=0
    ;;
esac

return ret
