#compdef printf

# Zsh completion for printf - formatted output
# Supports both GNU coreutils printf and BSD/macOS printf

local ret=1

# Detect GNU vs BSD printf
local is_gnu=false
if printf --version &>/dev/null 2>&1; then
  is_gnu=true
fi

if $is_gnu; then
  _arguments -s -S \
    '(- *)--help[display help and exit]' \
    '(- *)--version[output version information and exit]' \
    '1:format string:_printf_format' \
    '*:argument' && ret=0
else
  # BSD/macOS printf has no options, only format + arguments
  _arguments -s -S \
    '1:format string:_printf_format' \
    '*:argument' && ret=0
fi

# Helper: provide common format string completions
(( $+functions[_printf_format] )) || _printf_format() {
  _message -e formats 'format string (e.g. "%%s\\n", "%%d", "%%f")'
}

return ret
