#compdef pamshuffle
# Documentation: https://man.archlinux.org/search?q=pamshuffle
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '--column[Shuffle vertical columns, i. e. perform the same movement on all rows.]'
    '--randomseed[This is the seed for the random number generator that generates the pixels.]:integer'
    '*:filename:_files'
)
_arguments -s -S $arguments
