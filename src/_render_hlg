#compdef render_hlg

local -a arguments

arguments=(
  {-t,--target}'[_nits=nits]'
  {-s,--surround}'[_nits=nits]'
  '--preserve[_saturation=0..1]'
  {-p,--pq}'[write the output with absolute luminance using PQ]'
  {-h,--help}'[prints this help message. All options are shown above.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
