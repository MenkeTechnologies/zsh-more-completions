#compdef render_hlg
# Documentation: https://man.archlinux.org/search?q=render_hlg
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-t,--target_nits}'[set target display brightness in nits]:nits: '
  {-s,--surround_nits}'[set surround brightness in nits]:nits: '
  '--preserve_saturation[set saturation preservation factor (0..1)]:factor: '
  {-p,--pq}'[write the output with absolute luminance using PQ]'
  {-h,--help}'[prints this help message. All options are shown above.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
