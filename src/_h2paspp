#compdef h2paspp
# Documentation: https://man.archlinux.org/search?q=h2paspp
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-d[define symbol]:symbol:'
  '-o[output file]:outfile:'
  '-i[include also includes (default is to remove)]'
  '-h[display this help screen]'
  '*:filename:_files'
)

_arguments -s -S $arguments
