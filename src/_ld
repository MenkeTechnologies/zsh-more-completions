#compdef ld

# Zsh completion for ld (Apple/GNU linker)

_ld() {
  local -a arguments

  arguments=(
    # Output type options
    '-execute[produce a main executable (default)]'
    '-dylib[produce a shared library (MH_DYLIB)]'
    '-bundle[produce a bundle (MH_BUNDLE)]'
    {-r,-relocatable}'[produce a relocatable object file (MH_OBJECT)]'
    '-dylinker[produce a dynamic linker (MH_DYLINKER)]'
    '-dynamic[use dynamic linking (default)]'
    '-static[produce a static binary without dyld]'
    '-preload[produce a preload binary for firmware/embedded use]'

    # Output options
    '-o[specify the output file name]:output file:_files'
    '-arch[specify output architecture]:architecture:(arm64 arm64e x86_64 armv7 armv7s armv7k i386 ppc ppc64)'

    # Library options
    '*-l+[search for library libx.dylib or libx.a]:library name:'
    '*-needed-l+[link with dylib even if no symbols are used]:library name:'
    '*-reexport-l+[link and re-export all symbols from library]:library name:'
    '*-upward-l+[link library as upward dependency]:library name:'
    '*-hidden-l+[link static library with hidden visibility]:library name:'
    '*-weak-l+[link library as weak import]:library name:'
    '*-assert-weak-l+[verify weak imports for library]:library name:'
    '*-delay-l+[link library with delay initialization]:library name:'
    '*-merge-l+[merge library contents into this binary]:library name:'
    '-needed_library[link with dylib even if unused]:path to dylib:_files'
    '-reexport_library[link and re-export library]:path to library:_files'
    '-upward_library[link as upward dependency]:path to library:_files'
    '-weak_library[link library as weak import]:path to library:_files'
    '-assert_weak_library[verify weak imports for library]:path to library:_files'
    '-delay_library[link library with delay initialization]:path to library:_files'
    '-merge_library[merge library into this binary]:path to library:_files'
    '*-L+[add directory to library search path]:directory:_directories'
    '-Z[do not search standard directories for libraries and frameworks]'
    '-syslibroot[prepend directory to all search paths]:root directory:_directories'
    '-search_paths_first[search each dir for dylib then archive (default)]'
    '-search_dylibs_first[search all dirs for dylib first then archive]'

    # Framework options
    '*-framework[link with framework]:framework name:'
    '*-needed_framework[link with framework even if unused]:framework name:'
    '*-weak_framework[link framework as weak import]:framework name:'
    '*-assert_weak_framework[verify weak imports for framework]:framework name:'
    '*-reexport_framework[link and re-export framework]:framework name:'
    '*-upward_framework[link framework as upward dependency]:framework name:'
    '*-delay_framework[link framework with delay initialization]:framework name:'
    '*-merge_framework[merge framework into this binary]:framework name:'
    '*-F+[add directory to framework search path]:directory:_directories'

    # Archive loading options
    '-all_load[load all members of static archive libraries]'
    '-ObjC[load archive members implementing ObjC classes/categories/Swift types]'
    '-force_load[load all members of specified archive]:archive:_files'
    '-load_hidden[load archive with hidden visibility]:archive:_files'
    '-image_suffix[search for libraries with suffix]:suffix:'

    # Additional content
    '-sectcreate[create section from file contents]:segment name: :section name: :file:_files'
    '-add_empty_section[add an empty section]:segment name: :section name:'
    '-add_ast_path[add N_AST stab symbol]:file:_files'
    '-filelist[link files listed in specified file]:file list:_files'
    '-dtrace[enable dtrace static probes]:dtrace script:_files'

    # Optimization options
    '-dead_strip[remove unreachable functions and data]'
    '-order_file[specify symbol layout order]:order file:_files'
    '-no_order_inits[do not rearrange initializer routines]'
    '-platform_version[set platform, min version and SDK version]:platform: :min version: :sdk version:'
    '-macos_version_min[set minimum macOS deployment target]:version:'
    '-ios_version_min[set minimum iOS deployment target]:version:'
    '-image_base[set preferred load address for dylib/bundle]:hex address:'
    '-no_implicit_dylibs[do not hoist public dylibs]'
    '-no_zero_fill_sections[do not move zero-fill sections to end of __DATA]'
    '-merge_zero_fill_sections[merge all zero-fill sections in __DATA]'
    '-no_branch_islands[disable branch island creation]'
    '-O0[disable optimizations to speed up build time]'
    '-reproducible[create reproducible output binary]'

    # Dylib options
    '-install_name[set internal install path for dylib]:install name:'
    '-compatibility_version[set compatibility version number]:version:'
    '-current_version[set current version number]:version:'

    # Executable options
    '-pie[create position independent executable]'
    '-no_pie[do not create position independent executable]'
    '-pagezero_size[set page zero segment size]:hex size:'
    '-stack_size[set maximum stack size for main thread]:hex size:'
    '-allow_stack_execute[mark executable to allow stack execution]'
    '-export_dynamic[preserve all global symbols during LTO]'

    # Bundle options
    '-bundle_loader[specify executable that loads this bundle]:executable:_files'

    # Object file options
    '-keep_private_externs[keep private external symbols as private external]'
    '-d[force definition of common symbols]'

    # Symbol resolution
    '-exported_symbols_list[specify file of global symbols to export]:file:_files'
    '-exported_symbol[keep specified symbol as global]:symbol name:'
    '-no_exported_symbols[do not export any symbols]'
    '-unexported_symbols_list[specify file of symbols to make private]:file:_files'
    '-unexported_symbol[make specified symbol private]:symbol name:'
    '-reexported_symbols_list[specify file of symbols to re-export]:file:_files'
    '-alias[create alias for a symbol]:symbol name: :alias name:'
    '-alias_list[specify file of symbol aliases]:file:_files'
    '-flat_namespace[use flat namespace symbol resolution]'
    '-u[require symbol to be defined]:symbol name:'
    '-U[allow symbol to be undefined]:symbol name:'
    '-undefined[specify treatment of undefined symbols]:treatment:(error warning suppress dynamic_lookup)'
    '*-rpath[add runpath search path]:path:'
    '-commons[specify treatment of tentative definitions]:treatment:(ignore_dylibs error)'

    # Introspection
    '-why_load[log why each object file in a static library is loaded]'
    '-why_live[log chain of references to symbol]:symbol name:'
    '-print_statistics[log memory and time usage information]'
    '-t[log each file the linker loads]'
    '-order_file_statistics[log order file processing information]'
    '-map[write a linker map file]:map file:_files'

    # Symbol table
    '-S[do not put debug information in the output file]'
    '-x[do not put non-global symbols in the symbol table]'
    '-non_global_symbols_strip_list[specify non-global symbols to strip]:file:_files'
    '-non_global_symbols_no_strip_list[specify non-global symbols to keep]:file:_files'
    '-oso_prefix[remove prefix from OSO symbol paths]:prefix path:'

    # Bitcode
    '-bitcode_bundle[generate embedded bitcode bundle]'
    '-bitcode_hide_symbols[hide non-exported symbols from bitcode]'
    '-bitcode_symbol_map[output bitcode symbol reverse map]:path:_files'

    # Code signing
    '-adhoc_codesign[add ad-hoc code signature (default for Apple Silicon)]'
    '-no_adhoc_codesign[do not add ad-hoc code signature]'

    # Data/segment control
    '-data_const[force use of __DATA_CONST segment]'
    '-no_data_const[never move sections to __DATA_CONST]'
    '-const_selrefs[force __objc_selrefs into __DATA_CONST]'
    '-no_const_selrefs[keep __objc_selrefs in __DATA]'

    # Rarely used options
    '-v[print linker version]'
    '-version_details[print version in JSON format]'
    '-no_weak_imports[error if any symbols are weak imports]'
    '-no_deduplicate[do not run deduplication pass]'
    '-verbose_deduplicate[print names of deduplicated functions]'
    '-no_inits[error if output contains static initializers]'
    '-no_warn_inits[do not warn about static initializers]'
    '-warn_duplicate_libraries[warn on duplicate library options]'
    '-no_warn_duplicate_libraries[suppress duplicate library warnings]'
    '-debug_variant[suppress warnings only relevant for shipping binaries]'
    '-unaligned_pointers[treatment of unaligned pointers in __DATA]:treatment:(warning error suppress)'
    '-dirty_data_list[specify dirty data symbol list]:file:_files'
    '-max_default_common_align[set max alignment for common symbols]:hex value:'
    '-move_to_rw_segment[move data symbols to another segment]:segment name: :file:_files'
    '-move_to_ro_segment[move code symbols to another segment]:segment name: :file:_files'
    '-rename_section[rename a section]:old segment: :old section: :new segment: :new section:'
    '-rename_segment[rename all sections in a segment]:old segment: :new segment:'
    '-trace_symbol_layout[print trace of symbol movement]'
    '-trace_symbol_layout_file[write symbol layout trace to file]:file:_files'
    '-section_order[specify section ordering within a segment]:segment name: :colon-separated sections:'
    '-segment_order[specify segment ordering]:colon-separated segments:'
    '-headerpad[set minimum space for future load commands]:hex size:'
    '-headerpad_max_install_names[auto-add space for load command expansion]'
    '-bind_at_load[bind all symbols at load time]'
    '-force_flat_namespace[force flat namespace on all loaded images]'
    '-sectalign[set section alignment]:segment: :section: :hex alignment:'
    '-stack_addr[set initial stack pointer address]:hex address:'
    '-segprot[set segment memory protection]:segment: :max prot: :init prot:'
    '-segaddr[set segment starting address]:segment: :hex address:'
    '-seg_page_size[set segment page size]:segment: :size:'
    '-interposable[indirect access to all exported symbols]'
    '-init[specify initializer symbol for dylib]:symbol name:'
    '-sub_library[re-export specified dylib]:library name:'
    '-sub_umbrella[re-export specified framework]:framework name:'
    '-allowable_client[restrict what can link against this dylib]:client name:'
    '-client_name[specify client name for -allowable_client]:name:'
    '-umbrella[specify umbrella framework name]:framework name:'
    '-fatal_warnings[treat warnings as errors]'
    '-w[suppress all warning messages]'
    '-e[specify entry point symbol]:symbol name:'
    '-no_uuid[do not generate LC_UUID load command]'
    '-random_uuid[generate random UUID instead of content hash]'
    '-no_function_starts[do not create function start address table]'
    '-no_objc_category_merging[do not merge ObjC categories into classes]'
    '-objc_relative_method_lists[force use of relative ObjC method lists]'
    '-no_objc_relative_method_lists[force use of traditional ObjC method lists]'
    '-object_path_lto[specify path for LTO temp object file]:file:_files'
    '-lto_library[specify path to libLTO.dylib]:path:_files'
    '-cache_path_lto[specify LTO cache directory]:path:_directories'
    '-application_extension[mark code safe for app extensions]'
    '-no_application_extension[mark code not safe for app extensions]'
    '-dead_strip_dylibs[remove unreachable dylibs]'
    '-warn_unused_dylibs[warn about unused linked dylibs]'
    '-no_warn_unused_dylibs[suppress unused dylib warnings]'
    '-warn_commons[warn about tentative definition conflicts]'
    '-warn_compact_unwind[warn about functions that cannot use compact unwind]'
    '-warn_weak_exports[warn about weak external symbols]'
    '-no_weak_exports[error on weak external symbols]'
    '-interposable_list[specify symbols that should be interposable]:file:_files'
    '-no_arch_warnings[suppress wrong architecture warnings]'
    '-arch_errors_fatal[treat wrong architecture warnings as errors]'
    '-no_dynamic_access[prevent dlopen and dlsym on this binary]'
    '-page_align_data_atoms[place each global variable on its own page]'
    '-not_for_dyld_shared_cache[prevent dylib from being in shared cache]'
    '-poison_symbol[cause error on use of named symbol]:symbol name:'
    '-poison_symbols_list[specify file of poisoned symbols]:file:_files'

    # Mergeable library options
    '-make_mergeable[add metadata to make dylib mergeable]'
    '-no_merged_libraries_hook[disable bundle resource redirect hook]'
    '-add_mergeable_debug_hook[add debug hook for mergeable libraries]'

    # Linker variant
    '-ld_classic[force use of ld-classic linker]'
    '-ld_new[force use of new ld linker]'

    # GNU ld compatibility options (for cross-platform scripts)
    {-e,--entry}'[set start address]:symbol:'
    '--gc-sections[remove unused sections]'
    '--no-gc-sections[do not remove unused sections]'
    '--as-needed[only set DT_NEEDED for used dynamic libs]'
    '--no-as-needed[always set DT_NEEDED for dynamic libs]'
    {-shared,-Bshareable}'[create a shared library]'
    '--whole-archive[include all objects from following archives]'
    '--no-whole-archive[turn off --whole-archive]'
    '--version-script[read version information script]:file:_files'
    '--build-id[generate build ID note]'
    '--hash-style=[set hash style]:style:(sysv gnu both)'
    '--compress-debug-sections=[compress debug sections]:type:(none zlib zstd)'
    '-Bsymbolic[bind global references locally]'
    '-Bsymbolic-functions[bind global function references locally]'

    '*:file:_files'
  )

  _arguments -s $arguments
}

_ld "$@"
