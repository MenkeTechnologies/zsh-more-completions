#compdef wbinfo

local -a arguments

arguments=(
  {-u,--domain-users}'[lists all domain users]'
  {-g,--domain-groups}'[lists all domain groups]'
  {-N,--WINS-by-name}'[converts NetBIOS name to IP]:name:'
  {-I,--WINS-by-ip}'[converts IP address to NetBIOS name]:ip:'
  {-n,--name-to-sid}'[converts name to sid]'
  {-s,--sid-to-name}'[converts sid to name]'
  '--sid-to-fullname[converts sid to fullname]'
  {-R,--lookup-rids}'[converts RIDs to names]'
  '--lookup-sids[converts SIDs to types]'
  {-U,--uid-to-sid}'[converts uid to sid]'
  {-G,--gid-to-sid}'[converts gid to sid]'
  {-S,--sid-to-uid}'[converts sid to uid]'
  {-Y,--sid-to-gid}'[converts sid to gid]'
  '--allocate-uid[get a new UID out of idmap]'
  '--allocate-gid[get a new GID out of idmap]'
  '--set-uid-mapping[create or modify uid to SID mapping]:uid,sid:'
  '--set-gid-mapping[create or modify gid to SID mapping]:gid,sid:'
  '--remove-uid-mapping[remove uid to SID mapping]:uid,sid:'
  '--remove-gid-mapping[remove gid to SID mapping]:gid,sid:'
  '--sids-to-unix-ids[translate SIDs to Unix IDs]'
  '--unix-ids-to-sids[(u<num> g<num>) Translate Unix IDs to SIDs]'
  {-t,--check-secret}'[check shared secret]'
  {-c,--change-secret}'[change shared secret]'
  {-P,--ping-dc}'[check the NETLOGON connection]'
  {-m,--trusted-domains}'[list trusted domains]'
  '--all-domains[list all domains (trusted and own)]'
  '--own-domain[list own domain]'
  '--online-status[show whether domains are online or offline]'
  {-D,--domain-info}'[show domain info]:domain:'
  {-i,--user-info}'[get user info]'
  '--uid-info[get user info from uid]'
  '--group-info[get group info]'
  '--user-sidinfo[get user info from sid]'
  '--gid-info[get group info from gid]'
  {-r,--user-groups}'[get user groups]'
  '--user-domgroups[get user domain groups]'
  '--sid-aliases[get sid aliases]'
  '--user-sids[get user group sids for user]:user:'
  {-a,--authenticate}'[authenticate user with password]:user%password:'
  '--pam-logon[do a pam logon equivalent]:user%password:'
  '--logoff[log off user]'
  '--logoff-user[username to log off]'
  '--logoff-uid[uid to log off]'
  '--set-auth-user[store user and password]:user%password:'
  '--ccache-save[store user and password in ccache]:user%password:'
  '--getdcname[get a DC name for a domain]:domain:'
  '--dsgetdcname[find a DC for a domain]:domain:'
  '--dc-info[find the currently known DCs for a domain]:domain:'
  '--get-auth-user[retrieve user and password]'
  {-p,--ping}'[ping winbindd to see if it is alive]'
  '--domain[define the domain to restrict operation to]:domain:'
  {-K,--krb5auth}'[authenticate user using Kerberos]:user%password:'
  '--krb5ccname[Kerberos credentials cache name]:ccname:'
  '--separator[get the active winbind separator]'
  '--verbose[print additional information]'
  '--change-user-password[change the password for a user]:user:'
  '--ntlmv1[use NTLMv1 cryptography]'
  '--ntlmv2[use NTLMv2 cryptography]'
  '--lanman[use lanman cryptography]'
  '--usage[display brief usage]'
  {-V,--version}'[print version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
