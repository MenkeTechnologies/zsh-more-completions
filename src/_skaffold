#compdef skaffold

# Zsh completion for skaffold (Kubernetes development workflow)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a global_opts=(
  '(-v --verbosity)'{-v,--verbosity}'[log level]:level:(info warn debug trace fatal panic)'
  '--color[show colors in output]:bool:(true false)'
  '--interactive[allow user prompts]:bool:(true false)'
  '--timestamps[print timestamps in logs]'
  '--update-check[check for a more recent version]'
  '(-h --help)'{-h,--help}'[print help information]'
)

local -a subcommands=(
  'build:build the artifacts'
  'completion:output shell completion for the given shell'
  'config:interact with the global skaffold config'
  'debug:run a pipeline in debug mode'
  'delete:delete any resources deployed by skaffold'
  'deploy:deploy pre-built artifacts'
  'dev:run a pipeline in development mode'
  'diagnose:run a diagnostic on skaffold'
  'exec:execute a custom action'
  'fix:update old configuration to a newer schema version'
  'generate-pipeline:generate a pipeline from a skaffold file'
  'init:generate configuration for deploying an application'
  'inspect:helper commands for cloud code IDEs'
  'lint:lint skaffold configuration'
  'log:show the logs for deployed resources'
  'render:perform all image builds and render the manifests'
  'run:run a pipeline'
  'schema:list and print json schemas'
  'survey:open a survey form in your browser'
  'test:run tests against built artifacts'
  'verify:run verification tests against deployed resources'
  'version:print the version information'
)

_arguments -s -S -C \
  $global_opts \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t subcommands 'skaffold command' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      dev)
        _arguments -s -S \
          $global_opts \
          '--cleanup[delete deployments on exit]' \
          '--no-prune[skip removing images and containers]' \
          '--port-forward[port-forward exposed container ports]' \
          '--tail[stream logs from deployed objects]' \
          '--trigger[how to trigger builds]:trigger:(polling notify manual)' \
          '--auto-build[auto rebuild when files change]' \
          '--auto-deploy[auto deploy after build]' \
          '--auto-sync[auto sync files to running containers]' \
          '--build-concurrency[number of concurrently running builds]:num:' \
          '(-d --default-repo)'{-d,--default-repo}'[default image repository]:repo:' \
          '(-f --filename)'{-f,--filename}'[path to the skaffold config]:file:_files' \
          '(-n --namespace)'{-n,--namespace}'[run in the given namespace]:namespace:' \
          '(-p --profile)'{-p,--profile}'[activate given profiles]:profile:' \
          '--kube-context[deploy to the given kubeconfig context]:context:' \
          '--kubeconfig[path to the kubeconfig file]:file:_files' \
          '--status-check[wait for deployed resources to stabilize]' \
          '--force[recreate Kubernetes resources if necessary]' \
          '--iterative-dev[enable iterative dev mode]' \
          '--rpc-port[port for gRPC API]:port:' \
          '--rpc-http-port[port for HTTP API]:port:' \
          '*--label[add custom labels to deployed objects]:key=value:' \
          '--tag[the optional custom tag to use]:tag:' \
          '--toot[emit a terminal beep after build is complete]' && ret=0
        ;;
      build)
        _arguments -s -S \
          $global_opts \
          '--build-concurrency[number of concurrently running builds]:num:' \
          '*--build-image[only build these images]:image:' \
          '--cache-artifacts[set to true to use the build cache]' \
          '--cache-file[specify the build cache file]:file:_files' \
          '(-d --default-repo)'{-d,--default-repo}'[default image repository]:repo:' \
          '--dry-run[do not build; just print the image names]' \
          '--file-output[filename to write built images to]:file:_files' \
          '(-f --filename)'{-f,--filename}'[path to the skaffold config]:file:_files' \
          '*--insecure-registry[specify insecure image registries]:registry:' \
          '(-n --namespace)'{-n,--namespace}'[run in the given namespace]:namespace:' \
          '(-o --output)'{-o,--output}'[used in conjunction with --quiet to define output format]:format:' \
          '(-p --profile)'{-p,--profile}'[activate given profiles]:profile:' \
          '(-q --quiet)'{-q,--quiet}'[suppress all non-error output]' \
          '--push[push the built images to the specified image repository]' \
          '--tag[the optional custom tag to use]:tag:' \
          '--toot[emit a terminal beep after build is complete]' \
          '*:file:_files' && ret=0
        ;;
      run)
        _arguments -s -S \
          $global_opts \
          '--tail[stream logs from deployed objects]' \
          '--force[recreate Kubernetes resources if necessary]' \
          '--status-check[wait for deployed resources to stabilize]' \
          '(-d --default-repo)'{-d,--default-repo}'[default image repository]:repo:' \
          '(-f --filename)'{-f,--filename}'[path to the skaffold config]:file:_files' \
          '(-n --namespace)'{-n,--namespace}'[run in the given namespace]:namespace:' \
          '(-p --profile)'{-p,--profile}'[activate given profiles]:profile:' \
          '--kube-context[deploy to the given kubeconfig context]:context:' \
          '--kubeconfig[path to the kubeconfig file]:file:_files' \
          '--tag[the optional custom tag to use]:tag:' \
          '--toot[emit a terminal beep after build is complete]' && ret=0
        ;;
      deploy)
        _arguments -s -S \
          $global_opts \
          '*--images[images to deploy]:image:' \
          '--force[recreate Kubernetes resources if necessary]' \
          '--status-check[wait for deployed resources to stabilize]' \
          '(-d --default-repo)'{-d,--default-repo}'[default image repository]:repo:' \
          '(-f --filename)'{-f,--filename}'[path to the skaffold config]:file:_files' \
          '(-n --namespace)'{-n,--namespace}'[run in the given namespace]:namespace:' \
          '(-p --profile)'{-p,--profile}'[activate given profiles]:profile:' \
          '--kube-context[deploy to the given kubeconfig context]:context:' \
          '--kubeconfig[path to the kubeconfig file]:file:_files' \
          '--tag[the optional custom tag to use]:tag:' && ret=0
        ;;
      delete)
        _arguments -s -S \
          $global_opts \
          '(-f --filename)'{-f,--filename}'[path to the skaffold config]:file:_files' \
          '(-n --namespace)'{-n,--namespace}'[run in the given namespace]:namespace:' \
          '(-p --profile)'{-p,--profile}'[activate given profiles]:profile:' \
          '--kube-context[deploy to the given kubeconfig context]:context:' \
          '--kubeconfig[path to the kubeconfig file]:file:_files' && ret=0
        ;;
      debug)
        _arguments -s -S \
          $global_opts \
          '--cleanup[delete deployments on exit]' \
          '--port-forward[port-forward exposed container ports]' \
          '--tail[stream logs from deployed objects]' \
          '(-d --default-repo)'{-d,--default-repo}'[default image repository]:repo:' \
          '(-f --filename)'{-f,--filename}'[path to the skaffold config]:file:_files' \
          '(-n --namespace)'{-n,--namespace}'[run in the given namespace]:namespace:' \
          '(-p --profile)'{-p,--profile}'[activate given profiles]:profile:' \
          '--kube-context[deploy to the given kubeconfig context]:context:' \
          '--kubeconfig[path to the kubeconfig file]:file:_files' \
          '--tag[the optional custom tag to use]:tag:' && ret=0
        ;;
      render)
        _arguments -s -S \
          $global_opts \
          '(-d --default-repo)'{-d,--default-repo}'[default image repository]:repo:' \
          '(-f --filename)'{-f,--filename}'[path to the skaffold config]:file:_files' \
          '(-n --namespace)'{-n,--namespace}'[run in the given namespace]:namespace:' \
          '(-p --profile)'{-p,--profile}'[activate given profiles]:profile:' \
          '(-o --output)'{-o,--output}'[file to write rendered manifests to]:file:_files' \
          '--tag[the optional custom tag to use]:tag:' && ret=0
        ;;
      config)
        local -a config_commands=(
          'list:list all config values'
          'set:set a config value'
          'unset:unset a config value'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->config_cmd' \
          '*::arg:->config_args' && ret=0
        case $state in
          config_cmd)
            _describe -t commands 'config subcommand' config_commands && ret=0
            ;;
          config_args)
            case $line[1] in
              set)
                _arguments -s -S $global_opts ':key:' ':value:' && ret=0
                ;;
              unset)
                _arguments -s -S $global_opts ':key:' && ret=0
                ;;
              list)
                _arguments -s -S \
                  $global_opts \
                  '--all[show all values including defaults]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      completion)
        _arguments -s -S \
          $global_opts \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      init)
        _arguments -s -S \
          $global_opts \
          '--compose-file[docker-compose file to convert]:file:_files' \
          '(-f --filename)'{-f,--filename}'[path to the skaffold config]:file:_files' \
          '--force[force the generation of a skaffold config]' \
          '--skip-build[skip build setup]' && ret=0
        ;;
      test)
        _arguments -s -S \
          $global_opts \
          '(-f --filename)'{-f,--filename}'[path to the skaffold config]:file:_files' \
          '(-p --profile)'{-p,--profile}'[activate given profiles]:profile:' && ret=0
        ;;
      verify)
        _arguments -s -S \
          $global_opts \
          '(-f --filename)'{-f,--filename}'[path to the skaffold config]:file:_files' \
          '(-p --profile)'{-p,--profile}'[activate given profiles]:profile:' && ret=0
        ;;
      log)
        _arguments -s -S \
          $global_opts \
          '(-f --filename)'{-f,--filename}'[path to the skaffold config]:file:_files' \
          '(-n --namespace)'{-n,--namespace}'[run in the given namespace]:namespace:' \
          '(-p --profile)'{-p,--profile}'[activate given profiles]:profile:' && ret=0
        ;;
      diagnose|fix|generate-pipeline|inspect|lint|schema|survey|exec|version)
        _arguments -s -S \
          $global_opts \
          '(-f --filename)'{-f,--filename}'[path to the skaffold config]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
