#compdef pytest py.test

# Zsh completion for pytest
# https://docs.pytest.org/en/stable/reference/reference.html

_pytest() {
  local -a arguments

  arguments=(
    # General options
    '(-k)-k+[Only run tests matching given substring expression]:expression:'
    '(-m)-m+[Only run tests matching given mark expression]:mark expression:'
    '--markers[Show markers (builtin, plugin and per-project ones)]'
    {-x,--exitfirst}'[Exit instantly on first error or failed test]'
    '--maxfail=[Exit after first num failures or errors]:num:'
    '--strict-config[Any warnings encountered while parsing the pytest section of the config file raise errors]'
    '--strict-markers[Markers not registered in the markers section of the config file raise errors]'
    '--strict[Alias for --strict-markers and --strict-config combined]'
    '-c+[Load configuration from given file]:config file:_files'
    '--co[Synonym for --collect-only]'
    '--collect-only[Only collect tests, do not execute them]'
    '--continue-on-collection-errors[Force test execution even if collection errors occur]'
    '--rootdir=[Define root directory for tests]:root dir:_directories'
    {--fixtures,--funcargs}'[Show available fixtures, sorted by plugin appearance]'
    '--fixtures-per-test[Show fixtures per test]'
    '--import-mode=[Prepend/append to sys.path when importing test modules and conftest files]:mode:(prepend append importlib)'
    '--pyargs[Try to interpret all arguments as Python packages]'
    '*--ignore=[Ignore path during collection]:path:_files'
    '*--ignore-glob=[Ignore path pattern during collection]:glob pattern:'
    '*--deselect=[Deselect item (via node id prefix) during collection]:node id:'
    '--confcutdir=[Only load conftest.py files relative to specified dir]:dir:_directories'
    '--noconftest[Do not load any conftest.py files]'
    '--keep-duplicates[Keep duplicate tests]'
    '--collect-in-virtualenv[Do not ignore tests in a local virtualenv directory]'

    # Debugging and interactive options
    '--pdb[Start the interactive Python debugger on errors or KeyboardInterrupt]'
    '--pdbcls=[Specify a custom interactive Python debugger class]:modulename\:classname:'
    '--trace[Immediately break when running each test]'
    {-s,--capture=no}'[Shortcut for --capture=no (disable all capturing)]'
    '--capture=[Per-test capturing method]:method:(fd sys no tee-sys)'
    '--runxfail[Report the results of xfail tests as if they were not marked]'

    # Test failure behavior
    {--lf,--last-failed}'[Rerun only the tests that failed at the last run]'
    {--ff,--failed-first}'[Run all tests, but run last failures first]'
    {--nf,--new-first}'[Run tests from new files first, then the rest sorted by file mtime]'
    '--cache-show=[Show cache contents, do not perform collection or tests]:glob pattern:'
    '--cache-clear[Remove all cache contents at start of test run]'
    '--lfnf=[Determines whether to execute tests when there are no previously failed tests]:mode:(all none)'
    {--sw,--stepwise}'[Exit on test failure and continue from last failing test next time]'
    '--stepwise-skip[Ignore the first failing test but stop on the next failing test]'

    # Reporting
    {-v,--verbose}'[Increase verbosity]'
    '--no-header[Disable header]'
    {-q,--quiet}'[Decrease verbosity]'
    '--verbosity=[Set verbosity]:value:'
    '-r+[Show extra test summary info as specified by chars]:chars:(f E s x X p P a A N):'
    {--disable-warnings,--disable-pytest-warnings}'[Disable warnings summary]'
    {-l,--showlocals}'[Show locals in tracebacks (disabled by default)]'
    '--no-showlocals[Hide locals in tracebacks]'
    '--tb=[Traceback print mode]:mode:(auto long short line native no)'
    '--show-capture=[Controls how captured stdout/stderr/log is shown on failed tests]:mode:(no stdout stderr log all)'
    '--full-trace[Do not cut any tracebacks (default is to cut)]'
    '--color=[Color terminal output]:when:(yes no auto)'
    '--code-highlight=[Whether code should be highlighted (only if --color is also enabled)]:when:(yes no)'
    '--durations=[Show N slowest setup/test durations (N=0 for all)]:N:'
    '--durations-min=[Minimal duration in seconds for inclusion in slowest list]:N:'
    {-p,--plugin}'[Early-load given plugin module name or entry point]:plugin name:'

    # Junit/output
    '--junit-xml=[Create junit-xml style report file at given path]:path:_files'
    '--junit-prefix=[Prepend prefix to classnames in junit-xml output]:prefix:'

    # Doctest
    '--doctest-modules[Run doctests in all .py modules]'
    '--doctest-report=[Choose another output format for diffs]:format:(none cdiff ndiff udiff only_first_failure)'
    '--doctest-glob=[Doctests file matching pattern]:pattern:'
    '--doctest-ignore-import-errors[Ignore doctest collection errors]'
    '--doctest-continue-on-failure[For a given doctest, continue to run after the first failure]'

    # Temp directory
    '--basetemp=[Base temporary directory for this test run]:dir:_directories'

    # Version/help
    '--version[Display pytest version and import information]'
    '(- * :)'{-h,--help}'[Show help message and configuration info]'

    # Config/debug
    '--trace-config[Trace considerations of conftest.py files]'
    '--debug=[Store internal tracing debug information in given log file]:path:_files'
    '*'{-o,--override-ini}'[Override ini option with "option=value" style]:override:'
    '--assert=[Control assertion debugging tools]:mode:(plain rewrite)'
    {-W,--pythonwarnings}'[Set which warnings to report]:warning filter:'

    # Setup
    '--setup-only[Only setup fixtures, do not execute tests]'
    '--setup-show[Show setup of fixtures while executing tests]'
    '--setup-plan[Show what fixtures and tests would be executed but do not execute anything]'

    # Logging
    '--log-level=[Level of messages to catch/display]:level:(CRITICAL ERROR WARNING INFO DEBUG NOTSET)'
    '--log-format=[Log format used by the logging module]:format:'
    '--log-date-format=[Log date format used by the logging module]:format:'
    '--log-cli-level=[CLI logging level]:level:(CRITICAL ERROR WARNING INFO DEBUG NOTSET)'
    '--log-cli-format=[Log format used by the logging module (CLI)]:format:'
    '--log-cli-date-format=[Log date format used by the logging module (CLI)]:format:'
    '--log-file=[Path to a file to write logging to]:path:_files'
    '--log-file-level=[Log file logging level]:level:(CRITICAL ERROR WARNING INFO DEBUG NOTSET)'
    '--log-file-format=[Log format used for the log file]:format:'
    '--log-file-date-format=[Log date format used for the log file]:format:'
    '--log-auto-indent=[Auto-indent multiline messages]:value:(true false)'
    '--log-disable=[Disable a logger by name]:logger name:'
    '--no-print-logs[Disable printing caught logs on failed tests]'

    # Positional: files/dirs
    '*:file or directory:_files'
  )

  _arguments -s -S $arguments
}

_pytest "$@"
