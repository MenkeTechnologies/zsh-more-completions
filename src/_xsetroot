#compdef xsetroot

local -a arguments

arguments=(
  {-display,-d}'[specify X display]:display:'
  {-fg,-foreground}'[set foreground color]:color:'
  {-bg,-background}'[set background color]:color:'
  {-rv,-reverse}'[reverse foreground and background colors]'
  {-def,-default}'[reset to default settings]'
  '-name[set root window name]:name:'
  '-cursor[set cursor from cursor and mask files]:cursor-file:_files'
  '-cursor_name[set cursor from cursor font name]:name:'
  '-xcf[set cursor from XCF cursor file]:cursor-file:_files'
  '-solid[set solid color background]:color:'
  {-gray,-grey}'[set grey background]'
  '-bitmap[set bitmap background]:bitmap-file:_files'
  '-mod[set modula pattern]:x: :y:'
  '-help[display help]'
  '-version[display version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
