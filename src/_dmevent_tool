#compdef dmevent_tool
# Documentation: https://man.archlinux.org/search?q=dmevent_tool
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-V[show version of dmevent_tool]'
  '-m[list all currently active device mapper devices]'
  '-a[same as -m, but for devices with UUID only!]'
  '-r[register a device with dmeventd]'
  '-u[unregister a device with dmeventd]'
  '*:filename:_files'
)

_arguments -s -S $arguments
