#compdef xbrlapi
# Documentation: https://man.archlinux.org/search?q=xbrlapi
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-b,--brlapi}'[brlAPI host and/or port to connect to]'
  {-a,--auth}'[brlAPI authorization/authentication string]'
  {-d,--display}'[X display to connect to]'
  {-q,--quiet}'[do not write any text to the braille device]'
  '(- * :)'{-h,--help}'[print a usage summary (commonly used options]'
  {-H,--full-help}'[print a usage summary (all options), and then]'
  '*:filename:_files'
)

_arguments -s -S $arguments
