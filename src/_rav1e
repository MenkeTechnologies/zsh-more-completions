#compdef rav1e

local -a arguments

arguments=(
  '--fullhelp[prints more detailed help information]'
  '--low-latency[low latency mode; disables frame reordering]'
  '--still-picture[still picture mode]'
  '--benchmark[provide a benchmark report at the end of the encoding]'
  {-v,--verbose}'[verbose logging; outputs info for every frame]'
  {-q,--quiet}'[do not output any status message]'
  '--psnr[calculate and display PSNR metrics]'
  '--metrics[calulate and display several metrics including PSNR, SSIM, CIEDE2000 etc]'
  '-y[overwrite output file.]'
  '(- * :)'{-h,--help}'[prints help information]'
  {-V,--version}'[prints version information]'
  '--threads[set the threadpool size (default 0)]:threads: '
  {-o,--output}'[compressed AV1 in IVF video output]:file:_files'
  '--first-pass[perform the first pass of a two-pass encode, saving pass data to file]:file:_files'
  '--second-pass[perform the second pass of a two-pass encode, reading pass data from file]:file:_files'
  {-l,--limit}'[maximum number of frames to encode (default 0)]:frames: '
  '--skip[skip n number of frames and encode (default 0)]:frames: '
  '--quantizer[quantizer (0-255), smaller values are higher quality (default 100)]:quantizer: '
  '--min-quantizer[minimum quantizer (0-255) to use in bitrate mode (default 0)]:quantizer: '
  {-b,--bitrate}'[bitrate (kbps)]:bitrate: '
  {-s,--speed}'[speed level (0 is best quality, 10 is fastest)]:speed: '
  {-i,--min-keyint}'[minimum interval between keyframes (default 12)]:interval: '
  {-I,--keyint}'[maximum interval between keyframes (default 240)]:interval: '
  {-S,--switch-frame-interval}'[maximum interval between switch frames (default 0)]:interval: '
  '--reservoir-frame-delay[number of frames for rate control reservoir distribution]:frames: '
  '--rdo-lookahead-frames[number of frames encoder should lookahead for RDO (default 40)]:frames: '
  '--tune[quality tuning (default Psychovisual)]:tune:(Psnr Psychovisual)'
  '--tile-rows[number of tile rows, must be a power of 2 (default 0)]:rows: '
  '--tile-cols[number of tile columns, must be a power of 2 (default 0)]:cols: '
  '--tiles[number of tiles, overrides tile-cols and tile-rows]:tiles: '
  '--range[pixel range (default limited)]:range:(Limited Full)'
  '--primaries[color primaries used to describe color parameters]:primaries:(BT709 Unspecified BT470M BT470BG ST170M ST240M Film BT2020 ST428 P3DCI P3Display EBU3213)'
  '--transfer[transfer characteristics used to describe color parameters]:transfer:(BT709 Unspecified BT470M BT470BG ST170M ST240M Linear Logarithmic100 Logarithmic316 IEC61966 BT1361 SRGB BT2020Ten BT2020Twelve ST2084 ST428 HLG)'
  '--matrix[matrix coefficients used to describe color parameters]:matrix:(Identity BT709 Unspecified FCC BT470BG ST170M ST240M YCgCo BT2020NCL BT2020CL ST2085 ChromaDerivedNCL ChromaDerivedCL ICtCp)'
  '--mastering-display[mastering display primaries in G(x,y)B(x,y)R(x,y)WP(x,y)L(max,min) form]:primaries: '
  '--content-light[content light level (cll,fall) (default 0,0)]:cll,fall: '
  '--frame-rate[constant frame rate to set at the output]:frame-rate: '
  '--time-scale[the time scale associated with the frame rate (default 1)]:time-scale: '
  {-r,--reconstruction}'[outputs a Y4M file containing the output from the decoder]:file:_files'
  '*:filename:_files'
)

_arguments -s -S $arguments
