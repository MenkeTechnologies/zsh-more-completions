#compdef nvme

# Zsh completion for nvme-cli (NVMe management utility)

_nvme_devices() {
  local -a devices
  devices=(/dev/nvme*(N))
  _describe -t devices 'NVMe device' devices
}

_nvme_namespaces() {
  local -a namespaces
  namespaces=(/dev/nvme*n*(N))
  _describe -t namespaces 'NVMe namespace' namespaces
}

_nvme_commands() {
  local -a commands
  commands=(
    'list:list all NVMe devices and namespaces'
    'list-subsys:list NVMe subsystems'
    'id-ctrl:send NVMe identify controller'
    'id-ns:send NVMe identify namespace'
    'list-ns:send NVMe identify namespace list'
    'create-ns:create a new namespace'
    'delete-ns:delete a namespace'
    'attach-ns:attach a namespace to controller(s)'
    'detach-ns:detach a namespace from controller(s)'
    'list-ctrl:send NVMe identify controller list'
    'get-ns-id:get namespace ID of opened block device'
    'get-log:retrieve a log page'
    'telemetry-log:retrieve telemetry log'
    'fw-log:retrieve firmware log'
    'smart-log:retrieve SMART log'
    'smart-log-add:retrieve additional SMART log'
    'error-log:retrieve error log'
    'effects-log:retrieve command effects log'
    'endurance-log:retrieve endurance group log'
    'predictable-lat-log:retrieve predictable latency log'
    'supported-log-pages:retrieve supported log pages'
    'format:format NVMe namespace'
    'sanitize:sanitize NVMe device'
    'reset:reset NVMe controller'
    'subsystem-reset:reset NVMe subsystem'
    'fw-download:download firmware to device'
    'fw-commit:commit downloaded firmware'
    'fw-activate:activate downloaded firmware'
    'admin-passthru:send admin passthrough command'
    'io-passthru:send IO passthrough command'
    'read:submit a read command'
    'write:submit a write command'
    'compare:submit a compare command'
    'flush:submit a flush command'
    'resv-acquire:submit a reservation acquire command'
    'resv-register:submit a reservation register command'
    'resv-release:submit a reservation release command'
    'resv-report:submit a reservation report command'
    'dsm:submit a dataset management command'
    'copy:submit a copy command'
    'verify:submit a verify command'
    'show-regs:show NVMe controller registers'
    'discover:discover NVMe-oF subsystems'
    'connect-all:discover and connect to NVMe-oF subsystems'
    'connect:connect to an NVMe-oF subsystem'
    'disconnect:disconnect from an NVMe-oF subsystem'
    'disconnect-all:disconnect from all NVMe-oF subsystems'
    'gen-hostnqn:generate a host NQN'
    'show-hostnqn:show the host NQN'
    'version:show nvme-cli version'
    'help:display help'
  )
  _describe -t commands 'nvme command' commands
}

_nvme() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help message]' \
    '(- *)'{-V,--version}'[show version]' \
    '1:command:_nvme_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        list)
          _arguments \
            {-o,--output-format}'[output format]:format:(normal json binary)' \
            {-v,--verbose}'[increase output verbosity]'
          ;;
        list-subsys)
          _arguments \
            {-o,--output-format}'[output format]:format:(normal json binary)' \
            {-v,--verbose}'[increase output verbosity]' \
            '*:device:_nvme_devices'
          ;;
        id-ctrl|smart-log|smart-log-add|fw-log|error-log|effects-log|endurance-log|show-regs)
          _arguments \
            {-o,--output-format}'[output format]:format:(normal json binary)' \
            '*:device:_nvme_devices'
          ;;
        id-ns|read|write|compare|flush|verify)
          _arguments \
            {-o,--output-format}'[output format]:format:(normal json binary)' \
            {-n,--namespace-id}'[namespace ID]:ID:' \
            '*:device:_nvme_namespaces'
          ;;
        format)
          _arguments \
            {-n,--namespace-id}'[namespace ID]:ID:' \
            {-l,--lbaf}'[LBA format]:index:' \
            {-s,--ses}'[secure erase setting]:setting:(0 1 2)' \
            '*:device:_nvme_devices'
          ;;
        sanitize)
          _arguments \
            {-a,--sanact}'[sanitize action]:action:(1 2 4)' \
            '*:device:_nvme_devices'
          ;;
        fw-download)
          _arguments \
            {-f,--fw}'[firmware file]:file:_files' \
            {-x,--xfer}'[transfer size]:size:' \
            {-o,--offset}'[starting offset]:offset:' \
            '*:device:_nvme_devices'
          ;;
        fw-commit|fw-activate)
          _arguments \
            {-s,--slot}'[firmware slot]:slot:(1 2 3 4 5 6 7)' \
            {-a,--action}'[commit action]:action:(0 1 2 3)' \
            '*:device:_nvme_devices'
          ;;
        connect)
          _arguments \
            {-t,--transport}'[transport type]:type:(rdma fc tcp loop)' \
            {-n,--nqn}'[subsystem NQN]:NQN:' \
            {-a,--traddr}'[transport address]:address:_hosts' \
            {-s,--trsvcid}'[transport service ID]:service ID:' \
            {-q,--hostnqn}'[host NQN]:NQN:'
          ;;
        discover|connect-all)
          _arguments \
            {-t,--transport}'[transport type]:type:(rdma fc tcp loop)' \
            {-a,--traddr}'[transport address]:address:_hosts' \
            {-s,--trsvcid}'[transport service ID]:service ID:' \
            {-q,--hostnqn}'[host NQN]:NQN:'
          ;;
        disconnect)
          _arguments \
            {-n,--nqn}'[subsystem NQN to disconnect]:NQN:' \
            {-d,--device}'[device to disconnect]:device:_nvme_devices'
          ;;
        reset|subsystem-reset|gen-hostnqn|show-hostnqn|disconnect-all)
          _arguments '*:device:_nvme_devices'
          ;;
        get-ns-id)
          _arguments '*:device:_nvme_namespaces'
          ;;
        create-ns)
          _arguments \
            {-s,--nsze}'[namespace size]:size:' \
            {-c,--ncap}'[namespace capacity]:capacity:' \
            {-f,--flbas}'[formatted LBA size]:index:' \
            '*:device:_nvme_devices'
          ;;
        delete-ns)
          _arguments \
            {-n,--namespace-id}'[namespace ID to delete]:ID:' \
            '*:device:_nvme_devices'
          ;;
        attach-ns|detach-ns)
          _arguments \
            {-n,--namespace-id}'[namespace ID]:ID:' \
            {-c,--controllers}'[controller IDs]:IDs:' \
            '*:device:_nvme_devices'
          ;;
        *)
          _arguments '*:device:_nvme_devices'
          ;;
      esac
      ;;
  esac
}

_nvme "$@"
