#compdef mount mount.exfat-fuse
# Documentation: https://man.archlinux.org/search?q=mount
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '-d[Enable debug logging and do not detach from shell.]'
    '-n[Ignored.]'
    '-o[File system specific options.]:options'
    '-V[Print version and copyright.]'
    '-v[Ignored.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
