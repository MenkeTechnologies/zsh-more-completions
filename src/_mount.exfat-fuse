#compdef mount mount.exfat-fuse


local -a arguments

arguments=(
    '-d[Enable debug logging and do not detach from shell.]'
    '-n[Ignored.]'
    '-o[File system specific options.]:options'
    '-V[Print version and copyright.]'
    '-v[Ignored.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
