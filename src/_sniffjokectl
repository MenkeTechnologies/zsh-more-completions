#compdef sniffjokectl
# Documentation: https://man.archlinux.org/search?q=sniffjokectl
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--address[specify administration IP address \[default: 127.0.0.1:8844\]]'
  '--version[show sniffjoke version]'
  '--timeout[set milliseconds timeout when contacting SniffJoke service \[default: 500\]]'
  '--help[show this help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
