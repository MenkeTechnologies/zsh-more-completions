#compdef mosquitto


local -a arguments

arguments=(
    {-c,--config-file}'[specify configuration file]:config file:_files'
    '-p[specify listener port number]:port: '
    {-d,--daemon}'[run as a daemon in the background]'
    '--port[specify listener port number]:port: '
    {-v,--verbose}'[enable verbose logging]'
    '*:filename:_files'
)
_arguments -s -S $arguments
