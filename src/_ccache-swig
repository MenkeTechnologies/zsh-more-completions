#compdef ccache-swig

local -a arguments

arguments=(
  '-s[show statistics summary]'
  '-z[zero statistics]'
  '-c[run a cache cleanup]'
  '-C[clear the cache completely]'
  '-F[set maximum files in cache]:count:'
  '-M[set maximum size of cache (use G, M or K)]:size:'
  '-h[this help page]'
  '-V[print version number]'
  '*:filename:_files'
)

_arguments -s -S $arguments
