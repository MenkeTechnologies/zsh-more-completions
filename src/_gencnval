#compdef gencnval
# Documentation: https://man.archlinux.org/search?q=gencnval
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[-\? or --help this usage text]'
  {-v,--verbose}'[prints out extra information about the alias table]'
  {-q,--quiet}'[do not display warnings and progress]'
  {-c,--copyright}'[include a copyright notice]'
  {-d,--destdir}'[destination directory, followed by the path]'
  {-s,--sourcedir}'[source directory, followed by the path]'
  '*:filename:_files'
)

_arguments -s -S $arguments
