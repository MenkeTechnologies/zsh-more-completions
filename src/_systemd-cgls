#compdef systemd-cgls

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help]'
  '--version[show package version]'
  '--no-pager[do not pipe output into a pager]'
  {-a,--all}'[show all groups, including empty]'
  {-u,--unit}'[show the subtrees of specified system units]:unit'
  '--user-unit[show the subtrees of specified user units]:unit'
  {-l,--full}'[do not ellipsize output]'
  '-k[include kernel threads in output]'
  {-M,--machine=}'[show container]:machine'
  {-x,--xattr=}'[show extended attributes of control groups]:boolean:(true false)'
  {-c,--cgroup-id=}'[show numeric ID of control groups]:boolean:(true false)'
  '*::control group path:_directories'
)

_arguments -s -S $arguments
