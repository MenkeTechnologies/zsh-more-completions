#compdef blueman-browse
# Documentation: https://man.archlinux.org/search?q=blueman-browse
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-d,--device}'[browse this device]'
  '*:filename:_files'
)

_arguments -s -S $arguments
