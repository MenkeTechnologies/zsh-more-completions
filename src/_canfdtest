#compdef canfdtest
# Documentation: https://man.archlinux.org/search?q=canfdtest
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-v[low verbosity]'
  '-vv[high verbosity]'
  '-g[generate messages]'
  '-l[test loop count]:count:'
  '*:filename:_files'
)

_arguments -s -S $arguments
