#compdef yuy2topam
# Documentation: https://man.archlinux.org/search?q=yuy2topam
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '--width[Width of the image, in pixels. This must be an even number.]:width'
    '--height[Height of the image. These options are mandatory]:height'
    '*:filename:_files'
)
_arguments -s -S $arguments
