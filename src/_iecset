#compdef iecset
# Documentation: https://man.archlinux.org/search?q=iecset
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-D[specifies the control device to use]'
  '-c[specifies the card number to use (equiv. with -Dhw:#)]'
  '-n[specifies the control index number (default = 0)]'
  '-x[dump the dump the AESx hex code for IEC958 PCM parameters]'
  '-i[read commands from stdin]'
  '*:filename:_files'
)

_arguments -s -S $arguments
