#compdef fuse2fs

local -a arguments

arguments=(
  '-o[\[opt...\] mount options]'
  '(- * :)'{-h,--help}'[print help]'
  {-V,--version}'[print version]'
  '-o[read-only mount]'
  '-o[panic dump core on error]'
  '-o[minix-style df]'
  '-o[do not include default fuse options]'
  '-o[2fs_debug enable fuse2fs debugging]'
  '*:filename:_files'
)

_arguments -s -S $arguments
