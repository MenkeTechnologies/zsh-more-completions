#compdef proto

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'activate:activate proto for the current shell'
  'alias:manage tool version aliases'
  'bin:display the absolute path to a tools binary'
  'clean:clean stale tools, plugins, and temporary files'
  'completions:generate shell completions'
  'deactivate:deactivate proto for the current shell'
  'diagnose:diagnose potential issues with proto'
  'install:install a tool'
  'install-global:install a global package'
  'list:list installed versions of a tool'
  'list-global:list installed global packages'
  'list-remote:list available remote versions of a tool'
  'outdated:check if configured tools have newer versions'
  'pin:pin a global or local version of a tool'
  'plugin:manage tool plugins'
  'regen:regenerate shims'
  'run:run a tool after ensuring it is installed'
  'setup:setup proto for your current shell'
  'status:display tools and their configured versions'
  'unalias:remove a version alias'
  'uninstall:uninstall a tool'
  'uninstall-global:uninstall a global package'
  'unpin:remove a pinned version of a tool'
  'upgrade:upgrade proto to the latest version'
  'use:install all tools from .prototools'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--log=[log level]:level:(off error warn info debug trace)' \
  '--dump[dump a trace profile]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'proto command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (install)
        _arguments -s -S \
          '--pin[pin the version after installing]' \
          '--canary[install a canary version]' \
          '1:tool:(bun deno go node npm pnpm python ruby rust yarn)' \
          '2:version' && ret=0
        ;;
      (uninstall)
        _arguments -s -S \
          '--yes[skip confirmation]' \
          '1:tool:(bun deno go node npm pnpm python ruby rust yarn)' \
          '2:version' && ret=0
        ;;
      (list|list-remote)
        _arguments '1:tool:(bun deno go node npm pnpm python ruby rust yarn)' && ret=0
        ;;
      (pin)
        _arguments -s -S \
          '--global[pin globally]' \
          '--resolve[resolve the version before pinning]' \
          '1:tool:(bun deno go node npm pnpm python ruby rust yarn)' \
          '2:version' && ret=0
        ;;
      (run)
        _arguments -s -S \
          '--alt[use an alternative binary]' \
          '1:tool:(bun deno go node npm pnpm python ruby rust yarn)' \
          '*:args' && ret=0
        ;;
      (plugin)
        local -a plugin_cmds=(
          'add:add a plugin'
          'info:display information about a plugin'
          'list:list all configured plugins'
          'remove:remove a plugin'
          'search:search for available plugins'
        )
        _arguments \
          '1:subcommand:_describe -t plugin-commands "plugin command" plugin_cmds' \
          '*:args' && ret=0
        ;;
      (alias)
        _arguments -s -S \
          '1:tool:(bun deno go node npm pnpm python ruby rust yarn)' \
          '2:alias name' \
          '3:version' && ret=0
        ;;
    esac
    ;;
esac

return ret
