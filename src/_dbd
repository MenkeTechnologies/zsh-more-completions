#compdef dbd
# Documentation: https://man.archlinux.org/search?q=dbd
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-d[dump CNID database]'
  '-s[scan volume]'
  '-n[do not open CNID database, skip CNID checks]'
  '-r[rebuild volume]'
  '-f[wipe database and rebuild from IDs stored in AppleDouble]'
  '-u[opens the database which triggers any necessary upgrades]'
  '-e[work on inactive volumes and lock them (exclusive)]'
  '-x[rebuild indexes (just for completeness, mostly useless!)]'
  '-t[show statistics while running]'
  '-v[verbose output]'
  '*:filename:_files'
)

_arguments -s -S $arguments
