#compdef clamd
# Documentation: https://man.archlinux.org/search?q=clamd
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {--help,-h}'[show this help]'
  {--version,-V}'[show version number]'
  '--debug[enable debug mode]'
  {--config-file,-c}'[read configuration from FILE]'
  '*:filename:_files'
)

_arguments -s -S $arguments
