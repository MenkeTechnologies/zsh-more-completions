#compdef route

# Zsh completion for route (supports both Linux and macOS/BSD variants)

_route() {
    local curcontext="$curcontext" state line ret=1

    if [[ "$OSTYPE" == darwin* || "$OSTYPE" == freebsd* || "$OSTYPE" == openbsd* ]]; then
        # macOS / BSD variant
        _arguments -s -S \
            '-d[debug-only mode, do not modify routing table]' \
            '-n[do not resolve names, show addresses numerically]' \
            '-q[suppress all output]' \
            '-t[test-only mode, use /dev/null instead of socket]' \
            '-v[verbose, print additional details]' \
            '1:command:->commands' \
            '*:arguments:->args' \
            && ret=0

        case $state in
            commands)
                local -a commands
                commands=(
                    'add:add a route'
                    'flush:remove all routes'
                    'delete:delete a specific route'
                    'change:change aspects of a route'
                    'get:lookup and display the route for a destination'
                    'monitor:continuously report routing changes'
                )
                _describe -t commands 'route command' commands && ret=0
                ;;
            args)
                local -a modifiers
                modifiers=(
                    '-net:interpret destination as a network'
                    '-host:interpret destination as a host'
                    '-inet:use IPv4 address family'
                    '-inet6:use IPv6 address family'
                    '-link:subsequent addresses are link-level'
                    '-ifscope:scope the route to a specific interface'
                    '-interface:destination is directly reachable'
                    '-netmask:specify network mask'
                    '-prefixlen:specify prefix length for IPv6'
                    '-gateway:force route through a gateway'
                    '-cloning:generate a new route on use'
                    '-xresolve:emit message on use for external lookup'
                    '-iface:destination is directly reachable'
                    '-static:manually added route'
                    '-nostatic:pretend route added by kernel or daemon'
                    '-reject:emit ICMP unreachable when matched'
                    '-blackhole:silently discard packets'
                    '-proto1:set protocol specific routing flag 1'
                    '-proto2:set protocol specific routing flag 2'
                    '-llinfo:translates protocol addr to link addr'
                    '-proxy:published proxy-only ARP entry'
                    '-lock:lock the next metric modifier'
                    '-lockrest:lock all ensuing metric modifiers'
                    '-rtt:specify initial round trip time'
                    '-rttvar:specify initial round trip time variance'
                    '-sendpipe:specify initial send pipe size'
                    '-recvpipe:specify initial receive pipe size'
                    '-mtu:specify initial maximum transmission unit'
                    '-hopcount:specify initial hop count'
                    '-expire:specify expiration time'
                    '-ssthresh:specify initial slow start threshold'
                    '-ifindex:limit monitor to interface index or name'
                )
                _describe -t modifiers 'route modifier' modifiers && ret=0
                _arguments '*:host:_hosts' && ret=0
                ;;
        esac
    else
        # Linux variant
        _arguments -s -S \
            {-v,--verbose}'[be verbose]' \
            {-n,--numeric}'[do not resolve names]' \
            {-e,--extend}'[display other/more information]' \
            {-F,--fib}'[display Forwarding Information Base (default)]' \
            {-C,--cache}'[display routing cache instead of FIB]' \
            '(- *)'{-h,--help}'[display help information]' \
            '(- *)'{-V,--version}'[display version information]' \
            '-A[use specified address family]:address family:(inet inet6 ax25 netrom ipx ddp)' \
            '-4[use IPv4]' \
            '-6[use IPv6]' \
            '1:command:->commands' \
            '*:arguments:->args' \
            && ret=0

        case $state in
            commands)
                local -a commands
                commands=(
                    'add:add a new route'
                    'del:delete a route'
                    'flush:remove all routes'
                )
                _describe -t commands 'route command' commands && ret=0
                ;;
            args)
                local -a modifiers
                modifiers=(
                    '-net:route to a network'
                    '-host:route to a host'
                    'netmask:specify subnet mask'
                    'gw:specify gateway'
                    'metric:set the metric field'
                    'mss:set TCP Maximum Segment Size'
                    'window:set TCP window size'
                    'irtt:set initial round trip time'
                    'reject:install a blocking route'
                    'mod:restore a modified dynamic route'
                    'dyn:install a dynamic route'
                    'reinstate:reinstate route after timeout'
                    'dev:force the route through named device'
                )
                _describe -t modifiers 'route modifier' modifiers && ret=0
                _arguments '*:host:_hosts' && ret=0
                ;;
        esac
    fi

    return ret
}

_route "$@"
