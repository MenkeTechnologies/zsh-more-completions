#compdef newfs_hfs

local -a arguments

arguments=(
  '-N[do not create file system, just print out parameters]'
  '-s[use case-sensitive filenames (default is case-insensitive)]'
  '-J[make this HFS+ volume journaled]'
  '-D[use journal-dev for an external journal]:device:'
  '-G[group ID for root directory]:gid:'
  '-U[user ID for root directory]:uid:'
  '-M[access mask for root directory]:mask:'
  '-b[block size (4096 optimal)]:size:'
  '-c[clump size list (comma separated)]:sizes:'
  '-i[starting catalog node id]:id:'
  '-I[initial size list (comma separated)]:sizes:'
  '-n[node size list (comma separated)]:sizes:'
  '-v[volume name (in ascii or UTF-8)]:name:'
  '*:filename:_files'
)

_arguments -s -S $arguments
