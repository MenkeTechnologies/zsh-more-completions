#compdef kde-cp
# Documentation: https://man.archlinux.org/search?q=kde-cp
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--help[show help about options]'
  '--help-kde-tempfile[show KDE-tempfile specific options]'
  '--help-all[show all options]'
  '--author[show author information]'
  {-v,--version}'[show version information]'
  '--license[show license information]'
  '--noninteractive[non-interactive use: no message boxes]'
  '--overwrite[overwrite destination if it exists (for copy and move)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
