#compdef respberry
# Documentation: https://man.archlinux.org/search?q=respberry
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-V,--version}'[output the version number]'
  '-c[connect    (on Mac/PC) scan and connect to Pi]'
  '-p[panel      (on Pi) start or stop your panel]'
  '-w[wifi       (on Pi) scan wifi, list them , and connect to it.]'
  {-h,--help}'[display help for command]'
  '*:filename:_files'
)

_arguments -s -S $arguments
