#compdef govulncheck

_arguments -s -S \
  '-C[change to directory before running]:dir:_directories' \
  '-db[vulnerability database URL]:url:' \
  '-format[output format]:format:(text json sarif openvex)' \
  '-mode[analysis mode]:mode:(source binary extract)' \
  '-scan[scan level]:level:(module package symbol)' \
  '-show[output options]:options:(verbose traces color)' \
  '-tags[build tags]:tags:' \
  '-test[include test binaries]' \
  '-version[show version]' \
  '-help[show help]' \
  '*:package or binary:_files'
