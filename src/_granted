#compdef granted assume

local curcontext="$curcontext" state line ret=1

if [[ $service == assume ]]; then
  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show help]' \
    '--version[show version]' \
    '1:AWS profile:->profiles' && ret=0

  case $state in
    (profiles)
      local -a aws_profiles
      if [[ -f ~/.aws/config ]]; then
        aws_profiles=(${(f)"$(sed -n 's/^\[profile \(.*\)\]/\1/p' ~/.aws/config 2>/dev/null)"})
      fi
      _describe -t profiles 'AWS profile' aws_profiles && ret=0
      ;;
  esac
  return ret
fi

local -a subcommands=(
  'browser:manage the browser granted uses to open cloud consoles'
  'console:open the AWS console for a profile'
  'credential-process:manage credential process integration'
  'credentials:manage AWS credentials'
  'profile:manage profiles'
  'registry:manage profile registries'
  'settings:manage granted settings'
  'sso:manage AWS SSO'
  'token:manage tokens'
  'uninstall:uninstall granted'
  'version:show version'
  'completion:generate shell completions'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:subcommand:->subcommand' \
  '*::: :->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (browser)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--set[set the browser]:browser:(firefox chrome chromium brave edge arc safari stdout firefoxstdpath waterfox custom)' \
          '--path[set the browser path]:path:_files' && ret=0
        ;;
      (credentials)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--export[export credentials]' \
          '--exec[execute a command with credentials]' \
          '--exec-cmd[command to execute]:command:_command_names' \
          '--exec-args[arguments for the command]:args:' \
          '--unset[unset credentials]' && ret=0
        ;;
      (sso)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--sso-start-url[SSO start URL]:url:' \
          '--sso-region[SSO region]:region:' \
          '--sso-scope[SSO scope]:scope:' \
          '--prefix[profile prefix]:prefix:' && ret=0
        ;;
      (console|credential-process|profile|registry|settings|token|uninstall|version|completion)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
