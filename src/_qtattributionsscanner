#compdef qtattributionsscanner

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[displays help on commandline options.]'
  '--help-all[displays help including Qt specific options.]'
  {-v,--version}'[displays version information.]'
  '--output-format[output format ("qdoc", "json").]'
  '--input-files[input files ("qt_attributions" scans for qt_attribution.json files)]'
  '--filter[filter packages according to filter expression]'
  '--basedir[paths in documentation are made relative to this directory]'
  {-o,--output}'[write generated data to <file>.]'
  '--verbose[verbose output.]'
  {-s,--silent}'[minimal output.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
