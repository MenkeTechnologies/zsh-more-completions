#compdef snapfuse
# Documentation: https://man.archlinux.org/search?q=snapfuse
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-d,-o}'[enable debug output (implies -f)]'
  '-f[foreground operation]'
  '-s[disable multi-threaded operation]'
  '*:filename:_files'
)

_arguments -s -S $arguments
