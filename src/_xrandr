#compdef xrandr

local -a arguments

arguments=(
  {-d,--display}'[specify X display]:display:'
  '(- * :)--help[display help]'
  '-o[set orientation]:orientation:(normal inverted left right 0 1 2 3)'
  {-q,--query}'[query current settings]'
  {-s,--size}'[set screen size]:size:'
  {-r,--rate,--refresh}'[set refresh rate]:rate:'
  {-v,--version}'[display version]'
  '-x[reflect in x]'
  '-y[reflect in y]'
  '--screen[select screen]:screen:'
  '--verbose[be more verbose]'
  '--current[show current settings only]'
  '--dryrun[make no changes]'
  '--nograb[do not grab the server]'
  {--prop,--properties}'[show output properties]'
  '--fb[set framebuffer size]:WxH:'
  '--fbmm[set framebuffer physical size]:WxH:'
  '--dpi[set DPI]:dpi:'
  '--output[select output]:output:'
  '--auto[enable auto mode for output]'
  '--mode[set mode]:mode:'
  '--preferred[use preferred mode]'
  '--pos[set position]:position:'
  '--reflect[set reflection]:direction:(normal x y xy)'
  '--rotate[set rotation]:direction:(normal inverted left right)'
  '--left-of[position left of output]:output:'
  '--right-of[position right of output]:output:'
  '--above[position above output]:output:'
  '--below[position below output]:output:'
  '--same-as[position same as output]:output:'
  '--set[set output property]:property: :value:'
  '--scale[set output scaling]:WxH:'
  '--scale-from[set output scaling from size]:WxH:'
  '--transform[set output transformation matrix]:a,b,c,d,e,f,g,h,i:'
  '--filter[set scaling filter]:filter:(bilinear nearest)'
  '--off[disable output]'
  '--crtc[set CRTC]:crtc:'
  '--panning[set panning]:WxH+X+Y:'
  '--gamma[set gamma correction]:R:G:B:'
  '--brightness[set brightness]:brightness:'
  '--primary[set output as primary]'
  '--noprimary[unset primary output]'
  '--newmode[add a new mode]:name: :clock: :params:'
  '--rmmode[remove a mode]:mode:'
  '--addmode[add a mode to an output]:output: :mode:'
  '--delmode[delete a mode from an output]:output: :mode:'
  '--listproviders[list providers]'
  '--setprovideroutputsource[set provider output source]:provider: :source:'
  '--setprovideroffloadsink[set provider offload sink]:provider: :sink:'
  '--listmonitors[list monitors]'
  '--listactivemonitors[list active monitors]'
  '--setmonitor[define a monitor]:name: :geometry: :outputs:'
  '--delmonitor[delete a monitor]:name:'
  '*:filename:_files'
)

_arguments -s -S $arguments
