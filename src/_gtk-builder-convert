#compdef gtk-builder-convert

local -a arguments

arguments=(
  {-w,--skip-windows}'[convert everything but GtkWindow subclasses.]'
  {-r,--root}'[convert only widget named root and its children]'
  '(- * :)'{-h,--help}'[display this help and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
