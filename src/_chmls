#compdef chmls
# Documentation: https://man.archlinux.org/search?q=chmls
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[this screen]'
  {-p,--no-page}'[do not page list output]'
  {-n,--name-only}'[only show "name" column in list output]'
  '*:filename:_files'
)

_arguments -s -S $arguments
