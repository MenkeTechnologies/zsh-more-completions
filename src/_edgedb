#compdef edgedb

# Zsh completion for EdgeDB CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'database:manage databases'
  'branch:manage branches'
  'describe:describe database objects'
  'dump:create a database backup'
  'restore:restore a database backup'
  'configure:modify server configuration'
  'info:show information about an EdgeDB installation'
  'project:manage project'
  'instance:manage instances'
  'query:execute EdgeQL queries'
  'list:list database objects'
  'migrate:run migrations'
  'migration:manage migrations'
  'watch:watch for schema changes and apply migrations'
  'ui:open the web UI'
  'cloud:manage EdgeDB Cloud'
  'cli:manage the CLI'
)

_arguments -s -S \
  '(-I --instance)'{-I,--instance}'[instance name]:instance:' \
  '(-d --database)'{-d,--database}'[database name]:database:' \
  '--dsn[DSN for connection]:dsn:' \
  '--host[host]:host:_hosts' \
  '--port[port]:port:' \
  '--user[user]:user:' \
  '--password[prompt for password]' \
  '--password-from-stdin[read password from stdin]' \
  '--tls-ca-file[TLS CA certificate]:file:_files' \
  '--tls-security[TLS security mode]:mode:(default insecure no_host_verification strict)' \
  '--wait-until-available[wait for connection]:timeout:' \
  '--connect-timeout[connection timeout]:timeout:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'edgedb command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (query)
        _arguments \
          '--output-format[output format]:format:(json json-pretty tab-separated)' \
          '--file[read query from file]:file:_files' \
          '*:query:' && ret=0
        ;;
      (migrate|migration)
        local -a mig_cmds=('apply:apply migrations' 'create:create a migration' 'edit:edit a migration' 'log:show migration history' 'status:show migration status')
        _arguments '1:migration command:((${(j: :)${mig_cmds// /\\:}}))' '*:args:' && ret=0
        ;;
      (instance)
        local -a inst_cmds=(
          'create:create an instance'
          'destroy:destroy an instance'
          'link:link a remote instance'
          'list:list instances'
          'logs:show instance logs'
          'restart:restart an instance'
          'revert:revert to a previous version'
          'start:start an instance'
          'status:show instance status'
          'stop:stop an instance'
          'unlink:unlink a remote instance'
          'upgrade:upgrade an instance'
        )
        _arguments '1:instance command:((${(j: :)${inst_cmds// /\\:}}))' '*:args:' && ret=0
        ;;
      (project)
        local -a proj_cmds=('info:show project info' 'init:initialize a project' 'unlink:unlink project')
        _arguments '1:project command:((${(j: :)${proj_cmds// /\\:}}))' '*:args:' && ret=0
        ;;
      (dump)
        _arguments \
          '--all[dump all databases]' \
          '--format[dump format]:format:(dir)' \
          '1:output file:_files' && ret=0
        ;;
      (restore)
        _arguments \
          '--all[restore all databases]' \
          '1:input file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
