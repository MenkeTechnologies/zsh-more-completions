#compdef kismet_eventbus
# Documentation: https://man.archlinux.org/search?q=kismet_eventbus
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[show this help message and exit]'
  '--in-fd[input file descriptor]:fd:'
  '--out-fd[output file descriptor]:fd:'
  '*:filename:_files'
)

_arguments -s -S $arguments
