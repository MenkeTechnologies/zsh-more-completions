#compdef mwmail
# Documentation: https://man.archlinux.org/search?q=mwmail
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-c[file]'
  '-s[subject]'
  '-p[port]'
  '-i[(PEI generated by this manipulator)]'
  '-l[all log in the screen]'
  '-h[help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
