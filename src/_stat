#compdef stat gstat

# Zsh completion for stat (GNU coreutils and BSD/macOS)

_stat() {
  local -a bsd_args gnu_args

  # BSD/macOS stat options
  bsd_args=(
    '-F[display type indicator (like ls -F), implies -l]'
    '-L[use stat(2) instead of lstat(2), follow symbolic links]'
    '-n[do not force a newline at the end of each output piece]'
    '-q[suppress failure messages for stat/lstat calls]'
    '(-l -r -s -x)-f+[display information using specified format string]:format string'
    '(-f -r -s -x)-l[display output in ls -lT format]'
    '(-f -l -s -x)-r[display raw information (numerical values)]'
    '(-f -l -r -x)-s[display information in shell output format]'
    '(-f -l -r -s)-x[display information in verbose Linux-style format]'
    '-t+[display timestamps using specified strftime format]:time format'
    '*:file:_files'
  )

  # GNU coreutils stat options
  gnu_args=(
    {-L,--dereference}'[follow links]'
    {-f,--file-system}'[display file system status instead of file status]'
    '--cached=[specify how to use cached attributes]:mode:(always never default)'
    {-c,--format=}'[use the specified FORMAT instead of the default]:format string'
    '--printf=[like --format, but interpret backslash escapes]:format string'
    {-t,--terse}'[print the information in terse form]'
    '--help[display help and exit]'
    '--version[output version information and exit]'
    '*:file:_files'
  )

  case "$service" in
    gstat)
      _arguments -s -S $gnu_args
      ;;
    stat)
      case "$OSTYPE" in
        darwin*|freebsd*|openbsd*|netbsd*|dragonfly*)
          _arguments -s -S $bsd_args
          ;;
        *)
          _arguments -s -S $gnu_args
          ;;
      esac
      ;;
  esac
}

_stat "$@"
