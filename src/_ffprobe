#compdef ffprobe

# Zsh completion for ffprobe (FFmpeg multimedia stream analyzer)

_ffprobe_formats() {
  local -a formats
  formats=(${(f)"$(ffprobe -formats 2>/dev/null | awk '/^ [D ]/ {print $2}' | sort -u)"})
  _describe -t formats 'format' formats
}

_ffprobe_decoders() {
  local -a decoders
  decoders=(${(f)"$(ffprobe -decoders 2>/dev/null | awk 'NR>10 && /^ [^ ]/ {print $2}')"})
  _describe -t decoders 'decoder' decoders
}

