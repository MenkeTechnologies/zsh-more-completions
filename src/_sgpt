#compdef sgpt

local -a arguments

arguments=(
  '--model[model name]:model:'
  '--temperature[sampling temperature (0.0-2.0)]:temperature:'
  '--top-p[nucleus sampling (0.0-1.0)]:top_p:'
  '--max-tokens[maximum number of tokens]:tokens:'
  '(-s --shell)'{-s,--shell}'[generate shell command]'
  '(-d --describe-shell)'{-d,--describe-shell}'[describe shell command]'
  '(-c --code)'{-c,--code}'[generate code]'
  '(-e --editor)'{-e,--editor}'[open editor for input]'
  '--cache[enable cache]'
  '--no-cache[disable cache]'
  '--repl[start REPL session]:session name:'
  '--chat[continue named chat]:chat name:'
  '--role[role name]:role:'
  '--list-roles[list available roles]'
  '--create-role[create a new role]:role name:'
  '--show-role[show role definition]:role name:'
  '--install-integration[install shell integration]'
  '*:query:'
)

_arguments -s -S $arguments
