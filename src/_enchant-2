#compdef enchant-2
# Documentation: https://man.archlinux.org/search?q=enchant-2
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-a[suggestions in ispell pipe mode format]'
  '-d[uses the given dictionary]'
  '-h[this help message]'
  '-l[misspellings]'
  '-L[line numbers]'
  '-v[program version.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
