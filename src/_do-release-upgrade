#compdef do-release-upgrade

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-V,--version}'[show version and exit]'
  {-d,--devel-release}'[if using the latest supported release, upgrade to the development release]'
  '--data-dir[directory that contains the data files]'
  {-p,--proposed}'[try upgrading to the latest release using the upgrader from proposed]'
  {-m,--mode}'[run in a special upgrade mode (desktop or server)]:mode'
  {-f,--frontend}'[run the specified frontend]'
  {-c,--check-dist-upgrade-only}'[check only if a new distribution release is available]'
  {-q,--quiet}'[quiet mode, suppress output]'
  '*:filename:_files'
)

_arguments -s -S $arguments
