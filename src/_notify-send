#compdef notify-send

# Zsh completion for notify-send - send desktop notifications
# Covers both libnotify (notify-send) and notify-send.sh extensions

_arguments -s -S \
  {-u,--urgency=}'[set the urgency level]:urgency level:(low normal critical)' \
  {-t,--expire-time=}'[timeout in milliseconds at which to expire the notification]:time in ms' \
  {-a,--app-name=}'[specifies the app name for the notification]:app name' \
  {-i,--icon=}'[specifies an icon filename or stock icon to display]:icon:_files' \
  {-c,--category=}'[specifies the notification category]:category' \
  '*'{-h,--hint=}'[specifies extra data to pass (TYPE\:NAME\:VALUE)]:hint (type\:name\:value)' \
  '*'{-A,--action=}'[specifies an action (ID=Text or just Text)]:action' \
  {-e,--transient}'[show a transient notification]' \
  {-w,--wait}'[wait for the notification to be closed]' \
  {-p,--print-id}'[print the notification ID]' \
  {-r,--replace-id=}'[the ID of the notification to replace]:notification ID' \
  '(- * :)'{-v,--version}'[show the version of the package]' \
  '(- * :)'{-\?,--help}'[show help options]' \
  '(- * :)--help-all[show all help options]' \
  '1:summary (title)' \
  '2::body (message)'
