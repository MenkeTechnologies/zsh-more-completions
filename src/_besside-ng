#compdef besside-ng
# Documentation: https://man.archlinux.org/search?q=besside-ng
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-b[victim BSSID]:mac:'
  '-R[victim ESSID regex]:regex:'
  '-s[upload wpa.cap for cracking]:server:'
  '-c[channel lock]:channel:'
  '-p[flood rate]:pps:'
  '-W[WPA only]'
  '-v[verbose, -vv for more]'
  '-h[show this help screen]'
  '*:filename:_files'
)

_arguments -s -S $arguments
