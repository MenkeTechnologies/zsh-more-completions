#compdef cadaver
# Documentation: https://man.archlinux.org/search?q=cadaver
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-t,--tolerant}'[allow cd/open into non-WebDAV enabled collection.]'
  {-r,--rcfile}'[read script from FILE instead of ~/.cadaverrc]:file:_files'
  {-p,--proxy}'[use proxy host PROXY and optional proxy port PORT]:proxy:'
  {-V,--version}'[display version information.]'
  '(- * :)'{-h,--help}'[display this help message.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
