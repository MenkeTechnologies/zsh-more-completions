#compdef iptables iptables-save iptables-restore ip6tables ip6tables-save ip6tables-restore

# Zsh completion for iptables/ip6tables (netfilter)

local curcontext="$curcontext" state line
typeset -A opt_args

local -a chains targets protocols tables

chains=(INPUT OUTPUT FORWARD PREROUTING POSTROUTING)
targets=(ACCEPT DROP RETURN REJECT LOG MASQUERADE SNAT DNAT REDIRECT MARK QUEUE NFQUEUE NFLOG CONNMARK TPROXY TEE CLASSIFY IDLETIMER CHECKSUM CT NOTRACK SECMARK CONNSECMARK TCPMSS TCPOPTSTRIP TOS DSCP ECN TTL HL SET AUDIT TRACE)
protocols=(tcp udp udplite icmp icmpv6 esp ah sctp mh all)
tables=(filter nat mangle raw security)

local -a arguments
arguments=(
  # Commands (mutually exclusive)
  '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-A,--append}'[append rule to end of chain]:chain:($chains)' \
  '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-C,--check}'[check if rule exists in chain]:chain:($chains)' \
  '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-D,--delete}'[delete rule from chain]:chain:($chains)' \
  '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-I,--insert}'[insert rule in chain at position]:chain:($chains)' \
  '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-R,--replace}'[replace rule in chain at position]:chain:($chains)' \
  '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-L,--list}'[list all rules in chain]:chain:($chains)' \
  '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-S,--list-rules}'[print all rules in chain]:chain:($chains)' \
  '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-F,--flush}'[flush all rules in chain]:chain:($chains)' \
  '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-Z,--zero}'[zero packet and byte counters]:chain:($chains)' \
  '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-N,--new-chain}'[create a new user-defined chain]:chain name:' \
  '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-X,--delete-chain}'[delete a user-defined chain]:chain:' \
  '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-P,--policy}'[set policy for built-in chain]:chain:(INPUT OUTPUT FORWARD PREROUTING POSTROUTING):target:(ACCEPT DROP RETURN)' \
  '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-E,--rename-chain}'[rename a user-defined chain]:old chain name: :new chain name:' \

  # Table selection
  {-t,--table}'[table to manipulate]:table:($tables)' \

  # Match parameters
  {-p,--protocol}'[protocol to match]:protocol:($protocols)' \
  '*'{-s,--source}'[source address specification]:source address/mask:_hosts' \
  '*'{-d,--destination}'[destination address specification]:destination address/mask:_hosts' \
  {-i,--in-interface}'[name of input interface]:interface:_net_interfaces' \
  {-o,--out-interface}'[name of output interface]:interface:_net_interfaces' \
  {-f,--fragment}'[match second or further fragments only]' \

  # Target
  {-j,--jump}'[target for rule]:target:($targets)' \
  {-g,--goto}'[jump to chain with no return]:chain:' \

  # Match extensions
  '*'{-m,--match}'[extended match module]:match:(addrtype ah bpf cgroup cluster comment connbytes connlabel connlimit connmark conntrack cpu dccp devgroup dscp ecn esp eui64 frag hashlimit hbh helper hl icmp icmp6 iprange ipvs length limit mac mark mh multiport nfacct osf owner physdev pkttype policy quota quota2 rateest realm recent rpfilter rt sctp set socket state statistic string tcp tcpmss time tos ttl u32 udp unclean)' \

  # Counter initialization
  {-c,--set-counters}'[set packet and byte counters]:packets: :bytes:' \

  # Display options
  {-v,--verbose}'[verbose mode]' \
  {-n,--numeric}'[numeric output of addresses and ports]' \
  {-x,--exact}'[expand numbers (display exact values)]' \
  '--line-numbers[print line numbers when listing rules]' \

  # Protocol family
  '(-4 --ipv4 -6 --ipv6)'{-4,--ipv4}'[use IPv4 (ignored by ip6tables-restore)]' \
  '(-4 --ipv4 -6 --ipv6)'{-6,--ipv6}'[use IPv6 (ignored by iptables-restore)]' \

  # Lock and wait
  {-w,--wait}'[wait for xtables lock]:seconds:' \
  {-W,--wait-interval}'[wait interval to acquire xtables lock]:microseconds:' \

  # Miscellaneous
  '--modprobe=[module loading command]:command:_command_names' \
  '--compat[attach compatibility data for older parsing]' \
  {-V,--version}'[print version information]' \
  {-h,--help}'[display help message]' \

  # Common match extension options (frequently used)
  '--sport[source port or range]:port or range:' \
  '--dport[destination port or range]:port or range:' \
  '--sports[source port or range (synonym)]:port or range:' \
  '--dports[destination port or range (synonym)]:port or range:' \
  '--state[connection tracking state]:state:(NEW ESTABLISHED RELATED INVALID UNTRACKED)' \
  '--ctstate[connection tracking state]:state:(NEW ESTABLISHED RELATED INVALID UNTRACKED SNAT DNAT)' \
  '--to-destination[DNAT target address]:address\:port:' \
  '--to-source[SNAT source address]:address\:port:' \
  '--to-ports[redirect target ports]:port or range:' \
  '--comment[add a comment to the rule]:comment:' \
  '--log-prefix[prefix for log messages]:prefix:' \
  '--log-level[syslog level for LOG target]:level:(emerg alert crit error warning notice info debug)' \
  '--reject-with[REJECT response type]:type:(icmp-net-unreachable icmp-host-unreachable icmp-port-unreachable icmp-proto-unreachable icmp-net-prohibited icmp-host-prohibited icmp-admin-prohibited tcp-reset)' \
  '--limit[rate limit]:rate:' \
  '--limit-burst[rate limit burst]:number:' \
  '--mac-source[match source MAC address]:MAC address:' \
  '--icmp-type[ICMP type]:type:' \
  '--tcp-flags[match TCP flags]:flags to examine: :flags to match:' \
  '--syn[match SYN packets (shorthand for --tcp-flags SYN,RST,ACK,FIN SYN)]' \
  '--set-mark[set nfmark value]:mark:' \
  '--set-xmark[set xmark value]:mark:' \
  '--uid-owner[match owner UID]:uid:_users' \
  '--gid-owner[match owner GID]:gid:_groups' \
  '--connlimit-above[match if number of connections above]:number:' \
  '--connlimit-mask[group hosts using prefix length]:prefix length:' \
  '--hashlimit-upto[match if rate is below]:rate:' \
  '--hashlimit-above[match if rate is above]:rate:' \
  '--hashlimit-name[name for /proc/net/ipt_hashlimit]:name:' \
)

_arguments -s -S $arguments
