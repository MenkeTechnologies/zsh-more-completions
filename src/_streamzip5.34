#compdef streamzip5.34
# Documentation: https://man.archlinux.org/search?q=streamzip5.34
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-zipfile[write zip container to the filename F]'
  '-member-name[set member name to M \[Default -\]]'
  '-0[-9       Set compression level for Deflate]'
  '-zip64[create a Zip64-compliant zip file \[Default: No\]]'
  '-stream[force a streamed zip file when zipfile option is also enabled.]'
  '-method[compress using method M.]'
  '-version[display version number \[1.002\]]'
  '*:filename:_files'
)

_arguments -s -S $arguments
