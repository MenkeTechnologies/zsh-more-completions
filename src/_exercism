#compdef exercism

# Zsh completion for exercism (Exercism.io CLI for coding exercises)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a global_opts=(
  '(-h --help)'{-h,--help}'[show help]'
  '(-v --verbose)'{-v,--verbose}'[turn on verbose logging]'
)

local -a subcommands=(
  'configure:configure the exercism client'
  'download:download an exercise'
  'open:open an exercise in the browser'
  'submit:submit a solution to an exercise'
  'troubleshoot:troubleshoot the exercism client'
  'upgrade:upgrade to the latest version of the CLI'
  'workspace:print the path to the exercism workspace'
  'version:print the version of the CLI'
  'completion:generate shell completion scripts'
  'help:show help for a command'
)

_arguments -s -S -C \
  $global_opts \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t subcommands 'exercism command' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      configure)
        _arguments -s -S \
          $global_opts \
          '(-t --token)'{-t,--token}'[set the API token]:token:' \
          '(-w --workspace)'{-w,--workspace}'[set the workspace directory]:dir:_directories' \
          '(-a --api)'{-a,--api}'[set the API base URL]:url:' \
          '(-s --show)'{-s,--show}'[show the current configuration]' && ret=0
        ;;
      download)
        _arguments -s -S \
          $global_opts \
          '(-e --exercise)'{-e,--exercise}'[the exercise slug]:exercise:' \
          '(-t --track)'{-t,--track}'[the track ID]:track:' \
          '--uuid[the solution UUID]:uuid:' \
          '--team[the team slug]:team:' \
          '(-f --force)'{-f,--force}'[overwrite existing exercise]' && ret=0
        ;;
      submit)
        _arguments -s -S \
          $global_opts \
          '*:file:_files' && ret=0
        ;;
      open)
        _arguments -s -S $global_opts && ret=0
        ;;
      troubleshoot)
        _arguments -s -S \
          $global_opts \
          '--full-api-key[display the full API key]' && ret=0
        ;;
      upgrade)
        _arguments -s -S $global_opts && ret=0
        ;;
      workspace)
        _arguments -s -S $global_opts && ret=0
        ;;
      version)
        _arguments -s -S $global_opts && ret=0
        ;;
      completion)
        _arguments -s -S \
          $global_opts \
          '1:shell:(bash zsh fish)' && ret=0
        ;;
      help)
        _arguments -s -S \
          '1:command:(configure download open submit troubleshoot upgrade workspace version completion)' && ret=0
        ;;
    esac
    ;;
esac

return ret
