#compdef fstrim

local -a arguments

arguments=(
  {-a,--all}'[trim all mounted filesystems that are supported]'
  {-o,--offset}'[the offset in bytes to start discarding from]:offset:'
  {-l,--length}'[the number of bytes to discard]:length:'
  {-m,--minimum}'[the minimum extent length to discard]:minimum:'
  {-v,--verbose}'[print number of discarded bytes]'
  '(- * :)'{-h,--help}'[display this help]'
  {-V,--version}'[display version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
