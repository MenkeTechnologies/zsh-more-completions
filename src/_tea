#compdef tea

# Zsh completion for tea (Gitea CLI)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'comment:add a comment to an issue or PR'
  'issues:manage issues (alias: issue, i)'
  'labels:manage labels'
  'login:log in to a Gitea server'
  'logout:log out from a Gitea server'
  'milestones:manage milestones (alias: milestone, ms)'
  'notifications:manage notifications (alias: notification, n)'
  'organizations:manage organizations (alias: organization, org)'
  'pulls:manage pull requests (alias: pull, pr)'
  'releases:manage releases (alias: release, r)'
  'repos:manage repositories (alias: repo)'
  'times:manage tracked time'
  'whoami:show logged-in user info'
)

_arguments -s -S \
  '--login[use a specific login]:login:' \
  '--repo[repository]:owner/repo:' \
  '--remote[remote name]:remote:' \
  '--output[output format]:format:(simple table csv tsv yaml json)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'tea command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (issues|issue|i)
        local -a issue_cmds=('close:close an issue' 'create:create an issue' 'edit:edit an issue' 'list:list issues' 'reopen:reopen an issue')
        _arguments '1:issue command:((${(j: :)${issue_cmds// /\\:}}))' '*:args:' && ret=0
        ;;
      (pulls|pull|pr)
        local -a pr_cmds=('checkout:checkout a PR' 'clean:clean PR branch' 'close:close a PR' 'create:create a PR' 'list:list PRs' 'merge:merge a PR' 'reopen:reopen a PR' 'review:review a PR')
        _arguments '1:PR command:((${(j: :)${pr_cmds// /\\:}}))' '*:args:' && ret=0
        ;;
      (repos|repo)
        local -a repo_cmds=('browse:open in browser' 'clone:clone a repo' 'create:create a repo' 'create-from-template:create from template' 'delete:delete a repo' 'fork:fork a repo' 'list:list repos' 'search:search repos')
        _arguments '1:repo command:((${(j: :)${repo_cmds// /\\:}}))' '*:args:' && ret=0
        ;;
      (releases|release|r)
        local -a rel_cmds=('create:create a release' 'delete:delete a release' 'edit:edit a release' 'list:list releases')
        _arguments '1:release command:((${(j: :)${rel_cmds// /\\:}}))' '*:args:' && ret=0
        ;;
      (login)
        local -a login_cmds=('add:add a login' 'default:show default login' 'delete:delete a login' 'edit:edit a login' 'list:list logins')
        _arguments '1:login command:((${(j: :)${login_cmds// /\\:}}))' '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
