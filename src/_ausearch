#compdef ausearch

local -a arguments

arguments=(
  {-a,--event}'[search based on audit event id]:event id:'
  '--arch[search based on the CPU architecture]:arch:'
  {-c,--comm}'[search based on command line name]:Comm name:'
  '--checkpoint[search from last complete event]:file:_files'
  '--debug[write malformed events that are skipped to stderr]'
  {-e,--exit}'[search based on syscall exit code]:Exit code or errno:'
  {-f,--file}'[search based on file name]:File name:'
  {-ga,--gid-all}'[search based on all group ids]:group id:'
  {-ge,--gid-effective}'[search based on effective group id]:group id:'
  {-gi,--gid}'[search based on group id]:group id:'
  '(- * :)'{-h,--help}'[help]'
  {-hn,--host}'[search based on remote host name]:host name:'
  {-i,--interpret}'[interpret results to be human readable]'
  {-if,--input}'[use this file instead of current logs]:file name:_files'
  '--input-logs[use the logs even if stdin is a pipe]'
  '--just-one[emit just one event]'
  {-k,--key}'[search based on key field]:key string:'
  {-l,--line-buffered}'[flush output on every line]'
  {-m,--message}'[search based on message type]:Message type:'
  {-n,--node}'[search based on machines name]:Node name:'
  {-o,--object}'[search based on context of object]:SE Linux Object context:'
  {-p,--pid}'[search based on process id]:Process id:'
  {-pp,--ppid}'[search based on parent process id]:process id:'
  {-r,--raw}'[output is completely unformatted]'
  {-sc,--syscall}'[search based on syscall name or number]:syscall:'
  {-se,--context}'[search based on either subject or object context]:linux context:'
  '--session[search based on login session id]:session id:'
  {-su,--subject}'[search based on context of the subject]:linux context:'
  {-sv,--success}'[search based on syscall or event success value]:value:'
  {-te,--end}'[ending date and time for search]:end date time:'
  {-ts,--start}'[starting date and time for search]:start date time:'
  {-tm,--terminal}'[search based on terminal]:terminal:'
  {-ua,--uid-all}'[search based on all user ids]:user id:'
  {-ue,--uid-effective}'[search based on effective user id]:user id:'
  {-ui,--uid}'[search based on user id]:user id:'
  {-ul,--loginuid}'[search based on the users login id]:login id:'
  {-uu,--uuid}'[search for events related to the virtual machine UUID]:UUID:'
  {-v,--version}'[version]'
  {-vm,--vm-name}'[search for events related to the virtual machine name]:name:'
  {-w,--word}'[string matches are whole word]'
  {-x,--executable}'[search based on executable name]:name:'
  '*:filename:_files'
)

_arguments -s -S $arguments
