#compdef naabu

# Zsh completion for naabu - fast port scanning tool

_arguments -s -S \
  '(-host --host)--host[host to scan for ports]:host:_hosts' \
  '(-list --list)'{-list,-l}'[file containing list of hosts]:file:_files' \
  '(-port --port)'{-port,-p}'[ports to scan]:ports:' \
  '(-top-ports --top-ports)--top-ports[top ports to scan]:N:(100 1000)' \
  '(-exclude-ports --exclude-ports)--exclude-ports[ports to exclude from scan]:ports:' \
  '(-port-threshold --port-threshold)--port-threshold[port threshold to skip host scan]:N:' \
  '(-exclude-hosts --exclude-hosts)--exclude-hosts[hosts to exclude from scan]:hosts:' \
  '(-exclude-cdn --exclude-cdn)--exclude-cdn[skip full port scans for CDN/WAF]' \
  '(-o --output)'{-o,--output}'[output file to write results]:file:_files' \
  '(-json --json)--json[write output in JSON lines format]' \
  '(-csv --csv)--csv[write output in CSV format]' \
  '(-silent --silent)--silent[show only results in output]' \
  '(-v --version)'{-v,--version}'[show current version of naabu]' \
  '(-nc --no-color)'{-nc,--no-color}'[disable color in output]' \
  '(-verbose --verbose)--verbose[show verbose output]' \
  '(-no-stdin --no-stdin)--no-stdin[disable stdin processing]' \
  '(-health-check --health-check)--health-check[run a health check]' \
  '(-retries --retries)--retries[number of retries for port scan]:N:' \
  '(-rate --rate)--rate[packets per second]:rate:' \
  '(-timeout --timeout)--timeout[millisecond to wait before timing out]:milliseconds:' \
  '(-warm-up-time --warm-up-time)--warm-up-time[time in seconds between scan phases]:seconds:' \
  '(-ping --ping)--ping[use ping probe to verify host is up]' \
  '(-verify --verify)--verify[validate open ports with TCP connection]' \
  '(-interface-list --interface-list)--interface-list[list available network interfaces and exit]' \
  '(-interface --interface)--interface[network interface to use for port scan]:interface:' \
  '(-nmap --nmap)--nmap[invoke nmap scan on found ports]' \
  '(-nmap-cli --nmap-cli)--nmap-cli[nmap command line arguments]:args:' \
  '(-source-ip --source-ip)--source-ip[source IP and port]:source:' \
  '(-s --scan-type)'{-s,--scan-type}'[type of port scan]:type:(s c)' \
  '(-probe-icmp-echo --probe-icmp-echo)--probe-icmp-echo[use ICMP echo request]' \
  '(-probe-icmp-timestamp --probe-icmp-timestamp)--probe-icmp-timestamp[use ICMP timestamp request]' \
  '(-probe-icmp-address-mask --probe-icmp-address-mask)--probe-icmp-address-mask[use ICMP address mask request]' \
  '(-c --concurrency)'{-c,--concurrency}'[general number of concurrent threads]:N:' \
  '(-stats --stats)--stats[display stats of the running scan]' \
  '(-stats-interval --stats-interval)--stats-interval[waiting time between displaying stats]:seconds:' \
  '(-h --help)'{-h,--help}'[show help]'
