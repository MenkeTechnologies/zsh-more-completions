#compdef melt

# Zsh completion for melt (charm) - backup encryption/decryption tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-o --output)'{-o,--output}'[set output file]:file:_files' \
  '*:file:_files' && ret=0

return ret
