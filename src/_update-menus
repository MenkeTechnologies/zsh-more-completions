#compdef update-menus

local -a arguments

arguments=(
  '-d[output debugging messages.]'
  '-v[be verbose about what is going on.]'
  '(- * :)'{-h,--help}'[this message.]'
  '--menufilesdir[add directory to the lists of menu directories to search]:dir:_directories'
  '--menumethod[run only the specified menu method]:method:'
  '--nodefaultdirs[disable the use of all the standard menu directories.]'
  '--nodpkgcheck[do not check if packages are installed.]'
  '--remove[remove generated menus instead.]'
  '--stdout[output menu list in format suitable for piping to install-menu]'
  '--version[output version information and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
