#compdef zfgrep
# Documentation: https://man.archlinux.org/search?q=zfgrep
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {--exclude,--exclude-from,--exclude-dir,--include,--null}'[)]'
  '--null-data[), and --recursive (-r).]'
  '*:filename:_files'
)

_arguments -s -S $arguments
