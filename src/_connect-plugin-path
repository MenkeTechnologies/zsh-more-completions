#compdef connect-plugin-path

local -a subcommands
subcommands=(
    'list:List connector plugins on the path'
    'sync-manifests:Generate or update connector plugin manifests'
)

_arguments -C \
    '1:subcommand:->subcmd' \
    '*:: :->args'

case $state in
    subcmd)
        _describe -t subcommands 'connect-plugin-path subcommand' subcommands
        ;;
    args)
        _arguments \
            '--plugin-path[Plugin path]:directory:_directories' \
            '--worker-config[Worker config file]:file:_files -g "*.properties"' \
            '*:path:_directories'
        ;;
esac
