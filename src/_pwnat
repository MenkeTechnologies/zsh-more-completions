#compdef pwnat
# Documentation: https://man.archlinux.org/search?q=pwnat
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-c[client mode (default)]'
  '-s[server mode]'
  '-6[use IPv6]'
  '-v[show debug output (up to 2)]'
  '-h[show this help and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
