#compdef ip6tables

# Completion for ip6tables (IPv6 packet filter administration)

_ip6tables_chains() {
  local -a builtin_chains
  builtin_chains=(INPUT OUTPUT FORWARD PREROUTING POSTROUTING)
  _alternative \
    'chains:built-in chain:compadd -a builtin_chains' \
    'custom:custom chain:'
}

_ip6tables_tables() {
  local -a tables
  tables=(filter nat mangle raw security)
  _describe -t tables 'table' tables
}

_ip6tables_targets() {
  local -a targets
  targets=(
    ACCEPT DROP RETURN QUEUE
    AUDIT CHECKSUM CLASSIFY CONNMARK CONNSECMARK CT DNAT DNPT
    DSCP HL HMARK IDLETIMER LED LOG MARK MASQUERADE
    NFLOG NFQUEUE NOTRACK RATEEST REDIRECT REJECT
    SECMARK SET SNAT SNPT SYNPROXY TCPMSS TCPOPTSTRIP
    TEE TPROXY TRACE
  )
  _describe -t targets 'target' targets
}

_ip6tables_protocols() {
  local -a protocols
  protocols=(tcp udp udplite icmpv6 ipv6-icmp esp ah sctp mh dccp all)
  _describe -t protocols 'protocol' protocols
}

_ip6tables() {
  local arguments

  arguments=(
    # Commands (mutually exclusive)
    '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-A,--append}'[append rules to end of chain]:chain:_ip6tables_chains'
    '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-C,--check}'[check for the existence of a rule]:chain:_ip6tables_chains'
    '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-D,--delete}'[delete matching rule from chain]:chain:_ip6tables_chains'
    '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-I,--insert}'[insert rule in chain at given rule number]:chain:_ip6tables_chains'
    '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-R,--replace}'[replace rule in chain at given rule number]:chain:_ip6tables_chains'
    '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-L,--list}'[list all rules in chain or all chains]::chain:_ip6tables_chains'
    '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-S,--list-rules}'[print all rules in chain or all chains]::chain:_ip6tables_chains'
    '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-F,--flush}'[delete all rules in chain or all chains]::chain:_ip6tables_chains'
    '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-Z,--zero}'[zero packet and byte counters in chain or all chains]::chain:_ip6tables_chains'
    '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-N,--new-chain}'[create a new user-defined chain]:chain name'
    '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-X,--delete-chain}'[delete a user-defined chain]::chain:_ip6tables_chains'
    '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-P,--policy}'[set the policy for a built-in chain]:chain:_ip6tables_chains:target:(ACCEPT DROP)'
    '(-A --append -C --check -D --delete -I --insert -R --replace -L --list -S --list-rules -F --flush -Z --zero -N --new-chain -X --delete-chain -P --policy -E --rename-chain)'{-E,--rename-chain}'[rename a user-defined chain]:old chain name:new chain name'

    # Options
    {-p,--protocol}'[protocol of the rule]:protocol:_ip6tables_protocols'
    {-s,--source}'[source address/mask]:source address'
    {-d,--destination}'[destination address/mask]:destination address'
    {-j,--jump}'[target for rule (may load target extension)]:target:_ip6tables_targets'
    {-g,--goto}'[jump to chain with no return]:chain:_ip6tables_chains'
    {-i,--in-interface}'[name of input interface]:interface:_net_interfaces'
    {-o,--out-interface}'[name of output interface]:interface:_net_interfaces'
    '*'{-m,--match}'[extended match (may load extension)]:match name'
    {-n,--numeric}'[numeric output of addresses and ports]'
    {-t,--table}'[table to manipulate]:table:_ip6tables_tables'
    {-v,--verbose}'[verbose mode]'
    {-w,--wait}'[maximum wait to acquire xtables lock before giving up]:seconds'
    {-W,--wait-interval}'[wait interval to try to acquire xtables lock]:microseconds'
    '--line-numbers[print line numbers when listing]'
    {-x,--exact}'[expand numbers (display exact values)]'
    '--modprobe=[try to insert modules using this command]:command:_command_names'
    '--set-counters[set packet and byte counters during insert/append]:packets:bytes'
    {-4,--ipv4}'[this line is ignored by ip6tables]'
    {-6,--ipv6}'[this rule applies to IPv6 (no-op for ip6tables)]'

    # Rule specification parameters
    '(--fragment)-f[match second or further fragments only]'
    '-c[set the initial packet and byte counter]:packets:bytes'

    '(- *)'{-h,--help}'[print help text]'
  )

  _arguments -s -S $arguments
}

_ip6tables "$@"
