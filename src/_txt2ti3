#compdef txt2ti3
# Documentation: https://man.archlinux.org/search?q=txt2ti3
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-2[create dummy .ti2 file as well]'
  '-l[set ink limit, 0 - 400% (default max in file)]'
  '-d[set type of device as Display, not Output]'
  '-i[set type of device as Input, not Output]'
  '-T[transpose sample name Letters and Numbers]'
  '*:filename:_files'
)

_arguments -s -S $arguments
