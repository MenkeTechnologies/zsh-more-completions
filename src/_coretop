#compdef coretop

local -a arguments

arguments=(
    '-s[Update interval in seconds]:seconds'
    '-n[Number of iterations]:count'
    '-l[Logging mode, output suitable for file]'
    '-sort[Sort by column]:column:(name count)'
    '-type[Filter by event type]:event type'
    '-name[Filter by event name]:event name'
    '-pid[Filter by process ID]:pid'
    '-framework[Filter by framework]:framework name'
    '--help[Show help information]'
)

_arguments -s -S $arguments
