#compdef packemon

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:build packages for distribution'
  'pack:pack a package into a tarball'
  'validate:validate package configuration'
  'clean:clean build outputs'
  'init:initialize package configuration'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'packemon command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (build)
        _arguments -s -S \
          '--addFiles[add extra files to package]' \
          '--addExports[add missing exports to package.json]' \
          '--declaration[generate TypeScript declarations]' \
          '--filter=[filter packages]:glob' \
          '--formats=[output formats]:formats' \
          '--loadConfigs[load config files]' \
          '--skipPrivate[skip private packages]' \
          '--stamp[stamp packages with build timestamp]' \
          '--timeout=[build timeout in ms]:ms' && ret=0
        ;;
      (validate)
        _arguments -s -S \
          '--deps[check dependencies]' \
          '--engines[check engine requirements]' \
          '--entries[check entry points]' \
          '--files[check included files]' \
          '--license[check license]' \
          '--links[check links]' \
          '--people[check people fields]' \
          '--repo[check repository field]' \
          '--filter=[filter packages]:glob' \
          '--skipPrivate[skip private packages]' && ret=0
        ;;
    esac
    ;;
esac

return ret
