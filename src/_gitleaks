#compdef gitleaks

# Zsh completion for gitleaks - secret scanner for git repos

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'detect:detect secrets in code'
  'protect:protect against secrets in staged changes'
  'version:display gitleaks version'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'gitleaks command' commands && ret=0
    ;;
  (args)
    local -a common_flags=(
      '(-c --config)'{-c,--config}'[path to config file]:file:_files'
      '(-s --source)'{-s,--source}'[path to source]:path:_files'
      '(-r --report-path)'{-r,--report-path}'[path to write report]:file:_files'
      '(-f --report-format)'{-f,--report-format}'[report format]:format:(json csv junit sarif)'
      '(-b --baseline-path)'{-b,--baseline-path}'[path to baseline report]:file:_files'
      '(-l --log-level)'{-l,--log-level}'[log level]:level:(trace debug info warn error fatal)'
      '(-v --verbose)'{-v,--verbose}'[verbose output]'
      '--redact[redact secrets from output]'
      '--no-banner[suppress banner]'
      '--exit-code[exit code when secrets are found]:code'
      '--max-target-megabytes[maximum target size in MB]:size'
      '--no-color[disable color output]'
      '(-h --help)'{-h,--help}'[show help]'
    )
    case $words[1] in
      (detect)
        _arguments -s -S \
          $common_flags \
          '--no-git[scan files without git history]' \
          '--log-opts[git log options]:options' \
          '--follow-symlinks[follow symlinks]' \
          '*:path:_files' && ret=0
        ;;
      (protect)
        _arguments -s -S \
          $common_flags \
          '--staged[scan staged changes only]' \
          '*:path:_files' && ret=0
        ;;
      (version)
        ret=0
        ;;
    esac
    ;;
esac

return ret
