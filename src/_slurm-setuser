#compdef slurm-setuser
# Documentation: https://man.archlinux.org/search?q=slurm-setuser
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-u[the slurm file owner and SlurmUser (root)]'
  '-g[the slurm file group (root)]'
  '-y[answer yes to all questions (no)]'
  '-h[print help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
