#compdef nlcontrol
# Documentation: https://man.archlinux.org/search?q=nlcontrol
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-help[help on all flags \[tip: all flags can have two dashes\])]'
  '-domain[name) type: string default: ""]'
  '-server[name) type: string default: ""]'
  '*:filename:_files'
)

_arguments -s -S $arguments
