#compdef xdotool

# Zsh completion for xdotool - command-line X11 automation tool

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  # Keyboard commands
  'key:send a keystroke'
  'keydown:send key press (without release)'
  'keyup:send key release'
  'type:type a string as if on a keyboard'
  # Mouse commands
  'mousemove:move the mouse to a specific position'
  'mousemove_relative:move the mouse relative to current position'
  'click:send a mouse click'
  'mousedown:send mouse button press'
  'mouseup:send mouse button release'
  'getmouselocation:output the current mouse position'
  'behave_screen_edge:bind an action to events on screen edges'
  # Window commands
  'search:search for windows with matching attributes'
  'selectwindow:interactively select a window'
  'getwindowfocus:get the window currently focused'
  'getactivewindow:get the currently active window'
  'getwindowpid:get the PID of the window'
  'getwindowname:get the name (title) of the window'
  'getwindowgeometry:get the geometry of the window'
  'getwindowclassname:get the class name of the window'
  'getdisplaygeometry:get the display geometry'
  'windowactivate:activate the window'
  'windowfocus:focus the window'
  'windowraise:raise the window'
  'windowlower:lower the window'
  'windowsize:set the window size'
  'windowmove:move the window'
  'windowclose:close the window'
  'windowquit:close the window by sending a quit request'
  'windowkill:kill the window'\''s client'
  'windowminimize:minimize the window'
  'windowmap:map (show) the window'
  'windowunmap:unmap (hide) the window'
  'windowreparent:reparent window under a new parent window'
  'windowstate:change window state properties'
  'set_window:set window properties (name, icon, role, class, classname, overrideredirect)'
  'set_desktop_viewport:move the viewport to the given position'
  'set_num_desktops:set the number of desktops'
  'get_num_desktops:output the current number of desktops'
  'set_desktop:switch to the specified desktop'
  'get_desktop:output the current desktop'
  'set_desktop_for_window:move a window to a different desktop'
  'get_desktop_for_window:output the desktop containing a window'
  # Miscellaneous commands
  'exec:execute a program'
  'sleep:sleep for a specified number of seconds'
  'version:print xdotool version'
)

_arguments -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    _describe -t commands 'xdotool command' commands && ret=0
    ;;
  args)
    local cmd="${line[1]}"
    case "$cmd" in
      key|keydown|keyup)
        _arguments -s \
          '--window=[send keystrokes to a specific window]:window id' \
          '--clearmodifiers[clear active keyboard modifiers during keystrokes]' \
          '--delay=[delay between keystrokes in milliseconds]:delay (ms)' \
          '--repeat=[number of times to repeat the key sequence]:count' \
          '--repeat-delay=[delay between repetitions in milliseconds]:delay (ms)' \
          '*:key sequence' && ret=0
        ;;
      type)
        _arguments -s \
          '--window=[send keystrokes to a specific window]:window id' \
          '--clearmodifiers[clear active keyboard modifiers during keystrokes]' \
          '--delay=[delay between keystrokes in milliseconds]:delay (ms)' \
          '*:text to type' && ret=0
        ;;
      mousemove)
        _arguments -s \
          '--window=[move relative to the given window]:window id' \
          '--screen=[move to the specified screen number]:screen number' \
          '--polar[use polar coordinates (angle, distance)]' \
          '--clearmodifiers[clear active keyboard modifiers]' \
          '--sync[wait until the mouse actually moves]' \
          ':x coordinate' \
          ':y coordinate' && ret=0
        ;;
      mousemove_relative)
        _arguments -s \
          '--polar[use polar coordinates (angle, distance)]' \
          '--sync[wait until the mouse actually moves]' \
          '--clearmodifiers[clear active keyboard modifiers]' \
          ':x offset' \
          ':y offset' && ret=0
        ;;
      click|mousedown|mouseup)
        _arguments -s \
          '--window=[send click to a specific window]:window id' \
          '--clearmodifiers[clear active keyboard modifiers]' \
          '--repeat=[number of times to repeat the click]:count' \
          '--delay=[delay between clicks in milliseconds]:delay (ms)' \
          ':button (1=left 2=middle 3=right 4=wheelup 5=wheeldown):(1 2 3 4 5)' && ret=0
        ;;
      getmouselocation)
        _arguments -s \
          '--shell[output in shell eval-compatible format]' \
          '--prefix=[use a custom prefix for shell output variables]:prefix' && ret=0
        ;;
      behave_screen_edge)
        _arguments -s \
          '--delay=[delay before activating in milliseconds]:delay (ms)' \
          '--quiesce=[minimum quiet time between activations in ms]:time (ms)' \
          ':edge position:(left right top bottom top-left top-right bottom-left bottom-right)' \
          '*:command to execute' && ret=0
        ;;
      search)
        _arguments -s \
          '--class[match against the window class]' \
          '--classname[match against the window classname]' \
          '--name[match against the window name (title)]' \
          '--title[DEPRECATED: same as --name]' \
          '--pid=[match windows belonging to a specific PID]:pid:_pids' \
          '--screen=[match windows only on the given screen]:screen number' \
          '--desktop=[match windows on the given desktop]:desktop number' \
          '--limit=[stop searching after N results]:max results' \
          '--maxdepth=[set maximum search depth]:depth' \
          '--onlyvisible[match only visible windows]' \
          '--sync[wait until a matching window is found]' \
          '--all[require all conditions to be met]' \
          '--any[require any condition to be met (default)]' \
          '--role[match against the window role]' \
          '--classname[match the classname]' \
          ':search pattern' && ret=0
        ;;
      getwindowfocus)
        _arguments -s \
          '-f[report the window with input focus even if not a top-level window]' && ret=0
        ;;
      getwindowgeometry)
        _arguments -s \
          '--shell[output in shell eval-compatible format]' \
          '--prefix=[use a custom prefix for shell output variables]:prefix' \
          ':window id' && ret=0
        ;;
      getwindowpid|getwindowname|getwindowclassname)
        _arguments ':window id' && ret=0
        ;;
      windowactivate|windowfocus)
        _arguments -s \
          '--sync[wait until the window is actually activated/focused]' \
          ':window id' && ret=0
        ;;
      windowraise|windowlower|windowclose|windowquit|windowkill)
        _arguments ':window id' && ret=0
        ;;
      windowsize)
        _arguments -s \
          '--usehints[use window sizing hints (e.g., character cell size) when resizing]' \
          '--sync[wait until the window size actually changes]' \
          ':window id' \
          ':width' \
          ':height' && ret=0
        ;;
      windowmove)
        _arguments -s \
          '--relative[move relative to the current position]' \
          '--sync[wait until the window position actually changes]' \
          ':window id' \
          ':x position' \
          ':y position' && ret=0
        ;;
      windowminimize)
        _arguments -s \
          '--sync[wait until the window is actually minimized]' \
          ':window id' && ret=0
        ;;
      windowmap|windowunmap)
        _arguments -s \
          '--sync[wait until the window is actually mapped/unmapped]' \
          ':window id' && ret=0
        ;;
      windowreparent)
        _arguments \
          ':window id' \
          ':new parent window id' && ret=0
        ;;
      windowstate)
        _arguments -s \
          '--add[add a state property]:property:(MODAL STICKY MAXIMIZED_VERT MAXIMIZED_HORZ SHADED SKIP_TASKBAR SKIP_PAGER HIDDEN FULLSCREEN ABOVE BELOW DEMANDS_ATTENTION)' \
          '--remove[remove a state property]:property:(MODAL STICKY MAXIMIZED_VERT MAXIMIZED_HORZ SHADED SKIP_TASKBAR SKIP_PAGER HIDDEN FULLSCREEN ABOVE BELOW DEMANDS_ATTENTION)' \
          '--toggle[toggle a state property]:property:(MODAL STICKY MAXIMIZED_VERT MAXIMIZED_HORZ SHADED SKIP_TASKBAR SKIP_PAGER HIDDEN FULLSCREEN ABOVE BELOW DEMANDS_ATTENTION)' \
          ':window id' && ret=0
        ;;
      set_window)
        _arguments -s \
          '--name=[set the window name (title)]:name' \
          '--icon-name=[set the window icon name]:icon name' \
          '--role=[set the window role]:role' \
          '--classname=[set the window classname]:classname' \
          '--class=[set the window class]:class' \
          '--urgency=[set the urgency hint]:urgency:(0 1)' \
          '--overrideredirect=[set override-redirect flag]:value:(0 1)' \
          ':window id' && ret=0
        ;;
      set_desktop)
        _arguments \
          '--relative[use relative desktop number]' \
          ':desktop number' && ret=0
        ;;
      set_desktop_for_window)
        _arguments \
          ':window id' \
          ':desktop number' && ret=0
        ;;
      get_desktop_for_window)
        _arguments ':window id' && ret=0
        ;;
      set_num_desktops)
        _arguments ':number of desktops' && ret=0
        ;;
      set_desktop_viewport)
        _arguments \
          ':x position' \
          ':y position' && ret=0
        ;;
      exec)
        _arguments -s \
          '--sync[wait for the command to finish before continuing]' \
          '*::command:_command_names' && ret=0
        ;;
      sleep)
        _arguments ':seconds' && ret=0
        ;;
    esac
    ;;
esac

return ret
