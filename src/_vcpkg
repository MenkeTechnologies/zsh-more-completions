#compdef vcpkg

# Zsh completion for vcpkg - C/C++ package manager

local curcontext="$curcontext" state line ret=1

local -a global_opts=(
  '(-h --help)'{-h,--help}'[show help information]'
  '--version[show version]'
  '--triplet[set the default triplet]:triplet:'
  '--vcpkg-root[set the vcpkg root directory]:dir:_files -/'
  '--debug[enable debug output]'
  '--feature-flags[set feature flags]:flags:'
  '--disable-metrics[disable metrics]'
  '--overlay-ports[set overlay ports directory]:dir:_files -/'
  '--overlay-triplets[set overlay triplets directory]:dir:_files -/'
)

local -a subcommands=(
  'install:install a package'
  'remove:remove a package'
  'search:search for packages'
  'list:list installed packages'
  'update:list packages that can be updated'
  'upgrade:rebuild all outdated packages'
  'edit:open a port for editing'
  'create:create a new port'
  'cache:list cached compiled packages'
  'version:show version information'
  'contact:display contact information'
  'hash:hash a file by specific algorithm'
  'help:show help'
  'integrate:integrate vcpkg with shells and build systems'
  'export:export a package'
  'import:import a pre-built library'
  'x-package-info:display package info'
  'env:create a clean shell environment'
  'fetch:fetch tool'
  'format-manifest:format manifest files'
  'owns:search for files in installed packages'
  'depend-info:display dependency info for a package'
  'x-ci-clean:clean CI artifacts'
  'x-ci-verify-versions:verify package versions for CI'
  'x-add-version:add a version to the versions database'
  'x-set-installed:install a specific set of packages'
  'new:create a new manifest'
  'add:add a dependency to manifest'
  'use:use an artifact'
)

_arguments -s -S \
  $global_opts \
  '1:subcommand:->subcmd' \
  '*::args:->args' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'vcpkg subcommand' subcommands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (install)
        _arguments -s -S \
          $global_opts \
          '--triplet[set triplet]:triplet:' \
          '--host-triplet[set host triplet]:triplet:' \
          '--overlay-ports[set overlay ports directory]:dir:_files -/' \
          '--overlay-triplets[set overlay triplets directory]:dir:_files -/' \
          '--binarysource[set binary source]:source:' \
          '--x-buildtrees-root[set buildtrees root]:dir:_files -/' \
          '--x-install-root[set install root]:dir:_files -/' \
          '--x-packages-root[set packages root]:dir:_files -/' \
          '--recurse[allow removal of packages as part of installation]' \
          '--keep-going[continue installing on failure]' \
          '--clean-after-build[clean buildtrees, packages and downloads after building each package]' \
          '--clean-buildtrees-after-build[clean buildtrees after building each package]' \
          '--clean-packages-after-build[clean packages after building each package]' \
          '--clean-downloads-after-build[clean downloads after building each package]' \
          '--editable[disable source caching for editable packages]' \
          '--no-downloads[do not download new sources]' \
          '--only-downloads[download sources but do not build packages]' \
          '--only-binarycaching[only use binary caching]' \
          '--enforce-port-checks[fail install if a port has detected problems]' \
          '--allow-unsupported[install packages marked unsupported for the triplet]' \
          '--dry-run[do not actually build or install]' \
          '--x-write-nuget-packages-config[write NuGet packages config file]:file:_files' \
          '--head[request use of the latest upstream source]' \
          '--x-feature[install a feature]:feature:' \
          '--x-no-default-features[do not install default features]' \
          '*:package name:' && ret=0
        ;;
      (remove)
        _arguments -s -S \
          $global_opts \
          '--triplet[set triplet]:triplet:' \
          '--recurse[allow removal of dependent packages]' \
          '--dry-run[do not actually remove]' \
          '--outdated[remove all outdated packages]' \
          '--purge[purge extracted packages from the cache]' \
          '*:package name:' && ret=0
        ;;
      (search)
        _arguments -s -S \
          $global_opts \
          '--x-full-desc[show full description of packages]' \
          '*:search pattern:' && ret=0
        ;;
      (list)
        _arguments -s -S \
          $global_opts \
          '--x-full-desc[show full description of packages]' && ret=0
        ;;
      (export)
        _arguments -s -S \
          $global_opts \
          '--triplet[set triplet]:triplet:' \
          '--output-dir[set output directory]:dir:_files -/' \
          '--output[set output name]:name:' \
          '--raw[export raw directory]' \
          '--nuget[export NuGet package]' \
          '--zip[export zip archive]' \
          '--7zip[export 7zip archive]' \
          '--ifw[export IFW installer]' \
          '--chocolatey[export Chocolatey package]' \
          '--prefab[export Prefab format]' \
          '*:package name:' && ret=0
        ;;
      (integrate)
        local -a integrate_cmds=(
          'install:integrate with user-wide settings'
          'remove:remove user-wide integration'
          'project:generate a referencing NuGet package for project use'
          'powershell:enable PowerShell tab-completion'
        )
        _describe -t subcommands 'integrate subcommand' integrate_cmds && ret=0
        ;;
      (*)
        _arguments -s -S $global_opts '*:arguments:' && ret=0
        ;;
    esac
    ;;
esac

return ret
