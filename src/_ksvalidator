#compdef ksvalidator


local -a arguments

arguments=(
    {-e,--firsterror}'[Stop on the first warning or error.]'
    {-i,--followincludes}'[Process included files in the input file when they are seen, like anaconda wo]'
    {-l,--listversions}'[List all versions of kickstart syntax supported by ksvalidator.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
