#compdef ibqueryerrors


local -a arguments

arguments=(
    {--outstanding_smps,-o}'[specify the number of outstanding SMPs to issue during the scan]':val
    {-y,--m_key}'[use the specified M_key for requests.]':key
    '-d[raise the IB debugging level. May be used several times (-ddd or -d -d -d).]'
    '-e[show send and receive errors (timeouts and others).]'
    {-v,--verbose}'[increase the application verbosity level.]'
    {-s,--suppress}'[Suppress the errors listed in the comma separated list provided.]':err1err2...
    {-c,--suppress-common}'[Suppress some of the common "side effect" counters.]'
    {-r,--report-port}'[Report the port information.]'
    '--data[Include the optional transmit and receive data counters.]'
    '--threshold-file[Specify an alternate threshold file.]:filename'
    '--switch[query only switch ports]'
    '--ca[query only CA ports]'
    '--skip-sl[skip checks for service level]'
    '--router[query only router ports]'
    {--clear-errors,-k}'[clear error counters after querying]'
    {--clear-counts,-K}'[clear data counters after querying]'
    '--details[show detailed error information]'
    '--counters[show data traffic counters]'
    {--port-guid,-G}'[specify port GUID for partial scan]:port guid'
    {-D,--Direct}'[use direct route addressing]'
    '-S[specify switch GUID for partial scan]:switch guid'
    '--load-cache[Load and use the cached ibnetdiscover data stored in the specified filename.]:filename'
    {-C,--Ca}'[use specified CA]:ca name'
    {-P,--Port}'[use specified port]:port number'
    {--config,-z}'[use specified config file]:config file:_files'
    '--node-name-map[specify node name map file]:filename:_files'
    {-t,--timeout}'[set timeout in milliseconds]:timeout'
    {-h,--help}'[show help]'
    {-V,--version}'[show version]'
    '-R[recalculate routes after discovery]'
    '-1[force failure on first error]'
    '*:filename:_files'
)
_arguments -s -S $arguments
