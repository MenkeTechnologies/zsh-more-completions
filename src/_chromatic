#compdef chromatic

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--project-token=[chromatic project token]:token' \
  '-t+[chromatic project token]:token' \
  '--app-code=[deprecated alias for project-token]:token' \
  '--build-script-name=[script name for building Storybook]:script name' \
  '-b+[script name for building Storybook]:script name' \
  '--storybook-build-dir=[prebuilt Storybook directory]:directory:_directories' \
  '-d+[prebuilt Storybook directory]:directory:_directories' \
  '--output-dir=[write build results to a directory]:directory:_directories' \
  '--auto-accept-changes=[auto accept changes on branch]:branch pattern' \
  '--branch-name=[override the branch name]:branch' \
  '--ci[run in CI mode]' \
  '--debug[verbose logging]' \
  '--diagnostics[write process context information to file]' \
  '--dry-run[run without publishing to Chromatic]' \
  '--exit-once-uploaded[exit once Storybook is published]' \
  '--exit-zero-on-changes[exit with code 0 even when changes detected]' \
  '--external-build-url=[link to the build on your CI provider]:url' \
  '--force-rebuild=[do not skip build]:branch pattern' \
  '--ignore-last-build-on-branch=[do not use last build on branch]:branch pattern' \
  '--only-changed[only test stories affected by changes]' \
  '--only-story-files=[only test stories matching a glob]:glob pattern' \
  '--only-story-names=[only test stories matching names]:name pattern' \
  '--patch-build=[create a patch build]:base..head' \
  '--preserve-missing[do not treat removed stories as deleted]' \
  '--repository-slug=[override the repository slug]:owner/name' \
  '--skip=[skip testing on branch]:branch pattern' \
  '--storybook-base-dir=[relative path to storybook project root]:directory:_directories' \
  '--storybook-config-dir=[relative path to storybook config]:directory:_directories' \
  '--untraced=[do not trace changes for stories matching]:glob pattern' \
  '--upload-metadata[upload metadata files]' \
  '--zip[upload Storybook as a zip bundle]' \
  '--junit-report=[path for JUnit report]:file:_files' \
  '--log-file=[path for log file]:file:_files' \
  '--config-file=[path to config file]:file:_files' && ret=0

return ret
