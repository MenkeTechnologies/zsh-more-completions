#compdef font_cache

local -a arguments

arguments=(
  {-f,--force}'[Force cache recreation]'
  {-n,--no-osxfonts}'[Just cache X11 font directories]'
  {-s,--system}'[Cache system font dirs instead of user dirs]'
  {-v,--verbose}'[Verbose Output]'
  '*:filename:_files'
)

_arguments -s -S $arguments
