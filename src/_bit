#compdef bit

# Zsh completion for bit - modern Git CLI helper

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'save:save changes (commit and push)'
      'sync:synchronize with remote'
      'switch:switch branches'
      'info:show repository info'
      'complete:install shell completions'
      'release:create a release'
      'update:update bit'
      'pr:create a pull request'
    )
    _describe -t commands 'bit command' commands && ret=0
    ;;
  args)
    case ${line[1]} in
      save)
        _arguments -s \
          '--all[save all changes]' \
          '*:message' && ret=0
        ;;
      switch)
        __git_branch_names() {
          local -a branches
          branches=(${(f)"$(git branch --format='%(refname:short)' 2>/dev/null)"})
          _describe -t branches 'branch' branches
        }
        _arguments ':branch:__git_branch_names' && ret=0
        ;;
      release)
        _arguments ':version' && ret=0
        ;;
    esac
    ;;
esac

return ret
