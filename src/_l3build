#compdef l3build

local -a arguments

arguments=(
  {-c,--config}'[sets the config(s) used for running tests]'
  '--date[sets the date to insert into sources]'
  '--dirty[skip cleaning up the test area]'
  '--dry-run[dry run for install]'
  {-e,--engine}'[sets the engine(s) to use for running test]'
  '--epoch[sets the epoch for tests and typesetting]'
  '--first[name of first test to run]'
  {-f,--force}'[force tests to run if engine is not set up]'
  '--full[install all files]'
  {-H,--halt-on-error}'[stops running tests after the first failure]'
  '--last[name of last test to run]'
  {-q,--quiet}'[suppresses TeX output when unpacking]'
  '--rerun[skip setup: simply rerun tests]'
  '--shuffle[shuffle order of tests]'
  '--texmfhome[location of user texmf tree]'
  '*:filename:_files'
)

_arguments -s -S $arguments
