#compdef fastfetch

# Zsh completion for fastfetch - fast system information tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[Show help message]' \
  '--version[Show version]' \
  '--list-modules[List available modules]' \
  '--list-presets[List available presets]' \
  '--list-config-paths[List possible config file paths]' \
  '--list-data-paths[List possible data paths]' \
  '--list-logos[List available logos]' \
  '--print-logos[Print available logos]' \
  '--config[Path to config file]:config file:_files' \
  '--data-dir[Data directory]:directory:_files -/' \
  '(-s --structure)'{-s,--structure}'[Set output structure (colon-separated modules)]:structure' \
  '--set[Set the value of a module option]:module\:key=value' \
  '--set-keyless[Set the value of a module option without key]:module=value' \
  '(-l --logo)'{-l,--logo}'[Set logo]:logo' \
  '--logo-type[Set logo type]:type:(auto builtin small file raw kitty iterm chafa)' \
  '--logo-source[Set the source of the logo]:source:_files' \
  '--logo-width[Set logo width]:width' \
  '--logo-height[Set logo height]:height' \
  '--logo-padding[Set logo padding]:padding' \
  '--logo-padding-left[Left padding for logo]:padding' \
  '--logo-padding-right[Right padding for logo]:padding' \
  '--logo-padding-top[Top padding for logo]:padding' \
  '--logo-color-1[First logo color]:color' \
  '--logo-color-2[Second logo color]:color' \
  '--logo-color-3[Third logo color]:color' \
  '--logo-color-4[Fourth logo color]:color' \
  '--logo-color-5[Fifth logo color]:color' \
  '--logo-color-6[Sixth logo color]:color' \
  '--logo-color-7[Seventh logo color]:color' \
  '--logo-color-8[Eighth logo color]:color' \
  '--logo-color-9[Ninth logo color]:color' \
  '--color-keys[Color for keys]:color' \
  '--color-title[Color for title]:color' \
  '--color-output[Color for output]:color' \
  '--color-separator[Color for separator]:color' \
  '--separator[Separator string]:separator' \
  '--key-width[Key width in characters]:width' \
  '--show-errors[Print occurring errors]' \
  '--disable-linewrap[Disable line wrap during output]' \
  '--hide-cursor[Hide cursor during output]' \
  '--binary-prefix[Binary prefix type]:prefix:(iec si jedec)' \
  '--stat[Show time statistics for each module]' \
  '(-c --color)'{-c,--color}'[Enable or disable color output]:enabled:(true false)' \
  '--multithreading[Enable multithreading]' \
  '--pipe[Disable logo and all escape sequences]' \
  '--processing-timeout[Processing timeout in milliseconds]:timeout' \
  '--format[Output format]:format:(default json)' \
  '--ds-force-drm[Force DRM for display server detection]' \
  '--gen-config[Generate a config file]:format:(jsonc conf)' \
  '--gen-config-force[Generate config file even if it exists]:format:(jsonc conf)' \
  '--load-config[Load config from specified preset]:preset' \
  '--title-fqdn[Show fully qualified domain name in title]:option:(true false)' \
  '--os-file[File to read OS info from]:file:_files' \
  '--player-name[Name of the media player]:player' && ret=0

return ret
