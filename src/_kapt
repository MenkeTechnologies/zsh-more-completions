#compdef kapt

local -a arguments

arguments=(
    '-sources[Source files to process]:source files:_files'
    '-classpath[Classpath for annotation processing]:classpath:_files'
    '-d[Output directory for generated classes]:directory:_directories'
    '-s[Output directory for generated sources]:directory:_directories'
    '-processor[Annotation processor class names]:processor class'
    '-processorpath[Classpath for annotation processors]:processor path:_files'
    '-Xmaxerrs=[Maximum number of errors to print]:count'
    '-encoding=[Source file encoding]:encoding'
    '-stubs[Output directory for stubs]:directory:_directories'
    '-aptMode=[Annotation processing mode]:(stubs apt stubsAndApt)'
    '-correctErrorTypes[Correct error types in declarations]'
    '-verbose[Enable verbose output]'
    '-javacArguments=[Arguments passed to javac]:arguments'
    '-apoptions=[Annotation processing options]:options'
    '-useLightAnalysis[Use light analysis for stubs]'
    '-includeCompileClasspath[Include compile classpath in processor path]'
    '-dumpDefaultParameterValues[Dump default parameter values]'
    '*:files:_files'
)

_arguments -s -S $arguments
