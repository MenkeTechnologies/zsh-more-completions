#compdef bcmfw
# Documentation: https://man.archlinux.org/search?q=bcmfw
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-n[device name]:device:'
  '-m[mini-driver image file name for download]:image file:_files'
  '-f[firmware image file name for download]:image file:_files'
  '-h[display this message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
