#compdef pmlogsize
# Documentation: https://man.archlinux.org/search?q=pmlogsize
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    {-d,--detail}'[Enable detailed reporting.]'
    {-r,--replication}'[Display additional information about possible replicated values in the data f]'
    {-x,--threshold}'[With.]'
    {-v,--verbose}'[Enable verbose mode.]'
    {-?,--help}'[Display usage message and exit.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
