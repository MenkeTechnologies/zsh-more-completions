#compdef cachix

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'authtoken:configure the auth token'
  'config:manage configuration'
  'deploy:manage deploy agents and activations'
  'generate-keypair:generate signing key pair'
  'import:import a path from another cache'
  'pin:pin a store path'
  'push:push store paths to a cache'
  'remove:remove a store path from a cache'
  'use:configure a cache for use'
  'watch-exec:watch a command and push store paths'
  'watch-store:watch the nix store and push new paths'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config=[config file]:config file:_files' \
  '--hostname=[API hostname]:hostname' \
  '--verbose[verbose output]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'cachix command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (push)
        _arguments -s -S \
          '--compression-level=[compression level]:level:(1 2 3 4 5 6 7 8 9)' \
          '--compression-method=[compression method]:method:(xz zstd)' \
          '--jobs=[number of parallel uploads]:jobs' \
          '--omit-deriver[do not include deriver info]' \
          '1:cache name' \
          '*:store paths:_files' && ret=0
        ;;
      (use)
        _arguments -s -S \
          '(-m --mode)'{-m,--mode}'=[nix configuration mode]:mode:(nixos nix-env)' \
          '--output-directory=[output directory for NixOS config]:directory:_directories' \
          '1:cache name' && ret=0
        ;;
      (watch-exec)
        _arguments -s -S \
          '--compression-level=[compression level]:level' \
          '--compression-method=[compression method]:method:(xz zstd)' \
          '--jobs=[number of parallel uploads]:jobs' \
          '1:cache name' \
          '--:command separator' \
          '*:command' && ret=0
        ;;
      (watch-store)
        _arguments -s -S \
          '--compression-level=[compression level]:level' \
          '--compression-method=[compression method]:method:(xz zstd)' \
          '--jobs=[number of parallel uploads]:jobs' \
          '1:cache name' && ret=0
        ;;
      (authtoken)
        _arguments '1:token' && ret=0
        ;;
      (generate-keypair)
        _arguments '1:cache name' && ret=0
        ;;
      (pin)
        _arguments \
          '1:cache name' \
          '2:pin name' \
          '3:store path:_files' && ret=0
        ;;
      (deploy)
        local -a deploy_cmds=(
          'activate:activate a deployment'
          'agent:run a deploy agent'
        )
        _arguments \
          '1:subcommand:_describe -t deploy-commands "deploy command" deploy_cmds' \
          '*:args' && ret=0
        ;;
    esac
    ;;
esac

return ret
