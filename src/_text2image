#compdef text2image

local -a arguments

arguments=(
  '--exposure[exposure level in photocopier  (type:int default:0)]'
  '--resolution[pixels per inch  (type:int default:300)]'
  '--xsize[width of output image  (type:int default:3600)]'
  '--ysize[height of output image  (type:int default:4800)]'
  '--max_pages[maximum number of pages to output (0=unlimited)]:count:'
  '--margin[margin round edges of image  (type:int default:100)]'
  '--ptsize[size of printed text  (type:int default:12)]'
  '--leading[inter-line space (in pixels)  (type:int default:12)]'
  '--box_padding[padding around produced bounding boxes]:pixels:'
  '--glyph_resized_size[each glyph is square with this side length in pixels]:pixels:'
  '--glyph_num_border_pixels_to_pad[border pixels to pad around each glyph]:pixels:'
  '--tlog_level[minimum logging level for tlog output]:level:'
  '--debug_level[level of Trainer debugging]:level:'
  '--load_images[load images with tr files]:flag:'
  '--char_spacing[inter-character space in ems]:spacing:'
  '--underline_start_prob[fraction of words to underline (0 to 1)]:probability:'
  '--underline_continuation_prob[fraction of words to continue underline (0 to 1)]:probability:'
  '--min_coverage[minimum font coverage of characters (0 to 1)]:coverage:'
  '--clusterconfig_min_samples_fraction[min samples per proto as percent of total]:fraction:'
  '--clusterconfig_max_illegal[max percent of samples with more than 1 feature]:fraction:'
  '--clusterconfig_independence[desired independence between dimensions]:value:'
  '--clusterconfig_confidence[desired confidence in prototypes created]:value:'
  '--degrade_image[degrade rendered image with speckle noise and rotation]'
  '--rotate_image[rotate the image in a random way]'
  '--distort_image[degrade rendered image with noise, blur, invert]'
  '--invert[invert the image  (type:bool default:true)]'
  '--white_noise[add Gaussian noise]'
  '--smooth_noise[smoothen noise]'
  '--blur[blur the image  (type:bool default:true)]'
  '--strip_unrenderable_words[remove unrenderable words from source text]'
  '--ligatures[rebuild and render ligatures  (type:bool default:false)]'
  '--find_fonts[search for all fonts that can render the text]'
  '--render_per_font[render each font to its own image]'
  '--list_available_fonts[list available fonts and quit]'
  '--render_ngrams[put each space-separated entity into one bounding box]'
  '--output_word_boxes[output word bounding boxes instead of character boxes]'
  '--bidirectional_rotation[rotate the generated characters both ways]'
  '--only_extract_font_properties[extract spacing properties from ngrams]'
  '--output_individual_glyph_images[also output individual character images]'
  '--text[file name of text input to process]:file:_files'
  '--outputbase[basename for output image/box file]:name:'
  '--writing_mode[specify writing mode]:mode:'
  '--font[font description name to use]:font:'
  '--unicharset_file[file with characters in the unicharset]:file:_files'
  '--configfile[file to load more configs from]:file:_files'
  '-D[directory to write output files to]:directory:_directories'
  '-F[file listing font properties]:file:_files'
  '-X[file listing font xheights]:file:_files'
  '-U[file to load unicharset from]:file:_files'
  '-O[file to write unicharset to]:file:_files'
  '--output_trainer[file to write trainer to]:file:_files'
  '--test_ch[UTF8 test character string]:string:'
  '--fonts_dir[directory containing fonts]:directory:_directories'
  '--fontconfig_tmpdir[fontconfig temporary directory]:directory:_directories'
  '*:filename:_files'
)

_arguments -s -S $arguments
