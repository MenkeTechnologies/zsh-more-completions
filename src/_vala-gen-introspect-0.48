#compdef vala-gen-introspect-0 vala-gen-introspect-0.48


local -a arguments

arguments=(
    {-h,--help}'[Show help options . SS "Application Options:".]'
    {-v,--verbose}'[Be verbose.]'
    {-o,--output}'[write output here instead of stdout.]':FILE
    {-n,--namespace}'[Namespace of the module, like \Gtk\.]':NAMESPACE
    '--shared-library[Shared library which contains the symbols.]:FILE'
    '--include-idl[Other gidls to include.]:IDL'
    '*:filename:_files'
)
_arguments -s -S $arguments
