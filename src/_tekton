#compdef tkn

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'pipeline:manage pipelines'
  'pipelinerun:manage pipeline runs'
  'task:manage tasks'
  'taskrun:manage task runs'
  'clustertask:manage cluster tasks'
  'clustertriggerbinding:manage cluster trigger bindings'
  'eventlistener:manage event listeners'
  'hub:interact with Tekton Hub'
  'triggertemplate:manage trigger templates'
  'triggerbinding:manage trigger bindings'
  'condition:manage conditions'
  'resource:manage pipeline resources'
  'bundle:manage Tekton bundles'
  'chain:manage Tekton chains'
  'completion:generate shell completion scripts'
  'version:print version information'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-n --namespace)'{-n,--namespace}'=[kubernetes namespace]:namespace' \
  '(-C --context)'{-C,--context}'=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:kubeconfig:_files' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'tkn command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (pipeline)
        local -a pipeline_cmds=(
          'create:create a pipeline'
          'delete:delete a pipeline'
          'describe:describe a pipeline'
          'export:export a pipeline'
          'list:list pipelines'
          'logs:show pipeline logs'
          'start:start a pipeline'
          'sign:sign a pipeline'
          'verify:verify a signed pipeline'
        )
        _arguments \
          '1:subcommand:_describe -t pipeline-commands "pipeline command" pipeline_cmds' \
          '*:args' && ret=0
        ;;
      (pipelinerun)
        local -a pr_cmds=(
          'cancel:cancel a pipeline run'
          'delete:delete a pipeline run'
          'describe:describe a pipeline run'
          'export:export a pipeline run'
          'list:list pipeline runs'
          'logs:show pipeline run logs'
        )
        _arguments \
          '1:subcommand:_describe -t pr-commands "pipelinerun command" pr_cmds' \
          '*:args' && ret=0
        ;;
      (task)
        local -a task_cmds=(
          'create:create a task'
          'delete:delete a task'
          'describe:describe a task'
          'list:list tasks'
          'logs:show task logs'
          'start:start a task'
          'sign:sign a task'
          'verify:verify a signed task'
        )
        _arguments \
          '1:subcommand:_describe -t task-commands "task command" task_cmds' \
          '*:args' && ret=0
        ;;
      (taskrun)
        local -a tr_cmds=(
          'cancel:cancel a task run'
          'delete:delete a task run'
          'describe:describe a task run'
          'export:export a task run'
          'list:list task runs'
          'logs:show task run logs'
        )
        _arguments \
          '1:subcommand:_describe -t tr-commands "taskrun command" tr_cmds' \
          '*:args' && ret=0
        ;;
      (hub)
        local -a hub_cmds=(
          'check-upgrade:check for upgrades'
          'downgrade:downgrade a resource'
          'get:get a resource'
          'info:display info about a resource'
          'install:install a resource'
          'reinstall:reinstall a resource'
          'search:search for resources'
          'upgrade:upgrade a resource'
        )
        _arguments \
          '1:subcommand:_describe -t hub-commands "hub command" hub_cmds' \
          '*:args' && ret=0
        ;;
      (bundle)
        local -a bundle_cmds=(
          'list:list bundle contents'
          'push:push a bundle to a registry'
          'pull:pull a bundle from a registry'
        )
        _arguments \
          '1:subcommand:_describe -t bundle-commands "bundle command" bundle_cmds' \
          '*:args' && ret=0
        ;;
    esac
    ;;
esac

return ret
