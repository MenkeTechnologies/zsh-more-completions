#compdef pppctl
# Documentation: https://man.archlinux.org/search?q=pppctl
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-v[pppctl to output all conversation]'
  '-t[specifies a timeout of n seconds when connecting (default 2)]'
  '-p[specifies your password]'
  '*:filename:_files'
)

_arguments -s -S $arguments
