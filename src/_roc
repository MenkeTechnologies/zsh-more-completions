#compdef roc

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:build a roc application'
  'run:build and run a roc application'
  'test:build and run all tests'
  'repl:launch the interactive REPL'
  'check:check a roc file for errors'
  'format:format roc source files'
  'version:print the roc version'
  'docs:generate documentation for a roc package'
  'glue:generate glue code for a platform'
  'gen-stub-lib:generate a stub shared library'
  'dev:run in development mode with faster builds'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'roc command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (build)
        _arguments -s -S \
          '--optimize[build with optimizations]' \
          '--opt-size[optimize for binary size]' \
          '--dev[build without optimizations]' \
          '--profiling[build with profiling information]' \
          '--output=[specify output path]:output:_files' \
          '--target=[target triple]:target' \
          '--lib[build as a shared library]' \
          '--no-link[do not link the output]' \
          '--linker=[set the linker]:linker:(surgical legacy)' \
          '--prebuilt-platform[assume the platform has been prebuilt]' \
          '--fuzz[build for fuzzing]' \
          '1:roc file:_files -g "*.roc"' && ret=0
        ;;
      (run|dev)
        _arguments -s -S \
          '--optimize[build with optimizations]' \
          '--opt-size[optimize for binary size]' \
          '--dev[build without optimizations]' \
          '--profiling[build with profiling information]' \
          '--linker=[set the linker]:linker:(surgical legacy)' \
          '--prebuilt-platform[assume the platform has been prebuilt]' \
          '1:roc file:_files -g "*.roc"' \
          '*:args' && ret=0
        ;;
      (test)
        _arguments -s -S \
          '--optimize[build with optimizations]' \
          '--dev[build without optimizations]' \
          '--linker=[set the linker]:linker:(surgical legacy)' \
          '1:roc file:_files -g "*.roc"' && ret=0
        ;;
      (check|format)
        _arguments '*:roc file:_files -g "*.roc"' && ret=0
        ;;
      (docs)
        _arguments '1:roc file:_files -g "*.roc"' && ret=0
        ;;
      (glue)
        _arguments \
          '1:glue spec:_files' \
          '2:output dir:_directories' \
          '3:platform:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
