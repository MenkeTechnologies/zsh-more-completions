#compdef exim_id_update
# Documentation: https://man.archlinux.org/search?q=exim_id_update
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '-d[Downgrade mode.]'
    '-h[This help message.]'
    '-u[Upgrade mode.]'
    '-v[Version.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
