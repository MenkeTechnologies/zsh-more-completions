#compdef smistrip
# Documentation: https://man.archlinux.org/search?q=smistrip
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-V[show version and license information]'
  '-h[show usage information]'
  '-n[do not write module files]'
  '-i[try to read files from directory dir]'
  '-d[write module to directory dir]'
  '-m[strip only the specified module]'
  '*:filename:_files'
)

_arguments -s -S $arguments
