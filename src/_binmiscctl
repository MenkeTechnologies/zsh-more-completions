#compdef binmiscctl
# Documentation: https://man.archlinux.org/search?q=binmiscctl
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--magic[specify magic bytes]:magic bytes:'
  '--mask[specify mask bytes]:mask bytes:'
  '--size[specify size]:size:'
  '--offset[specify magic offset]:offset:'
  '*:filename:_files'
)

_arguments -s -S $arguments
