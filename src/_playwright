#compdef playwright

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'test:run tests'
  'show-report:show HTML test report'
  'codegen:open page and generate code for user actions'
  'open:open page in browser'
  'install:install browsers'
  'install-deps:install system dependencies'
  'screenshot:capture a screenshot'
  'pdf:save page as pdf'
  'show-trace:show trace viewer'
  'merge-reports:merge multiple blob reports'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'playwright command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (test)
        _arguments -s -S \
          '--browser=[browser to use]:browser:(chromium firefox webkit)' \
          '--config=[path to config file]:config file:_files' \
          '--debug[run tests with Playwright Inspector]' \
          '--forbid-only[fail if test.only is called]' \
          '--fully-parallel[run all tests in parallel]' \
          '--global-timeout=[maximum time in ms for the whole test suite]:timeout' \
          '--grep=[only run tests matching this regex]:pattern' \
          '--grep-invert=[only run tests not matching this regex]:pattern' \
          '--headed[run tests in headed browsers]' \
          '--ignore-snapshots[ignore screenshot and snapshot expectations]' \
          '--last-failed[only re-run failures]' \
          '--list[list all tests without running]' \
          '--max-failures=[stop after specified number of failures]:count' \
          '--no-deps[do not run project dependencies]' \
          '--output=[directory for artifacts]:directory:_directories' \
          '--pass-with-no-tests[allow the suite to pass when no tests found]' \
          '--project=[only run tests from specified projects]:project' \
          '--quiet[suppress stdio]' \
          '--repeat-each=[run each test N times]:count' \
          '--reporter=[reporter to use]:reporter:(dot line list json html blob junit github)' \
          '--retries=[maximum retry count for flaky tests]:count' \
          '--shard=[shard tests (e.g. 1/3)]:shard' \
          '--timeout=[maximum timeout in ms for each test]:timeout' \
          '--trace=[force tracing mode]:mode:(on off retain-on-failure)' \
          '--ui[run tests in interactive UI mode]' \
          '--ui-host=[host for UI mode server]:host' \
          '--ui-port=[port for UI mode server]:port' \
          '-u[update snapshots with actual results]' \
          '--update-snapshots[update snapshots with actual results]' \
          '-j+[number of concurrent workers]:workers' \
          '--workers=[number of concurrent workers]:workers' \
          '-x[stop on first failure]' \
          '*:test files:_files' && ret=0
        ;;
      (codegen)
        _arguments -s -S \
          '-o+[saves the generated script to a file]:output file:_files' \
          '--output=[saves the generated script to a file]:output file:_files' \
          '--target=[language to generate]:language:(javascript typescript python python-async csharp java)' \
          '--browser=[browser to use]:browser:(chromium firefox webkit)' \
          '--channel=[chromium channel]:channel' \
          '--color-scheme=[color scheme]:scheme:(light dark no-preference)' \
          '--device=[emulate a device]:device' \
          '--geolocation=[specify geolocation]:coordinates' \
          '--ignore-https-errors[ignore https errors]' \
          '--load-storage=[load context storage state]:file:_files' \
          '--locale=[specify locale]:locale' \
          '--proxy-server=[specify proxy server]:proxy' \
          '--save-storage=[save context storage state]:file:_files' \
          '--timezone=[specify timezone]:timezone' \
          '--viewport-size=[specify viewport size]:size' \
          '*:url' && ret=0
        ;;
      (install)
        _arguments -s -S \
          '--with-deps[install system dependencies]' \
          '--force[force reinstall of browsers]' \
          '--dry-run[do not execute, print actions]' \
          '*:browser:(chromium firefox webkit msedge chrome)' && ret=0
        ;;
      (show-report)
        _arguments -s -S \
          '--host=[host to serve report on]:host' \
          '--port=[port to serve report on]:port' \
          '1:report path:_directories' && ret=0
        ;;
      (show-trace)
        _arguments '1:trace file:_files' && ret=0
        ;;
      (screenshot|pdf)
        _arguments -s -S \
          '--browser=[browser to use]:browser:(chromium firefox webkit)' \
          '--channel=[chromium channel]:channel' \
          '--color-scheme=[color scheme]:scheme:(light dark)' \
          '--device=[emulate a device]:device' \
          '--full-page[capture a full page screenshot]' \
          '--ignore-https-errors[ignore https errors]' \
          '--viewport-size=[specify viewport size]:size' \
          '--wait-for-selector=[wait for selector before screenshot]:selector' \
          '--wait-for-timeout=[wait for timeout in ms]:timeout' \
          '-o+[output file]:file:_files' \
          '1:url' && ret=0
        ;;
    esac
    ;;
esac

return ret
