#compdef gcc-ar-11
# Documentation: https://man.archlinux.org/search?q=gcc-ar-11
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--target[- specify the target object format as BFDNAME]'
  '--output[- specify the output directory for extraction operations]'
  '--record-libdeps[- specify the dependencies of this library]'
  '--plugin[- load the specified plugin]'
  '*:filename:_files'
)

_arguments -s -S $arguments
