#compdef iprconfig
# Documentation: https://man.archlinux.org/search?q=iprconfig
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-k[kernel messages root directory]'
  '-c[command line configuration]'
  '--version[print iprconfig version]'
  '--debug[enable additional error logging]'
  '--force[disable safety checks. See man page for details.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
