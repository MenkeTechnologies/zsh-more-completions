#compdef php

_php() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '-a[run as interactive shell (requires readline extension)]' \
    '-c+[look for php.ini file in this directory or file]:config path:_files' \
    '-n[no configuration (ini) files will be used]' \
    '*-d+[define INI entry foo with value bar]:INI entry (foo=bar):' \
    '-e[generate extended information for debugger/profiler]' \
    '-f+[parse and execute file]:PHP script:_files -g "*.php(-.)"' \
    '-h[display help information]' \
    '-i[display PHP information (phpinfo)]' \
    '-l[syntax check only (lint)]' \
    '-m[show compiled-in modules]' \
    '-r+[run PHP code without using script tags]:PHP code:' \
    '-B+[run PHP code before processing input lines]:begin code:' \
    '-R+[run PHP code for every input line]:line code:' \
    '-F+[parse and execute file for every input line]:PHP file:_files -g "*.php(-.)"' \
    '-E+[run PHP code after processing all input lines]:end code:' \
    '-H[hide any passed arguments from external tools]' \
    '-S+[run with built-in web server]:address and port (addr\:port):' \
    '-t+[specify document root for built-in web server]:document root:_directories' \
    '-s[output HTML syntax highlighted source]' \
    '-v[display version number]' \
    '-w[output source with stripped comments and whitespace]' \
    '-z+[load Zend extension file]:Zend extension:_files -g "*.so(-.)"' \
    '--ini[show configuration file names]' \
    '--rf+[show information about function]:function name:' \
    '--rc+[show information about class]:class name:' \
    '--re+[show information about extension]:extension name:' \
    '--rz+[show information about Zend extension]:Zend extension name:' \
    '--ri+[show configuration for extension]:extension name:' \
    '--repeat+[repeat script execution count times]:count:' \
    '(-)*--[end of options, start of script arguments]' \
    '1:PHP script:_files -g "*.php(-.)"' \
    '*:script arguments:_files' && ret=0

  return ret
}

_php "$@"
