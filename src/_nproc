#compdef nproc

# Completion for nproc (print the number of processing units)

local -a arguments

arguments=(
  '(- *)--help[display help information and exit]'
  '(- *)--version[output version information and exit]'

  '--all[print the number of installed processors, ignoring OMP environment variables and CPU quotas]'
  '--ignore=[if possible, exclude N processing units (result is at least 1)]:number of CPUs to ignore'
)

_arguments -s -S $arguments
