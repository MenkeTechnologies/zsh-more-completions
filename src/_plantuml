#compdef plantuml

# Zsh completion for PlantUML - UML diagram generator

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-tpng[generate PNG images]' \
  '-tsvg[generate SVG images]' \
  '-teps[generate EPS images]' \
  '-tpdf[generate PDF images]' \
  '-ttxt[generate ASCII art]' \
  '-tutxt[generate ASCII art using Unicode]' \
  '-thtml[generate HTML output]' \
  '-tlatex[generate LaTeX output]' \
  '-charset[specify character encoding]:charset:' \
  '-o[output directory]:output directory:_files -/' \
  '-config[include config file before each diagram]:config file:_files' \
  '*-I[include file or directory]:include path:_files' \
  '-darkmode[use dark mode]' \
  '-verbose[enable verbose output]' \
  '-version[display version information]' \
  '-help[display help]' \
  '-testdot[test Graphviz installation]' \
  '-graphvizdot[path to Graphviz dot executable]:dot path:_files' \
  '-pipe[read diagram from stdin]' \
  '-pipeimageindex[specify image index in pipe mode]:index:' \
  '-pipemap[output image map in pipe mode]' \
  '-syntax[report syntax errors]' \
  '-checkonly[check syntax only]' \
  '-failfast[stop at first error]' \
  '-failfast2[stop at first error and return error code]' \
  '-pattern[print pattern definition]' \
  '-duration[print duration of generation]' \
  '-nbthread[number of threads]:thread count:' \
  '-timeout[set processing timeout]:timeout seconds:' \
  '-gui[run graphical user interface]' \
  '-progress[display progress bar]' \
  '-nometadata[do not include metadata in output]' \
  '-nosuggestengine[do not suggest alternative rendering engines]' \
  '*:file:_files' && ret=0

return ret
