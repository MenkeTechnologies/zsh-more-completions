#compdef gtkdoc-mkdb

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  '--version[show programs version number and exit]'
  '--module[name of the doc module being parsed]'
  '--source-dir[source directory]:directory:_directories'
  '--source-suffixes[source file suffixes]:suffixes:'
  '--ignore-files[files to ignore]:files:'
  '--output-dir[output directory]:directory:_directories'
  '--tmpl-dir[DEPRECATED - template directory]:directory:_directories'
  '--main-sgml-file[main SGML/XML file]:file:_files'
  '--expand-content-files[files to expand content from]:files:'
  '--sgml-mode[use SGML mode]'
  '--xml-mode[use XML mode]'
  '--default-stability[set default stability level]:stability:(Stable Private Unstable)'
  '--default-includes[default include headers]:includes:'
  '--output-format[output format]:format:'
  '--name-space[library namespace]:namespace:'
  '--outputallsymbols[output all symbols]'
  '--outputsymbolswithoutsince[output symbols without since tag]'
  '*:filename:_files'
)

_arguments -s -S $arguments
