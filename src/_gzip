#compdef gzip

local arguments

arguments=(
  '(-1 -2 -3 -4 -5 -6 -7 -8 -9 --fast --best)'{-1,--fast}'[compress faster]'
  '(-1 -2 -3 -4 -5 -6 -7 -8 -9 --fast --best)-2[compression level 2]'
  '(-1 -2 -3 -4 -5 -6 -7 -8 -9 --fast --best)-3[compression level 3]'
  '(-1 -2 -3 -4 -5 -6 -7 -8 -9 --fast --best)-4[compression level 4]'
  '(-1 -2 -3 -4 -5 -6 -7 -8 -9 --fast --best)-5[compression level 5]'
  '(-1 -2 -3 -4 -5 -6 -7 -8 -9 --fast --best)-6[compression level 6 (default)]'
  '(-1 -2 -3 -4 -5 -6 -7 -8 -9 --fast --best)-7[compression level 7]'
  '(-1 -2 -3 -4 -5 -6 -7 -8 -9 --fast --best)-8[compression level 8]'
  '(-1 -2 -3 -4 -5 -6 -7 -8 -9 --fast --best)'{-9,--best}'[compress better (slowest)]'
  {-a,--ascii}'[ascii text mode: convert end-of-lines using local conventions]'
  {-c,--stdout,--to-stdout}'[write on standard output, keep original files unchanged]'
  {-d,--decompress,--uncompress}'[decompress]'
  {-f,--force}'[force overwrite of output file and compress links]'
  '(- * :)'{-h,--help}'[display help and exit]'
  {-k,--keep}'[keep (do not delete) input files]'
  {-l,--list}'[list compressed file contents]'
  {-L,--license}'[display software license]'
  {-n,--no-name}'[do not save or restore the original name and timestamp]'
  {-N,--name}'[save or restore the original name and timestamp]'
  {-q,--quiet}'[suppress all warnings]'
  {-r,--recursive}'[operate recursively on directories]'
  '--rsyncable[make rsync-friendly archive]'
  {-S+,--suffix}'[use specified suffix on compressed files]:suffix'
  '--synchronous[synchronous output (safer if system crashes, but slower)]'
  {-t,--test}'[test compressed file integrity]'
  {-v,--verbose}'[verbose mode]'
  {-V,--version}'[display version number]'
  '*:file:_files'
)

_arguments -s -S $arguments
