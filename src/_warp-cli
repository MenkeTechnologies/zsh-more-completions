#compdef warp-cli

# Zsh completion for warp-cli - Cloudflare WARP client

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'connect:connect to Cloudflare WARP'
  'disconnect:disconnect from Cloudflare WARP'
  'disable-wifi-detection:disable WiFi detection'
  'enable-wifi-detection:enable WiFi detection'
  'get-excluded-hosts:get excluded split tunnel hosts'
  'get-excluded-routes:get excluded split tunnel routes'
  'get-included-hosts:get included split tunnel hosts'
  'get-included-routes:get included split tunnel routes'
  'get-mode:get current WARP mode'
  'get-organization:get the organization name'
  'get-pause-end:get time when WARP will unpause'
  'get-stats:get connection statistics'
  'get-virtual-networks:get available virtual networks'
  'mode:set WARP mode'
  'registration:manage WARP registration'
  'resolve:resolve a hostname via DoH'
  'set-custom-endpoint:set a custom WARP endpoint'
  'clear-custom-endpoint:clear custom WARP endpoint'
  'set-families-mode:set Cloudflare Families mode'
  'get-families-mode:get Cloudflare Families mode'
  'set-gateway-unique-id:set Zero Trust organization'
  'set-mode:set WARP mode'
  'set-proxy-port:set local proxy port'
  'settings:show current settings'
  'status:show WARP connection status'
  'warp-stats:show WARP tunnel statistics'
  'account:show account information'
  'teams-enroll:enroll in Cloudflare Zero Trust'
  'teams-enroll-token:enroll using a service token'
  'dns:manage DNS settings'
  'override:manage local policy overrides'
  'tunnel:manage WARP tunnel'
  'debug:debug utilities'
  'help:show help information'
)

_arguments -s -S \
  '1:subcommand:->subcmd' \
  '*::args:->args' \
  '--accept-tos[accept the Terms of Service]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'warp-cli subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (mode|set-mode)
        _arguments '1:mode:(warp doh warp+doh proxy dot)' && ret=0
        ;;
      (set-families-mode)
        _arguments '1:mode:(off malware full)' && ret=0
        ;;
      (set-custom-endpoint)
        _arguments '1:endpoint (host\:port):' && ret=0
        ;;
      (set-proxy-port)
        _arguments '1:port:' && ret=0
        ;;
      (set-gateway-unique-id|teams-enroll)
        _arguments '1:organization name:' && ret=0
        ;;
      (teams-enroll-token)
        _arguments '1:token:' && ret=0
        ;;
      (resolve)
        _arguments '1:hostname:' && ret=0
        ;;
      (registration)
        _arguments '1:action:(show new delete)' && ret=0
        ;;
    esac
    ;;
esac

return ret
