#compdef ibnetdiscover


local -a arguments

arguments=(
    {--outstanding_smps,-o}'[specify the number of outstanding SMPs to issue during the scan]':val
    {-y,--m_key}'[use the specified M_key for requests.]':key
    '-d[raise the IB debugging level. May be used several times (-ddd or -d -d -d).]'
    '-e[show send and receive errors (timeouts and others).]'
    {-v,--verbose}'[increase the application verbosity level.]'
    {-l,--list}'[List of connected nodes.]'
    {-g,--grouping}'[Show grouping.]'
    {-H,--Hca_list}'[List of connected CAs.]'
    {-S,--Switch_list}'[List of connected switches.]'
    {-R,--Router_list}'[List of connected routers.]'
    {-s,--show}'[Show progress information during discovery.]'
    {-f,--full}'[Show full information (ports\ speed and width, vlcap).]'
    {-p,--ports}'[obtain a ports report with relevant information]'
    {-m,--max_hops}'[Report max hops discovered.]'
    '--cache[Cache the ibnetdiscover network data in the specified filename.]:filename'
    '--load-cache[Load and use the cached ibnetdiscover data stored in the specified filename.]:filename'
    '--diff[load cached data and do a diff comparison to the current network]:filename'
    '--diffcheck[Specify what diff checks should be done in the --diff option above.]:key(s)'
    {-C,--Ca}'[use specified CA]:ca name'
    {-P,--Port}'[use specified port]:port number'
    {--config,-z}'[use specified config file]:config file:_files'
    '--node-name-map[specify node name map file]:filename:_files'
    {-t,--timeout}'[set timeout in milliseconds]:timeout'
    {-h,--help}'[show help]'
    {-V,--version}'[show version]'
    '*:filename:_files'
)
_arguments -s -S $arguments
