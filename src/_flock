#compdef flock

# flock - manage locks from shell scripts
# Part of util-linux

_arguments -s -S \
  '(-x --exclusive -u --unlock)'{-s,--shared}'[obtain a shared lock]' \
  '(-s --shared -u --unlock)'{-x,--exclusive}'[obtain an exclusive lock (default)]' \
  '(-s --shared -x --exclusive)'{-u,--unlock}'[remove a lock]' \
  {-n,--nonblock}'[fail rather than wait for the lock]' \
  {-w,--timeout}'[fail if the lock cannot be acquired within specified seconds]:seconds' \
  {-E,--conflict-exit-code}'[exit code to use when -n or -w results in conflict]:exit code' \
  {-o,--close}'[close the file descriptor before running the command]' \
  {-c,--command}'[execute a single command string through the shell]:command string' \
  {-F,--no-fork}'[execute command without forking]' \
  '--verbose[increase verbosity]' \
  '(- *)'{-h,--help}'[display help text and exit]' \
  '(- *)'{-V,--version}'[display version information and exit]' \
  '1:lock file:_files' \
  '*:command:_command_names -e'
