#compdef lsd

# Zsh completion for lsd - ls with a lot of pretty colors and some other stuff

_arguments -s -S \
  '(-a --all)'{-a,--all}'[do not ignore entries starting with .]' \
  '(-A --almost-all)'{-A,--almost-all}'[do not list implied . and ..]' \
  '--classic[enable classic mode (display output similar to ls)]' \
  '--color[when to use terminal colors]:mode:(always auto never)' \
  '--config-file[provide a custom config file]:file:_files' \
  '(-d --directory-only)'{-d,--directory-only}'[only list directories]' \
  '--blocks[specify the blocks to display in order]:blocks:(permission user group context size date name inode links git)' \
  '--date[how to display date]:mode:(relative +date date)' \
  '--depth[stop recursing into directories after given number]:N:' \
  '--dereference[when showing file information, dereference symbolic links]' \
  '(-F --classify)'{-F,--classify}'[append indicator (one of */=>@|) to entries]' \
  '--format[specify the layout mode for the terminal]:mode:(oneline grid tree across commas)' \
  '--git[show git status on file and directory]' \
  '--git-repos[show git status of repositories]' \
  '--git-repos-no-status[show git status of repositories without status]' \
  '--group-dirs[sort the directories then the files]:mode:(none first last)' \
  '--group-dirs[group directories and files]:mode:(none first last)' \
  '(-h --human-readable)'{-h,--human-readable}'[display file sizes in human-readable format]' \
  '--hyperlink[attach hyperlinks to file names]:mode:(always auto never)' \
  '--header[display column headers]' \
  '(-I --ignore-glob)'{-I,--ignore-glob}'[do not list entries matching given glob pattern]:glob:' \
  '--icon[when to print glyphs]:mode:(always auto never)' \
  '--icon-theme[use the given icon theme]:theme:(fancy unicode)' \
  '(-i --inode)'{-i,--inode}'[display the index number of each file]' \
  '(-l --long)'{-l,--long}'[use long format]' \
  '(-1 --oneline)'{-1,--oneline}'[display one entry per line]' \
  '(-R --recursive)'{-R,--recursive}'[recurse into directories]' \
  '(-r --reverse)'{-r,--reverse}'[reverse order while sorting]' \
  '(-S --sizesort)'{-S,--sizesort}'[sort by file size, largest first]' \
  '--total-size[display the total size of directories]' \
  '--ignore-config[ignore the configuration file]' \
  '(-s --size)'{-s,--size}'[how to display size]:format:(default bytes short)' \
  '--sort[sort by WORD]:WORD:(size time version extension git name none)' \
  '(-t --timesort)'{-t,--timesort}'[sort by time, newest first]' \
  '--tree[recurse into directories as a tree]' \
  '--version-sort[natural sort of numbers within text]' \
  '-v[natural sort of (version) numbers within text]' \
  '(-X --extensionsort)'{-X,--extensionsort}'[sort alphabetically by entry extension]' \
  '-Z[print any security context of each file]' \
  '--context[print any security context of each file]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:file:_files'
