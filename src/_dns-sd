#compdef dns-sd

local -a arguments

arguments=(
    '-E[Enumerate recommended registration/browsing domains]'
    '-F[Enumerate recommended registration/browsing domains (find)]'
    '-B[Browse for service instances]:service type:(_values "service type" _tcp._local. _http._tcp. _ssh._tcp. _ftp._tcp. _smb._tcp. _afpovertcp._tcp. _printer._tcp. _ipp._tcp. _airplay._tcp. _raop._tcp.):domain'
    '-L[Look up a service instance]:service name:service type:domain'
    '-R[Register a service]:service name:service type:domain:port'
    '-P[Register a service with a proxy]:service name:service type:domain:port:host'
    '-Q[Query for any DNS record]:name:record type:(A AAAA SRV TXT PTR CNAME MX NS SOA ANY):record class'
    '-Z[Browse and display as zone file]:service type:domain'
    '-G[Get address information]:protocol:(v4 v6 v4v6):name'
    '-V[Get version]'
    '-C[Query with DNS class]:name:record type:record class'
    '-T[Test mode]'
    '-M[Discover services via multicast]'
    '-I[Discover services in interface]:interface:_net_interfaces'
    '-lo[Use local only interface]'
    '-p2p[Use peer-to-peer interface]'
    '-includeP2P[Include peer-to-peer interfaces]'
    '-includeAWDL[Include AWDL interface]'
    '-timeout[Set timeout]:timeout in seconds'
)

_arguments -s -S $arguments
