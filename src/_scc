#compdef scc

# Zsh completion for scc - count lines of code

_arguments -s -S \
  '(-a --avg-wage)'{-a,--avg-wage}'[average wage in dollars per year]:dollars:' \
  '--binary[disable binary file detection]' \
  '--by-file[display output for every file]' \
  '--ci[enable CI output format]' \
  '--cocomo-project-type[COCOMO project type]:type:(organic semi-detached embedded)' \
  '--count-as[count extension as another language]:ext\:language:' \
  '--currency-symbol[currency symbol]:symbol:' \
  '--debug[enable debug output]' \
  '--exclude-ext[exclude files with this extension]:extension:' \
  '--exclude-dir[exclude directories matching this pattern]:directory:_files -/' \
  '(-f --format)'{-f,--format}'[output format]:format:(tabular wide json csv html sql)' \
  '(-z --format-multi-line)'{-z,--format-multi-line}'[enable multiline output format]' \
  '(-i --include-ext)'{-i,--include-ext}'[only include files with this extension]:extension:' \
  '(-l --languages)'{-l,--languages}'[print all supported languages and exit]' \
  '--large-byte-count[files this size in bytes will be considered large]:bytes:' \
  '--large-line-count[files with this many lines will be considered large]:N:' \
  '(-m --mix-duplication)'{-m,--mix-duplication}'[include duplicate files in totals]' \
  '--no-cocomo[remove COCOMO calculation]' \
  '--no-complexity[skip code complexity calculations]' \
  '--no-duplicates[ignore duplicate files]' \
  '--no-gen[ignore generated files]' \
  '--no-gitignore[ignore gitignore files]' \
  '--no-ignore[ignore .ignore files]' \
  '--no-min-gen[do not attempt to identify minified or generated files]' \
  '--no-size[remove size from output]' \
  '(-o --output)'{-o,--output}'[output filename]:file:_files' \
  '(-p --percent)'{-p,--percent}'[print percentage of code/comment/blank]' \
  '--remap-all[remaps all extensions to this language]:language:' \
  '--remap-unknown[remaps unknown extensions to this language]:language:' \
  '--size-unit[size display unit]:unit:(si binary)' \
  '(-s --sort)'{-s,--sort}'[column to sort by]:column:(files lines blanks code comments complexity)' \
  '(-t --trace)'{-t,--trace}'[enable trace output (very verbose)]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--version[display version]' \
  '(-w --wide)'{-w,--wide}'[wider output with additional information]' \
  '(-h --help)'{-h,--help}'[print help]' \
  '*:directory or file:_files'
