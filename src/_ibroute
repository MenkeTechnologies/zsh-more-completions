#compdef ibroute


local -a arguments

arguments=(
    {-a,--all}'[show all lids in range, even invalid entries.]'
    {-n,--no_dests}'[do not try to resolve destinations.]'
    {-M,--Multicast}'[show multicast forwarding tables]'
    '-d[raise the IB debugging level. May be used several times (-ddd or -d -d -d).]'
    '-e[show send and receive errors (timeouts and others).]'
    {-v,--verbose}'[increase the application verbosity level.]'
    {-y,--m_key}'[use the specified M_key for requests.]':key
    {-D,--Direct}'[use direct route addressing]'
    {-G,--Guid}'[use GUID address]'
    {-L,--Lid}'[use LID address]'
    {-s,--sm_port}'[use specified SM port]:smlid'
    {-C,--Ca}'[use specified CA]:ca name'
    {-P,--Port}'[use specified port]:port number'
    {-h,--help}'[show help]'
    {-V,--version}'[show version]'
    {-t,--timeout}'[set timeout in milliseconds]:timeout'
    '--node-name-map[specify node name map file]:filename:_files'
    {--config,-z}'[use specified config file]:config file:_files'
    '*:filename:_files'
)
_arguments -s -S $arguments
