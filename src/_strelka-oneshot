#compdef strelka-oneshot
# Documentation: https://man.archlinux.org/search?q=strelka-oneshot
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-c[path to connection certificate]'
  '-f[file to submit for scanning]'
  '-l[path to response log file (default "strelka-oneshot.log")]'
  '-s[url for the strelka frontend server (default "127.0.0.1:57314")]'
  '*:filename:_files'
)

_arguments -s -S $arguments
