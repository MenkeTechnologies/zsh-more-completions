#compdef ghost-inspector
# Documentation: https://man.archlinux.org/search?q=ghost-inspector
# Reference accessed: 2026-05-16

# Zsh completion for ghost-inspector (automated browser testing)

local -a commands
commands=(
  'test:Manage tests'
  'suite:Manage suites'
  'folder:Manage folders'
  'test-result:Manage test results'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[Print help message]' \
  '--apiKey=[Your API key]:key:' \
  '--json[Return output in JSON format]' \
  '1: :_describe -t commands "command" commands' \
  '*:: :->args'

case $words[1] in
  test)
    local -a test_cmds
    test_cmds=('execute' 'list')
    _arguments \
      '1: :_describe -t test_cmds "test command" test_cmds' \
      '--browser=[Specify browser]:browser:(chrome firefox)' \
      '--region=[Specify region]:region:(us-east-1 us-west-1 eu-central-1)' \
      '--immediate[Return immediately]' \
      '--errorOnFail[Error on failure]'
    ;;
  suite)
    local -a suite_cmds
    suite_cmds=('execute' 'list')
    _arguments \
      '1: :_describe -t suite_cmds "suite command" suite_cmds'
    ;;
  folder)
    _arguments '1:command:(list)'
    ;;
  test-result)
    _arguments '1:command:(get)'
    ;;
esac
