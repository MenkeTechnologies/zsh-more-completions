#compdef texliveonfly

local -a arguments

arguments=(
  '--version[show programs version number and exit]'
  '(- * :)'{-h,--help}'[print this help text and exit]'
  {-c,--compiler}'[your LaTeX compiler; defaults to pdflatex]'
  {-a,--arguments}'[arguments to pass to compiler]:args:'
  '--texlive_bin[location of TeX Live binaries]:location:_directories'
  '--terminal_only[force running only in this terminal]'
  {-s,--speech_when}'[when to use speech output]:option:'
  {-f,--fail_silently}'[if tlmgr cannot be found, compile document anyway]'
  '*:filename:_files'
)

_arguments -s -S $arguments
