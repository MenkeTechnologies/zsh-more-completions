#compdef just

# Zsh completion for just (command runner)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '--check[Run --fmt in check mode]' \
  '--chooser=[Override binary invoked by --choose]:chooser program' \
  '--choose[Select one or more recipes to run using a chooser]' \
  '--clear-shell-args[Clear shell arguments]' \
  '--color=[Print colorful output]:color:(auto always never)' \
  '--command=[Run an arbitrary command with the working directory and dotenv]:command' \
  '--command-color=[Echo recipe lines in specified color]:color:(black blue cyan green purple red yellow)' \
  '--completions=[Print shell completion script]:shell:(zsh bash fish powershell elvish)' \
  '--dotenv-filename=[Search for additional dotenv file]:filename:_files' \
  '--dotenv-path=[Load additional dotenv file at path]:path:_files' \
  '-n[Print what just would do without doing it]' \
  '--dry-run[Print what just would do without doing it]' \
  '--dump[Print justfile]' \
  '--dump-format=[Dump justfile in given format]:format:(just json)' \
  '-e[Edit justfile with editor given by $VISUAL or $EDITOR]' \
  '--edit[Edit justfile with editor given by $VISUAL or $EDITOR]' \
  '--evaluate[Evaluate and print all variables]' \
  '-f+[Use specified justfile]:justfile:_files' \
  '--justfile=[Use specified justfile]:justfile:_files' \
  '--fmt[Format and overwrite justfile]' \
  '--global-justfile[Use global justfile]' \
  '--highlight[Highlight echoed recipe lines in bold]' \
  '--init[Initialize new justfile in project root]' \
  '-l[List available recipes and their arguments]' \
  '--list[List available recipes and their arguments]' \
  '--list-heading=[Print heading before list]:heading' \
  '--list-prefix=[Print prefix before each item in list]:prefix' \
  '--list-submodules[List recipes in submodules]' \
  '--no-aliases[Do not print aliases in list]' \
  '--no-deps[Do not run recipe dependencies]' \
  '--no-dotenv[Do not load .env file]' \
  '--no-highlight[Do not highlight echoed recipe lines]' \
  '-q[Suppress all output]' \
  '--quiet[Suppress all output]' \
  '--set=[Override variable with value]:assignment' \
  '--shell=[Invoke specified shell to run recipes]:shell' \
  '--shell-arg=[Invoke shell with specified argument to run recipes]:arg' \
  '--shell-command[Invoke --command with the shell used to run recipe lines]' \
  '-s+[Show information about specified recipe]:recipe' \
  '--show=[Show information about specified recipe]:recipe' \
  '--summary[List names of available recipes]' \
  '--unsorted[Do not sort output of --list]' \
  '--unstable[Enable unstable features]' \
  '-u[Return list and summary entries in source order]' \
  '-v[Use verbose output]' \
  '--verbose[Use verbose output]' \
  '-V[Print version information]' \
  '--version[Print version information]' \
  '-d+[Use specified working directory]:dir:_directories' \
  '--working-directory=[Use specified working directory]:dir:_directories' \
  '--yes[Automatically confirm all recipes]' \
  '*:: :->recipes' && ret=0

case $state in
  recipes)
    local -a recipes
    recipes=( ${(f)"$(just --summary --unsorted 2>/dev/null)"} )
    if [[ -n "$recipes" ]]; then
      _describe -t recipes 'recipe' recipes && ret=0
    fi
    ;;
esac

return ret
