#compdef pacscripts
# Documentation: https://man.archlinux.org/search?q=pacscripts
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[print this help message]'
  {-v,--version}'[print program name and version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
