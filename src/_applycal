#compdef applycal
# Documentation: https://man.archlinux.org/search?q=applycal
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-v[verbose mode]'
  '-a[apply or re-apply calibration (default)]'
  '-u[remove calibration]'
  '-c[check calibration]'
  '*:filename:_files'
)

_arguments -s -S $arguments
