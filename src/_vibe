#compdef vibecoding vibe

# Zsh completion for vibecoding / vibe (AI-driven prototyping CLI)

local -a commands
commands=(
  'init:Initialize a new project'
  'create:Generate code from natural language'
  'plan:Generate an implementation plan'
  'run:Execute the project'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[Print help message]' \
  '1: :_describe -t commands "command" commands' \
  '*:: :->args'
