#compdef instantfpc
# Documentation: https://man.archlinux.org/search?q=instantfpc
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--set-cache[to cache>]'
  '--compiler[to compiler>]'
  '--skip-run[do not execute the program. Useful to test if script compiles.]'
  '-B[always recompile.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
