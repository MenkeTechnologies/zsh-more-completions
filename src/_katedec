#compdef katedec
# Documentation: https://man.archlinux.org/search?q=katedec
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-V[version]'
  '-v[verbose]'
  '-h[help]'
  '-o[set output filename]'
  '-t[set output format (kate (default), srt, lrc)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
