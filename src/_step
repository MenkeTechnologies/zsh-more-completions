#compdef step

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'certificate:manage certificates'
      'ca:manage step CA'
      'ssh:manage SSH certificates'
      'oauth:OAuth authentication'
      'crypto:cryptographic operations'
      'path:print path to step config'
      'context:manage step contexts'
      'api:API commands'
      'beta:beta commands'
      'completion:generate shell completion'
      'version:print version'
    )
    _describe -t commands 'step command' commands && ret=0
    ;;
  args)
    case $words[1] in
      certificate)
        _arguments -s -S -C \
          '1:subcommand:->cert_cmds' \
          '*::cert_arg:->cert_args' && ret=0
        case $state in
          cert_cmds)
            local -a cert_commands=(
              'create:create a certificate or CSR'
              'inspect:inspect a certificate'
              'verify:verify a certificate'
              'bundle:bundle certificates'
              'install:install a root certificate'
              'uninstall:uninstall a root certificate'
              'fingerprint:print certificate fingerprint'
              'lint:lint a certificate'
              'format:format a certificate'
              'needs-renewal:check if certificate needs renewal'
              'sign:sign a certificate'
              'p12:create PKCS#12 file'
              'key:manage certificate keys'
            )
            _describe -t commands 'certificate command' cert_commands && ret=0
            ;;
          cert_args)
            _arguments -s -S \
              '--ca=[CA certificate]:ca:_files' \
              '--ca-key=[CA key]:key:_files' \
              '--profile=[certificate profile]:profile' \
              '--not-before=[not before time]:time' \
              '--not-after=[not after time]:time' \
              '--san=[subject alternative name]:san' \
              '--kty=[key type]:kty:(EC OKP RSA)' \
              '--size=[key size]:size' \
              '--crv=[elliptic curve]:curve:(P-256 P-384 P-521 Ed25519)' \
              '--no-password[do not prompt for password]' \
              '--insecure[use insecure options]' \
              '*:file:_files' \
              && ret=0
            ;;
        esac
        ;;
      ca)
        _arguments -s -S -C \
          '1:subcommand:->ca_cmds' \
          '*::ca_arg:->ca_args' && ret=0
        case $state in
          ca_cmds)
            local -a ca_commands=(
              'health:check CA health'
              'token:generate CA token'
              'certificate:create a certificate'
              'renew:renew a certificate'
              'rekey:rekey a certificate'
              'revoke:revoke a certificate'
              'provisioner:manage provisioners'
              'admin:manage admins'
              'roots:download root certificates'
              'federation:download federation certificates'
              'sign:sign a certificate'
              'init:initialize a CA'
              'bootstrap:bootstrap CA configuration'
              'policy:manage policies'
            )
            _describe -t commands 'ca command' ca_commands && ret=0
            ;;
          ca_args)
            _arguments -s -S \
              '--ca-url=[CA URL]:url' \
              '--root=[root certificate]:root:_files' \
              '--token=[auth token]:token' \
              '--provisioner=[provisioner name]:provisioner' \
              '--offline[create certificate offline]' \
              '*:file:_files' \
              && ret=0
            ;;
        esac
        ;;
      completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
