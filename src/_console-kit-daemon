#compdef console-kit-daemon
# Documentation: https://man.archlinux.org/search?q=console-kit-daemon
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  '--debug[enable debugging code]'
  '--no-daemon[dont become a daemon]'
  '--timed-exit[exit after a time - for debugging]'
  '*:filename:_files'
)

_arguments -s -S $arguments
