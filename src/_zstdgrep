#compdef zstdgrep

local -a arguments

arguments=(
    '-c[count matching lines]'
    '-h[suppress filename prefix]'
    '-i[case insensitive]'
    '-l[list matching files]'
    '-n[show line numbers]'
    '-v[invert match]'
    '-e[specify pattern]:pattern'
    '-G[use basic regular expressions]'
    '-E[use extended regular expressions]'
    '-F[use fixed strings]'
    '-P[use Perl regular expressions]'
    '--color=[color output]:(auto always never)'
    '1:pattern:'
    '*:zstd file:_files -g "*.{zst,zstd}"'
)

_arguments -s -S $arguments
