#compdef autorandr
# Zsh completion for autorandr - Automatically select display configuration
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-s --save)'{-s,--save}'[save current configuration as profile]:profile name:' \
  '(-c --change)'{-c,--change}'[automatically load appropriate profile]' \
  '(-l --load)'{-l,--load}'[load a specific profile]:profile name:' \
  '(-d --default)'{-d,--default}'[set default profile]:profile name:' \
  '--list[list all profiles]' \
  '--current[list current profile]' \
  '--config[dump current xrandr configuration]' \
  '--dry-run[show what would be done]' \
  '--force[force loading of a profile]' \
  '--detected[list detected profiles]' \
  '--fingerprint[show fingerprint of current setup]' \
  '--skip-options[set xrandr options to skip]:options:' \
  '--ignore-lid[treat lid as open]' \
  '--match-edid[match profiles by EDID data]' \
  '--batch[run autorandr for all users]' \
  '(- *)--version[show version]' \
  '(- *)--help[show help information]' \
  '*:profile:' && ret=0
return ret
