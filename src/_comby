#compdef comby

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-match-only[only show matches, do not rewrite]' \
  '-count[show match count only]' \
  '-json-lines[output results as JSON lines]' \
  '-json-only-diff[output JSON diffs only]' \
  '-stdout[print to stdout]' \
  '-in-place[rewrite files in place]' \
  '-diff[show diff output]' \
  '-color[force color output]' \
  '-no-color[disable color output]' \
  '-verbose[verbose output]' \
  '-newline-separated[patterns are newline separated]' \
  '-matcher[language matcher]:matcher:(\.go \.js \.py \.rs \.c \.java \.rb \.html \.css \.generic)' \
  '-rule[rule expression]:rule' \
  '-templates[directory containing templates]:dir:_directories' \
  '-directory[directory to search]:dir:_directories' \
  '*-extensions[file extensions to include]:extensions' \
  '-exclude[exclude pattern]:pattern' \
  '-exclude-dir[exclude directory pattern]:pattern' \
  '-jobs[number of parallel jobs]:jobs' \
  '-sequential[run sequentially]' \
  '-timeout[timeout in seconds]:seconds' \
  '-zip[search in zip files]' \
  '-review[interactive review]' \
  '-omega[use omega matcher]' \
  '1:match template' \
  '2:rewrite template' \
  '*:file or directory:_files' && ret=0

return ret
