#compdef scsi_mandat
# Documentation: https://man.archlinux.org/search?q=scsi_mandat
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-L,--log}'[append stderr to scsi_mandat.err]'
  '-q[suppress some output]'
  '-v[increase verbosity of output]'
  '*:filename:_files'
)

_arguments -s -S $arguments
