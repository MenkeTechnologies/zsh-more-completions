#compdef knip

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config}'=[path to config file]:config file:_files' \
  '--tsConfig=[path to TypeScript config]:tsconfig:_files' \
  '(-W --workspace)'{-W,--workspace}'=[lint a single workspace]:workspace' \
  '--directory=[working directory]:directory:_directories' \
  '--no-gitignore[do not use .gitignore]' \
  '--include=[report only listed issue types]:types' \
  '--exclude=[exclude listed issue types]:types' \
  '--dependencies[shortcut for --include dependencies]' \
  '--exports[shortcut for --include exports]' \
  '--files[shortcut for --include files]' \
  '--include-entry-exports[include entry file exports]' \
  '--include-libs[include exports of external libs]' \
  '--no-progress[do not show progress bar]' \
  '--reporter=[select reporter]:reporter:(symbols compact codeowners json)' \
  '--reporter-options=[reporter options]:options' \
  '--no-config-hints[suppress config hints]' \
  '--max-issues=[maximum number of issues before non-zero exit]:count' \
  '--no-exit-code[always exit with code 0]' \
  '--preprocessor=[preprocess input files]:preprocessor' \
  '--tags=[select exports with specified JSDoc tags]:tags' \
  '--fix[auto-fix issues]' \
  '--fix-type=[auto-fix only specific types]:types' \
  '--allow-remove-files[allow removing unused files with --fix]' \
  '--cache[use cache]' \
  '--cache-location=[set cache location]:directory:_directories' \
  '--debug[enable debug output]' \
  '--performance[show performance metrics]' \
  '--strict[enable strict mode]' \
  '--production[analyze production code only]' && ret=0

return ret
