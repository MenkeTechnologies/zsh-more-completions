#compdef shell-quote
# Documentation: https://man.archlinux.org/search?q=shell-quote
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--debug[turn debugging on]'
  '--help[show this and then die]'
  '--version[show the version (1.3) and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
