#compdef brltty-hid

local -a arguments

arguments=(
  {-h,--help}'[show this usage summary, and then exit.]'
  {-u,--match-usb-devices}'[filter for a USB device (the default if not ambiguous).]'
  {-b,--match-bluetooth-devices}'[filter for a Bluetooth device.]'
  {-v,--match-vendor-identifier}'[match the vendor identifier (four hexadecimal digits)]:identifier:'
  {-p,--match-product-identifier}'[match the product identifier (four hexadecimal digits)]:identifier:'
  {-m,--match-manufacturer-name}'[match the start of the manufacturer name (USB only)]:string:'
  {-d,--match-product-description}'[match the start of the product description (USB only)]:string:'
  {-s,--match-serial-number}'[match the start of the serial number (USB only)]:string:'
  {-a,--match-device-address}'[match the full device address (Bluetooth only)]:octets:'
  {-n,--match-device-name}'[match the start of the device name (Bluetooth only)]:string:'
  {-I,--show-device-identifiers}'[show the vendor and product identifiers.]'
  {-A,--show-device-address}'[show the device address (USB serial number, Bluetooth device address, etc).]'
  {-N,--show-device-name}'[show the device name (USB manufacturer and/or product strings, Bluetooth device name, etc).]'
  {-P,--show-host-path}'[show the host path (USB topology, Bluetooth host controller address, etc).]'
  {-D,--show-host-device}'[show the host device (usually its absolute path).]'
  {-l,--list-items}'[list the HID report descriptors items.]'
  {-L,--list-reports}'[list each reports identifier and sizes.]'
  {-r,--read-report}'[read (get) an input report (two hexadecimal digits)]:identifier:'
  {-R,--read-feature}'[read (get) a feature report (two hexadecimal digits)]:identifier:'
  {-w,--write-report}'[write (set) an output report]:bytes:'
  {-W,--write-feature}'[write (set) a feature report]:bytes:'
  {-e,--echo-input}'[echo (in hexadecimal) input received from the device.]'
  {-t,--input-timeout}'[the input timeout (in seconds)]:seconds:'
  '*:filename:_files'
)

_arguments -s -S $arguments
