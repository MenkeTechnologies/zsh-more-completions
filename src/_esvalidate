#compdef esvalidate
# Documentation: https://man.archlinux.org/search?q=esvalidate
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--format[set the report format, plain (default) or junit]'
  {-v,--version}'[print program version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
