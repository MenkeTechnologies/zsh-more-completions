#compdef cupsaddsmb
# Documentation: https://man.archlinux.org/search?q=cupsaddsmb
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-E[encrypt the connection.]'
  '-H[use the named SAMBA server.]'
  '-U[specify username.]'
  '-a[export all printers.]'
  '-h[specify server address.]'
  '-v[be verbose.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
