#compdef kpsepath
# Documentation: https://man.archlinux.org/search?q=kpsepath
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-n[pretend to be progname to kpathsea]'
  '-m[set Metafont mode]'
  '-w[locate files (similar to kpsewhich)]'
  '-p[act like kpsepath]'
  '-v[act like kpsexpand]'
  '*:filename:_files'
)

_arguments -s -S $arguments
