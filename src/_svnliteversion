#compdef svnliteversion
# Documentation: https://man.archlinux.org/search?q=svnliteversion
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-n[do not output the trailing newline]'
  '-c[last changed rather than current revisions]'
  '-h[display this help]'
  '--version[show program version information]'
  '-q[no progress (only errors) to stderr]'
  '*:filename:_files'
)

_arguments -s -S $arguments
