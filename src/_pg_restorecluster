#compdef pg_restorecluster


local -a arguments

arguments=(
    {-d,--datadir}'[use DIR as data directory for the restored cluster]:directory:_directories'
    {-p,--port}'[port for restored cluster (default is next free port)]:port'
    {-s,--start}'[start cluster after restoring]'
    '--archive'
    '--pitr'
    '--recovery-target-time[Additionally to setting restore_command, set recovery_target_time to TIMESTAM]'
    '--wal-archive'
    '*:filename:_files'
)
_arguments -s -S $arguments
