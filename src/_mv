#compdef mv

# Zsh completion for mv - move (rename) files
# Supports both GNU coreutils and BSD/macOS variants

local -a arguments

if [[ "$OSTYPE" == darwin* || "$OSTYPE" == freebsd* ]]; then
  # BSD/macOS variant
  arguments=(
    '(-i -n)-f[do not prompt before overwriting]'
    '(-f -n)-i[prompt before overwriting]'
    '(-f -i)-n[do not overwrite an existing file]'
    '-h[if target is a symlink to a directory, do not follow it]'
    '-v[be verbose, show files after they are moved]'
    '*:file:_files'
  )
else
  # GNU coreutils variant
  arguments=(
    '--backup=-[make a backup of each existing destination file]::method:(none off numbered t existing nil simple never)'
    '-b[like --backup but does not accept an argument]'
    '(-i -n)-f[do not prompt before overwriting]'
    {-f,--force}'[do not prompt before overwriting]'
    '(-f -n)-i[prompt before overwrite]'
    {-i,--interactive}'[prompt before overwrite]'
    '(-f -i)-n[do not overwrite an existing file]'
    {-n,--no-clobber}'[do not overwrite an existing file]'
    '--strip-trailing-slashes[remove any trailing slashes from each SOURCE argument]'
    {-S,--suffix}'=[override the usual backup suffix]:suffix: '
    {-t,--target-directory}'=[move all SOURCE arguments into DIRECTORY]:directory:_directories'
    {-T,--no-target-directory}'[treat DEST as a normal file]'
    {-u,--update}'[move only when SOURCE is newer than destination or destination is missing]'
    {-v,--verbose}'[explain what is being done]'
    {-Z,--context}'[set SELinux security context of destination file to default type]'
    '--help[display help and exit]'
    '--version[output version information and exit]'
    '*:file:_files'
  )
fi

_arguments -s -S $arguments
