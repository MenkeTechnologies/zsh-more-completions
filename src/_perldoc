#compdef perldoc

local -a arguments

arguments=(
  '-h[display this help message]'
  '-V[report version]'
  '-r[recursive search (slow)]'
  '-i[ignore case]'
  '-t[display pod using pod2text instead of Pod::Man and groff]'
  '-u[display unformatted pod text]'
  '-m[display modules file in its entirety]'
  '-n[specify replacement for groff]'
  '-l[display the modules file name]'
  '-U[dont attempt to drop privs for security]'
  '-F[arguments are file names, not modules (implies -U)]'
  '-D[verbosely describe whats going on]'
  '-T[send output to STDOUT without any pager]'
  '-d[specify destination file]'
  '-o[specify output format]'
  '-M[specify module to use]'
  '-w[set width for output]'
  '-L[choose doc translation (if any)]'
  '-X[use index if present (looks for pod.idx at /usr/lib/perl5/5.26.1/aarch64-linux-thread-multi)]'
  '-q[search the text of questions (not answers) in perlfaq\[1-9\]]'
  '-f[search Perl built-in functions]'
  '-a[search Perl API]'
  '-v[search predefined Perl variables]'
  '*:filename:_files'
)

_arguments -s -S $arguments
