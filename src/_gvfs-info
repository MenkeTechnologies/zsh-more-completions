#compdef gvfs-info

local -a arguments

arguments=(
  {-w,--query-writable}'[list writable attributes]'
  {-f,--filesystem}'[get file system info]'
  {-a,--attributes}'[the attributes to get]'
  {-n,--nofollow-symlinks}'[don’t follow symbolic links]'
  '*:filename:_files'
)

_arguments -s -S $arguments
