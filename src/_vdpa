#compdef vdpa
# Documentation: https://man.archlinux.org/search?q=vdpa
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    {-V,--Version}'[Print the version of the vdpa utility and exit.]'
    {-j,--json}'[Generate JSON output.]'
    {-p,--pretty}'[When combined with -j generate a pretty JSON output. SS OBJECT.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
