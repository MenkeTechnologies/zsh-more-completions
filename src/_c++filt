#compdef c++filt

local -a arguments

arguments=(
  {-n,--no-strip-underscores}'[do not remove leading underscores.]'
  {-p,--no-params}'[(Accepted but ignored).]'
  {-s,--format}'[select the encoding scheme to use]:scheme:(auto gnu lucid arm hp edg gnu-v3 java gnat)'
  '--help[print a help message.]'
  '--version[print a version identifier and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
