#compdef thin

local -a arguments

arguments=(
  {-a,--address}'[bind to HOST address (default: 0.0.0.0)]:host:'
  {-p,--port}'[use PORT (default: 3000)]:port:'
  {-S,--socket}'[bind to unix domain socket]:socket:_files'
  {-y,--swiftiply}'[run using swiftiply]'
  {-A,--adapter}'[rack adapter to use (default: autodetect)]:adapter:'
  {-R,--rackup}'[load a Rack config file instead of Rack adapter]:file:_files'
  {-c,--chdir}'[change to dir before starting]:directory:_directories'
  '--stats[mount the Stats adapter under PATH]:path:'
  '--ssl[enables SSL]'
  '--ssl-key-file[path to private key]:file:_files'
  '--ssl-cert-file[path to certificate]:file:_files'
  '--ssl-disable-verify[disables (optional) client cert requests]'
  '--ssl-version[TLS version]:version:(TLSv1 TLSv1_1 TLSv1_2)'
  '--ssl-cipher-list[SSL cipher list]:ciphers:'
  {-e,--environment}'[framework environment (default: development)]:environment:'
  '--prefix[mount the app under PATH (start with /)]:path:'
  {-d,--daemonize}'[run daemonized in the background]'
  {-l,--log}'[file to redirect output]:file:_files'
  {-P,--pid}'[file to store PID (default: tmp/pids/thin.pid)]:file:_files'
  {-u,--user}'[user to run daemon as (use with -g)]:user:_users'
  {-g,--group}'[group to run daemon as (use with -u)]:group:_groups'
  '--tag[additional text to display in process listing]:tag:'
  {-s,--servers}'[number of servers to start]:count:'
  {-o,--only}'[send command to only one server of the cluster]:server:'
  {-C,--config}'[load options from config file]:file:_files'
  {-O,--onebyone}'[restart the cluster one by one (only works with restart command)]'
  {-w,--wait}'[maximum wait time for server to be started in seconds (use with -O)]:seconds:'
  {-b,--backend}'[backend to use, full classname]:backend:'
  {-t,--timeout}'[request or command timeout in sec (default: 30)]:seconds:'
  {-f,--force}'[force the execution of the command]'
  '--max-conns[maximum number of open file descriptors (default: 1024)]:count:'
  '--max-persistent-conns[maximum number of persistent connections]:count:'
  '--threaded[call the Rack application in threads \[experimental\]]'
  '--threadpool-size[sets the size of the EventMachine threadpool.]:size:'
  {-r,--require}'[require the library]:library:'
  {-q,--quiet}'[silence all logging]'
  {-D,--debug}'[enable debug logging]'
  {-V,--trace}'[set tracing on (log raw request/response)]'
  '(- * :)'{-h,--help}'[show this message]'
  {-v,--version}'[show version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
