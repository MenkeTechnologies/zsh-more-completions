#compdef massagevendor

local -a arguments

arguments=(
  {-e,--expression}'[add script expression to commands]:expression: '
  {-f,--file}'[add script file to commands]:file:_files'
  '--help[display this help and exit]'
  '--line-length[specify desired line length]:length: '
  '--null-data[separate lines by NUL characters]'
  {--quiet,--silent}'[suppress automatic printing of pattern space]'
  '--sandbox[operate in sandbox mode]'
  '--separate[consider files as separate rather than a single stream]'
  '--unbuffered[flush output after every line]'
  '--version[output version information and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
