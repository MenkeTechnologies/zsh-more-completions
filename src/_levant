#compdef levant

# Zsh completion for levant - HashiCorp Nomad job templating and deployment

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'deploy:render and deploy a Nomad job'
  'dispatch:dispatch a Nomad parameterized job'
  'plan:render and plan a Nomad job'
  'render:render a Nomad job template'
  'scale-in:scale in a Nomad task group'
  'scale-out:scale out a Nomad task group'
  'version:show version'
)

_arguments -s -S \
  '1:subcommand:->subcmd' \
  '*::args:->args' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'levant subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (deploy)
        _arguments \
          '-address[Nomad server address]:address:' \
          '-allow-stale[allow stale consistency mode]' \
          '-canary-auto-promote[auto-promote canary deployments]:seconds:' \
          '-consul-address[Consul server address]:address:' \
          '-force-batch[force a batch job to run]' \
          '-force-count[use count from local job file]' \
          '-ignore-no-changes[exit cleanly when no changes detected]' \
          '-log-level[set log level]:level:(DEBUG INFO WARN ERROR)' \
          '-log-format[set log format]:format:(HUMAN JSON)' \
          '-var-file[path to variables file]:file:_files -g "*.yaml *.yml *.json *.tf"' \
          '-var[set a variable]:key=value:' \
          '1:job template:_files -g "*.nomad *.nomad.hcl *.hcl"' && ret=0
        ;;
      (dispatch)
        _arguments \
          '-address[Nomad server address]:address:' \
          '-log-level[set log level]:level:(DEBUG INFO WARN ERROR)' \
          '-log-format[set log format]:format:(HUMAN JSON)' \
          '-meta[metadata key/value pairs]:key=value:' \
          '1:job ID:' \
          '2:payload file:_files' && ret=0
        ;;
      (plan)
        _arguments \
          '-address[Nomad server address]:address:' \
          '-consul-address[Consul server address]:address:' \
          '-log-level[set log level]:level:(DEBUG INFO WARN ERROR)' \
          '-log-format[set log format]:format:(HUMAN JSON)' \
          '-var-file[path to variables file]:file:_files -g "*.yaml *.yml *.json *.tf"' \
          '-var[set a variable]:key=value:' \
          '1:job template:_files -g "*.nomad *.nomad.hcl *.hcl"' && ret=0
        ;;
      (render)
        _arguments \
          '-consul-address[Consul server address]:address:' \
          '-log-level[set log level]:level:(DEBUG INFO WARN ERROR)' \
          '-log-format[set log format]:format:(HUMAN JSON)' \
          '-out[output rendered template to file]:file:_files' \
          '-var-file[path to variables file]:file:_files -g "*.yaml *.yml *.json *.tf"' \
          '-var[set a variable]:key=value:' \
          '1:job template:_files -g "*.nomad *.nomad.hcl *.hcl"' && ret=0
        ;;
      (scale-in|scale-out)
        _arguments \
          '-address[Nomad server address]:address:' \
          '-count[number to scale by]:count:' \
          '-log-level[set log level]:level:(DEBUG INFO WARN ERROR)' \
          '-log-format[set log format]:format:(HUMAN JSON)' \
          '-percent[percentage to scale by]:percent:' \
          '-task-group[task group to scale]:group:' \
          '1:job ID:' && ret=0
        ;;
    esac
    ;;
esac

return ret
