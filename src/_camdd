#compdef camdd

local -a arguments

arguments=(
  '-i[specify input device/file and parameters]:input:'
  '-o[specify output device/file and parameters]:output:'
  '-C[specify a retry count for pass(4) devices]:count:'
  '-E[enable CAM error recovery for pass(4) devices]'
  '-m[specify the maximum amount to be transferred in bytes]:max:'
  '-t[specify the I/O timeout to use with pass(4) devices]:timeout:'
  '-v[enable verbose error recovery]'
  '-h[print this message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
