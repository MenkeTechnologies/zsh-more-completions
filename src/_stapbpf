#compdef stapbpf

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help text]'
  {-v,--verbose}'[increase verbosity]'
  {-V,--version}'[show version]'
  '-w[suppress warnings]'
  '-x[sets the _stp_target variable to pid.]'
  '-o[send output to FILE]'
  '*:filename:_files'
)

_arguments -s -S $arguments
