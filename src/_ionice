#compdef ionice

# ionice - set or get process I/O scheduling class and priority
# Part of util-linux

local -a class_values
class_values=(
  '0:none'
  '1:realtime'
  '2:best-effort'
  '3:idle'
)

_arguments -s -S \
  {-c,--class}'[scheduling class (0\: none, 1\: realtime, 2\: best-effort, 3\: idle)]:class:(none realtime best-effort idle 0 1 2 3)' \
  {-n,--classdata}'[class data / priority level (0-7, lower is higher priority)]:priority:(0 1 2 3 4 5 6 7)' \
  '*'{-p,--pid}'[act on specified already running process]:pid:_pids' \
  '*'{-P,--pgid}'[act on specified already running process group]:pgid:_sequence _pids' \
  {-t,--ignore}'[ignore failure to set the requested priority]' \
  '*'{-u,--uid}'[act on processes owned by specified already running user]:user:_users' \
  '(- *)'{-h,--help}'[display help text and exit]' \
  '(- *)'{-V,--version}'[display version information and exit]' \
  '*:command:_command_names -e'
