#compdef gobject-query
# Documentation: https://man.archlinux.org/search?q=gobject-query
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-r[specifiy root type]'
  '-n[dont descend type tree]'
  '-h[guess what ;)]'
  '-b[specify indent string]'
  '-i[specify incremental indent string]'
  '-s[specify line spacing]'
  '*:filename:_files'
)

_arguments -s -S $arguments
