#compdef pet

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config=[config file path]:config file:_files' \
  '--debug[debug mode]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'configure:edit config file'
      'edit:edit snippet file'
      'exec:run a snippet'
      'list:show all snippets'
      'new:create a new snippet'
      'search:search snippets'
      'sync:sync snippets'
      'clip:copy snippet to clipboard'
    )
    _describe -t commands 'pet command' commands && ret=0
    ;;
  args)
    case $line[1] in
      new)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-t[use tag]' \
          '--tag[use tag]' && ret=0
        ;;
      exec|search|list)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-q+[query string]:query' \
          '--query=[query string]:query' \
          '--color[enable color]' \
          '--no-color[disable color]' && ret=0
        ;;
      sync)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-u[upload snippets]' \
          '--upload[upload snippets]' && ret=0
        ;;
    esac
    ;;
esac

return ret
