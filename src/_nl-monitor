#compdef nl-monitor
# Documentation: https://man.archlinux.org/search?q=nl-monitor
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-f,--format}'[output format { brief | details | stats }]'
  '(- * :)'{-h,--help}'[show this help.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
