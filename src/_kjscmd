#compdef kjscmd
# Documentation: https://man.archlinux.org/search?q=kjscmd
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-e,--exec}'[execute script without gui support.]'
  {-i,--interactive}'[start interactive kjs interpreter.]'
  {-n,--no-kde}'[start without KDE KApplication support.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
