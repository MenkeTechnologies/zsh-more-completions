#compdef sipcrack
# Documentation: https://man.archlinux.org/search?q=sipcrack
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-s[use stdin for passwords]'
  '-w[file containing all passwords to try]'
  '-p[print cracking process every n passwords (for -w)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
