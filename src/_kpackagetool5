#compdef kpackagetool5

local -a arguments

arguments=(
  {-v,--version}'[displays version information.]'
  '(- * :)'{-h,--help}'[displays this help.]'
  '--hash[generate a SHA1 hash for the package at the given path]:path:_files'
  {-g,--global}'[for install or remove, operates on packages installed for all users]'
  {-t,--type}'[the type of package, corresponding to the service type]:type:'
  {-i,--install}'[install the package at <path>]'
  {-s,--show}'[show information of package <name>]'
  {-u,--upgrade}'[upgrade the package at <path>]'
  {-l,--list}'[list installed packages]'
  '--list-types[list all known package types that can be installed]'
  {-r,--remove}'[remove the package named <name>]'
  {-p,--packageroot}'[absolute path to the package root]:path:_files -/'
  '--generate-index[recreate the plugin index]'
  '--remove-index[remove the plugin index]'
  '--appstream-metainfo[outputs the metadata for the package]'
  '--appstream-metainfo-output[outputs the metadata for the package into a file]:file:_files'
  '*:filename:_files'
)

_arguments -s -S $arguments
