#compdef macipgw
# Documentation: https://man.archlinux.org/search?q=macipgw
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '-d[do not fork, trace all actions]:debug-class: '
    '-n[specify IP address of DNS name server]:nameserver: '
    '-u[drop root privileges and change to specified user]:unprivileged-user:_users'
    '-z[register in specified zone instead of default zone]:zone: '
    {-v,-V}'[show version information and exit]'
    '*:filename:_files'
)
_arguments -s -S $arguments
