#compdef rtcwake

local -a arguments

arguments=(
  {-a,--auto}'[reads the clock mode from adjust file (default)]'
  {-A,--adjfile}'[specifies the path to the adjust file]:file:_files'
  '--date[date time of timestamp to wake]:timestamp: '
  {-d,--device}'[select rtc device (rtc0|rtc1|...)]:device: '
  {-n,--dry-run}'[does everything, but suspend]'
  {-l,--local}'[RTC uses local timezone]'
  '--list-modes[list available modes]'
  {-m,--mode}'[sleep mode]:mode:(standby mem disk off no on disable)'
  {-s,--seconds}'[seconds to sleep]:seconds: '
  {-t,--time}'[time to wake]:time_t: '
  {-u,--utc}'[RTC uses UTC]'
  {-v,--verbose}'[verbose messages]'
  '(- * :)'{-h,--help}'[display this help]'
  {-V,--version}'[display version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
