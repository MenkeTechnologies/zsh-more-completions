local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[print this help and exit]'
  {-p,--output-file}'[print output to file NAME (default file is]'
  {-V,--version}'[print version number]'
  '*:filename:_files'
)

_arguments -s -S $arguments
