#compdef sipdump
# Documentation: https://man.archlinux.org/search?q=sipdump
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-i[interface to listen on]'
  '-p[use pcap data file]'
  '-m[enter login data manually]'
  '-f[" = set libpcap filter]'
  '*:filename:_files'
)

_arguments -s -S $arguments
