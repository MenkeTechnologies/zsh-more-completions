#compdef exa eza

# Completion for exa and its maintained fork eza
# Supports options from both tools

local prog=${words[1]:t}
local -a display_opts filter_opts longview_opts

display_opts=(
    '(- *)'{-v,--version}'[Show version information]'
    '(- *)'{-\?,--help}'[Show list of command-line options]'
    {-1,--oneline}'[Display one entry per line]'
    {-l,--long}'[Display extended file metadata as a table]'
    {-G,--grid}'[Display entries as a grid (default)]'
    {-x,--across}'[Sort the grid across, rather than downwards]'
    {-R,--recurse}'[Recurse into directories]'
    {-T,--tree}'[Recurse into directories as a tree]'
    {-F,--classify}'[Display type indicator by file names]'
    '--color=[When to use terminal colours]:when:(always auto never)'
    '--colour=[When to use terminal colours]:when:(always auto never)'
    '--color-scale[Highlight levels of file sizes distinctly]'
    '--colour-scale[Highlight levels of file sizes distinctly]'
    '--icons[Display icons next to file names]'
    '--no-icons[Do not display icons]'
    '--no-quotes[Do not quote file names with spaces]'
    {-w,--width}'[Set screen width in columns]:width:'
)

filter_opts=(
    {-a,--all}'[Show hidden and dot files]'
    {-d,--list-dirs}'[List directories as files; do not list their contents]'
    {-D,--only-dirs}'[List only directories]'
    {-L,--level}'[Limit the depth of recursion]:depth:'
    {-r,--reverse}'[Reverse the sort order]'
    {-s,--sort}'[Which field to sort by]:sort field:(name Name extension Extension size type modified accessed created changed inode date time old new oldest newest none)'
    {-I,--ignore-glob}'[Glob patterns (pipe-separated) of files to ignore]:globs:'
    '--group-directories-first[List directories before other files]'
    '--git-ignore[Ignore files mentioned in .gitignore]'
)

longview_opts=(
    {-b,--binary}'[List file sizes with binary prefixes]'
    {-B,--bytes}'[List file sizes in bytes, without any prefixes]'
    {-g,--group}'[List each file group]'
    {-h,--header}'[Add a header row to each column]'
    {-H,--links}'[List each file number of hard links]'
    {-i,--inode}'[List each file inode number]'
    {-m,--modified}'[Use the modified timestamp field]'
    {-n,--numeric}'[List numeric user and group IDs]'
    {-S,--blocks}'[Show number of file system blocks]'
    {-t,--time}'[Which timestamp field to list]:time field:(modified accessed created)'
    {-u,--accessed}'[Use the accessed timestamp field]'
    {-U,--created}'[Use the created timestamp field]'
    '--changed[Use the changed timestamp field]'
    '--time-style[How to format timestamps]:time style:(default iso long-iso full-iso relative)'
    '--no-permissions[Suppress the permissions field]'
    '--octal-permissions[List each file permission in octal format]'
    '--no-filesize[Suppress the filesize field]'
    '--no-user[Suppress the user field]'
    '--no-time[Suppress the time field]'
    '--git[List each file Git status, if tracked or ignored]'
    '--no-git[Suppress Git status]'
    '--git-repos[List root of git-tree status]'
    '--git-repos-no-status[List each git-repos branch name (much faster)]'
    {-@,--extended}'[List each file extended attributes and sizes]'
    '--total-size[Show the size of a directory as the size of all files inside]'
)

# eza-specific options (superset of exa)
local -a eza_opts
if [[ $prog == eza ]] || eza --version &>/dev/null; then
    eza_opts=(
        {-A,--almost-all}'[Equivalent to --all; included for ls compatibility]'
        {-X,--dereference}'[Dereference symbolic links when displaying information]'
        {-f,--only-files}'[List only files]'
        {-o,--octal-permissions}'[List each file permission in octal format]'
        {-M,--mounts}'[Show mount details (Linux and Mac only)]'
        {-O,--flags}'[List file flags (Mac, BSD, and Windows only)]'
        {-Z,--context}'[List each file security context]'
        '--show-symlinks[Explicitly show symbolic links (for use with --only-dirs | --only-files)]'
        '--no-symlinks[Do not show symbolic links]'
        '--group-directories-last[List directories after other files]'
        '--color-scale=[Highlight levels of field distinctly]:field:(all age size)'
        '--colour-scale=[Highlight levels of field distinctly]:field:(all age size)'
        '--color-scale-mode=[Use gradient or fixed colors in --color-scale]:mode:(fixed gradient)'
        '--colour-scale-mode=[Use gradient or fixed colors in --colour-scale]:mode:(fixed gradient)'
        '--hyperlink[Display entries as hyperlinks]'
        '--absolute=[Display entries with their absolute path]:mode:(on follow off)'
        '--follow-symlinks[Drill down into symbolic links that point to directories]'
        '--stdin[Read file names from stdin]'
        '--smart-group[Only show group if it differs from owner]'
        {-d,--treat-dirs-as-files}'[List directories as files; do not list their contents]'
    )
fi

_arguments -s \
    $display_opts \
    $filter_opts \
    $longview_opts \
    $eza_opts \
    '*:file:_files'
