#compdef cryptsetup

# Zsh completion for cryptsetup (LUKS/dm-crypt disk encryption)
# Covers cryptsetup 2.7.x options and actions

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a cryptsetup_actions=(
  'open:open a device and set up a mapping'
  'close:close a device (remove mapping)'
  'status:report mapping status'
  'resize:resize an active mapping'
  'refresh:refresh (reactivate) device with new flags'
  'reencrypt:reencrypt LUKS2 device in-place'
  'luksFormat:initialize a LUKS partition and set initial passphrase'
  'luksOpen:open LUKS device (old syntax)'
  'luksClose:close LUKS device (old syntax)'
  'luksSuspend:suspend active LUKS device'
  'luksResume:resume suspended LUKS device'
  'luksAddKey:add a new passphrase'
  'luksRemoveKey:remove a passphrase'
  'luksChangeKey:change a passphrase'
  'luksConvertKey:convert a LUKS2 keyslot to new PBKDF parameters'
  'luksKillSlot:wipe key with given key slot number'
  'luksUUID:print or set UUID of a LUKS device'
  'isLuks:check if device is a LUKS device'
  'luksDump:dump LUKS header information'
  'luksHeaderBackup:store binary backup of LUKS header and keyslots'
  'luksHeaderRestore:restore LUKS header and keyslots from backup file'
  'token:manage LUKS2 tokens'
  'convert:convert LUKS device between LUKS1 and LUKS2 format'
  'config:set permanent configuration options for LUKS2 device'
  'erase:erase all keyslots (DANGEROUS)'
  'benchmark:benchmark cipher/PBKDF'
  'repair:try to repair LUKS device metadata'
  'tcryptOpen:open TCRYPT (TrueCrypt/VeraCrypt) device'
  'tcryptDump:dump TCRYPT device information'
  'bitlkOpen:open BitLocker compatible device'
  'bitlkDump:dump BitLocker device information'
  'fvault2Open:open FileVault2 compatible device'
  'fvault2Dump:dump FileVault2 device information'
  'plainOpen:open plain dm-crypt device (old syntax)'
  'loopaesOpen:open loop-AES device'
)

_arguments -s -S \
  '(- *)--help[display help text and exit]' \
  '(- *)--usage[display brief usage]' \
  '(- *)--version[print package version]' \
  {-v,--verbose}'[show more detailed error messages]' \
  '--debug[show debug messages]' \
  '--debug-json[show debug messages including JSON metadata]' \
  {-q,--batch-mode}'[do not ask for confirmation]' \
  {-y,--verify-passphrase}'[verify passphrase by asking for it twice]' \
  {-c,--cipher}'[set the cipher used to encrypt the disk]:cipher (e.g. aes-xts-plain64)' \
  {-h,--hash}'[set the hash used for passphrase hashing]:hash (e.g. sha256)' \
  {-d,--key-file}'[read the key from a file]:key file:_files' \
  '--volume-key-file[read the volume (master) key from file]:master key file:_files' \
  '--dump-volume-key[dump volume (master) key instead of keyslots info]' \
  {-s,--key-size}'[set the key size in bits]:key size (bits)' \
  {-l,--keyfile-size}'[limit read from keyfile]:keyfile size (bytes)' \
  '--keyfile-offset[number of bytes to skip in keyfile]:offset (bytes)' \
  '--new-keyfile-size[limit read from newly added keyfile]:keyfile size (bytes)' \
  '--new-keyfile-offset[number of bytes to skip in newly added keyfile]:offset (bytes)' \
  {-S,--key-slot}'[slot number for new key (default is first free)]:key slot (0-31)' \
  {-b,--size}'[force the size of the device (in 512-byte sectors)]:size (sectors)' \
  {-o,--offset}'[start offset in the backend device (in 512-byte sectors)]:offset (sectors)' \
  {-p,--skip}'[sectors to skip at the beginning of encrypted data]:skip (sectors)' \
  {-r,--readonly}'[create a read-only mapping]' \
  {-t,--timeout}'[timeout for interactive passphrase prompt (in seconds)]:timeout (seconds)' \
  '--progress-frequency[progress line update interval (in seconds)]:interval (seconds)' \
  '--progress-json[print progress data in JSON format]' \
  {-T,--tries}'[maximum number of passphrase retries]:number of tries' \
  '--align-payload[align payload at <n> sector boundaries]:alignment (sectors)' \
  '--header-backup-file[file with LUKS header and keyslots backup]:backup file:_files' \
  '--use-random[use /dev/random for generating volume key]' \
  '--use-urandom[use /dev/urandom for generating volume key]' \
  '--shared[share device with another non-overlapping crypt segment]' \
  '--uuid[UUID for device to use]:UUID' \
  '--allow-discards[allow discard (TRIM) requests for the device]' \
  '--header[device or file with separated LUKS header]:header device or file:_files' \
  '--test-passphrase[do not activate device, just check passphrase]' \
  '--tcrypt-hidden[use hidden header (hidden TCRYPT device)]' \
  '--tcrypt-system[device is system TCRYPT drive (with bootloader)]' \
  '--tcrypt-backup[use backup (secondary) TCRYPT header]' \
  '--veracrypt[scan also for VeraCrypt compatible device]' \
  '--veracrypt-pim[personal Iteration Multiplier for VeraCrypt device]:PIM' \
  '--veracrypt-query-pim[query Personal Iteration Multiplier for VeraCrypt device]' \
  {-M,--type}'[type of device metadata]:type:(luks luks1 luks2 plain loopaes tcrypt bitlk fvault2)' \
  '--force-password[disable password quality check (if enabled)]' \
  '--perf-same_cpu_crypt[use dm-crypt same_cpu_crypt performance flag]' \
  '--perf-submit_from_crypt_cpus[use dm-crypt submit_from_crypt_cpus performance flag]' \
  '--perf-no_read_workqueue[bypass dm-crypt read workqueue]' \
  '--perf-no_write_workqueue[bypass dm-crypt write workqueue]' \
  '--deferred[defer device removal until the last user closes it]' \
  {-i,--iter-time}'[PBKDF iteration time for LUKS (in milliseconds)]:time (ms)' \
  '--pbkdf[PBKDF algorithm (for LUKS2)]:algorithm:(argon2i argon2id pbkdf2)' \
  '--pbkdf-memory[PBKDF memory cost limit (in kilobytes)]:memory (kB)' \
  '--pbkdf-parallel[PBKDF parallel cost (number of threads)]:threads' \
  '--pbkdf-force-iterations[PBKDF iterations cost (forced, disables benchmark)]:iterations' \
  '--priority[keyslot priority]:priority:(ignore normal prefer)' \
  '--disable-locks[disable locking of on-disk metadata]' \
  '--disable-keyring[disable loading volume keys via kernel keyring]' \
  '--disable-external-tokens[disable loading of external LUKS2 token plugins]' \
  '--external-tokens-path[path to directory with external token handlers]:token path:_directories' \
  {-I,--integrity}'[data integrity algorithm (LUKS2 only)]:integrity algorithm' \
  '--integrity-no-journal[disable journal for integrity device]' \
  '--integrity-no-wipe[do not wipe device after format]' \
  '--integrity-legacy-padding[use legacy integrity padding (for old kernels)]' \
  '--token-only[do not ask for passphrase if activation by token fails]' \
  '--token-id[token number (default: any)]:token id' \
  '--token-type[restrict tokens to specific type]:token type' \
  '--token-replace[replace existing token]:replace' \
  '--key-description[key description (for kernel keyring)]:key description' \
  '--sector-size[encryption sector size]:sector size (bytes):(512 1024 2048 4096)' \
  '--iv-large-sectors[use IV counted in sector size (not in 512 bytes)]' \
  '--persistent[set activation flags persistent for device]' \
  '--label[set label for the LUKS2 device]:label' \
  '--subsystem[set subsystem label for the LUKS2 device]:subsystem' \
  '--unbound[create or dump unbound (no assigned data segment) LUKS2 keyslot]' \
  '--json-file[read token JSON from or dump to file]:JSON file:_files' \
  '--luks2-metadata-size[LUKS2 header metadata area size]:metadata size' \
  '--luks2-keyslots-size[LUKS2 header keyslots area size]:keyslots size' \
  '--encrypt[encrypt LUKS2 device in-place]' \
  '--decrypt[decrypt LUKS2 device in-place]' \
  '--init-only[initialize reencryption metadata only]' \
  '--resume-only[resume reencryption process only]' \
  '--resilience[reencryption resilience mode]:resilience mode:(checksum journal none shift)' \
  '--resilience-hash[reencrypt resilience hash]:hash' \
  '--hotzone-size[maximal reencryption hotzone size]:size' \
  '--reduce-device-size[reduce data device size (move data offset)]:size' \
  '--device-size[use only specified device size for reencrypt (ignore rest of device)]:size' \
  '--active-name[override device autodetection of dm device for reencryption]:name' \
  '1:action:->actions' \
  '*:device or name:_files' && ret=0

case "$state" in
  actions)
    _describe -t actions 'cryptsetup action' cryptsetup_actions && ret=0
    ;;
esac

return ret
