#compdef prlsga
# Documentation: https://man.archlinux.org/search?q=prlsga
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[This help]'
  '-r[Service poll period (in milliseconds) \[100, 1000\], default: 500]'
  '-l[Logging level \[0, 3\], default 2]'
  '-v[Verbose logging, set log level to 3]'
  '*:filename:_files'
)

_arguments -s -S $arguments
