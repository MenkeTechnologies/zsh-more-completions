#compdef loginctl

# zsh completions for 'loginctl'

_loginctl_commands() {
  local -a session_cmds user_cmds seat_cmds
  session_cmds=(
    'list-sessions:list current sessions'
    'session-status:show runtime status information of sessions'
    'show-session:show properties of sessions or the manager'
    'activate:activate a session'
    'lock-session:screen lock sessions'
    'unlock-session:screen unlock sessions'
    'lock-sessions:screen lock all sessions'
    'unlock-sessions:screen unlock all sessions'
    'terminate-session:terminate sessions'
    'kill-session:send signal to session processes'
  )
  user_cmds=(
    'list-users:list currently logged in users'
    'user-status:show runtime status of users'
    'show-user:show properties of users or the manager'
    'enable-linger:enable lingering for users'
    'disable-linger:disable lingering for users'
    'terminate-user:terminate all sessions of users'
    'kill-user:send signal to all processes of users'
  )
  seat_cmds=(
    'list-seats:list currently available seats'
    'seat-status:show runtime status of seats'
    'show-seat:show properties of seats or the manager'
    'attach:persistently attach devices to a seat'
    'flush-devices:remove all device assignments'
    'terminate-seat:terminate all sessions on seats'
  )
  _describe -t session-commands 'session command' session_cmds
  _describe -t user-commands 'user command' user_cmds
  _describe -t seat-commands 'seat command' seat_cmds
}

_loginctl() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -s \
    '(- *)'{-h,--help}'[show help message and exit]' \
    '(- *)--version[show package version]' \
    '--no-pager[do not pipe output into a pager]' \
    '--no-legend[do not show the headers and footers]' \
    '--no-ask-password[do not query the user for authentication]' \
    {-H+,--host=}'[execute the operation on a remote host]:user@host:_hosts' \
    {-M+,--machine=}'[execute operation on a local container]:machine name' \
    '*'{-p+,--property=}'[show only properties by this name]:property name' \
    '--value[show only property values without names]' \
    {-a,--all}'[show all properties, including empty ones]' \
    {-l,--full}'[do not ellipsize output]' \
    '--kill-whom=[whom to send signal to]:whom:(leader all)' \
    {-s+,--signal=}'[which signal to send]:signal:_signals' \
    {-n+,--lines=}'[number of journal lines to show]:number of lines' \
    {-o+,--output=}'[change journal output mode]:output mode:(short short-precise short-iso short-iso-precise short-full short-monotonic short-unix verbose export json json-pretty json-sse json-seq cat with-unit)' \
    '--json=[format output as JSON]:mode:(short pretty off)' \
    '-j[JSON output (pretty on tty, short otherwise)]' \
    '(-): :_loginctl_commands' \
    '(-)*:: :->args'

  case $state in
    args)
      case ${line[1]} in
        list-sessions|list-users|list-seats|lock-sessions|unlock-sessions|flush-devices)
          ;;
        session-status|show-session|activate|lock-session|unlock-session|terminate-session|kill-session)
          _arguments '*:session id'
          ;;
        user-status|show-user|enable-linger|disable-linger|terminate-user|kill-user)
          _arguments '*:user:_users'
          ;;
        seat-status|show-seat|terminate-seat)
          _arguments '*:seat name'
          ;;
        attach)
          _arguments \
            ':seat name' \
            '*:device:_files -W /sys/devices'
          ;;
      esac
      ;;
  esac
}

_loginctl "$@"
