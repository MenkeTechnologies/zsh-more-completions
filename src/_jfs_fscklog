#compdef jfs_fscklog

local -a arguments

arguments=(
  '-d[display an already extracted fsck.jfs service log.]'
  '-e[extract the fsck.jfs service log from device.]'
  '-f[specify the file name that the fsck.jfs log will be extracted into or displayed from]:filename:_files'
  '-p[extract the previous fsck.jfs service log.]'
  '-V[print version information only.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
