#compdef navigator-updater
# Documentation: https://man.archlinux.org/search?q=navigator-updater
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[show this help message and exit]'
  '--version[print version information]'
  '--latest-version[latest version available for update]'
  '--prefix[environment prefix on which to perform the update]'
  '--debug[print debug statements]'
  '*:filename:_files'
)

_arguments -s -S $arguments
