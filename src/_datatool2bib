#compdef datatool2bib

local -a arguments

arguments=(
  {-h,--help}'[display this help message and exit.]'
  {-v,--version}'[display version information and exit.]'
  '--debug-mode[teX Parser debug mode.]'
  {-q,--quiet,--silent}'[only display error messages.]'
  '--log-file[log file (for debugging).]'
  '--texenc[.tex file encoding.]'
  '--bibenc[.bib file encoding.]'
  '--locale[use language resource file given by iso tag]:tag'
  {-p,--preamble-only}'[only parse the document preamble.]'
  {-f,--ignore-fields}'[ignore the fields identified by their names]:list'
  {-s,--space-sub}'[substitute spaces in labels with <val>.]:val'
  {-i,--index-conversion}'[convert @entry to @index if no description.]'
  {-m,--map-fields}'[add source field identifiers to bib field mappings]:mappings'
  '--field-case[specify the case-change to apply to field names]'
  {-L,--label}'[use column identified by <col-key> for the label]:col-key'
  {-F,--fallback-label}'[use column identified by <col-key> as a fallback label]:col-key'
  {-a,--auto-label}'[auto-generate entry label instead of using a column]'
  '--auto-label-prefix[prefix to use for auto-generated entry labels.]:prefix'
  '--setup[implement \DTLsetup{<options>}.]:options'
  '--numeric-locale[identify the language tag for detecting or formatting numeric values]:tag'
  '*:filename:_files'
)

_arguments -s -S $arguments
