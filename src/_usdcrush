#compdef usdcrush
# Documentation: https://man.archlinux.org/search?q=usdcrush
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[print this help message and exit]'
  {-o,--out}'[REQUIRED      The output file to write to]'
  {-t,--textureQuality}'[\[75\]]'
  '--version[display program version information and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
