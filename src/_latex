#compdef latex

local -a arguments

arguments=(
  '-draftmode[switch on draft mode (generates no output PDF)]'
  '-enc[enable encTeX extensions such as \mubyte]'
  '-etex[enable e-TeX extensions]'
  '-fmt[use FMTNAME instead of program name or a %& line]'
  '-halt-on-error[stop processing at the first error]'
  '-ini[be pdfinitex, for dumping formats]'
  '-interaction[set interaction mode]:mode:(batchmode nonstopmode scrollmode errorstopmode)'
  '-ipc[send DVI output to a socket as well as the usual output]'
  '-ipc-start[as -ipc, and also start the server at the other end]'
  '-jobname[set the job name to STRING]'
  '-kpathsea-debug[set path searching debugging flags according to the bits of NUMBER]:number:'
  '-mltex[enable MLTeX extensions such as \charsubdef]'
  '-output-comment[use STRING for DVI file comment instead of date]'
  '-output-directory[use existing DIR as the directory to write files in]:dir:_files -/'
  '-output-format[use FORMAT for job output; FORMAT is `dvi or `pdf]'
  '-progname[set program (and fmt) name to STRING]'
  '-recorder[enable filename recorder]'
  '-shell-restricted[enable restricted \write18]'
  '-src-specials[insert source specials into the DVI file]'
  '-synctex[generate SyncTeX data for previewers according to bits of NUMBER]:number:'
  '-translate-file[use the TCX file TCXNAME]'
  '-8bit[make all characters printable by default]'
  '-help[display this help and exit]'
  '-version[output version information and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
