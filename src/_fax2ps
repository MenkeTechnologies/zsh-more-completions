#compdef fax2ps

local -a arguments

arguments=(
  '-w[suppress warning messages]'
  '-l[set maximum output line length for generated PostScript]:length:'
  '-p[select page to print (can use multiple times)]:page:'
  '-x[set default horizontal resolution of input data (dpi)]:dpi:'
  '-y[set default vertical resolution of input data (lpi)]:lpi:'
  '-S[scale output to page size]'
  '-W[set output page width (inches), default is 8.5]:width:'
  '-H[set output page height (inches), default is 11]:height:'
  '*:filename:_files'
)

_arguments -s -S $arguments
