#compdef affuse

local -a arguments

arguments=(
  '-d[enable debug output (implies -f)]'
  '-f[foreground operation]'
  '-s[disable multi-threaded operation]'
  '*-o[FUSE mount option]:option:(allow_other allow_root auto_unmount nonempty default_permissions fsname= subtype= large_read max_read= hard_remove use_ino readdir_ino direct_io kernel_cache auto_cache umask= uid= gid= entry_timeout= negative_timeout= attr_timeout= ac_attr_timeout= noforget remember= nopath intr intr_signal= modules= max_write= max_readahead= max_background= congestion_threshold= async_read sync_read atomic_o_trunc big_writes no_remote_lock no_remote_flock no_remote_posix_lock splice_write splice_move splice_read from_code= to_code= rellinks)'
  '*:filename:_files'
)

_arguments -s -S $arguments
