#compdef nfsref
# Documentation: https://man.archlinux.org/search?q=nfsref
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    {-d,--debug}'[Enables debugging messages during operation.]'
    {-t,--type}'[Specifies the junction type for the operation.]':junction-type
    '*:filename:_files'
)
_arguments -s -S $arguments
