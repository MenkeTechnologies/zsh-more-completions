#compdef callgrind_annotate

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this message]'
  '--version[show version]'
  '--show[only show figures for specified events]:events:'
  '--sort[sort columns by specified events]:events:'
  '--threshold[percentage of counts to show (0-100)]:threshold:'
  '--auto[annotate all source files containing functions]'
  '--context[print N lines of context before and after]:lines:'
  '--inclusive[add subroutine costs to function calls]:yes or no:(yes no)'
  '--tree[print for each function their callers]:mode:(none caller both)'
  {-I,--include}'[add directory to list of directories to search for source]:dir:_files -/'
  '*:filename:_files'
)

_arguments -s -S $arguments
