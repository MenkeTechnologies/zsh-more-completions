#compdef rga

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-V,--version}'[display version]' \
  '--rga-no-cache[disable caching of results]' \
  '--rga-cache-max-blob-len[max blob size for caching]:size' \
  '--rga-cache-path[path to cache directory]:directory:_directories' \
  '--rga-adapters[change which adapters to use]:adapters' \
  '--rga-list-adapters[list available adapters]' \
  '--rga-print-config-schema[print the config schema]' \
  '--rga-fzf-exe[set fzf executable]:fzf path:_files' \
  {-e,--regexp}'[pattern to search for]:pattern' \
  {-i,--ignore-case}'[case insensitive search]' \
  {-s,--case-sensitive}'[case sensitive search]' \
  {-S,--smart-case}'[smart case search]' \
  {-w,--word-regexp}'[only show matches surrounded by word boundaries]' \
  {-c,--count}'[only show count of matching lines]' \
  {-l,--files-with-matches}'[only print matched file paths]' \
  '--files[print each file that would be searched]' \
  {-F,--fixed-strings}'[treat pattern as literal string]' \
  {-g,--glob}'[include or exclude files]:glob pattern' \
  '--hidden[search hidden files and directories]' \
  {-L,--follow}'[follow symbolic links]' \
  '--max-depth[descend at most N directories]:depth' \
  '--max-filesize[ignore files above specified size]:size' \
  '--no-ignore[do not respect ignore files]' \
  {-t,--type}'[only search files matching type]:type' \
  {-T,--type-not}'[do not search files matching type]:type' \
  '--type-list[show all supported file types]' \
  {-j,--threads}'[number of threads]:count' \
  '--color[when to use color]:when:(auto always never)' \
  {-n,--line-number}'[show line numbers]' \
  {-N,--no-line-number}'[suppress line numbers]' \
  {-H,--with-filename}'[print file name with matches]' \
  '--no-filename[suppress file name prefix]' \
  '--heading[print file name above matches]' \
  '--no-heading[do not group matches by file]' \
  {-p,--pretty}'[alias for --color always --heading --line-number]' \
  {-z,--search-zip}'[search in compressed files]' \
  {-A,--after-context}'[show N lines after match]:lines' \
  {-B,--before-context}'[show N lines before match]:lines' \
  {-C,--context}'[show N lines before and after match]:lines' \
  '1:pattern' \
  '*:file or directory:_files' \
  && ret=0

return ret
