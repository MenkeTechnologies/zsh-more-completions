#compdef pkfix
# Documentation: https://man.archlinux.org/search?q=pkfix
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--help[print usage]'
  '--version[print version number]'
  '--tex[tex command name (plain format) (tex)]'
  '--dvips[dvips command name (dvips)]'
  '--options[dvips options (-Ppdf -G0)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
