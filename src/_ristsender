#compdef ristsender

local -a arguments

arguments=(
  {-i,--inputurl}'[comma separated list of input udp or rtp URLs]:urls: '
  {-o,--outputurl}'[comma separated list of output rist URLs]:urls: '
  {-b,--buffer}'[default buffer size for packet retransmissions]:size: '
  {-s,--secret}'[default pre-shared encryption secret]:secret: '
  {-e,--encryption-type}'[default encryption type]:type:(0 128 256)'
  {-p,--profile}'[rist profile]:profile:(0 1 2)'
  {-n,--null-packet-deletion}'[enable NPD, receiver needs to support this]'
  {-S,--statsinterval}'[interval at which stats get printed, 0 to disable]:ms: '
  {-v,--verbose-level}'[log level, -1 to disable]:level: '
  {-r,--remote-logging}'[send logs and stats to this address using udp]:ip\:port: '
  {-F,--srpfile}'[file to hold the SRP list in listening mode]:file:_files'
  {-f,--fast-start}'[controls data output flow before handshake is completed]'
  '(- * :)'{-h,--help}'[show this help]'
  {-u,--help-url}'[show all the possible url options]'
  '*:filename:_files'
)

_arguments -s -S $arguments
