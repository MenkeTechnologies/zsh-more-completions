#compdef eu-ranlib
# Documentation: https://man.archlinux.org/search?q=eu-ranlib
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-D[use zero for uid, gid, and date in archive]'
  '-U[use actual uid, gid, and date in archive members.]'
  '--usage[give a short usage message]'
  {-V,--version}'[print program version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
