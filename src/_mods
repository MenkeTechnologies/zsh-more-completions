#compdef mods

# Zsh completion for mods (AI on the command line)

_arguments -s -S \
  '(-m --model)'{-m,--model}'[model to use]:model:' \
  '(-a --api)'{-a,--api}'[API provider]:api:(openai azure anthropic google)' \
  '(-x --max-tokens)'{-x,--max-tokens}'[max tokens in response]:tokens:' \
  '(-n --no-limit)'{-n,--no-limit}'[do not limit tokens]' \
  '--max-retries[max retries]:retries:' \
  '(-t --temp)'{-t,--temp}'[temperature]:temp:' \
  '(-p --topp)'{-p,--topp}'[top-p sampling]:topp:' \
  '--fanciness[fanciness of output]:fanciness:' \
  '(-s --stop)'{-s,--stop}'[stop sequences]:stop:' \
  '(-r --role)'{-r,--role}'[system role/prompt]:role:' \
  '(-P --prefix)'{-P,--prefix}'[response prefix]:prefix:' \
  '(-R --raw)'{-R,--raw}'[output raw response]' \
  '(-f --format)'{-f,--format}'[ask for output in format]' \
  '--format-as[specify output format]:format:(json markdown)' \
  '(-c --continue)'{-c,--continue}'[continue from last response]' \
  '--continue-last[continue last conversation]' \
  '(-C --show-last)'{-C,--show-last}'[show last conversation]' \
  '(-t --title)'{-t,--title}'[set conversation title]:title:' \
  '(-l --list)'{-l,--list}'[list saved conversations]' \
  '(-d --delete)'{-d,--delete}'[delete conversation]:title:' \
  '--delete-older-than[delete conversations older than]:duration:' \
  '--no-cache[do not cache responses]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '--settings[open settings in editor]' \
  '--dirs[print directories]' \
  '--reset-settings[reset settings to defaults]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:prompt:' && return 0
