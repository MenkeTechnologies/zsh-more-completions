#compdef ecryptfs-setup-private

local -a arguments

arguments=(
  {-f,--force}'[force overwriting of an existing setup]'
  {-w,--wrapping}'[use an independent wrapping passphrase]'
  {-n,--no-fnek}'[do not encrypt filenames]'
  {-u,--username}'[username for encrypted private mountpoint]'
  {-l,--loginpass}'[login/Wrapping passphrase for USER]'
  '--nopwcheck[do not check the validity of the specified passphrase]'
  '--noautomount[setup this user such that the encrypted private directory is not automounted]'
  '--noautoumount[setup this user such that the encrypted private directory is not autoumounted]'
  {-m,--mountpass}'[passphrase for mounting the ecryptfs directory]'
  {-b,--bootstrap}'[bootstrap a new users entire home directory]'
  '--undo[provide instructions on how to undo an encrypted private setup]'
  '*:filename:_files'
)

_arguments -s -S $arguments
