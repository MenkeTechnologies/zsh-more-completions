#compdef logrotate

local -a arguments

arguments=(
  {-d,--debug}'[turn on debug mode, implies -v, no changes are made to the logs]'
  {-f,--force}'[force file rotation even if logrotate does not consider it necessary]'
  {-m,--mail}'[specify command to use when mailing logs]:mail command:_command_names'
  {-s,--state}'[use an alternate state file]:state file:_files'
  {-v,--verbose}'[turn on verbose mode, display messages during rotation]'
  {-l,--log}'[log verbose output into the specified log file or "syslog" for syslog]:log file:_files'
  '--skip-state-lock[do not lock the state file]'
  '--wait-for-state-lock[wait until lock on the state file is released by another logrotate process]'
  '(- *)'{-\?,--help}'[print help message]'
  '(- *)--usage[display brief usage message]'
  '(- *)--version[display version information]'
  '*:config file:_files'
)

_arguments -s -S $arguments
