#compdef mimir

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,-help}'[show help]' \
  '(- *)-version[show version]' \
  '-config.file=[YAML config file]:config file:_files' \
  '-config.expand-env[expand environment variables in config]' \
  '-target=[comma-separated list of modules to run]:target' \
  '-server.http-listen-address=[HTTP server listen address]:address' \
  '-server.http-listen-port=[HTTP server listen port]:port' \
  '-server.grpc-listen-address=[gRPC server listen address]:address' \
  '-server.grpc-listen-port=[gRPC server listen port]:port' \
  '-log.level=[log level]:level:(debug info warn error)' \
  '-log.format=[log format]:format:(logfmt json)' \
  '-print-config[dump the whole config]' \
  '-mem-ballast-size-bytes=[size of memory ballast in bytes]:bytes' \
  '-blocks-storage.backend=[backend for blocks storage]:backend:(filesystem s3 gcs azure swift)' \
  '-blocks-storage.s3.bucket-name=[S3 bucket name]:bucket' \
  '-blocks-storage.s3.endpoint=[S3 endpoint]:endpoint' \
  '-blocks-storage.gcs.bucket-name=[GCS bucket name]:bucket' \
  '-blocks-storage.filesystem.dir=[local filesystem directory]:directory:_directories' \
  '-ingester.ring.instance-addr=[ingester instance address]:address' \
  '-ingester.ring.replication-factor=[replication factor]:factor' \
  '-distributor.ring.instance-addr=[distributor instance address]:address' \
  '-store-gateway.sharding-ring.replication-factor=[store gateway replication factor]:factor' && ret=0

return ret
