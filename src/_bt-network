#compdef bt-network
# Documentation: https://man.archlinux.org/search?q=bt-network
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  {-a,--adapter}'[adapter Name or MAC]'
  {-c,--connect}'[connect to the network device]'
  {-s,--server}'[start GN/PANU/NAP server]'
  {-d,--daemon}'[run in background (as daemon)]'
  {-c,--connect}'[<uuid>]'
  {-s,--server}'[<brige>]'
  '*:filename:_files'
)

_arguments -s -S $arguments
