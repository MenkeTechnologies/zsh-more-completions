#compdef tracker3-import
# Documentation: https://man.archlinux.org/search?q=tracker3-import
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[show help options]'
  {-d,--database}'[location of the database]'
  {-b,--dbus-service}'[service name        Connects to a DBus service]'
  {-r,--remote-service}'[service URI     Connects to a remote service]'
  {-g,--trig}'[read TriG format which includes named graph information]'
  '*:filename:_files'
)

_arguments -s -S $arguments
