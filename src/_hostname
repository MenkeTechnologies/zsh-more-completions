#compdef hostname

# Zsh completion for hostname (show or set system hostname)
# Supports both BSD (macOS/FreeBSD) and GNU/Linux versions

local curcontext="$curcontext" ret=1

if [[ "$OSTYPE" == linux* ]]; then
  # GNU hostname (net-tools / systemd)
  _arguments -s -S \
    '(-s -d -f -A -I -i)'{-a,--alias}'[display alias name of the host]' \
    '(-s -d -f -a -I -i)'{-A,--all-fqdns}'[display all FQDNs of the machine]' \
    {-b,--boot}'[set default hostname if none available]:hostname' \
    '(-s -a -A -I -i)'{-d,--domain}'[display DNS domain name]' \
    '(-d -a -A -I -i)'{-f,--fqdn,--long}'[display fully qualified domain name (FQDN)]' \
    {-F,--file}'[read hostname or NIS domain name from file]:file:_files' \
    '(-s -d -f -a -A -I)'{-i,--ip-address}'[display IP address(es) for the hostname]' \
    '(-s -d -f -a -A -i)'{-I,--all-ip-addresses}'[display all IP addresses of the host]' \
    '(-d -f -a -A -I -i)'{-s,--short}'[display short hostname (up to first dot)]' \
    {-y,--yp,--nis}'[display NIS/YP domain name]' \
    '(- *)'{-h,--help}'[display help and exit]' \
    '(- *)'{-V,--version}'[output version information and exit]' \
    '1:hostname' && ret=0
else
  # BSD hostname (macOS/FreeBSD)
  _arguments -s -S \
    '(-s -d)-f[include domain information in printed name (default)]' \
    '(-f -d)-s[trim off domain information from printed name]' \
    '(-f -s)-d[only print domain information]' \
    '1:hostname' && ret=0
fi

return ret
