#compdef libreoffice

local -a arguments

arguments=(
  '(- * :)'{--help,-h}'[show help and quit]'
  '--helpwriter[open built-in or online Help on Writer]'
  '--helpcalc[open built-in or online Help on Calc]'
  '--helpdraw[open built-in or online Help on Draw]'
  '--helpimpress[open built-in or online Help on Impress]'
  '--helpbase[open built-in or online Help on Base]'
  '--helpbasic[open built-in or online Help on Basic scripting]'
  '--helpmath[open built-in or online Help on Math]'
  '--version[show the version and quit]'
  '--quickstart[activate the Quickstarter service]'
  '--nolockcheck[disable check for remote instances using one installation]'
  '--infilter[force an input filter type if possible]:filter:'
  '--pidfile[store soffice.bin pid to file]:file:_files'
  '--display[set the DISPLAY environment variable]:display:'
  '--nologo[disable the splash screen at program start]'
  '--minimized[start minimized, no splash screen]'
  '--nodefault[start without displaying anything except the splash screen]'
  '--invisible[start in invisible mode]'
  '--headless[start in headless mode for command-line usage]'
  '--norestore[disable restart and file recovery after a system crash]'
  '--safe-mode[start in safe mode with a fresh user profile]'
  '--accept[specify a UNO-URL connect-string to create an UNO acceptor]:connect-string:'
  '--unaccept[close an acceptor created with --accept]:connect-string:'
  '--language[use specified language]:language:'
  '--terminate_after_init[terminate after initialization]'
  '--eventtesting[exit after loading documents]'
  '--writer[create an empty Writer document]'
  '--calc[create an empty Calc document]'
  '--draw[create an empty Draw document]'
  '--impress[create an empty Impress document]'
  '--base[create a new database]'
  '--global[create an empty Writer master (global) document]'
  '--math[create an empty Math document (formula)]'
  '--web[create an empty HTML document]'
  '-n[treat following files as templates for creation of new documents]'
  '-o[open following files for editing]'
  '--pt[print following files to the specified printer]:printer name:'
  '--print-to-file[print following files to file]'
  '-p[print following files to the default printer]'
  '--view[open following files in viewer mode (read-only)]'
  '--show[open and start the following presentation documents]'
  '--convert-to[convert following files to the specified format]:format:'
  '--outdir[specify output directory for conversion]:dir:_files -/'
  '--convert-images-to[convert images in the document to the specified format]:format:'
  '--cat[dump text content of the following files to console]'
  '--script-cat[dump text content of any scripts embedded in the files to console]'
  '--printer-name[specify the printer name for --print-to-file]:printer:'
  '--nofirststartwizard[no-op, accepted only for backward compatibility]'
  '*:filename:_files'
)

_arguments -s -S $arguments
