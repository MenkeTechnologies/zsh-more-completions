#compdef curlie

# Zsh completion for curlie - The power of curl, the ease of use of httpie

local curcontext="$curcontext" state line ret=1

local -a methods=(
  'GET:HTTP GET request'
  'POST:HTTP POST request'
  'PUT:HTTP PUT request'
  'DELETE:HTTP DELETE request'
  'PATCH:HTTP PATCH request'
  'HEAD:HTTP HEAD request'
  'OPTIONS:HTTP OPTIONS request'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-v[verbose mode]' \
  '--verbose[verbose mode]' \
  '-k[allow insecure connections]' \
  '--insecure[allow insecure connections]' \
  '-i[include response headers in output]' \
  '--include[include response headers in output]' \
  '-s[silent mode]' \
  '--silent[silent mode]' \
  '-L[follow redirects]' \
  '--location[follow redirects]' \
  '-o[write output to file]:output file:_files' \
  '--output=[write output to file]:output file:_files' \
  '-H[add custom header]:header:' \
  '--header=[add custom header]:header:' \
  '-d[send data]:data:' \
  '--data=[send data]:data:' \
  '-X[specify request method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
  '--request=[specify request method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
  '-u[server user and password]:user\:password:' \
  '--user=[server user and password]:user\:password:' \
  '-A[specify user agent]:user agent:' \
  '--user-agent=[specify user agent]:user agent:' \
  '-b[send cookies]:cookies:' \
  '--cookie=[send cookies]:cookies:' \
  '-c[write cookies to file]:cookie file:_files' \
  '--cookie-jar=[write cookies to file]:cookie file:_files' \
  '-x[use proxy]:proxy URL:' \
  '--proxy=[use proxy]:proxy URL:' \
  '--connect-timeout=[maximum time for connection]:seconds:' \
  '-m[maximum time for transfer]:seconds:' \
  '--max-time=[maximum time for transfer]:seconds:' \
  '-F[specify multipart form data]:form data:' \
  '--form=[specify multipart form data]:form data:' \
  '--cert=[client certificate file]:cert file:_files' \
  '--key=[private key file]:key file:_files' \
  '--cacert=[CA certificate file]:ca file:_files' \
  '-I[fetch headers only]' \
  '--head[fetch headers only]' \
  '*:URL:_urls' && ret=0

return ret
