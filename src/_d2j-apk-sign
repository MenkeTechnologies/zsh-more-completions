#compdef d2j-apk-sign
# Documentation: https://man.archlinux.org/search?q=d2j-apk-sign
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-f,--force}'[force overwrite]'
  '(- * :)'{-h,--help}'[print this help message]'
  {-o,--output}'[output .apk file, default is $current_dir/\[apk-name\]-signed.apk]:file:_files'
  {-t,--tiny}'[use tiny sign]'
  '*:filename:_files'
)

_arguments -s -S $arguments
