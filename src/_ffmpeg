#compdef ffmpeg

# Zsh completion for ffmpeg - universal media converter
# https://ffmpeg.org/

_ffmpeg() {
    local -a arguments

    arguments=(
        # Print help / information / capabilities
        '(- 1 *)'{-h,-help,--help}'[show help]:topic:(long full)'
        '(- 1 *)'{-\?}'[show help]:topic:(long full)'
        '(- 1 *)'-L'[show license]'
        '(- 1 *)'-license'[show license]'
        '(- 1 *)'-version'[show version]'
        '(- 1 *)'-buildconf'[show build configuration]'
        '(- 1 *)'-formats'[show available formats]'
        '(- 1 *)'-muxers'[show available muxers]'
        '(- 1 *)'-demuxers'[show available demuxers]'
        '(- 1 *)'-devices'[show available devices]'
        '(- 1 *)'-codecs'[show available codecs]'
        '(- 1 *)'-decoders'[show available decoders]'
        '(- 1 *)'-encoders'[show available encoders]'
        '(- 1 *)'-filters'[show available filters]'
        '(- 1 *)'-pix_fmts'[show available pixel formats]'
        '(- 1 *)'-layouts'[show standard channel layouts]'
        '(- 1 *)'-sample_fmts'[show available audio sample formats]'
        '(- 1 *)'-dispositions'[show available stream dispositions]'
        '(- 1 *)'-colors'[show available color names]'
        '(- 1 *)'-bsfs'[show available bit stream filters]'
        '(- 1 *)'-protocols'[show available protocols]'
        '(- 1 *)'-hwaccels'[show available HW acceleration methods]'
        '(- 1 *)'-sources'[list sources of the input device]:device:'
        '(- 1 *)'-sinks'[list sinks of the output device]:device:'

        # Global options
        '-y[overwrite output files without asking]'
        '-n[never overwrite output files]'
        {-v,-loglevel}'[set logging level]:level:(quiet panic fatal error warning info verbose debug trace)'
        '-stats[print progress report during encoding]'
        '-nostats[disable printing progress/statistics]'
        '-hide_banner[suppress printing banner]'
        '-report[generate a report]'
        '-print_graphs[print execution graph data to stderr]'
        '-print_graphs_file[write execution graph data to file]:file:_files'
        '-print_graphs_format[set output printing format]:format:(default compact csv flat ini json xml mermaid mermaidhtml)'
        '-max_alloc[set maximum size of a single allocated block]:bytes:'
        '-cpuflags[force specific CPU flags]:flags:'
        '-cpucount[force specific CPU count]:count:'
        '-ignore_unknown[ignore unknown stream types]'
        '-copy_unknown[copy unknown stream types]'
        '-recast_media[allow recasting stream type to force a decoder of different media type]'
        '-benchmark[add timings for benchmarking]'
        '-benchmark_all[add timings for each task]'
        '-progress[write program-readable progress information]:url:'
        '-stdin[enable or disable interaction on standard input]'
        '-timelimit[set max runtime in seconds in CPU user time]:limit:'
        '-dump[dump each input packet]'
        '-hex[when dumping packets also dump the payload]'
        '-frame_drop_threshold[frame drop threshold]:threshold:'
        '-copyts[copy timestamps]'
        '-start_at_zero[shift input timestamps to start at 0 when using copyts]'
        '-copytb[copy input stream time base when stream copying]:mode:'
        '-dts_delta_threshold[timestamp discontinuity delta threshold]:threshold:'
        '-dts_error_threshold[timestamp error delta threshold]:threshold:'
        '-xerror[exit on error]:error:'
        '-abort_on[abort on the specified condition flags]:flags:'
        '-filter_threads[number of non-complex filter threads]:threads:'
        '-filter_buffered_frames[maximum number of buffered frames in a filter graph]:frames:'
        '-filter_complex_threads[number of threads for -filter_complex]:threads:'
        '-auto_conversion_filters[enable automatic conversion filters globally]'
        '-stats_period[set the period at which ffmpeg updates stats]:time:'
        '-debug_ts[print timestamp debugging info]'
        '-max_error_rate[ratio of decoding errors above which ffmpeg returns an error]:rate:'
        '-vstats[dump video coding statistics to file]'
        '-vstats_file[dump video coding statistics to file]:file:_files'
        '-vstats_version[version of the vstats format to use]'
        '-sdp_file[specify a file in which to print SDP information]:file:_files'
        '-init_hw_device[initialise hardware device]:args:'
        '-filter_hw_device[set hardware device used when filtering]:device:'
        '-threads[set number of threads]:threads:'

        # Per-file options (input and output)
        '-f[force container format]:format:'
        '-t[stop transcoding after specified duration]:duration:'
        '-to[stop transcoding after specified time is reached]:time_stop:'
        '-ss[start transcoding at specified time]:time_off:'
        '-bitexact[bitexact mode]'
        '-thread_queue_size[set the maximum number of queued packets from the demuxer]:size:'

        # Per-file options (input-only)
        '-sseof[set the start time offset relative to EOF]:time_off:'
        '-seek_timestamp[enable/disable seeking by timestamp with -ss]'
        '-accurate_seek[enable/disable accurate seeking with -ss]'
        '-isync[indicate the input index for sync reference]:sync_ref:'
        '-itsoffset[set the input ts offset]:time_off:'
        '-re[read input at native frame rate]'
        '-readrate[read input at specified rate]:speed:'
        '-readrate_initial_burst[initial amount of input to burst read]:seconds:'
        '-readrate_catchup[temporary readrate to catch up if input lags]:speed:'
        '*-dump_attachment[extract an attachment into a file]:filename:_files'
        '-stream_loop[set number of times input stream shall be looped]:count:'
        '-find_stream_info[read and decode the streams to fill missing information]'

        # Per-file options (output-only)
        '*-metadata[add metadata key=value pair]:metadata:'
        '*-map[set input stream mapping]:map:'
        '*-map_metadata[set metadata information of output from input]:map:'
        '-map_chapters[set chapters mapping]:input_index:'
        '-fs[set the limit file size in bytes]:limit_size:'
        '-timestamp[set the recording timestamp]:timestamp:'
        '*-program[add program with specified streams]:program_spec:'
        '*-stream_group[add stream group with specified streams]:group_spec:'
        '-dframes[set the number of data frames to output]:number:'
        '-target[specify target file type]:type:(vcd svcd dvd dv dv50 pal-vcd ntsc-vcd pal-svcd ntsc-svcd pal-dvd ntsc-dvd pal-dv ntsc-dv film-dv)'
        '-shortest[finish encoding within shortest input]'
        '-shortest_buf_duration[maximum buffering duration for the -shortest option]:duration:'
        '-qscale[use fixed quality scale (VBR)]:quality:'
        '-profile[set profile]:profile:'
        '-attach[add an attachment to the output file]:filename:_files'
        '-muxdelay[set the maximum demux-decode delay]:seconds:'
        '-muxpreload[set the initial demux-decode delay]:seconds:'
        '-fpre[set options from indicated preset file]:filename:_files'

        # Per-stream options
        '*'{-c,-codec}'[select encoder/decoder]:codec:'
        '*-filter[apply specified filters to audio/video]:filter_graph:'
        '*-pre[preset name]:preset:'
        '*-itsscale[set the input ts scale]:scale:'
        '*-copyinkf[copy initial non-keyframes]'
        '*-copypriorss[copy or discard frames before start time]'
        '*-frames[set the number of frames to output]:number:'
        '*-tag[force codec tag/fourcc]:fourcc:'
        '*-q[use fixed quality scale (VBR)]:quality:'
        '*-reinit_filter[reinit filtergraph on input parameter changes]'
        '*-drop_changed[drop frame instead of reiniting filtergraph on input parameter changes]'
        '*-discard[discard]:discard:'
        '*-disposition[set disposition]:disposition:'
        '*-bits_per_raw_sample[set the number of bits per raw sample]:number:'
        '*-bsf[bitstream filters]:filters:'
        '*-max_muxing_queue_size[maximum number of packets buffered while waiting for all streams]:packets:'
        '*-muxing_queue_data_threshold[threshold after which max_muxing_queue_size is taken into account]:bytes:'
        '*-time_base[set the desired time base hint for output stream]:ratio:'
        '*-enc_time_base[set the desired time base for the encoder]:ratio:'

        # Video options
        {-vcodec,-c:v}'[set video codec]:codec:(libx264 libx265 libvpx-vp9 libaom-av1 libsvtav1 copy h264_videotoolbox hevc_videotoolbox mpeg4 libtheora rawvideo png mjpeg prores av1)'
        {-vf,-filter:v}'[set video filters]:filter_graph:'
        '-r[set frame rate]:rate:'
        '-s[set frame size WxH]:size:'
        '-aspect[set aspect ratio]:aspect:(4\:3 16\:9 16\:10 1\:1)'
        '-vn[disable video]'
        '-vframes[set the number of video frames to output]:number:'
        '-b:v[set video bitrate]:bitrate:'
        '-crf[set constant rate factor]:crf:'
        '-preset[set encoding preset]:preset:(ultrafast superfast veryfast faster fast medium slow slower veryslow placebo)'
        '-tune[set encoding tuning]:tune:(film animation grain stillimage psnr ssim fastdecode zerolatency)'
        '-profile:v[set video profile]:profile:(baseline main high high10 high422 high444)'
        '-level[set encoding level]:level:'
        '-pix_fmt[set pixel format]:format:'
        '-g[set GOP size]:size:'
        '-bf[set number of B-frames]:frames:'
        '-pass[select pass number]:pass:(1 2 3)'
        '-passlogfile[select two pass log file name prefix]:prefix:'
        '-rc-lookahead[set number of frames for ratecontrol lookahead]:frames:'
        '-maxrate[set maximum bitrate]:rate:'
        '-minrate[set minimum bitrate]:rate:'
        '-bufsize[set rate control buffer size]:size:'
        '-fpsmax[set max frame rate]:rate:'
        '-display_rotation[set pure counter-clockwise rotation in degrees]:angle:'
        '-display_hflip[set display horizontal flip for stream]'
        '-display_vflip[set display vertical flip for stream]'
        '-rc_override[rate control override for specific intervals]:override:'
        '-timecode[set initial TimeCode value]:timecode:'
        '-force_key_frames[force key frames at specified timestamps]:timestamps:'
        '-fps_mode[set framerate mode for matching video streams]:mode:(passthrough cfr vfr auto)'
        '-force_fps[force the selected framerate]'
        '-streamid[set the value of an outfile streamid]:streamIndex\:value:'
        '-vtag[force video tag/fourcc]:fourcc:'
        '-autorotate[automatically insert correct rotate filters]'
        '-autoscale[automatically insert a scale filter at the end of the filter graph]'
        '-apply_cropping[select the cropping to apply]'
        '-vpre[set video options to the indicated preset]:preset:'

        # Audio options
        {-acodec,-c:a}'[set audio codec]:codec:(aac libmp3lame libopus libvorbis flac pcm_s16le pcm_s24le pcm_s32le pcm_f32le copy ac3 eac3 libfdk_aac alac pcm_s16be pcm_mulaw pcm_alaw)'
        {-af,-filter:a}'[set audio filters]:filter_graph:'
        '-ar[set audio sampling rate in Hz]:rate:(8000 11025 16000 22050 32000 44100 48000 88200 96000 176400 192000)'
        '-ac[set number of audio channels]:channels:'
        '-an[disable audio]'
        '-aframes[set the number of audio frames to output]:number:'
        '-b:a[set audio bitrate]:bitrate:(32k 64k 96k 128k 160k 192k 224k 256k 320k)'
        '-ab[alias for -b:a (select bitrate for audio streams)]:bitrate:'
        '-aq[set audio quality (codec-specific)]:quality:'
        '-vol[change audio volume (256=normal)]:volume:'
        '-sample_fmt[set sample format]:format:'
        '-channel_layout[set channel layout]:layout:'
        '-ch_layout[set channel layout]:layout:'
        '-guess_layout_max[set maximum number of channels to try to guess channel layout]:channels:'
        '-apad[audio pad]:pad_params:'
        '-atag[force audio tag/fourcc]:fourcc:'
        '-apre[set audio options to the indicated preset]:preset:'

        # Subtitle options
        {-scodec,-c:s}'[set subtitle codec]:codec:(mov_text ass srt subrip webvtt dvd_subtitle dvb_subtitle copy)'
        '-sn[disable subtitles]'
        '-stag[force subtitle tag/fourcc]:fourcc:'
        '-fix_sub_duration[fix subtitles duration]'
        '-canvas_size[set canvas size]:size:'
        '-spre[set subtitle options to the indicated preset]:preset:'

        # Data stream options
        '-dcodec[alias for -c:d (select encoder/decoder for data streams)]:codec:'
        '-dn[disable data]'

        # Complex filters
        '-filter_complex[create a complex filtergraph]:filtergraph:'
        '-lavfi[create a complex filtergraph (alias for -filter_complex)]:filtergraph:'
        '-filter_complex_script[read complex filtergraph description from a file]:filename:_files'

        # Output options
        '-movflags[set MOV muxer flags]:flags:(faststart frag_keyframe empty_moov default_base_moof separate_moof negative_cts_offsets)'

        # Input
        '*-i[input file]:input file:_files'

        # Hardware acceleration
        '-hwaccel[set hardware acceleration method]:method:(none auto videotoolbox cuda vaapi qsv d3d11va dxva2 vulkan)'
        '-hwaccel_device[select a device for hardware acceleration]:device:'
        '-hwaccel_output_format[select output format used with hardware acceleration]:format:'

        # Stats encoding/muxing
        '-stats_enc_pre[write encoding stats before encoding]'
        '-stats_enc_post[write encoding stats after encoding]'
        '-stats_mux_pre[write packets stats before muxing]'
        '-stats_enc_pre_fmt[format of stats written with -stats_enc_pre]:format:'
        '-stats_enc_post_fmt[format of stats written with -stats_enc_post]:format:'
        '-stats_mux_pre_fmt[format of stats written with -stats_mux_pre]:format:'

        # Positional output file
        '*:output file:_files'
    )

    _arguments -s -S $arguments
}

_ffmpeg "$@"
