#compdef sg_rdac
# Documentation: https://man.archlinux.org/search?q=sg_rdac
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-6[use 6 byte cdbs for mode sense/select]'
  '-a[transfer all devices to the controller]'
  '-f[transfer the device at LUN to the]'
  '-v[verbose]'
  '-V[print version then exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
