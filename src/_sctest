#compdef sctest

local -a arguments

arguments=(
  {-a,--argos-csi}'[use this argos csi file as input]:path:_files'
  {-b,--bind}'[bind this ip:port]:ip\:port:'
  {-c,--connect}'[redirect connects to this ip:port]:ip\:port:'
  {-C,--cmd}'[command to execute for "cmd" in shellcode]:cmd:'
  {-d,--dump}'[dump the shellcode (binary) to stdout]'
  {-g,--getpc}'[run getpc mode, try to detect a shellcode]'
  {-G,--graph}'[save a dot formatted callgraph in filepath]:path:_files'
  '(- * :)'{-h,--help}'[show this help]'
  {-i,--interactive}'[proxy api calls to the host operating system]'
  {-l,--listtests}'[list all tests]'
  {-o,--offset}'[manual offset for shellcode]:offset:'
  {-p,--profile}'[write shellcode profile to this file]:path:_files'
  {-S,--stdin}'[read shellcode/buffer from stdin]'
  {-s,--steps}'[max number of steps to run]:steps:'
  {-t,--testnumber}'[the test to run]:number:'
  {-v,--verbose}'[be verbose, can be used multiple times]'
  '*:filename:_files'
)

_arguments -s -S $arguments
