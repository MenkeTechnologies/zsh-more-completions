#compdef s3fs
# Documentation: https://man.archlinux.org/search?q=s3fs
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '*-o[mount option]:option'
  {-u,--incomplete-mpu-list}'[list multipart incomplete objects uploaded to the specified bucket]'
  '--incomplete-mpu-abort[abort incomplete multipart uploads older than given date]:date'
  {-h,--help}'[output this help.]'
  '--version[output version info.]'
  {-d,--debug}'[turn on DEBUG messages to syslog]'
  '-f[FUSE foreground option - do not run as daemon.]'
  '-s[FUSE single-threaded option]'
  '*:filename:_files'
)

_arguments -s -S $arguments
