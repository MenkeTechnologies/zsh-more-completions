#compdef shares-admin
# Documentation: https://man.archlinux.org/search?q=shares-admin
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  '--help-all[show all help options]'
  '--help-gtk[show GTK+ Options]'
  {-a,--add-share}'[add a shared path, modifies it if it already exists]'
  '--display[X display to use]'
  '*:filename:_files'
)

_arguments -s -S $arguments
