#compdef imgpkg

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'copy:copy a bundle from one location to another'
  'describe:describe a bundle'
  'pull:pull remote bundle into local directory'
  'push:push a new bundle to a registry'
  'tag:manage tags for images and bundles'
  'version:print client version'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--debug[enable debug output]' \
  '--tty[force TTY-like output]' \
  '--column=[control column output]:column' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'imgpkg command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (push)
        _arguments -s -S \
          '(-b --bundle)'{-b,--bundle}'=[set bundle image reference]:image ref' \
          '(-i --image)'{-i,--image}'=[set image reference]:image ref' \
          '(-f --file)'{-f,--file}'=[set directory to push]:directory:_directories' \
          '--file-exclusion=[exclude files matching glob]:glob' \
          '--lock-output=[file path to write bundle lock]:file:_files' \
          '--label=[set metadata labels]:label (key=value)' \
          '--registry-ca-cert-path=[path to CA cert]:file:_files' \
          '--registry-username=[registry username]:username' \
          '--registry-password=[registry password]:password' \
          '--registry-token=[registry token]:token' \
          '--registry-insecure[allow insecure connections]' && ret=0
        ;;
      (pull)
        _arguments -s -S \
          '(-b --bundle)'{-b,--bundle}'=[set bundle image reference]:image ref' \
          '(-i --image)'{-i,--image}'=[set image reference]:image ref' \
          '(-o --output)'{-o,--output}'=[set output directory]:directory:_directories' \
          '--lock-output=[file path to write lock]:file:_files' \
          '--registry-ca-cert-path=[path to CA cert]:file:_files' \
          '--registry-username=[registry username]:username' \
          '--registry-password=[registry password]:password' \
          '--registry-token=[registry token]:token' \
          '--registry-insecure[allow insecure connections]' && ret=0
        ;;
      (copy)
        _arguments -s -S \
          '(-b --bundle)'{-b,--bundle}'=[source bundle image reference]:image ref' \
          '(-i --image)'{-i,--image}'=[source image reference]:image ref' \
          '--to-repo=[destination repository]:repo' \
          '--to-tar=[destination tar file]:file:_files' \
          '--tar=[source tar file]:file:_files' \
          '--lock-output=[file path to write lock]:file:_files' \
          '--concurrency=[number of concurrent copies]:number' \
          '--include-non-distributable-layers[include non-distributable layers]' \
          '--registry-ca-cert-path=[path to CA cert]:file:_files' \
          '--registry-username=[registry username]:username' \
          '--registry-password=[registry password]:password' && ret=0
        ;;
      (tag)
        local -a tag_cmds=(
          'list:list tags for image'
          'resolve:resolve a tag to a digest'
        )
        _arguments \
          '1:subcommand:_describe -t tag-commands "tag command" tag_cmds' \
          '*:args' && ret=0
        ;;
    esac
    ;;
esac

return ret
