  '-X[enable X11 forwarding]'
  '-x[disable X11 forwarding]'
  '-Y[enable trusted X11 forwarding]'
  '-y[send log information using syslog(3) system module]'

  '1:host:_ssh_hosts'
  '*:command:_command_names -e'
)

_arguments -s -S $arguments
