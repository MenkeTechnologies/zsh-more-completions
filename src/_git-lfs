#compdef git-lfs

# Zsh completion for git-lfs - Git Large File Storage

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'track:view or add LFS paths to gitattributes'
  'untrack:remove LFS paths from gitattributes'
  'install:ensure git-lfs configuration'
  'uninstall:uninstall git-lfs configuration'
  'pull:download LFS files for current ref'
  'push:push LFS files to remote'
  'fetch:download LFS files from remote'
  'checkout:populate working tree with real LFS content'
  'lock:set a file as locked on the server'
  'unlock:remove a file lock from the server'
  'locks:list currently locked files'
  'migrate:migrate history to or from LFS'
  'ls-files:show information about LFS files'
  'status:show LFS status of files'
  'logs:show errors from LFS command'
  'env:show the LFS environment'
  'ext:manage extensions'
  'prune:delete old LFS files from local storage'
  'dedup:deduplicate LFS files'
  'pointer:build or compare pointers'
  'version:show the version number'
)

_arguments -s -S \
  '1:command:->command' \
  '--version[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'git-lfs command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (track)
        _arguments -s -S \
          '--lockable[make tracked patterns lockable]' \
          '--not-lockable[make tracked patterns not lockable]' \
          '--no-excluded[exclude .gitattributes rules from listing]' \
          '--no-modify-attrs[do not modify .gitattributes]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:pattern' && ret=0
        ;;
      (untrack)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:pattern' && ret=0
        ;;
      (install)
        _arguments -s -S \
          '--force[set LFS filters, overwriting existing]' \
          '--local[set local repository filters]' \
          '--system[set system-wide filters]' \
          '--worktree[set per-worktree filters]' \
          '--skip-smudge[skip automatic downloading of objects]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (pull)
        _arguments -s -S \
          '(-I --include)'{-I,--include}'[include paths matching pattern]:pattern' \
          '(-X --exclude)'{-X,--exclude}'[exclude paths matching pattern]:pattern' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:remote' && ret=0
        ;;
      (push)
        _arguments -s -S \
          '--all[push all objects to remote]' \
          '--dry-run[do not actually push]' \
          '--object-id[push by object ID]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:remote' \
          '2:ref' && ret=0
        ;;
      (fetch)
        _arguments -s -S \
          '(-I --include)'{-I,--include}'[include paths matching pattern]:pattern' \
          '(-X --exclude)'{-X,--exclude}'[exclude paths matching pattern]:pattern' \
          '--all[fetch all objects]' \
          '--recent[fetch recent refs and commits]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:remote' \
          '*:ref' && ret=0
        ;;
      (lock)
        _arguments -s -S \
          '--json[print output in JSON]' \
          '(-r --remote)'{-r,--remote}'[specify the remote]:remote' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:file:_files' && ret=0
        ;;
      (unlock)
        _arguments -s -S \
          '(-f --force)'{-f,--force}'[unlock files by another user]' \
          '--id[unlock by lock ID]:id' \
          '--json[print output in JSON]' \
          '(-r --remote)'{-r,--remote}'[specify the remote]:remote' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:file:_files' && ret=0
        ;;
      (locks)
        _arguments -s -S \
          '--path[filter by path]:path:_files' \
          '--id[filter by lock ID]:id' \
          '(-r --remote)'{-r,--remote}'[specify the remote]:remote' \
          '--json[print output in JSON]' \
          '--local[only list local locks]' \
          '--limit[limit number of results]:number' \
          '--verify[verify lock owner]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (migrate)
        local -a migrate_cmds=(
          'import:convert pointer files to LFS objects'
          'export:convert LFS objects to pointer files'
          'info:show information about LFS objects'
        )
        _arguments -s -S \
          '1:subcommand:->migrate_cmd' \
          '*:: :->migrate_args' && ret=0
        case $state in
          (migrate_cmd)
            _describe -t commands 'migrate subcommand' migrate_cmds && ret=0
            ;;
          (migrate_args)
            _arguments -s -S \
              '(-I --include)'{-I,--include}'[include paths matching pattern]:pattern' \
              '(-X --exclude)'{-X,--exclude}'[exclude paths matching pattern]:pattern' \
              '--include-ref[include ref]:ref' \
              '--exclude-ref[exclude ref]:ref' \
              '--everything[migrate all refs]' \
              '--above[only migrate files above this size]:size' \
              '--object-map[write old/new OID mapping to file]:file:_files' \
              '--no-rewrite[do not rewrite git history]' \
              '--fixup[only fix up existing LFS objects]' \
              '--yes[answer yes to all prompts]' \
              '(-h --help)'{-h,--help}'[show help]' && ret=0
            ;;
        esac
        ;;
      (ls-files)
        _arguments -s -S \
          '--all[show all LFS files, not just current]' \
          '(-l --long)'{-l,--long}'[show full OIDs]' \
          '(-s --size)'{-s,--size}'[show size of LFS object]' \
          '(-d --debug)'{-d,--debug}'[show debug information]' \
          '(-I --include)'{-I,--include}'[include paths matching pattern]:pattern' \
          '(-X --exclude)'{-X,--exclude}'[exclude paths matching pattern]:pattern' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:ref' && ret=0
        ;;
      (prune)
        _arguments -s -S \
          '--dry-run[do not actually prune]' \
          '--verify-remote[verify objects exist on remote]' \
          '--no-verify-remote[do not verify objects on remote]' \
          '--recent[prune recent files too]' \
          '--force[prune without confirming]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (pointer)
        _arguments -s -S \
          '--file[file to build pointer for]:file:_files' \
          '--pointer[pointer to compare]:pointer' \
          '--stdin[read from stdin]' \
          '--check[check if file is an LFS pointer]' \
          '--strict[be strict about pointer format]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (*)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
