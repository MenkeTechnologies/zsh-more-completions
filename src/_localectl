#compdef localectl

# zsh completions for 'localectl'

_localectl_commands() {
  local -a commands
  commands=(
    'status:show current settings of the system locale and keyboard mapping'
    'set-locale:set the system locale'
    'list-locales:list available locales'
    'set-keymap:set the system keyboard mapping for console and X11'
    'list-keymaps:list available keyboard mappings for the console'
    'set-x11-keymap:set the system X11 keyboard mapping'
    'list-x11-keymap-models:list available X11 keymap models'
    'list-x11-keymap-layouts:list available X11 keymap layouts'
    'list-x11-keymap-variants:list available X11 keymap variants'
    'list-x11-keymap-options:list available X11 keymap options'
  )
  _describe -t commands 'localectl command' commands
}

_localectl() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -s \
    '(- *)'{-h,--help}'[show help message and exit]' \
    '(- *)--version[show package version]' \
    '--no-pager[do not pipe output into a pager]' \
    '--no-ask-password[do not query the user for authentication]' \
    {-H+,--host=}'[execute the operation on a remote host]:user@host:_hosts' \
    {-M+,--machine=}'[execute operation on a local container]:machine name' \
    '--no-convert[do not convert keyboard mappings between console and X11]' \
    {-l,--full}'[do not ellipsize output]' \
    '(-): :_localectl_commands' \
    '(-)*:: :->args'

  case $state in
    args)
      case ${line[1]} in
        status)
          ;;
        set-locale)
          _arguments '*:locale variable=value'
          ;;
        list-locales)
          ;;
        set-keymap)
          _arguments \
            ':keymap' \
            '::toggle keymap'
          ;;
        list-keymaps)
          ;;
        set-x11-keymap)
          _arguments \
            ':layout' \
            '::model' \
            '::variant' \
            '::options'
          ;;
        list-x11-keymap-models|list-x11-keymap-layouts|list-x11-keymap-options)
          ;;
        list-x11-keymap-variants)
          _arguments '::layout'
          ;;
      esac
      ;;
  esac
}

_localectl "$@"
