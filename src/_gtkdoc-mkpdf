#compdef gtkdoc-mkpdf
# Documentation: https://man.archlinux.org/search?q=gtkdoc-mkpdf
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  '--version[show programs version number and exit]'
  '--verbose[print extra output while processing.]'
  '--path[extra source directories.]'
  '--imgdir[extra image directories.]'
  '--uninstalled[???]'
  '*:filename:_files'
)

_arguments -s -S $arguments
