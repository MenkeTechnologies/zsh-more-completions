#compdef newfs_exfat
# Documentation: https://man.archlinux.org/search?q=newfs_exfat
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-N[do not create file system, just print out parameters]'
  '-I[volume ID]:id:'
  '-S[bytes per sector]:bytes:'
  '-P[physical bytes per sector]:bytes:'
  '-a[sectors per FAT]:sectors:'
  '-b[cluster size in bytes]:size:'
  '-c[sectors per cluster]:sectors:'
  '-n[number of FATs]:count:'
  '-s[file system size in sectors]:sectors:'
  '-v[volume name]:name:'
  '*:filename:_files'
)

_arguments -s -S $arguments
