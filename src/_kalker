#compdef kalker

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-i --input-file)'{-i,--input-file}'[load script file]:file:_files -g "*.kalker"' \
  '--completion[generate shell completion]:shell:(bash zsh fish)' \
  '--no-leading-zeroes[hide leading zeroes on decimals]' \
  '--no-notation[disable scientific notation]' \
  '--precision[decimal precision]:digits' \
  '1:expression' && ret=0

return ret
