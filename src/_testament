#compdef testament

local -a arguments

arguments=(
  '--print[print results to the console]'
  '--verbose[print commands (compiling and running tests)]'
  '--simulate[see what tests would be run but dont run them (for debugging)]'
  '--failing[only show failing/ignored tests]'
  '--targets[run tests for specified targets (default: c)]:targets:'
  '--nim[use a particular nim executable]:path:_files'
  '--directory[change to directory before reading tests]:dir:_directories'
  '--colors[turn messages coloring on or off]:switch:(on off)'
  '--backendLogging[disable or enable backend logging (default: on)]:switch:(on off)'
  '--megatest[enable or disable megatest (default: on)]:switch:(on off)'
  '--valgrind[enable or disable valgrind support (default: on)]:switch:(on off)'
  '--skipFrom[read tests to skip from file]:file:_files'
  '*:filename:_files'
)

_arguments -s -S $arguments
