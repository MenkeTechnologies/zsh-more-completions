#compdef homectl

local -a arguments

arguments=(
    '--identity[read the user JSON record from the specified file]:file:_files'
    {--json,-j}'[control whether to output the user record in JSON format]:mode:(pretty short off)'
    {--export-format,-E}'[suppress certain fields in JSON output]'
    {-H,--host}'[execute the operation remotely]:host:_hosts'
    {-M,--machine}'[execute operation on a local container]:machine:'
    '--no-pager[do not pipe output into a pager]'
    '--no-legend[do not print the legend]'
    '--no-ask-password[do not query the user for authentication]'
    {-h,--help}'[print a short help text and exit]'
    '--version[print a short version string and exit]'
    {--real-name,-c}'[set real name of user]:name:'
    '--realm[set realm of user]:realm:'
    '--email-address[set email address of user]:email:'
    '--location[set location of user]:text:'
    '--icon-name[set icon name of user]:icon:'
    '--home-dir[set home directory of user]:path:_directories'
    '--image-path[set image path for user home]:path:_files'
    '--uid[set UID of user]:uid:'
    {--member-of,-G}'[set group memberships]:groups:'
    '--skel[set skeleton directory]:path:_directories'
    '--shell[set shell of user]:shell:_shells'
    '--setenv[set environment variable for user]:variable=value:'
    '--timezone[set timezone of user]:timezone:'
    '--language[set preferred language for user]:language:'
    '--ssh-authorized-keys[set SSH authorized keys]:keys:'
    '--pkcs11-token-uri[set PKCS#11 security token URI]:uri:'
    '--fido2-device[set FIDO2 device for authentication]:device:'
    '--recovery-key[set whether to configure a recovery key]:bool:(yes no)'
    '--locked[set whether the user account is locked]:bool:(yes no)'
    {--not-before,--not-after}'[set time-based access restriction]'
    {--rate-limit-interval,--rate-limit-burst}'[set rate limiting for authentication]'
    '--password-hint[set password hint]:text:'
    {--enforce-password-policy,-P}'[set whether to enforce password policy]:bool:(yes no)'
    '--password-change-now[require password change on next login]:bool:(yes no)'
    {--password-change-min,--password-change-max,--password-change-warn,--password-change-inactive}'[set password change time restrictions]'
    '--disk-size[set disk size for user home]:bytes:'
    '--access-mode[set access mode for user home]:mode:'
    '--umask[set umask for user]:mask:'
    '--nice[set nice level for user]:nice:'
    '--rlimit[set resource limit for user]:limit:'
    '--tasks-max[set maximum number of tasks for user]:tasks:'
    {--memory-high,--memory-max}'[set memory limits for user]'
    {--cpu-weight,--io-weight}'[set CPU/IO weight for user]'
    '--storage[set storage type for user home]:storage:(luks fscrypt directory subvolume cifs)'
    '--fs-type[set filesystem type for user home]:type:'
    '--luks-discard[enable/disable LUKS discard]:bool:(yes no)'
    '--luks-offline-discard[enable/disable LUKS offline discard]:bool:(yes no)'
    '--luks-cipher[set LUKS cipher]:cipher:'
    {--nosuid,--nodev,--noexec}'[set mount flags for user home]'
    {--cifs-domain,--cifs-user-name,--cifs-service}'[set CIFS parameters]'
    '--stop-delay[set stop delay for user home]:seconds:'
    '--kill-processes[kill user processes on logout]:bool:(yes no)'
    '--auto-login[enable/disable auto-login]:bool:(yes no)'
    '*:filename:_files'
)
_arguments -s -S $arguments
