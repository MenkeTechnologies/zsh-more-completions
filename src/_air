#compdef air

# Zsh completion for air - Go live reload

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'[path to config file]:config file:_files' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '1:command:->commands' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:create .air.toml config file'
    )
    _describe -t commands 'air command' commands && ret=0
    ;;
esac

return ret
