#compdef dirsearch

# Zsh completion for dirsearch (web directory/file scanner)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)--version[show version number]' \
  {-u,--url}'[target URL]:URL:_urls' \
  '*'{-l,--urls-file}'[URL list file]:file:_files' \
  {-e,--extensions}'[extension list (comma-separated)]:extensions:' \
  '*'{-w,--wordlists}'[wordlist file]:file:_files' \
  {-r,--recursive}'[brute-force recursively]' \
  '--deep-recursive[perform recursive scan on every directory depth]' \
  '--force-recursive[perform recursive brute-force on every found path]' \
  {-t,--threads}'[number of threads]:threads:' \
  '--timeout[connection timeout in seconds]:seconds:' \
  '--delay[delay between requests in seconds]:seconds:' \
  '*'{-x,--exclude-status}'[exclude status codes (comma-separated)]:status codes:' \
  '*'{-i,--include-status}'[include status codes (comma-separated)]:status codes:' \
  '--min-response-size[minimum response body length]:bytes:' \
  '--max-response-size[maximum response body length]:bytes:' \
  '*'{-H,--header}'[custom header]:header:' \
  '--user-agent[custom User-Agent]:user agent:' \
  '--cookie[cookie string]:cookie:' \
  '--random-agent[use random User-Agent]' \
  {-F,--follow-redirects}'[follow HTTP redirects]' \
  {-m,--http-method}'[HTTP method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
  {-d,--data}'[HTTP request data]:data:' \
  '--proxy[proxy URL]:proxy URL:_urls' \
  '--proxy-list[file with proxy list]:file:_files' \
  {-o,--output}'[output file]:file:_files' \
  '--format[output format]:format:(plain simple json xml md csv html)' \
  {-q,--quiet}'[quiet mode]' \
  '--full-url[print full URL in output]' \
  '*:target URL:_urls'
