#compdef genl-ctrl-list
# Documentation: https://man.archlinux.org/search?q=genl-ctrl-list
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-d,--details}'[include detailed information in the list]'
  '(- * :)'{-h,--help}'[show this help]'
  {-v,--version}'[show versioning information]'
  '*:filename:_files'
)

_arguments -s -S $arguments
