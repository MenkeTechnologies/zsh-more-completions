#compdef typer

local -a arguments

arguments=(
  '-r[search directories recursively for .erl files]'
  '--show[print type specifications for all functions on stdout]'
  '--show-exported[print type specifications for exported functions only]'
  '--annotate[annotate the specified files with type specifications]'
  '--annotate-inc-files[same as --annotate but also annotate include files]'
  '--edoc[print type information as Edoc @spec comments]'
  '--plt[use the specified dialyzer PLT file]:file:_files'
  '-T[apply file-specific options]:file:_files'
  '-D[define a macro for TypEr]:name:'
  '-I[pass the include directory to TypEr]:directory:_directories'
  '-pa[add directory to beginning of code path]:directory:_directories'
  '-pz[add directory to end of code path]:directory:_directories'
  {--version,-v}'[print version and exit]'
  '(- * :)'{--help,-h}'[print help and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
