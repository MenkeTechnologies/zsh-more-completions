#compdef create-munge-key
# Documentation: https://man.archlinux.org/search?q=create-munge-key
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-f[force overwriting existing old key]'
  '-r[specify /dev/random as random file for key generation]'
  '-h[display this help and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
