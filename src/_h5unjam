#compdef h5unjam

local -a arguments

arguments=(
  '-i[specifies the HDF5 input file]:input file:_files'
  '-o[specifies output HDF5 file without a user block]:output file:_files'
  '-u[specifies the output file containing user block data]:user block file:_files'
  '--delete[remove the user block from the input HDF5 file]'
  '-h[prints a usage message and exits.]'
  '-V[prints the HDF5 library version and exits.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
