#compdef so-firewall
# Documentation: https://man.archlinux.org/search?q=so-firewall
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--apply[- After updating the firewall configuration files, apply the new firewall state]'
  '--defaultports[- Read port groups from default configuration files instead of local configuration.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
