#compdef mkdumprd

local -a arguments

arguments=(
  '--kver[set kernel version to \[VERSION\].]'
  {-f,--force}'[overwrite existing initramfs file.]'
  {-a,--add}'[add a space-separated list of dracut modules.]'
  '--rebuild[append arguments to those of existing image and rebuild]'
  {-m,--modules}'[specify a space-separated list of dracut modules to call]'
  {-o,--omit}'[omit a space-separated list of dracut modules.]'
  '--force-add[force to add a space-separated list of dracut modules]'
  {-d,--drivers}'[specify a space-separated list of kernel modules to exclusively include]'
  '--add-drivers[specify a space-separated list of kernel modules to add]'
  '--force-drivers[specify a space-separated list of kernel modules to force-add]'
  '--omit-drivers[specify a space-separated list of kernel modules to omit]'
  '--filesystems[specify a space-separated list of kernel filesystem modules]'
  {-k,--kmoddir}'[specify the directory where to look for kernel modules]'
  '--fwdir[specify additional directories where to look for firmware files]'
  '--kernel-only[only install kernel drivers and firmware files]'
  '--no-kernel[do not install kernel drivers and firmware files]'
  '--print-cmdline[print the kernel command line for the given disk layout]'
  '--early-microcode[combine early microcode with ramdisk]'
  '--no-early-microcode[do not combine early microcode with ramdisk]'
  '--kernel-cmdline[specify default kernel command line parameters]'
  '--strip[strip binaries in the initramfs]'
  '--nostrip[do not strip binaries in the initramfs]'
  '--hardlink[hardlink files in the initramfs]'
  '--nohardlink[do not hardlink files in the initramfs]'
  '--prefix[prefix initramfs files with \[DIR\]]'
  '--noprefix[do not prefix initramfs files]'
  '--mdadmconf[include local /etc/mdadm.conf]'
  '--nomdadmconf[do not include local /etc/mdadm.conf]'
  '--lvmconf[include local /etc/lvm/lvm.conf]'
  '--nolvmconf[do not include local /etc/lvm/lvm.conf]'
  '--fscks[add a space-separated list of fsck helpers.]'
  '--nofscks[inhibit installation of any fsck helpers.]'
  '--ro-mnt[mount / and /usr read-only by default.]'
  {-h,--help}'[this message]'
  '--debug[output debug information of the build process]'
  '--profile[output profile information of the build process]'
  {-L,--stdlog}'[0-6\]    Specify logging level (to standard error)]'
  {-v,--verbose}'[increase verbosity level]'
  {-q,--quiet}'[decrease verbosity level]'
  {-c,--conf}'[specify configuration file to use.]'
  '--confdir[specify configuration directory to use *.conf files]'
  '--tmpdir[temporary directory to be used instead of default]'
  {-r,--sysroot}'[specify sysroot directory to collect files from.]'
  {-l,--local}'[local mode. Use modules from the current working directory]'
  {-H,--hostonly}'[host-only mode: install only what is needed for booting the local host]'
  {-N,--no-hostonly}'[disables Host-Only mode]'
  '--hostonly-mode[specify the hostonly mode to use]'
  '--hostonly-cmdline[store kernel command line arguments needed in the initramfs]'
  '--no-hostonly-cmdline[do not store kernel command line arguments in the initramfs]'
  '--no-hostonly-default-device[do not generate implicit host devices like root, swap, etc.]'
  '--hostonly-i18n[install only needed keyboard and font files according to the host configuration]'
  '--no-hostonly-i18n[install all keyboard and font files available.]'
  '--hostonly-nics[only enable listed NICs in the initramfs.]'
  '--persistent-policy[use \[POLICY\] to address disks and partitions.]'
  '--fstab[use /etc/fstab to determine the root device.]'
  '--add-fstab[add file to the initramfs fstab]'
  '--mount[mount a device in the initramfs]'
  '--add-device[bring up a device in initramfs]'
  {-i,--include}'[include a file or directory in the initramfs]'
  {-I,--install}'[install the space separated list of files into the initramfs]'
  '--install-optional[install the space separated list of files into the initramfs]'
  '--gzip[compress the generated initramfs using gzip.]'
  '--bzip2[compress the generated initramfs using bzip2.]'
  '--lzma[compress the generated initramfs using lzma.]'
  '--xz[compress the generated initramfs using xz.]'
  '--lzo[compress the generated initramfs using lzop.]'
  '--lz4[compress the generated initramfs using lz4.]'
  '--zstd[compress the generated initramfs using Zstandard.]'
  '--compress[compress the generated initramfs with the specified compression program]'
  '--no-compress[do not compress the generated initramfs]'
  '--list-modules[list all available dracut modules.]'
  {-M,--show-modules}'[print included modules to standard output during build]'
  '--keep[keep the temporary initramfs for debugging purposes]'
  '--printsize[print out the module install size]'
  '--sshkey[add ssh key to initramfs (use with ssh-client module)]'
  '--logfile[logfile to use (overrides configuration setting)]'
  '--reproducible[create reproducible images]'
  '--no-reproducible[do not create reproducible images]'
  '--loginstall[log all files installed from the host to \[DIR\]]'
  '--uefi[create a UEFI executable with the kernel cmdline and initramfs]'
  '--no-uefi[disables UEFI mode]'
  '--uefi-stub[use the UEFI stub \[FILE\] to create an UEFI executable]'
  '--uefi-splash-image[use FILE as a splash image when creating a UEFI executable]'
  '--kernel-image[location of the kernel image]'
  '--regenerate-all[regenerate all initramfs images at the default location]'
  '--version[display version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
