#compdef reformime
# Documentation: https://man.archlinux.org/search?q=reformime
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-x[extract content of MIME sections to files]'
  '-X[ARGS Filter content of MIME sections through PROG]'
  '*:filename:_files'
)

_arguments -s -S $arguments
