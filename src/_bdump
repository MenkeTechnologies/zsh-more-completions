#compdef bdump
# Documentation: https://man.archlinux.org/search?q=bdump
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-d[file containing words to add to the dictionary]:file:_files'
  '-h[location of the dictionary used for unhashing]:file:_files'
  '-w[comma-separated list of words]:words:'
  '-x[do not load nor update the dictionary used for name unhashing]'
  {-help,--help}'[display this list of options]'
  '*:filename:_files'
)

_arguments -s -S $arguments
