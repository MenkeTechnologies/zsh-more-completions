#compdef gimp

# Zsh completion for GIMP - GNU Image Manipulation Program
# https://www.gimp.org/

_arguments -s -S \
  '(- *)'{-h,--help}'[show help options]' \
  '(- *)--help-all[show all help options]' \
  '(- *)--help-gegl[show GEGL options]' \
  '(- *)--help-gtk[show GTK+ options]' \
  '(- *)'{-v,--version}'[show version information and exit]' \
  '(- *)--license[show license information and exit]' \
  '--verbose[be more verbose]' \
  '(-n --new-instance)'{-n,--new-instance}'[start a new GIMP instance]' \
  '(-a --as-new)'{-a,--as-new}'[open images as new]' \
  '(-i --no-interface)'{-i,--no-interface}'[run without a user interface]' \
  '(-d --no-data)'{-d,--no-data}'[do not load brushes, gradients, patterns, ...]' \
  '(-f --no-fonts)'{-f,--no-fonts}'[do not load any fonts]' \
  '(-s --no-splash)'{-s,--no-splash}'[do not show a splash screen]' \
  '--no-shm[do not use shared memory between GIMP and plug-ins]' \
  '--no-cpu-accel[do not use special CPU acceleration functions]' \
  '--session=[use an alternate sessionrc file]:session name:' \
  '(-g --gimprc)'{-g,--gimprc=}'[use an alternate user gimprc file]:file:_files' \
  '--system-gimprc=[use an alternate system gimprc file]:file:_files' \
  '*'{-b,--batch=}'[batch command to run (can be used multiple times)]:command:' \
  '--batch-interpreter=[the procedure to process batch commands with]:interpreter:' \
  '--quit[quit immediately after performing requested actions]' \
  '(-c --console-messages)'{-c,--console-messages}'[send messages to console instead of using a dialog]' \
  '--pdb-compat-mode=[PDB compatibility mode]:mode:(off on warn)' \
  '--stack-trace-mode=[debug in case of a crash]:mode:(never query always)' \
  '--debug-handlers[enable non-fatal debugging signal handlers]' \
  '--g-fatal-warnings[make all warnings fatal]' \
  '--dump-gimprc[output a gimprc file with default settings]' \
  '--show-playground[show a preferences page with experimental features]' \
  '--show-debug-menu[show an image submenu with debug actions]' \
  '--display=[X display to use]:display:_x_display' \
  '*:image file:_files -g "(#i)*.(xcf|psd|jpg|jpeg|png|gif|tif|tiff|bmp|webp|svg|ico|heif|heic|avif|pdf|eps|raw|cr2|nef|orf|sr2|dng|ora|gbr|gih|pat|vbr|exr|hdr|fit|fits|pgm|ppm|pnm|pbm|xpm|xbm|pcx|tga|sgi)(-.)"'
