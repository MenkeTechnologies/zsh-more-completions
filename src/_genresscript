#compdef genresscript
# Documentation: https://man.archlinux.org/search?q=genresscript
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-t,--type}'[list resources of this type instead of group_icon]'
  {-b,--base}'[the default extraction name of all resources]'
  {-s,--sort}'[sort alphabetically instead of using order in binary]'
  '--help[display this help and exit]'
  '--version[output version information and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
