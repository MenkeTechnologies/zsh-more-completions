#compdef rz-agent


local -a arguments

arguments=(
    '-a[Listen for everyone (localhost by default).]'
    '-d[Run in daemon mode.]'
    '-h[Show help prompt.]'
    '-u[Enable HTTP Authentification support.]'
    '-t[user:password authentification file.]'
    '-p[Specify listening port for the agent.]'
    '-v[Show version information El]'
    '*:filename:_files'
)
_arguments -s -S $arguments
