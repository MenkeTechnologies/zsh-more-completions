#compdef re2d

local -a arguments

arguments=(
    '-o[Specify output file]:output file:_files'
    '--output[Specify output file]:output file:_files'
    '-b[Generate bit vectors]'
    '--bit-vectors[Generate bit vectors]'
    '-s[Generate nested ifs]'
    '--nested-ifs[Generate nested ifs]'
    '-g[Generate computed gotos]'
    '--computed-gotos[Generate computed gotos]'
    '-e[Cross-compile for different encoding]:encoding:(ascii ebcdic utf-8 utf-16 utf-32 ucs-2)'
    '--encoding[Cross-compile for different encoding]:encoding:(ascii ebcdic utf-8 utf-16 utf-32 ucs-2)'
    '-i[Do not output #line information]'
    '--no-generation-date[Do not output #line information]'
    '-r[Allow reuse of scanner definitions]'
    '--reusable[Allow reuse of scanner definitions]'
    '-c[Use conditions support]'
    '--conditions[Use conditions support]'
    '-t[Generate conditions header file]:header file:_files'
    '--type-header[Generate conditions header file]:header file:_files'
    '-T[Use tags support]'
    '--tags[Use tags support]'
    '-P[Use POSIX captures support]'
    '--posix-captures[Use POSIX captures support]'
    '-f[Generate storable state]:state file:_files'
    '--storable-state[Generate storable state]'
    '-F[Generate flex-compatible lexer]'
    '--flex-syntax[Generate flex-compatible lexer]'
    '--case-insensitive[Generate case-insensitive lexer]'
    '--case-inverted[Generate case-inverted lexer]'
    '--single-pass[Single pass]'
    '--empty-class[What to do with empty classes]:policy:(match-empty match-none error)'
    '-W[Turn on all warnings]'
    '-Werror[Turn warnings into errors]'
    '-Wno-match-empty-string[Suppress match-empty-string warnings]'
    '-Wno-nondeterministic-tags[Suppress nondeterministic-tags warnings]'
    '-Wno-swapped-range[Suppress swapped-range warnings]'
    '-Wno-undefined-control-flow[Suppress undefined-control-flow warnings]'
    '-Wno-useless-escape[Suppress useless-escape warnings]'
    '-1[Single-pass mode (deprecated)]'
    '--no-debug-info[Do not generate debug info]'
    '--no-version[Do not output version info]'
    '-S[Generate skeleton]'
    '--skeleton[Generate skeleton]'
    '-8[Generate 8-bit scanner]'
    '-x[Generate 16-bit scanner]'
    '-u[Generate 32-bit scanner]'
    '--utf-8[Generate UTF-8 scanner]'
    '--utf-16[Generate UTF-16 scanner]'
    '--utf-32[Generate UTF-32 scanner]'
    '--input[Input API]:api:(default custom)'
    '--api[API style]:style:(simple record)'
    '-V[Show version]'
    '--version[Show version]'
    '-h[Show help]'
    '--help[Show help]'
    '*:input files:_files'
)

_arguments -s -S $arguments
