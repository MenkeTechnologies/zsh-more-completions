#compdef ocamldumpobj
# Documentation: https://man.archlinux.org/search?q=ocamldumpobj
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-noloc[dont print source information]'
  '-reloc[print relocation information]'
  '-args[read additional newline separated command line arguments]'
  '-args0[read additional NUL separated command line arguments from]'
  '-help[display this list of options]'
  '--help[display this list of options]'
  '*:filename:_files'
)

_arguments -s -S $arguments
