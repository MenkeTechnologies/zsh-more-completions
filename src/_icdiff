#compdef icdiff

# Zsh completion for icdiff - improved colored diff

_arguments \
  '(-)--help[display help information]' \
  '(-)--version[display version information]' \
  {-c,--color-map}'[set color mapping]:color mapping' \
  '--cols[set number of columns]:columns' \
  {-E,--exclude-lines}'[exclude lines matching pattern]:pattern' \
  {-H,--highlight}'[highlight changes within lines]' \
  {-L,--label}'[set label]:label' \
  {-N,--line-numbers}'[show line numbers]' \
  '--no-bold[disable bold output]' \
  '--no-headers[disable headers]' \
  {-o,--output-encoding}'[set output encoding]:encoding' \
  '--strip-trailing-cr[strip trailing carriage returns]' \
  {-r,--recursive}'[recursively compare directories]' \
  '--show-all-spaces[show all whitespace]' \
  '--tabsize[set tab size]:tab size' \
  {-U,--unified}'[set number of context lines]:lines' \
  {-W,--whole-file}'[show whole file]' \
  '--is-git-diff[input is from git diff]' \
  '-u[short for unified output]' \
  '*:file:_files'
