#compdef stapdyn
# Documentation: https://man.archlinux.org/search?q=stapdyn
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-v[increase verbosity.]'
  '-c[command cmd will be run and stapdyn will]'
  '-x[sets the _stp_target variable to pid.]'
  '-o[send output to FILE. This supports strftime(3)]'
  '-C[enable colored errors. WHEN must be either auto]'
  '-V[show version.]'
  '-h[show this help text.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
