#compdef flash_eraseall
# Documentation: https://man.archlinux.org/search?q=flash_eraseall
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-j,--jffs2}'[format the device for jffs2]'
  {-N,--noskipbad}'[dont skip bad blocks]'
  {-u,--unlock}'[unlock sectors before erasing]'
  {-q,--quiet}'[do not display progress messages]'
  '--silent[same as --quiet]'
  '--help[display this help and exit]'
  '--version[output version information and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
