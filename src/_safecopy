#compdef safecopy

local -a arguments

arguments=(
  '--stage1[preset to rescue most of the data fast]'
  '--stage2[preset to rescue more data, using no retries]'
  '--stage3[preset to rescue everything that can be rescued]'
  '-b[blocksize for default read operations]:size'
  '-f[blocksize when skipping over badblocks]:size'
  '-r[resolution in bytes when searching for exact boundaries]:size'
  '-R[minimum read attempts on the first bad block]:count'
  '-Z[force seek the read head on each error]:offset'
  '-L[use low level device calls]:level'
  '--sync[use synchronized read calls (disable driver buffering)]'
  '--forceopen[keep trying to reopen the source after a read error]'
  '-s[start position where to start reading]:offset'
  '-l[maximum length of data to be read]:length'
  '-I[incremental mode badblocks file]:file:_files'
  '-i[blocksize to interpret the badblockfile given with -I]:size'
  '-c[continue copying at this position]:position'
  '-X[exclusion mode badblocks file]:file:_files'
  '-x[blocksize to interpret the badblockfile given with -X]:size'
  '-o[write a badblocks-compatible bad block file]:file:_files'
  '-S[use external script for seeking in input file]:script:_files'
  '-M[mark unrecovered data with this string]:string'
  '--debug[enable debug output (level is a bit field)]:level'
  '-T[write sector read timing information to file]:file:_files'
  '(- * :)'{-h,--help}'[show this text]'
  '*:filename:_files'
)

_arguments -s -S $arguments
