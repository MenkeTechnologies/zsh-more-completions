#compdef calc_tickadj
# Documentation: https://man.archlinux.org/search?q=calc_tickadj
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-d,--drift-file}'[ntp drift file to use]:file:_files'
  {-t,--tick}'[tick value of this host]:tick:'
  '--more-help[pass the extended usage text through a pager]'
  '*:filename:_files'
)

_arguments -s -S $arguments
