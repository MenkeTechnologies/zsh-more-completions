#compdef rustfmt

local -a arguments

arguments=(
  '--check[run in check mode, exits with 0 if input is formatted correctly]'
  '--emit[what data to emit and how]:emit:(files stdout)'
  '--backup[backup any modified files]'
  '--config-path[path to the configuration file]:file:_files'
  '--edition[rust edition to use]:edition:(2015 2018 2021)'
  '--color[use colored output (if supported)]:color:(auto always never)'
  '--print-config[print config to stdout]:mode:(default current minimal)'
  {-l,--files-with-diff}'[prints the names of mismatched files that were formatted]'
  '--config[set configuration options]:key=value: '
  {-v,--verbose}'[print verbose output]'
  {-q,--quiet}'[print less output]'
  {-V,--version}'[show version information]'
  '(- * :)'{-h,--help}'[show help message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
