#compdef sbsiglist
# Documentation: https://man.archlinux.org/search?q=sbsiglist
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--owner[signature owner GUID]'
  '--type[signature type. One]'
  '--output[write signed data to <file>]'
  '*:filename:_files'
)

_arguments -s -S $arguments
