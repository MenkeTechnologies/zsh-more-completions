#compdef sentry-cli

# Zsh completion for sentry-cli (Sentry error tracking CLI)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a commands=(
  'login:authenticate with the Sentry server'
  'info:print information about the Sentry server'
  'releases:manage releases on Sentry'
  'events:manage events on Sentry'
  'issues:manage issues on Sentry'
  'deploys:manage deploys on Sentry'
  'difutil:utility for debug information files'
  'react-native:upload build artifacts for React Native projects'
  'send-event:send a manual event to Sentry'
  'send-envelope:send a stored envelope to Sentry'
  'sourcemaps:manage sourcemaps for Sentry'
  'debug-files:manage debug information files'
  'monitors:manage monitors on Sentry'
  'uninstall:uninstall the sentry-cli executable'
  'update:update the sentry-cli executable'
  'upload-dif:upload debug information files'
  'upload-dsym:upload dSYM files'
  'upload-proguard:upload ProGuard mapping files'
  'bash-hook:print a bash script that configures error reporting'
)

local -a global_flags=(
  '--auth-token[use the given Sentry auth token]:token:'
  '--url[fully qualified URL to connect to]:url:'
  {-o,--org}'[the organization slug]:org:'
  {-p,--project}'[the project slug]:project:'
  '--header[custom HTTP header in key\:value format]:header:'
  '--log-level[set the log output verbosity]:level:(trace debug info warn error)'
  '--quiet[do not print any output while preserving correct exit code]'
  '(-h --help)'{-h,--help}'[print help information]'
  '(-V --version)'{-V,--version}'[print version information]'
)

_arguments -s -S -C \
  $global_flags \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'sentry-cli command' commands && ret=0
    ;;
  args)
    case $line[1] in
      releases)
        local -a releases_commands=(
          'new:create a new release'
          'delete:delete a release'
          'finalize:mark a release as finalized'
          'list:list the most recent releases'
          'propose-version:propose a version name for a new release'
          'set-commits:set commits for a release'
          'files:manage release artifacts'
        )
        _arguments -s -S -C \
          $global_flags \
          '1:subcommand:->releases_cmd' \
          '*::arg:->releases_args' && ret=0
        case $state in
          releases_cmd)
            _describe -t commands 'releases subcommand' releases_commands && ret=0
            ;;
          releases_args)
            case $line[1] in
              new)
                _arguments -s -S \
                  $global_flags \
                  '--finalize[immediately finalize the release]' \
                  '--url[optional URL to the release]:url:' \
                  '*:version:' && ret=0
                ;;
              delete)
                _arguments -s -S $global_flags ':version:' && ret=0
                ;;
              finalize)
                _arguments -s -S \
                  $global_flags \
                  '--started[set the release start date]:date:' \
                  '--released[set the release date]:date:' \
                  ':version:' && ret=0
                ;;
              list)
                _arguments -s -S $global_flags && ret=0
                ;;
              set-commits)
                _arguments -s -S \
                  $global_flags \
                  '--auto[use the git repository to determine commits]' \
                  '--clear[clear all commits for this release]' \
                  '*--commit[set a commit range]:repo\@from..to:' \
                  ':version:' && ret=0
                ;;
              files)
                local -a files_commands=(
                  'upload:upload a file for a release'
                  'upload-sourcemaps:upload sourcemaps for a release'
                  'delete:delete a file from a release'
                  'list:list all files for a release'
                )
                _arguments -s -S -C \
                  $global_flags \
                  '1:subcommand:->files_cmd' \
                  '*::arg:->files_args' && ret=0
                case $state in
                  files_cmd)
                    _describe -t commands 'files subcommand' files_commands && ret=0
                    ;;
                  files_args)
                    case $line[1] in
                      upload)
                        _arguments -s -S \
                          $global_flags \
                          '--name[override the file name]:name:' \
                          '--dist[set the distribution identifier]:dist:' \
                          '*:file:_files' && ret=0
                        ;;
                      upload-sourcemaps)
                        _arguments -s -S \
                          $global_flags \
                          '--url-prefix[set URL prefix for source maps]:prefix:' \
                          '--url-suffix[set URL suffix for source maps]:suffix:' \
                          '--dist[set the distribution identifier]:dist:' \
                          '--validate[enable source map validation]' \
                          '--no-rewrite[disable rewriting of matching source maps]' \
                          '*--strip-prefix[strip the given prefix from filenames]:prefix:' \
                          '*--strip-common-prefix[strip common prefix from filenames]' \
                          '*:path:_files' && ret=0
                        ;;
                      delete)
                        _arguments -s -S $global_flags ':file name:' && ret=0
                        ;;
                      list)
                        _arguments -s -S $global_flags && ret=0
                        ;;
                    esac
                    ;;
                esac
                ;;
            esac
            ;;
        esac
        ;;
      deploys)
        local -a deploys_commands=(
          'new:create a new deploy'
          'list:list all deploys for a release'
        )
        _arguments -s -S -C \
          $global_flags \
          '1:subcommand:->deploys_cmd' \
          '*::arg:->deploys_args' && ret=0
        case $state in
          deploys_cmd)
            _describe -t commands 'deploys subcommand' deploys_commands && ret=0
            ;;
          deploys_args)
            case $line[1] in
              new)
                _arguments -s -S \
                  $global_flags \
                  {-e,--env}'[set the environment for this deploy]:env:' \
                  '--started[set the deploy start date]:date:' \
                  '--finished[set the deploy finish date]:date:' \
                  '--name[optional name for the deploy]:name:' \
                  '--url[optional URL for the deploy]:url:' \
                  ':release version:' && ret=0
                ;;
              list)
                _arguments -s -S $global_flags ':release version:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      sourcemaps)
        local -a sourcemaps_commands=(
          'explain:explain why sourcemaps are not working'
          'inject:inject debug ids into source files and sourcemaps'
          'upload:upload sourcemaps'
          'resolve:resolve sourcemap for a given source location'
        )
        _arguments -s -S -C \
          $global_flags \
          '1:subcommand:->sm_cmd' \
          '*::arg:->sm_args' && ret=0
        case $state in
          sm_cmd)
            _describe -t commands 'sourcemaps subcommand' sourcemaps_commands && ret=0
            ;;
          sm_args)
            case $line[1] in
              upload)
                _arguments -s -S \
                  $global_flags \
                  {-r,--release}'[the release slug]:release:' \
                  '--dist[set the distribution identifier]:dist:' \
                  '--url-prefix[set URL prefix for source maps]:prefix:' \
                  '--url-suffix[set URL suffix for source maps]:suffix:' \
                  '--validate[enable source map validation]' \
                  '--no-rewrite[disable rewriting of matching source maps]' \
                  '*--strip-prefix[strip the given prefix from filenames]:prefix:' \
                  '--strip-common-prefix[strip common prefix from filenames]' \
                  '*:path:_files' && ret=0
                ;;
              inject)
                _arguments -s -S \
                  $global_flags \
                  '*:path:_files' && ret=0
                ;;
              explain)
                _arguments -s -S $global_flags && ret=0
                ;;
              resolve)
                _arguments -s -S $global_flags ':source location:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      debug-files)
        local -a df_commands=(
          'upload:upload debug information files'
          'check:check debug information files'
          'find:locate debug information files'
          'print-sources:print source files linked by debug files'
          'bundle-sources:create a source bundle for debug files'
          'bundle-jni:create a JNI source bundle'
        )
        _arguments -s -S -C \
          $global_flags \
          '1:subcommand:->df_cmd' \
          '*::arg:->df_args' && ret=0
        case $state in
          df_cmd)
            _describe -t commands 'debug-files subcommand' df_commands && ret=0
            ;;
          df_args)
            case $line[1] in
              upload)
                _arguments -s -S \
                  $global_flags \
                  '--type[filter for a specific file type]:type:(elf dsym breakpad pdb pe sourcebundle bcsymbolmap)' \
                  '--no-unwind[do not scan for stack unwinding information]' \
                  '--no-debug[do not scan for debug information]' \
                  '--no-sources[do not scan for source information]' \
                  '--ids[only consider files with these debug identifiers]:ids:' \
                  '--require-all[fail if not all identifiers are found]' \
                  '--symbol-maps[path to BCSymbolMap files]:path:_files -/' \
                  '--derived-data[search for dSYMs in Xcode derived data]' \
                  '--no-zips[do not search in ZIP files]' \
                  '--info-plist[override bundle ID from Info.plist]:path:_files' \
                  '--no-upload[disable the actual upload]' \
                  '--force-foreground[wait for the process to finish]' \
                  '--include-sources[include sources from the local filesystem]' \
                  '*:path:_files' && ret=0
                ;;
              check|find)
                _arguments -s -S \
                  $global_flags \
                  '--type[filter for a specific file type]:type:(elf dsym breakpad pdb pe sourcebundle)' \
                  '*:path:_files' && ret=0
                ;;
              print-sources|bundle-sources|bundle-jni)
                _arguments -s -S $global_flags '*:path:_files' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      difutil)
        local -a difutil_commands=(
          'check:check debug info files for problems'
          'find:locate debug information files for given criteria'
          'id:print the debug identifier for a file'
          'bundle-sources:create a source bundle for a debug info file'
        )
        _arguments -s -S -C \
          $global_flags \
          '1:subcommand:->difutil_cmd' \
          '*::arg:->difutil_args' && ret=0
        case $state in
          difutil_cmd)
            _describe -t commands 'difutil subcommand' difutil_commands && ret=0
            ;;
          difutil_args)
            _arguments -s -S $global_flags '*:path:_files' && ret=0
            ;;
        esac
        ;;
      react-native)
        local -a rn_commands=(
          'codepush:upload source maps for react-native CodePush releases'
          'gradle:upload source maps for a react-native Android Gradle build'
          'xcode:upload source maps for a react-native Xcode build'
        )
        _arguments -s -S -C \
          $global_flags \
          '1:subcommand:->rn_cmd' \
          '*::arg:->rn_args' && ret=0
        case $state in
          rn_cmd)
            _describe -t commands 'react-native subcommand' rn_commands && ret=0
            ;;
          rn_args)
            _arguments -s -S \
              $global_flags \
              '--bundle-id[override the bundle ID]:id:' \
              '--dist[set the distribution]:dist:' \
              '*:path:_files' && ret=0
            ;;
        esac
        ;;
      monitors)
        local -a monitors_commands=(
          'run:wrap a command for monitoring'
          'list:list monitors'
        )
        _arguments -s -S -C \
          $global_flags \
          '1:subcommand:->monitors_cmd' \
          '*::arg:->monitors_args' && ret=0
        case $state in
          monitors_cmd)
            _describe -t commands 'monitors subcommand' monitors_commands && ret=0
            ;;
          monitors_args)
            case $line[1] in
              run)
                _arguments -s -S \
                  $global_flags \
                  '--environment[set the environment]:env:' \
                  ':monitor slug:' \
                  '--[end of options]' \
                  '*:command:_command_names' && ret=0
                ;;
              list)
                _arguments -s -S $global_flags && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      send-event)
        _arguments -s -S \
          $global_flags \
          {-l,--level}'[set the log level]:level:(debug info warning error fatal)' \
          {-m,--message}'[set the event message]:message:' \
          '--logfile[read a logfile to create breadcrumbs]:file:_files' \
          {-r,--release}'[set the release]:release:' \
          {-d,--dist}'[set the distribution]:dist:' \
          {-E,--env}'[set the environment]:env:' \
          {-t,--tag}'[set a tag]:key\:value:' \
          {-e,--extra}'[set extra data]:key\:value:' \
          {-f,--fingerprint}'[change the fingerprint of the event]:fingerprint:' \
          '--user[set the event user]:key\:value:' \
          '--no-environ[do not send environment variables with the event]' && ret=0
        ;;
      send-envelope)
        _arguments -s -S \
          $global_flags \
          '--raw[send the envelope without processing]:envelope:' \
          '*:path:_files' && ret=0
        ;;
      login)
        _arguments -s -S \
          $global_flags \
          '--global[write config to global file]' && ret=0
        ;;
      info)
        _arguments -s -S \
          $global_flags \
          '--config-status-json[return the status as JSON]' && ret=0
        ;;
      events|issues)
        _arguments -s -S $global_flags && ret=0
        ;;
      upload-dif|upload-dsym)
        _arguments -s -S \
          $global_flags \
          '--no-unwind[do not scan for stack unwinding info]' \
          '--no-debug[do not scan for debug info]' \
          '--no-sources[do not scan for source info]' \
          '--include-sources[include sources from local filesystem]' \
          '--derived-data[search in Xcode derived data]' \
          '--no-zips[do not search in ZIP files]' \
          '*:path:_files' && ret=0
        ;;
      upload-proguard)
        _arguments -s -S \
          $global_flags \
          '--android-manifest[read build info from AndroidManifest.xml]:file:_files' \
          '--app-id[override the App ID]:id:' \
          '--version[override the version]:version:' \
          '--version-code[override the version code]:code:' \
          '--no-upload[disable the actual upload]' \
          '--require-one[require at least one file to upload]' \
          '--uuid[override the UUID for the mapping file]:uuid:' \
          '*:path:_files' && ret=0
        ;;
      update)
        _arguments -s -S \
          $global_flags \
          '--force[force update even if already up to date]' && ret=0
        ;;
      uninstall|bash-hook)
        _arguments -s -S $global_flags && ret=0
        ;;
    esac
    ;;
esac

return ret
