#compdef tauri

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:initialize a Tauri project'
  'dev:run your app in development mode'
  'build:build your app for production'
  'icon:generate app icons from a source image'
  'info:show a concise list of information about the environment'
  'add:add a Tauri plugin to the project'
  'remove:remove a Tauri plugin from the project'
  'plugin:manage Tauri plugins'
  'signer:sign and verify files'
  'completions:generate shell completions'
  'permission:manage permissions'
  'capability:manage capabilities'
  'inspect:inspect Tauri project configuration'
  'android:Android commands'
  'ios:iOS commands'
  'migrate:migrate from v1 to v2'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--verbose[enable verbose logging]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'tauri command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (dev)
        _arguments -s -S \
          '(-r --release)'{-r,--release}'[run in release mode]' \
          '(-e --exit-on-panic)'{-e,--exit-on-panic}'[exit on panic]' \
          '(-c --config)'{-c,--config}'=[config file or inline JSON]:config:_files' \
          '(-f --features)'{-f,--features}'=[list of cargo features]:features' \
          '--target=[target triple]:target' \
          '--no-watch[disable file watcher]' \
          '--port=[specify port for dev server]:port' \
          '--host=[specify host for dev server]:host' \
          '--no-dev-server[disable the built-in dev server]' \
          '(- *)'{-h,--help}'[show help]' \
          '*:args' && ret=0
        ;;
      (build)
        _arguments -s -S \
          '(-d --debug)'{-d,--debug}'[build in debug mode]' \
          '(-c --config)'{-c,--config}'=[config file or inline JSON]:config:_files' \
          '(-f --features)'{-f,--features}'=[list of cargo features]:features' \
          '--target=[target triple]:target' \
          '(-b --bundles)'{-b,--bundles}'=[list of bundles]:bundles:(deb rpm appimage dmg updater)' \
          '--no-bundle[skip bundle creation]' \
          '--ci[enable CI mode]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      (init)
        _arguments -s -S \
          '--app-name=[app name]:name' \
          '--window-title=[window title]:title' \
          '--dist-dir=[web assets directory]:dir:_directories' \
          '--dev-path=[dev server URL or directory]:path' \
          '--before-dev-command=[command to run before dev]:command' \
          '--before-build-command=[command to run before build]:command' \
          '(-d --directory)'{-d,--directory}'=[target directory]:directory:_directories' \
          '(-f --force)'{-f,--force}'[force init to overwrite existing config]' \
          '(-l --log)'{-l,--log}'[enable logging]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      (icon)
        _arguments -s -S \
          '-o+[output directory]:directory:_directories' \
          '--output=[output directory]:directory:_directories' \
          '--ios-color=[iOS icon background color]:color' \
          '(-p --png)'{-p,--png}'=[custom icon sizes to generate]:sizes' \
          '(- *)'{-h,--help}'[show help]' \
          '1:input file:_files' && ret=0
        ;;
      (signer)
        local -a signer_cmds=(
          'sign:sign a file'
          'generate:generate a new signing key pair'
        )
        _arguments \
          '1:subcommand:_describe -t signer-commands "signer command" signer_cmds' \
          '*:args' && ret=0
        ;;
      (add|remove)
        _arguments '1:plugin name' && ret=0
        ;;
      (android)
        local -a android_cmds=(
          'init:initialize Android target'
          'dev:run on Android device or emulator'
          'build:build for Android'
          'open:open project in Android Studio'
        )
        _arguments \
          '1:subcommand:_describe -t android-commands "android command" android_cmds' \
          '*:args' && ret=0
        ;;
      (ios)
        local -a ios_cmds=(
          'init:initialize iOS target'
          'dev:run on iOS device or simulator'
          'build:build for iOS'
          'open:open project in Xcode'
        )
        _arguments \
          '1:subcommand:_describe -t ios-commands "ios command" ios_cmds' \
          '*:args' && ret=0
        ;;
    esac
    ;;
esac

return ret
