#compdef arping

local -a arguments

arguments=(
  '-0[ping with source IP address 0.0.0.0]'
  '-a[audible ping]'
  '-A[only count addresses matching requested address]'
  '-b[like -0 but use broadcast source address 255.255.255.255]'
  '-B[use instead of host if you want to address 255.255.255.255]'
  '-c[only send count requests]:count:'
  '-C[only wait for this many replies]:count:'
  '-d[find duplicate replies]'
  '-D[display answers as exclamation points and missing packets as dots]'
  '-e[like -a but beep when there is no reply]'
  '-F[dont try to be smart about the interface name]'
  '-g[setgid() to this group instead of the nobody group]:group:'
  '-h[displays a help message and exits]'
  '-i[use the specified interface]:interface:'
  '-m[type of timestamp to use for incoming packets]:type:'
  '-q[does not display messages, except error messages]'
  '-Q[802.1p priority to set. Should be used with 802.1Q (-V)]:priority:'
  '-r[raw output: only the MAC/IP address is displayed for each reply]'
  '-R[raw output: like -r but shows the other one]'
  '-s[set source MAC address]:MAC address:'
  '-S[like -b and -0 but with set source address]:IP address:'
  '-t[set target MAC address to use when pinging IP address]:MAC address:'
  '-T[use as target address when pinging MACs]:IP address:'
  '-p[turn on promiscuous mode on interface]'
  '-P[send ARP replies instead of requests. Useful with -U]'
  '-u[show index=received/sent instead of just index=received]'
  '-U[send unsolicited ARP]'
  '-v[verbose output. Use twice for more messages]'
  '-V[802.1Q tag to add. Defaults to no VLAN tag]:VLAN tag:'
  '-w[specify a timeout before ping exits]:timeout:'
  '-W[time to wait between pings]:seconds:'
  '*:filename:_files'
)

_arguments -s -S $arguments
