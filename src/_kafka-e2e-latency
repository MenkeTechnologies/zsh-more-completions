#compdef kafka-e2e-latency

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--topic[Topic to use]:topic:'
    '--num-messages[Number of messages to send]:count:'
    '--producer-props[Producer properties as key=value pairs]:properties:'
    '--consumer-props[Consumer properties as key=value pairs]:properties:'
    '--message-size[Message size in bytes]:bytes:'
    '--timeout[Timeout in ms]:ms:'
)

_arguments -s -S $arguments
