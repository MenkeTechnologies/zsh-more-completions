#compdef bun

# Zsh completion for bun (JavaScript runtime/bundler)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '--version[Print version and exit]' \
  '--revision[Print version with revision and exit]' \
  '--cwd=[Change working directory]:dir:_directories' \
  '--bunfig=[Set path to bunfig.toml]:file:_files' \
  '-h[Print help]' \
  '--help[Print help]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'run:Execute a file or package.json script'
      'test:Run unit tests'
      'x:Execute a package binary, installing if needed'
      'repl:Start a REPL session'
      'exec:Run a shell script directly with Bun'
      'install:Install dependencies for a package.json'
      'i:Install dependencies for a package.json'
      'add:Add a dependency to package.json'
      'remove:Remove a dependency from package.json'
      'rm:Remove a dependency from package.json'
      'update:Update outdated dependencies'
      'link:Register or link a local npm package'
      'unlink:Unregister a local npm package'
      'pm:Additional package management utilities'
      'build:Bundle TypeScript and JavaScript'
      'init:Start an empty Bun project'
      'create:Create a new project from a template'
      'upgrade:Upgrade to the latest version of bun'
      'outdated:Display the latest versions of outdated dependencies'
      'patch:Prepare a package for patching'
      'patch-commit:Create a patch from patching changes'
    )
    _describe -t commands 'bun command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      run)
        _arguments -s -S \
          '--watch[Automatically restart the process on file change]' \
          '--hot[Enable hot reloading]' \
          '--smol[Use less memory but run garbage collection more often]' \
          '--if-present[Exit without error if the script is not found]' \
          '--no-install[Disable auto install in bun run]' \
          '--silent[Do not print the script command]' \
          '-b[Force a script to be treated as a package.json script]' \
          '--bun[Force a script to be treated as a package.json script]' \
          '--filter=[Run in all workspace packages matching the pattern]:pattern' \
          '--inspect=[Activate inspector]:host_port' \
          '--inspect-wait=[Activate inspector wait]:host_port' \
          '--inspect-brk=[Activate inspector break]:host_port' \
          '--preload=[Import a module before other modules are loaded]:module:_files' \
          '--env-file=[Load environment variables from specified file]:file:_files' \
          '-e+[Evaluate argument as a script]:code' \
          '--eval=[Evaluate argument as a script]:code' \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:script or file:->scripts_or_files' \
          '*:args' && ret=0
        ;;
      test)
        _arguments -s -S \
          '--timeout=[Set the per-test default timeout in milliseconds]:ms' \
          '--update-snapshots[Update snapshot files]' \
          '-u[Update snapshot files]' \
          '--rerun-each=[Re-run each test N times]:count' \
          '--bail=[Abort after N failures]:count' \
          '--only[Only run tests that are marked with test.only]' \
          '--todo[Include tests marked with test.todo]' \
          '--preload=[Import a module before other modules are loaded]:module:_files' \
          '--coverage[Generate a coverage report]' \
          '--coverage-dir=[Directory for coverage output]:dir:_directories' \
          '--coverage-reporter=[Coverage reporter]:reporter:(text lcov json-summary)' \
          '--env-file=[Load environment variables from specified file]:file:_files' \
          '-t+[Only run tests whose names match this pattern]:pattern' \
          '--test-name-pattern=[Only run tests whose names match this pattern]:pattern' \
          '--watch[Automatically re-run tests on file change]' \
          '--hot[Enable hot reloading in tests]' \
          '--smol[Use less memory]' \
          '--inspect=[Activate inspector]:host_port' \
          '--inspect-wait=[Activate inspector wait]:host_port' \
          '--inspect-brk=[Activate inspector break]:host_port' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:test files:_files' && ret=0
        ;;
      build)
        _arguments -s -S \
          '--entrypoints=[Entry point(s)]:files:_files' \
          '--outdir=[Output directory]:dir:_directories' \
          '--outfile=[Output file (for single entry point)]:file:_files' \
          '--target=[Target environment]:target:(browser bun node)' \
          '--format=[Output format]:format:(esm cjs iife)' \
          '--splitting[Enable code splitting]' \
          '--sourcemap=[Generate source maps]:sourcemap:(none linked inline external)' \
          '--minify[Enable all minification]' \
          '--minify-syntax[Minify syntax]' \
          '--minify-whitespace[Minify whitespace]' \
          '--minify-identifiers[Minify identifiers]' \
          '--external=[Mark a module as external]:module' \
          '--packages=[Specify how packages are handled]:how:(bundle external)' \
          '--loader=[Map file extensions to loaders]:ext=loader' \
          '--define=[Substitute compile-time value]:key=value' \
          '--compile[Generate a standalone executable]' \
          '--root=[Root directory for entrypoints]:dir:_directories' \
          '--asset-naming=[Customizes asset names]:template' \
          '--chunk-naming=[Customizes chunk names]:template' \
          '--entry-naming=[Customizes entry point names]:template' \
          '--server-components[Enable server components]' \
          '--no-bundle[Transpile only, do not bundle]' \
          '--env-file=[Load environment variables from specified file]:file:_files' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:entrypoints:_files' && ret=0
        ;;
      add)
        _arguments -s -S \
          '-d[Add as devDependency]' \
          '--development[Add as devDependency]' \
          '--dev[Add as devDependency]' \
          '-D[Add as devDependency]' \
          '--optional[Add as optionalDependency]' \
          '-E[Install exact version]' \
          '--exact[Install exact version]' \
          '-g[Install globally]' \
          '--global[Install globally]' \
          '--no-save[Do not save to package.json]' \
          '--trust[Add to trustedDependencies]' \
          '--dry-run[Do not install]' \
          '--frozen-lockfile[Disallow changes to lockfile]' \
          '--verbose[Log all resolved modules]' \
          '-p[Add as peerDependency]' \
          '--peer[Add as peerDependency]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:package' && ret=0
        ;;
      remove|rm)
        _arguments -s -S \
          '-g[Remove globally]' \
          '--global[Remove globally]' \
          '--dry-run[Do not remove]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:package' && ret=0
        ;;
      install|i)
        _arguments -s -S \
          '-y[Assume yes to all prompts]' \
          '--yarn[Write a yarn.lock instead of bun.lockb]' \
          '-p[Do not install devDependencies]' \
          '--production[Do not install devDependencies]' \
          '--no-save[Do not update package.json or lockfile]' \
          '--dry-run[Do not install]' \
          '--frozen-lockfile[Disallow changes to lockfile]' \
          '--trust[Add all packages to trustedDependencies]' \
          '--verbose[Log all resolved modules]' \
          '--no-progress[Disable progress bar]' \
          '--no-summary[Do not print summary]' \
          '--no-verify[Skip integrity verification]' \
          '--ignore-scripts[Skip lifecycle scripts]' \
          '--concurrent-scripts=[Maximum number of concurrent lifecycle scripts]:count' \
          '-g[Install globally]' \
          '--global[Install globally]' \
          '--force[Always request the latest versions from the registry]' \
          '--cache-dir=[Store and load cached data from specified directory]:dir:_directories' \
          '--no-cache[Ignore manifest cache]' \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
      update)
        _arguments -s -S \
          '--latest[Update to latest version ignoring semver]' \
          '--frozen-lockfile[Disallow changes to lockfile]' \
          '--dry-run[Do not install]' \
          '--no-save[Do not update package.json]' \
          '--verbose[Log all resolved modules]' \
          '-g[Update globally]' \
          '--global[Update globally]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:package' && ret=0
        ;;
      x)
        _arguments -s -S \
          '--bun[Force usage of bun runtime]' \
          '--silent[Do not print the script command]' \
          '-q[Do not print the script command]' \
          '--quiet[Do not print the script command]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*::command:_command_names -e' && ret=0
        ;;
      create)
        _arguments -s -S \
          '--force[Overwrite existing files]' \
          '--no-install[Skip installing node_modules]' \
          '--no-git[Do not initialize a git repository]' \
          '--open[Open in browser after creation]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:template' \
          '2:destination:_directories' && ret=0
        ;;
      init)
        _arguments -s -S \
          '-y[Accept all default values]' \
          '--yes[Accept all default values]' \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
      upgrade)
        _arguments -s -S \
          '--canary[Upgrade to canary build]' \
          '--stable[Upgrade to latest stable build]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:version' && ret=0
        ;;
      link)
        _arguments -s -S \
          '--save[Add to package.json dependencies]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:package:_files' && ret=0
        ;;
      pm)
        local -a subcmds=(
          'bin:Print the path to bin folder'
          'ls:List installed packages'
          'hash:Print the hash of the lockfile'
          'hash-string:Print the string used to hash the lockfile'
          'hash-print:Print the hash stored in the lockfile'
          'cache:Print info on the package manager cache'
          'migrate:Migrate from another package manager'
          'pack:Pack the current package into a tarball'
          'untrusted:Print current untrusted dependencies'
          'default-trusted:Print the default trusted dependencies'
          'trust:Add packages to trustedDependencies'
        )
        _describe -t subcmds 'pm subcommand' subcmds && ret=0
        ;;
      outdated)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:package' && ret=0
        ;;
    esac

    if [[ $state == scripts_or_files ]]; then
      local -a scripts
      if [[ -f package.json ]]; then
        scripts=( ${(f)"$(node -e "try{const p=require('./package.json');Object.keys(p.scripts||{}).forEach(k=>console.log(k))}catch(e){}" 2>/dev/null)"} )
      fi
      _alternative \
        'scripts:script:_describe -t scripts script scripts' \
        'files:file:_files' && ret=0
    fi
    ;;
esac

return ret
