#compdef tagmedia
# Documentation: https://man.archlinux.org/search?q=tagmedia
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--show[list tags]'
  '--digest[add DIGEST (md5, sha1, sha224, sha256, sha384, sha512)]:digest:(md5 sha1 sha224 sha256 sha384 sha512)'
  '--pad[ignore N 2k-sectors of padding]:sectors:'
  '--check[force yast check]'
  '--add-tag[add tag with value]:tag=value:'
  '--remove-tag[remove tag]:tag:'
  '--clean[remove all tags]'
  '*:filename:_files'
)

_arguments -s -S $arguments
