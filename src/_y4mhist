#compdef y4mhist
# Documentation: https://man.archlinux.org/search?q=y4mhist
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-t[emit text summary even if graphical mode enabled]'
  '-p[label the scale in percent not absolute numbers]'
  '-s[enable also the vectorscope, allowed numbers 1-16]'
  '*:filename:_files'
)

_arguments -s -S $arguments
