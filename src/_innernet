#compdef innernet

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'install:Install a new peer from an invitation file'
  'show:Show interface details'
  'up:Bring up the interface'
  'down:Bring down the interface'
  'fetch:Fetch and update peer information'
  'uninstall:Uninstall an interface'
  'add-peer:Add a new peer to the network'
  'rename-peer:Rename a peer'
  'add-cidr:Add a new CIDR to the network'
  'delete-cidr:Delete a CIDR'
  'list-cidrs:List all CIDRs'
  'disable-peer:Disable a peer'
  'enable-peer:Enable a peer'
  'override-endpoint:Override the endpoint for a peer'
  'completions:Generate shell completions'
  'help:Print help information'
)

local -a global_flags
global_flags=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)'{-V,--version}'[show version]'
  '--config-dir=[configuration directory]:dir:_directories'
  '--data-dir=[data directory]:dir:_directories'
  '--backend=[WireGuard backend]:backend:(kernel userspace)'
)

_arguments -C \
  $global_flags \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'innernet command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      install)
        _arguments \
          $global_flags \
          '1:invitation file:_files' && ret=0
        ;;
      show)
        _arguments \
          $global_flags \
          {-s,--short}'[short output]' \
          '--json[output in JSON format]' \
          {-t,--tree}'[display as tree]' \
          '1:interface:' && ret=0
        ;;
      up|down|fetch|uninstall|list-cidrs|disable-peer|enable-peer|rename-peer)
        _arguments \
          $global_flags \
          '1:interface:' && ret=0
        ;;
      add-peer)
        _arguments \
          $global_flags \
          '--name=[peer name]:name:' \
          '--cidr=[CIDR name]:name:' \
          '--admin=[set as admin]:bool:(true false)' \
          '--ip=[IP address]:ip:' \
          '--save-config=[save config to file]:file:_files' \
          '--invite-expires=[invitation expiration duration]:duration:' \
          '--auto-ip[automatically assign an IP address]' \
          '1:interface:' && ret=0
        ;;
      add-cidr|delete-cidr)
        _arguments \
          $global_flags \
          '1:interface:' && ret=0
        ;;
      override-endpoint)
        _arguments \
          $global_flags \
          '--name=[peer name]:name:' \
          '--endpoint=[endpoint address]:addr:' \
          '--unset[unset the endpoint override]' \
          '1:interface:' && ret=0
        ;;
      completions)
        _arguments \
          '1:shell:(bash zsh fish powershell elvish)' && ret=0
        ;;
      *)
        _arguments $global_flags && ret=0
        ;;
    esac
    ;;
esac

return ret
