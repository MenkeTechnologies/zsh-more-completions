#compdef ssh-import-id ssh-import-id-lp ssh-import-id-gh
# Documentation: https://man.archlinux.org/search?q=ssh-import-id
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  {-o,--output}'[write output to file (default ~/.ssh/authorized_keys)]'
  {-r,--remove}'[remove a key from authorized keys file]'
  {-u,--useragent}'[append to the http user agent string]'
  '*:filename:_files'
)

_arguments -s -S $arguments
