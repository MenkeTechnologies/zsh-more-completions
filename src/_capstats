#compdef capstats

local -a arguments

arguments=(
  {-i,--interface}'[listen on interface]:interface:'
  {-f,--filter}'[BPF filter]:filter:'
  {-I,--interval}'[stats logging interval]:secs:'
  {-l,--syslog}'[use syslog rather than print to stderr]'
  {-n,--number}'[stop after outputting N intervals]:count:'
  {-N,--select}'[use select() for live pcap (for testing only)]'
  {-p,--payload}'[verify that packet payloads consist entirely of bytes of the given value]:n:'
  {-q,--quiet}'[suppress output, exit code indicates >= count packets received]:count:'
  {-S,--size}'[verify packets to have given size]:size:'
  {-s,--snaplen}'[use pcap snaplen]:size:'
  {-v,--version}'[print version and exit]'
  {-w,--write}'[write packets to file]:filename:_files'
  '*:filename:_files'
)

_arguments -s -S $arguments
