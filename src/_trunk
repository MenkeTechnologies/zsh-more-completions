#compdef trunk

# Zsh completion for trunk (code quality tool)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'actions:manage actions'
  'cache:manage the cache'
  'check:run linters and formatters'
  'completion:generate shell completions'
  'config:manage trunk configuration'
  'daemon:manage the trunk daemon'
  'deinit:remove trunk from the project'
  'fmt:format files (alias: format)'
  'init:initialize trunk in the project'
  'login:log in to trunk.io'
  'logout:log out from trunk.io'
  'tools:manage tools'
  'upgrade:upgrade trunk'
  'version:print version'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--ci[run in CI mode]' \
  '--no-progress[disable progress bar]' \
  '--monitor[enable monitoring]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'trunk command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (check)
        _arguments \
          '(-a --all)'{-a,--all}'[check all files]' \
          '--fix[attempt to auto-fix issues]' \
          '--no-fix[do not auto-fix]' \
          '--filter[filter by linter]:linter:' \
          '--sample[sample N files]:count:' \
          '--ci[run in CI mode]' \
          '--output[output format]:format:(text json sarif)' \
          '--upstream[compare against upstream]:ref:' \
          '--trigger[trigger type]:trigger:(ci manual)' \
          '*:file:_files' && ret=0
        ;;
      (fmt|format)
        _arguments \
          '(-a --all)'{-a,--all}'[format all files]' \
          '--filter[filter by formatter]:formatter:' \
          '--ci[run in CI mode]' \
          '*:file:_files' && ret=0
        ;;
      (tools)
        local -a tools_cmds=('enable:enable a tool' 'disable:disable a tool' 'install:install a tool' 'list:list tools')
        _arguments '1:tools command:((${(j: :)${tools_cmds// /\\:}}))' '*:tool:' && ret=0
        ;;
    esac
    ;;
esac

return ret
