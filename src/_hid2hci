local -a arguments

arguments=(
  '--mode[mode to switch to \[hid|hci\] (default hci)]'
  '--devpath[sys device path]'
  '--method[method to use to switch \[csr|csr2|logitech-hid|dell\]]'
  '--help[show help]'
  '--mode[mode to switch to \[hid|hci\] (default hci)]'
  '--devpath[sys device path]'
  '--method[method to use to switch \[csr|csr2|logitech-hid|dell\]]'
  '--help[show help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
