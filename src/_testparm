#compdef testparm

local -a arguments

arguments=(
    {-s,--suppress-prompt}'[Suppress prompt for enter]'
    {-v,--verbose}'[Show default options too]'
    {-l,--skip-logic-checks}'[Skip the global checks]'
    '--show-all-parameters[Show the parameters, type, possible values]'
    '--parameter-name[Limit testparm to a named parameter]:name:'
    '--section-name[Limit testparm to a named section]:name:'
    '--usage[Display brief usage message]'
    {-V,--version}'[Print version]'
    {-d,--debuglevel}'[Set debug level]:level:'
    '--option[Set smb.conf option from command line]:option=value:'
    '*:filename:_files'
)

_arguments -s -S $arguments
