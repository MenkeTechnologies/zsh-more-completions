#compdef pam-config

local -a arguments

arguments=(
  {-a,--add}'[add options/PAM modules]'
  {-c,--create}'[create new configuration]'
  {-d,--delete}'[remove options/PAM modules]'
  '--confdir[use a custom configuration directory]'
  '--initialize[convert old config and create new one]'
  '--service[service to modify config of]'
  '--update[read current config and write them new]'
  '--verify[read and verify current configuration]'
  {-q,--query}'[query for installed modules and options]'
  '--list-modules[list all supported modules]'
  '--help[give this help list]'
  {-u,--usage}'[give a short usage message]'
  {-v,--version}'[print program version]'
  '--access[enable pam_access module (account access control)]'
  '--access-debug[enable debug logging for access module]'
  '--access-nodefgroup[do not use default groups]'
  '--access-noaudit[do not log via audit]'
  '--access-accessfile[access.conf file path]'
  '--access-fieldsep[field separator character]'
  '--access-listsep[list separator character]'
  '--apparmor[enable pam_apparmor module (AppArmor profile changes)]'
  '--apparmor-debug[enable debug logging for apparmor module]'
  '--ccreds[enable pam_ccreds module (cached credentials)]'
  '--cracklib[enable pam_cracklib module (password strength check)]'
  '--cracklib-debug[enable debug logging for cracklib module]'
  '--cracklib-enforce[_for_root]'
  '--cracklib-authtok_type=[<value>]'
  '--cracklib-retry[number of retries for password]'
  '--cracklib-difok[minimum different chars from old password]'
  '--cracklib-difignore[ignore difok if password length]'
  '--cracklib-minlen[minimum password length]'
  '--cracklib-dcredit[credit for digit characters]'
  '--cracklib-ucredit[credit for uppercase characters]'
  '--cracklib-lcredit[credit for lowercase characters]'
  '--cracklib-ocredit[credit for other characters]'
  '--cracklib-minclass[minimum number of character classes]'
  '--cracklib-dictpath[path to cracklib dictionary]'
  '--ecryptfs[enable pam_ecryptfs module (encrypted home directory)]'
  '--ecryptfs-unwrap[unwrap passphrase]'
  '--env[enable pam_env module (environment variables)]'
  '--env-debug[enable debug logging for env module]'
  '--env-conffile[config file path]:file:_files'
  '--env-envfile[environment file path]'
  '--env-readenv[read environment from file]'
  '--exec[enable pam_exec module (execute external command)]'
  '--exec-debug[enable debug logging for exec module]'
  '--exec-expose[_authtok]'
  '--exec-seteuid[run as effective uid]'
  '--exec-quiet[suppress non-error output]'
  '--exec-log[log file path]:file:_files'
  '--exec-option[module-specific option]'
  '--fp[enable pam_fp module (fingerprint authentication)]'
  '--fp-debug[enable debug logging for fp module]'
  '--fprint[enable pam_fprint module (fingerprint authentication)]'
  '--fprint-debug[enable debug logging for fprint module]'
  '--fprintd[enable pam_fprintd module (fingerprint daemon)]'
  '--fprintd-debug[enable debug logging for fprintd module]'
  '--gnome[_keyring]'
  '--gnome[_keyring-auto_start]'
  '--gnome_keyring-only_if=[<value>]'
  '--group[enable pam_group module (group-based access)]'
  '--krb5[enable pam_krb5 module (Kerberos authentication)]'
  '--krb5-debug[enable debug logging for krb5 module]'
  '--krb5-ignore[_unknown_principals]'
  '--krb5-minimum_uid=[<value>]'
  '--kwallet5[enable pam_kwallet5 module (KDE wallet)]'
  '--ldap[enable pam_ldap module (LDAP authentication)]'
  '--ldap-debug[enable debug logging for ldap module]'
  '--limits[enable pam_limits module (resource limits)]'
  '--limits-debug[enable debug logging for limits module]'
  '--limits-change[_uid]'
  '--limits-utmp[_early]'
  '--limits-conf[config file path]:file:_files'
  '--localuser[pam_localuser module (only allow local users)]'
  '--localuser-debug[enable debug logging for localuser module]'
  '--localuser-file[localuser config file path]'
  '--mkhomedir[enable pam_mkhomedir module (create home directory)]'
  '--mkhomedir-debug[enable debug logging for mkhomedir module]'
  '--mkhomedir-silent[silent mkhomedir (do not print message)]'
  '--mkhomedir-umask[umask for new home directory]'
  '--mkhomedir-skel[skeleton directory for new homes]'
  '--nam[pam_nam module]'
  '--passwdqc[pam_passwdqc module (password quality)]'
  '--passwdqc-ask[_oldauthtok]'
  '--passwdqc-check[_oldauthtok]'
  '--passwdqc-use[_first_pass]'
  '--passwdqc-use[_authtok]'
  '--passwdqc-min[minimum password length per class count]'
  '--passwdqc-max[maximum password length]'
  '--passwdqc-passphrase[minimum passphrase word count]'
  '--passwdqc-match[common substring match length]'
  '--passwdqc-similar[similarity check (permit or deny)]'
  '--passwdqc-random[random password generation length]'
  '--passwdqc-enforce[enforce password quality]'
  '--passwdqc-retry[number of password retries]'
  '--pkcs11[enable pam_pkcs11 module (smart card auth)]'
  '--pkcs11-debug[enable debug logging for pkcs11 module]'
  '--pkcs11-configfile[pkcs11 config file path]'
  '--pwcheck[enable pam_pwcheck module (password check)]'
  '--pwcheck-debug[enable debug logging for pwcheck module]'
  '--pwcheck-nullok[pwcheck: allow empty passwords]'
  '--pwcheck-cracklib[pwcheck: use cracklib check]'
  '--pwcheck-no[_obscure_checks]'
  '--pwcheck-enforce[_for_root]'
  '--pwcheck-cracklib_path=[<value>]'
  '--pwcheck-maxlen[maximum password length]'
  '--pwcheck-minlen[minimum password length]'
  '--pwcheck-tries[maximum password tries]'
  '--pwcheck-remember[remember N old passwords]'
  '--pwhistory[enable pam_pwhistory module (password history)]'
  '--pwhistory-debug[enable debug logging for pwhistory module]'
  '--pwhistory-use[_authtok]'
  '--pwhistory-enforce[_for_root]'
  '--pwhistory-remember[number of old passwords to remember]'
  '--pwhistory-retry[password history retry count]'
  '--pwhistory-authtok_type=[<value>]'
  '--selinux[pam_selinux module (SELinux context)]'
  '--selinux-debug[enable debug for selinux module]'
  '--ssh[pam_ssh module (SSH key auth)]'
  '--ssh-debug[enable debug for ssh module]'
  '--ssh-nullok[allow empty SSH passphrases]'
  '--ssh-keyfiles[SSH keyfile paths]'
  '--sss[enable pam_sss module (SSSD authentication)]'
  '--sss-debug[enable debug logging for sss module]'
  '--systemd[enable pam_systemd module (register session with systemd)]'
  '--systemd-debug[enable debug logging for systemd module]'
  '--systemd-kill_session_processes=[<value>]'
  '--systemd-kill_only_users=[<value>]'
  '--systemd-kill_exclude_users=[<value>]'
  '--systemd-controllers[systemd cgroup controllers]'
  '--systemd-reset_controllers=[<value>]'
  '--thinkfinger[enable pam_thinkfinger module (ThinkPad fingerprint)]'
  '--thinkfinger-debug[enable debug logging for thinkfinger module]'
  '--umask[enable pam_umask module (set user umask)]'
  '--umask-debug[enable debug logging for umask module]'
  '--umask-silent[silent umask (no error messages)]'
  '--umask-usergroups[usergroups for umask]'
  '--umask-umask[umask value]'
  '--unix[enable pam_unix module (standard Unix authentication)]'
  '--unix-debug[enable debug logging for unix module]'
  '--unix-audit[unix module audit logging]'
  '--unix-nodelay[no delay on auth failure]'
  '--unix-nullok[allow empty passwords]'
  '--unix-shadow[unix module use shadow file]'
  '--unix-md5[use MD5 password hashing]'
  '--unix-bigcrypt[unix module use bigcrypt]'
  '--unix-sha256[use SHA-256 hashing]'
  '--unix-sha512[use SHA-512 hashing]'
  '--unix-blowfish[use Blowfish hashing]'
  '--unix-nis[unix module use NIS]'
  '--unix-broken[_shadow]'
  '--unix-use[_first_pass]'
  '--unix-try[_first_pass]'
  '--unix-authtok_type=[<value>]'
  '--unix-remember[remember N old passwords]'
  '--unix-rounds[rounds for hashing]'
  '--unix-minlen[minimum password length]'
  '--unix2[enable pam_unix2 module (extended Unix auth)]'
  '--unix2-nullok[allow empty passwords]'
  '--unix2-debug[enable debug logging for unix2 module]'
  '--unix2-trace[unix2 module trace]'
  '--unix2-none[unix2 module: no specific behavior]'
  '--unix2-call_modules[set call modules]:value'
  '--unix2-nisdir[unix2 module NIS directory]'
  '--winbind[enable pam_winbind module (Windows domain auth)]'
  '--winbind-debug[enable debug logging for winbind module]'
  '--ck_connector[enable ck_connector module]'
  '--ck_connector-debug[enable ck_connector debug]'
  '--cryptpass[encrypted password]'
  '--csync[cifs sync]'
  '--csync-use_first_pass[use first pass for csync]'
  '--csync-try_first_pass[try first pass for csync]'
  '--csync-soft_try_pass[soft try pass for csync]'
  '--csync-nullok[csync allow empty password]'
  '--csync-debug[csync module debug]'
  '--csync-silent[csync module silent]'
  '--keyinit[pam_keyinit module (kernel session keyring)]'
  '--keyinit-debug[keyinit module debug]'
  '--keyinit-force[force new keyring]'
  '--lastlog[pam_lastlog module]'
  '--lastlog-debug[lastlog module debug]'
  '--lastlog-silent[lastlog silent (no last login message)]'
  '--lastlog-never[no warning if no last login]'
  '--lastlog-nodate[no date in last login]'
  '--lastlog-nohost[no hostname in last login]'
  '--lastlog-noterm[no terminal in last login]'
  '--lastlog-nowtmp[do not update wtmp]'
  '--lastlog-noupdate[do not update lastlog]'
  '--lastlog-showfailed[show failed login info]'
  '--loginuid[pam_loginuid module (set audit login UID)]'
  '--loginuid-require_auditd[require auditd for loginuid]'
  '--mount[pam_mount module (mount volumes on login)]'
  '--google_authenticator[enable google authenticator module]'
  '--google_authenticator-noskewadj[disable skew adjustment for google authenticator]'
  '--google_authenticator-nullok[allow null for google authenticator]'
  '--google_authenticator-secret[set secret for google authenticator]:value'
  '*:filename:_files'
)

_arguments -s -S $arguments
