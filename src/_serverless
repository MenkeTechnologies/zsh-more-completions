#compdef serverless sls

# Zsh completion for serverless / sls - Serverless Framework

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'create:create new Serverless service'
  'install:install a Serverless service from GitHub or a plugin'
  'package:packages a Serverless service'
  'deploy:deploy a Serverless service'
  'invoke:invoke a deployed function'
  'remove:remove a deployed service'
  'info:display information about the service'
  'logs:output the logs of a deployed function'
  'metrics:show metrics for a specific function'
  'print:print the resolved config file'
  'plugin:plugin management'
  'config:configure Serverless'
  'login:login to the Serverless Dashboard'
  'logout:logout from the Serverless Dashboard'
  'generate-event:generate mock event'
  'test:run tests'
  'dashboard:open the Serverless Dashboard'
  'output:manage outputs'
  'param:manage params'
  'stage:manage stages'
  'dev:run in development mode'
  'doctor:troubleshoot your service'
  'compose:run serverless compose'
)

local -a global_args=(
  '(-c --config)'{-c,--config}'[path to serverless config file]:config file:_files'
  '(-s --stage)'{-s,--stage}'[stage of the service]:stage:'
  '(-r --region)'{-r,--region}'[region of the service]:region:'
  '--app[dashboard app]:app:'
  '--org[dashboard org]:org:'
  '--help[show help]'
  '--version[show version number]'
  '--verbose[show verbose output]'
  '--debug[show debug output]'
)

_arguments -s -S \
  ${global_args[@]} \
  '1:command:->command' \
  '*:option:->options' && ret=0

case $state in
  (command)
    _describe -t commands 'serverless command' subcommands && ret=0
    ;;
  (options)
    case ${line[1]} in
      (create)
        _arguments -s -S \
          ${global_args[@]} \
          '(-t --template)'{-t,--template}'[template name]:template:(aws-clojurescript-gradle aws-clojure-gradle aws-nodejs aws-nodejs-docker aws-nodejs-typescript aws-alexa-typescript aws-python aws-python3 aws-python-docker aws-groovy-gradle aws-java-gradle aws-java-maven aws-kotlin-jvm-gradle aws-kotlin-jvm-maven aws-kotlin-nodejs-gradle aws-scala-sbt aws-csharp aws-fsharp aws-go aws-go-dep aws-go-mod aws-ruby)' \
          '(-u --template-url)'{-u,--template-url}'[template URL]:URL:' \
          '--template-path[template local path]:path:_files -/' \
          '(-p --path)'{-p,--path}'[path for the service]:path:_files -/' \
          '(-n --name)'{-n,--name}'[name for the service]:name:' && ret=0
        ;;
      (deploy)
        _arguments -s -S \
          ${global_args[@]} \
          '--package[path to pre-packaged directory]:package dir:_files -/' \
          '--force[force a deployment]' \
          '--conceal[hide secrets from output]' \
          '--aws-s3-accelerate[enable S3 Transfer Acceleration]' \
          '(-f --function)'{-f,--function}'[function name for deploy function]:function:' \
          '1:sub-command:(function list)' && ret=0
        ;;
      (invoke)
        _arguments -s -S \
          ${global_args[@]} \
          '(-f --function)'{-f,--function}'[function name]:function:' \
          '(-p --path)'{-p,--path}'[path to JSON or YAML event data]:path:_files' \
          '(-t --type)'{-t,--type}'[invocation type]:type:(Event RequestResponse DryRun)' \
          '(-l --log)'{-l,--log}'[trigger logging data output]' \
          '(-d --data)'{-d,--data}'[input data]:data:' \
          '--raw[pass raw input data]' \
          '--context[context of the service]:context:' \
          '1:sub-command:(local)' && ret=0
        ;;
      (logs)
        _arguments -s -S \
          ${global_args[@]} \
          '(-f --function)'{-f,--function}'[function name]:function:' \
          '--tail[tail the log output]' \
          '--startTime[start time for logs]:time:' \
          '--filter[filter expression]:filter:' \
          '--interval[tail polling interval in ms]:interval:' && ret=0
        ;;
      (metrics)
        _arguments -s -S \
          ${global_args[@]} \
          '(-f --function)'{-f,--function}'[function name]:function:' \
          '--startTime[start time for metrics]:time:' \
          '--endTime[end time for metrics]:time:' && ret=0
        ;;
      (plugin)
        _arguments -s -S \
          ${global_args[@]} \
          '1:sub-command:(list search install uninstall)' \
          '2:plugin name:' && ret=0
        ;;
      (config)
        _arguments -s -S \
          ${global_args[@]} \
          '1:sub-command:(credentials)' && ret=0
        ;;
      (output)
        _arguments -s -S \
          ${global_args[@]} \
          '1:sub-command:(get list set)' \
          '--name[output name]:name:' \
          '--service[service name]:service:' && ret=0
        ;;
      (param)
        _arguments -s -S \
          ${global_args[@]} \
          '1:sub-command:(get list set)' \
          '--name[param name]:name:' && ret=0
        ;;
      (remove|info|package|print|install|login|logout|generate-event|test|dashboard|stage|dev|doctor|compose)
        _arguments -s -S ${global_args[@]} && ret=0
        ;;
      (*)
        _arguments -s -S ${global_args[@]} && ret=0
        ;;
    esac
    ;;
esac

return ret
