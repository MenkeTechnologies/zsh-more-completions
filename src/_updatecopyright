#compdef updatecopyright
# Documentation: https://man.archlinux.org/search?q=updatecopyright
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-y,--update-year}'[the current year on every notice]'
  {-v,--verbose}'[more verbose]'
  {-h,--help}'[help information.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
