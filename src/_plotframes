#compdef plotframes
# Documentation: https://man.archlinux.org/search?q=plotframes
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {--input,-i}'[infile]'
  {--help,--usage,-h}'[show help]'
  {--manpage,-m}'[show manual page]'
  {--output,-o}'[outfile]'
  {--stream,--s}'[stream_specifier]'
  {--terminal,-t}'[terminal]'
  '*:filename:_files'
)

_arguments -s -S $arguments
