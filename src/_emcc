#compdef emcc em++

# Zsh completion for emcc/em++ - Emscripten C/C++ compiler

_arguments -s -S \
  '-O+[set optimization level]:level:(0 1 2 3 g s z)' \
  '-o[set output file]:output file:_files' \
  '-c[compile and assemble, do not link]' \
  '-g[include debug information]' \
  '-g+[debug level]:level:(0 1 2 3 4)' \
  '-v[verbose output]' \
  '-w[suppress warnings]' \
  '-Wall[enable all warnings]' \
  '-Werror[treat warnings as errors]' \
  '-Wextra[enable extra warnings]' \
  '-std=[language standard]:standard:(c99 c11 c17 c++11 c++14 c++17 c++20 gnu99 gnu11 gnu++11 gnu++14 gnu++17 gnu++20)' \
  '-I+[add include directory]:directory:_files -/' \
  '-L+[add library directory]:directory:_files -/' \
  '-l+[link with library]:library:' \
  '-D+[define preprocessor macro]:macro:' \
  '-U+[undefine preprocessor macro]:macro:' \
  '-E[preprocess only]' \
  '-S[compile only, produce assembly]' \
  '-shared[create shared library]' \
  '-s+[set Emscripten setting]:setting:' \
  '--preload-file[preload file into virtual FS]:file:_files' \
  '--embed-file[embed file into virtual FS]:file:_files' \
  '--exclude-file[exclude file from embedding]:file:_files' \
  '--use-preload-cache[enable preload cache]' \
  '--shell-file[HTML shell file]:file:_files -g "*.html"' \
  '--pre-js[prepend JavaScript file]:file:_files -g "*.js"' \
  '--post-js[append JavaScript file]:file:_files -g "*.js"' \
  '--extern-pre-js[prepend JS before optimizations]:file:_files -g "*.js"' \
  '--extern-post-js[append JS before optimizations]:file:_files -g "*.js"' \
  '--js-library[add JavaScript library]:file:_files -g "*.js"' \
  '--closure[enable Closure compiler]:mode:(0 1 2)' \
  '--minify[minify output]:mode:(0 1)' \
  '--profiling[include profiling information]' \
  '--profiling-funcs[include function names in profiling]' \
  '--memory-init-file[use a memory init file]:mode:(0 1)' \
  '--source-map-base[base URL for source maps]:url:' \
  '--emit-symbol-map[emit a symbol map]' \
  '--no-entry[do not emit entry point]' \
  '--bind[enable embind C++ bindings]' \
  '--proxy-to-worker[proxy to web worker]' \
  '--emrun[enable emrun support]' \
  '--cpuprofiler[enable CPU profiler]' \
  '--memoryprofiler[enable memory profiler]' \
  '--threadprofiler[enable thread profiler]' \
  '--default-obj-ext[default object file extension]:extension:' \
  '--valid-abspath[allow absolute path]:path:_files' \
  '--cache[set cache directory]:directory:_files -/' \
  '--clear-cache[clear cache]' \
  '--clear-ports[clear ports]' \
  '--show-ports[show ports]' \
  '--check[run Emscripten sanity checks]' \
  '--version[show version]' \
  '--help[show help]' \
  '*:source file:_files -g "*.{c,cc,cpp,cxx,c++,h,hh,hpp,hxx,o,a,bc,wasm}"' && return 0
