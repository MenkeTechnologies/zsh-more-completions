#compdef rscreen
# Documentation: https://man.archlinux.org/search?q=rscreen
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-M[monitor port. May be overridden by environment]'
  '-f[in background (autossh handles this, and does not]'
  '-V[autossh version and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
