#compdef brltty-genkey
# Documentation: https://man.archlinux.org/search?q=brltty-genkey
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[show usage summary (this output), and then exit]'
  '-q[decrease output verbosity]'
  '-v[increase output verbosity]'
  '-f[the BrlAPI key file (default is /etc/brlapi.key)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
