#compdef visidata

# Zsh completion for visidata (alias: vd) - terminal spreadsheet multitool

_arguments -s -S \
  '(-f --filetype)'{-f,--filetype}'[specify file type]:filetype:(csv tsv json jsonl sqlite xlsx xlsm xls ods html markdown md yaml toml xml pcap postgres mysql fixed fwf rec las sas7bdat arrow parquet hdf5 mbtiles vds)' \
  '--config[config file path]:file:_files' \
  '--play[replay keystrokes from a .vd file]:file:_files' \
  '--batch[replay in batch mode without opening visidata]' \
  '--output[output to file]:file:_files' \
  '(-o --output)'{-o,--output}'[output to file]:file:_files' \
  '--diff[specify source sheet to diff against]:file:_files' \
  '--encoding[file encoding]:encoding:' \
  '--encoding-errors[encoding error handling]:errors:(strict ignore replace)' \
  '--skip[skip N lines at the start of each file]:N:' \
  '--csv-dialect[CSV dialect]:dialect:(excel excel-tab unix)' \
  '--csv-delimiter[CSV delimiter]:delimiter:' \
  '--csv-quotechar[CSV quote character]:char:' \
  '--csv-skipinitialspace[skip whitespace after delimiter]' \
  '--tsv-delimiter[TSV delimiter]:delimiter:' \
  '--header[number of header rows]:N:' \
  '--json-lines[force JSONL format]' \
  '--json-indent[indentation for JSON output]:N:' \
  '--safe-error[error string for conversions]:string:' \
  '--null-value[null string values]:string:' \
  '--debug[enable debug logging]' \
  '--profile[enable profiling]' \
  '--no-curses[disable curses/ncurses and fallback to stdout]' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:file:_files'
