#compdef kbroadcastnotification

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[displays this help.]'
  {-v,--version}'[displays version information.]'
  '--application[name of the application that should be notified]:name:'
  '--summary[A brief one-line summary of the notification]'
  '--icon[icon for the notification]'
  '--uids[a comma-separated list of user IDs this notification applies to]:uids:'
  '--timeout[timeout for the notification]'
  '--persistent[keep the notification in the history until the user closes it]'
  '--author[show author information.]'
  '--license[show license information.]'
  '--desktopfile[the base file name of the desktop entry for this application]:name:'
  '*:filename:_files'
)

_arguments -s -S $arguments
