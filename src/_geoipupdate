#compdef geoipupdate
# Documentation: https://man.archlinux.org/search?q=geoipupdate
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-d[store downloaded files in DIR]'
  '-f[use configuration found in FILE (see GeoIP.conf(5) man page)]'
  '-h[display this help text]'
  '-v[use verbose output]'
  '-V[display the version and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
