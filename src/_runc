#compdef runc

local -a arguments

arguments=(
  '--debug[enable debug output for logging]'
  '--log[set the log file path where internal debug information is written]:file:_files'
  '--log-format[set the format used by logs (default text)]:format:(text json)'
  '--root[root directory for storage of container state (default /run/runc)]:dir:_directories'
  '--criu[path to the criu binary used for checkpoint and restore]:path:_files'
  '--systemd-cgroup[enable systemd cgroup support, expects cgroupsPath to be of form "slice:prefix:name" for e.g. "system.slice:runc:434234"]'
  '--rootless[ignore cgroup permission errors (default auto)]:mode:(true false auto)'
  {--help,-h}'[show help]'
  {--version,-v}'[print the version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
