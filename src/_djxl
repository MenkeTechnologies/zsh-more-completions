#compdef djxl

local -a arguments

arguments=(
  {-V,--version}'[print version number and exit]'
  '--num_reps[number of repetitions]:N'
  '--num_threads[number of threads]:N'
  '--print_profile[print color profile (0 or 1)]:0|1'
  '--bits_per_sample[bits per sample]:N'
  '--tone_map[apply tone mapping]'
  '--display_nits[display nits (0.3-250)]:nits'
  '--color_space[color space]:colorspace'
  {-s,--downsampling}'[downsampling factor (1,2,4,8,16)]:factor'
  '--allow_partial_files[allow decoding of partial files]'
  '--allow_more_progressive_steps[allow more progressive steps]'
  {-j,--pixels_to_jpeg}'[convert pixels to JPEG]'
  {-q,--jpeg_quality}'[JPEG quality]:N'
  '--use_sjpeg[use sjpeg encoder]'
  '--print_read_bytes[print number of bytes read]'
  '--quiet[silence output (except for errors)]'
  {-h,--help}'[prints this help message.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
