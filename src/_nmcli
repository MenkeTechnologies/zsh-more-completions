#compdef nmcli

# Zsh completion for nmcli (NetworkManager command-line client)

_nmcli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a global_opts
    global_opts=(
        {-a,--ask}'[ask for missing parameters]'
        {-c,--color}'[whether to use colors in output]:color:(auto yes no)'
        {-e,--escape}'[escape columns separators in values]:escape:(yes no)'
        {-f,--fields}'[specify fields to output]:fields'
        {-g,--get-values}'[shortcut for -m tabular -t -f]:fields'
        '(- *)'{-h,--help}'[print help information]'
        {-m,--mode}'[output mode]:mode:(tabular multiline)'
        '--complete-args[list possible completions for the last argument]'
        {-o,--overview}'[overview mode]'
        {-p,--pretty}'[pretty output]'
        {-s,--show-secrets}'[allow displaying passwords]'
        {-t,--terse}'[terse output]'
        '(- *)'{-v,--version}'[show program version]'
        {-w,--wait}'[set timeout waiting for finishing operations]:seconds'
        '(-): :->command'
        '(-)*:: :->option-or-argument'
    )

    _arguments -s -C $global_opts && ret=0

    case $state in
        (command)
            local -a commands
            commands=(
                'general:NetworkManager general status and operations'
                'networking:overall networking control'
                'radio:NetworkManager radio switches'
                'connection:NetworkManager connection management'
                'device:devices managed by NetworkManager'
                'agent:NetworkManager secret agent or polkit agent'
                'monitor:monitor NetworkManager changes'
            )
            _describe -t commands 'nmcli command' commands && ret=0
            ;;
        (option-or-argument)
            curcontext=${curcontext%:*:*}:nmcli-$words[1]:
            case $words[1] in
                general)
                    local -a general_cmds
                    general_cmds=(
                        'status:show overall status of NetworkManager'
                        'hostname:get or change persistent system hostname'
                        'permissions:show caller permissions for authenticated operations'
                        'logging:get or change NetworkManager logging level and domains'
                        'reload:reload NetworkManager configuration'
                    )
                    _describe -t commands 'general command' general_cmds && ret=0
                    ;;
                networking)
                    local -a networking_cmds
                    networking_cmds=(
                        'on:switch networking on'
                        'off:switch networking off'
                        'connectivity:get network connectivity state'
                    )
                    _describe -t commands 'networking command' networking_cmds && ret=0
                    ;;
                radio)
                    local -a radio_cmds
                    radio_cmds=(
                        'wifi:show or set status of Wi-Fi in NetworkManager'
                        'wwan:show or set status of WWAN (mobile broadband) in NetworkManager'
                        'all:show or set all radio switches'
                    )
                    _describe -t commands 'radio command' radio_cmds && ret=0
                    ;;
                connection)
                    local -a connection_cmds
                    connection_cmds=(
                        'show:list in-memory and on-disk connection profiles'
                        'up:activate a connection'
                        'down:deactivate a connection from a device'
                        'add:create a new connection using specified properties'
                        'modify:modify one or more properties of a connection profile'
                        'clone:clone an existing connection profile'
                        'edit:edit an existing connection or add a new one using interactive editor'
                        'delete:delete a configured connection'
                        'monitor:monitor connection profile activity'
                        'reload:reload all connection files from disk'
                        'load:load or reload one or more connection files from disk'
                        'import:import an external or foreign configuration as a NetworkManager connection profile'
                        'export:export a connection'
                        'migrate:migrate connection profiles to a different storage plugin'
                    )
                    _describe -t commands 'connection command' connection_cmds && ret=0
                    ;;
                device)
                    local -a device_cmds
                    device_cmds=(
                        'status:print status of devices'
                        'show:show detailed information about devices'
                        'set:set device properties'
                        'connect:connect the device'
                        'reapply:attempt to update device with changes to the currently active connection'
                        'modify:modify the settings currently active on the device'
                        'disconnect:disconnect a device and prevent it from auto-activating'
                        'delete:delete a device (removing it from NetworkManager management)'
                        'monitor:monitor device activity'
                        'wifi:manage Wi-Fi connections'
                        'lldp:display LLDP neighbors discovered on devices'
                    )
                    _describe -t commands 'device command' device_cmds && ret=0
                    ;;
                agent)
                    local -a agent_cmds
                    agent_cmds=(
                        'secret:register nmcli as a NetworkManager secret agent'
                        'polkit:register nmcli as a polkit agent for the user session'
                        'all:register nmcli as a secret and polkit agent'
                    )
                    _describe -t commands 'agent command' agent_cmds && ret=0
                    ;;
                monitor)
                    ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_nmcli "$@"
