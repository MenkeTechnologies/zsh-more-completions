#compdef faad

local -a arguments

arguments=(
  '-h[shows this help screen.]'
  '-i[shows info about the input file.]'
  '-a[write MPEG-4 AAC ADTS output file.]'
  '-t[assume old ADTS format.]'
  '-o[set output filename]:file:_files'
  '-f[set output format]:format:'
  '-b[set output sample format]:format:'
  '-s[force the samplerate (for RAW files)]:samplerate:'
  '-l[set object type]:type:'
  '-d[down matrix 5.1 to 2 channels]'
  '-w[write output to stdio instead of a file.]'
  '-g[disable gapless decoding.]'
  '-q[quiet - suppresses status messages.]'
  '-j[jump - start output X seconds into track (MP4 only)]:seconds:'
  '*:filename:_files'
)

_arguments -s -S $arguments
