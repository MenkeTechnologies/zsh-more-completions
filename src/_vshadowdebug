#compdef vshadowdebug
# Documentation: https://man.archlinux.org/search?q=vshadowdebug
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[shows this help]'
  '-o[specify the volume offset in bytes]'
  '-v[verbose output to stderr]'
  '-V[print version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
