#compdef lesskey
# Documentation: https://man.archlinux.org/search?q=lesskey
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-o[specify output file, otherwise $HOME/.less is used]'
  '-i[specify input file, otherwise standard input is used]'
  '-V[print lesskey version]'
  '-h[print this help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
