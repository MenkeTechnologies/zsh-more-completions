#compdef bin2obj

local -a arguments

arguments=(
  '-a[write ascii data instead of bytes]'
  '-z[compress data]'
  '-e[encrypt data with key (must have 8 characters)]:key:'
  '-o[output filename]:filename:_files'
  '-u[make a unit instead of an include file (unit name is outfile)]'
  '-U[same as -u, and compile the unit. (requires outfile)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
