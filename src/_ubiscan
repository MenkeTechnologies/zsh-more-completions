#compdef ubiscan
# Documentation: https://man.archlinux.org/search?q=ubiscan
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[-?, --help               print help message]'
  {-H,--histrogram}'[comma-separated list of bin thresholds]'
  {-v,--verbose}'[be verbose]'
  {-V,--version}'[print program version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
