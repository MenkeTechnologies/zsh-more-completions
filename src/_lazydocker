#compdef lazydocker

# Zsh completion for lazydocker (docker TUI)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-f --config-file)'{-f,--config-file}'[path to config file]:config file:_files' \
  '(-d --config-dir)'{-d,--config-dir}'[path to config directory]:config dir:_directories' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
