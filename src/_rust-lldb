#compdef rust-lldb

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[print usage information and exit]'
  {-v,--version}'[print version number and exit]'
  {-a,--arch}'[use the specified architecture]:architecture: '
  {-f,--file}'[use the file as the program to debug]:filename:_files'
  {-c,--core}'[use the fullpath as the core file]:path:_files'
  {-p,--attach-pid}'[attach to a process with the given pid]:pid:_pids'
  {-n,--attach-name}'[attach to a process with the given name]:name: '
  {-w,--wait-for}'[wait for a process with the given pid or name to launch]'
  {-s,--source}'[read in and execute lldb commands from file]:file:_files'
  {-o,--one-line}'[execute one-line lldb command after loading file]:command: '
  {-S,--source-before-file}'[execute lldb commands from file before loading program]:file:_files'
  {-O,--one-line-before-file}'[execute one-line lldb command before loading file]:command: '
  {-k,--one-line-on-crash}'[execute one-line lldb command on crash in batch mode]:command: '
  {-K,--source-on-crash}'[source this file of lldb commands on crash in batch mode]:file:_files'
  {-Q,--source-quietly}'[execute commands from file without echoing]:file:_files'
  {-b,--batch}'[run commands from -s, -S, -o and -O then quit]'
  {-e,--editor}'[open source files using the host external editor]'
  {-x,--no-lldbinit}'[do not automatically parse any .lldbinit files]'
  {-X,--no-use-colors}'[do not use colors]'
  {-P,--python-path}'[print path to the lldb.py file]'
  {-l,--script-language}'[use the specified scripting language]:language: '
  {-d,--debug}'[print extra debugging information]'
  {-r,--repl}'[run lldb in REPL mode with a stub process]'
  {-R,--repl-language}'[choose the language for the REPL]:language: '
  '*:filename:_files'
)

_arguments -s -S $arguments
