#compdef img2xpm
# Documentation: https://man.archlinux.org/search?q=img2xpm
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-o[the directory to place the .xpm file(s), defaults to]'
  '-m[if the original image has a mask or transparency defined]'
  '-n[A filename to write the .xpm data to. Defaults to the]'
  '*:filename:_files'
)

_arguments -s -S $arguments
