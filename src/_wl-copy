#compdef wl-copy
# Zsh completion for wl-copy (wl-clipboard)
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-t --type)'{-t,--type}'[Set MIME type]:mime type:' \
  '(-s --seat)'{-s,--seat}'[Pick seat to work with]:seat:' \
  '(-p --primary)'{-p,--primary}'[Use the primary selection]' \
  '(-n --trim-newline)'{-n,--trim-newline}'[Trim trailing newline]' \
  '(-o --paste-once)'{-o,--paste-once}'[Only serve one paste request and then exit]' \
  '(-f --foreground)'{-f,--foreground}'[Stay in foreground instead of forking]' \
  '(-c --clear)'{-c,--clear}'[Clear the clipboard]' \
  '(- *)--help[Show help message]' \
  '(- *)--version[Show version]' \
  '*:text to copy:' && ret=0
return ret
