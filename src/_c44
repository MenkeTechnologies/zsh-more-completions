#compdef c44

local -a arguments

arguments=(
  '-slice[select an increasing sequence of data slices]:slices:'
  '-bpp[select an increasing sequence of bitrates]:bitrates:'
  '-size[select an increasing sequence of minimal sizes]:sizes:'
  '-percent[select the percentage of original file size]:percentages:'
  '-decibel[select an increasing sequence of luminance error]:decibels:'
  '-dbfrac[limit decibel estimation to a fraction of pixels]:fraction:'
  '-mask[bitmask specifying image zone to encode]:mask:'
  '-dpi[the image resolution]:dpi:'
  '-gamma[the image gamma correction]:gamma:'
  '-crcbfull[chrominance with highest quality]'
  '-crcbnormal[chrominance with normal resolution (default)]'
  '-crcbhalf[chrominance with half resolution]'
  '-crcbnone[do not encode chrominance at all]'
  '-crcbdelay[chrominance coding delay (default 10)]:delay:'
  '*:filename:_files'
)

_arguments -s -S $arguments
