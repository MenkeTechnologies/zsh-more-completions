#compdef podebconf-report-po

local -a arguments

arguments=(
  '--addlanguageteam[send a copy of the messages for language LANG also]'
  '--bts[specify the Debian bug number to set as reply-to]'
  '--call[send a call for translations to the LIST (or to]'
  '--conf[config file path]'
  '--noconf[do not read config file]'
  '--deadline[specify the deadline for receiving the updated]'
  '--default[dont open the editor and use the template as is]'
  '--nodefault[do not use default values]'
  {-f,--force}'[send the email without confirmation]'
  '--noforce[do not force operations]'
  '--from[specify the name and the email address of the sender]'
  '--gzip[compress PO files with gzip]'
  '--nogzip[do not gzip output]'
  '--help[display this help and exit]'
  '--langs[restrict sending emails only to these languages]'
  '--languageteam[send the email also to the Language Team]'
  '--nolanguageteam[do not include language team]'
  '--mutt[send the mails with mutt. This set the --postpone]'
  '--notdebconf[this is not for debconf translation. Do not]'
  '--package[specify the name of the package]'
  '--podir[specify where are located the PO files]'
  '--postpone[do not send emails, append them in MBOX. This file]'
  '--potfile[when used with --call, specifies the POT file to]'
  '--sendmessage[only send a message, without any attachment]'
  '--smtp[specify SMTP server for mailing (default localhost)]'
  '--submit[send a bug report against the package with a report]'
  '--summary[send a status report to the maintainer with the list]'
  '--nosummary[no summary at end]'
  '--utf8[send the mail in UTF-8]'
  '--noutf8[do not require UTF-8]'
  '--version[display version information and exit]'
  {-v,--verbose}'[display additional information]'
  '--noverbose[non-verbose output]'
  '--templatecall[specify file to use it as template for the emails]'
  '--templatesubmit[specify file to use it as template for the emails]'
  '--templatetranslators[specify file to use it as template for the emails]'
  '--template[specify file to use it as template for the emails]'
  '--notemplate[do not include templates]'
  '--withtranslators[when used with --call, specifies that request for]'
  '--withouttranslators[do not include translators]'
  '*:filename:_files'
)

_arguments -s -S $arguments
