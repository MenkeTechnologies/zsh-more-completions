#compdef oco opencommit

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'commit:generate AI commit message and commit'
  'config:manage configuration'
  'hook:manage git hooks'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--yes[skip confirmation prompt]' \
  '-y[skip confirmation prompt]' \
  '--all[stage all changes before committing]' \
  '-a[stage all changes before committing]' \
  '--fgpt[use FGPT model]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'oco command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (config)
        local -a config_cmds=(
          'get:get a config value'
          'set:set a config value'
        )
        _arguments \
          '1:subcommand:_describe -t config-commands "config command" config_cmds' \
          '2:key:(OCO_API_KEY OCO_MODEL OCO_LANGUAGE OCO_MESSAGE_TEMPLATE_PLACEHOLDER OCO_PROMPT_MODULE OCO_AI_PROVIDER OCO_ONE_LINE_COMMIT OCO_DESCRIPTION OCO_EMOJI OCO_TOKENS_MAX_INPUT OCO_TOKENS_MAX_OUTPUT)' \
          '3:value' && ret=0
        ;;
      (hook)
        local -a hook_cmds=(
          'set:set git hook'
          'unset:unset git hook'
        )
        _arguments \
          '1:subcommand:_describe -t hook-commands "hook command" hook_cmds' && ret=0
        ;;
    esac
    ;;
esac

return ret
