#compdef gvnccapture
# Documentation: https://man.archlinux.org/search?q=gvnccapture
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  {-d,--debug}'[enables debug output]'
  {-q,--quiet}'[dont print any status to console]'
  '*:filename:_files'
)

_arguments -s -S $arguments
