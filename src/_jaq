#compdef jaq

# Zsh completion for jaq (jq clone in Rust)

_arguments -s -S \
  '(-c --compact-output)'{-c,--compact-output}'[compact output]' \
  '(-r --raw-output)'{-r,--raw-output}'[raw string output]' \
  '(-R --raw-input)'{-R,--raw-input}'[read each line as string]' \
  '(-j --join-output)'{-j,--join-output}'[like -r but no newlines]' \
  '(-s --slurp)'{-s,--slurp}'[read all inputs into array]' \
  '(-n --null-input)'{-n,--null-input}'[use null as input]' \
  '(-e --exit-status)'{-e,--exit-status}'[exit with status based on output]' \
  '--tab[use tabs for indentation]' \
  '--indent[number of spaces for indentation]:n:' \
  '--arg[set variable to string value]:name: :value:' \
  '--argjson[set variable to JSON value]:name: :json:' \
  '--slurpfile[set variable from file contents]:name: :file:_files' \
  '--rawfile[set variable from raw file]:name: :file:_files' \
  '--jsonargs[remaining args are JSON]' \
  '--args[remaining args are strings]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:filter:' \
  '*:file:_files' && return 0
