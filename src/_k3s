#compdef k3s

# Zsh completion for K3s (lightweight Kubernetes)

_k3s() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a global_opts
    global_opts=(
        '--debug[Turn on debug logs]'
        {-d,--data-dir}'[Folder to hold state]:directory:_directories'
        '(- *)'{-h,--help}'[Show help]'
        '(- *)'{-v,--version}'[Print the version]'
    )

    _arguments -C \
        $global_opts \
        '(-): :->command' \
        '(-)*:: :->option-or-argument' && ret=0

    case $state in
        (command)
            local -a commands
            commands=(
                'server:Run management server'
                'agent:Run node agent'
                'kubectl:Run kubectl'
                'crictl:Run crictl'
                'ctr:Run ctr'
                'token:Manage bootstrap tokens'
                'etcd-snapshot:Trigger an immediate etcd snapshot'
                'secrets-encrypt:Control secrets encryption and target rotation'
                'certificate:Manage K3s certificates'
                'completion:Install shell completion script'
                'check-config:Run config check'
                'help:Shows a list of commands or help for one command'
            )
            _describe -t commands 'command' commands && ret=0
            ;;
        (option-or-argument)
            curcontext=${curcontext%:*:*}:k3s-$words[1]:
            case $words[1] in
                (server)
                    _arguments -s \
                        '--config[Load configuration from file]:file:_files' \
                        {-v,--log}'[Number for the log level verbosity]:level' \
                        '--vmodule[Comma-separated list of pattern=N settings for file-filtered logging]:pattern' \
                        '--alsologtostderr[Log to standard error as well as files]' \
                        '--bind-address[K3s bind address]:address' \
                        '--https-listen-port[HTTPS listen port]:port' \
                        '--advertise-address[IPv4/IPv6 address that apiserver uses to advertise to cluster members]:address' \
                        '--advertise-port[Port that apiserver uses to advertise to cluster members]:port' \
                        '--tls-san[Add additional hostnames or IPv4/IPv6 addresses as Subject Alternative Names on the server TLS cert]:host' \
                        '--data-dir[Folder to hold state]:directory:_directories' \
                        '--cluster-cidr[IPv4/IPv6 network CIDRs to use for pod IPs]:cidr' \
                        '--service-cidr[IPv4/IPv6 network CIDRs to use for service IPs]:cidr' \
                        '--service-node-port-range[Port range to reserve for services with NodePort visibility]:range' \
                        '--cluster-dns[IPv4 cluster IP for coredns service]:ip' \
                        '--cluster-domain[Cluster domain]:domain' \
                        '--flannel-backend[Backend for flannel]:backend:(vxlan host-gw ipsec wireguard-native none)' \
                        '--flannel-ipv6-masq[Enable IPv6 masquerading for flannel]' \
                        '--flannel-external-ip[Use node external IP addresses as destination for flannel traffic]' \
                        '--egress-selector-mode[Set egress selector mode]:mode:(agent cluster pod disabled)' \
                        '--servicelb-namespace[Namespace of the pods for the servicelb component]:namespace' \
                        '--token[Shared secret used to join a server or agent to a cluster]:token' \
                        {-t,--token-file}'[File containing the cluster-secret/token]:file:_files' \
                        '--agent-token[Shared secret used to join agents to the cluster]:token' \
                        '--agent-token-file[File containing the agent secret]:file:_files' \
                        '--server[Server to connect to when joining existing cluster]:url' \
                        '--cluster-init[Initialize a new cluster using embedded etcd]' \
                        '--cluster-reset[Forget all peers and become sole member of a new cluster]' \
                        '--cluster-reset-restore-path[Path to snapshot file to be restored]:file:_files' \
                        '--kube-apiserver-arg[Customized flag for kube-apiserver process]:arg' \
                        '--etcd-arg[Customized flag for etcd process]:arg' \
                        '--kube-controller-manager-arg[Customized flag for kube-controller-manager process]:arg' \
                        '--kube-scheduler-arg[Customized flag for kube-scheduler process]:arg' \
                        '--kube-cloud-controller-manager-arg[Customized flag for kube-cloud-controller-manager process]:arg' \
                        '--datastore-endpoint[Specify etcd, Mysql, Postgres, or Sqlite data source name]:endpoint' \
                        '--datastore-cafile[TLS CA cert file used to secure datastore backend communication]:file:_files' \
                        '--datastore-certfile[TLS cert file used to secure datastore backend communication]:file:_files' \
                        '--datastore-keyfile[TLS key file used to secure datastore backend communication]:file:_files' \
                        '--etcd-expose-metrics[Expose etcd metrics to client interface]' \
                        '--etcd-disable-snapshots[Disable automatic etcd snapshots]' \
                        '--etcd-snapshot-name[Set the base name of etcd snapshots]:name' \
                        '--etcd-snapshot-schedule-cron[Snapshot interval time in cron spec]:cron' \
                        '--etcd-snapshot-retention[Number of snapshots to retain]:count' \
                        '--etcd-snapshot-dir[Directory to save db snapshots]:directory:_directories' \
                        '--etcd-snapshot-compress[Compress etcd snapshot]' \
                        '--etcd-s3[Enable backup to S3]' \
                        '--etcd-s3-endpoint[S3 endpoint url]:url' \
                        '--etcd-s3-endpoint-ca[S3 custom CA cert]:file:_files' \
                        '--etcd-s3-skip-ssl-verify[Disables S3 SSL certificate validation]' \
                        '--etcd-s3-access-key[S3 access key]:key' \
                        '--etcd-s3-secret-key[S3 secret key]:key' \
                        '--etcd-s3-bucket[S3 bucket name]:bucket' \
                        '--etcd-s3-region[S3 region / bucket location]:region' \
                        '--etcd-s3-folder[S3 folder]:folder' \
                        '--etcd-s3-insecure[Disables S3 over HTTPS]' \
                        '--etcd-s3-timeout[S3 timeout]:timeout' \
                        '--default-local-storage-path[Default local storage path for local provisioner storage class]:path:_directories' \
                        '--disable[Do not deploy packaged components]:component:(coredns servicelb traefik local-storage metrics-server)' \
                        '--disable-scheduler[Disable Kubernetes default scheduler]' \
                        '--disable-cloud-controller[Disable k3s default cloud controller manager]' \
                        '--disable-kube-proxy[Disable running kube-proxy]' \
                        '--disable-network-policy[Disable k3s default network policy controller]' \
                        '--disable-helm-controller[Disable Helm controller]' \
                        '--disable-apiserver[Disable running the API server]' \
                        '--disable-controller-manager[Disable running the controller manager]' \
                        '--disable-etcd[Disable running etcd]' \
                        '--node-name[Node name]:name' \
                        '--with-node-id[Append id to node name]' \
                        '--node-label[Registering and starting kubelet with set of labels]:label' \
                        '--node-taint[Registering kubelet with set of taints]:taint' \
                        '--image-credential-provider-bin-dir[The path to the directory where credential provider plugin binaries are located]:dir:_directories' \
                        '--image-credential-provider-config[The path to the credential provider plugin config file]:file:_files' \
                        '--docker[Use cri-dockerd instead of containerd]' \
                        '--container-runtime-endpoint[Disable embedded containerd and use the CRI socket at the given path]:path' \
                        '--snapshotter[Override default containerd snapshotter]:snapshotter' \
                        '--private-registry[Private registry configuration file]:file:_files' \
                        '--system-default-registry[Private registry to use for all system images]:registry' \
                        '--node-ip[IPv4/IPv6 addresses to advertise for node]:ip' \
                        '--node-external-ip[IPv4/IPv6 external IP addresses to advertise for node]:ip' \
                        '--resolv-conf[Kubelet resolv.conf file]:file:_files' \
                        '--flannel-iface[Override default flannel interface]:interface' \
                        '--flannel-conf[Override default flannel config file]:file:_files' \
                        '--flannel-cni-conf[Override default flannel cni config file]:file:_files' \
                        '--kubelet-arg[Customized flag for kubelet process]:arg' \
                        '--kube-proxy-arg[Customized flag for kube-proxy process]:arg' \
                        '--protect-kernel-defaults[Kernel tuning behavior]' \
                        '--secrets-encryption[Enable secret encryption at rest]' \
                        '--enable-pprof[Enable pprof endpoint on supervisor port]' \
                        '--rootless[Run rootless]' \
                        '--prefer-bundled-bin[Prefer bundled userspace binaries over host binaries]' \
                        '--selinux[Enable SELinux in containerd]' \
                        '--lb-server-port[Local port for supervisor client load-balancer]:port' \
                        '--write-kubeconfig[Write kubeconfig for admin client to this file]:file:_files' \
                        {-o,--write-kubeconfig-mode}'[Write kubeconfig with this mode]:mode' \
                        '--helm-job-image[Default image to use for helm jobs]:image' \
                        '--embedded-registry[Enable embedded distributed container registry]' \
                        '--vpn-auth[VPN auth credentials]:credentials' \
                        '--vpn-auth-file[VPN auth credentials file]:file:_files' \
                        && ret=0
                    ;;
                (agent)
                    _arguments -s \
                        '--config[Load configuration from file]:file:_files' \
                        {-v,--log}'[Number for the log level verbosity]:level' \
                        '--vmodule[Comma-separated list of pattern=N settings for file-filtered logging]:pattern' \
                        '--alsologtostderr[Log to standard error as well as files]' \
                        '--token[Token to use for authentication]:token' \
                        {-t,--token-file}'[Token file to use for authentication]:file:_files' \
                        {-s,--server}'[Server to connect to]:url' \
                        '--data-dir[Folder to hold state]:directory:_directories' \
                        '--node-name[Node name]:name' \
                        '--with-node-id[Append id to node name]' \
                        '--node-label[Registering and starting kubelet with set of labels]:label' \
                        '--node-taint[Registering kubelet with set of taints]:taint' \
                        '--image-credential-provider-bin-dir[The path to the directory where credential provider plugin binaries are located]:dir:_directories' \
                        '--image-credential-provider-config[The path to the credential provider plugin config file]:file:_files' \
                        '--docker[Use cri-dockerd instead of containerd]' \
                        '--container-runtime-endpoint[Disable embedded containerd and use the CRI socket at the given path]:path' \
                        '--snapshotter[Override default containerd snapshotter]:snapshotter' \
                        '--private-registry[Private registry configuration file]:file:_files' \
                        '--system-default-registry[Private registry to use for all system images]:registry' \
                        '--node-ip[IPv4/IPv6 addresses to advertise for node]:ip' \
                        '--node-external-ip[IPv4/IPv6 external IP addresses to advertise for node]:ip' \
                        '--resolv-conf[Kubelet resolv.conf file]:file:_files' \
                        '--flannel-iface[Override default flannel interface]:interface' \
                        '--flannel-conf[Override default flannel config file]:file:_files' \
                        '--flannel-cni-conf[Override default flannel cni config file]:file:_files' \
                        '--kubelet-arg[Customized flag for kubelet process]:arg' \
                        '--kube-proxy-arg[Customized flag for kube-proxy process]:arg' \
                        '--protect-kernel-defaults[Kernel tuning behavior]' \
                        '--rootless[Run rootless]' \
                        '--prefer-bundled-bin[Prefer bundled userspace binaries over host binaries]' \
                        '--selinux[Enable SELinux in containerd]' \
                        '--lb-server-port[Local port for supervisor client load-balancer]:port' \
                        '--vpn-auth[VPN auth credentials]:credentials' \
                        '--vpn-auth-file[VPN auth credentials file]:file:_files' \
                        && ret=0
                    ;;
                (token)
                    _arguments -C \
                        '(-): :->subcmd' \
                        '(-)*:: :->subargs' && ret=0
                    case $state in
                        (subcmd)
                            local -a token_cmds
                            token_cmds=(
                                'create:Create bootstrap tokens on the server'
                                'delete:Delete bootstrap tokens on the server'
                                'generate:Generate and print a bootstrap token'
                                'list:List bootstrap tokens on the server'
                                'rotate:Rotate original server token with a new token'
                            )
                            _describe -t token-commands 'token command' token_cmds && ret=0
                            ;;
                        (subargs)
                            case $words[1] in
                                (create|delete|list|rotate)
                                    _arguments -s \
                                        '--data-dir[Folder to hold state]:directory:_directories' \
                                        '--kubeconfig[K3s kubeconfig for authenticating to the cluster]:file:_files' \
                                        '--token[Existing token used to join a server or agent to a cluster]:token' \
                                        '--description[A human friendly description of how this token is used]:description' \
                                        '--groups[Extra groups that this token will authenticate as]:groups' \
                                        '--ttl[The duration before the token is automatically deleted]:duration' \
                                        '--usages[Describes the ways in which this token can be used]:usages' \
                                        '--new-token[New token to rotate to]:token' \
                                        {-o,--output}'[Output format]:format:(json yaml table)' \
                                        '*:token:' \
                                        && ret=0
                                    ;;
                                (*)
                                    _arguments -s '*:arguments:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                (etcd-snapshot)
                    _arguments -C \
                        '(-): :->subcmd' \
                        '(-)*:: :->subargs' && ret=0
                    case $state in
                        (subcmd)
                            local -a snapshot_cmds
                            snapshot_cmds=(
                                'save:Trigger an immediate etcd snapshot'
                                'delete:Delete given snapshot(s)'
                                'list:List snapshots'
                                'prune:Remove snapshots that exceed the configured retention count'
                            )
                            _describe -t snapshot-commands 'etcd-snapshot command' snapshot_cmds && ret=0
                            ;;
                        (subargs)
                            _arguments -s \
                                '--data-dir[Folder to hold state]:directory:_directories' \
                                '--name[Set the base name of the etcd on-demand snapshot]:name' \
                                '--node-name[Node name]:name' \
                                {-d,--dir}'[Directory to save snapshots to]:directory:_directories' \
                                '--compress[Compress snapshot file]' \
                                '--s3[Enable backup to S3]' \
                                '--s3-endpoint[S3 endpoint url]:url' \
                                '--s3-endpoint-ca[S3 custom CA cert]:file:_files' \
                                '--s3-skip-ssl-verify[Disables S3 SSL certificate validation]' \
                                '--s3-access-key[S3 access key]:key' \
                                '--s3-secret-key[S3 secret key]:key' \
                                '--s3-bucket[S3 bucket name]:bucket' \
                                '--s3-region[S3 region / bucket location]:region' \
                                '--s3-folder[S3 folder]:folder' \
                                '--s3-insecure[Disables S3 over HTTPS]' \
                                '--s3-timeout[S3 timeout]:timeout' \
                                '--snapshot-retention[Number of snapshots to retain]:count' \
                                '--etcd-snapshot-dir[Directory to save db snapshots]:directory:_directories' \
                                '--cluster-reset[Forget all peers and become sole member of a new cluster]' \
                                '*:snapshot:_files' \
                                && ret=0
                            ;;
                    esac
                    ;;
                (secrets-encrypt)
                    _arguments -C \
                        '(-): :->subcmd' \
                        '(-)*:: :->subargs' && ret=0
                    case $state in
                        (subcmd)
                            local -a secrets_cmds
                            secrets_cmds=(
                                'status:Display current status of secrets encryption'
                                'enable:Enable secrets encryption'
                                'disable:Disable secrets encryption'
                                'prepare:Prepare for secrets encryption key rotation'
                                'rotate:Rotate secrets encryption keys'
                                'reencrypt:Reencrypt all secrets with the current key'
                                'rotate-keys:Rotate secrets encryption keys and reencrypt'
                            )
                            _describe -t secrets-commands 'secrets-encrypt command' secrets_cmds && ret=0
                            ;;
                        (subargs)
                            _arguments -s \
                                '--data-dir[Folder to hold state]:directory:_directories' \
                                '--server[Server to connect to]:url' \
                                '--token[Token to use for authentication]:token' \
                                '--force[Force this stage even if previous stage is not done]' \
                                '*:arguments:' \
                                && ret=0
                            ;;
                    esac
                    ;;
                (certificate)
                    _arguments -C \
                        '(-): :->subcmd' \
                        '(-)*:: :->subargs' && ret=0
                    case $state in
                        (subcmd)
                            local -a cert_cmds
                            cert_cmds=(
                                'rotate:Rotate individual or all k3s component certificates on disk'
                                'rotate-ca:Rotate CA certificates and keys'
                            )
                            _describe -t cert-commands 'certificate command' cert_cmds && ret=0
                            ;;
                        (subargs)
                            _arguments -s \
                                '--data-dir[Folder to hold state]:directory:_directories' \
                                '--server[Server to connect to]:url' \
                                '--token[Token to use for authentication]:token' \
                                '--service[Rotate certificates for the given service]:service:(admin api-server controller-manager scheduler k3s-controller k3s-server cloud-controller etcd auth-proxy kubelet kube-proxy)' \
                                '--path[Path to directory containing new CA certificates]:path:_directories' \
                                '--force[Force this stage even if previous stage is not done]' \
                                '*:arguments:' \
                                && ret=0
                            ;;
                    esac
                    ;;
                (completion)
                    _arguments -s \
                        '1:shell:(bash zsh fish)' \
                        && ret=0
                    ;;
                (check-config)
                    _arguments -s \
                        '*:arguments:' \
                        && ret=0
                    ;;
                (kubectl)
                    # Delegate to kubectl completion if available
                    _arguments -s '*:arguments:' && ret=0
                    ;;
                (crictl)
                    # Delegate to crictl completion if available
                    _arguments -s '*:arguments:' && ret=0
                    ;;
                (ctr)
                    # Delegate to ctr completion if available
                    _arguments -s '*:arguments:' && ret=0
                    ;;
                (*)
                    _arguments -s '*:arguments:' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_k3s "$@"
