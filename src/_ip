#compdef ip

# Zsh completion for iproute2 ip command
# Covers ip from iproute2 (Linux)

local curcontext="$curcontext" state line
typeset -A opt_args

local -a ip_objects
ip_objects=(
  'address:protocol (IP or IPv6) address on a device'
  'addrlabel:label configuration for protocol address selection'
  'fou:Foo-over-UDP receive port configuration'
  'ila:manage identifier locator addresses (ILA)'
  'ioam:manage IOAM namespaces and schemas'
  'l2tp:tunnel Ethernet over IP (L2TPv3)'
  'link:network device configuration'
  'macsec:MACsec device configuration'
  'maddress:multicast address management'
  'monitor:watch for netlink messages'
  'mptcp:manage MPTCP path manager'
  'mroute:multicast routing cache entry'
  'mrule:rule in multicast routing policy database'
  'neighbour:manage ARP or NDISC cache entries'
  'netconf:network configuration monitoring'
  'netns:manage network namespaces'
  'nexthop:manage nexthop objects'
  'ntable:manage the neighbor cache operation'
  'route:routing table management'
  'rule:routing policy database management'
  'sr:manage IPv6 segment routing'
  'stats:manage and show interface statistics'
  'tcp_metrics:manage TCP metrics'
  'token:manage tokenized interface identifiers'
  'tunnel:tunnel over IP'
  'tuntap:manage TUN/TAP devices'
  'vrf:manage virtual routing and forwarding devices'
  'xfrm:manage IPsec policies'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[display help information]' \
  '(-V -Version)'{-V,-Version}'[print the version and exit]' \
  '(-s -stats -statistics)'{-s,-stats,-statistics}'[output more information and statistics]' \
  '(-d -details)'{-d,-details}'[output more detailed information]' \
  '(-l -loops)'{-l,-loops}'[max number of loops for address flush]:count:' \
  '(-f -family)'{-f,-family}'[specify protocol family]:family:(inet inet6 bridge mpls link)' \
  '(-4 -6 -B -M -0)-4[shortcut for -family inet]' \
  '(-4 -6 -B -M -0)-6[shortcut for -family inet6]' \
  '(-4 -6 -B -M -0)-B[shortcut for -family bridge]' \
  '(-4 -6 -B -M -0)-M[shortcut for -family mpls]' \
  '(-4 -6 -B -M -0)-0[shortcut for -family link]' \
  '(-o -oneline)'{-o,-oneline}'[output each record on a single line]' \
  '(-r -resolve)'{-r,-resolve}'[use DNS names instead of host addresses]' \
  '(-n -netns)'{-n,-netns}'[switch to specified network namespace]:namespace:' \
  '(-N -Numeric)'{-N,-Numeric}'[print protocol, scope, dsfield values as numbers]' \
  '(-a -all)'{-a,-all}'[execute command over all objects]' \
  '(-c -color)'{-c,-color}'[configure color output]:when:(auto always never)' \
  '(-t -timestamp)'{-t,-timestamp}'[display current time when using monitor]' \
  '(-ts -tshort)'{-ts,-tshort}'[display short timestamp]' \
  '(-rc -rcvbuf)'{-rc,-rcvbuf}'[set netlink socket receive buffer size]:size:' \
  '-iec[print human readable rates in IEC units]' \
  '(-h -human -human-readable)'{-hu,-human,-human-readable}'[output statistics with human readable values]' \
  '(-br -brief)'{-br,-brief}'[print information in brief tabular format]' \
  '(-j -json)'{-j,-json}'[output results in JSON format]' \
  '(-p -pretty)'{-p,-pretty}'[pretty print JSON output]' \
  '-echo[request kernel to send applied configuration back]' \
  '(-b -batch)'{-b,-batch}'[read commands from file or stdin]:file:_files' \
  '-force[do not terminate on errors in batch mode]' \
  '1:object:->objects' \
  '*::arg:->args'

case $state in
  objects)
    _describe 'ip object' ip_objects
    ;;
  args)
    case $words[1] in
      address|addr|a)
        local -a addr_cmds=(
          'add:add new protocol address'
          'change:change existing protocol address'
          'replace:replace protocol address'
          'del:delete protocol address'
          'show:look at protocol addresses'
          'list:look at protocol addresses'
          'flush:flush protocol addresses'
          'save:save address configuration'
          'restore:restore address configuration'
          'showdump:show address dump'
        )
        _describe 'address command' addr_cmds
        ;;
      link|l)
        local -a link_cmds=(
          'add:add virtual link'
          'delete:remove virtual link'
          'set:change device attributes'
          'show:display device attributes'
          'list:display device attributes'
          'xstats:display extended statistics'
          'afstats:display address-family statistics'
          'property:manage device properties'
          'help:display help'
        )
        _describe 'link command' link_cmds
        ;;
      route|r|ro)
        local -a route_cmds=(
          'add:add new route'
          'change:change existing route'
          'replace:change or add new route'
          'delete:delete a route'
          'show:list routes'
          'list:list routes'
          'flush:flush routing tables'
          'get:get a single route to a destination'
          'append:append route to multipath route'
          'save:save routing table information'
          'restore:restore routing table information'
        )
        _describe 'route command' route_cmds
        ;;
      neighbour|neigh|n)
        local -a neigh_cmds=(
          'add:add a new neighbour entry'
          'change:change an existing entry'
          'replace:add or change entry'
          'delete:delete a neighbour entry'
          'show:list neighbour entries'
          'list:list neighbour entries'
          'flush:flush neighbour entries'
        )
        _describe 'neighbour command' neigh_cmds
        ;;
      netns)
        local -a netns_cmds=(
          'add:create a new named network namespace'
          'attach:attach process to a network namespace'
          'delete:delete network namespace'
          'exec:execute command in network namespace'
          'identify:identify network namespace for a process'
          'list:list available network namespaces'
          'list-id:list network namespace IDs'
          'monitor:monitor network namespace events'
          'pids:list PIDs in a network namespace'
          'set:set properties of a network namespace'
        )
        _describe 'netns command' netns_cmds
        ;;
      tunnel|tun)
        local -a tunnel_cmds=(
          'add:add a new tunnel'
          'change:change existing tunnel'
          'delete:destroy a tunnel'
          'show:list tunnels'
          'prl:potential router list (ISATAP)'
          '6rd:set 6RD delegation prefix'
        )
        _describe 'tunnel command' tunnel_cmds
        ;;
      tuntap)
        local -a tuntap_cmds=(
          'add:add a TUN/TAP device'
          'del:delete a TUN/TAP device'
          'show:show TUN/TAP devices'
          'list:list TUN/TAP devices'
          'help:show help'
        )
        _describe 'tuntap command' tuntap_cmds
        ;;
      rule|ru)
        local -a rule_cmds=(
          'add:insert a new rule'
          'delete:delete a rule'
          'flush:flush rules'
          'show:list rules'
          'list:list rules'
          'save:save rules'
          'restore:restore rules'
        )
        _describe 'rule command' rule_cmds
        ;;
      maddress|maddr)
        local -a maddr_cmds=(
          'add:join a multicast group'
          'delete:leave a multicast group'
          'show:list multicast addresses'
        )
        _describe 'multicast address command' maddr_cmds
        ;;
      mroute)
        local -a mroute_cmds=(
          'show:list multicast routing cache entries'
          'list:list multicast routing cache entries'
        )
        _describe 'multicast route command' mroute_cmds
        ;;
      monitor)
        local -a monitor_objects=(
          'all:monitor all objects'
          'link:monitor link changes'
          'address:monitor address changes'
          'route:monitor route changes'
          'mroute:monitor multicast route changes'
          'neigh:monitor neighbour changes'
          'netconf:monitor netconf changes'
          'rule:monitor rule changes'
          'nsid:monitor nsid changes'
          'nexthop:monitor nexthop changes'
        )
        _describe 'monitor object' monitor_objects
        ;;
      vrf)
        local -a vrf_cmds=(
          'show:list VRF devices'
          'list:list VRF devices'
          'exec:run command in VRF context'
          'identify:identify VRF for a process'
          'pids:list PIDs in a VRF'
        )
        _describe 'vrf command' vrf_cmds
        ;;
      l2tp)
        local -a l2tp_cmds=(
          'add:add a tunnel or session'
          'del:delete a tunnel or session'
          'show:show tunnel or session information'
        )
        _describe 'l2tp command' l2tp_cmds
        ;;
      macsec)
        local -a macsec_cmds=(
          'add:create a new MACsec device'
          'set:modify MACsec device or parameters'
          'del:delete a receive channel or secure association'
          'show:display MACsec device configuration'
          'offload:configure MACsec offload'
        )
        _describe 'macsec command' macsec_cmds
        ;;
      nexthop|nh)
        local -a nexthop_cmds=(
          'add:add a nexthop entry'
          'replace:replace a nexthop entry'
          'delete:delete a nexthop entry'
          'show:list nexthop entries'
          'list:list nexthop entries'
          'flush:flush nexthop entries'
          'get:get a single nexthop'
          'bucket:list nexthop group buckets'
        )
        _describe 'nexthop command' nexthop_cmds
        ;;
      mptcp)
        local -a mptcp_cmds=(
          'endpoint:manage MPTCP endpoints'
          'limits:manage MPTCP limits'
          'monitor:monitor MPTCP events'
        )
        _describe 'mptcp command' mptcp_cmds
        ;;
      addrlabel)
        local -a addrlabel_cmds=(
          'add:add an address label'
          'del:delete an address label'
          'list:list address labels'
          'flush:flush address labels'
        )
        _describe 'addrlabel command' addrlabel_cmds
        ;;
      ntable)
        local -a ntable_cmds=(
          'change:change neighbour table parameters'
          'show:list neighbour table parameters'
        )
        _describe 'ntable command' ntable_cmds
        ;;
      token)
        local -a token_cmds=(
          'set:set tokenized interface identifier'
          'get:get tokenized interface identifier'
          'list:list tokenized interface identifiers'
        )
        _describe 'token command' token_cmds
        ;;
      stats|stat)
        local -a stats_cmds=(
          'show:show interface statistics'
          'set:set interface statistics options'
        )
        _describe 'stats command' stats_cmds
        ;;
      tcp_metrics|tcpmetrics)
        local -a tcpmetrics_cmds=(
          'show:show TCP metrics'
          'delete:delete TCP metrics'
          'flush:flush TCP metrics'
        )
        _describe 'tcp_metrics command' tcpmetrics_cmds
        ;;
      fou)
        local -a fou_cmds=(
          'add:add a FOU receive port'
          'del:delete a FOU receive port'
          'show:show FOU receive ports'
        )
        _describe 'fou command' fou_cmds
        ;;
      sr)
        local -a sr_cmds=(
          'hmac:manage SR HMAC'
          'tunsrc:manage SR tunnel source'
        )
        _describe 'sr command' sr_cmds
        ;;
      xfrm)
        local -a xfrm_cmds=(
          'state:manage xfrm states'
          'policy:manage xfrm policies'
          'monitor:monitor xfrm events'
        )
        _describe 'xfrm command' xfrm_cmds
        ;;
      ila)
        local -a ila_cmds=(
          'add:add an ILA mapping'
          'del:delete an ILA mapping'
          'list:list ILA mappings'
        )
        _describe 'ila command' ila_cmds
        ;;
      ioam)
        local -a ioam_cmds=(
          'namespace:manage IOAM namespaces'
          'schema:manage IOAM schemas'
        )
        _describe 'ioam command' ioam_cmds
        ;;
      *)
        _default
        ;;
    esac
    ;;
esac
