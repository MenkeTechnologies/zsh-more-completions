#compdef mosh

# Zsh completion for mosh (mobile shell)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--client=[path to client helper]:client binary:_files' \
  '--server=[command to run server helper]:server command:' \
  '--predict=[controls speculative local echo]:predict mode:(adaptive always never experimental)' \
  '--family=[address family]:address family:(inet inet6 auto prefer-inet prefer-inet6)' \
  '-a[synonym for --predict=adaptive]' \
  '-n[synonym for --predict=never]' \
  '-4[use IPv4 only]' \
  '-6[use IPv6 only]' \
  '-p[server-side UDP port or range]:port or range:' \
  '--port=[server-side UDP port or range]:port or range:' \
  '--bind-server=[ask the server to reply from a specific IP address]:bind mode:(ssh any IP)' \
  '--ssh=[SSH command to use]:ssh command:' \
  '--no-ssh-pty[do not allocate a pseudo-tty on the SSH connection]' \
  '--no-init[do not send terminal initialization string]' \
  '--local[run mosh-server locally without SSH]' \
  '--experimental-remote-ip=[method for discovering remote IP]:method:(local remote proxy)' \
  '--help[display help message]' \
  '--version[display version information]' \
  '1:remote host:_hosts' \
  '*:command:' && ret=0

return ret
