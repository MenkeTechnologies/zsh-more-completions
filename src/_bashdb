#compdef bashdb

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[print this help]'
  {-q,--quiet}'[do not print introductory and quiet messages]'
  {-A,--annotate}'[set the annotation level]:level:'
  {-B,--basename}'[show basename only on source file listings]'
  '--highlight[use dark or light background ANSI terminal sequence]:highlight:(dark light)'
  '--no-highlight[do not use ANSI terminal sequences for syntax]'
  '--init-file[source script file, similar to bash]:file:_files'
  {-L,--library}'[set the directory location of library helper file]:directory:_files -/'
  {-c,--command}'[run STRING instead of a script file]:string:'
  {-n,--nx,--no-init}'[dont run initialization files]'
  {-S,--style}'[use pygments STYLE for formatting source code]:style:'
  {--tty,--terminal}'[set terminal for debugger output]:device:_files'
  {-T,--tempdir}'[use DIRECTORY to store temporary files]:directory:_files -/'
  {-V,--version}'[print the debugger version number]'
  {-X,--trace}'[set line tracing similar to set -x]'
  {-x,--eval-command}'[execute debugger commands from CMDFILE]:cmdfile:_files'
  '*:filename:_files'
)

_arguments -s -S $arguments
