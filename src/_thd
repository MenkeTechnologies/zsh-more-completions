#compdef thd

local -a arguments

arguments=(
  '--help[display this help message]'
  '--daemon[run as daemon process]'
  '--dump[dump events to console]'
  '--listevents[print a list of all known events]'
  '--triggers[load trigger definitions from file]:file:_files'
  '--socket[read commands from socket]:socket:_files'
  '--ignore[ignore key events with name]:event:'
  '--user[drop privileges to name after opening devices]:user:_users'
  '*:filename:_files'
)

_arguments -s -S $arguments
