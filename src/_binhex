#compdef binhex

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[display this usage statement and exit]'
  {-V,--version}'[display version of binhex]'
  {-v,--verbose}'[display verbose output]'
  {-R,--no-runlength-encoding}'[dont generate compressed BinHex file]'
  {-s,--suffix}'[suffix to use instead of hqx]:suffix:'
  {-p,--pipe,--stdout}'[pipe encoded output to standard output]'
  {-C,--directory}'[save encoded file in specified directory]:directory:_files -/'
  {-o,--rename}'[specify name for output file]:name:'
  {-n,--overwrite}'[overwrite output file if it exists]'
  '*:filename:_files'
)

_arguments -s -S $arguments
