#compdef dagger

# Zsh completion for Dagger - programmable CI/CD engine

local curcontext="$curcontext" state line ret=1

local -a global_flags=(
  '--debug[Enable debug logging]'
  '--silent[Disable terminal UI and progress output]'
  '--progress[Progress output mode]:mode:(auto plain tty)'
  '--workdir[Set the working directory]:directory:_files -/'
  '--help[Show help]'
)

local -a commands=(
  'call:Call a module function'
  'functions:List available functions'
  'init:Initialize a new Dagger module'
  'install:Install a Dagger module'
  'develop:Setup or update a Dagger module for local development'
  'query:Send API query'
  'run:Run a command in a Dagger session'
  'login:Login to Dagger Cloud'
  'logout:Logout from Dagger Cloud'
  'version:Print Dagger version'
  'config:Get or set module configuration'
  'shell:Open an interactive shell'
  'watch:Watch builds'
)

_arguments -s -S -C \
  $global_flags \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'dagger command' commands && ret=0
    ;;
  args)
    case $words[1] in
      call)
        _arguments -s -S \
          $global_flags \
          '--json[Output result as JSON]' \
          '(-m --mod)'{-m,--mod}'[Path to module]:module path:_files -/' \
          '--focus[Only show output for focused commands]' \
          '(-o --output)'{-o,--output}'[Save output to file]:output file:_files' \
          '*:function and args' && ret=0
        ;;
      functions)
        _arguments -s -S \
          $global_flags \
          '(-m --mod)'{-m,--mod}'[Path to module]:module path:_files -/' && ret=0
        ;;
      init)
        _arguments -s -S \
          $global_flags \
          '--sdk[SDK to use for the module]:sdk:(go python typescript)' \
          '--name[Name of the module]:name' \
          '--source[Directory to store module source code]:directory:_files -/' && ret=0
        ;;
      install)
        _arguments -s -S \
          $global_flags \
          '(-m --mod)'{-m,--mod}'[Path to module]:module path:_files -/' \
          '--name[Name to use for the dependency]:name' \
          ':module reference' && ret=0
        ;;
      develop)
        _arguments -s -S \
          $global_flags \
          '(-m --mod)'{-m,--mod}'[Path to module]:module path:_files -/' \
          '--sdk[SDK to use]:sdk:(go python typescript)' \
          '--source[Directory for module source code]:directory:_files -/' && ret=0
        ;;
      query)
        _arguments -s -S \
          $global_flags \
          '(-m --mod)'{-m,--mod}'[Path to module]:module path:_files -/' \
          '--doc[Document string]:query' \
          '--var[Variable values (key=value)]:var' \
          '*:query' && ret=0
        ;;
      run)
        _arguments -s -S \
          $global_flags \
          '--cleanup[Run cleanup on exit]' \
          '--focus[Only show output for focused commands]' \
          '*:command:_command_names -e' && ret=0
        ;;
      login)
        _arguments -s -S \
          $global_flags \
          ':organization' && ret=0
        ;;
      config)
        _arguments -s -S \
          $global_flags \
          '(-m --mod)'{-m,--mod}'[Path to module]:module path:_files -/' && ret=0
        ;;
      version)
        _arguments -s -S \
          $global_flags && ret=0
        ;;
    esac
    ;;
esac

return ret
