#compdef wg

# Zsh completion for WireGuard (wg)

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'show:show current configuration and device information'
  'showconf:show current configuration for a WireGuard interface'
  'set:change current configuration'
  'setconf:apply a configuration file to a WireGuard interface'
  'addconf:append a configuration file to a WireGuard interface'
  'syncconf:synchronize a configuration file to a WireGuard interface'
  'genkey:generate a new private key'
  'genpsk:generate a new preshared key'
  'pubkey:calculate the public key from a private key'
  'strip:strip comments and unnecessary whitespace from a configuration file'
)

local -a interfaces
interfaces=( ${(f)"$(command wg show interfaces 2>/dev/null)"} )

_arguments -s -S \
  '1:subcommand:->subcmd' \
  '*::args:->args' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'wg subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (show)
        _arguments \
          '1:interface:(all ${interfaces})' \
          '2:field:(public-key private-key listen-port fwmark peers preshared-keys endpoints allowed-ips latest-handshakes transfer persistent-keepalive dump)' && ret=0
        ;;
      (showconf|syncconf|setconf|addconf)
        _arguments \
          '1:interface:(${interfaces})' \
          '2:config file:_files -g "*.conf"' && ret=0
        ;;
      (set)
        _arguments \
          '1:interface:(${interfaces})' \
          '--listen-port[set listening port]:port:' \
          '--fwmark[set fwmark]:fwmark:' \
          '--private-key[set private key]:key file:_files' \
          '--peer[specify peer public key]:public key:' \
          '--remove[remove specified peer]' \
          '--preshared-key[set preshared key]:key file:_files' \
          '--endpoint[set peer endpoint]:endpoint (host\:port):' \
          '--persistent-keepalive[set keepalive interval]:seconds:' \
          '--allowed-ips[set allowed IP addresses]:CIDR list:' && ret=0
        ;;
      (genkey|genpsk|pubkey)
        ;;
      (strip)
        _arguments '1:config file:_files -g "*.conf"' && ret=0
        ;;
    esac
    ;;
esac

return ret
