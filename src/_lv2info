#compdef lv2info
# Documentation: https://man.archlinux.org/search?q=lv2info
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '-p[Write Turtle description of plugin to FILE.]:FILE'
    '-m[Add record of plugin to manifest FILE.]:FILE'
    '--help[Display help and exit.]'
    '--version[Display version information and exit.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
