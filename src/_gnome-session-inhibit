#compdef gnome-session-inhibit
# Documentation: https://man.archlinux.org/search?q=gnome-session-inhibit
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help]'
  '--version[show program version]'
  '--app-id[the application id to use]'
  '--reason[the reason for inhibiting (optional)]'
  '--inhibit[things to inhibit, colon-separated list]'
  '--inhibit-only[do not launch COMMAND and wait forever instead]'
  '*:filename:_files'
)

_arguments -s -S $arguments
