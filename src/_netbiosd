#compdef netbiosd

local -a arguments

arguments=(
  '-help[display help on all flags]'
  '-debug[enable extended debug output]'
  '-dump-packets[dump sent and received NetBIOS packet contents]'
  '-max-refresh[maximum time in seconds between refresh searches]:seconds:'
  '-min-refresh[minimum time in seconds between refresh searches]:seconds:'
  '-stdout[log messages to standard output]'
  '*:filename:_files'
)

_arguments -s -S $arguments
