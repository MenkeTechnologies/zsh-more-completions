#compdef pg_versions
# Documentation: https://man.archlinux.org/search?q=pg_versions
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-q[be quiet, dont print errors.]'
  '-v[be verbose.]'
  {-h,--help}'[show this message and exit.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
