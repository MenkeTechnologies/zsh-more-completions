#compdef restic

# Zsh completion for restic (fast, secure backup program)

_restic() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    local -a global_flags=(
        '(-r --repo)'{-r,--repo}'=[repository to backup to or restore from]:repository:'
        '--repository-file=[file to read the repository location from]:file:_files'
        '(-p --password-file)'{-p,--password-file}'=[file to read the repository password from]:password file:_files'
        '--password-command=[specify a shell command to obtain the repository password]:command:'
        '--key-hint=[key ID of key to try decrypting first]:key ID:'
        '--cache-dir=[set the cache directory]:directory:_directories'
        '--cleanup-cache[remove old cache directories]'
        '--no-cache[do not use a local cache]'
        '--no-lock[do not lock the repository]'
        '--json[set output mode to JSON]'
        '(-q --quiet)'{-q,--quiet}'[do not output comprehensive progress report]'
        '(-v --verbose)'{-v,--verbose}'[be verbose (specify multiple times for more verbosity)]'
        '--limit-download=[limit download rate in KiB/s]:rate:'
        '--limit-upload=[limit upload rate in KiB/s]:rate:'
        '--tls-client-cert=[path to TLS client certificate and key]:cert file:_files'
    )

    local -a commands=(
        'backup:create a new backup of files and/or directories'
        'cache:operate on local cache directories'
        'cat:print internal objects to stdout'
        'check:check the repository for errors'
        'copy:copy snapshots from one repository to another'
        'diff:show differences between two snapshots'
        'dump:print a backed-up file to stdout'
        'find:find a file, directory or restic ID'
        'forget:remove snapshots from the repository'
        'generate:generate manual pages and auto-completion files'
        'init:initialize a new repository'
        'key:manage keys (passwords)'
        'list:list objects in the repository'
        'ls:list files in a snapshot'
        'migrate:apply migrations'
        'mount:mount the repository'
        'prune:remove unneeded data from the repository'
        'rebuild-index:build a new index'
        'recover:recover data from the repository not referenced by snapshots'
        'repair:repair the repository'
        'restore:extract the data from a snapshot'
        'rewrite:rewrite snapshots to exclude unwanted files'
        'self-update:update the restic binary'
        'snapshots:list all snapshots'
        'stats:scan the repository and show basic statistics'
        'tag:modify tags on snapshots'
        'unlock:remove locks other processes created'
        'version:print version information'
    )

    _arguments -C \
        $global_flags \
        '(- *)'{-h,--help}'[help for restic]' \
        '1:command:->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'restic command' commands
            ;;
        args)
            case $words[1] in
                backup)
                    _arguments -s -S \
                        $global_flags \
                        '*'{-e,--exclude}'=[exclude a pattern]:pattern:' \
                        '--exclude-caches[excludes cache directories]' \
                        '*--exclude-file=[read exclude patterns from a file]:file:_files' \
                        '*--exclude-if-present=[exclude contents of directories containing a file]:filename:' \
                        '--exclude-larger-than=[max size of file to be backed up]:size:' \
                        '--files-from=[read the files to back up from file]:file:_files' \
                        '--files-from-raw=[read the files to back up from file (no splitting)]:file:_files' \
                        '--files-from-verbatim=[read the files to back up from file (no processing)]:file:_files' \
                        '(-f --force)'{-f,--force}'[force re-reading the target files/directories]' \
                        '--host=[set the hostname for the snapshot]:hostname:_hosts' \
                        '*--iexclude=[exclude a pattern (case-insensitive)]:pattern:' \
                        '*--iexclude-file=[read case-insensitive exclude patterns from file]:file:_files' \
                        '--ignore-ctime[ignore ctime changes when checking for modified files]' \
                        '--ignore-inode[ignore inode number changes when checking for modified files]' \
                        '(-x --one-file-system)'{-x,--one-file-system}'[exclude other file systems]' \
                        '--parent=[use this parent snapshot]:snapshot ID:' \
                        '--stdin[read backup from stdin]' \
                        '--stdin-filename=[filename to use when reading from stdin]:name:' \
                        '*--tag=[add a tag for the new snapshot]:tag:' \
                        '--time=[time of the backup]:time:' \
                        '--with-atime[store the atime for all files and directories]' \
                        '(-n --dry-run)'{-n,--dry-run}'[do not back up, just print what would be done]' \
                        '*:file or directory:_files'
                    ;;
                cache)
                    _arguments -s -S \
                        $global_flags \
                        '--cleanup[remove old cache directories]' \
                        '--max-age=[max age in days for cache directories]:days:' \
                        '--no-size[do not output the size of the cache directories]'
                    ;;
                cat)
                    _arguments -s -S \
                        $global_flags \
                        '1:type:(config index snapshot key masterkey lock pack blob tree)' \
                        '2:ID:'
                    ;;
                check)
                    _arguments -s -S \
                        $global_flags \
                        '--read-data[read all data blobs]' \
                        '--read-data-subset=[read a subset of data packs]:subset:' \
                        '--with-cache[use existing cache, only read uncached data from repository]'
                    ;;
                copy)
                    _arguments -s -S \
                        $global_flags \
                        '--from-key-hint=[key ID of key to decrypt source repository]:key ID:' \
                        '--from-password-command=[command to obtain source repository password]:command:' \
                        '--from-password-file=[file with source repository password]:file:_files' \
                        '--from-repo=[source repository]:repository:' \
                        '--from-repository-file=[file from which to read source repository location]:file:_files' \
                        '*--host=[only consider snapshots for this host]:hostname:_hosts' \
                        '*--tag=[only consider snapshots with this tag]:tag:' \
                        '*:snapshot ID:'
                    ;;
                diff)
                    _arguments -s -S \
                        $global_flags \
                        '--metadata[print changes in metadata]' \
                        '1:snapshot ID:' \
                        '2:snapshot ID:'
                    ;;
                dump)
                    _arguments -s -S \
                        $global_flags \
                        '--archive=[set archive format]:format:(tar zip)' \
                        '*--host=[only consider snapshots for this host]:hostname:_hosts' \
                        '*--tag=[only consider snapshots with this tag]:tag:' \
                        '1:snapshot ID:' \
                        '2:file:'
                    ;;
                find)
                    _arguments -s -S \
                        $global_flags \
                        '*--host=[only consider snapshots for this host]:hostname:_hosts' \
                        '-i[ignore case]' \
                        '-l[long listing]' \
                        '-N[newest only]' \
                        '--pack[also search in packs]' \
                        '--path=[only consider snapshots with this path]:path:' \
                        '--show-pack-id[display the pack ID the blob belongs to]' \
                        '*--tag=[only consider snapshots with this tag]:tag:' \
                        '--tree-blob[also search in tree blobs]' \
                        '*:pattern:'
                    ;;
                forget)
                    _arguments -s -S \
                        $global_flags \
                        '-l --keep-last=[keep the last n snapshots]:number:' \
                        '-H --keep-hourly=[keep the last n hourly snapshots]:number:' \
                        '-d --keep-daily=[keep the last n daily snapshots]:number:' \
                        '-w --keep-weekly=[keep the last n weekly snapshots]:number:' \
                        '-m --keep-monthly=[keep the last n monthly snapshots]:number:' \
                        '-y --keep-yearly=[keep the last n yearly snapshots]:number:' \
                        '--keep-within=[keep snapshots within this duration]:duration:' \
                        '--keep-within-hourly=[keep hourly snapshots within this duration]:duration:' \
                        '--keep-within-daily=[keep daily snapshots within this duration]:duration:' \
                        '--keep-within-weekly=[keep weekly snapshots within this duration]:duration:' \
                        '--keep-within-monthly=[keep monthly snapshots within this duration]:duration:' \
                        '--keep-within-yearly=[keep yearly snapshots within this duration]:duration:' \
                        '*--keep-tag=[keep snapshots with this tag]:tag:' \
                        '*--host=[only consider snapshots for this host]:hostname:_hosts' \
                        '*--tag=[only consider snapshots with this tag]:tag:' \
                        '*--path=[only consider snapshots with this path]:path:_files' \
                        '--compact[use compact output format]' \
                        '--group-by=[group snapshots by host, paths and/or tags]:group:(host paths tags)' \
                        '(-n --dry-run)'{-n,--dry-run}'[do not delete anything, just print what would be done]' \
                        '--prune[automatically run the prune command]' \
                        '*:snapshot ID:'
                    ;;
                generate)
                    _arguments -s -S \
                        $global_flags \
                        '--bash-completion=[write bash completion to file]:file:_files' \
                        '--fish-completion=[write fish completion to file]:file:_files' \
                        '--zsh-completion=[write zsh completion to file]:file:_files' \
                        '--man=[write man pages to directory]:directory:_directories'
                    ;;
                init)
                    _arguments -s -S \
                        $global_flags \
                        '--copy-chunker-params[copy chunker parameters from the secondary repository]' \
                        '--from-key-hint=[key ID of key to decrypt secondary repository]:key ID:' \
                        '--from-password-command=[command to obtain secondary repository password]:command:' \
                        '--from-password-file=[file with secondary repository password]:file:_files' \
                        '--from-repo=[secondary repository to copy parameters from]:repository:' \
                        '--from-repository-file=[file from which to read secondary repository location]:file:_files' \
                        '--repository-version=[repository format version]:version:(1 2)'
                    ;;
                key)
                    local -a key_commands=(
                        'add:add a new key (password) to the repository'
                        'list:list keys for the repository'
                        'passwd:change the password of the repository'
                        'remove:remove a key from the repository'
                    )
                    _arguments -C \
                        $global_flags \
                        '1:key subcommand:->keycmd' \
                        '*::arg:->keyargs'
                    case $state in
                        keycmd)
                            _describe -t key_commands 'key subcommand' key_commands
                            ;;
                        keyargs)
                            case $line[1] in
                                add)
                                    _arguments -s -S \
                                        $global_flags \
                                        '--host=[set the hostname for new key]:hostname:_hosts' \
                                        '--user=[set the username for new key]:username:' \
                                        '--new-password-file=[file from which to read the new password]:file:_files'
                                    ;;
                                remove)
                                    _arguments -s -S \
                                        $global_flags \
                                        '1:key ID:'
                                    ;;
                                list|passwd)
                                    _arguments -s -S $global_flags
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                list)
                    _arguments -s -S \
                        $global_flags \
                        '1:object type:(blobs packs index snapshots keys locks)'
                    ;;
                ls)
                    _arguments -s -S \
                        $global_flags \
                        '-l[use a long listing format]' \
                        '--recursive[include files in sub-directories]' \
                        '*--host=[only consider snapshots for this host]:hostname:_hosts' \
                        '*--tag=[only consider snapshots with this tag]:tag:' \
                        '*--path=[only consider snapshots with this path]:path:_files' \
                        '1:snapshot ID:' \
                        '2:path:'
                    ;;
                migrate)
                    _arguments -s -S \
                        $global_flags \
                        '(-f --force)'{-f,--force}'[apply a migration even if check fails]' \
                        '1:migration name:'
                    ;;
                mount)
                    _arguments -s -S \
                        $global_flags \
                        '--allow-other[allow other users to access the data]' \
                        '--allow-root[allow root to access the data]' \
                        '*--host=[only consider snapshots for this host]:hostname:_hosts' \
                        '--no-default-permissions[do not use kernel to enforce permissions]' \
                        '--owner-root[use root as owner of files]' \
                        '*--path=[only consider snapshots with this path]:path:_files' \
                        '--snapshot-template=[set template for snapshot dir names]:template:' \
                        '*--tag=[only consider snapshots with this tag]:tag:' \
                        '--time-template=[set template for snapshot timestamps]:template:' \
                        '1:mountpoint:_directories'
                    ;;
                prune)
                    _arguments -s -S \
                        $global_flags \
                        '--max-repack-size=[maximum size to repack]:size:' \
                        '--max-unused=[tolerate given limit of unused data]:limit:' \
                        '--repack-cacheable-only[only repack packs which are cached]' \
                        '(-n --dry-run)'{-n,--dry-run}'[do not modify the repository]'
                    ;;
                rebuild-index)
                    _arguments -s -S \
                        $global_flags \
                        '--read-all-packs[read all data packs to regenerate the index]'
                    ;;
                recover)
                    _arguments -s -S $global_flags
                    ;;
                repair)
                    local -a repair_commands=(
                        'index:rebuild the index'
                        'packs:salvage damaged pack files'
                        'snapshots:repair snapshots'
                    )
                    _arguments -C \
                        $global_flags \
                        '1:repair subcommand:->repaircmd' \
                        '*::arg:->repairargs'
                    case $state in
                        repaircmd)
                            _describe -t repair_commands 'repair subcommand' repair_commands
                            ;;
                        repairargs)
                            case $line[1] in
                                snapshots)
                                    _arguments -s -S \
                                        $global_flags \
                                        '--forget[remove damaged snapshots after repair]' \
                                        '*--host=[only consider snapshots for this host]:hostname:_hosts' \
                                        '*--tag=[only consider snapshots with this tag]:tag:' \
                                        '*:snapshot ID:'
                                    ;;
                                index|packs)
                                    _arguments -s -S $global_flags
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                restore)
                    _arguments -s -S \
                        $global_flags \
                        '*'{-e,--exclude}'=[exclude a pattern]:pattern:' \
                        '*--iexclude=[exclude a pattern (case-insensitive)]:pattern:' \
                        '*-i --include=[include a pattern]:pattern:' \
                        '*--iinclude=[include a pattern (case-insensitive)]:pattern:' \
                        '(-t --target)'{-t,--target}'=[directory to extract data to]:directory:_directories' \
                        '--verify[verify restored files content]' \
                        '*--host=[only consider snapshots for this host]:hostname:_hosts' \
                        '*--tag=[only consider snapshots with this tag]:tag:' \
                        '*--path=[only consider snapshots with this path]:path:_files' \
                        '1:snapshot ID:'
                    ;;
                rewrite)
                    _arguments -s -S \
                        $global_flags \
                        '*--exclude=[exclude a pattern]:pattern:' \
                        '*--iexclude=[exclude a pattern (case-insensitive)]:pattern:' \
                        '--exclude-file=[read exclude patterns from file]:file:_files' \
                        '--iexclude-file=[read case-insensitive exclude patterns from file]:file:_files' \
                        '(-n --dry-run)'{-n,--dry-run}'[do not modify the repository]' \
                        '--forget[remove rewritten snapshots]' \
                        '*--host=[only consider snapshots for this host]:hostname:_hosts' \
                        '*--tag=[only consider snapshots with this tag]:tag:' \
                        '*:snapshot ID:'
                    ;;
                self-update)
                    _arguments -s -S \
                        $global_flags \
                        '--output=[save the downloaded file as]:file:_files'
                    ;;
                snapshots)
                    _arguments -s -S \
                        $global_flags \
                        '--compact[use compact output format]' \
                        '--group-by=[group snapshots by host, paths and/or tags]:group:(host paths tags)' \
                        '*--host=[only consider snapshots for this host]:hostname:_hosts' \
                        '--latest=[only show the last n snapshots]:number:' \
                        '*--path=[only consider snapshots with this path]:path:_files' \
                        '*--tag=[only consider snapshots with this tag]:tag:' \
                        '*:snapshot ID:'
                    ;;
                stats)
                    _arguments -s -S \
                        $global_flags \
                        '--mode=[counting mode]:mode:(restore-size files-by-contents raw-data)' \
                        '*--host=[only consider snapshots for this host]:hostname:_hosts' \
                        '*--tag=[only consider snapshots with this tag]:tag:' \
                        '*--path=[only consider snapshots with this path]:path:_files' \
                        '*:snapshot ID:'
                    ;;
                tag)
                    _arguments -s -S \
                        $global_flags \
                        '*--add=[tags to add]:tag:' \
                        '*--remove=[tags to remove]:tag:' \
                        '--set=[tags to set (replaces existing)]:tag:' \
                        '*--host=[only consider snapshots for this host]:hostname:_hosts' \
                        '*--tag=[only consider snapshots with this tag]:tag:' \
                        '*--path=[only consider snapshots with this path]:path:_files' \
                        '*:snapshot ID:'
                    ;;
                unlock)
                    _arguments -s -S \
                        $global_flags \
                        '--remove-all[remove all locks, even non-stale ones]'
                    ;;
                version)
                    _arguments -s -S $global_flags
                    ;;
            esac
            ;;
    esac
}

_restic "$@"
