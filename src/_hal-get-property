#compdef hal-get-property
# Documentation: https://man.archlinux.org/search?q=hal-get-property
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--udi[unique Device Id]'
  '--key[key of the property to get]'
  '--hex[show integer values in hex (without leading 0x)]'
  '--verbose[be verbose]'
  '--version[show version and exit]'
  '--help[show this information and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
