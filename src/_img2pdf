#compdef img2pdf
# Zsh completion for img2pdf
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-o --output)'{-o,--output}'[output PDF file]:file:_files -g "*.pdf"' \
  '--pagesize[page size]:size:' \
  '--imgsize[image size]:size:' \
  '--border[border size]:size:' \
  '--fit[image fit mode]:mode:(into fill exact shrink)' \
  '--rotation[image rotation]:rotation:(auto none ifvalid 0 90 180 270)' \
  '--auto-orient[auto-orient based on EXIF]' \
  '--engine[PDF engine]:engine:(internal pikepdf pdfrw)' \
  '--first-frame-only[only use first frame of multi-frame images]' \
  '--pillow-limit-break[bypass Pillow image size limit]' \
  '--title[PDF title]:text:' \
  '--author[PDF author]:text:' \
  '--creator[PDF creator]:text:' \
  '--producer[PDF producer]:text:' \
  '--creationdate[PDF creation date]:date:' \
  '--moddate[PDF modification date]:date:' \
  '--subject[PDF subject]:text:' \
  '--keywords[PDF keywords]:text:' \
  '--viewer-panes[viewer pane mode]:panes:(thumbs outlines attachments)' \
  '--viewer-initial-page[viewer initial page number]:N:' \
  '--viewer-magnification[viewer magnification]:magnification:(fit width custom)' \
  '--viewer-page-layout[viewer page layout]:layout:(single onecolumn twocolumnright twocolumnleft)' \
  '--viewer-fit-window[fit viewer window to page]' \
  '--viewer-center-window[center viewer window]' \
  '--viewer-fullscreen[open in fullscreen mode]' \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)--version[show version]' \
  '*:image file:_files -g "*.{jpg,jpeg,png,gif,tiff,tif,bmp,webp}"' && ret=0
return ret
