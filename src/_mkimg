#compdef mkimg

local -a arguments

arguments=(
  '--formats[ list image formats]'
  '--schemes[ list partition schemes]'
  '--version[ show version information]'
  '-a[ mark numth partion as active]'
  '-b[ file containing boot code]'
  '-c[ minimum capacity (in bytes) of the disk]'
  '-C[ maximum capacity (in bytes) of the disk]'
  '-f[specify output format]:format: '
  '-o[file to write image into]:file:_files'
  '-p[add partition specification]:partition spec: '
  '-s[specify partition scheme]:scheme: '
  '-v[ increase verbosity]'
  '-y[ \[developers\] enable unit test]'
  '-H[ number of heads to simulate]'
  '-P[ physical sector size]'
  '-S[ logical sector size]'
  '-T[ number of tracks to simulate]'
  '*:filename:_files'
)

_arguments -s -S $arguments
