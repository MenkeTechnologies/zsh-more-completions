#compdef ansible-lint
# Zsh completion for ansible-lint
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-L --list-rules)'{-L,--list-rules}'[list all available rules]' \
  '(-l --list-tags)'{-l,--list-tags}'[list all available tags]' \
  '(-p --parseable)'{-p,--parseable}'[use parseable output format]' \
  '(-q --quiet)'{-q,--quiet}'[quieter output]' \
  '--force-color[force colored output]' \
  '--nocolor[disable colored output]' \
  '(-f --format)'{-f,--format}'[output format]:format:(brief full md json codeclimate quiet pep8 sarif)' \
  '--sarif-file[SARIF output file]:file:_files' \
  '--progressive[progressively increase strictness]' \
  '(-c --config)'{-c,--config}'[config file]:file:_files' \
  '--project-dir[project directory]:dir:_directories' \
  '(-x --skip-list)'{-x,--skip-list}'[rules to skip]:rules:' \
  '(-w --warn-list)'{-w,--warn-list}'[rules to warn about]:rules:' \
  '--enable-list[rules to enable]:rules:' \
  '(-R --rulesdir)'{-R,--rulesdir}'[custom rules directory]:dir:_directories' \
  '--offline[run without internet access]' \
  '--profile[specify named profile]:profile:(min basic moderate safety shared production)' \
  '(-s --strict)'{-s,--strict}'[treat warnings as errors]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(- *)--version[show version]' \
  '(- *)'{-h,--help}'[show help message]' \
  '--fix[auto-fix rule violations]' \
  '--generate-ignore[generate ignore file]' \
  '--ignore-file[ignore file path]:file:_files' \
  '*--exclude[paths to exclude]:paths:_files' \
  '--write[write fixes]:mode:' \
  '*:playbook or role:_files' && ret=0
return ret
