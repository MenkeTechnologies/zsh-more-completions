#compdef chartex
# Documentation: https://man.archlinux.org/search?q=chartex
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '--cR[This sets the root name for the extracted charts, defaults to \\*(L"chart\\*(R".]'
    '--hR[Print a brief help message and exits.]'
    '*:filename:_files'
)
_arguments -s -S $arguments
