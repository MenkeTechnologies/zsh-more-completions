#compdef bccmd
# Documentation: https://man.archlinux.org/search?q=bccmd
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-t[select the transport]:transport:'
  '-d[select the device]:device:'
  '-b[select the bcsp transfer rate]:rate:'
  '(- * :)'{-h,--help}'[display help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
