#compdef geteltorito
# Documentation: https://man.archlinux.org/search?q=geteltorito
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-h[This help.]'
  '-v[Print version of script and exit.]'
  '-o[write extracted data to file <file> instead of STDOUT.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
