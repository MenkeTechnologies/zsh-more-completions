#compdef mise

# Zsh completion for mise (dev tool version manager, formerly rtx)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-C+[Change directory before running command]:dir:_directories' \
  '--cd=[Change directory before running command]:dir:_directories' \
  '-q[Suppress non-error messages]' \
  '--quiet[Suppress non-error messages]' \
  '-v[Show extra output]' \
  '--verbose[Show extra output]' \
  '-y[Answer yes to all confirmation prompts]' \
  '--yes[Answer yes to all confirmation prompts]' \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'activate:Initializes mise in the current shell session'
      'alias:Manage aliases'
      'a:Manage aliases'
      'backends:Manage backends'
      'b:Manage backends'
      'bin-paths:List all the active runtime bin paths'
      'cache:Manage the mise cache'
      'completion:Generate shell completions'
      'config:Manage config files'
      'cfg:Manage config files'
      'current:Shows current active and installed runtime versions'
      'c:Shows current active and installed runtime versions'
      'deactivate:Disable mise for current shell session'
      'direnv:Output direnv function to use mise inside direnv'
      'doctor:Check mise installation for potential problems'
      'dr:Check mise installation for potential problems'
      'env:Exports env vars to activate mise a single time'
      'e:Exports env vars to activate mise a single time'
      'exec:Execute a command with tool(s) set'
      'x:Execute a command with tool(s) set'
      'generate:Generate files'
      'g:Generate files'
      'global:Sets/gets the global tool version(s)'
      'hook-env:Called when the shell is activated'
      'hook-not-found:Called when a command is not found'
      'implode:Removes mise CLI and all related data'
      'install:Install a tool version'
      'i:Install a tool version'
      'latest:Gets the latest available version for a plugin'
      'link:Symlinks a tool version into mise'
      'ln:Symlinks a tool version into mise'
      'local:Sets/gets the local tool version(s)'
      'l:Sets/gets the local tool version(s)'
      'ls:List installed and active tool versions'
      'ls-remote:List runtime versions available for install'
      'outdated:Shows outdated tool versions'
      'plugins:Manage plugins'
      'p:Manage plugins'
      'prune:Delete unused versions of tools'
      'registry:List available tools to install'
      'r:List available tools to install'
      'reshim:Rebuilds the shim farm'
      'run:Run task(s)'
      'self-update:Updates mise itself'
      'set:Set environment variables in mise.toml'
      'settings:Manage settings'
      'shell:Sets a tool version for the current session'
      's:Sets a tool version for the current session'
      'sync:Sync mise state with external tools'
      'tasks:Manage tasks'
      't:Manage tasks'
      'trust:Marks a config file as trusted'
      'uninstall:Removes installed tool versions'
      'un:Removes installed tool versions'
      'unset:Remove environment variables from mise.toml'
      'upgrade:Upgrades outdated tools'
      'up:Upgrades outdated tools'
      'usage:Generate a usage CLI spec'
      'use:Install and set tool version(s) in mise.toml'
      'u:Install and set tool version(s) in mise.toml'
      'version:Display the version of mise'
      'v:Display the version of mise'
      'watch:Run task(s) and re-run on file changes'
      'w:Run task(s) and re-run on file changes'
      'where:Display the installation path for a runtime'
      'which:Shows the path that a tool\x27s bin points to'
    )
    _describe -t commands 'mise command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      install|i)
        _arguments -s -S \
          '-f[Force reinstall even if already installed]' \
          '--force[Force reinstall even if already installed]' \
          '-j+[Number of jobs to run in parallel]:jobs' \
          '--jobs=[Number of jobs to run in parallel]:jobs' \
          '--raw[Directly pipe stdin/stdout/stderr]' \
          '-v[Show installation output]' \
          '--verbose[Show installation output]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:tool@version' && ret=0
        ;;
      use|u)
        _arguments -s -S \
          '-f[Force reinstall even if already installed]' \
          '--force[Force reinstall even if already installed]' \
          '--fuzzy[Save fuzzy version to config file]' \
          '-g[Use the global config file]' \
          '--global[Use the global config file]' \
          '-e+[Modify an environment-specific config file]:env' \
          '--env=[Modify an environment-specific config file]:env' \
          '-j+[Number of jobs to run in parallel]:jobs' \
          '--jobs=[Number of jobs to run in parallel]:jobs' \
          '--raw[Directly pipe stdin/stdout/stderr]' \
          '--remove=[Remove the plugin(s) from config file]:tool' \
          '-p+[Specify a path to a config file]:path:_files' \
          '--path=[Specify a path to a config file]:path:_files' \
          '--pin[Save exact version to config file]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:tool@version' && ret=0
        ;;
      exec|x)
        _arguments -s -S \
          '-c+[Command to execute]:command' \
          '--command=[Command to execute]:command' \
          '-j+[Number of jobs to run in parallel]:jobs' \
          '--jobs=[Number of jobs to run in parallel]:jobs' \
          '--raw[Directly pipe stdin/stdout/stderr]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:tool@version' && ret=0
        ;;
      env|e)
        _arguments -s -S \
          '-J[Output in JSON format]' \
          '--json[Output in JSON format]' \
          '-s+[Shell type to generate for]:shell:(bash fish nu xonsh zsh)' \
          '--shell=[Shell type to generate for]:shell:(bash fish nu xonsh zsh)' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:tool@version' && ret=0
        ;;
      ls)
        _arguments -s -S \
          '-c[Only show tool versions currently in use]' \
          '--current[Only show tool versions currently in use]' \
          '-g[Only show tool versions from the global config]' \
          '--global[Only show tool versions from the global config]' \
          '-i[Only show tool versions that are installed]' \
          '--installed[Only show tool versions that are installed]' \
          '-m[Only show tool versions that are missing]' \
          '--missing[Only show tool versions that are missing]' \
          '-J[Output in JSON format]' \
          '--json[Output in JSON format]' \
          '--prefix=[Display versions matching this prefix]:prefix' \
          '--no-header[Do not print table header]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:plugin' && ret=0
        ;;
      uninstall|un)
        _arguments -s -S \
          '-a[Delete all installed versions]' \
          '--all[Delete all installed versions]' \
          '-n[Do not actually delete anything]' \
          '--dry-run[Do not actually delete anything]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:tool@version' && ret=0
        ;;
      plugins|p)
        local -a subcmds=(
          'install:Install a plugin'
          'i:Install a plugin'
          'link:Symlinks a plugin into mise'
          'ln:Symlinks a plugin into mise'
          'ls:List installed plugins'
          'ls-remote:List all available remote plugins'
          'uninstall:Removes a plugin'
          'un:Removes a plugin'
          'update:Updates a plugin to the latest version'
          'up:Updates a plugin to the latest version'
        )
        _describe -t subcmds 'plugins subcommand' subcmds && ret=0
        ;;
      run)
        _arguments -s -S \
          '-n[Do not actually run the task(s)]' \
          '--dry-run[Do not actually run the task(s)]' \
          '-f[Force the task to run]' \
          '--force[Force the task to run]' \
          '-p[Print stdout/stderr by line]' \
          '--prefix[Print stdout/stderr by line]' \
          '-i[Run tasks interactively]' \
          '--interleave[Run tasks interactively]' \
          '-t+[Tool to run task in]:tool' \
          '--tool=[Tool to run task in]:tool' \
          '-j+[Number of tasks to run in parallel]:jobs' \
          '--jobs=[Number of tasks to run in parallel]:jobs' \
          '--raw[Read/write from stdin/stdout/stderr]' \
          '--timings[Show elapsed time after completion]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:task' && ret=0
        ;;
      settings)
        local -a subcmds=(
          'add:Add a value to a list setting'
          'get:Show a current setting'
          'ls:Show current settings'
          'set:Add/update a setting'
          'unset:Clears a setting'
        )
        _describe -t subcmds 'settings subcommand' subcmds && ret=0
        ;;
      tasks|t)
        local -a subcmds=(
          'deps:Display a tree visualization of task dependencies'
          'edit:Edit a tasks with $EDITOR'
          'info:Get information about a task'
          'ls:List available tasks to execute'
          'run:Run task(s)'
        )
        _describe -t subcmds 'tasks subcommand' subcmds && ret=0
        ;;
      activate)
        _arguments -s -S \
          '-s+[Shell type]:shell:(bash fish nu xonsh zsh)' \
          '--shims[Use shims instead of PATH modification]' \
          '--quiet[Suppress output]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:shell:(bash fish nu xonsh zsh)' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '-s+[Shell type]:shell:(bash fish zsh)' \
          '--shell=[Shell type]:shell:(bash fish zsh)' \
          '--usage[Output a usage spec]' \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
      trust)
        _arguments -s -S \
          '-a[Trust all config files in the current directory and its parents]' \
          '--all[Trust all config files in the current directory and its parents]' \
          '--untrust[No longer trust this config]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:config file:_files' && ret=0
        ;;
      watch|w)
        _arguments -s -S \
          '-t+[Tasks to run]:task' \
          '--task=[Tasks to run]:task' \
          '-g+[Glob pattern to watch]:glob' \
          '--glob=[Glob pattern to watch]:glob' \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:args' && ret=0
        ;;
      self-update)
        _arguments -s -S \
          '-f[Update even if already up to date]' \
          '--force[Update even if already up to date]' \
          '--no-plugins[Disable auto-updating plugins]' \
          '-y[Skip confirmation prompt]' \
          '--yes[Skip confirmation prompt]' \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:version' && ret=0
        ;;
    esac
    ;;
esac

return ret
