#compdef tunctl
# Documentation: https://man.archlinux.org/search?q=tunctl
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-f[TUN device (default /dev/net/tun)]'
  '-t[create iface (default: tapN)]'
  '-d[delete iface]'
  '-u[set iface owner]'
  '-g[set iface group]'
  '-b[brief output]'
  '*:filename:_files'
)

_arguments -s -S $arguments
