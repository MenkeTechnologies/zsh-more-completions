#compdef hcxpioff

local -a arguments

arguments=(
  '-h[show this help]'
  '-v[show version]'
  '--gpio_button=[<digit> : Raspberry Pi GPIO pin number of button (2...27)]'
  '--gpio_statusled=[<digit> : Raspberry Pi GPIO number of status LED (2...27)]'
  '--help[show this help]'
  '--version[show version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
