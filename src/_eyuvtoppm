#compdef eyuvtoppm
# Documentation: https://man.archlinux.org/search?q=eyuvtoppm
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '--width[Width of the image, in pixels. Must be an even number.]:width'
    '--height[Height of the image, in pixels. Must be an even number.]:height'
    '*:filename:_files'
)
_arguments -s -S $arguments
