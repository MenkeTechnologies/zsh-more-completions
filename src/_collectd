#compdef collectd
# Documentation: https://man.archlinux.org/search?q=collectd
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-C[configuration file.]'
  '-t[test config and exit.]'
  '-T[test plugin read and exit.]'
  '-P[PID-file.]'
  '-f[dont fork to the background.]'
  '-B[dont create the BaseDir]'
  '-h[display help (this message)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
