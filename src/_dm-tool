#compdef dm-tool
# Documentation: https://man.archlinux.org/search?q=dm-tool
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  {-v,--version}'[show release version]'
  '--session-bus[use session D-Bus]'
  '*:filename:_files'
)

_arguments -s -S $arguments
