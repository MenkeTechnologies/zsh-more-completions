#compdef lsofng

local arguments

arguments=(
  '-a[AND selections (default: OR)]'
  '-b[avoid kernel blocks]'
  '-c[select by command name (prefix, ^exclude, /regex/)]:command name:'
  '+c[set COMMAND column width (default: 9)]:width:'
  '-d[select by file descriptor set]:fd set:'
  '+d[list open files in DIR]:directory:_files -/'
  '+D[recursively list open files in DIR (slow)]:directory:_files -/'
  '+f[filesystem names]'
  '-f[file names]'
  '-F[select output fields; -F ? for help]:fields:'
  '-g[exclude(^) or select process group IDs]:PGID:'
  '-h[display help]'
  '-i[select IPv4/6 files]:address:'
  '-l[display UID numbers instead of login names]'
  '+L[list link counts]:count:'
  '-L[suppress link counts]'
  '+M[enable portmap registration]'
  '-M[disable portmap registration]'
  '-n[inhibit host name resolution]'
  '-N[select NFS files]'
  '-o[display file offset]:digits:'
  '-O[avoid overhead of extra processing (risky)]'
  '-p[select by PID (comma-separated, ^excludes)]:PID:'
  '-P[inhibit port number to name conversion]'
  '+r[repeat mode until no files]:seconds:'
  '-r[repeat mode forever]:seconds:'
  '-R[list parent PID]'
  '-s[exclude(^) or select protocol states by name]:proto\:state:'
  '-S[stat(2) timeout (default: 15)]:seconds:'
  '-t[terse output (PID only)]'
  '-T[disable or select TCP/TPI info]:level:'
  '-u[select by login name or UID (comma-separated, ^excludes)]:user:'
  '-U[select UNIX domain socket files]'
  '-v[display version information]'
  '-V[verbose search]'
  '+w[enable warnings]'
  '-w[suppress warnings]'
  '-x[cross over +d|+D file systems or symbolic links]:fl:'
  '--[end option processing]'
  '*:filename:_files'
)

_arguments -s $arguments
