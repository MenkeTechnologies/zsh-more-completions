#compdef kdeinit5
# Documentation: https://man.archlinux.org/search?q=kdeinit5
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--no-fork[do not fork]'
  '--kded[start kded]'
  '--suicide[terminate when no KDE applications are left running]'
  '--version[show version information]'
  '*:filename:_files'
)

_arguments -s -S $arguments
