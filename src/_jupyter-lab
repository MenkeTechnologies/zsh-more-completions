#compdef jupyter-lab

local -a arguments

arguments=(
    '--no-browser[Do not open a browser window]'
    '--autoreload[Auto-reload the webapp in debug mode]'
    '--no-autoreload[Do not auto-reload the webapp]'
    '--debug[Set debug level for logging]'
    '--generate-config[Generate default config file]'
    '-y[Answer yes to any prompts]'
    '--allow-root[Allow the server to be run as root]'
    '--ip=[Set the IP address]:ip address'
    '--port=[Set the port]:port number'
    '--port-retries=[Number of port retries]:retries'
    '--keyfile=[SSL key file]:key file:_files'
    '--certfile=[SSL certificate file]:cert file:_files'
    '--client-ca=[SSL client CA file]:ca file:_files'
    '--notebook-dir=[Set the notebook directory]:directory:_directories'
    '--browser=[Browser to use]:browser'
    '--pylab=[Disabled. Use notebook-dir instead]'
    '--config=[Load this config file]:config file:_files'
    '--log-level=[Set log level]:(DEBUG INFO WARN ERROR CRITICAL)'
    '--app-dir=[Application directory]:directory:_directories'
    '--core-mode[Start in core mode]'
    '--dev-mode[Start in dev mode]'
    '--watch[Watch for changes]'
    '--expose-app-in-browser[Expose app in browser]'
    '--extensions-in-dev-mode[Load extensions in dev mode]'
    '--collaborative[Enable collaborative mode]'
    '--ServerApp.token=[Set token for authentication]:token'
    '*:files:_files'
)

_arguments -s -S $arguments
