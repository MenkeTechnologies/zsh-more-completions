#compdef rollup

local -a arguments

arguments=(
  {-c,--config}'[use this config file]:file:_files'
  {-d,--dir}'[directory for chunks (if absent, prints to stdout)]:dir:_directories'
  {-e,--external}'[comma-separated list of module IDs to exclude]:ids: '
  {-f,--format}'[type of output]:format:(amd cjs esm iife umd)'
  {-g,--globals}'[comma-separated list of moduleID\:Global pairs]:globals: '
  '(- * :)'{-h,--help}'[show this help message]'
  {-i,--input}'[input (alternative to <entry file>)]:file:_files'
  {-m,--sourcemap}'[generate sourcemap (-m inline for inline map)]'
  {-n,--name}'[name for UMD export]:name: '
  {-o,--file}'[single output file (if absent, prints to stdout)]:file:_files'
  {-v,--version}'[show version number]'
  {-w,--watch}'[watch files in bundle and rebuild on changes]'
  '--amd.id[ID for AMD module (default is anonymous)]:id: '
  '--amd.define[function to use in place of define]:name: '
  '--assetFileNames[name pattern for emitted assets]:pattern: '
  '--banner[code to insert at top of bundle (outside wrapper)]:code: '
  '--chunkFileNames[name pattern for emitted secondary chunks]:pattern: '
  '--compact[minify wrapper code]'
  '--context[specify top-level this value]:value: '
  '--entryFileNames[name pattern for emitted entry chunks]:pattern: '
  '--environment[settings passed to config file]:settings: '
  '--no-esModule[do not add __esModule property]'
  '--exports[specify export mode]:mode:(auto default named none)'
  '--extend[extend global variable defined by --name]'
  '--footer[code to insert at end of bundle (outside wrapper)]:code: '
  '--no-freeze[do not freeze namespace objects]'
  '--no-indent[dont indent result]'
  '--no-interop[do not include interop block]'
  '--inlineDynamicImports[create single bundle when using dynamic imports]'
  '--intro[code to insert at top of bundle (inside wrapper)]:code: '
  '--namespaceToStringTag[create proper `.toString` methods for namespaces]'
  '--noConflict[generate a noConflict method for UMD globals]'
  '--no-strict[dont emit `"use strict";` in the generated modules]'
  '--outro[code to insert at end of bundle (inside wrapper)]:code: '
  '--preferConst[use `const` instead of `var` for exports]'
  '--preserveModules[preserve module structure]'
  '--preserveSymlinks[do not follow symlinks when resolving files]'
  '--shimMissingExports[create shim variables for missing exports]'
  '--silent[dont print warnings]'
  '--sourcemapExcludeSources[do not include source code in source maps]'
  '--sourcemapFile[specify bundle position for source maps]:file:_files'
  '--no-treeshake[disable tree-shaking optimisations]'
  '--no-treeshake.propertyReadSideEffects[ignore property access side-effects]'
  '--treeshake.pureExternalModules[assume side-effect free externals]'
  '*:filename:_files'
)

_arguments -s -S $arguments
