#compdef printer-profile

local -a arguments

arguments=(
  '-b[2 Bits per pixel (1)]'
  '-r[resolution. Default=. ()]'
  '-P[remote print (64-bit) machine, or none (amd)]'
  '-S[remote scan (ColorMunki) machine, or none (none)]'
  '-D[debug level]'
  '*:filename:_files'
)

_arguments -s -S $arguments
