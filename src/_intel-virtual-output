#compdef intel-virtual-output
# Documentation: https://man.archlinux.org/search?q=intel-virtual-output
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-d[display> source display]'
  '-f[keep in foreground (do not detach from console and daemonize)]'
  '-b[start bumblebee]'
  '-a[connect to all local displays (e.g. :1, :2, etc)]'
  '-S[disable use of a singleton and launch a fresh intel-virtual-output process]'
  '-v[all verbose output, implies -f]'
  '-V[specific verbose output, implies -f]'
  '-h[this help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
