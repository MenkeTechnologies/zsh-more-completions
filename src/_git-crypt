#compdef git-crypt

# Zsh completion for git-crypt - transparent git encryption

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:generate a key and prepare repo to use git-crypt'
  'status:display which files are encrypted'
  'lock:de-configure and re-encrypt files in working tree'
  'unlock:decrypt files in working tree'
  'add-gpg-user:add a GPG user to the repo'
  'export-key:export the git-crypt key'
  'help:display help'
)

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'git-crypt command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (init)
        _arguments -s -S \
          '(-k --key-name)'{-k,--key-name}'[name of the key]:key name' && ret=0
        ;;
      (status)
        _arguments -s -S \
          '-e[show only encrypted files]' \
          '-u[show only unencrypted files]' \
          '-f[show only files that are fixed (not encrypted but should be)]' \
          '*:file:_files' && ret=0
        ;;
      (lock)
        _arguments -s -S \
          '(-k --key-name)'{-k,--key-name}'[name of the key to lock]:key name' \
          '-a[lock all keys]' \
          '-f[force lock even if there are uncommitted changes]' && ret=0
        ;;
      (unlock)
        _arguments -s -S \
          '(-k --key-name)'{-k,--key-name}'[name of the key to unlock]:key name' \
          '*:key file:_files' && ret=0
        ;;
      (add-gpg-user)
        _arguments -s -S \
          '(-k --key-name)'{-k,--key-name}'[name of the key]:key name' \
          '-n[do not automatically commit]' \
          '--trusted[do not verify GPG key trust]' \
          '1:GPG user ID' && ret=0
        ;;
      (export-key)
        _arguments -s -S \
          '(-k --key-name)'{-k,--key-name}'[name of the key to export]:key name' \
          '1:output file:_files' && ret=0
        ;;
      (help)
        _describe -t commands 'git-crypt command' commands && ret=0
        ;;
    esac
    ;;
esac

return ret
