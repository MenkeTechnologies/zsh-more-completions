#compdef infracost

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'breakdown:show cost breakdown'
      'diff:show cost diff'
      'output:combine and output results'
      'configure:configure Infracost'
      'auth:authenticate'
      'comment:post cost comment to PR'
      'upload:upload cost estimates'
      'completion:generate shell completion'
    )
    _describe -t commands 'infracost command' commands && ret=0
    ;;
  args)
    case $words[1] in
      breakdown)
        _arguments -s -S \
          {-p,--path}'=[path to Terraform directory or plan]:path:_files' \
          '--config-file=[config file]:config:_files' \
          '--usage-file=[usage file]:usage:_files' \
          '--show-skipped[show skipped resources]' \
          '--no-cache[disable caching]' \
          '--format=[output format]:format:(table json html)' \
          {-o,--out-file}'=[output file]:file:_files' \
          '--fields=[fields to show]:fields:(all price monthlyQuantity unit hourlyCost monthlyCost)' \
          '--terraform-workspace=[Terraform workspace]:workspace' \
          '*--terraform-var=[Terraform variable]:key=value' \
          '*--terraform-var-file=[Terraform var file]:file:_files' \
          && ret=0
        ;;
      diff)
        _arguments -s -S \
          {-p,--path}'=[path to Terraform directory or plan]:path:_files' \
          '--config-file=[config file]:config:_files' \
          '--usage-file=[usage file]:usage:_files' \
          '--show-skipped[show skipped resources]' \
          '--no-cache[disable caching]' \
          '--format=[output format]:format:(table json html)' \
          {-o,--out-file}'=[output file]:file:_files' \
          '--compare-to=[compare to JSON file]:file:_files' \
          && ret=0
        ;;
      output)
        _arguments -s -S \
          '*-p[path to JSON files]:path:_files' \
          '--format=[output format]:format:(table json html diff slack-message github-comment gitlab-comment azure-repos-comment bitbucket-comment)' \
          {-o,--out-file}'=[output file]:file:_files' \
          '--show-skipped[show skipped resources]' \
          '--fields=[fields to show]:fields' \
          && ret=0
        ;;
      comment)
        _arguments -s -S -C \
          '1:subcommand:(github gitlab azure-repos bitbucket)' \
          && ret=0
        ;;
      auth)
        _arguments -s -S -C \
          '1:subcommand:(login)' \
          && ret=0
        ;;
      configure)
        _arguments -s -S -C \
          '1:subcommand:(set get)' \
          && ret=0
        ;;
      completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish powershell)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
