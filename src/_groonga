#compdef groonga

local -a arguments

arguments=(
  '-c[run in client mode]'
  '-s[run in server mode]'
  '-d[run in daemon mode]'
  '-n[create new database (except client mode)]'
  {-e,--encoding}'[specify encoding for new database]:encoding'
  '--file[read commands from specified file (has priority over --input-fd)]:file:_files'
  '--input-fd[read commands from specified file descriptor]:fd'
  '--output-fd[output response to specified file descriptor]:fd'
  {-p,--port}'[specify server port number]:port'
  '--bind-address[specify address to bind to]:address'
  {-i,--server-id}'[specify server id]:id'
  '--protocol[specify server protocol to listen]:protocol'
  '--document-root[specify document root path (http only)]:path:_directories'
  '--cache-limit[specify max number of cache data (default: 100)]:limit'
  {-t,--max-threads}'[specify max number of threads]:threads'
  '--pid-path[specify file to write process ID to]:path:_files'
  '--default-request-timeout[specify the default request timeout in seconds]:seconds'
  '--cache-base-path[specify the cache base path]:path:_directories'
  '--listen-backlog[specify the backlog for listen(2)]:backlog'
  '--memcached-column[specify column to access by memcached protocol]:column'
  {-l,--log-level}'[specify log level]:level'
  '--log-flags[specify log flags]:flags'
  '--log-path[specify log path]:path:_files'
  '--log-rotate-threshold-size[specify threshold for log rotate]:size'
  '--query-log-path[specify query log path]:path:_files'
  '--query-log-rotate-threshold-size[specify threshold for query log rotate]:size'
  '--working-directory[specify working directory path]:path:_directories'
  '--config-path[specify config file path]:path:_files'
  '--default-command-version[specify default command version (default: 1)]:version'
  '--default-match-escalation-threshold[specify default match escalation threshold (default: 0)]:threshold'
  '--show-config[show config]'
  '(- * :)'{-h,--help}'[show usage]'
  '--version[show groonga version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
