#compdef dnsextd
# Documentation: https://man.archlinux.org/search?q=dnsextd
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-f[specify configuration file. The default is /etc/dnsextd.conf.]'
  '-d[run daemon in foreground.]'
  '-h[print help.]'
  '-v[verbose output.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
