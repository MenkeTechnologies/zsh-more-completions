#compdef bootctl

_bootctl_commands() {
  local -a commands=(
    'status:show firmware and boot loader information'
    'reboot-to-firmware:query or set firmware setup flag for next reboot'
    'list:display all available boot loader entries'
    'unlink:remove a boot loader entry and its referenced files'
    'cleanup:remove orphaned files from ESP and XBOOTLDR partitions'
    'set-default:persistently set the default boot entry'
    'set-oneshot:set the default boot entry for next boot only'
    'set-sysfail:set boot entry for system failure scenarios'
    'set-timeout:configure the boot loader menu timeout'
    'set-timeout-oneshot:set timeout for next boot only'
    'install:install systemd-boot to the EFI system partition'
    'update:update installed systemd-boot versions'
    'remove:remove systemd-boot from the ESP'
    'is-installed:check if systemd-boot is installed'
    'random-seed:generate and store random seed for entropy'
    'kernel-identify:identify kernel image type'
    'kernel-inspect:display kernel image details'
  )
  _describe -t commands 'bootctl command' commands
}

_bootctl() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a options=(
    '(- *)'{-h,--help}'[show help text]'
    '(- *)--version[print version string]'
    '--esp-path=[path to the EFI System Partition]:path:_directories'
    '--boot-path=[path to the Extended Boot Loader partition]:path:_directories'
    '--root=[prefix all paths with alternate root directory]:path:_directories'
    '--image=[apply operations to disk image or block device]:image:_files'
    '--image-policy=[image policy string per systemd.image-policy]:policy'
    '--install-source=[source for binaries]:type:(auto image host)'
    {-p,--print-esp-path}'[print the path to the EFI System Partition]'
    {-x,--print-boot-path}'[print the path to the boot partition or ESP]'
    '--print-loader-path[show the EFI boot loader binary path]'
    '--print-stub-path[show UKI/stub EFI binary path]'
    {-R,--print-root-device}'[print root filesystem block device]'
    '--variables=[control EFI variables modification]:bool:(yes no)'
    '--random-seed=[control random seed initialization]:bool:(yes no)'
    '--graceful[ignore certain failure conditions]'
    {-q,--quiet}'[suppress output and hints]'
    '--make-entry-directory=[control boot entry directory creation]:bool:(yes no)'
    '--entry-token=[set boot entry naming method]:token'
    '--all-architectures[install for all supported EFI architectures]'
    '--efi-boot-option-description=[custom firmware boot option label]:description'
    '--dry-run[preview unlink/cleanup without executing]'
    '--secure-boot-auto-enroll=[enable secure boot auto-enrollment]:bool:(yes no)'
    '--private-key=[private key for secure boot signing]:path:_files'
    '--private-key-source=[OpenSSL engine/provider for private key]:type'
    '--certificate=[X.509 certificate for secure boot]:path:_files'
    '--certificate-source=[OpenSSL provider for certificate]:type'
    '--no-pager[do not pipe output into a pager]'
    '--json=[output format]:mode:(short pretty off)'
  )

  _arguments -s -S : \
    $options \
    '1:command:_bootctl_commands' \
    '*:arguments'
}

_bootctl "$@"
