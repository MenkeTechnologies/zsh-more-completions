#compdef mifare-desfire-write-ndef
# Documentation: https://man.archlinux.org/search?q=mifare-desfire-write-ndef
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-y[do not ask for confirmation]'
  '-i[use FILE as NDEF message to write on card ("-" = stdin)]'
  '-k[provide another NDEF Tag Application key than the default one]'
  '*:filename:_files'
)

_arguments -s -S $arguments
