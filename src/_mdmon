#compdef mdmon
# Documentation: https://man.archlinux.org/search?q=mdmon
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {--help,-h}'[This message]'
  {--all,-a}'[All devices]'
  {--foreground,-F}'[Run in foreground (do not fork)]'
  {--takeover,-t}'[Takeover container]'
  '*:filename:_files'
)

_arguments -s -S $arguments
