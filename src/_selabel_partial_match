#compdef selabel_partial_match
# Documentation: https://man.archlinux.org/search?q=selabel_partial_match
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-v[validate file_contxts entries against loaded policy.]'
  '-p[path to check if a match or partial match is possible]'
  '-f[optional file_contexts file (defaults to current policy).]'
  '*:filename:_files'
)

_arguments -s -S $arguments
