#compdef gvpr
# Documentation: https://man.archlinux.org/search?q=gvpr
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-c[use source graph for output]'
  '-f[find program in file <pfile>]'
  '-i[create node induced subgraph]'
  '-a[string arguments available as ARGV\[0..\]]'
  '-o[write output to <ofile>; stdout by default]'
  '-n[no read-ahead of input graphs]'
  '-q[turn off warning messages]'
  '-V[print version info]'
  '*:filename:_files'
)

_arguments -s -S $arguments
