#compdef fcrls
# Documentation: https://man.archlinux.org/search?q=fcrls
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--port[rport bsg name, e.g., rport-7:0-1]:port:'
  '--fcid[rport port FC_ID, e.g., 0xce000d]:fc-id:'
  '--quiet[disable verbose output.]'
  '--help[print useage information.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
