#compdef todoist

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a cmds=(
      'list:list tasks'
      'add:add a task'
      'modify:modify a task'
      'close:close a task'
      'delete:delete a task'
      'labels:list labels'
      'projects:list projects'
      'sync:sync with Todoist'
      'quick:add task with quick syntax'
    )
    _describe -t commands 'todoist command' cmds && ret=0
    ;;
  args)
    case "${words[1]}" in
      list)
        _arguments -s -S \
          '(-f --filter)'{-f,--filter}'[filter expression]:filter' \
          '(-p --project-id)'{-p,--project-id}'[project ID]:project id' && ret=0
        ;;
      add)
        _arguments -s -S \
          '(-p --priority)'{-p,--priority}'[priority level (1-4)]:priority:(1 2 3 4)' \
          '(-L --label-ids)'{-L,--label-ids}'[label IDs]:label ids' \
          '(-P --project-id)'{-P,--project-id}'[project ID]:project id' \
          '(-d --date)'{-d,--date}'[due date]:date' \
          '--content[task content]:content' && ret=0
        ;;
      modify)
        _arguments -s -S \
          '(-p --priority)'{-p,--priority}'[priority level (1-4)]:priority:(1 2 3 4)' \
          '(-L --label-ids)'{-L,--label-ids}'[label IDs]:label ids' \
          '(-P --project-id)'{-P,--project-id}'[project ID]:project id' \
          '(-d --date)'{-d,--date}'[due date]:date' \
          '--content[task content]:content' && ret=0
        ;;
    esac
    ;;
esac
return ret
