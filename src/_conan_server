#compdef conan_server
# Documentation: https://man.archlinux.org/search?q=conan_server
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--help}'[show this help message and exit]'
  '--migrate[run the pending migrations]'
  '--server[_dir SERVER_DIR, -d SERVER_DIR]'
  '*:filename:_files'
)

_arguments -s -S $arguments
