#compdef mate-desktop-item-edit
# Documentation: https://man.archlinux.org/search?q=mate-desktop-item-edit
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  '--help-all[show all help options]'
  '--help-gtk[show GTK+ Options]'
  '--create-new[create new file in the given directory]'
  '--display[X display to use]'
  '*:filename:_files'
)

_arguments -s -S $arguments
