#compdef picocrypt

# Zsh completion for picocrypt (encryption tool)

_arguments -s -S \
  '(-e --encrypt)'{-e,--encrypt}'[encrypt files]' \
  '(-d --decrypt)'{-d,--decrypt}'[decrypt files]' \
  '(-p --password)'{-p,--password}'[password]:password:' \
  '(-k --keyfile)'{-k,--keyfile}'[keyfile]:file:_files' \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '(-c --comments)'{-c,--comments}'[add comments]:comments:' \
  '--paranoid[use paranoid mode]' \
  '--reedsolo[use Reed-Solomon encoding]' \
  '--deniability[enable deniability]' \
  '--recursive[recursively process directories]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:file:_files' && return 0
