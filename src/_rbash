#compdef rbash

local -a arguments

arguments=(
  '--debug[enable debug mode]'
  '--debugger[arrange for the debugger profile to be executed]'
  '--dump-po-strings[equivalent to -D, but output in GNU gettext format]'
  '--dump-strings[equivalent to -D]'
  '(- * :)--help[display help message and exit]'
  '--init-file[execute commands from file instead of ~/.bashrc]:file:_files'
  '--login[make bash act as a login shell]'
  '--noediting[do not use readline for command-line editing]'
  '--noprofile[do not read profile files]'
  '--norc[do not read ~/.bashrc]'
  '--posix[change behavior to match POSIX standard]'
  '--rcfile[execute commands from file instead of ~/.bashrc]:file:_files'
  '--restricted[start in restricted mode]'
  '--verbose[print shell input lines as they are read]'
  '--version[display version information and exit]'
  '-c[execute commands from the following string]:command: '
  '-i[force interactive mode]'
  '-l[make bash act as a login shell]'
  '-r[start in restricted mode]'
  '-s[read commands from standard input]'
  '-D[print all double-quoted strings preceded by $]'
  '-O[set shopt option]:shopt-option: '
  '*:filename:_files'
)

_arguments -s -S $arguments
