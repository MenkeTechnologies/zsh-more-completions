#compdef lstmeval

local -a arguments

arguments=(
  '--max_image_MB[max memory to use for images (default 2000)]:int:'
  '--verbosity[amount of diagnostic information to output (0-2)]:int:'
  '--debug_level[level of Trainer debugging]:int:'
  '--load_images[load images with tr files]:int:'
  '--clusterconfig_min_samples_fraction[min number of samples per proto as percent of total]:double:'
  '--clusterconfig_max_illegal[max percentage of samples in a cluster with more than 1 feature]:double:'
  '--clusterconfig_independence[desired independence between dimensions]:double:'
  '--clusterconfig_confidence[desired confidence in prototypes created]:double:'
  '--model[name of model file (training or recognition)]:string:'
  '--traineddata[traineddata file that was given to the trainer]:string:'
  '--eval_listfile[file listing sample files in lstmf training format]:file:_files'
  '--configfile[file to load more configs from]:file:_files'
  '--D[directory to write output files to]:dir:_files -/'
  '--F[file listing font properties]:file:_files'
  '--X[file listing font xheights]:file:_files'
  '--U[file to load unicharset from]:file:_files'
  '--O[file to write unicharset to]:file:_files'
  '--output_trainer[file to write trainer to]:file:_files'
  '--test_ch[UTF8 test character string]:string:'
  '--fonts_dir[fonts directory]:dir:_files -/'
  '--fontconfig_tmpdir[fontconfig temp directory]:dir:_files -/'
  '*:filename:_files'
)

_arguments -s -S $arguments
