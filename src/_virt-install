#compdef virt-install


local -a arguments

arguments=(
    '--connect[connect to hypervisor URI]'
    {-n,--name}'[specify guest name]'
    '--memory[configure guest memory allocation]'
    '--memorybacking[configure memory backing policy]'
    '--arch[specify CPU architecture to simulate]'
    '--machine[specify machine type to emulate]'
    '--metadata[configure guest metadata]'
    '--events[configure guest lifecycle events]'
    '--resource[configure CPU/memory resource partitioning]'
    '--sysinfo[configure SMBIOS system information]'
    '--xml[customize generated domain XML]'
    '--qemu-commandline[pass arguments directly to QEMU]'
    '--display[specify display connection type]'
    '--vcpus[configure virtual CPUs]'
    '--numatune[tune NUMA policy for the domain]'
    '--memtune[tune memory policy for the domain]'
    '--blkiotune[tune block I/O policy for the domain]'
    '--cpu[configure CPU model and topology]'
    '--cputune[tune CPU scheduler parameters]'
    {--security,--seclabel}'[set security label]'
    '--keywrap[configure S390 keywrap options]'
    '--iothreads[configure IOThreads]'
    '--features[configure hypervisor features]'
    '--clock[configure guest clock and timers]'
    '--pm[configure power management]'
    '--launchSecurity[configure launch security (SEV)]'
    {-c,--cdrom}'[specify CD-ROM device or ISO]'
    {-l,--location}'[specify installation source location]'
    '--extra-args[additional kernel arguments for location installs]'
    '--pxe[boot from PXE network]'
    '--import[skip install, import existing disk image]'
    {--disk,--filesystem}'[configure disk or filesystem]'
    '-x[additional kernel arguments]'
    '--initrd-inject[inject file into initrd for install]'
    '--install[specify installation method]'
    '--reinstall[reinstall existing domain]:DOMAIN'
    '--unattended[perform unattended installation]'
    '--cloud-init[configure cloud-init for first boot]'
    '--boot[configure boot device order and options]'
    '--idmap[configure user namespace ID mapping]'
    {--os-variant,--osinfo}'[specify guest OS variant]'
    {-w,--network}'[configure network interface]'
    '--graphics[configure graphical display]'
    {--video,--channel}'[configure video device and channel]'
    {--vnc,--vncport,--vnclisten,--k/--keymap,--sdl,--nographics}'[configure graphics display]'
    '--autoconsole[configure automatic console connection]'
    '--noautoconsole[do not automatically connect to guest console]'
    {-v,--hvm}'[request full virtualization]'
    {-p,--paravirt}'[request paravirtualization]'
    '--container[create a container guest]'
    '--virt-type[specify hypervisor type to use]'
    '--controller[configure emulated storage or USB controllers]'
    '--input[configure input device (mouse, keyboard, tablet)]'
    {--hostdev,--host-device}'[configure host device passthrough]'
    '--sound[configure sound device emulation]'
    '--watchdog[configure watchdog device]'
    '--serial[configure serial port]'
    '--parallel[configure parallel port]'
    '--console[configure text console]'
    '--smartcard[configure smartcard device]'
    '--redirdev[configure USB redirection device]'
    '--memballoon[configure memory balloon device]'
    '--tpm[configure TPM device]'
    '--rng[configure random number generator device]'
    '--panic[configure panic device]'
    '--memdev[configure memory device]'
    '--vsock[configure vsock device]'
    '--iommu[configure IOMMU device]'
    {-h,--help}'[show help message]'
    '--version[show version information]'
    '--autostart[automatically start domain at boot]'
    '--transient[create a transient domain]'
    '--destroy-on-exit[destroy domain when viewer is closed]'
    '--print-xml[print generated XML without creating domain]'
    '--noreboot[do not reboot guest after install]'
    '--wait[wait for install to complete]:minutes'
    '--dry-run[perform a dry run without changes]'
    '--check[enable or disable specific validation checks]'
    {-q,--quiet}'[suppress output]'
    {-d,--debug}'[enable debug output]'
    '*:filename:_files'
)
_arguments -s -S $arguments
