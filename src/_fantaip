#compdef fantaip
# Documentation: https://man.archlinux.org/search?q=fantaip
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-d[detach from terminal and daemonize]'
  '-H[hardware address like XX:XX:XX:XX:XX:XX]:address:'
  '-h[help]'
  '-i[network interface]:interface:_net_interfaces'
  '-v[verbose operation]'
  '*:filename:_files'
)

_arguments -s -S $arguments
