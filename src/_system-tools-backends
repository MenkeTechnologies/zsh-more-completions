#compdef system-tools-backends
# Documentation: https://man.archlinux.org/search?q=system-tools-backends
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show help options]'
  {-d,--debug}'[debug mode]'
  {-D,--daemon}'[daemon mode]'
  '*:filename:_files'
)

_arguments -s -S $arguments
