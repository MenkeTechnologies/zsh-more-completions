#compdef gvfs-tree
# Documentation: https://man.archlinux.org/search?q=gvfs-tree
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-h,--hidden}'[show hidden files]'
  {-l,--follow-symlinks}'[follow symbolic links, mounts and shortcuts]'
  '*:filename:_files'
)

_arguments -s -S $arguments
