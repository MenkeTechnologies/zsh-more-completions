#compdef sss_ssh_authorizedkeys
# Documentation: https://man.archlinux.org/search?q=sss_ssh_authorizedkeys
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-d,--domain}'[the SSSD domain to use]'
  '--usage[display brief usage message]'
  '*:filename:_files'
)

_arguments -s -S $arguments
