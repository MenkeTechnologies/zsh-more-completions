#compdef uhd_cal_rx_iq_balance

local -a arguments

arguments=(
  '--help[help message]'
  '--verbose[enable some verbose]'
  '--args[device address args \[default = ""\]]'
  '--subdev[subdevice specification (default: first]'
  '--tx_wave_ampl=[TX waveform amplitude]:value'
  '--tx_offset=[TX LO offset from the RX LO in Hz]:value'
  '--freq_start=[frequency start in Hz]:value'
  '--freq_stop=[frequency stop in Hz]:value'
  '--freq_step=[step size for LO sweep in Hz]:value'
  '--nsamps[samples per data capture]'
  '--precision[(=0.0001) Correction precision (default=0.0001)]'
  '*:filename:_files'
)

_arguments -s -S $arguments
