#compdef git-filter-repo

# Zsh completion for git filter-repo (rewrite git history)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '*--path[path to include/rewrite]:path:_files' \
  '*--path-glob[glob pattern for paths to include]:glob pattern:' \
  '*--path-regex[regex pattern for paths to include]:regex:' \
  '--invert-paths[invert path filtering]' \
  '--message-callback[Python callback for rewriting messages]:callback:' \
  '--name-callback[Python callback for rewriting names]:callback:' \
  '--email-callback[Python callback for rewriting emails]:callback:' \
  '--refname-callback[Python callback for rewriting refnames]:callback:' \
  '--blob-callback[Python callback for rewriting blobs]:callback:' \
  '--commit-callback[Python callback for rewriting commits]:callback:' \
  '--tag-callback[Python callback for rewriting tags]:callback:' \
  '--reset-callback[Python callback for rewriting resets]:callback:' \
  '--replace-text[file with text replacements]:file:_files' \
  '*--replace-message[replace text in commit messages]:replacement:' \
  '--strip-blobs-bigger-than[strip blobs bigger than size]:size:' \
  '--strip-blobs-with-ids[strip blobs with given IDs]:file:_files' \
  '--to-subdirectory-filter[move all files to a subdirectory]:directory:' \
  '--subdirectory-filter[only keep files from a subdirectory]:directory:' \
  '--prune-empty[prune empty commits]:mode:(auto always never)' \
  '--prune-degenerate[prune degenerate merges]:mode:(auto always never)' \
  '--no-ff[do not fast-forward]' \
  '(-f --force)'{-f,--force}'[rewrite history even if not a fresh clone]' \
  '--partial[do a partial history rewrite]' \
  '*--refs[limit to specific refs]:ref:' \
  '--dry-run[do not change the repository]' \
  '--debug[show extra debugging output]' \
  '--quiet[suppress non-error output]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
