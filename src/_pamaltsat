#compdef pamaltsat
# Documentation: https://man.archlinux.org/search?q=pamaltsat
# Reference accessed: 2026-05-16


local -a arguments

arguments=(
    '--method[specifies the saturation method to use: The default is spectrum.]:method'
    '--strength[This specifies a real nonnegative factor whereby to modify saturation.]:strength'
    '--linear[This tells pamaltsat that the input is the intensity-linear variation of a Ne]'
    '*:filename:_files'
)
_arguments -s -S $arguments
