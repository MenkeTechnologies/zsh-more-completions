#compdef glacier

local -a arguments

arguments=(
  '--access_key[your AWS Access Key ID]:access key:'
  '--secret_key[your AWS Secret Access Key]:secret key:'
  '--region[AWS region to use]:region:(us-east-1 us-west-1 us-west-2 eu-west-1 ap-northeast-1 ap-southeast-2)'
  '*:filename:_files'
)

_arguments -s -S $arguments
