#compdef ctags

# Zsh completion for Universal Ctags / Exuberant Ctags

_ctags_languages() {
  local -a langs
  langs=(${(f)"$(ctags --list-languages 2>/dev/null)"})
  _describe -t languages 'language' langs
}

_ctags_output_formats() {
  local -a formats
  formats=(
    'u-ctags:universal ctags format'
    'e-ctags:exuberant ctags format'
    'etags:emacs tag format'
    'xref:cross reference format'
    'json:JSON output format'
  )
  _describe -t formats 'output format' formats
}

_arguments -s -S \
  '(- *)--help[print option summary]' \
  '(- *)-?[print option summary]' \
  '(- *)--help-full[print option summary including experimental features]' \
  '(- *)--version[print version identifier]' \
  '(- *)--license[print details of software license]' \
  '-a[append tags to an existing tag file]' \
  '-B[use backward searching patterns]' \
  '-e[output tag file for use with Emacs]' \
  '-f+[write tags to specified file ("-" for stdout)]:tag file:_files' \
  '-F[use forward searching patterns (default)]' \
  '-G[equivalent to --guess-language-eagerly]' \
  '-h+[specify list of file extensions to be treated as include files]:extensions' \
  '-I+[list of tokens to be specially handled]:token list or @file:_files' \
  '-L+[read list of source file names from specified file]:file list:_files' \
  '-n[equivalent to --excmd=number]' \
  '-N[equivalent to --excmd=pattern]' \
  '-o+[alternative for -f]:tag file:_files' \
  '-R[equivalent to --recurse]' \
  '-u[equivalent to --sort=no]' \
  '-V[equivalent to --verbose]' \
  '-x[print a tabular cross reference file to stdout]' \
  '--append=-[append tags to existing tag file]::bool:(yes no)' \
  '--etags-include=[include reference to file in Emacs-style tag file]:file:_files' \
  '--exclude=[exclude files and directories matching pattern]:pattern' \
  '--exclude-exception=[don'\''t exclude files matching pattern even if they match --exclude]:pattern' \
  '--excmd=[type of EX command to locate tags]:type:(number pattern mix combine)' \
  '--extras=[include extra tag entries for selected information]:flags' \
  '--fields=[include selected extension fields]:flags' \
  '--filter=-[behave as a filter, reading file names from stdin]::bool:(yes no)' \
  '--filter-terminator=[string to print to stdout following tags for each file]:string' \
  '--format=[force output of specified tag file format]:format:(1 2)' \
  '--guess-language-eagerly[guess the language of input file more eagerly]' \
  '--if0=-[should C code within \#if 0 be parsed]::bool:(yes no)' \
  '--input-encoding=[specify encoding of all input files]:encoding' \
  '--input-encoding-*=[specify encoding of language input files]:encoding' \
  '--langdef=[define a new language to be parsed with regular expressions]:language name' \
  '--langmap=[override default mapping of language to input file extension]:mappings' \
  '--language-force=[force all files to be interpreted using specified language]:language:_ctags_languages' \
  '--languages=[restrict files scanned to those mapped to specified languages]:language list:_ctags_languages' \
  '--links=-[indicate whether symbolic links should be followed]::bool:(yes no)' \
  '--list-aliases=-[output list of alias patterns]::language:_ctags_languages' \
  '--list-excludes[output list of exclude patterns]' \
  '--list-extras=-[output list of extra tag flags]::language:_ctags_languages' \
  '--list-features[output list of compiled features]' \
  '--list-fields=-[output list of fields]::language:_ctags_languages' \
  '--list-kinds=-[output list of all tag kinds for specified language or all]::language:_ctags_languages' \
  '--list-kinds-full=-[list details of all tag kinds]::language:_ctags_languages' \
  '--list-languages[output list of supported languages]' \
  '--list-map-extensions=-[output list of language extensions in mapping]::language:_ctags_languages' \
  '--list-map-patterns=-[output list of language patterns in mapping]::language:_ctags_languages' \
  '--list-maps=-[output list of language mappings]::language:_ctags_languages' \
  '--list-mline-regex-flags[output list of flags for multiline regex parser]' \
  '--list-output-formats[output list of output formats]' \
  '--list-params=-[output list of language parameters]::language:_ctags_languages' \
  '--list-pseudo-tags[output list of pseudo tags]' \
  '--list-regex-flags[output list of flags for regex parser definition]' \
  '--list-roles=-[output list of all roles of tag kinds]::language:_ctags_languages' \
  '--list-subparsers=-[output list of subparsers for the base language]::language:_ctags_languages' \
  '--machinable=-[use tab separated representation in --list-* output]::bool:(yes no)' \
  '--map-*=[set, add, or remove the map for a language]:extension or pattern' \
  '--maxdepth=[specify maximum recursion depth]:depth' \
  '--options=[specify file from which command line options should be read]:options file:_files' \
  '--output-format=[specify the output format]:format:_ctags_output_formats' \
  '--pattern-length-limit=[cutoff patterns of tag entries after N characters]:length' \
  '--print-language[print the guessed language name for input file]' \
  '--pseudo-tags=[enable/disable emitting pseudo tags]:pseudo tag' \
  '--put-field-prefix[put UCTAGS as prefix for new field names]' \
  '--quiet=-[don'\''t print NOTICE class messages]::bool:(yes no)' \
  '--recurse=-[recurse into directories supplied on command line]::bool:(yes no)' \
  '--sort=[should tags be sorted]:order:(yes no foldcase)' \
  '--tag-relative=[should paths be relative to location of tag file]:mode:(yes no always never)' \
  '--totals=-[print statistics about input and tag files]::mode:(yes no extra)' \
  '--verbose=-[enable verbose messages describing actions on each input file]::bool:(yes no)' \
  '--with-list-header=-[prepend column descriptions in --list-* output]::bool:(yes no)' \
  '*:file:_files'
