#compdef podman-mac-helper

local -a arguments

arguments=(
    '1:command:(install uninstall)'
    '*:: :->args'
)

_arguments -s -S $arguments && return

case "$state" in
    args)
        case ${words[1]} in
            install)
                _arguments \
                    '--prefix[Installation prefix]:prefix:_directories' \
                    '--user[User to install for]:user:_users'
                ;;
            uninstall)
                _arguments \
                    '--prefix[Installation prefix]:prefix:_directories' \
                    '--user[User to uninstall for]:user:_users'
                ;;
        esac
        ;;
esac
