#compdef blkcat

local -a arguments

arguments=(
  '-a[display in all ASCII]'
  '-h[display in hexdump-like fashion]'
  '-i[the format of the image file (use -i list for supported types)]:format:'
  '-b[the size (in bytes) of the device sectors]:size:'
  '-o[the offset of the file system in the image (in sectors)]:offset:'
  '-f[file system type (use -f list for supported types)]:type:'
  '-s[display basic block stats such as unit size, fragments, etc.]'
  '-v[verbose output to stderr]'
  '-V[display version]'
  '-w[display in web-like (html) fashion]'
  '-u[size of each data unit in image]:size:'
  '*:filename:_files'
)

_arguments -s -S $arguments
