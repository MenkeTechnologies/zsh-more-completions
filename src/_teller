#compdef teller

# Zsh completion for teller (secrets manager for developers)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'copy:copy a secret from one provider to another'
  'delete:delete a secret'
  'drift:detect drift between providers'
  'env:print env vars from your .teller.yml'
  'exec:execute a command with secrets'
  'graph:show graph of providers and secrets'
  'mirror:mirror all secrets from one provider to another'
  'new:create a new .teller.yml file'
  'put:set a secret'
  'redact:redact secrets from a stream'
  'run:run a command with secrets'
  'scan:scan for secrets in code'
  'show:show secrets'
  'template:render a template with secrets'
  'version:show version'
  'yaml:render YAML with secrets'
)

_arguments -s -S \
  '(-c --config)'{-c,--config}'[config file]:file:_files -g "*.yml *.yaml"' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'teller command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (run|exec)
        _arguments '*:command:_command_names -e' && ret=0
        ;;
      (put)
        _arguments '1:key:' '2:value:' && ret=0
        ;;
      (delete)
        _arguments '1:key:' && ret=0
        ;;
      (scan)
        _arguments \
          '--path[path to scan]:path:_files -/' \
          '--silent[only report findings]' && ret=0
        ;;
      (template)
        _arguments '1:template file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
