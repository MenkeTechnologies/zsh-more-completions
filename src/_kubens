#compdef kubens

# Zsh completion for kubens (switch Kubernetes namespaces)

local curcontext="$curcontext" state line ret=1

local -a namespaces
namespaces=(${(f)"$(kubectl get namespaces -o jsonpath='{range .items[*]}{.metadata.name}{"\n"}{end}' 2>/dev/null)"})

_arguments -s -S \
  '(-c --current)'{-c,--current}'[Show current namespace]' \
  '(-h --help)'{-h,--help}'[Show help message]' \
  '(-u --unset)'{-u,--unset}'[Unset the current namespace]' \
  '1:namespace:->ns' && ret=0

case "$state" in
  ns)
    _describe -t namespaces 'kubernetes namespace' namespaces && ret=0
    ;;
esac

return ret
