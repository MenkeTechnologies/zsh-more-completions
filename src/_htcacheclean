#compdef htcacheclean

local -a arguments

arguments=(
  '-d[daemonize and repeat cache cleaning every INTERVAL minutes]:interval:'
  '-D[do a dry run and do not delete anything]'
  '-v[be verbose and print statistics]'
  '-r[clean thoroughly, assumes Apache web server is not running]'
  '-n[be nice, causes slower processing in favour of other processes]'
  '-t[delete all empty directories]'
  '-p[specify PATH as the root directory of the disk cache]:path:_directories'
  '-P[specify PIDFILE as the file to write the pid to]:pidfile:_files'
  '-R[specify amount to round sizes up to]:size:'
  '-l[specify LIMIT as the total disk cache size limit]:limit:'
  '-L[specify LIMIT as the total disk cache inode limit]:limit:'
  '-i[be intelligent and run only when cache was modified]'
  '-a[list the URLs currently stored in the cache]'
  '-A[list the URLs currently stored in the cache with metadata]'
  '*:filename:_files'
)

_arguments -s -S $arguments
