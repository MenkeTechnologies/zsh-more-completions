#compdef blueman-tray
# Documentation: https://man.archlinux.org/search?q=blueman-tray
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '(- * :)'{-h,--help}'[show this help message and exit]'
  '--loglevel[set log level]:level:'
  '--syslog[log to syslog]'
  '*:filename:_files'
)

_arguments -s -S $arguments
