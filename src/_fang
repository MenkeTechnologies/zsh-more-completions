#compdef fang

local -a arguments

arguments=(
  '-r[Bluetooth address range to scan]:range:'
  '-o[output scan to text logfile]:filename:_files'
  '-t[connect timeout (default 10000)]:timeout:'
  '-n[number of dongles]:num:'
  '-d[show debug information]'
  '-s[perform Bluetooth Discovery]'
  '-l[show device manufacturer codes]'
  '-h[display help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
