#compdef du

# Completion for du(1) - display disk usage statistics
# Supports both macOS/BSD and GNU coreutils variants

local is_gnu=false
if du --version &>/dev/null; then
    is_gnu=true
fi

local -a arguments

if $is_gnu; then
    # GNU coreutils du
    arguments=(
        {-0,--null}'[end each output line with NUL, not newline]'
        {-a,--all}'[write counts for all files, not just directories]'
        '--apparent-size[print apparent sizes rather than disk usage]'
        {-B,--block-size}'[scale sizes by SIZE before printing]:size:(K M G T P E KB MB GB TB PB EB 1K 1M 1G 1T 1P 1E)'
        {-b,--bytes}'[equivalent to --apparent-size --block-size=1]'
        {-c,--total}'[produce a grand total]'
        {-D,--dereference-args}'[dereference only symlinks listed on the command line]'
        {-d,--max-depth}'[print the total for a directory only if it is N or fewer levels deep]:depth:'
        '--files0-from[summarize disk usage of NUL-terminated file names specified in file]:file:_files'
        '-H[equivalent to --dereference-args (-D)]'
        {-h,--human-readable}'[print sizes in human readable format (e.g., 1K 234M 2G)]'
        '--inodes[list inode usage information instead of block usage]'
        '-k[like --block-size=1K]'
        {-L,--dereference}'[dereference all symbolic links]'
        {-l,--count-links}'[count sizes many times if hard linked]'
        '-m[like --block-size=1M]'
        {-P,--no-dereference}'[do not follow any symbolic links (this is the default)]'
        {-S,--separate-dirs}'[for directories do not include size of subdirectories]'
        '--si[like -h, but use powers of 1000 not 1024]'
        {-s,--summarize}'[display only a total for each argument]'
        {-t,--threshold}'[exclude entries smaller than SIZE if positive, or larger if negative]:size:'
        '--time[show time of the last modification of any file in the directory]:word:(atime access use ctime status)'
        '--time-style[show times using specified style]:style:(full-iso long-iso iso +FORMAT)'
        {-X,--exclude-from}'[exclude files that match any pattern in FILE]:file:_files'
        '--exclude[exclude files that match PATTERN]:pattern:'
        {-x,--one-file-system}'[skip directories on different file systems]'
        '(- *)--help[display this help and exit]'
        '(- *)--version[output version information and exit]'
        '*:file:_files'
    )
else
    # macOS / BSD du
    arguments=(
        '-A[display the apparent size instead of the disk usage]'
        '-B[calculate block counts in specified byte blocks]:blocksize:'
        '(-L -P)-H[follow symbolic links on the command line only]'
        '-I[ignore files and directories matching the specified mask]:mask:'
        '(-H -P)-L[follow all symbolic links]'
        '(-H -L)-P[do not follow any symbolic links (default)]'
        '(-s -d)-a[display an entry for each file in a file hierarchy]'
        '-c[display a grand total]'
        '(-s -a)-d[display an entry for all files and directories depth directories deep]:depth:'
        '(-h -k -m --si)-g[display block counts in 1 GiB blocks]'
        '(-g -k -m --si)-h[human-readable output using unit suffixes]'
        '(-g -h -m --si)-k[display block counts in 1 kiB blocks]'
        '-l[count sizes many times if hard linked]'
        '(-g -h -k --si)-m[display block counts in 1 MiB blocks]'
        '-n[ignore files and directories with user nodump flag set]'
        '-r[generate messages about unreadable directories]'
        '(-a -d)-s[display an entry for each specified file (equivalent to -d 0)]'
        '(-g -h -k -m)--si[human-readable output using powers of 1000]'
        '-t[display only entries for which size exceeds threshold]:threshold:'
        '-x[do not traverse file systems differing from the one of the command line argument]'
        '*:file:_files'
    )
fi

_arguments -s -S $arguments
