#compdef sqlite-utils

# Zsh completion for sqlite-utils

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'query:execute a SQL query'
  'memory:execute SQL against in-memory database'
  'insert:insert data from JSON, CSV, TSV, or NL'
  'upsert:upsert data from JSON, CSV, TSV, or NL'
  'bulk:execute parameterized SQL for each input record'
  'search:search a table using SQLite FTS'
  'transform:transform a table'
  'extract:extract columns into a separate table'
  'schema:show full schema for a database or table'
  'insert-files:insert file contents into a table'
  'find-files:find files and insert into a table'
  'tables:list tables in a database'
  'views:list views in a database'
  'rows:output all rows in a table'
  'triggers:list triggers'
  'indexes:list indexes'
  'create-table:create a table'
  'create-view:create a view'
  'drop-table:drop a table'
  'drop-view:drop a view'
  'add-column:add a column to a table'
  'add-foreign-key:add a foreign key'
  'add-foreign-keys:add foreign keys'
  'index-foreign-keys:create indexes for all foreign keys'
  'enable-fts:enable full-text search'
  'populate-fts:populate full-text search'
  'disable-fts:disable full-text search'
  'rebuild-fts:rebuild FTS tables'
  'enable-counts:enable count caching'
  'reset-counts:reset count cache'
  'enable-wal:enable WAL mode'
  'disable-wal:disable WAL mode'
  'vacuum:run VACUUM'
  'optimize:run optimize'
  'rebuild:rebuild tables'
  'convert:transform column values'
  'duplicate:duplicate a table'
  'install:install a SQLite extension'
  'uninstall:uninstall a SQLite extension'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'sqlite-utils command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (query)
        _arguments \
          '--csv[output as CSV]' \
          '--tsv[output as TSV]' \
          '--json-cols[detect JSON in columns]' \
          '--nl[output newline-delimited JSON]' \
          '--table[output as table]' \
          '--raw[output raw data]' \
          '--raw-lines[output raw lines]' \
          '(-p --param)'{-p,--param}'[named parameter]:key\=value:' \
          '--load-extension[load SQLite extension]:ext:_files' \
          '1:database:_files -g "*.db *.sqlite *.sqlite3"' \
          '2:SQL:' && ret=0
        ;;
      (insert|upsert)
        _arguments \
          '--csv[input is CSV]' \
          '--tsv[input is TSV]' \
          '--nl[input is newline-delimited JSON]' \
          '--pk[column(s) to use as primary key]:column:' \
          '--flatten[flatten nested JSON objects]' \
          '--batch-size[commit every N records]:size:' \
          '--alter[add any missing columns]' \
          '--detect-types[detect column types]' \
          '--not-null[column(s) that are NOT NULL]:column:' \
          '1:database:_files -g "*.db *.sqlite *.sqlite3"' \
          '2:table:' && ret=0
        ;;
      (tables|views|schema)
        _arguments \
          '1:database:_files -g "*.db *.sqlite *.sqlite3"' && ret=0
        ;;
      (rows)
        _arguments \
          '--csv[output as CSV]' \
          '--tsv[output as TSV]' \
          '--nl[output as NL JSON]' \
          '--table[output as table]' \
          '--limit[limit rows]:count:' \
          '--offset[row offset]:offset:' \
          '1:database:_files -g "*.db *.sqlite *.sqlite3"' \
          '2:table:' && ret=0
        ;;
    esac
    ;;
esac

return ret
