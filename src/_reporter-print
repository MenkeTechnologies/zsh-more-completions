#compdef reporter-print
# Documentation: https://man.archlinux.org/search?q=reporter-print
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-v,--verbose}'[be verbose]'
  '-d[problem directory]'
  '-o[output file]'
  '-a[/no Append to, or overwrite FILE]'
  '-r[create reported_to in DIR]'
  '*:filename:_files'
)

_arguments -s -S $arguments
