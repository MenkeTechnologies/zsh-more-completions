#compdef kafka-verifiable-producer

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--topic[Topic to produce to]:topic:'
    '--max-messages[Maximum number of messages to produce (-1 for unlimited)]:count:'
    '--throughput[Throttle maximum message throughput per second (-1 for no limit)]:throughput:'
    '--acks[Number of acks required]:acks:(0 1 -1 all)'
    '--producer.config[Producer config properties file]:file:_files'
    '--message-create-time[Send messages with creation timestamp]:ms:'
    '--value-prefix[Prefix each message value with this number]:prefix:'
    '--repeating-keys[Number of keys to use (0 for null keys)]:count:'
)

_arguments -s -S $arguments
