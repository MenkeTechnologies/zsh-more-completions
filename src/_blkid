#compdef blkid

# zsh completions for 'blkid'

_blkid() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -s -S \
        {-c,--cache-file}'[read from specified cache file instead of default]:cache file:_files' \
        {-d,--no-encoding}'[do not encode non-printing characters]' \
        {-D,--no-part-details}'[do not print partition table information (PART_ENTRY_* tags)]' \
        {-g,--garbage-collect}'[perform a garbage collection pass on the blkid cache]' \
        {-H,--hint}'[set probing hint (e.g. for multi-session UDF)]:hint setting:' \
        {-h,--help}'[print usage message and exit]' \
        {-i,--info}'[display information about I/O limits]' \
        {-k,--list-filesystems}'[list all known filesystems and RAIDs and exit]' \
        {-l,--list-one}'[look up only first device with token specified by -t]' \
        {-L,--label}'[convert LABEL to device name]:filesystem label:' \
        {-n,--match-types}'[restrict probing to specified filesystem/RAID types]:type list:' \
        {-o,--output}'[use the specified output format]:output format:(full value list device udev export json)' \
        {-O,--offset}'[probe at the given byte offset]:byte offset:' \
        {-p,--probe}'[switch to low-level superblocks probing mode (bypass cache)]' \
        {-s,--match-tag}'[show only specified tag(s) for each device]:tag name:(TYPE LABEL UUID PARTUUID PARTLABEL UUID_SUB USAGE)' \
        {-S,--size}'[override the size of device/file]:size (bytes):' \
        {-t,--match-token}'[search for block devices with specified token]:NAME=value:' \
        {-u,--usages}'[restrict probing to specified usage types]:usage list:(filesystem raid crypto other)' \
        {-U,--uuid}'[convert UUID to device name]:filesystem UUID:' \
        {-V,--version}'[print version and exit]' \
        '*:block device:_files -g "*(b)"' && ret=0

    return ret
}

_blkid "$@"
