#compdef netsed
# Documentation: https://man.archlinux.org/search?q=netsed
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {--ipv6,-6}'[force address resolution in IPv6]'
  '--ipany[resolve the address in either IPv4 or IPv6.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
