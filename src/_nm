#compdef nm

local -a arguments

arguments=(
  '(-a --debug-syms)'{-a,--debug-syms}'[show all symbols, even debugger only]'
  '(-A -o --print-file-name)'{-A,-o,--print-file-name}'[print name of the input file before every symbol]'
  '-B[same as --format=bsd]'
  '(-C --demangle)'{-C,--demangle}'[demangle C++ symbol names]'
  '--no-demangle[do not demangle symbol names]'
  '(-D --dynamic)'{-D,--dynamic}'[display dynamic symbols instead of normal symbols]'
  '--defined-only[display only defined symbols]'
  '(-f --format)'{-f,--format}'[specify output format]:format:(bsd posix sysv darwin just-symbols)'
  '(-g --extern-only)'{-g,--extern-only}'[display only external (global) symbols]'
  '--export-symbols[export symbol list for all inputs]'
  '-j[same as --format=just-symbols]'
  '(-l --line-numbers)'{-l,--line-numbers}'[use debugging information to print filenames and line numbers]'
  '-m[display Mach-O N_SECT symbols with segment/section info (same as --format=darwin)]'
  '(-n -v --numeric-sort)'{-n,-v,--numeric-sort}'[sort symbols numerically by address]'
  '(-p --no-sort)'{-p,--no-sort}'[do not sort; display in symbol-table order]'
  '(-P --portability)'{-P,--portability}'[same as --format=posix]'
  '(-r --reverse-sort)'{-r,--reverse-sort}'[sort in reverse order]'
  '(-S --print-size)'{-S,--print-size}'[print size of defined symbols]'
  '--print-armap[print the archive symbol map]'
  '--size-sort[sort symbols by size]'
  '--special-syms[do not filter special symbols from the output]'
  '--synthetic[display synthetic symbols as well]'
  '(-t --radix)'{-t,--radix}'[specify radix for printing symbol values]:radix:(o d x)'
  '--target[specify the target object format]:target:'
  '(-u --undefined-only)'{-u,--undefined-only}'[display only undefined symbols]'
  '(-U)-U[display only defined symbols (same as --defined-only)]'
  '(-W --no-weak)'{-W,--no-weak}'[show only non-weak symbols]'
  '--quiet[suppress "no symbols" diagnostic]'
  '--no-llvm-bc[disable LLVM bitcode reader]'
  '--with-symbol-versions[display version strings after symbol names]'
  '-L[display symbols from LLVM bitcode bundle section]'
  '-X+[specify ELF/XCOFF/IR object type to examine]:value:(32 64 32_64 any)'
  '-x[print symbol table entry fields in hexadecimal]'
  '*--arch=[architecture to dump from a Mach-O universal file]:architecture:(x86_64 arm64 arm64e i386 all)'
  '--add-dyldinfo[add symbols from dyldinfo not in the symbol table]'
  '--add-inlinedinfo[add symbols from inlined libraries (TBD only)]'
  '--dyldinfo-only[show only symbols from the dyldinfo]'
  '--no-dyldinfo[do not add any symbols from the dyldinfo]'
  '--no-rsrc[exclude resource file symbols from export list (XCOFF)]'
  '--plugin[load the specified plugin]:plugin:'
  '(- * :)'{-h,--help}'[display help information]'
  '(-V --version)'{-V,--version}'[display version information]'
  '*:object file:_files'
)

_arguments -s -S $arguments
