#compdef avrdude

local -a arguments

arguments=(
  '-p[specify AVR device (required)]:device:'
  '-b[override RS-232 baud rate]:baud rate:'
  '-B[specify JTAG/STK500v2 bit clock period (us)]:period:'
  '-C[specify location of configuration file]:config file:_files'
  '-c[specify programmer type]:programmer:'
  '-D[disable auto erase for flash memory]'
  '-i[ISP Clock Delay in microseconds]:delay:'
  '-P[specify connection port]:port:'
  '-F[override invalid signature check]'
  '-e[perform a chip erase]'
  '-O[perform RC oscillator calibration (see AVR053)]'
  '-U[memory operation specification]:memop:'
  '-n[do not write anything to the device]'
  '-V[do not verify]'
  '-u[disable safemode, default when running from a script]'
  '-s[silent safemode operation]'
  '-t[enter terminal mode]'
  '-E[list programmer exit specifications]:exitspec:'
  '-x[pass extended param to programmer]:extended_param:'
  '-y[count erase cycles in EEPROM]'
  '-Y[initialize erase cycle count in EEPROM]:cycles:'
  '-v[verbose output. -v -v for more]'
  '-q[quell progress output. -q -q for less]'
  '-l[use logfile rather than stderr for diagnostics]:logfile:_files'
  '*:filename:_files'
)

_arguments -s -S $arguments
