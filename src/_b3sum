#compdef b3sum

# Zsh completion for b3sum - BLAKE3 cryptographic hash function

_arguments -s -S \
  '(-l --length)'{-l,--length}'[number of output bytes, prior to any encoding]:N:' \
  '--keyed[use keyed mode; the key is 32 raw bytes from stdin]' \
  '--derive-key[use KDF mode with context string from CONTEXT]:CONTEXT:' \
  '--no-names[omit filenames in the output]' \
  '--raw[write raw output bytes to stdout]' \
  '--check[read BLAKE3 sums from FILEs and check them]:file:_files' \
  '--tag[create a BSD-style checksum]' \
  '--quiet[do not print OK for each successfully verified file]' \
  '--status[do not output anything, only return exit code]' \
  '--strict[exit non-zero if any line is improperly formatted]' \
  '--warn[warn about improperly formatted checksum lines]' \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '*:file:_files'
