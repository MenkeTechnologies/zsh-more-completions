#compdef wmctrl

# Zsh completion for wmctrl - interact with an EWMH/NetWM compatible X window manager

local -a action_opts modifier_opts

# Actions (mutually exclusive operations)
action_opts=(
  '(-l -d -s -a -c -R -k -o -n -g)-m[display information about the window manager]'
  '(-m -d -s -a -c -R -k -o -n -g)-l[list windows managed by the window manager]'
  '(-m -l -s -a -c -R -k -o -n -g)-d[list desktops; current desktop is marked with an asterisk]'
  '(-m -l -d -a -c -R -k -o -n -g)-s[switch to the specified desktop]:desktop number'
  '(-m -l -d -s -c -R -k -o -n -g)-a[activate the window by switching to its desktop and raising it]:window title'
  '(-m -l -d -s -a -R -k -o -n -g)-c[close the window gracefully]:window title'
  '(-m -l -d -s -a -c -k -o -n -g)-R[move the window to the current desktop and activate it]:window title'
  '(-m -l -d -s -a -c -R -o -n -g)-k[activate or deactivate window manager'\''s "showing the desktop" mode]:(on off)'
  '(-m -l -d -s -a -c -R -k -n -g)-o[change the viewport for the current desktop]:X,Y coordinates'
  '(-m -l -d -s -a -c -R -k -o -g)-n[change number of desktops]:number of desktops'
  '(-m -l -d -s -a -c -R -k -o -n)-g[change geometry (common size) of all desktops]:W,H geometry'
)

# Modifier options
modifier_opts=(
  '-r[specify target window for action]:window title or :SELECT: or :ACTIVE:'
  '-t[move window to the specified desktop (use with -r)]:desktop number'
  '-e[resize and move the window (use with -r)]:gravity,X,Y,W,H'
  '-b[change the state of the window (use with -r)]:property:(add remove toggle)"\:property\:(modal sticky maximized_vert maximized_horz shaded skip_taskbar skip_pager hidden fullscreen above below demands_attention)"'
  '-N[set the name (long title) of the window (use with -r)]:name'
  '-I[set the icon name (short title) of the window (use with -r)]:icon name'
  '-T[set both the name and icon name of the window (use with -r)]:name'
  '-i[interpret window argument as a numerical window ID]'
  '-p[include PIDs in the window list]'
  '-G[include geometry in the window list]'
  '-x[include WM_CLASS in the window list or interpret as WM_CLASS]'
  '-u[override auto-detection and force UTF-8 mode]'
  '-F[require exact match for window title (no substring matching)]'
  '-v[be verbose (useful for debugging)]'
  '*-w[use a workaround]:workaround name:(DESKTOP_TITLES_INVALID_UTF8)'
  '(- *)-h[print help]'
)

_arguments -s $action_opts $modifier_opts
