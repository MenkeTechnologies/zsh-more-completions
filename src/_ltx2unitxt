#compdef ltx2unitxt
# Documentation: https://man.archlinux.org/search?q=ltx2unitxt
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {-c,--config}'[read (Perl) config FILE for a hook, as explained above]'
  {-e,--entities}'[output entities &#xNNNN; instead of literal characters]'
  {-g,--german}'[handle some features of the german package]'
  {-h,--html}'[output simplistic HTML instead of plain text]'
  {-o,--output}'[output to FILE instead of stdout]'
  {-v,--verbose}'[be verbose]'
  {-V,--version}'[output version information and exit]'
  '*:filename:_files'
)

_arguments -s -S $arguments
