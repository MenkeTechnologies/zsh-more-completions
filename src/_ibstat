#compdef ibstat
# Documentation: https://man.archlinux.org/search?q=ibstat
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  {--list_of_cas,-l}'[list all IB devices]'
  {--short,-s}'[short output]'
  {--port_list,-p}'[show port list]'
  {--config,-z}'[use config file, default: /etc/infiniband-diags/ibdiag.conf]'
  {--verbose,-v}'[increase verbosity level]'
  {--debug,-d}'[raise debug level]'
  {--help,-h}'[help message]'
  {--version,-V}'[show version]'
  '*:filename:_files'
)

_arguments -s -S $arguments
