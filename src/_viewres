#compdef viewres
# Documentation: https://man.archlinux.org/search?q=viewres
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-top[object to be top of tree]'
  '-variable[show variable name instead of class name]'
  '-vertical[list the tree vertically]'
  '*:filename:_files'
)

_arguments -s -S $arguments
