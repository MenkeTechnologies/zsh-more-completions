#compdef mpcdec
# Documentation: https://man.archlinux.org/search?q=mpcdec
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-i[print file information on stdout]'
  '-c[check the file for stream errors]'
  '-h[print this help]'
  '*:filename:_files'
)

_arguments -s -S $arguments
