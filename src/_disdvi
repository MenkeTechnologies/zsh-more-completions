#compdef disdvi
# Documentation: https://man.archlinux.org/search?q=disdvi
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-p[support ASCII pTeX dvi]'
  '-u[support upTeX dvi]'
  '-x[support XeTeX xdv]'
  '-Eenc[output multibyte encoding. The enc argument denotes u:UTF8 e:EUC-JP s:Shift_JIS j:JIS]'
  '-h[this help message.]'
  '*:filename:_files'
)

_arguments -s -S $arguments
