#compdef aarch64-portbld-freebsd14.0-gcc-ar10
# Documentation: https://man.archlinux.org/search?q=aarch64-portbld-freebsd14.0-gcc-ar10
# Reference accessed: 2026-05-16

local arguments

arguments=(
  '--target[- specify the target object format as BFDNAME]'
  '--output[- specify the output directory for extraction operations]'
  '--record-libdeps[- specify the dependencies of this library]'
  '--plugin[- load the specified plugin]'
  '*:filename:_files'
)

_arguments -s $arguments
