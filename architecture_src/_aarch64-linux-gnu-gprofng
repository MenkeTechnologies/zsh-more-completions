#compdef aarch64-linux-gnu-gprofng
# Documentation: https://man.archlinux.org/search?q=aarch64-linux-gnu-gprofng
# Reference accessed: 2026-05-16

local arguments

arguments=(
  '--version[print the version number and exit.]'
  '--help[print usage information and exit.]'
  '--check[verify if the hardware and software environment is supported.]'
  '--verbose[}  enable (on) or disable (off) verbose mode; the default is "off".]'
  '*:filename:_files'
)

_arguments -s $arguments
