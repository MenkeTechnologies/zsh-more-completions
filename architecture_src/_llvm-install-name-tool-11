#compdef llvm-install-name-tool-11
# Documentation: https://man.archlinux.org/search?q=llvm-install-name-tool-11
# Reference accessed: 2026-05-16

local arguments

arguments=(
  '-add[_rpath <value>      Add new rpath]'
  '-change[<value> Change dependent shared library install name]'
  '-delete[_rpath <value>   Delete specified rpath]'
  '-id[change dynamic shared library id]'
  '-rpath[<value>  Change rpath path name]'
  '--version[print the version and exit.]'
  '*:filename:_files'
)

_arguments -s $arguments
