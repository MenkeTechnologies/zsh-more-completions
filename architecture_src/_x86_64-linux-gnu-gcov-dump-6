#compdef x86_64-linux-gnu-gcov-dump-6
# Documentation: https://man.archlinux.org/search?q=x86_64-linux-gnu-gcov-dump-6
# Reference accessed: 2026-05-16

local arguments

arguments=(
  '(- * :)'{-h,--help}'[print this help]'
  {-v,--version}'[print version number]'
  {-l,--long}'[dump record contents too]'
  {-p,--positions}'[dump record positions]'
  {-w,--working-sets}'[dump working set computed from summary]'
  '*:filename:_files'
)

_arguments -s $arguments
