#compdef aarch64-linux-gnu-gp-display-text
# Documentation: https://man.archlinux.org/search?q=aarch64-linux-gnu-gp-display-text
# Reference accessed: 2026-05-16

local arguments

arguments=(
  '--version[print the version number and exit.]'
  '--help[print usage information and exit.]'
  '--verbose[}  enable (on) or disable (off) verbose mode; the default is "off".]'
  '-script[execute the commands stored in the script file]'
  '*:filename:_files'
)

_arguments -s $arguments
