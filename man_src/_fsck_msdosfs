#compdef fsck_msdosfs

local arguments

arguments=(
    '-C[Skip check if clean, default behavior]'
    '-F[Determine whether file system needs immediate cleaning]'
    '-f[Force checking of clean file systems when preening]'
    '-n[Assume no as the answer to all operator questions]'
    '-p[Preen the specified file systems]'
    '-y[Assume yes as the answer to all operator questions]'
    '*:filename:_files'
)
_arguments -s $arguments
