#compdef exim_lock
# Documentation: https://man.archlinux.org/search?q=exim_lock
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--fcntl[Use fcntl() locking on the open mailbox]'
    '--flock[Use flock() locking on the open mailbox]'
    '--interval[Set the interval between retries in seconds]:seconds'
    '--lockfile[Create a lock file before opening the mailbox]'
    '--mbx[Lock the mailbox using MBX rules]'
    '-q[Suppress verification output]'
    '--retries[Set the number of times to try to get the lock]:number'
    '--restore_time[Restore the modified and read times to the locked mailbox]'
    '--timeout[Set a timeout for the lock in seconds]:seconds'
    '-v[Generate verbose output]'
    '*:filename:_files'
)
_arguments -s $arguments
