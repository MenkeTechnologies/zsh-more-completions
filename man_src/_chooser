#compdef xdm chooser

local arguments

arguments=(
    '--config[Specify the configuration file]:configuration file:_files'
    '--nodaemon[Run in the foreground, do not daemonize]'
    '--debug[Set the debug level]:debug level'
    '--error[Specify the error log file]:error log file:_files'
    '--resources[Specify the resources file]:resource file:_files'
    '--server[Specify the server entry]:server entry'
    '--udpPort[Specify the UDP port number]:port number'
    '--session[Specify the session program]:session program:_files'
    '--xrm[Specify an arbitrary resource]:resource specification'
    '*:filename:_files'
)
_arguments -s $arguments
