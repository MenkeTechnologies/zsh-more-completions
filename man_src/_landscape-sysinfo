#compdef landscape-sysinfo
# Documentation: https://man.archlinux.org/search?q=landscape-sysinfo
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--version[Show program version number and exit]'
    '(- * :)'{-h,--help}'[Show help message and exit]'
    {-c,--config}'[Use config from this file]:config:_files'
    {-d,--data-path}'[The directory to store data files in]:path:_directories'
    '--sysinfo-plugins[Comma-delimited list of sysinfo plugins to use]:plugins'
    '--exclude-sysinfo-plugins[Comma-delimited list of sysinfo plugins to NOT use]:plugins'
    '*:filename:_files'
)
_arguments -s $arguments
