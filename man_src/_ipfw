#compdef ipfw

local arguments

arguments=(
    '-a[Show counter values when listing rules]'
    '-b[Only show the action and the comment, not the body of a rule]'
    '-c[When entering or showing rules, print them in compact form]'
    '-d[When listing, show dynamic rules in addition to static ones]'
    '-e[When listing and -d is specified, also show expired dynamic rules]'
    '-f[Do not ask for confirmation for commands that can cause problems if misused]'
    '-i[When listing a table, show additional table info]'
    '-n[Only check syntax of the command strings, without passing them to the kernel]'
    '-N[Try to resolve addresses and service names in output]'
    '-q[Be quiet when executing add, nat, zero, resetlog or flush commands]'
    '-S[When listing rules, show the set each rule belongs to]'
    '-s[When listing pipes, sort according to one of the four counters]:field'
    '-t[When listing, show last match timestamp converted with ctime]'
    '-T[When listing, show last match timestamp as seconds from the epoch]'
    '*:filename:_files'
)
_arguments -s $arguments
