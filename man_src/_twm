#compdef twm
# Documentation: https://man.archlinux.org/search?q=twm
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--display[specify the X server to use]:display'
    '-s[manage only the default screen]'
    '-f[specify the name of the startup file to use]:filename:_files'
    '-v[print error messages for unexpected X errors]'
    '*:filename:_files'
)
_arguments -s $arguments
