#compdef tcpkill

local arguments

arguments=(
    '-i[specify the interface to listen on]:interface'
    '-1[specify the degree of brute force in killing a connection]'
    '-2[specify the degree of brute force in killing a connection]'
    '-3[specify the degree of brute force in killing a connection]'
    '-4[specify the degree of brute force in killing a connection]'
    '-5[specify the degree of brute force in killing a connection]'
    '-6[specify the degree of brute force in killing a connection]'
    '-7[specify the degree of brute force in killing a connection]'
    '-8[specify the degree of brute force in killing a connection]'
    '-9[specify the degree of brute force in killing a connection]'
    '*:filename:_files'
)
_arguments -s $arguments
