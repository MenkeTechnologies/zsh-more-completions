#compdef tpm2_duplicate

local arguments

arguments=(
    {-G,--wrapper-algorithm}'[symmetric algorithm for the inner wrapper]:algorithm'
    '--key-algorithm[key algorithm associated with the public parent]:algorithm'
    {-i,--encryptionkey-in}'[filename of the symmetric key for inner wrapper]:file:_files'
    {-o,--encryptionkey-out}'[filename to store the symmetric key used]:file:_files'
    '--input-key-file[have the TPM generate the key]'
    {-C,--parent-context}'[the parent key object]:object:_files'
    {-U,--parent-public}'[file path to the public key of the parent on destination TPM]:file:_files'
    {-k,--private-key}'[file path to the external private key to be encrypted]:file:_files'
    {-r,--private}'[file path to save the private portion of the duplicated object]:file:_files'
    {-u,--public}'[file path to save the public portion of the duplicated object]:file:_files'
    {-s,--encrypted-seed}'[file to save the encrypted seed]:file:_files'
    {-p,--auth}'[authorization value for the key]:auth'
    {-L,--policy}'[input policy file]:file:_files'
    {-c,--key-context}'[the object to be duplicated]:object:_files'
    {-a,--attributes}'[the object attributes]:attributes'
    '--cphash[file path to record command parameter hash]:file:_files'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    {-V,--verbose}'[increase verbosity of tool output]'
    {-Q,--quiet}'[suppress informational output]'
    {-Z,--enable-errata}'[enable errata fixups]'
    {-R,--autoflush}'[autoflush objects created by the command]'
    '*:filename:_files'
)
_arguments -s $arguments
