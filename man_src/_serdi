#compdef serdi

# Updated with fixes for trailing periods

local arguments

arguments=(
    '-a[Write ASCII output if possible]'
    '-b[Fast bulk output for large serialisations]'
    '-c[Chop PREFIX from matching blank node IDs]:prefix'
    '-e[Eat input one character at a time]'
    '-f[Keep full URIs in input (do not qualify)]'
    '-h[Display help and exit]'
    '-i[Input syntax]:syntax:(turtle ntriples trig nquads)'
    '-l[Lax (non-strict) parsing]'
    '-o[Output syntax]:syntax:(turtle ntriples nquads)'
    '-p[Add PREFIX to blank node IDs]:prefix'
    '-q[Suppress all output except data]'
    '-r[Keep relative URIs within ROOT_URI]:root_uri'
    '-s[Parse INPUT as string (terminates options)]:input'
    '-v[Display version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
