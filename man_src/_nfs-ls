#compdef nfs-ls

local arguments

arguments=(
    {-s,--summary}'[Print a summary line at the end of output]'
    {-R,--recursive}'[Recursive listing of the specified URL]'
    {-D,--discovery}'[Discover local NFS servers and list their exports]'
    {-\?,--help}'[Display basic help text]'
    '--usage[Display basic usage text]'
    '*:filename:_files'
)
_arguments -s $arguments
