#compdef jack_wait

local arguments

arguments=(
    {-w,--wait}'[Wait for jackd to be available]'
    {-q,--quit}'[Wait for jackd to quit]'
    {-c,--check}'[Only check for existence of jackd, and exit]'
    {-s,--server}'[Connect to the JACK server named servername]:servername'
    {-t,--timeout}'[Only wait for the specified timeout in seconds]:seconds'
    '(- * :)'{-h,--help}'[Display help/usage message]'
    {-v,--version}'[Display version]'
    '*:filename:_files'
)
_arguments -s $arguments
