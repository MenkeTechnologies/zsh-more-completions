#compdef tapestat

local arguments

arguments=(
    '--human[print sizes in human readable format (e.g. 1.0k, 1.2M)]'
    '-k[show data written or read in kilobytes per second]'
    '-m[show data written or read in megabytes per second]'
    '-t[display time stamps]'
    '-V[print version and exit]'
    '-y[omit the initial statistic showing values since boot]'
    '-z[omit output for any tapes for which there was no activity]'
    '*:filename:_files'
)
_arguments -s $arguments
