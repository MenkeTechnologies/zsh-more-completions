#compdef lintian-annotate-hints

local arguments

arguments=(
    {-a,--annotate}'[Display descriptions of tags in Lintian overrides]'
    '--include-dir[Check for Lintian data in DIR]:dir:_directories'
    '--profile[Use vendor profile X to determine severities]:profile'
    '--output-width[Set output width instead of probing terminal]:width'
    '--version[Show version info and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
