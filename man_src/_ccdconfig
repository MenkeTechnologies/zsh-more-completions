#compdef ccdconfig

local arguments

arguments=(
    '-c[Configure a ccd device]'
    '-C[Configure all ccd devices listed in the ccd configuration file]'
    '-f[Read the specified config file instead of the default]:config file:_files'
    '-g[Dump the current ccd configuration in a format suitable for the config file]'
    '-u[Unconfigure a ccd device]'
    '-U[Unconfigure all ccd devices listed in the ccd configuration file]'
    '-v[Verbose mode]'
    '*:filename:_files'
)
_arguments -s $arguments
