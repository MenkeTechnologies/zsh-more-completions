#compdef compiz

local arguments

arguments=(
    '--display[Manage the specified display instead of $DISPLAY]:display'
    '--bg-image[Use the specified image as background]:image:_files'
    '--refresh-rate[Set the default refresh rate]:rate'
    '--fast-filter[Use a fast texture filter]'
    '--indirect-rendering[Force an indirect rendering context]'
    '--loose-binding[Disable strict binding of textures]'
    '--replace[Replace any existing window managers on the given display]'
    '--sm-disable[Disable session management]'
    '--sm-client-id[Use the given ID as the client ID for session management]:id'
    '--no-detection[Disable output screen detection]'
    '--no-fbo[Disable the use of frame buffer objects]'
    '--ignore-desktop-hints[Do not use desktop hints left by the previous window manager]'
    '--only-current-screen[Manage only the screen defined by $DISPLAY]'
    '--use-root-window[Use the root window instead of the composite overlay window]'
    '--version[Show the compiz version string]'
    '(- * :)--help[Show a summary of the command-line options]'
    '*:filename:_files'
)
_arguments -s $arguments
