#compdef xclock

local arguments

arguments=(
    '-help[Print a brief summary of the allowed options]'
    '-analog[Display a conventional 12 hour clock face with tick marks]'
    {-digital,-d}'[Display a 24 hour digital clock]'
    '-brief[Display the digital clock with only hours and minutes]'
    '-utime[Display seconds since the Epoch]'
    '-strftime[Use the specified strftime format string for the digital clock]:format'
    '-twelve[Display the time in twelve hour format]'
    '-twentyfour[Display the time in twenty-four hour format]'
    '-chime[Chime once on the half hour and twice on the hour]'
    {-hands,-hd}'[Specify the color of the hands on an analog clock]:color'
    {-highlight,-hl}'[Specify the color of the edges of the hands]:color'
    '-update[Frequency in seconds at which xclock should update its display]:seconds'
    '-padding[Width in pixels of the padding between the window border and clock]:number'
    '-render[Use the Xrender extension to draw an anti-aliased face]'
    '-norender[Turn off the use of Xrender]'
    '-sharp[Use sharper edges when drawn using Xrender]'
    '-face[Font to use in digital mode with Xrender]:pattern'
    '*:filename:_files'
)
_arguments -s $arguments
