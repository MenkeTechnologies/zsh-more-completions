#compdef virt-ssh-helper
# Documentation: https://man.archlinux.org/search?q=virt-ssh-helper
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-h,--help}'[Show help options]'
    {-r,--readonly}'[Connect read-only]'
    {-V,--version}'[Display version information]'
    '*:filename:_files'
)
_arguments -s $arguments
