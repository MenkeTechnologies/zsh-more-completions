#compdef grotty

local arguments

arguments=(
    '-b[Suppress overstriking for bold characters]'
    '-B[Use only overstriking for bold-italic characters]'
    '-c[Use old output format with langstrokes and langbackspaces]'
    '-d[Ignore all escape sequences in the input]'
    '-f[Use form feeds in the output]'
    '-F[Set the search directory for font files]:dir:_directories'
    '-h[Use horizontal tab characters in the output]'
    '-i[Render italic characters as underlined]'
    '-o[Suppress overstriking]'
    '-r[Use old output format with only printable ASCII characters]'
    '-u[Suppress underlining for italic characters]'
    '-U[Use only overstriking for bold characters]'
    '-v[Print version number]'
    '*:filename:_files'
)
_arguments -s $arguments
