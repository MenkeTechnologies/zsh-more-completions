#compdef file2cable
# Documentation: https://man.archlinux.org/search?q=file2cable
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-v[Verbose mode]'
    '-i[Specify the network interface]:interface'
    '-f[Specify the input file]:file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
