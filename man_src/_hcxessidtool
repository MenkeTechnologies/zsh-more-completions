#compdef hcxessidtool

local arguments

arguments=(
    '-e[Filter by ESSID]:essid'
    '-E[Filter by ESSID from file]:essid_file:_files'
    '-l[Filter by ESSID length]:length'
    '-h[Show help]'
    '-v[Show version]'
    '--pmkid1[Input PMKID file 1]:file:_files'
    '--pmkid2[Input PMKID file 2]:file:_files'
    '--pmkidout12[Output matched PMKIDs from both files]:file:_files'
    '--pmkidout1[Output matched PMKIDs from file 1]:file:_files'
    '--pmkidout2[Output matched PMKIDs from file 2]:file:_files'
    '--pmkidout[Output unmatched PMKIDs]:file:_files'
    '--pmkidgroupout[Output PMKIDs grouped by ESSID]:file:_files'
    '--hccapx1[Input hccapx file 1]:file:_files'
    '--hccapx2[Input hccapx file 2]:file:_files'
    '--hccapxout12[Output matched hccapx from both files]:file:_files'
    '--hccapxout1[Output matched hccapx from file 1]:file:_files'
    '--hccapxout2[Output matched hccapx from file 2]:file:_files'
    '--hccapxout[Output unmatched hccapx entries]:file:_files'
    '--hccapxgroupout[Output hccapx grouped by ESSID]:file:_files'
    '--essidout[Output ESSIDs]:file:_files'
    '--essidmacapout[Output ESSID and MAC AP pairs]:file:_files'
    '--help[Show help]'
    '--version[Show version]'
    '*:filename:_files'
)
_arguments -s $arguments
