#compdef faraday-client

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Show this help message and exit]'
    '--disable-excepthook[Disable the application exception hook]'
    '--login[Enable prompt for authentication database credentials]'
    '--dev-mode[Enable dev mode using user config and plugin folder]'
    '--cert[Path to the valid Faraday server certificate]:CERT_PATH:_files'
    '--gui[Select interface to start Faraday]:GUI'
    '--cli[Set this flag to avoid GUI and use Faraday as a CLI]'
    {-w,--workspace}'[Workspace to be opened]:workspace'
    {-r,--report}'[Report to be parsed by the CLI]:report:_files'
    {-d,--debug}'[Enable debug mode]'
    '--creds-file[File containing user credentials for CLI mode]:CREDS_FILE:_files'
    '--keep-old[Keep old object in CLI mode if Faraday finds a conflict]'
    '--keep-new[Keep new object in CLI mode if Faraday finds a conflict (default)]'
    {-v,--version}'[Show program version number and exit]'
    {-n,--hostname}'[The hostname where server APIs will listen]:hostname'
    {--px,--port-xmlrpc}'[Set the port where the XMLRPC Server will listen]:port'
    {--pr,--port-rest}'[Set the port where the RESTful Server will listen]:port'
    '*:filename:_files'
)
_arguments -s $arguments
