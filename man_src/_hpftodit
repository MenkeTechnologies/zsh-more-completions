#compdef hpftodit

local arguments

arguments=(
    '-a[Include characters in the TFM file that are not included in the map file]'
    '-d[Dump information about the TFM file to the standard output]'
    '-q[Suppress warnings about characters in the map file that were not found in the TFM file]'
    '-v[Print the hpftodit version number]'
    '-s[The font is special]'
    '-i[Generate an italic correction for each character so that the characters width plus the italic correction equals n units]:n'
    '*:filename:_files'
)
_arguments -s $arguments
