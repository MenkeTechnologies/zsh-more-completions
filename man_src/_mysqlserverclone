#compdef mysqlserverclone

local arguments

arguments=(
    '--help[Display help and exit]'
    '--delete-data[Remove the data directory before cloning]'
    '--mysqld[Additional options for the new server instance]:options'
    '--new-data[Data directory for the new instance]:path:_directories'
    '--new-id[Server ID for the new instance]:server_id'
    '--new-port[Port for the new server instance]:port'
    {-q,--quiet}'[Turn off all messages for quiet execution]'
    '--root-password[Root password for the new server instance]:password'
    '--server[Connection information for the source server]:source'
    '--start-timeout[Seconds to wait for the new server to start]:timeout'
    {-v,--verbose}'[Verbose output]'
    '--version[Display version information and exit]'
    {--write-command,-w}'[Write startup command to file]:filename:_files'
    '*:filename:_files'
)
_arguments -s $arguments
