#compdef eu-strings

local arguments

arguments=(
    {-a,--all}'[Scan entire file, not only loaded sections]'
    {-e,--encoding}'[Select character size and endianness]:encoding:(s S b l B L)'
    {-f,--print-file-name}'[Print name of the file before each string]'
    {-n,--bytes}'[Only NUL-terminated sequences of at least MIN-LEN characters]:MIN-LEN'
    '-o[Alias for --radix=o]'
    {-t,--radix}'[Print location of the string in base 8, 10, or 16]:base:(o d x)'
    '--usage[Give a short usage message]'
    {-V,--version}'[Print program version]'
    '*:filename:_files'
)

_arguments -s $arguments
