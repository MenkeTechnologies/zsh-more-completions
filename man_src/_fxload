#compdef fxload

local arguments

arguments=(
    '-c[Download firmware to an I2C boot EEPROM]:config'
    '-s[Hex file holding a second stage loader]:loader:_files'
    '-t[Indicate the type of microcontroller used in the device]:type'
    '-v[Print diagnostics such as download addresses and sizes to stderr]'
    '-l[Print error and verbose messages to syslog]'
    '*:filename:_files'
)
_arguments -s $arguments
