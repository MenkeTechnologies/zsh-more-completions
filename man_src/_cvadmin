#compdef cvadmin

local arguments

arguments=(
    '-H[Connect to the FSM located on the specified machine]:hostname:_hosts'
    '-F[Automatically set the specified volume as the active volume]:volume name'
    '-M[When listing file systems, display managed status]'
    '-f[Read commands from the specified file]:filename:_files'
    '-e[Execute command(s) and exit]:command'
    '-x[Enable extended commands]'
    '*:filename:_files'
)
_arguments -s $arguments
