#compdef limits

local arguments

arguments=(
    '-C[Use current resource values, modified by the resource entries applicable for the current login class]'
    '-U[Use current resource values, modified by the resource entries applicable to the specified user]:user'
    '-P[Select or set limits for the process identified by the PID]:pid'
    '-S[Select display or setting of soft (current) resource limits]'
    '-H[Select display or setting of hard (maximum) resource limits]'
    '-B[Select display or setting of both soft and hard resource limits]'
    '-e[Select eval mode formatting for output]'
    '-b[Select or set the sbsize resource limit]:val'
    '-c[Select or set the coredumpsize resource limit]:val'
    '-d[Select or set the datasize resource limit]:val'
    '-f[Select or set the filesize resource limit]:val'
    '-k[Select or set the kqueues resource limit]:val'
    '-l[Select or set the memorylocked resource limit]:val'
    '-m[Select or set the memoryuse size limit]:val'
    '-n[Select or set the openfiles resource limit]:val'
    '-o[Select or set the umtxp resource limit]:val'
    '-p[Select or set the pseudoterminals resource limit]:val'
    '-s[Select or set the stacksize resource limit]:val'
    '-t[Select or set the cputime resource limit]:val'
    '-u[Select or set the maxproc resource limit]:val'
    '-v[Select or set the virtualmem resource limit]:val'
    '-w[Select or set the swapuse resource limit]:val'
    '-E[Completely ignore the inherited environment]'
    '-a[Force all resource settings to be displayed]'
    '*:filename:_files'
)
_arguments -s $arguments
