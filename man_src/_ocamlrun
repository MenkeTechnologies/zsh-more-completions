#compdef ocamlrun

local arguments

arguments=(
    '-b[Print a detailed backtrace when the program aborts due to an uncaught exception]'
    '-I[Search the directory for dynamically-loaded libraries]:dir:_directories'
    '-p[Print the names of the primitives known to this version of ocamlrun and exit]'
    '-v[Direct the memory manager to print verbose messages on standard error]'
    '--version[Print version string and exit]'
    '-g[Ignored for backwards compatibility with ocamlc debug option]'
    '--vnum[Print short version number and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
