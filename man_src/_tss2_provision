#compdef tss2_provision
# Documentation: https://man.archlinux.org/search?q=tss2_provision
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-E,--authValueEh}'[authorization value for the endorsement hierarchy]:auth'
    {-S,--authValueSh}'[authorization value for the storage hierarchy]:auth'
    {-L,--authValueLockout}'[authorization value for the lockout authorization]:auth'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
