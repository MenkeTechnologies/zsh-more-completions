#compdef ir-ctl

local arguments

arguments=(
    {-d,--device}'[LIRC device to control]:device:_files'
    {-f,--features}'[List the features of the LIRC device]'
    {-r,--receive}'[Receive IR and print to standard output or save to file]:file:_files'
    {-s,--send}'[Send IR in text file]:file:_files'
    {-S,--scancode}'[Send the IR scancode in the protocol specified]:protocol:scancode'
    {-K,--keycode}'[Send the keycode from the keymap]:keycode'
    {-k,--keymap}'[The rc keymap file in TOML format]:keymap:_files'
    {-1,--oneshot}'[When receiving, stop receiving after the first message]'
    '--mode2[When receiving, output IR in mode2 format]'
    {-w,--wideband}'[Use the wideband receiver if available on the hardware]'
    {-n,--narrowband}'[Switch back to the normal narrowband receiver]'
    {-R,--carrier-range}'[Set the accepted carrier range for the narrowband receiver]:range'
    {-m,--measure-carrier}'[Report what the carrier frequency is on receiving]'
    {-M,--no-measure-carrier}'[Disable reporting of the carrier frequency]'
    {-t,--timeout}'[Set the length of a space at which the receiver goes idle]:timeout'
    {-c,--carrier}'[Set the send carrier frequency]:carrier'
    {-D,--duty-cycle}'[Set the duty cycle for sending in percent]:duty'
    {-e,--emitters}'[Comma separated list of emitters to use for sending]:emitters'
    {-g,--gap}'[Set the gap between scancodes or between files]:gap'
    {-\?,--help}'[Print the help message]'
    '--usage[Give a short usage message]'
    {-v,--verbose}'[Verbose output; print the IR before sending]'
    {-V,--version}'[Print the v4l2-utils version]'
    '*:filename:_files'
)
_arguments -s $arguments
