#compdef vde_plug2tap

local arguments

arguments=(
    {-p,--port}'[Decide which port of the switch to use]:portnum'
    {-g,--group}'[Group ownership of the communication socket]:group'
    {-m,--mod}'[Octal chmod like permissions for the comm sockets]:octal-mode'
    {-s,--sock}'[Specify the UNIX socket for joining the VDE]:socket:_files'
    {-d,--daemon}'[Start as a background process]'
    {-P,--pidfile}'[Write the process ID to pidfile]:pidfile:_files'
    {-h,--help}'[Show a brief help]'
    '*:filename:_files'
)
_arguments -s $arguments
