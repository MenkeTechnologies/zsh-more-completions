#compdef iprop-log
# Documentation: https://man.archlinux.org/search?q=iprop-log
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--version[Print version information]'
    '-h[Print help]'
    '-c[Use specified configuration file]:config:_files'
    '-r[Specify realm]:realm'
    '--start-version[Start replay with this version]:version'
    '*:filename:_files'
)
_arguments -s $arguments
