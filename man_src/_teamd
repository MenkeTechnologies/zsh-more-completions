#compdef teamd

local arguments

arguments=(
    '(- * :)'{-h,--help}'[print help text to console and exit]'
    {-V,--version}'[print version information to console and exit]'
    {-d,--daemonize}'[daemonize after startup]'
    {-k,--kill}'[kill running daemon instance]'
    {-e,--check}'[return 0 if a daemon is already running]'
    {-f,--config-file}'[load the specified configuration file]:file:_files'
    {-c,--config}'[use given JSON format configuration string]:config'
    {-p,--pid-file}'[use the specified PID file]:file:_files'
    {-g,--debug}'[turn on debugging messages]'
    {-r,--force-recreate}'[force team device recreation if it already exists]'
    {-o,--take-over}'[take over the device if it already exists]'
    {-N,--no-quit-destroy}'[do not remove the team device after teamd finishes]'
    {-t,--team-dev}'[use the specified team device name]:name'
    {-n,--no-ports}'[start without ports, even if listed in configuration]'
    {-D,--dbus-enable}'[enable D-Bus interface]'
    {-Z,--zmq-enable}'[enable ZMQ interface]'
    {-U,--usock-enable}'[enable UNIX domain socket interface]'
    {-u,--usock-disable}'[disable UNIX domain socket interface]'
    '*:filename:_files'
)
_arguments -s $arguments
