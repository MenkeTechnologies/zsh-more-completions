#compdef weakpass_edit
# Documentation: https://man.archlinux.org/search?q=weakpass_edit
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-p[Add or delete a passphrase to the weak passphrase database]:passphrase'
    '-f[Add or delete all passphrases contained in a file]:file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
