#compdef iconutil
# Documentation: https://man.archlinux.org/search?q=iconutil
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-c[Convert format: iconset to convert .iconset to .icns, or icns to do the reverse]:format:(iconset icns)'
    '-o[Override the default output file name]:output:_files'
    '*:filename:_files'
)
_arguments -s $arguments
