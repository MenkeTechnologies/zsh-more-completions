#compdef meld

local arguments

arguments=(
    {--auto-compare,-a}'[Automatically compare all differing files on startup]'
    '--auto-merge[Automatically merge files]'
    '--comparison-file[Load a saved comparison from a Meld comparison file]:file:_files'
    '--diff[Create a diff tab for the given files or directories]'
    {--help,-h}'[Print application help and usage]'
    {--label,-L}'[Set application window title to label]:label'
    {--newtab,-n}'[Open the comparison as a new tab in an already-running instance]'
    {--output,-o}'[Set the save path for the middle buffer in a three-pane merge view]:file:_files'
    {--unified,-u}'[Ignored for compatibility]'
    '--version[Show version information]'
    '*:filename:_files'
)
_arguments -s $arguments
