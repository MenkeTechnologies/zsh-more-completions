#compdef krbservicesetup

local arguments

arguments=(
    '-x[Use kadmin.local instead of kadmin]'
    '-r[The Kerberos realm of the server]:realm'
    '-a[Name of an administrator with privileges to add principals to the KDC]:admin'
    '-p[Password for the administrator]:password'
    '-t[The path of the keytab file to write]:keytab:_files'
    '-f[The path of the plist file containing the list of services]:file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
