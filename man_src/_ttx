#compdef ttx

local arguments

arguments=(
    '-h[display usage information]'
    '-d[write output files to specified directory]:dir:_directories'
    '-o[write the output to specified file]:file:_files'
    '-v[be verbose]'
    '-a[allow virtual glyph IDs on compile or decompile]'
    '-l[list table information]'
    '-t[dump specified table]:table'
    '-x[exclude specified table from the list of tables to dump]:table'
    '-s[split tables]'
    '-i[do not disassemble TrueType instructions]'
    '-y[when decompiling TTC, decompile font number n]:n'
    '-m[merge the input TTX file with fontfile]:fontfile:_files'
    '-b[do not recalculate glyph bounding boxes]'
    '*:filename:_files'
)
_arguments -s $arguments
