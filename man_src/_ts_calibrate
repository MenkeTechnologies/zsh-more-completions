#compdef ts_calibrate
# Documentation: https://man.archlinux.org/search?q=ts_calibrate
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-r,--rotate}'[rotate the screen]:value'
    {-t,--min_interval}'[time in milliseconds before a crosshair is pressed]:ms'
    {-c,--validate}'[validate the calibration]'
    {-b,--boundary}'[validation boundary in pixels (only with --validate)]:pixels'
    {-l,--loops}'[number of loops in validation mode (only with --validate)]:loops'
    '*:filename:_files'
)
_arguments -s $arguments
