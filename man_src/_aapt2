#compdef aapt2

# Updated with latest Android Asset Packaging Tool 2 options

local arguments

arguments=(
    '-h[Display help menu]'
    '*:: :->subcmd'
)

local -a subcmds
subcmds=(
    'compile:Compile a resource file'
    'link:Link compiled resources and produce an APK'
    'dump:Dump information about an APK'
    'diff:Show differences between two APKs'
    'optimize:Optimize an APK'
    'convert:Convert between proto and binary formats'
    'version:Print the version of aapt2'
)

_arguments -s $arguments

case "$state" in
    subcmd)
        _describe 'command' subcmds
        ;;
esac
