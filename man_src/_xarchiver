#compdef xarchiver

local arguments

arguments=(
    {-a,--add}'[Add to archive by asking which files and quit]'
    {-c,--compress}'[Add the given files by asking the name of the archive and quit]'
    {-e,--extract}'[Extract archive by asking the extraction directory and quit]'
    {-m,--multi-extract}'[Extract multiple archives by asking the extraction directory and quit]'
    {-x,--extract-to}'[Extract archive to the destination directory and quit]:destination:_directories'
    {-i,--info}'[Show found command line programs to be used and exit]'
    {-v,--version}'[Show version and exit]'
    '--display[X display to use]:display'
    {-h,--help}'[Show help options]'
    '--help-gtk[Show GTK+ options]'
    '--help-all[Show all help options]'
    '*:filename:_files'
)
_arguments -s $arguments
