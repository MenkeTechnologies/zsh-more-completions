#compdef era_invalidate

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Print help and exit]'
    {-V,--version}'[Print version information and exit]'
    '-o[Write output to a file rather than stdout]:file:_files'
    '--metadata-snapshot[Use the metadata snapshot rather than the current superblock]'
    '--written-since[Blocks written since the given era will be listed]:era'
    '*:filename:_files'
)
_arguments -s $arguments
