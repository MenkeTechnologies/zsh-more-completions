#compdef chio

local arguments

arguments=(
    '-f[Use the specified device changer instead of /dev/ch0]:device:_files'
    '-v[Print the primary volume tag for each loaded medium]'
    '-V[Print the alternate volume tag for each loaded medium]'
    '-s[Print the additional sense code and qualifier for each element]'
    '-S[Print the element source address for each element]'
    '-b[Print SCSI bus information for each element]'
    '-I[Print the internal element addresses for each element]'
    '-a[Print all additional information]'
    '*:filename:_files'
)
_arguments -s $arguments
