#compdef hastd
# Documentation: https://man.archlinux.org/search?q=hastd
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-c[Specify alternative location of the configuration file]:config:_files'
    '-d[Print or log debugging information]'
    '-F[Start the hastd daemon in the foreground]'
    '-h[Print the hastd usage message]'
    '-P[Specify alternative location of PID file]:pidfile:_files'
    '*:filename:_files'
)
_arguments -s $arguments
