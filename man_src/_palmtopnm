#compdef palmtopnm

local arguments

arguments=(
    '--verbose[Display various information about the input file and process]'
    '--transparent[Set the transparent color RGB value for output]'
    '--rendition[Select a specific rendition from multi-rendition Palm pixmaps]:n'
    '--showhist[Write a histogram of colors in the input file to stderr]'
    '--forceplain[Force the output to be in ASCII plain netpbm format]'
    '*:filename:_files'
)
_arguments -s $arguments
