#compdef libnet-config
# Documentation: https://man.archlinux.org/search?q=libnet-config
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--cflags[Set of compiler options to use when compiling files that use libnet]'
    '--libs[Show the complete set of libs and other linker options needed to link with libnet]'
    '--defines[Set of compiler defines used to compile libnet]'
    '*:filename:_files'
)
_arguments -s $arguments
