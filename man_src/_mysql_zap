#compdef mysql_zap
# Documentation: https://man.archlinux.org/search?q=mysql_zap
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-\?,--help}'[Display help and exit]'
    '-I[Display help]'
    '-f[Force mode; do not ask for confirmation]'
    '-t[Test mode; show what would happen but do not kill anything]'
    '--signal[Specify the signal name or number to send]:signal'
    '*:filename:_files'
)
_arguments -s $arguments
