#compdef fdread

local arguments

arguments=(
    '-q[Turn on quiet mode]'
    '-r[Enable error recovery]'
    '-d[Specify the input floppy device, defaulting to /dev/fd0]:device'
    '-f[Value of the fill byte used for dummy blocks in recovery mode]:byte'
    '-o[Specify the output file]:file:_files'
    '-I[Read numsects sector ID fields and write their contents to stdout]:numsects'
    '-t[Specify the track number to start reading from]:track'
    '*:filename:_files'
)
_arguments -s $arguments
