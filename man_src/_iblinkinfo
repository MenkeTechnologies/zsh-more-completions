#compdef iblinkinfo

local arguments

arguments=(
    '--node-name-map[Node name map file]:file:_files'
    {--switch,-S}'[Start partial scan at the specified switch port]:port_guid'
    {--port-guid,-G}'[Same as -S]:port_guid'
    {--Direct,-D}'[Start partial scan at the port specified by directed route path]:dr_path'
    {--all,-a}'[Print all nodes found in a partial fabric scan]'
    {--hops,-n}'[Number of hops to include away from specified node]:hops'
    {--down,-d}'[Print only down links]'
    {--line,-l}'[Line mode: print all information for each link]'
    {--additional,-p}'[Print additional port settings]'
    '--load-cache[Filename of ibnetdiscover cache to load]:file:_files'
    '--diff[Filename of ibnetdiscover cache to diff]:file:_files'
    '--diffcheck[Specify checks to execute for --diff]:checks'
    '--filterdownports[Filename of ibnetdiscover cache to filter downports]:file:_files'
    {--outstanding_smps,-o}'[Specify the number of outstanding SMPs]:val'
    '--switches-only[Output only switches]'
    '--cas-only[Output only CAs]'
    {--config,-z}'[Use config file]:config:_files'
    {--Ca,-C}'[CA name to use]:ca_name'
    {--Port,-P}'[CA port number to use]:port'
    {--timeout,-t}'[Timeout in ms]:timeout'
    {--sm_port,-s}'[SM port LID]:lid'
    {--m_key,-y}'[M_Key to use in request]:key'
    {--errors,-e}'[Show send and receive errors]'
    {--verbose,-v}'[Increase verbosity level]'
    {--help,-h}'[Show help message]'
    {--version,-V}'[Show version]'
    '*:filename:_files'
)
_arguments -s $arguments
