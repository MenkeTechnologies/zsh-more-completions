#compdef chattr

local arguments

arguments=(
    '-R[Recursively change attributes of directories and their contents]'
    '-V[Be verbose with output and print the program version]'
    '-f[Suppress most error messages]'
    '-v[Set the file version/generation number]:version'
    '-p[Set the file project number]:project'
    '*:filename:_files'
)
_arguments -s $arguments
