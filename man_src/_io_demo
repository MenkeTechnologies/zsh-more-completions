#compdef io_demo

local arguments

arguments=(
    '-p[TCP port number to use]:port'
    '-n[Timeout for connecting to the peer]:timeout'
    '-o[Comma-separated string of IO operations]:operations'
    '-d[Data range that should be used]:range'
    '-b[Number of offcache IO buffers]:buffers'
    '-i[Number of iterations to run communication]:iterations'
    '-w[Number of outstanding requests]:requests'
    '-a[Number of outstanding requests per connection]:requests'
    '-k[Split the data transfer to chunks of this size]:size'
    '-r[Size of IO request packet]:size'
    '-t[Client timeout]:timeout'
    '-c[Number of connection retries on client]:retries'
    '-y[Retry interval]:interval'
    '-l[Time limit to run the IO client]:limit'
    '-s[Random seed to use for randomizing]:seed'
    '-v[Set verbose mode]'
    '-q[Enable data integrity and transaction check]'
    '-A[Use UCP Active Messages API instead of TAG API]'
    '-H[Use human-readable timestamps]'
    '-P[Set report printing interval]:interval'
    '*:filename:_files'
)
_arguments -s $arguments
