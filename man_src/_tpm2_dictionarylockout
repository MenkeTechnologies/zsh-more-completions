#compdef tpm2_dictionarylockout

local arguments

arguments=(
    '-s[setup dictionary-attack-lockout parameters]'
    '-c[clear dictionary-attack-lockout state]'
    {-l,--lockout-recovery-time}'[wait time in seconds before another lockout authentication attempt]:seconds'
    '-t[wait time in seconds before another DA-protected-object authentication attempt]:seconds'
    '-n[maximum number of allowed authentication attempts]:count'
    '-S[input session handle]:session_handle'
    '-h[display help information]'
    '-v[display version, supported tctis and exit]'
    '-V[increase verbosity of tool output]'
    '-Q[suppress informational output]'
    '-Z[enable errata fixups]'
    '-T[select the TCTI used for communication]:tcti'
    '*:filename:_files'
)
_arguments -s $arguments
