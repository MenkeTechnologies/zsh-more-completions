#compdef faraday-server

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Show this help message and exit]'
    '--ssl[Enable HTTPS]'
    '--debug[Run Faraday Server in debug mode]'
    '--start[Run Faraday Server in background]'
    '--stop[Stop Faraday Server]'
    '--restart[Restart Faraday Server]'
    '--nodeps[Skip dependency check]'
    '--port[Override server.ini port configuration]:PORT'
    '--websocket_port[Override server.ini websocket port configuration]:WEBSOCKET_PORT'
    '--bind_address[Override server.ini bind_address configuration]:BIND_ADDRESS'
    {-v,--version}'[Show program version number and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
