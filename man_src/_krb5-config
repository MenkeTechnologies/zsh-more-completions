#compdef krb5-config
# Documentation: https://man.archlinux.org/search?q=krb5-config
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--prefix[Print the prefix, or set prefix to dir]:dir:_directories'
    '--exec-prefix[Print the exec-prefix, or set exec-prefix to dir]:dir:_directories'
    '--libs[Output the set of libraries that should be linked against]:library'
    '--cflags[Output the set of flags to give to the C compiler when using the Heimdal libraries]'
    '*:filename:_files'
)
_arguments -s $arguments
