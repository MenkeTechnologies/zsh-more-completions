#compdef exfatfsck
# Documentation: https://man.archlinux.org/search?q=exfatfsck
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-a[Automatically repair the file system]'
    '-n[No-operation mode: check for errors but do not write anything]'
    '-p[Same as -a for compatibility with other *fsck]'
    '-V[Print version and copyright]'
    '-y[Same as -a for compatibility with other *fsck]'
    '*:filename:_files'
)
_arguments -s $arguments
