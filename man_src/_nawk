#compdef nawk

# Updated with latest nawk (one-true-awk) options

local arguments

arguments=(
    '-F[Set the input field separator]:separator'
    '-v[Assign a value to a variable before execution]:var=value'
    '-f[Read the AWK program source from file]:file:_files'
    '-mr[Set the maximum number of fields]:number'
    '-mf[Set the maximum number of fields]:number'
    '--posix[Use POSIX compatibility mode]'
    '--re-interval[Enable interval expressions in regular expressions]'
    '--version[Print version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
