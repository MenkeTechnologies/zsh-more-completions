#compdef tnftp

local arguments

arguments=(
    '-4[force IPv4 addresses only]'
    '-6[force IPv6 addresses only]'
    '-A[force active mode FTP]'
    '-a[use anonymous login]'
    '-d[enable debugging]'
    '-e[disable command line editing]'
    '-f[force cache reload for transfers through FTP or HTTP proxies]'
    '-g[disable file name globbing]'
    '-i[turn off interactive prompting during multiple file transfers]'
    '-N[use specified netrc file instead of ~/.netrc]:netrc:_files'
    '-n[do not attempt auto-login upon initial connection]'
    '-o[when auto-fetching, save contents in output]:output:_files'
    '-P[set the port number]:port'
    '-p[enable passive mode]'
    '-q[quit if the connection has stalled for specified seconds]:quittime'
    '-R[restart all non-proxied auto-fetches]'
    '-r[retry the connection attempt if it failed]:wait'
    '-s[use specified local IP address for all connections]:srcaddr'
    '-t[enable packet tracing]'
    '-T[set the maximum transfer rate]:direction\:maximum'
    '-u[upload files on the command line to url]:url'
    '-V[disable verbose and progress]'
    '-v[enable verbose and progress]'
    '-x[set the size of the socket send and receive buffers]:xfersize'
    '-?[display help and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
