#compdef mono-service

local arguments

arguments=(
    '-d[Use this option to specify the working directory for the service]:directory:_directories'
    '-l[Specify the file to use for locking]:lockfile:_files'
    '-m[Name to show in the syslog]:message'
    '-n[Specify the service to be launched]:name'
    '--debug[Do not redirect stdin and stdout, useful for debugging]'
    '--no-daemon[Do not redirect stdin and stdout, useful for debugging]'
    '*:filename:_files'
)
_arguments -s $arguments
