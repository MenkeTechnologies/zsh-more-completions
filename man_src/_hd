#compdef hd
# Documentation: https://man.archlinux.org/search?q=hd
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-b[One-byte octal display]'
    '-c[One-byte character display]'
    '-C[Canonical hex+ASCII display]'
    '-d[Two-byte decimal display]'
    '-e[Specify a format string to be used for displaying data]:format'
    '-f[Specify a file that contains one or more newline separated format strings]:file:_files'
    '-n[Interpret only length bytes of input]:length'
    '-o[Two-byte octal display]'
    '-s[Skip offset bytes from the beginning of the input]:offset'
    '-v[Cause hexdump to display all input data]'
    '-x[Two-byte hexadecimal display]'
    '*:filename:_files'
)
_arguments -s $arguments
