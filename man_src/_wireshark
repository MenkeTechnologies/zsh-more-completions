#compdef wireshark

# Updated with latest Wireshark options

local arguments

arguments=(
    '-a[Specify capture autostop criterion]:criterion'
    '-b[Enable multiple files mode]:criterion'
    '-B[Set capture buffer size in MiB (default: 4)]:size'
    '-c[Set maximum number of packets to capture]:count'
    '-C[Start with the given configuration profile]:profile'
    '-D[Print a list of capture interfaces and exit]'
    '--display[Specify X display to use]:display'
    '-f[Set the capture filter expression]:filter'
    '-g[Go to the given packet number]:packet_number'
    '(- * :)'-h[Print version and options and exit]'
    '-H[Hide the capture info dialog during live capture]'
    '-i[Set network interface or pipe for live capture]:interface'
    '-I[Put the interface in monitor mode]'
    '-j[Use after -J to change behavior when no exact match is found]'
    '-J[Jump to the packet matching the filter]:filter'
    '-k[Start the capture session immediately]'
    '-K[Load kerberos crypto keys from the specified keytab file]:keytab:_files'
    '-l[Turn on automatic scrolling during packet updates]'
    '-L[List data link types supported by the interface and exit]'
    '-m[Set the font name]:font'
    '-n[Disable network object name resolution]'
    '-N[Turn on name resolving for particular types]:flags'
    '-o[Set a preference or recent value]:preference'
    '-p[Do not put the interface into promiscuous mode]'
    '-P[Special path settings]:setting'
    '-r[Read packet data from file]:infile:_files'
    '-R[Specify a read filter]:filter'
    '-s[Set the default snapshot length]:snaplen'
    '-S[Automatically update the packet display]'
    '-t[Set the format of the packet timestamp]:format:(a ad adoy d dd e r u ud udoy)'
    '-v[Print the version and exit]'
    '-w[Set the default capture file name]:outfile:_files'
    '-X[Specify an option to be passed to a Wireshark module]:options'
    '-y[Set the data link type]:type'
    '-Y[Start with the given display filter]:filter'
    '-z[Collect various types of statistics]:statistics'
    '*:capture file:_files'
)
_arguments -s $arguments
