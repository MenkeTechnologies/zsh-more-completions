#compdef kate

local arguments

arguments=(
    {-s,--start}'[Start Kate with a given session]:name'
    '--startanon[Start Kate with a new anonymous session, implies -n]'
    {-n,--new}'[Force start of a new Kate instance]'
    {-b,--block}'[If using an already running Kate instance, block until it exits]'
    {-p,--pid}'[Only try to reuse kate instance with this PID]:pid'
    {-e,--encoding}'[Set encoding for the file to open]:encoding'
    {-l,--line}'[Navigate to this line]:line'
    {-c,--column}'[Navigate to this column]:column'
    {-i,--stdin}'[Read the contents of stdin]'
    '--tempfile[The files/URLs opened by the application will be deleted after use]'
    '*:filename:_files'
)
_arguments -s $arguments
