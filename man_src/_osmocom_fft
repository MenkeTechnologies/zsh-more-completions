#compdef osmocom_fft

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Show this help message and exit]'
    {-a,--args}'[Device args]:args'
    {-A,--antenna}'[Select RX antenna where appropriate]:antenna'
    {-s,--samp-rate}'[Set sample rate (bandwidth), minimum by default]:rate'
    {-f,--center-freq}'[Set frequency]:freq'
    {-c,--freq-corr}'[Set frequency correction in ppm]:ppm'
    {-g,--gain}'[Set gain in dB (default is midpoint)]:gain'
    {-W,--waterfall}'[Enable waterfall display]'
    {-S,--oscilloscope}'[Enable oscilloscope display]'
    '--avg-alpha[Set FFT sink averaging factor]:alpha'
    '--averaging[Enable FFT sink averaging]'
    '--ref-scale[Set dBFS=0dB input value]:scale'
    '--fft-size[Set number of FFT bins]:size'
    '--fft-rate[Set FFT update rate]:rate'
    {-v,--verbose}'[Use verbose console output]'
    '*:filename:_files'
)
_arguments -s $arguments
