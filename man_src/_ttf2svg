#compdef ttf2svg

local arguments

arguments=(
    {-l,-h}'[specify the range of characters by codepoint to be converted]:range'
    '--ascii[force usage of the ASCII character map instead of Unicode]'
    '--id[specify the value for the id attribute of the generated font element]:id'
    '-o[specify the pathname of the output SVG document]:output-path:_files'
    '--testcard[append a sequence of SVG text elements to the output as a test]'
    '*:filename:_files'
)
_arguments -s $arguments
