#compdef arpd

# Updated with latest iproute2 arpd options

local arguments

arguments=(
    {-h,-\?}'[Print help]'
    '-l[Dump the arpd database to stdout and exit]'
    '-f[Read and load an arpd database from FILE in text format]:FILE:_files'
    '-b[Set the location of the database file]:DATABASE:_files'
    '-a[Actively poll missing entries in the ARP table]:NUMBER'
    '-k[Suppress sending broadcast queries by the kernel]'
    '-n[Specify timeout of the negative cache]:TIME'
    '-p[Time to wait in seconds between polling attempts to the kernel ARP table]:TIME'
    '-R[Maximal steady rate of broadcasts sent by arpd in packets per second]:RATE'
    '-B[Number of broadcasts sent by arpd back to back (default 3)]:NUMBER'
    '*:interface:'
)
_arguments -s $arguments
