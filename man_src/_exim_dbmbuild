#compdef exim_dbmbuild
# Documentation: https://man.archlinux.org/search?q=exim_dbmbuild
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-nolc[Do not lowercase lookup keys]'
    '-nozero[Create files without terminating zeroes in keys or values]'
    '-noduperr[Do not treat duplicate keys as errors]'
    '-lastdup[Use data for the last duplicate instead of the first]'
    '-nowarn[Do not list duplicate keys to stderr]'
    '*:filename:_files'
)
_arguments -s $arguments
