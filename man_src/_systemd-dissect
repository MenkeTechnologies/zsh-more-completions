#compdef systemd-dissect

# Updated with fixes for descriptions

local arguments

arguments=(
    {-r,--read-only}'[Mount read-only]'
    '--fsck[Run fsck before mounting]:bool:(yes no)'
    '--mkdir[Make mount directory before mounting, if missing]'
    '--discard[Choose discard mode]:mode:(disabled loop all crypto)'
    '--root-hash[Specify root hash for verity]:hash'
    '--root-hash-sig[Specify PKCS7 signature of root hash for verity]:sig'
    '--verity-data[Specify data file with hash tree for verity]:file:_files'
    '--json[Generate JSON output]:mode:(pretty short off)'
    {-h,--help}'[Show help]'
    '--version[Show package version]'
    {-m,--mount}'[Mount the image to the specified directory]:directory:_directories'
    '-M[Shortcut for --mount --mkdir]'
    {-x,--copy-from}'[Copy files from image to host]:path'
    {-a,--copy-to}'[Copy files from host to image]:path'
    '*:filename:_files'
)
_arguments -s $arguments
