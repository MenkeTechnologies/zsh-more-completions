#compdef text2wave
# Documentation: https://man.archlinux.org/search?q=text2wave
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--mode[specify text mode]:mode'
    '-o[specify output file]:file:_files'
    '--otype[specify output type]:type:(riff aiff nist snd)'
    '-f[specify sample frequency]:frequency'
    '--scale[specify volume scale factor]:float'
    '--eval[evaluate Scheme expression]:expression'
    '*:filename:_files'
)
_arguments -s $arguments
