#compdef tpm2_sign

local arguments

arguments=(
    {-c,--key-context}'[context of the key for signing]:object:_files'
    {-p,--auth}'[authorization value for the key]:auth'
    {-g,--hash-algorithm}'[hash algorithm to use]:algorithm'
    {-s,--scheme}'[signing scheme]:algorithm'
    {-d,--digest}'[digest to be signed]:file:_files'
    {-t,--ticket}'[the ticket data from tpm2_hash]:file:_files'
    {-o,--signature}'[output signature file]:file:_files'
    {-f,--format}'[output signature format]:format'
    '--cphash[file path to record command parameter hash]:file:_files'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    {-V,--verbose}'[increase verbosity of tool output]'
    {-Q,--quiet}'[suppress informational output]'
    {-Z,--enable-errata}'[enable errata fixups]'
    {-R,--autoflush}'[autoflush objects created by the command]'
    '*:filename:_files'
)
_arguments -s $arguments
