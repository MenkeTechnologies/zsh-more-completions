#compdef parallel.moreutils

local arguments

arguments=(
    '-j[Limit the number of jobs run at the same time]:maxjobs'
    '-l[Wait as needed to avoid starting new jobs when load average is too high]:maxload'
    '-i[Replace {} in the command with the argument]'
    '-n[Number of arguments to pass to a command at a time]:count'
    '*:filename:_files'
)
_arguments -s $arguments
