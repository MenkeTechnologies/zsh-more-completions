#compdef mysqldbimport

local arguments

arguments=(
    '--help[Display help and exit]'
    '--bulk-insert[Use bulk insert statements for data]'
    {-d,--drop-first}'[Drop each database before importing]'
    '--dryrun[Import the files and generate the statements but do not execute them]'
    '--format[Input file format]:format:(sql grid csv tab vertical raw)'
    {-i,--import}'[Import type]:type:(definitions data both)'
    '--new-storage-engine[New storage engine for all tables]:engine'
    '--default-storage-engine[Default storage engine for tables]:engine'
    '--no-headers[Files do not contain column headers]'
    {-q,--quiet}'[Turn off all messages for quiet execution]'
    '--server[Connection information for the server]:server'
    '--skip[Skip specific objects]:objects'
    '--skip-blobs[Skip BLOB data]'
    '--skip-gtid[Skip GTID statements]'
    '--skip-rpl[Skip replication statements in the file]'
    '--table[Table definition for raw format]:definition'
    {-v,--verbose}'[Verbose output]'
    '--version[Display version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
