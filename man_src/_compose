#compdef run-mailcap

local arguments

arguments=(
    '--action[Perform the specified action on the files]:action'
    '--debug[Turn on extra information to find out what is happening]'
    '--nopager[Ignore any copiousoutput directive and send output to stdout]'
    '--norun[Display the found command without actually executing it]'
    '*:filename:_files'
)
_arguments -s $arguments
