#compdef flashrom

local arguments

arguments=(
    {-h,--help}'[Print help text]'
    {-R,--version}'[Print version (release)]'
    {-r,--read}'[Read flash and save to file]:file:_files'
    {-w,--write}'[Write file to flash]:file:_files'
    {-v,--verify}'[Verify flash against file]:file:_files'
    {-E,--erase}'[Erase flash memory]'
    {-V,--verbose}'[More verbose output]'
    {-c,--chip}'[Probe only for specified flash chip]:chipname'
    {-f,--force}'[Force specific operations]'
    {-n,--noverify}'[Do not auto-verify]'
    {-N,--noverify-all}'[Verify included regions only]'
    {-l,--layout}'[Read ROM layout from layoutfile]:layoutfile:_files'
    '--flash-name[Read out the detected flash name]'
    '--flash-size[Read out the detected flash size]'
    '--fmap[Read ROM layout from fmap embedded in ROM]'
    '--fmap-file[Read ROM layout from fmap in fmapfile]:fmapfile:_files'
    '--ifd[Read layout from an Intel Firmware Descriptor]'
    {-i,--image}'[Only flash image from flash layout]:name'
    {-o,--output}'[Log output to logfile]:logfile:_files'
    '--flash-contents[Assume flash contents to be ref-file]:ref-file:_files'
    {-L,--list-supported}'[Print supported devices]'
    {-p,--programmer}'[Specify the programmer device]:programmer'
    '*:filename:_files'
)

_arguments -s $arguments
