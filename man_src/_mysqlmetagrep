#compdef mysqlmetagrep

local arguments

arguments=(
    '--help[Display help and exit]'
    {-b,--body}'[Search the body of routines]'
    '--database[Search in a specific database]:pattern'
    {-e,--pattern}'[Pattern to use for matching]:pattern'
    '--format[Output format]:format:(grid csv tab vertical)'
    {--object-types,--search-objects}'[Object types to search]:types'
    {-G,--basic-regexp}'[Use basic regular expression matching]'
    '--regexp[Use REGEXP matching]'
    {-p,--print-sql}'[Print the SQL statement rather than executing it]'
    '--server[Connection information for the server]:server'
    '--sql[Display the SQL statement used for the search]'
    '--version[Display version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
