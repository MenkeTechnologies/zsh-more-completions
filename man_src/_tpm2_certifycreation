#compdef tpm2_certifycreation

local arguments

arguments=(
    {-C,--signingkey-context}'[context object for the key used to sign attestation]:object:_files'
    {-P,--signingkey-auth}'[authorization value for the signing key]:auth'
    {-c,--certifiedkey-context}'[context object for the key to be certified]:object:_files'
    {-g,--hash-algorithm}'[hash algorithm used to digest the creation data]:algorithm'
    {-s,--scheme}'[signing scheme used to sign the attestation data]:algorithm'
    {-d,--creation-hash}'[file containing the digest of the creation data]:file:_files'
    {-t,--ticket}'[the ticket file to validate creation data]:file:_files'
    {-o,--signature}'[file containing the signature of the attestation data]:file:_files'
    {-f,--format}'[output signature format selection]:format'
    {-q,--qualification}'[policy qualifier data]:file_or_hex'
    '--cphash[file path to record command parameter hash]:file:_files'
    '--rphash[file path to record response parameter hash]:file:_files'
    {-S,--session}'[the session created using tpm2_startauthsession]:file:_files'
    '--attestation[file to save attestation data]:file:_files'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    {-V,--verbose}'[increase verbosity of tool output]'
    {-Q,--quiet}'[suppress informational output]'
    {-Z,--enable-errata}'[enable errata fixups]'
    {-R,--autoflush}'[autoflush objects created by the command]'
    '*:filename:_files'
)
_arguments -s $arguments
