#compdef tracker3-info

local arguments

arguments=(
    {-f,--full-namespaces}'[show full namespaces for all keys and values]'
    {-c,--plain-text-content}'[show the plain text content of the resource]'
    {-i,--resource-is-iri}'[treat the argument as an IRI rather than a file path]'
    {-t,--turtle}'[output results as Turtle RDF]'
    '*:filename:_files'
)
_arguments -s $arguments
