#compdef ldns-config
# Documentation: https://man.archlinux.org/search?q=ldns-config
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--cflags[Show the C compiler flags needed to compile with ldns]'
    '--libs[Show the flags to be used to link with ldns]'
    '--version[Show the ldns version of the installed ldns library]'
    '--libversion[Show version of the binary API of the installed ldns library]'
    '--help[Show ldns-config usage description]'
    '*:filename:_files'
)
_arguments -s $arguments
