#compdef volatility

local arguments

arguments=(
    '(- * :)'{-h,--help}'[List all available options and their default values]'
    '--conf-file[User based configuration file]:file:_files'
    {-d,--debug}'[Debug Volatility]'
    '--plugins[Additional plugin directories to use (colon separated)]:dirs'
    '--info[Print information about all registered objects]'
    '--cache-directory[Directory where cache files are stored]:directory:_directories'
    '--cache[Use caching]'
    '--tz[Set the Olson timezone for displaying timestamps]:timezone'
    {-f,--filename}'[Filename to use when opening an image]:file:_files'
    '--profile[Name of the profile to load]:profile'
    {-l,--location}'[A URN location from which to load an address space]:location'
    {-w,--write}'[Enable write support]'
    '--dtb[DTB Address]:address'
    '--shift[Mac KASLR shift address]:address'
    '--output[Output in this format]:format:(text dot json sqlite3 xlsx)'
    '--output-file[Write output in this file]:file:_files'
    {-v,--verbose}'[Verbose information]'
    '--physical_shift[Linux kernel physical shift address]:address'
    '--virtual_shift[Linux kernel virtual shift address]:address'
    {-g,--kdbg}'[Specify a specific KDBG virtual address]:address'
    {-k,--kpcr}'[Specify a specific KPCR address]:address'
    '--force[Force utilization of suspect profile]'
    '--cookie[Specify the address of nt!ObHeaderCookie (Windows 10 only)]:address'
    '*:filename:_files'
)
_arguments -s $arguments
