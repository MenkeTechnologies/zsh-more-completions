#compdef gluster
# Documentation: https://man.archlinux.org/search?q=gluster
# Reference accessed: 2026-05-16

local arguments

arguments=(
  '--help[shows the help information]'
  '--version[shows the version]'
  '--print-logdir[shows the log directory]'
  '--print-statedumpdir[the state dump directory]'
  '*:filename:_files'
)

_arguments -s $arguments
