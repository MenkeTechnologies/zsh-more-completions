#compdef Thunar
# Documentation: https://man.archlinux.org/search?q=Thunar
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--bulk-rename[open the bulk rename dialog]'
    {-\?,--help}'[display help information]'
    {-V,--version}'[display version information]'
    '-B[open the bulk rename dialog]'
    '--daemon[run as a daemon]'
    '--display[X display to use]:display'
    {-q,--quit}'[quit a running Thunar instance]'
    '*:filename:_files'
)
_arguments -s $arguments
