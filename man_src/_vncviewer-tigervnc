#compdef vncviewer-tigervnc

local arguments

arguments=(
    '--display[Specify the X display on which the VNC viewer window should appear]:display'
    '--geometry[Standard X position and sizing specification]:geometry'
    '--listen[Listen on the given port for reverse connections]:port'
    '--SecurityTypes[Specify which security schemes to attempt]:types'
    {--passwd,--PasswordFile}'[Password file to use for authentication]:file:_files'
    '--X509CA[Path to CA certificate for authenticating remote servers]:path:_files'
    '--X509CRL[Path to certificate revocation list]:path:_files'
    '--Shared[Share the connection with other existing connections]'
    '--ViewOnly[Do not send keyboard or mouse events to the server]'
    '--AcceptClipboard[Accept clipboard changes from the server]'
    '--SetPrimary[Set the primary selection as well as the clipboard selection]'
    '--SendClipboard[Send clipboard changes to the server]'
    '--SendPrimary[Send the primary selection to the server as well]'
    '--Maximize[Maximize viewer window]'
    '--FullScreen[Start in full-screen mode]'
    '--FullScreenAllMonitors[Use all local monitors when switching to full-screen mode]'
    '--FullscreenSystemKeys[Pass special keys directly to the server in full-screen mode]'
    '--DesktopSize[Set remote desktop size]:widthxheight'
    '--RemoteResize[Dynamically resize the remote desktop as the local window size changes]'
    '--AutoSelect[Use automatic selection of encoding and pixel format]'
    '--FullColor[Tell the VNC server to send full-color pixels]'
    '--LowColorLevel[Select the reduced color level to use on slow links]:level'
    '--PreferredEncoding[Specify the preferred encoding]:encoding:(Tight ZRLE Hextile Raw)'
    '--NoJpeg[Disable lossy JPEG compression in Tight encoding]'
    '--QualityLevel[JPEG quality level (0=Low, 9=High)]:level'
    '--CompressLevel[Lossless compression level (0=Low, 6=High)]:level'
    '--CustomCompressLevel[Use custom compression level]'
    '--DotWhenNoCursor[Show the dot cursor when the server sends an invisible cursor]'
    '--PointerEventInterval[Time in milliseconds to rate-limit successive pointer events]:time'
    '--Log[Configure debug log settings]:logname\:dest\:level'
    '--MenuKey[Key which brings up the popup menu]:keysym-name'
    '--via[Create encrypted TCP tunnel to the gateway machine]:gateway'
    '*:host\:\:port:'
)
_arguments -s $arguments
