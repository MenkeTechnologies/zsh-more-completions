#compdef ipmon

local arguments

arguments=(
    '-a[Open all of the device logfiles for reading log entries from]'
    '-b[For rules which log the body of a packet, generate hex output]'
    '-B[Enable logging of the raw, unformatted binary data to the specified file]:logfile:_files'
    '-D[Cause ipmon to turn itself into a daemon]'
    '-f[Specify an alternative device/file from which to read the log information]:device:_files'
    '-F[Flush the current packet log buffer]'
    '-L[Change the default syslog facility that ipmon uses]:facility'
    '-n[Map IP addresses and port numbers back into hostnames and service names]'
    '-N[Set the logfile to be opened for reading NAT log records]:device:_files'
    '-o[Specify which log files to actually read data from]:logfiles'
    '-O[Specify which log files you do not wish to read from]:logfiles'
    '-p[Cause the port number in log messages to always be printed as a number]'
    '-P[Write the pid of the ipmon process to a file]:pidfile:_files'
    '-s[Packet information read in will be sent through syslogd]'
    '-S[Set the logfile to be opened for reading state log records]:device:_files'
    '-t[Read the input file/device in a manner akin to tail]'
    '-v[Show tcp window, ack and sequence fields]'
    '-x[Show the packet data in hex]'
    '-X[Show the log header record data in hex]'
    '*:filename:_files'
)
_arguments -s $arguments
