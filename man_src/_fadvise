#compdef fadvise

local arguments

arguments=(
    {-d,--fd}'[Apply advice to the given file descriptor]:file-descriptor'
    {-a,--advice}'[Specify the advice to apply]:advice:(normal sequential random noreuse willneed dontneed)'
    {-o,--offset}'[Specify the beginning offset of the range]:offset'
    {-l,--length}'[Specify the length of the range]:length'
    {-h,--help}'[Display help text and exit]'
    {-V,--version}'[Print version and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
