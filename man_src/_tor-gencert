#compdef tor-gencert

local arguments

arguments=(
    '-v[display verbose output]'
    '(- * :)'{-h,--help}'[display help text and exit]'
    {-r,--reuse}'[generate a new certificate, but not a new signing key]'
    '--create-identity-key[generate a new identity key]'
    '-i[read the identity key from the specified file]:filename:_files'
    '-s[write the signing key to the specified file]:filename:_files'
    '-c[write the certificate to the specified file]:filename:_files'
    '-m[number of months that the certificate should be valid]:months'
    '--passphrase-fd[file descriptor to read the passphrase from]:fd'
    '-a[advertise the address:port combination as this authority]:address\:port'
    '*:filename:_files'
)
_arguments -s $arguments
