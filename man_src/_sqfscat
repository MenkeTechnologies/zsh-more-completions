#compdef sqfscat

# Updated with fixes for broken option format and descriptions

local arguments

arguments=(
    '-v[Print version, licence and copyright information]'
    '-p[Use specified number of processors]:number'
    '-o[Skip specified bytes at start of destination]:bytes'
    '-ig[Treat errors writing files to output as non-fatal]'
    '-st[Treat all errors as fatal]'
    '-no-exit[Do not set exit code to nonzero on non-fatal errors]'
    '-da[Set data queue to specified Mbytes]:size'
    '-fr[Set fragment queue to specified Mbytes]:size'
    '-no-wild[Do not use wildcard matching in extract names]'
    '-r[Treat extract names as POSIX regular expressions]'
    '-h[Output options text to stdout]'
    '*:filename:_files'
)
_arguments -s $arguments
