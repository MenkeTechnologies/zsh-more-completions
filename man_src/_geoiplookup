#compdef geoiplookup
# Documentation: https://man.archlinux.org/search?q=geoiplookup
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-f[Specify a custom path to a single GeoIP datafile]:file:_files'
    '-d[Specify a custom directory containing GeoIP datafiles]:directory:_directories'
    '-v[List the date and build number for the GeoIP datafiles]'
    '*:filename:_files'
)
_arguments -s $arguments
