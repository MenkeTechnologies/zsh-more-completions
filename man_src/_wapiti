#compdef wapiti

local arguments

arguments=(
    {-u,--url}'[The URL that will be used as the base for the scan]:URL'
    '--scope[Set scan scope]:scope:(page folder domain url)'
    {-m,--module}'[Set the list of attack modules]:modules'
    '--list-modules[List available attack modules and exit]'
    {-l,--level}'[Set attack level]:level'
    {-p,--proxy}'[URL to use as a proxy for HTTP and HTTPS requests]:proxy_url'
    {-a,--auth-cred}'[Set credentials for HTTP authentication]:credentials'
    '--auth-type[Set authentication type]:type:(basic digest kerberos ntlm)'
    {-c,--cookie}'[Load cookies from a Wapiti JSON cookie file]:file:_files'
    '--skip-crawl[Do not crawl, use only provided URLs]'
    '--resume-crawl[Resume a previously stopped crawl]'
    '--flush-attacks[Flush attack history and rescan]'
    '--flush-session[Flush the entire session and rescan]'
    {-s,--start}'[Add a start URL for crawling]:URL'
    {-x,--exclude}'[Prevent the given URL from being scanned]:URL'
    {-r,--remove}'[Remove a parameter from scanned URLs]:parameter'
    '--skip[Skip named parameter]:parameter'
    {-d,--depth}'[Set the maximum crawl depth]:depth'
    '--max-links-per-page[Maximum number of links per page]:number'
    '--max-files-per-dir[Maximum number of files per directory]:number'
    '--max-scan-time[Maximum scan time in seconds]:seconds'
    '--max-parameters[Maximum number of parameters to test]:number'
    {-S,--scan-force}'[Set scan force level]:level:(paranoid sneaky polite normal aggressive insane)'
    {-t,--timeout}'[Time to wait for HTTP response in seconds]:seconds'
    {-H,--header}'[Set a custom HTTP header]:header'
    {-A,--user-agent}'[Set user agent string]:agent'
    '--verify-ssl[Set SSL verification]:yn:(0 1)'
    '--color[Enable colored output]'
    {-v,--verbose}'[Set verbosity level]:level'
    {-f,--format}'[Set report format]:format:(json html txt openvas vulneranet xml)'
    {-o,--output}'[Set the output path for the report]:path:_files'
    '--no-bugreport[Do not send bug report]'
    '--version[Print version and exit]'
    {-h,--help}'[Show detailed options description]'
    '*:filename:_files'
)
_arguments -s $arguments
