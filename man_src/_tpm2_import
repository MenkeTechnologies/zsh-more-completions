#compdef tpm2_import

local arguments

arguments=(
    {-G,--key-algorithm}'[algorithm used by the key to be imported]:algorithm'
    {-g,--hash-algorithm}'[hash algorithm for generating the object name]:algorithm'
    {-i,--input}'[filename of the key to be imported]:file:_files'
    {-C,--parent-context}'[the parent key object]:object:_files'
    {-U,--parent-public}'[parent key public data file]:file:_files'
    {-k,--encryption-key}'[optional encryption key file]:file:_files'
    {-r,--private}'[file path to save the encrypted private portion]:file:_files'
    {-u,--public}'[file path to save the public portion]:file:_files'
    {-a,--attributes}'[the object attributes]:attributes'
    {-P,--parent-auth}'[authorization value for the parent key]:auth'
    {-p,--key-auth}'[authorization value for the imported key]:auth'
    {-L,--policy}'[policy file or hex string for authorization]:policy'
    {-s,--seed}'[file containing the encrypted seed]:file:_files'
    '--passin[password for OpenSSL PEM file]:password'
    '--cphash[file path to record command parameter hash]:file:_files'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    {-V,--verbose}'[increase verbosity of tool output]'
    {-Q,--quiet}'[suppress informational output]'
    {-Z,--enable-errata}'[enable errata fixups]'
    {-R,--autoflush}'[autoflush objects created by the command]'
    '*:filename:_files'
)
_arguments -s $arguments
