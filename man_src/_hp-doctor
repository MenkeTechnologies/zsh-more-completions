#compdef hp-doctor
# Documentation: https://man.archlinux.org/search?q=hp-doctor
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-i,--interactive}'[Run in interactive mode]'
    '(- * :)'{-h,--help}'[Show help information]'
    {-l,--logging}'[Set the logging level]:level:(none info error warn debug)'
    {-g,--ldebug}'[Run in debug mode]'
    '*:filename:_files'
)
_arguments -s $arguments
