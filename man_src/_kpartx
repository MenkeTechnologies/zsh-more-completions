#compdef kpartx

local arguments

arguments=(
    '-a[Add partition mappings]'
    '-d[Delete partition mappings]'
    '-u[Update partition mappings]'
    '-l[List partition mappings that would be added with -a]'
    '-r[Read-only partition mappings]'
    '-p[Set device name-partition number delimiter]:delimiter'
    '-f[Force creation of mappings; overrides no_partitions feature]'
    '-g[Force GUID partition table (GPT)]'
    '-s[Sync mode; do not return until the partitions are created]'
    '-v[Operate verbosely]'
    '*:filename:_files'
)
_arguments -s $arguments
