#compdef i686-w64-mingw32-gprof

local arguments

arguments=(
    {-A,--annotated-source}'[Print annotated source code]:symspec'
    {-b,--brief}'[Brief output; do not print explanations]'
    {-C,--exec-counts}'[Print tally of functions and number of times each was called]:symspec'
    {-i,--file-info}'[Display summary information about the profile data files]'
    {-I,--directory-path}'[Specify search directories for source files]:dirs'
    {-J,--no-annotated-source}'[Do not print annotated source for the specified symbols]:symspec'
    {-L,--print-path}'[Print full path of source filenames]'
    {-p,--flat-profile}'[Print flat profile]:symspec'
    {-P,--no-flat-profile}'[Suppress flat profile for the specified symbols]:symspec'
    {-q,--graph}'[Print call graph analysis]:symspec'
    {-Q,--no-graph}'[Suppress call graph for the specified symbols]:symspec'
    {-t,--table-length}'[Set length of table for -p output]:num'
    {-y,--separate-files}'[Output annotated source in separate files]'
    {-Z,--no-exec-counts}'[Suppress exec counts for the specified symbols]:symspec'
    {-r,--function-ordering}'[Print suggested function ordering based on profiling data]'
    {-R,--file-ordering}'[Print suggested ordering of .o files]:map_file:_files'
    {-T,--traditional}'[Display output in traditional BSD style]'
    {-w,--width}'[Set output width]:width'
    {-x,--all-lines}'[Show all lines in annotated source]'
    '--demangle[Demangle C++ symbol names]:style'
    '--no-demangle[Do not demangle C++ symbol names]'
    {-a,--no-static}'[Suppress statically declared (private) functions]'
    {-c,--static-call-graph}'[Discover the programs static call graph]'
    {-D,--ignore-non-functions}'[Ignore symbols that are not functions]'
    {-k,--ignore}'[Delete arcs from sym1 to sym2]:from,to'
    {-l,--line}'[Print line-by-line profiling information]'
    '--inline-file-names[Print file names for inline functions]'
    {-m,--min-count}'[Do not print routines with fewer than num counts]:num'
    {-z,--display-unused-functions}'[Display routines that have zero usage]'
    {-d,--debug}'[Set debug level]:num'
    {-h,--help}'[Display help message]'
    {-s,--sum}'[Summarize profile data and write summary to gmon.sum]'
    {-v,--version}'[Print version number]'
    '*:filename:_files'
)
_arguments -s $arguments
