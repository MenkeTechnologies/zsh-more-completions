#compdef tpm2_getsessionauditdigest

local arguments

arguments=(
    {-P,--hierarchy-auth}'[authorization value for the endorsement hierarchy]:auth'
    {-c,--key-context}'[context object for the signing key]:object:_files'
    {-p,--auth}'[authorization value for key]:auth'
    {-q,--qualification}'[data to qualify the quote]:hex_string_or_path'
    {-s,--signature}'[signature output file]:file:_files'
    {-m,--message}'[message output file with quote data]:file:_files'
    {-f,--format}'[format selection for signature output]:format'
    {-g,--hash-algorithm}'[hash algorithm for signature]:algorithm'
    '--scheme[signing scheme used to sign the message]:algorithm'
    {-S,--session}'[path of the session that enables and records audit digests]:file:_files'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    {-V,--verbose}'[increase verbosity of tool output]'
    {-Q,--quiet}'[suppress informational output]'
    {-Z,--enable-errata}'[enable errata fixups]'
    {-R,--autoflush}'[autoflush objects created by the command]'
    '*:filename:_files'
)
_arguments -s $arguments
