#compdef mariadb-convert-table-format mysql_convert_table_format
# Documentation: https://man.archlinux.org/search?q=mariadb-convert-table-format
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-\?,--help}'[Display help and exit]'
    '--engine[Specify the storage engine to convert to]:engine'
    {-f,--force}'[Continue even if errors occur]'
    {-h,--host}'[Connect to the specified host]:host_name:_hosts'
    {-p,--password}'[Password to use for connection]:password'
    {-P,--port}'[Port number for connection]:port_num'
    {-S,--socket}'[Socket file for connection]:path:_files'
    '--type[Specify the storage engine to convert to]:engine'
    {-u,--user}'[User name for login]:user_name'
    {-v,--verbose}'[Verbose output]'
    {-V,--version}'[Display version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
