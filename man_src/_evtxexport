#compdef evtxexport

local arguments

arguments=(
    '-c[Specify the codepage of ASCII strings]:codepage'
    '-f[Output format]:format:(xml text)'
    '-h[Show this help]'
    '-l[Specify the file in which to log information about exported items]:file:_files'
    '-m[Export mode]:mode:(all items recovered)'
    '-p[Search PATH for the resource files]:path:_directories'
    '-r[Name of the directory containing the Registry files]:directory:_directories'
    '-s[Filename of the SYSTEM Registry file]:file:_files'
    '-S[Filename of the SOFTWARE Registry file]:file:_files'
    '-t[Event log type]:type:(application security system)'
    '-T[Use event template definitions to parse the event record data]'
    '-v[Verbose output to stderr]'
    '-V[Print version]'
    '*:filename:_files'
)
_arguments -s $arguments
