#compdef composefs-info
# Documentation: https://man.archlinux.org/search?q=composefs-info
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--basedir[Directory of backing files for the missing command]:path:_directories'
    '--filter[Only print entries whose name matches the given name]:name'
    '*:filename:_files'
)
_arguments -s $arguments
