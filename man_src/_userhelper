#compdef userhelper

local arguments

arguments=(
    '-t[Use text mode authentication]'
    '-w[Specify a program name to be run and arguments to be passed to it]:program:_command_names'
    '-c[Change the current user password]'
    '-f[Specify a new Full Name]:name'
    '-o[Specify a new Office]:office'
    '-p[Specify a new Office Phone]:phone'
    '-h[Specify a new Home Phone]:phone'
    '-s[Specify a new shell]:shell:_shells'
    '*:filename:_files'
)
_arguments -s $arguments
