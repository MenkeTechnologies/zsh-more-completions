#compdef twistd3

local arguments

arguments=(
    {-q,--quiet}'[no-op for backwards compatibility]'
    {-p,--profile}'[run the application under the profiler]:file:_files'
    '--profiler[specify the profiler to use]:name'
    '--savestats[save the Stats object rather than the text output]'
    {-b,--debug}'[run the application in the Python Debugger]'
    {-e,--encrypted}'[the specified tap/aos file is encrypted]:file:_files'
    '--euid[set only effective user-id rather than real user-id]'
    {-o,--no_save}'[do not save shutdown state]'
    '--originalname[behave as though the Application has no process name set]'
    {-l,--logfile}'[log to a specified file, - for stdout]:logfile:_files'
    '--logger[a fully-qualified name to a log observer factory]:logger'
    '--pidfile[save pid in specified file]:pidfile:_files'
    '--chroot[chroot to a supplied directory before running]:directory:_directories'
    {-d,--rundir}'[change to a supplied directory before running]:directory:_directories'
    {-u,--uid}'[the uid to run as]:uid'
    {-g,--gid}'[the gid to run as]:gid'
    '--umask[the octal file creation mask to apply]:mask'
    {-r,--reactor}'[choose which reactor to use]:reactor'
    '--help-reactors[list the names of possibly available reactors]'
    '--spew[write an extremely verbose log of everything]'
    {-f,--file}'[read the given .tap file]:file:_files'
    {-s,--source}'[load an Application from the given .tas file]:file:_files'
    {-y,--python}'[use the variable "application" from the given Python file]:file:_files'
    '--syslog[log to syslog instead of a file]'
    '--version[print version information and exit]'
    {-n,--nodaemon}'[do not daemonize, stay in foreground]'
    '--prefix[use the specified prefix when logging to logfile]:prefix'
    '*:filename:_files'
)
_arguments -s $arguments
