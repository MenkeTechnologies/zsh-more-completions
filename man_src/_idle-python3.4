#compdef idle-python3.4

local arguments

arguments=(
    '-h[Print help message and exit]'
    '-n[Run IDLE without a subprocess]'
    '-e[Open an edit window]'
    '-i[Open a shell window]'
    '-c[Run the command in a shell]:cmd'
    '-r[Run script from file]:file:_files'
    '-d[Enable the debugger]'
    '-s[Run $IDLESTARTUP or $PYTHONSTARTUP before anything else]'
    '-t[Set the title of the shell window]:title'
    '*:filename:_files'
)
_arguments -s $arguments
