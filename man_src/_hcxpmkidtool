#compdef hcxpmkidtool

local arguments

arguments=(
    '-p[Input PMKID hash file]:file:_files'
    '-w[Output PMK, ESSID, and password]:file:_files'
    '-W[Output PMK, ESSID, and password (verbose)]:file:_files'
    '-K[Output PMK and ESSID]:file:_files'
    '-h[Show help]'
    '-v[Show version]'
    '--help[Show help]'
    '--version[Show version]'
    '*:filename:_files'
)
_arguments -s $arguments
