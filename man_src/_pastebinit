#compdef pastebinit

local arguments

arguments=(
    '-a[Specify an author name]:author'
    '-b[Specify the pastebin URL to use]:url'
    '-E[Specify the text encoding]:encoding'
    '-f[Specify the format of the paste]:format'
    '-i[Read from file instead of stdin]:file:_files'
    '-l[List available pastebins]'
    '-j[Display the paste URL in JSON format]'
    '-m[Specify the syntax highlighting]:syntax'
    '-t[Set the title of the paste]:title'
    '-P[Use a custom paste format parameter]'
    '-p[Specify a password for the paste]:password'
    '-u[Specify a username]:username'
    '*:filename:_files'
)
_arguments -s $arguments
