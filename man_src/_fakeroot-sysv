#compdef fakeroot-sysv

local arguments

arguments=(
    {-l,--lib}'[Specify an alternative wrapper library]:library:_files'
    '--faked[Specify an alternative binary to use as faked]:binary:_files'
    '-s[Save the fakeroot environment to save-file on exit]:save-file:_files'
    '-i[Load a fakeroot environment previously saved using -s]:load-file:_files'
    {-u,--unknown-is-real}'[Use real ownership of files previously unknown to fakeroot]'
    '-b[Specify fd base (TCP mode only)]:fd'
    '-h[Display help]'
    '-v[Display version]'
    '*:filename:_files'
)
_arguments -s $arguments
