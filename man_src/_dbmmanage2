#compdef dbmmanage dbmmanage2

local arguments

arguments=(
    '-d[Use crypt encryption (default except on Win32/Netware)]'
    '-m[Use MD5 encryption (default on Win32/Netware)]'
    '-s[Use SHA1 encryption]'
    '-p[Use plaintext (not recommended)]'
    '*:filename:_files'
)
_arguments -s $arguments
