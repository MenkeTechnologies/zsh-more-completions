#compdef uhsoctl

local arguments

arguments=(
    '-a[Specify APN to connect to]:apn'
    '-c[Specify CID (Context ID) to use]:cid'
    '-p[Specify SIM PIN]:pin'
    '-u[Specify username]:username'
    '-k[Specify password]:password'
    '-r[Path to resolv.conf]:file:_files'
    '-f[Explicitly set the serial port to use as controlling terminal]:port'
    '-b[Fork into background directly, before a connection has been established]'
    '-n[Never fork into background, run entirely in foreground]'
    '*:filename:_files'
)
_arguments -s $arguments
