#compdef fixproc

local arguments

arguments=(
    '--min[Minimum number of processes that should be running, defaults to 1]:n'
    '--max[Maximum number of processes that should be running, defaults to 1]:n'
    '--check[Check process against database]'
    '--kill[Kill process, wait 5 seconds, kill -9 if still exists]'
    '--restart[Kill process, wait 5 seconds, kill -9 if still exists, then start again]'
    '--exist[Check if process exists and count is within min/max range]'
    '--fix[Check process against database and fix if needed]'
    '*:filename:_files'
)
_arguments -s $arguments
