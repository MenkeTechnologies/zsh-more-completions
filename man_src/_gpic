#compdef gpic

local arguments

arguments=(
    '-C[Be compatible with tpic]'
    '-n[Do not use groff extensions]'
    '-S[Safer mode, do not execute sh commands]'
    '-T[Set output device]:dev'
    '-v[Print the version number]'
    '-z[Do not output any picture, only the drawing commands]'
    '*:filename:_files'
)
_arguments -s $arguments
