#compdef electrum

local arguments

arguments=(
    {-g,--gui}'[Select user interface]:interface:(qt lite gtk text)'
    {-w,--wallet}'[Use wallet from specified path]:wallet_path:_files'
    {-o,--offline}'[Remain offline]'
    {-a,--all}'[Show all addresses]'
    {-b,--balance}'[Show the balance of listed addresses]'
    {-l,--labels}'[Show the labels of listed addresses]'
    {-f,--fee}'[Set transaction fee]:fee'
    {-F,--fromaddr}'[Set source address for payto/mktx]:address'
    {-c,--changeaddr}'[Set the change address for payto/mktx]:address'
    {-s,--server}'[Set server host\:port\:protocol]:server'
    {-p,--proxy}'[Set proxy \[type\:\]host\[\:port\]]:proxy'
    {-v,--verbose}'[Show debugging information]'
    {-P,--portable}'[Portable wallet]'
    {-L,--lang}'[Default language used in GUI]:language'
    {-u,--usb}'[Turn on support for hardware wallets]'
    '*:filename:_files'
)
_arguments -s $arguments
