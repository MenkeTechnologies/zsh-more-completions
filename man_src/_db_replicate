#compdef db_replicate

local arguments

arguments=(
    '-h[Specify a home directory for the database environment]:directory:_directories'
    '-L[Log the execution to the specified file]:file:_files'
    '-M[Start as the master site of the replication group]'
    '-P[Specify an environment password]:password'
    '-T[Specify the number of replication message processing threads]:threads'
    '-t[Specify how often to check for program interruption]:seconds'
    '-V[Write the library version number and exit]'
    '-v[Turn on replication verbose messages]'
    '*:filename:_files'
)
_arguments -s $arguments
