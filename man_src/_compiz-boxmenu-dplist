#compdef compiz-boxmenu-dplist
# Documentation: https://man.archlinux.org/search?q=compiz-boxmenu-dplist
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-h[Show help options]'
    {-i,--images}'[Use images in the desktop list]'
    {-d,--desktop-icon}'[Use specified icon as the desktop icon]:icon'
    '*:filename:_files'
)
_arguments -s $arguments
