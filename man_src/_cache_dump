#compdef cache_dump
# Documentation: https://man.archlinux.org/search?q=cache_dump
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Print help and exit]'
    {-V,--version}'[Print version information and exit]'
    {-r,--repair}'[Repair the metadata whilst dumping it]'
    '-o[Specify an output file for the xml, rather than printing to stdout]:file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
