#compdef tpm2_readpublic

local arguments

arguments=(
    {-c,--object-context}'[context of the object to read]:object:_files'
    {-o,--output}'[output file for the public portion]:file:_files'
    {-n,--name}'[output file for the name]:file:_files'
    {-q,--qualified-name}'[output file for the qualified name]:file:_files'
    {-t,--serialized-handle}'[output file for the serialized handle]:file:_files'
    '--cphash[file path to record command parameter hash]:file:_files'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    {-V,--verbose}'[increase verbosity of tool output]'
    {-Q,--quiet}'[suppress informational output]'
    {-Z,--enable-errata}'[enable errata fixups]'
    {-R,--autoflush}'[autoflush objects created by the command]'
    '*:filename:_files'
)
_arguments -s $arguments
