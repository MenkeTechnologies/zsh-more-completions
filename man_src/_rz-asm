local arguments

arguments=(
    '-a[set architecture to assemble/disassemble (see -L)]:arch'
    '-A[show analysis information from given hexpairs]'
    '-b[set cpu register size (8, 16, 32, 64)]:bits:(8 16 32 64)'
    '-B[binary input/output (-l is mandatory for binary input)]'
    '-c[select specific CPU (depends on arch)]:cpu'
    '-C[output in C format]'
    {-d,-D}'[disassemble from hexpair bytes (-D show hexpairs)]'
    '-e[use big endian instead of little endian]'
    '-E[display ESIL expression (same input as in -d)]'
    '-f[read data from file]:file:_files'
    '-F[specify input and/or output filters]:filter'
    {-h,-hh}'[show this help, -hh for long]'
    '-i[ignore/skip N bytes of the input buffer]:N'
    '-j[output in json format]'
    '-k[select operating system]:os:(linux windows darwin)'
    '-l[input/output length]:length'
    '-L[list asm plugins (a=asm, d=disasm, A=analyze, e=ESIL)]'
