#compdef nbdkit

local arguments

arguments=(
    '--help[Display help]'
    '-4[Listen on IPv4 only]'
    '--ipv4-only[Listen on IPv4 only]'
    '-6[Listen on IPv6 only]'
    '--ipv6-only[Listen on IPv6 only]'
    {-D,--debug}'[Enable debug messages]'
    '--dump-config[Dump config and exit]'
    '--dump-plugin[Dump plugin information and exit]'
    '--exit-with-parent[Exit when the parent process exits]'
    {-e,--export,--export-name,--exportname}'[Set the export name]:name'
    '--filter[Add a filter]:filter'
    {-f,--foreground,--no-fork}'[Do not fork into the background]'
    {-g,--group}'[Change group after starting up]:group'
    {-i,--ip-addr,--ipaddr}'[Listen on the specified interface]:address'
    '--log[Log to specified destination]:destination:(stderr syslog)'
    '--mask-handshake[Mask handshake flags]:flags'
    {-n,--new-style,--newstyle}'[Use the newstyle NBD protocol (default)]'
    '--no-sr[Do not advertise structured replies]'
    {-o,--old-style,--oldstyle}'[Use the oldstyle NBD protocol]'
    {-P,--pid-file,--pidfile}'[Write PID file]:pidfile:_files'
    {-p,--port}'[Change the TCP/IP port number]:port'
    {-r,--read-only,--readonly}'[Export as read-only]'
    '--run[Run the specified command]:command'
    '--selinux-label[Set SELinux label]:label'
    {-s,--single,--stdin}'[Handle a single NBD connection on stdin/stdout]'
    '--swap[Do not perform an mlockall at startup]'
    {-t,--threads}'[Set the number of threads per connection]:threads'
    '--tls[Require TLS]:mode:(off on require)'
    '--tls-certificates[Path to TLS certificates directory]:directory:_directories'
    '--tls-psk[Path to TLS PSK file]:file:_files'
    '--tls-verify-peer[Require TLS peer verification]'
    {-U,--unix}'[Listen on a Unix domain socket]:socket:_files'
    {-u,--user}'[Change user after starting up]:user'
    {-v,--verbose}'[Enable verbose messages]'
    {-V,--version}'[Print the version number and exit]'
    '--vsock[Listen on a vsock socket]'
    '*:filename:_files'
)
_arguments -s $arguments
