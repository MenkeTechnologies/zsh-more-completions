#compdef jps

local arguments

arguments=(
    '-q[Suppress the output of the class name, JAR file name, and arguments]'
    '-m[Output the arguments passed to the main method]'
    '-l[Output the full package name for the main class or the full path name of the JAR file]'
    '-v[Output the arguments passed to the JVM]'
    '-V[Output the arguments passed to the JVM through the flags file]'
    '-J[Pass option to the Java launcher]:option'
    '*:filename:_files'
)
_arguments -s $arguments
