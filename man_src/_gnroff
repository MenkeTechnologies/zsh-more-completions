#compdef gnroff

local arguments

arguments=(
    '-a[Generate a text approximation of the typeset output]'
    '-b[Print a backtrace when an error or warning occurs]'
    '-c[Disable color output]'
    '-C[Enable compatibility mode]'
    '-d[Define a string or macro]:cs'
    '-D[Set default input encoding]:enc'
    '-e[Preprocess with eqn]'
    '-E[Inhibit all error messages]'
    '-f[Set the default font family]:fam'
    '-F[Set font directory path]:dir:_directories'
    '-g[Preprocess with grn]'
    '-G[Preprocess with grap]'
    '-I[Search directory for input files]:dir:_directories'
    '-j[Preprocess with chem]'
    '-k[Preprocess with preconv]'
    '-K[Set input encoding]:encoding'
    '-l[Spool the output to a printer]'
    '-L[Pass arg to the spooler]:arg'
    '-m[Read macro file]:name'
    '-M[Set the macro directory path]:dir:_directories'
    '-n[Set the initial page number]:num'
    '-N[Do not allow newlines within eqn delimiters]'
    '-o[Output only the specified pages]:list'
    '-p[Preprocess with pic]'
    '-P[Pass arg to the postprocessor]:arg'
    '-r[Set number register]:cn'
    '-R[Preprocess with refer]'
    '-s[Preprocess with soelim]'
    '-S[Safer mode]'
    '-t[Preprocess with tbl]'
    '-T[Set output device]:dev'
    '-U[Unsafe mode]'
    '-v[Print version information]'
    '-V[Output the pipeline on stdout instead of executing it]'
    '-w[Enable warning]:name'
    '-W[Inhibit warning]:name'
    '-z[Suppress output]'
    '-Z[Do not automatically postprocess]'
    '*:filename:_files'
)
_arguments -s $arguments
