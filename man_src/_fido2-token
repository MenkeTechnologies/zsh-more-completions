#compdef fido2-token

local arguments

arguments=(
    '-C[Change the PIN of device]'
    '-D[Delete the resident credential specified by id from device]:id'
    '-G[Get a CTAP 2.1 large blob]'
    '-I[Retrieve information on device]'
    '-L[List authenticators found by the operating system]'
    '-R[Perform a reset on device]'
    '-S[Set the PIN of device]'
    '-V[Print version information]'
    '-d[Emit debugging output on stderr]'
    '*:filename:_files'
)
_arguments -s $arguments
