#compdef kismetdb_to_wiglecsv

local arguments

arguments=(
    {-i,--in}'[Input kismetdb file]:filename:_files'
    {-o,--out}'[Output Wigle CSV file]:filename:_files'
    {-f,--force}'[Force writing to the target file, even if it exists]'
    {-r,--rate-limit}'[Limit updated records to one update per rate seconds per device]:rate'
    {-c,--cache-limit}'[Maximum number of devices to cache]:limit'
    {-v,--verbose}'[Verbose output]'
    {-s,--skip-clean}'[Do not clean (SQL vacuum) input database]'
    {-e,--exclude}'[Exclude records within dist meters of the lat,lon provided]:lat,lon,dist'
    '*:filename:_files'
)
_arguments -s $arguments
