#compdef hp-makeuri
# Documentation: https://man.archlinux.org/search?q=hp-makeuri
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-p,--port}'[Specify port number]:port'
    {-c,--cups}'[Show the CUPS URI only (quiet mode)]'
    {-s,--sane}'[Show the SANE URI only (quiet mode)]'
    {-f,--fax}'[Show the HP Fax URI only (quiet mode)]'
    {-l,--logging}'[Set the logging level]:level:(none info error warn debug)'
    {-g,--ldebug}'[Run in debug mode]'
    '(- * :)'{-h,--help}'[Show help information]'
    '*:filename:_files'
)
_arguments -s $arguments
