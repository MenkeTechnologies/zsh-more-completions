#compdef mysqldbexport

local arguments

arguments=(
    '--help[Display help and exit]'
    '--all[Export all databases]'
    '--bulk-insert[Use bulk insert statements for data]'
    '--comment-rpl[Place replication statements inside comments]'
    '--display[Display format]:format:(brief full names)'
    {-e,--export}'[Export type]:type:(definitions data both)'
    '--exclude[Exclude specific objects]:pattern'
    '--file-per-table[Write each table data to a separate file]'
    '--format[Output format]:format:(sql grid csv tab vertical)'
    '--locking[Locking type]:type:(no-locks lock-all snapshot)'
    '--no-headers[Suppress column headers for grid/csv/tab display]'
    {-q,--quiet}'[Turn off all messages for quiet execution]'
    {-G,--basic-regexp}'[Use basic regular expression matching]'
    '--regexp[Patterns use REGEXP matching]'
    '--rpl[Include replication commands]:mode:(master slave both)'
    '--rpl-file[Output replication statements to file]:file:_files'
    '--rpl-user[Replication user and password]:user:password'
    '--server[Connection information for the server]:server'
    '--skip[Skip specific objects]:objects'
    '--skip-blobs[Skip BLOB data]'
    '--skip-gtid[Skip GTID statements]'
    {-v,--verbose}'[Verbose output]'
    '--version[Display version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
