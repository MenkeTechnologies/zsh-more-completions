#compdef libinput-debug-events

local arguments

arguments=(
    '--device[Use the given device with the path backend]:device:_files'
    '--grab[Exclusively grab all opened devices]'
    '--help[Print help]'
    '--quiet[Only print libinput messages, do not print anything from this tool]'
    '--show-keycodes[Show keycodes without obfuscation]'
    '--udev[Use the udev backend to listen for device notifications on the given seat]:seat'
    '--verbose[Use verbose output]'
    '--disable-sendevents[Set the send-events option to disabled for matching patterns]:pattern'
    '--enable-tap[Enable tap-to-click]'
    '--disable-tap[Disable tap-to-click]'
    '--enable-drag[Enable tap-and-drag]'
    '--disable-drag[Disable tap-and-drag]'
    '--enable-drag-lock[Enable tap-and-drag lock]'
    '--disable-drag-lock[Disable tap-and-drag lock]'
    '--enable-natural-scrolling[Enable natural scrolling]'
    '--disable-natural-scrolling[Disable natural scrolling]'
    '--enable-left-handed[Enable left handed button configuration]'
    '--disable-left-handed[Disable left handed button configuration]'
    '--enable-middlebutton[Enable middle button emulation]'
    '--disable-middlebutton[Disable middle button emulation]'
    '--enable-dwt[Enable disable-while-typing]'
    '--disable-dwt[Disable disable-while-typing]'
    '--set-click-method[Set the desired click method]:method:(none clickfinger buttonareas)'
    '--set-scroll-method[Set the desired scroll method]:method:(none twofinger edge button)'
    '--set-scroll-button[Set the button to the given button code]:button'
    '--set-profile[Set pointer acceleration profile]:profile:(adaptive flat)'
    '--set-speed[Set pointer acceleration speed (-1 to 1)]:value'
    '--set-tap-map[Set button mapping for tapping]:map:(lrm lmr)'
    '*:filename:_files'
)
_arguments -s $arguments
