#compdef mysqluc

local arguments

arguments=(
    '--help[Display help and exit]'
    {-e,--execute}'[Execute the specified utility command and exit]:command'
    '--utildir[Path to MySQL Utilities directory]:path:_directories'
    {-v,--verbose}'[Verbose output]'
    '--quiet[Turn off all messages for quiet execution]'
    '--version[Display version information and exit]'
    '--width[Display width]:number'
    '*:filename:_files'
)
_arguments -s $arguments
