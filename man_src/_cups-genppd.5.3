#compdef cups-genppd.5.3

local arguments

arguments=(
    '-h[Show help message]'
    '-L[List available translations]'
    '-M[List available printer models]'
    '-V[Show version information and defaults]'
    '-N[Localize numbers]'
    '-l[Output PPDs translated for the specified locale]:locale'
    '-p[Output PPDs in directory prefix]:directory:_directories'
    '-d[Embed directory prefix in PPD file]:directory:_directories'
    '-s[Generate simplified PPD files]'
    '-a[Generate all (simplified and full) PPD files]'
    '-q[Quiet mode]'
    '-v[Verbose mode]'
    '-z[Compress PPD files]'
    '-Z[Do not compress PPD files]'
    '-S[Skip PPD files with duplicate model identifiers]'
    '-R[Generate every Nth PPD file]:size'
    '-r[Generate the PPD files with specified divisor]:divisor'
    '*:filename:_files'
)
_arguments -s $arguments
