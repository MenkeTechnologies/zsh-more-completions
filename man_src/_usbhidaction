#compdef usbhidaction

local arguments

arguments=(
    '-d[Toggle the daemon flag]'
    '-e[Instruct usbhidaction to die early]'
    '-i[Ignore HID items in the configuration file that do not exist in the device]'
    '-v[Be verbose, and do not become a daemon]'
    '-c[Specify a path name for the configuration file]:config:_files'
    '-t[Specify a path name for the HID usage table file]:table:_files'
    '-f[Specify a path name for the device to operate on]:device:_files'
    '-p[Specify an alternate file in which to store the process ID]:pidfile:_files'
    '*:filename:_files'
)
_arguments -s $arguments
