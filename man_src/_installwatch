#compdef installwatch

local arguments

arguments=(
    {-o,--logfile}'[Direct output from the logged command to the specified file]:file:_files'
    {-r,--root}'[Set the directory under which meta-info and translated files will be stored]:dir:_directories'
    {-t,--trans}'[Toggle translation capabilities]'
    {-e,--exclude}'[Set a comma separated list of neutral directories not concerned by translation]:dirs'
    {-d,--dbgfile}'[Specify a debug file]:file:_files'
    {-v,--dbglvl}'[Set the debug level]:level'
    '*:filename:_files'
)
_arguments -s $arguments
