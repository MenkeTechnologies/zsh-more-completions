#compdef irqtop

local arguments

arguments=(
    {-d,--delay}'[Delay updates]:seconds'
    {-o,--output}'[Define which output columns to use]:columns'
    {-s,--sort}'[Specify sort column]:column'
    {-h,--help}'[Display help]'
    {-V,--version}'[Display version]'
    '*:filename:_files'
)
_arguments -s $arguments
