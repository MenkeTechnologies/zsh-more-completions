#compdef isympy3

local arguments

arguments=(
    {-c,--console}'[Select type of interactive session]:type:(ipython python)'
    {-p,--pretty}'[Setup pretty printing]:type:(unicode ascii no)'
    {-t,--types}'[Setup ground types]:type:(gmpy gmpy1 python)'
    {-o,--order}'[Setup ordering of terms]:order:(lex grlex grevlex rev-lex rev-grlex rev-grevlex)'
    {-q,--quiet}'[Print only version information at startup]'
    {-d,--doctest}'[Use the doctest format for output]'
    {-C,--no-cache}'[Disable caching mechanism]'
    {-a,--auto-symbols}'[Automatically construct missing symbols]'
    {-i,--int-to-Integer}'[Automatically wrap int literals with Integer]'
    {-I,--interactive}'[Equivalent to -a -i]'
    {-D,--debug}'[Enable debugging output]'
    {-h,--help}'[Show help message and exit]'
    '--version[Show version number and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
