#compdef ipf

local arguments

arguments=(
    '-6[Display filter lists and states for IPv6]'
    '-A[Set the list to make changes to the active list (default)]'
    '-c[Generate output files for a compiler that supports the specified language]:language'
    '-d[Turn debug mode on]'
    '-D[Disable the filter]'
    '-E[Enable the filter]'
    '-F[Specify which filter list to flush]:list:(i o a)'
    '-f[Specify which files to use for input]:filename:_files'
    '-I[Set the list to make changes to the inactive list]'
    '-l[Toggle default logging of packets]:type:(pass block nomatch)'
    '-n[No-change mode: prevent ipf from making any ioctl calls]'
    '-o[Force rules to be added/deleted to/from the output list]'
    '-P[Add rules as temporary entries in the authentication rule table]'
    '-r[Remove matching filter rules rather than add them]'
    '-s[Swap the active filter list in use to be the other one]'
    '-T[Allow run-time changing of IPFilter kernel variables]:optionlist'
    '-v[Turn verbose mode on]'
    '-V[Show version information]'
    '-y[Manually resync the in-kernel interface list with the current interface list]'
    '-z[For each rule in the input file, reset the statistics to zero]'
    '-Z[Zero global statistics held in the kernel for filtering only]'
    '*:filename:_files'
)
_arguments -s $arguments
