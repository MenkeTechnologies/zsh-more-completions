#compdef errno
# Documentation: https://man.archlinux.org/search?q=errno
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-l,--list}'[List all errno values]'
    {-s,--search}'[Search for errors whose description contains all the given words]'
    {-S,--search-all-locales}'[Like --search, but searches all installed locales]'
    '*:filename:_files'
)
_arguments -s $arguments
