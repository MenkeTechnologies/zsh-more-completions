#compdef gio

local arguments

arguments=(
    {-T,--no-target-directory}'[Do not treat the last argument as a target directory]'
    {-p,--progress}'[Show progress]'
    {-i,--interactive}'[Prompt before overwrite]'
    '--preserve[Preserve permissions and timestamps]'
    {-b,--backup}'[Backup existing destination files]'
    {-P,--no-dereference}'[Never follow symbolic links]'
    {-w,--query-writable}'[List writable attributes]'
    {-f,--filesystem}'[Get filesystem info]'
    {-a,--attributes}'[Attributes to get]:ATTRIBUTES'
    {-n,--nofollow-symlinks}'[Do not follow symbolic links]'
    {-h,--hidden}'[Show hidden files]'
    {-l,--long}'[Use a long listing format]'
    {-u,--print-uris}'[Print full URIs]'
    '--parent[Create parent directories as needed]'
    {-d,--dir}'[Specify a directory location]:LOCATION'
    '--file[Specify a file location]:LOCATION'
    {-D,--direct}'[Open file directly]:LOCATION'
    {-s,--silent}'[Silent mode]:LOCATION'
    '--no-moves[Do not move files, only copy]'
    {-m,--mounts}'[Show mount points]'
