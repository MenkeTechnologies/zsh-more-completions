#compdef tifftopnm
# Documentation: https://man.archlinux.org/search?q=tifftopnm
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--alphaout[write alpha channel to PGM file]:alpha-filename:_files'
    '--respectfillorder[respect the fillorder tag in the TIFF input]'
    '--headerdump[dump TIFF file information to stderr]'
    '*:filename:_files'
)
_arguments -s $arguments
