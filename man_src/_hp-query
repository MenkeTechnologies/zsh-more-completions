#compdef hp-query

local arguments

arguments=(
    {-n,--non-interactive}'[Run in non-interactive mode]'
    {-l,--logging}'[Set the logging level]:level:(none info error warn debug)'
    {-g,--ldebug}'[Run in debug mode]'
    '(- * :)'{-h,--help}'[Show help information]'
    {-d,--device}'[Specify model by device URI]:device_uri'
    {-m,--model}'[Specify normalized model name]:model_name'
    {-r,--raw}'[Specify raw model name]:model_name'
    {-k,--key}'[Specify key to query]:key'
    {-a,--all}'[Query all keys]'
    {-s,--sep}'[Specify the separator when multiple keys are queried]:separator'
    '-x[Suppress trailing linefeed]'
    '*:filename:_files'
)
_arguments -s $arguments
