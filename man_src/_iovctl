#compdef iovctl

local arguments

arguments=(
    '-C[Enable SR-IOV on the specified PF device and create VF children]'
    '-d[Specify the PF device to use for the given operation]:device'
    '-D[Delete all VF children of the specified PF device]'
    '-f[Specify the pathname of the configuration file]:config:_files'
    '-n[Perform a dry-run]'
    '-S[Read the configuration schema from the specified device and print its contents]'
    '*:filename:_files'
)
_arguments -s $arguments
