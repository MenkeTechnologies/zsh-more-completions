#compdef crunchgen

local arguments

arguments=(
    '-c[Set output C file name]:c file:_files'
    '-e[Set crunched binary executable file name]:exec file:_files'
    '-f[Flush cache and force recalculation of cached parameters]'
    '-l[List names this binary will respond to]'
    '-h[Set the name of a file to be included at the beginning of the Makefile]:file:_files'
    '-m[Set output Makefile name]:makefile:_files'
    '-o[Add make obj rules to each program make target]'
    '-p[Set the pathname to prepend to srcdir when computing objdir]:path:_directories'
    '-q[Quiet operation, suppress status messages]'
    '*:filename:_files'
)
_arguments -s $arguments
