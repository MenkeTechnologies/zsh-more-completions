#compdef lv2apply
# Documentation: https://man.archlinux.org/search?q=lv2apply
# Reference accessed: 2026-05-16

local arguments

arguments=(
  '-i[input file]'
  '-o[output file]'
  '-c[VAL   Control value]'
  '--help[display this help and exit]'
  '--version[display version information and exit]'
  '*:filename:_files'
)

_arguments -s $arguments
