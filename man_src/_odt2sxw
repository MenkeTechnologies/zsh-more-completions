#compdef odt2sxw

local arguments

arguments=(
    {-c,--connection}'[UNO connection string to connect to a LibreOffice instance]'
    {-d,--doctype}'[Specify the LibreOffice document type of the backend format]'
    {-e,--export}'[Set specific export filter options]'
    {-f,--format}'[Specify the output format for the document]'
    {-F,--field}'[Replace user-defined text field with value]'
    {-i,--import}'[Set specific import filter options]'
    {-l,--listener}'[Start unoconv as listener for unoconv clients to connect to]'
    {-n,--no-launch}'[Do not launch a listener if none is running]'
    {-o,--output}'[Output directory or filename for converted documents]:output:_files'
    '--password[Provide a password to decrypt the document]'
    '--pipe[Use a pipe as an alternative connection mechanism to LibreOffice]'
    {-p,--port}'[Port to listen on or to connect to]:port'
    '--preserve[Keep timestamp and permissions of the original document]'
    {-s,--server}'[Server address to listen on or to connect to]:server'
    '--show[List the possible output formats to be used with -f]'
    '--stdin[Read input file from stdin]'
    '--stdout[Print converted output file to stdout]'
    {-t,--template}'[Specify the template to use for importing styles from]:template:_files'
    {-T,--timeout}'[Timeout in seconds when starting own listener]:timeout'
    {-v,--verbose}'[Be more and more verbose]'
    '*:filename:_files'
)
_arguments -s $arguments
