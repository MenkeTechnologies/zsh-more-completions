#compdef tracker3-endpoint

local arguments

arguments=(
    {-b,--dbus-service}'[service name to use on the endpoint]:service_name'
    {-d,--database-path}'[path where the database will be stored]:database_path:_directories'
    {-o,--ontology}'[name of an ontology to use on the constructed database]:ontology'
    {-p,--ontology-path}'[full path to an ontology]:path:_files'
    '--session[use the session bus (default)]'
    '--system[use the system bus]'
    {-l,--list}'[list all SPARQL endpoints available in DBus]'
    {-L,--list-http}'[list network-local HTTP SPARQL endpoints]'
    '--http-port[create a HTTP endpoint on the specified port]:port'
    '--loopback[allow only HTTP connections on the loopback device]'
    '*:filename:_files'
)
_arguments -s $arguments
