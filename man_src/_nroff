#compdef nroff

local arguments

arguments=(
    '-T[Select the output encoding emitted by grotty]:encoding'
    '-h[Use tabs in the output (grotty option)]'
    '-c[Use old output scheme instead of SGR escape sequences (grotty option)]'
    '-d[Define a string register]:cs'
    '-C[Enable compatibility mode]'
    '-i[Read standard input after processing input files]'
    '-M[Prepend directory to the search path for macro files]:directory:_directories'
    '-m[Include macro file before processing input files]:macro'
    '-n[Number the first generated page as num]:num'
    '-o[Output only pages specified by page_list]:page_list'
    '-r[Set number register to value]:cn'
    '-e[Produce equally-spaced words]'
    '-p[Pipe output through pic preprocessor]'
    '-t[Pipe output through tbl preprocessor]'
    '-S[Enable safer mode (disable certain requests)]'
    '-U[Enable unsafe mode]'
    '-v[Show the version number]'
    '*:filename:_files'
)
_arguments -s $arguments
