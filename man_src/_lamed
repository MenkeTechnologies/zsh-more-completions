#compdef lamed

local arguments

arguments=(
    '--fmt[Use format as the name of the format to be used]:format'
    '--halt-on-error[Exit with an error code when an error is encountered during processing]'
    '--help[Print help message and exit]'
    '--ini[Be initial Aleph for dumping formats]'
    '--interaction[Set the interaction mode]:mode:(batchmode nonstopmode scrollmode errorstopmode)'
    '--ipc[Send DVI output to a socket as well as the usual output file]'
    '--ipc-start[As --ipc, and starts the server at the other end as well]'
    '--kpathsea-debug[Set path searching debugging flags according to the bitmask]:bitmask'
    '--maketex[Enable mktex for the specified format]:fmt:(tex tfm)'
    '--no-maketex[Disable mktex for the specified format]:fmt:(tex tfm)'
    '--output-comment[Use string for the DVI file comment instead of the date]:string'
    '--output-directory[Write output files in directory instead of the current directory]:directory:_directories'
    '--parse-first-line[If the first line begins with %& parse it to look for a format name]'
    '--progname[Pretend to be program name]:name'
    '--recorder[Enable the filename recorder]'
    '--shell-escape[Enable the \\write18 command construct]'
    '--version[Print version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
