#compdef tracker3-daemon

local arguments

arguments=(
    {-p,--list-processes}'[list all Tracker processes in the system]'
    '--kill[use SIGKILL to stop all Tracker processes matching the parameter]:parameter'
    '--terminate[use SIGTERM to stop all Tracker processes]'
    {-s,--start}'[start all miners]'
    {-f,--follow}'[follow status changes to daemons as they happen]'
    {-w,--watch}'[watch changes that happen to the database in real time]:ontology'
    '--list-common-statuses[list statuses most commonly produced by miners and the store]'
    '--list-miners-running[list all miners which have responded to a D-Bus call]'
    '--list-miners-available[list all miners which are available even if not running]'
    '--pause-details[list all miners which are paused and the reasons]'
    '--miner[specify which miner to use with --pause or --resume]:miner'
    '--pause[pause the specified miner with a given reason]:reason'
    '--pause-for-process[like --pause but only keeps the miner paused while calling process alive]:reason'
    '--resume[resume a paused miner using the given cookie]:cookie'
    '*:filename:_files'
)
_arguments -s $arguments
