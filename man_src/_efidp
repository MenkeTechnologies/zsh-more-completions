#compdef efidp
# Documentation: https://man.archlinux.org/search?q=efidp
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-f[Format a binary UEFI Device Path into its canonical UTF-8 textual form]'
    '-p[Parse a UEFI Device Path UTF-8 specification and output binary Device Path]'
    '-e[Translate a Unix file path to an EFI Device Path]'
    '-u[Translate an EFI device path to a Unix file path]'
    '*:filename:_files'
)
_arguments -s $arguments
