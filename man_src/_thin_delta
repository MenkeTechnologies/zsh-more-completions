#compdef thin_delta

local arguments

arguments=(
    {--thin1,--snap1}'[numeric identifier for the first thin volume to diff]:id'
    {--thin2,--snap2}'[numeric identifier for the second thin volume to diff]:id'
    '--metadata-snap[use a metadata snapshot]:nr'
    '--verbose[provide extra information on the mappings]'
    '(- * :)'{-h,--help}'[print help and exit]'
    {-V,--version}'[output version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
