#compdef fixfiles

local arguments

arguments=(
    '-B[Record the current date for onboot scheduling]'
    '-F[Force reset of context to match file_context for customizable files]'
    '-f[Clear /tmp directory without prompt for removal]'
    '-R[Use rpm database to discover all files within the specified packages]:packages'
    '-C[Run a diff on the previous file context to the currently installed one]:PREVIOUS_FILECONTEXT:_files'
    '-N[Only act on files created after the specified date]:time'
    '*:filename:_files'
)
_arguments -s $arguments
