#compdef mariadb-report mysql_report

local arguments

arguments=(
    {-\?,--help}'[Display help and exit]'
    {-h,--host}'[Connect to the specified host]:host_name:_hosts'
    {-p,--password}'[Password to use for connection]:password'
    {-P,--port}'[Port number for connection]:port_num'
    {-S,--socket}'[Socket file for connection]:path:_files'
    {-u,--user}'[User name for login]:user_name'
    '--all[Report everything]'
    '--com[Report command counters]'
    '--dms[Report data manipulation statement counters]'
    '--innodb[Report InnoDB information]'
    '--tab[Report table information]'
    '*:filename:_files'
)
_arguments -s $arguments
