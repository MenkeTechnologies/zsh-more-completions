#compdef codesign

local arguments

arguments=(
    '--all-architectures[Verify all architectures in universal binaries]'
    '-a[Explicitly select the Mach-O architecture]:architecture'
    '--bundle-version[Explicitly specify the version when handling versioned bundles]:version'
    '-d[Display information about the code at the given paths]'
    '-D[Write a detached signature to the specified file]:file:_files'
    '--deep[Sign nested code content such as helpers, frameworks, and plugins]'
    '--detached-database[Generate a detached signature in the security database]'
    '-f[Replace any existing signature on the paths]'
    '-h[Print the hosting chain of a running program]'
    '-i[Specify the unique identifier string for the code signature]:identifier'
    '-o[Specify a set of option flags for the code signature]:flags'
    '-P[Specify the code signing page size]:pagesize'
    '-r[Embed internal requirements in the code signature]:requirements'
    '-R[Verify against the specified requirements]:requirements'
    '-s[Sign the code using this identity]:identity'
    '-v[Set or increment the verbosity level of output]'
    '--continue[Continue processing path arguments even if one fails]'
    '--dryrun[Perform signing operations without actually writing the signature]'
    '--entitlements[Embed the contents of the given file as entitlements]:file:_files'
    '--extract-certificates[Extract the certificates to files with the given prefix]:prefix'
    '--file-list[Write a list of files implicitly signed to the given path]:file:_files'
    '--ignore-resources[Do not validate the contents of the code resources]'
    '--keychain[Only search for the signing identity in the specified keychain]:keychain:_files'
    '--prefix[Use the given prefix for unique identifier if none specified]:prefix'
    '--preserve-metadata[Reuse metadata from existing signature when re-signing]:list'
    '--strict[Apply additional restrictions beyond the defaults when validating]'
    '--timestamp[Request a timestamp from a timestamp authority server]:URL'
    '--runtime-version[Specify the runtime version for hardened runtime]:version'
    '*:filename:_files'
)
_arguments -s $arguments
