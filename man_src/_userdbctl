#compdef userdbctl

local arguments

arguments=(
    {-h,--help}'[Show this help]'
    '--version[Show package version]'
    '--no-pager[Do not pipe output into a pager]'
    '--no-legend[Do not show the headers and footers]'
    '--output[Select output mode]:mode:(classic friendly table json)'
    '-j[Equivalent to --output=json]'
    {-s,--service}'[Query the specified service]:service'
    '--with-nss[Control whether to include glibc NSS data]:boolean:(yes no)'
    '-N[Do not synthesize or include glibc NSS data]'
    '--synthesize[Synthesize root/nobody user]:boolean:(yes no)'
    '*:filename:_files'
)
_arguments -s $arguments
