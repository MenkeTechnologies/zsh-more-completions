#compdef dpkg-fsys-usrunmess
# Documentation: https://man.archlinux.org/search?q=dpkg-fsys-usrunmess
# Reference accessed: 2026-05-16

local arguments

arguments=(
  {-p,--prompt}'[prompt before the point of no return]'
  {-n,--no-act,--dry-run}'[just check and create the new structure, no switch]'
  '--version[show the version]'
  '*:filename:_files'
)

_arguments -s $arguments
