#compdef tor-resolve

local arguments

arguments=(
    '-v[display verbose output]'
    '-x[perform a reverse lookup (get PTR record for an IPv4 address)]'
    '-5[use the SOCKS5 protocol (default)]'
    '-4[use the SOCKS4a protocol]'
    '-p[override the default SOCKS port]:socksport'
    '*:filename:_files'
)
_arguments -s $arguments
