#compdef iscsictl

local arguments

arguments=(
    '--libxo[Generate output via libxo in a selection of different formats]:format'
    '-A[Add session]'
    '-M[Modify session]'
    '-R[Remove session]'
    '-L[List sessions]'
    '-a[Add all sessions defined in the configuration file]'
    '-c[Path to the configuration file]:config:_files'
    '-d[Target host name or address used for SendTargets discovery]:host:_hosts'
    '-e[Enable or disable the session]:state:(on off)'
    '-i[Session ID]:session_id'
    '-n[The nickname of session defined in the configuration file]:nickname'
    '-p[Target portal host name or address for statically defined targets]:portal:_hosts'
    '-r[Use iSER (iSCSI over RDMA) instead of plain iSCSI over TCP/IP]'
    '-s[CHAP secret]:secret'
    '-t[Target name]:target'
    '-u[CHAP login]:login'
    '-v[Verbose mode]'
    '-w[Wait up to timeout seconds until all configured sessions are connected]:timeout'
    '*:filename:_files'
)
_arguments -s $arguments
