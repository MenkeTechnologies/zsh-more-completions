#compdef fmtree

local arguments

arguments=(
    '-L[Follow all symbolic links in the file hierarchy]'
    '-P[Do not follow symbolic links, consider the symbolic link itself]'
    '-U[Modify the owner, group, permissions, and modification time of existing files]'
    '-c[Print a specification for the file hierarchy to standard output]'
    '-d[Ignore everything except directory type files]'
    '-e[Do not complain about files in the file hierarchy but not in the specification]'
    '-i[Indent the output 4 spaces each time a directory level is descended]'
    '-n[Do not emit pathname comments when creating a specification]'
    '-q[Quiet mode]'
    '-r[Remove any files in the file hierarchy not described in the specification]'
    '-u[Same as U except a status of 2 is returned if hierarchy did not match]'
    '-w[Make some errors non-fatal warnings]'
    '-x[Do not descend below mount points in the file hierarchy]'
    '-f[Read the specification from file instead of standard input]:file:_files'
    '-K[Add the specified keywords to the current set]:keywords'
    '-k[Use the type keyword plus the specified keywords]:keywords'
    '-p[Use the file hierarchy rooted in path instead of current directory]:path:_directories'
    '-s[Display a single checksum to stderr]:seed'
    '-X[Specified file contains fnmatch patterns for files to be excluded]:exclude_file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
