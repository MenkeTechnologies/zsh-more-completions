#compdef tcopy
# Documentation: https://man.archlinux.org/search?q=tcopy
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-c[copy src to dest and verify that the two tapes are identical]'
    '-s[specify a maximum block size]:maxblk'
    '-v[verify that two tapes are identical]'
    '-x[output all informational messages to standard error]'
    '*:filename:_files'
)
_arguments -s $arguments
