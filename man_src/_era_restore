#compdef era_restore

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Print help and exit]'
    {-V,--version}'[Print version information and exit]'
    {-q,--quiet}'[Do not print any output, check the exit code for success]'
    {-i,--input}'[Specify input file containing xml metadata]:file:_files'
    {-o,--output}'[Output device or file for restored binary metadata]:device_or_file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
