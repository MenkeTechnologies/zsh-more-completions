#compdef rake2.1

# Autogenerated from man page
# Updated with latest rake options

local arguments

arguments=(
    '--version[display the program version]'
    {-C,--classic-namespace}'[put Task and FileTask in the top level namespace]'
    {-D,--describe}'[describe the tasks (matching optional PATTERN), then exit]:pattern'
    {-E,--execute-continue}'[execute some Ruby code, then continue with normal task processing]:code'
    {-G,--no-system,--nosystem}'[use standard project Rakefile search paths, ignore system wide rakefiles]'
    {-I,--libdir}'[include LIBDIR in the search path for required modules]:LIBDIR:_directories'
    {-N,--no-search,--nosearch}'[do not search parent directories for the Rakefile]'
    {-P,--prereqs}'[display the tasks and dependencies, then exit]'
    {-R,--rakelib,--rakelibdir}'[auto-import any .rake files in RAKELIBDIR (default is rakelib)]:RAKELIBDIR:_directories'
    {-T,--tasks}'[display the tasks (matching optional PATTERN) with descriptions, then exit]:pattern'
    {-e,--execute}'[execute some Ruby code and exit]:code'
    {-f,--rakefile}'[use FILE as the rakefile]:FILE:_files'
    {-h,--help}'[print a summary of options]'
    {-g,--system}'[use system wide (global) rakefiles (~/.rake/*.rake)]'
    {-n,--dry-run}'[do a dry run without executing actions]'
    {-p,--execute-print}'[execute some Ruby code, print the result, then exit]:code'
    {-q,--quiet}'[do not log messages to standard output]'
    {-r,--require}'[require MODULE before executing rakefile]:MODULE'
    {-s,--silent}'[like --quiet, but also suppresses the "in directory" announcement]'
    {-t,--trace}'[turn on invoke/execute tracing, enable full backtrace]'
    {-v,--verbose}'[log message to standard output (default)]'
    '--rules[trace the rules resolution]'
    '*:filename:_files'
)
_arguments -s $arguments
