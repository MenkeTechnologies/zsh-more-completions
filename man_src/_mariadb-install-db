#compdef mariadb-install-db mysql_install_db

local arguments

arguments=(
    {-\?,--help}'[Display help and exit]'
    '--basedir[Path to the MariaDB installation directory]:path:_directories'
    '--builddir[Path to the MariaDB build directory]:path:_directories'
    '--cross-bootstrap[For internal use during cross-compiling]'
    '--datadir[Path to the data directory]:path:_directories'
    '--defaults-extra-file[Read option file after the global files]:filename:_files'
    '--defaults-file[Only read options from the given file]:filename:_files'
    '--force[Force execution even if the data directory already exists]'
    '--ldata[Alternative path to the data directory]:path:_directories'
    '--no-defaults[Do not read any option files]'
    '--rpm[For internal use during RPM builds]'
    '--skip-name-resolve[Do not resolve host names]'
    '--srcdir[For internal use during source builds]:path:_directories'
    '--user[The login username to use for running the server]:user'
    '--verbose[Be more verbose]'
    '--auth-root-authentication-method[Authentication method for the root user]:method:(normal socket)'
    '*:filename:_files'
)
_arguments -s $arguments
