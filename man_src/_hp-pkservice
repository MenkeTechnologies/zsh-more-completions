#compdef hp-pkservice
# Documentation: https://man.archlinux.org/search?q=hp-pkservice
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-i,--interactive}'[Run in interactive mode]'
    {-l,--logging}'[Set the logging level]:level:(none info error warn debug)'
    {-g,--ldebug}'[Run in debug mode]'
    '(- * :)'{-h,--help}'[Show help information]'
    {-v,--version}'[Show PolicyKit version]'
    '*:filename:_files'
)
_arguments -s $arguments
