#compdef ctm_dequeue

local arguments

arguments=(
    '-l[Log diagnostics and messages to the specified log file]:log file:_files'
    '-m[Limit the maximum size mail message]:size'
    '-c[Limit the maximum size delta that will be sent]:size'
    '-q[Store delta pieces in the given directory instead of mailing]:directory:_directories'
    '-n[Limit the number of mail messages sent per run]:count'
    '-p[Collect pieces of deltas in this directory]:directory:_directories'
    '-d[Collect completed deltas in this directory]:directory:_directories'
    '-b[Apply any completed deltas to this source tree]:directory:_directories'
    '-D[Delete deltas after successful application]'
    '-f[Fork and execute in the background while applying deltas]'
    '-u[Pass the -u flag to ctm when applying deltas]'
    '-v[Pass the -v flag to ctm when applying deltas]'
    '*:filename:_files'
)
_arguments -s $arguments
