#compdef htags-server
# Documentation: https://man.archlinux.org/search?q=htags-server
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-b,--bind}'[Specify the IP address on which htags-server listens]:ip_address'
    {-u,--use}'[Specify language to use]:language:(python ruby)'
    '--retry[If the port is already in use, retry n times with incrementing port number]:n'
    '*:filename:_files'
)
_arguments -s $arguments
