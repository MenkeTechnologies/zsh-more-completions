#compdef pdfopen

local arguments

arguments=(
    {-h,--help,-\?}'[Output help and exit]'
    {-v,--version,-V}'[Output the version number and exit]'
    {-p,--page}'[Display the specified page number when starting the viewer]:page'
    {-g,--goto}'[Display the page containing the named destination]:name'
    {-r,--reset_focus}'[Attempt to reset the input focus to the previous window after sending commands]'
    '--viewer[Select the PDF viewer to use]:viewer:(ar9 ar9-tab ar8 ar7 ar5 xpdf evince)'
    '*:filename:_files'
)
_arguments -s $arguments
