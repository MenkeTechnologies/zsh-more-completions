#compdef swtpm_cert

# Updated with fixes for descriptions

local arguments

arguments=(
    '--pubkey[PEM file for public key (EK)]:file:_files'
    '--signkey[PEM file for CA signing key]:file:_files'
    '--signkey-password[Password for the CA signing key]:password'
    '--signkey-pwd[Alternative password option for CA signing key]:password'
    '--parentkey-password[Password of parent key; SRK password of TPM]:password'
    '--parentkey-pwd[Alternative password option for SRK password]:password'
    '--issuercert[PEM file with CA cert]:file:_files'
    '--out-cert[Filename for certificate]:file:_files'
    '--modulus[The modulus of the public key]:string'
    '--exponent[The exponent of the public key]:exponent'
    '--ecc-x[ECC key x component]:x'
    '--ecc-y[ECC key y component]:y'
    '--ecc-curveid[ECC curve id]:curve:(secp256r1 secp384r1 secp521r1)'
    '--serial[The certificate serial number]:number'
    '--days[Number of days the cert is valid]:days'
    '--pem[Write certificate in PEM format (default is DER)]'
    '--type[The type of certificate to create (default is ek)]:type:(ek platform)'
    '--tpm-manufacturer[The name of the TPM manufacturer]:name'
    '--tpm-model[The TPM model (part number)]:model'
    '--tpm-version[The TPM version (firmware version)]:version'
    '--platform-manufacturer[The name of the Platform manufacturer]:name'
    '--platform-model[The Platform model (part number)]:model'
    '--platform-version[The Platform version (firmware version)]:version'
    '--tpm-spec-family[Specification family (string)]:family'
    '--tpm-spec-level[Specification level (integer)]:level'
    '--tpm-spec-revision[Specification revision (integer)]:revision'
    '--subject[Subject such as location]:subject'
    '--add-header[Add the TCG certificate header]'
    '--tpm2[Issue a TPM 2 compliant certificate]'
    '--allow-signing[The EK of a TPM 2 allows signing]'
    '--decryption[The EK of a TPM 2 can be used for key encipherment]'
    '--print-capabilities[Print capabilities and exit]'
    '--version[Display version and exit]'
    '--help[Display help screen and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
