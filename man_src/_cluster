#compdef cluster
# Documentation: https://man.archlinux.org/search?q=cluster
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-C[Specify a targeted number of clusters to generate]:k'
    '-c[Specify clustering method]:k'
    '-o[Specify output file]:output file:_files'
    '-v[Verbose mode]'
    '*:filename:_files'
)
_arguments -s $arguments
