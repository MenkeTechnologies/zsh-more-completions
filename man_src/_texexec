#compdef texexec

local arguments

arguments=(
    '--make[make formats]'
    '--check[check versions]'
    '--process[process file]'
    '--mptex[process mp file]'
    '--mpxtex[process mpx file]'
    '--mpgraphic[process mp file to stand-alone graphics]'
    '--mpstatic[process mp/ctx file to stand-alone graphics]'
    '--listing[list of file content]'
    '--figures[generate overview of figures]'
    '--modules[generate module documentation]'
    '--pdfarrange[impose pages (booklets)]'
    '--pdfselect[select pages from files]'
    '--pdfcopy[copy pages from files]'
    '--pdftrim[trim pages from files]'
    '--pdfcombine[combine multiple pages]'
    '--pdfsplit[split file in pages]'
    '*:filename:_files'
)
_arguments -s $arguments
