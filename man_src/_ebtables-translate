#compdef xtables-translate ebtables-translate
# Documentation: https://man.archlinux.org/search?q=xtables-translate
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-A[Append rule to chain]:chain'
    '-p[Match protocol]:protocol'
    '-m[Load match extension]:match'
    '-j[Jump to target]:target'
    '--dport[Match destination port]:port'
    '--sport[Match source port]:port'
    '--ctstate[Match connection tracking state]:state'
    '*:filename:_files'
)
_arguments -s $arguments
