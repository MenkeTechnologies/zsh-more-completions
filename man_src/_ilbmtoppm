#compdef ilbmtoppm

local arguments

arguments=(
    '--verbose[Give some information about the ILBM file]'
    '--ignore[Skip a chunk]:chunkID'
    '--isham[Treat the input file as a HAM picture]'
    '--isehb[Treat the input file as an Extra_Halfbrite picture]'
    '--adjustcolors[If all colors in the CMAP have a value less than 16, assume a 4-bit palette and adjust]'
    '*:filename:_files'
)
_arguments -s $arguments
