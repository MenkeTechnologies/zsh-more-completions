#compdef tcutest
# Documentation: https://man.archlinux.org/search?q=tcutest
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--rd[test reading]'
    '--tr[test traversal]'
    '--rnd[use random keys]'
    '--dk[use decimal keys]'
    '--dc[use decimal for columns]'
    '--dai[use auto-increment for integer keys]'
    '--dad[use auto-increment for double keys]'
    '--dpr[test database printing]'
    '*:filename:_files'
)
_arguments -s $arguments
