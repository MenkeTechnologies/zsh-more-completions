#compdef memusagestat

local arguments

arguments=(
    {-o,--output}'[Name of the output file]:file:_files'
    {-s,--string}'[Use string as the title inside the output graph]:string'
    {-t,--time}'[Use time (rather than number of function calls) as the scale for the X axis]'
    {-T,--total}'[Also draw a graph of total memory consumption]'
    {-x,--x-size}'[Make the output graph specified number of pixels wide]:pixels'
    {-y,--y-size}'[Make the output graph specified number of pixels high]:pixels'
    {-\?,--help}'[Print a help message and exit]'
    '--usage[Print a short usage message and exit]'
    {-d,--data}'[Input data file from memusage]:file:_files'
    {-V,--version}'[Print version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
