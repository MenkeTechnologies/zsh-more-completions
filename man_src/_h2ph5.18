#compdef h2ph5.18
# Documentation: https://man.archlinux.org/search?q=h2ph5.18
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-d[Put the resulting .ph files beneath the specified directory]:destination_dir:_directories'
    '-r[Run recursively on directories found in headerfiles]'
    '-a[Run automagically; convert headerfiles as well as any included files]'
    '-l[Symbolic links will be replicated in the destination directory]'
    '-h[Put hints in the .ph files which will help in locating problems with h2ph]'
    '-D[Include the code from the .h file as a comment in the .ph file]'
    '*:filename:_files'
)
_arguments -s $arguments
