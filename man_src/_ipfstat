#compdef ipfstat

local arguments

arguments=(
    '-6[Display filter lists and states for IPv6]'
    '-a[Display the accounting filter list and show bytes counted against each rule]'
    '-A[Display packet authentication statistics]'
    '-C[Only valid in combination with -t]'
    '-d[Produce debugging output when displaying data]'
    '-D[Only valid in combination with -t; specify a destination address/port filter]:addrport'
    '-f[Show fragment state information and held state information]'
    '-g[Show groups currently configured (both active and inactive)]'
    '-h[Show per-rule the number of times each one scores a hit]'
    '-i[Display the filter list used for the input side of kernel IP processing]'
    '-I[Swap between retrieving inactive/active filter list details]'
    '-n[Show the rule number for each rule as it is printed]'
    '-o[Display the filter list used for the output side of kernel IP processing]'
    '-P[Only valid in combination with -t; filter by protocol]:protocol'
    '-R[Do not try to resolve addresses to hostnames and ports to services]'
    '-s[Show packet/flow state information (statistics only)]'
    '-S[Only valid in combination with -t; specify a source address/port filter]:addrport'
    '-t[Show the state table in a way similar to how top shows the process table]'
    '-T[Only valid in combination with -t; set the refresh time]:refreshtime'
    '-v[Turn verbose mode on]'
    '*:filename:_files'
)
_arguments -s $arguments
