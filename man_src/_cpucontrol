#compdef cpucontrol
# Documentation: https://man.archlinux.org/search?q=cpucontrol
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-d[Directory paths where to look for microcode images]:directory:_directories'
    '-n[Do not look for microcode images in the standard directories]'
    '-m[Show value of the specified MSR]:MSR'
    '-i[Retrieve CPUID info for the given level]:level'
    '-u[Apply CPU firmware updates]'
    '-e[Re-evaluate the kernel flags indicating present CPU features]'
    '-v[Increase the verbosity level]'
    '-h[Show help message]'
    '*:filename:_files'
)
_arguments -s $arguments
