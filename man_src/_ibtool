#compdef ibtool

local arguments

arguments=(
    '--write[Write the resulting Interface Builder document to the specified path]:path:_files'
    '--output-format[Output format for ibtool]:format:(xml binary human-readable-text)'
    '--compile[Compile the input file and write it to the specified path]:path:_files'
    '--flatten[Instruct ibtool to flatten an XIB file]:boolean:(YES NO)'
    '--module[Specify the module name to include in applicable custom class names at runtime]:moduleName'
    '--strip[Remove design-time content from the input NIB document and save to the specified path]:path:_files'
    '--bundle[Load the bundle located at bundlePath]:bundlePath:_files'
    '--previous-file[Specify the Interface Builder document from the previous version]:previousFile:_files'
    '--incremental-file[Specify the Interface Builder document from the incremental build]:incrementalFile:_files'
    '--localize-incremental[Consolidate the structural and localization changes between documents]'
    '--reference-external-strings-file[Indicate that the files in the lproj directories are references]'
    '--companion-strings-file[Specify the strings file to use with the compile option]:stringsFile:_files'
    '--import[Apply the property values specified in plist to the object]:plist'
    '--import-strings-file[Replace the localizable strings with the translations specified]:stringsFile:_files'
    '--import-xliff[Replace the localizable strings with the translations from XLIFF]:XLIFFDocument:_files'
    '--convert[Rename the class named old to new]:old-new'
    '--upgrade[Upgrade the input Interface Builder document to the latest document type]'
    '--remove-plugin-dependencies[Remove any dependencies on Interface Builder 3 plug-ins]'
    '--enable-auto-layout[Enable Auto Layout in the given document]'
    '--update-frames[Adjust the frames of misplaced or ambiguous objects to match their constraints]'
    '--update-constraints[Adjust the constraint constants of misplaced objects to match their frames]'
    '--export-xliff[Extract the localizable strings into an XLIFF document]:XLIFFDocument:_files'
    '--source-language[Specify the source language of the resultant XLIFF document]:sourceLanguage'
    '--target-language[Specify the target language of the resultant XLIFF document]:targetLanguage'
    '--all[Include all information in ibtool plist output]'
    '--export-strings-file[Extract the localizable strings into a strings file]:stringsfile:_files'
    '--generate-strings-file[Generate a strings file from the document]'
    '--warnings[Include document warning messages in plist output]'
    '--errors[Include document error messages in plist output]'
    '--notices[Include document notice messages in plist output]'
    '--localizable-strings[Include non-empty localizable strings in plist output]'
    '--localizable-stringarrays[Include localizable string arrays in plist output]'
    '--localizable-geometry[Include localizable geometry in plist output]'
    '--localizable-other[Include other localizable attributes in plist output]'
    '--localizable-to-many-relationships[Include localizable to-many relationships in plist output]'
    '--localizable-all[Include all localizable attributes in plist output]'
    '--objects[Include the objects in plist output]'
    '--hierarchy[Include the hierarchy in plist output]'
    '--connections[Include the connections in plist output]'
    '--classes[Include the classes in plist output]'
    '--version-history[Print the version of IB/System Version used when the document was last saved]'
    '--version[Print the version of ibtool]'
    '*:filename:_files'
)
_arguments -s $arguments
