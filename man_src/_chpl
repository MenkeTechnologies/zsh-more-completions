#compdef chpl

local arguments

arguments=(
    '--count-tokens[Print the total number of static lexical tokens in the Chapel code files]'
    '--main-module[Specify the main module for programs with multiple entry points]:module'
    {-M,--module-dir}'[Add the specified directory to the module search path]:directory:_directories'
    '--print-code-size[Print the size of the Chapel code files]'
    '--print-module-files[Print the Chapel module source files parsed by the compiler]'
    '--print-search-dirs[Print the module search path used to resolve modules]'
    '--permit-unhandled-module-errors[Allow unhandled errors in module code]'
    '--warn-unstable[Enable warnings for unstable code]'
    '--warnings[Enable the printing of compiler warnings]'
    '--local[Compile code for single locale execution]'
    '--no-local[Compile for multi-locale execution]'
    '--baseline[Turn off all optimizations and generate naive C code]'
    '--cache-remote[Enable the cache for remote data]'
    '--copy-propagation[Enable copy propagation]'
    '--dead-code-elimination[Enable dead code elimination]'
    '--fast[Turn off runtime checks and turn on optimizations]'
    '--specialize[Enable specialization]'
    '--fast-followers[Enable the fast follower optimization]'
    '--ieee-float[Disable optimizations that may affect IEEE floating point conformance]'
    '--loop-invariant-code-motion[Enable loop invariant code motion optimization]'
    '--optimize-forall-unordered-ops[Enable optimization of forall unordered operations]'
    '--ignore-local-classes[Disable local classes]'
    '--inline[Enable function inlining]'
    '--inline-iterators[Enable iterator inlining]'
    '--inline-iterators-yield-limit[Limit on yield statements in an inlined iterator]:limit'
    '--live-analysis[Enable live variable analysis]'
    '--optimize-range-iteration[Enable anonymous range iteration optimizations]'
    '--optimize-loop-iterators[Enable loop iterator optimizations]'
    '--vectorize[Enable generating vectorization hints]'
    '--optimize-on-clauses[Enable optimization of on clauses]'
    '--optimize-on-clause-limit[Limit on function call depth for on clause optimization]:limit'
    '--privatization[Enable privatization of distributed arrays and domains]'
    '--remove-copy-calls[Enable removal of copy calls]'
    '--remote-value-forwarding[Enable remote value forwarding of read-only values]'
    '--remote-serialization[Enable serialization for globals and remote constants]'
    '--scalar-replacement[Enable scalar replacement of records and classes]'
    '--scalar-replace-limit[Limit on the size of tuples for scalar replacement]:limit'
    '--tuple-copy-opt[Enable the tuple copy optimization]'
    '--tuple-copy-limit[Limit on the size of tuples for tuple copy optimization]:limit'
    '--infer-local-fields[Enable analysis to infer local fields]'
    '--auto-local-access[Enable automatic local access optimization for forall loops]'
    '--dynamic-auto-local-access[Enable the dynamic portion of auto local access analysis]'
    '--auto-aggregation[Enable automatic aggregation optimization]'
    '--checks[Enable all run-time checks]'
    '--bounds-checks[Enable run-time bounds checking]'
    '--cast-checks[Enable run-time checks in safeCast calls]'
    '--div-by-zero-checks[Enable run-time division by zero checks]'
    '--formal-domain-checks[Enable run-time formal domain checks]'
    '--local-checks[Enable run-time locality checks]'
    '--nil-checks[Enable run-time nil reference checks]'
    '--stack-checks[Enable run-time stack overflow checking]'
    '--codegen[Enable generating C code and the binary executable]'
    '--cpp-lines[Emit cpp #line directives into the generated code]'
    '--max-c-ident-len[Limit the length of identifiers in generated code]:length'
    '--munge-user-idents[Munge all user identifiers in the generated C code]'
    '--savec[Save the compiler-generated C code in the specified directory]:directory:_directories'
    '--ccflags[Add flags to the C compiler command line]:flags'
    {-g,--debug}'[Compile generated C code with debugging turned on]'
    '--devel[Enable developer mode]'
    '--dynamic[Use dynamic linking when generating the final binary]'
    '--static[Use static linking when generating the final binary]'
    {-I,--hdr-search-path}'[Add directory to the C compiler header search path]:directory:_directories'
    '--ldflags[Add flags to the C compiler link line]:flags'
    {-l,--lib-linkage}'[Specify a C library to link]:library'
    {-L,--lib-search-path}'[Add directory to the C compiler library search path]:directory:_directories'
    {-O,--optimize}'[Compile generated C code with optimizations]'
    {-o,--output}'[Specify the name of the compiler-generated executable]:filename:_files'
    '--llvm[Use LLVM as the code generation target]'
    '--llvm-wide-opt[Enable LLVM wide pointer communication optimizations]'
    '--mllvm[Pass an option to the LLVM optimization passes]:option'
    '--print-commands[Print the system commands executed during compilation]'
    '--print-passes[Print the compiler passes during compilation]'
    '--print-passes-file[Save compiler passes to a file]:filename:_files'
    '--explain-call[Explain the function resolution process for the named function]:call'
    '--explain-instantiation[List all instantiations of a function or type]:function or type'
    '--explain-verbose[Show verbose explanation with explain-call or explain-instantiation]'
    '--instantiate-max[Maximum number of instantiations to avoid infinite loops]:max'
    '--print-all-candidates[Show all candidates on function resolution errors]'
    '--print-callgraph[Print a textual call graph of the program]'
    '--print-callstack-on-error[Show the Chapel call stack with error messages]'
    '--print-unused-functions[Print names and source locations of unused functions]'
    {-s,--set}'[Override the default value of a configuration variable]:config=value'
    '--task-tracking[Enable the Chapel task tracking table]'
    '--home[Specify the location of the Chapel installation directory]:path:_directories'
    '--atomics[Specify the atomic variables implementation]:implementation'
    '--network-atomics[Specify the network atomics implementation]:implementation'
    '--aux-filesys[Specify runtime support for additional file systems]:filesystem'
    '--comm[Specify the communication implementation]:implementation'
    '--comm-substrate[Specify the communication conduit]:conduit'
    '--gasnet-segment[Specify memory segment to use with GASNet]:segment'
    '--gmp[Specify the GMP library implementation]:version'
    '--hwloc[Specify whether to use the hwloc library]:implementation'
    '--launcher[Specify the launcher for job execution]:launcher'
    '--locale-model[Specify the locale model]:model'
    '--make[Specify the GNU compatible make utility]:utility:_files'
    '--mem[Specify the memory allocator]:implementation'
    '--re2[Specify the RE2 library to use]:re2'
    '--target-arch[Specify the target machine architecture]:architecture'
    '--target-compiler[Specify the compiler suite for building generated C code]:compiler'
    '--target-cpu[Specify the target CPU model]:cpu'
    '--target-platform[Specify the target platform]:platform'
    '--tasks[Specify the tasking layer]:implementation'
    '--timers[Specify the timer implementation]:implementation'
    '--copyright[Print copyright information]'
    {-h,--help}'[Print a list of the command line options]'
    '--help-env[Print help with environment variable equivalents]'
    '--help-settings[Print help with current settings]'
    '--license[Print license information]'
    '--version[Print the version number of the compiler]'
    '*:filename:_files'
)
_arguments -s $arguments
