#compdef lckdo

local arguments

arguments=(
    '-w[If the lock is already held, wait for it to complete instead of failing]'
    '-W[Same as -w but wait not more than specified seconds]:seconds'
    '-e[Execute the program directly without forking and waiting]'
    '-E[Set the file descriptor number to keep open when execing (implies -e)]:fd'
    '-n[Do not create the lock file if it does not exist]'
    '-q[Produce no output if lock is already held]'
    '-s[Lock in shared (read) mode]'
    '-x[Lock in exclusive (write) mode (default)]'
    '-t[Test for lock existence]'
    '*:filename:_files'
)
_arguments -s $arguments
