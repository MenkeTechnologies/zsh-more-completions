#compdef ipmievd

local arguments

arguments=(
    '-a[Prompt for the remote server password]'
    '-A[Specify an authentication type to use during IPMIv1.5 session activation]:authtype'
    '-c[Present output in CSV format]'
    '-C[Remote server authentication, integrity, and encryption cipher suite]:ciphersuite'
    '-E[Remote server password specified by the environment variable IPMI_PASSWORD]'
    '-f[Specify a file containing the remote server password]:password_file:_files'
    '-h[Get basic usage help]'
    '-H[Remote server address]:address:_hosts'
    '-I[Select IPMI interface to use]:interface'
    '-L[Force session privilege level]:privlvl:(CALLBACK USER OPERATOR ADMIN)'
    '-m[Set the local IPMB address]:local_address'
    '-o[Select OEM type to support]:oemtype'
    '-O[Open file for OEM SEL event descriptions]:file:_files'
    '-p[Remote server UDP port to connect to]:port'
    '-P[Remote server password]:password'
    '-S[Use local file for remote SDR cache]:sdr_cache_file:_files'
    '-t[Bridge IPMI requests to the remote target address]:target_address'
    '-U[Remote server username]:username'
    '-d[Use device number N to specify /dev/ipmiN]:N'
    '-v[Increase verbose output level]'
    '*:filename:_files'
)
_arguments -s $arguments
