#compdef dave
# Documentation: https://man.archlinux.org/search?q=dave
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--debug[Set debug level]:level'
    '-h[Show help]'
    '--man[Show manual]'
    '-p[Password for authentication]:password'
    '-u[Username for authentication]:username'
    '--tmpdir[Set temporary directory]:path:_directories'
    '*:filename:_files'
)
_arguments -s $arguments
