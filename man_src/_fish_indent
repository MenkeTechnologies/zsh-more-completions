#compdef fish_indent

local arguments

arguments=(
    {-w,--write}'[Write to file instead of stdout]'
    {-i,--no-indent}'[Do not indent output]'
    {-v,--version}'[Display version and exit]'
    '--ansi[Output ANSI-highlighted syntax]'
    '--html[Output HTML-highlighted syntax]'
    {-d,--debug}'[Enable debug output]:category_glob'
    {-D,--debug-stack-frames}'[Specify how many stack frames to display for debug messages]:level'
    '--dump-parse-tree[Dump the parse tree for debugging]'
    '*:filename:_files'
)
_arguments -s $arguments
