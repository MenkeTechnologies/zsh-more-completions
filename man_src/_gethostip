#compdef gethostip
# Documentation: https://man.archlinux.org/search?q=gethostip
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-d[Output the IP address in decimal format]'
    '-x[Output the IP address in hexadecimal format]'
    '-n[Output the host canonical name]'
    '*:filename:_files'
)
_arguments -s $arguments
