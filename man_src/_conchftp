#compdef conchftp

local arguments

arguments=(
    '-B[Specify the default buffer size for sending and receiving]:size'
    '-b[File to read commands from, - for stdin]:file:_files'
    '-R[Number of requests to make before waiting for a reply]:count'
    '-s[Subsystem/server program to connect to]:subsystem'
    '*:filename:_files'
)
_arguments -s $arguments
