#compdef fsck_exfat
# Documentation: https://man.archlinux.org/search?q=fsck_exfat
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-q[Quickly check whether the volume was unmounted cleanly]'
    '-f[Force check (ignored, present for compatibility)]'
    '-p[Preen the specified file systems]'
    '-y[Assume yes as the answer to all questions]'
    '-n[Assume no as the answer to all questions]'
    '-g[Produce output in GUI-compatible form]'
    '-x[Produce output in XML-like form]'
    '-d[Produce extra debugging output]'
    '*:filename:_files'
)
_arguments -s $arguments
