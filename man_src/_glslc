#compdef glslc

local arguments

arguments=(
    '--fshader-stage[Override the shader stage for subsequent files]:stage:(vertex fragment compute geometry tesscontrol tesseval)'
    '-S[Output assembly instead of a binary module]'
    '--help[Display available options]'
    '--show-limits[Display default resource limits]'
    '-o[Write output to specified file]:file:_files'
    '--flimit[Set a resource limit]:limit=value'
    '--flimit-file[Set resource limits from a file]:file:_files'
    '--std[Select GLSL version and profile]:version'
    '--target-env[Set the target environment]:env'
    '-x[Treat subsequent files as having the given type]:type:(glsl hlsl)'
    '-c[Output a binary module (SPIR-V)]'
    '-E[Preprocess only]'
    '-D[Define a preprocessor macro]:macro=value'
    '-I[Add directory to include search path]:directory:_directories'
    '-g[Generate debug info]'
    '-O0[No optimization]'
    '-Os[Optimize for size]'
    '-O[Optimize]'
    '--mfmt[Output format]:format:(bin c num)'
    '--fhlsl-offsets[Use HLSL packing rules for offsets]'
    '--fhlsl-functionality1[Enable HLSL functionality1 extension]'
    '--fentry-point[Set the entry point name]:name'
    '--fauto-map-locations[Automatically assign locations to uniform variables]'
    '-w[Suppress all warnings]'
    '--Werror[Treat all warnings as errors]'
    '-M[Generate make dependencies]'
    '-MM[Generate make dependencies, ignoring system headers]'
    '--MD[Generate make dependencies in a separate file]'
    '--MF[Specify the make dependency output file]:file:_files'
    '--MT[Specify the make dependency target]:target'
    '--fauto-bind-uniforms[Automatically assign bindings to uniform variables]'
    '--fhlsl-iomap[Use HLSL IO mappings]'
    '--fimage-binding-base[Set base binding for images]:binding'
    '--fsampler-binding-base[Set base binding for samplers]:binding'
    '--ftexture-binding-base[Set base binding for textures]:binding'
    '--fubo-binding-base[Set base binding for UBOs]:binding'
    '--fcbuffer-binding-base[Set base binding for cbuffers]:binding'
    '--fssbo-binding-base[Set base binding for SSBOs]:binding'
    '--fuav-binding-base[Set base binding for UAVs]:binding'
    '--fresource-set-binding[Set bindings for a resource set]:set binding'
    '*:filename:_files'
)
_arguments -s $arguments
