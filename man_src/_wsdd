#compdef wsdd

local arguments

arguments=(
    {-4,--ipv4only}'[Restrict to IPv4]'
    {-6,--ipv6only}'[Restrict to IPv6]'
    {-A,--no-autostart}'[Do not start networking activities automatically when the program is started]'
    {-c,--chroot}'[Chroot into the given directory after initialization]:directory:_directories'
    {-h,--help}'[Show help and exit]'
    {-H,--hoplimit}'[Set the hop limit for multicast packets]:limit'
    {-i,--interface}'[Specify on which interfaces wsdd will be listening]:interface'
    '--metadata-timeout[Set the timeout for HTTP-based metadata exchange]:timeout'
    {-s,--shortlog}'[Use a shorter logging format]'
    {-u,--user}'[Change user when running before handling network packets]:user'
    {-U,--uuid}'[Specify a unique WSD device UUID]:uuid'
    {-v,--verbose}'[Increase verbosity of the log output]'
    {-V,--version}'[Show the version number and exit]'
    {-d,--domain}'[Assume that the host running wsdd joined an ADS domain]:domain'
    {-n,--hostname}'[Override the host name wsdd uses during discovery]:hostname'
    {-o,--no-host}'[Disable host operation mode]'
    {-p,--preserve-case}'[Preserve the hostname as it is]'
    {-t,--no-http}'[Do not service HTTP requests of the WSD protocol]'
    {-w,--workgroup}'[Set the workgroup name]:workgroup'
    {-D,--discovery}'[Enable discovery mode to search for other WSD hosts/servers]'
    {-l,--listen}'[Specify the location of the socket for the server programming interface]:socket:_files'
    '*:filename:_files'
)
_arguments -s $arguments
