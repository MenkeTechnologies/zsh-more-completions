#compdef fish

local arguments

arguments=(
    {-c,--command}'[Evaluate the specified commands instead of reading from commandline]:commands'
    {-C,--init-command}'[Evaluate the specified commands after reading the configuration]:commands'
    {-d,--debug}'[Enable debug output and specify a glob for matching debug categories]:category_glob'
    {-o,--debug-output}'[Specify a file path to receive the debug output]:path:_files'
    {-i,--interactive}'[Specify that fish is to run in interactive mode]'
    {-l,--login}'[Specify that fish is to run as a login shell]'
    {-n,--no-execute}'[Do not execute any commands, only perform syntax checking]'
    {-p,--profile}'[When fish exits, output timing information to the specified file]:file:_files'
    {-P,--private}'[Enable private mode, do not access old or store new history]'
    '--print-rusage-self[When fish exits, output stats from getrusage]'
    '--print-debug-categories[Output the list of debug categories and then exit]'
    '(- * :)'{-v,--version}'[Display version and exit]'
    {-D,--debug-stack-frames}'[Specify how many stack frames to display for debug messages]:debug_level'
    {-f,--features}'[Enable specified feature flags]:features'
    '*:filename:_files'
)
_arguments -s $arguments
