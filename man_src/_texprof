#compdef texprof

local arguments

arguments=(
    '--cnf-line[parse string as a texmf.cnf configuration line]:string'
    '--etex[enable the e-TeX extensions]'
    '--file-line-error[print error messages in file:line:error style]'
    '--no-file-line-error[disable printing error messages in file:line:error style]'
    '--fmt[use format as the name of the format to be used]:format'
    '--help[print help message and exit]'
    '--ini[start in INI mode, used to dump formats]'
    '--interaction[set the interaction mode]:mode:(batchmode nonstopmode scrollmode errorstopmode)'
    '--jobname[use name for the job name]:name'
    '--kpathsea-debug[set path searching debugging flags]:bitmask'
    '--ltx[enable the LaTeX extensions]'
    '--mktex[enable mktex for specified format]:fmt'
    '--no-mktex[disable mktex for specified format]:fmt'
    '--output-directory[write output files in directory]:directory:_directories'
    '--parse-first-line[parse the first line of the main input file for format info]'
    '--no-parse-first-line[disable parsing of the first line]'
    '--pdf[enable the simulation of common pdftex primitives]'
    '--prof[enable profiling as soon as TeX enters the main loop]'
    '--progname[pretend to be program name]:name'
    '--version[print version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
