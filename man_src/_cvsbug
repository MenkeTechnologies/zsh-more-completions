#compdef cvsbug

local arguments

arguments=(
    '-f[Specify a file containing a complete problem report]:problem report:_files'
    '-t[Change mail address at the support site for problem reports]:mail address'
    '-P[Print the form on standard output]'
    '-L[Print the list of available categories]'
    '--request-id[Send mail with a request for a new id]'
    '-v[Display the cvsbug version number]'
    '*:filename:_files'
)
_arguments -s $arguments
