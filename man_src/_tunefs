#compdef tunefs

local arguments

arguments=(
    '-A[select backup super-block]'
    '-a[turn on/off administrative POSIX.1e ACL enable flag]:flag:(enable disable)'
    '-e[indicate maximum blocks any single file can allocate out of a cylinder group]:maxbpg'
    '-f[specify the expected average file size]:avgfilesize'
    '-j[turn on/off soft updates journaling]:flag:(enable disable)'
    '-J[turn on/off gjournal flag]:flag:(enable disable)'
    '-k[set the amount of space to be held for metadata blocks]:held-for-metadata-blocks'
    '-L[add/modify an optional file system volume label]:label'
    '-l[turn on/off MAC multilabel flag]:flag:(enable disable)'
    '-m[specify the percentage of space held back from normal users]:free-space-percent'
    '-N[turn on/off administrative NFSv4 ACL enable flag]:flag:(enable disable)'
    '-n[turn on/off soft updates]:flag:(enable disable)'
    '-o[optimize for space or time]:optimization:(space time)'
    '-p[show a summary of current tunable settings]'
    '-s[specify the expected number of files per directory]:files-per-directory'
    '-S[specify the softdep journal size in bytes]:journal-size'
    '-t[turn on/off the TRIM enable flag]:flag:(enable disable)'
    '*:filename:_files'
)
_arguments -s $arguments
