#compdef csharp
# Documentation: https://man.archlinux.org/search?q=csharp
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-s[Execute the specified script file]:script file:_files'
    '--attach[Attach to a running Mono process for debugging]:pid'
    '-e[Evaluate the specified C# expression and exit]:expression'
    '*:filename:_files'
)
_arguments -s $arguments
