    '--tcl[Generate Tcl wrappers]'
    '--xml[Generate XML wrappers]'
    '--c++[Enable C++ processing]'
    '--co[Check a file out of the SWIG library]'
    '--dirprot[Turn on wrapping of protected members for director classes]'
    '-D[Define a symbol for conditional compilation]:symbol'
    '-E[Preprocess only, do not generate wrapper code]'
    '--fcompact[Compile in compact mode]'
    '--fvirtual[Compile in virtual elimination mode]'
    '--Fstandard[Display messages in commonly used format]'
    '--Fmicrosoft[Display messages in Microsoft format]'
    '--help[Show a summary of supported options]'
    '-I[Look for SWIG files in dir]:dir:_directories'
