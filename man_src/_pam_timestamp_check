#compdef pam_timestamp_check
# Documentation: https://man.archlinux.org/search?q=pam_timestamp_check
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-k[Remove the timestamp instead of checking its validity]'
    '-d[Loop indefinitely, polling the timestamp and signaling on changes]'
    '*:filename:_files'
)
_arguments -s $arguments
