#compdef orte-info

local arguments

arguments=(
    {-a,--all}'[Show all configuration options and MCA parameters]'
    '--arch[Show architecture ORTE was compiled on]'
    {-c,--config}'[Show configuration options]'
    '--gmca[Pass global MCA parameters applicable to all contexts]:value'
    '(- * :)'{-h,--help}'[Show help / usage message]'
    '--hostname[Show the hostname that ORTE was configured and built on]'
    '--internal[Show internal MCA parameters not meant to be modified by users]'
    '--mca[Pass context-specific MCA parameters]:value'
    '--param[Show MCA parameters]:component'
    '--parsable[Display output in a machine-parsable format]'
    '--path[Show paths that ORTE was configured with]:type'
    '--pretty[Display output in a human-readable format]'
    '--parseable[Synonym for --parsable]'
    {-v,--version}'[Show version of ORTE or a component]:scope'
    '*:filename:_files'
)
_arguments -s $arguments
