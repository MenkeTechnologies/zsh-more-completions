#compdef kvm

local arguments

arguments=(
    {-h,-help}'[Display help and exit]'
    '-version[Display version information and exit]'
    '-machine[Select emulated machine]:machine'
    '-cpu[Select CPU model]:cpu'
    '-accel[Select accelerator]:accelerator'
    '-smp[Set the number of CPUs]:cpus'
    '-m[Set guest startup RAM size]:megs'
    '-k[Use keyboard layout]:layout'
    '-kernel[Use specified file as kernel image]:bzImage:_files'
    '-append[Use specified string as kernel command line]:cmdline'
    '-initrd[Use specified file as initial ram disk]:file:_files'
    '-dtb[Use specified file as device tree image]:file:_files'
    '-hda[Use file as IDE hard disk 0 image]:file:_files'
    '-hdb[Use file as IDE hard disk 1 image]:file:_files'
    '-hdc[Use file as IDE hard disk 2 image]:file:_files'
    '-hdd[Use file as IDE hard disk 3 image]:file:_files'
    '-cdrom[Use file as IDE cdrom image]:file:_files'
    '-fda[Use file as floppy disk 0 image]:file:_files'
    '-fdb[Use file as floppy disk 1 image]:file:_files'
    '-drive[Define a new drive]:options'
    '-snapshot[Write to temporary files instead of disk image files]'
    '-nographic[Disable graphical output and redirect serial I/Os to console]'
    '-serial[Redirect the serial port to char device]:dev'
    '-parallel[Redirect the parallel port to char device]:dev'
    '-monitor[Redirect the monitor to char device]:dev'
    '-pidfile[Write PID to file]:file:_files'
    '-S[Freeze CPU at startup]'
    '-s[Shorthand for -gdb tcp::1234]'
    '-gdb[Accept gdb connection on dev]:dev'
    '-d[Enable logging of specified items]:items'
    '-D[Output log to logfile]:logfile:_files'
    '-enable-kvm[Enable KVM full virtualization support]'
    '-no-reboot[Exit instead of rebooting]'
    '-no-shutdown[Stop before shutdown]'
    '-loadvm[Start right away with a saved state]:tag'
    '-daemonize[Daemonize QEMU after initializing]'
    '-name[Set the name of the guest]:name'
    '-uuid[Set the UUID of the guest]:uuid'
    '-usb[Enable on-board USB host controller]'
    '-device[Add device]:driver'
    '-vga[Select type of VGA card to emulate]:type:(std cirrus vmware qxl virtio none)'
    '-full-screen[Start in full screen]'
    '-vnc[Start a VNC server on display]:display'
    '-no-acpi[Disable ACPI]'
    '-boot[Set boot order]:order'
    '-rtc[Set RTC start date and clock]:options'
    '-net[Configure guest network]:options'
    '-object[Create a new object]:options'
    '-chardev[Create a character device backend]:options'
    '*:filename:_files'
)
_arguments -s $arguments
