#compdef vshadowmount
# Documentation: https://man.archlinux.org/search?q=vshadowmount
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-h[Show this help]'
    '-o[Specify the volume offset in bytes]:offset'
    '-v[Verbose output to stderr]'
    '-V[Print version]'
    '-X[Extended options to pass to sub system]:options'
    '*:filename:_files'
)
_arguments -s $arguments
