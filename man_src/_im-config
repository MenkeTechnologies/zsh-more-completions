#compdef im-config

local arguments

arguments=(
    '-a[List all possible input methods even if not available on the system]'
    '-c[Use console dialogue]'
    '-x[Use X dialogue with zenity]'
    '-s[No action; perform a simulation of events that would occur]'
    '-l[List all available input method configuration settings to STDOUT]'
    '-m[List configuration values to STDOUT]'
    '-n[Set input method to the specified name]:input_method'
    '-o[Set input method for system-wide default]:input_method'
    '*:filename:_files'
)
_arguments -s $arguments
