#compdef mcc
# Documentation: https://man.archlinux.org/search?q=mcc
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-g[Keep the C file generated by mprep after compilation]'
    '-E[Pass the preprocessor flag to the C compiler]'
    '-P[Pass the flag to the C preprocessor]'
    '-o[Write the output file to the specified name]:name:_files'
    '*:filename:_files'
)
_arguments -s $arguments
