#compdef py3smi
# Documentation: https://man.archlinux.org/search?q=py3smi
# Reference accessed: 2026-05-16

local arguments

arguments=(
  {-h,--help}'[show this help message and exit]'
  {-l,--loop}'[loop period]'
  {-f,--full}'[print extended version]'
  {-w,--width}'[print width]'
  '--left[prints left part of process name]'
  '*:filename:_files'
)

_arguments -s $arguments
