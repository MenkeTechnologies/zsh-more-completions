#compdef tcptrack

local arguments

arguments=(
    '-d[only track connections started after tcptrack was started]'
    '-f[enable fast average recalculation]'
    '-h[display command line help]'
    '-i[sniff packets from the specified network interface]:interface'
    '-T[read packets from the specified file]:file:_files'
    '-p[do not put the interface into promiscuous mode]'
    '-r[wait this many seconds before removing a closed connection]:seconds'
    '-v[display tcptrack version]'
    '*:filename:_files'
)
_arguments -s $arguments
