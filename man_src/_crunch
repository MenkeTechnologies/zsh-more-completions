#compdef crunch

local arguments

arguments=(
    '-b[Maximum size of output file]:number and type'
    '-c[Number of lines to write to output file]:number'
    '-d[Limit duplicate characters]:numbersymbol'
    '-e[End string, stop after reaching this string]:string'
    '-f[Specify a charset file and charset name]:file charset'
    '-i[Invert the output order]'
    '-l[Literal characters, treat as placeholders]:string'
    '-t[Specify a pattern for output]:pattern'
    '-o[Specify output file]:wordlist:_files'
    '-p[Permutations mode]'
    '-q[Read input from file]:file:_files'
    '-r[Resume from a previously generated output]'
    '-s[Specify a starting string]:string'
    '-u[Suppress percentage output]'
    '-z[Compress output]:type:(gzip bzip2 lzma 7z)'
    '*:filename:_files'
)
_arguments -s $arguments
