#compdef tikztosvg

local arguments

arguments=(
    {-o,--output}'[specify output path]:output path:_files'
    {-p,--package}'[add LaTeX package]:package'
    {-q,--quiet}'[suppress output]'
    '(- * :)'{-h,--help}'[display help information]'
    {-v,--version}'[display version information]'
    '*:filename:_files'
)
_arguments -s $arguments
