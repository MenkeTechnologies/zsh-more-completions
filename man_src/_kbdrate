#compdef kbdrate
# Documentation: https://man.archlinux.org/search?q=kbdrate
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-s[Silent mode; no messages are printed]'
    '-r[Change the keyboard repeat rate]:rate'
    '-d[Change the delay in milliseconds]:delay'
    {-V,--version}'[Display a version number and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
