#compdef w3mman
# Documentation: https://man.archlinux.org/search?q=w3mman
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-M[Specify path as alternative MANPATH to use]:path'
    '-k[Specify keyword]:keyword'
    '-l[Specify a file]:file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
