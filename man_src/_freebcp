#compdef freebcp

local arguments

arguments=(
    '-A[Set the size of a TDS packet]:packet_size'
    '-D[The name of the default database to use]:database'
    '-E[Write data to the table IDENTITY column]'
    '-F[The first row to copy from the input file]:row'
    '-I[Name and location of the interfaces file]:file:_files'
    '-L[The last row to copy from an input file]:row'
    '-O[SQL text to set connection options prior to the bcp operation]:sql'
    '-P[The password associated with username]:password'
    '-S[The name of the Database Server to connect to]:server'
    '-T[Maximum number of characters to request from server for text/image columns]:size'
    '-U[A database login name]:username'
    '-b[The number of rows per batch of data copied]:rows'
    '-c[Host data file is in character/text format]'
    '-d[Turn off any logging]'
    '-e[Write errors to errfile]:errfile:_files'
    '-f[Use the specified format file for host data]:formatfile:_files'
    '-h[Set bcp hints]:hints'
    '-m[Stop after encountering maxerror errors]:maxerror'
    '-n[Host data file is in native format]'
    '-r[The row terminator for a character file]:terminator'
    '-t[The field terminator for character file]:terminator'
    '-v[Verbose output]'
    '-V[Print version information and exit]'
    '-i[Read input data from file]:file:_files'
    '-o[Write output data to file]:file:_files'
    '-C[Specify character set to use to talk to server]:charset'
    '*:filename:_files'
)
_arguments -s $arguments
