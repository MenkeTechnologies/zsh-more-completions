#compdef hls

local arguments

arguments=(
    '-1[Output one entry per line]'
    '-a[Show all files and directories, including invisible files]'
    '-b[Display special characters in an escaped backslash notation]'
    '-c[Sort and display entries by creation date rather than modification date]'
    '-d[List directory entries themselves rather than their contents]'
    '-f[Do not sort directory contents; list them in the order they appear]'
    '-i[Show the catalog IDs for each entry]'
    '-l[Display entries in long format]'
    '-m[Display entries in a continuous format separated by commas]'
    '-q[Replace special and non-printable characters with question marks]'
    '-r[Sort entries in reverse order before displaying]'
    '-s[Show the file size for each entry in 1K block units]'
    '-t[Sort and display entries by time]'
    '-x[Display entries in column format sorted horizontally into rows]'
    '-w[Format output lines suitable for display in the given width]:width'
    '-C[Display entries in column format with entries sorted vertically]'
    '-F[Append a single-character flag indicating the entry type]'
    '-N[Output all filenames verbatim without any escaping]'
    '-Q[Enclose all filenames within double-quotes and escape special characters]'
    '-R[Recursively descend into each directory encountered]'
    '-S[Sort and display entries by size]'
    '-U[Do not sort directory contents; list them in the order they appear]'
    '*:filename:_files'
)
_arguments -s $arguments
