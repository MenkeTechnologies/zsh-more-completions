#compdef vde_autolink

local arguments

arguments=(
    {-h,--help}'[Display help]'
    {-f,--rcfile}'[Configuration file]:file:_files'
    {-d,--daemon}'[Daemonize vde_autolink once run]'
    {-p,--pidfile}'[Write pid of daemon to pidfile]:pidfile:_files'
    {-M,--mgmt}'[Path of the management UNIX socket]:socket:_files'
    '--mgmtmode[Management UNIX socket access mode (octal)]:mode'
    {-s,--sock}'[Attach to this vde_switch socket]:socket:_files'
    {-S,--switchmgmt}'[Attach to this vde_switch management socket]:socket:_files'
    '*:filename:_files'
)
_arguments -s $arguments
