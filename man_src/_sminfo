#compdef sminfo

# Updated with fixes for broken option format

local arguments

arguments=(
    {-s,--state}'[Set SM state]:state'
    {-p,--priority}'[Set SM priority]:priority'
    {-a,--activity}'[Set activity count]:count'
    {-z,--config}'[Use config file]:file:_files'
    {-C,--Ca}'[CA name to use]:ca'
    {-P,--Port}'[CA port number to use]:port'
    {-D,--Direct}'[Use Direct address argument]'
    {-L,--Lid}'[Use LID address argument]'
    {-G,--Guid}'[Use GUID address argument]'
    {-t,--timeout}'[Timeout in ms]:ms'
    {-y,--m_key}'[M_Key to use in request]:key'
    {-e,--errors}'[Show send and receive errors]'
    {-v,--verbose}'[Increase verbosity level]'
    {-d,--debug}'[Raise debug level]'
    {-h,--help}'[Show help message]'
    {-V,--version}'[Show version]'
    '*:filename:_files'
)
_arguments -s $arguments
