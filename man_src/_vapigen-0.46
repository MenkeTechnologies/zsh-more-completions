#compdef vapigen-0.46

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Show help options]'
    '--vapidir[Look for package bindings in directory]:directory:_directories'
    '--girdir[Look for GIR bindings in directory]:directory:_directories'
    '--metadatadir[Look for GIR .metadata files in directory]:directory:_directories'
    '--nostdpkg[Do not include standard packages]'
    '--pkg[Include binding for package]:package'
    '--library[Library name]:name'
    {-d,--directory}'[Output directory]:directory:_directories'
    '--disable-warnings[Disable warnings]'
    '--version[Display version number]'
    {-q,--quiet}'[Do not print messages to the console]'
    '*:filename:_files'
)
_arguments -s $arguments
