#compdef mariadb-dump mysqldump

# Updated with latest MariaDB mariadb-dump/mysqldump options

local arguments

arguments=(
    {-A,--all-databases}'[Dump all databases]'
    '--add-drop-database[Add DROP DATABASE before each CREATE DATABASE]'
    '--add-drop-table[Add DROP TABLE before each CREATE TABLE]'
    '--add-drop-trigger[Add DROP TRIGGER before each CREATE TRIGGER]'
    '--add-locks[Surround each table dump with LOCK TABLES and UNLOCK TABLES]'
    '--allow-keywords[Allow creation of column names that are keywords]'
    '--apply-slave-statements[Add STOP SLAVE prior to CHANGE MASTER and START SLAVE at end of dump]'
    {-B,--databases}'[Dump several databases. Normally treats first name as db, rest as tables]'
    '--character-sets-dir[Directory for character set files]:dir:_directories'
    '--column-statistics[Add ANALYZE TABLE statements to generate statistics]'
    {-i,--comments}'[Write additional information in the dump file]'
    '--compact[Produce more compact output]'
    {-c,--complete-insert}'[Use complete INSERT statements that include column names]'
    '--compress[Compress all information sent between client and server]'
    '--create-options[Include all MySQL-specific table options in CREATE TABLE statements]'
    {-C,--compress}'[Use compression in server/client protocol]'
    {-#,--debug}'[Write debug log]:debug_options'
    '--debug-check[Print debug info on exit]'
    '--debug-info[Print debugging info, memory, and CPU usage on exit]'
    '--default-auth[Default authentication plugin]:plugin'
    '--default-character-set[Set the default character set]:charset'
    '--defaults-extra-file[Read defaults from file after global defaults files]:file:_files'
    '--defaults-file[Only read defaults from specified file]:file:_files'
    '--defaults-group-suffix[Also read groups with suffix]:suffix'
    '--delete-master-logs[On a master replication server, delete binary logs after performing the dump]'
    '--disable-keys[Add disable-keys statements around INSERT statements]'
    '--dump-slave[Include CHANGE MASTER statement listing binary log coordinates of slave]:value'
    {-E,--events}'[Dump events from the database]'
    {-e,--extended-insert}'[Use multiple-row INSERT syntax]'
    '--fields-terminated-by[Fields terminated by given string]:string'
    '--fields-enclosed-by[Fields enclosed by given character]:char'
    '--fields-optionally-enclosed-by[Fields optionally enclosed by given character]:char'
    '--fields-escaped-by[Fields escaped by given character]:char'
    {-F,--flush-logs}'[Flush the log file before starting the dump]'
    '--flush-privileges[Emit a FLUSH PRIVILEGES after dumping mysql database]'
    {-f,--force}'[Continue even if an SQL error occurs during a table dump]'
    '--gtid[Add SET @@GLOBAL.gtid_slave_pos in output]'
    {-?,--help}'[Display help message and exit]'
    '--hex-blob[Dump binary columns using hexadecimal notation]'
    {-h,--host}'[Connect to the specified host]:host:_hosts'
    '--ignore-table[Do not dump the specified table]:db.table'
    '--include-master-host-port[Add MASTER_HOST and MASTER_PORT to CHANGE MASTER]'
    '--insert-ignore[Use INSERT IGNORE instead of INSERT]'
    '--lines-terminated-by[Lines terminated by given string]:string'
    {-x,--lock-all-tables}'[Lock all tables across all databases]'
    {-l,--lock-tables}'[Lock all tables before dumping them]'
    '--log-error[Log warnings and errors to specified file]:file:_files'
    '--master-data[Write the binary log file name and position to the output]:value'
    '--max-allowed-packet[Maximum packet length to send to or receive from server]:length'
    '--net-buffer-length[Buffer size for TCP/IP and socket communication]:length'
    {-n,--no-create-db}'[Do not write CREATE DATABASE statements]'
    {-t,--no-create-info}'[Do not write CREATE TABLE statements]'
    {-d,--no-data}'[Do not write any table row information (dump only the structure)]'
    '--no-defaults[Do not read any option files]'
    '-N[Do not include SET NAMES statement in output]'
    '--opt[Shorthand for --add-drop-table --add-locks --create-options --disable-keys --extended-insert --lock-tables --quick --set-charset]'
    '--order-by-primary[Sort each table rows by its primary key]'
    {-p,--password}'[Password to use when connecting to server]:password'
    '--pipe[On Windows, connect to server using named pipe]'
    '--plugin-dir[Directory for client-side plugins]:dir:_directories'
    {-P,--port}'[TCP/IP port number to use for connection]:port'
    '--print-defaults[Print defaults and exit]'
    '--protocol[Connection protocol to use]:protocol:(TCP SOCKET PIPE MEMORY)'
    {-q,--quick}'[Do not buffer query results, dump directly to stdout]'
    {-Q,--quote-names}'[Quote identifiers within backtick characters]'
    '--replace[Use REPLACE INTO instead of INSERT INTO]'
    '--result-file[Direct output to specified file]:file:_files'
    {-R,--routines}'[Dump stored routines (functions and procedures)]'
    '--set-charset[Add SET NAMES default_character_set to the output]'
    '--single-transaction[Issue a BEGIN statement before dumping data]'
    '--skip-add-drop-table[Do not add DROP TABLE before each CREATE TABLE]'
    '--skip-add-locks[Do not add locks]'
    '--skip-comments[Do not write additional information]'
    '--skip-compact[Do not produce compact output]'
    '--skip-disable-keys[Do not disable keys]'
    '--skip-dump-date[Do not add dump date to output]'
    '--skip-extended-insert[Do not use multiple-row INSERT syntax]'
    '--skip-lock-tables[Do not lock tables before dumping]'
    '--skip-opt[Disable --opt]'
    '--skip-quick[Do not retrieve rows for a table from the server one row at a time]'
    '--skip-quote-names[Do not quote identifiers]'
    '--skip-set-charset[Do not write SET NAMES]'
    '--skip-triggers[Do not dump triggers]'
    '--skip-tz-utc[Do not set TIME_ZONE]'
    {-S,--socket}'[For connections to localhost, the Unix socket file to use]:socket:_files'
    '--ssl[Enable SSL for connection]'
    '--ssl-ca[Path to CA file in PEM format]:file:_files'
    '--ssl-capath[Path to directory containing CA certificates]:dir:_directories'
    '--ssl-cert[Path to SSL certificate in PEM format]:file:_files'
    '--ssl-cipher[List of permitted SSL ciphers]:ciphers'
    '--ssl-key[Path to SSL key in PEM format]:file:_files'
    '--ssl-verify-server-cert[Verify server certificate]'
    {-T,--tab}'[Create tab-separated data files for each table]:path:_directories'
    '--tables[Override --databases, following arguments are table names]'
    '--triggers[Dump triggers for each dumped table]'
    '--tz-utc[Add SET TIME_ZONE to dump file]'
    {-u,--user}'[MySQL user name]:user'
    {-v,--verbose}'[Verbose mode]'
    {-V,--version}'[Output version information and exit]'
    {-w,--where}'[Dump only rows matching the given WHERE condition]:condition'
    '--xml[Produce XML output]'
    '*:database:_files'
)
_arguments -s $arguments
