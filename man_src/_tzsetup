#compdef tzsetup
# Documentation: https://man.archlinux.org/search?q=tzsetup
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-C[open all files and directories relative to chroot_directory]:chroot_directory:_directories'
    '-n[do not create or copy files]'
    '-r[reinstall the zoneinfo file installed last time]'
    '-s[skip the initial question about adjusting the clock if not set to UTC]'
    '*:filename:_files'
)
_arguments -s $arguments
