#compdef thingy52

local arguments

arguments=(
  {-h,--help}'[show this help message and exit]'
  '-n[number of times to loop data]'
  '-t[time between polling]'
  '--temperature[monitor temperature sensor]'
  '--pressure[monitor pressure sensor]'
  '--humidity[monitor humidity sensor]'
  '--gas[monitor gas (air quality) sensor]'
  '--color[monitor color sensor]'
  '--keypress[monitor button keypress events]'
  '--tap[monitor tap detection]'
  '--orientation[monitor orientation]'
  '--quaternion[monitor quaternion (rotation)]'
  '--stepcnt[monitor step counter]'
  '--rawdata[monitor raw sensor data]'
  '--euler[monitor euler angles]'
  '--rotation[monitor rotation matrix]'
  '--heading[monitor compass heading]'
  '--gravity[monitor gravity vector]'
  '--battery[monitor battery level]'
  '--speaker[control speaker]'
  '--microphone[monitor microphone]'
  '*:filename:_files'
)

_arguments -s $arguments
