#compdef mariadb-find-rows mysql_find_rows

local arguments

arguments=(
    {-\?,--help}'[Display help and exit]'
    '--regexp[Regular expression to match]:pattern'
    '--rows[Only include queries that affect at least this many rows]:num'
    '--skip-use-db[Skip USE db statements]'
    '--start-datetime[Start reading at the specified datetime]:datetime'
    '--start-position[Start reading at the specified position]:position'
    '*:filename:_files'
)
_arguments -s $arguments
