#compdef erl

local arguments

arguments=(
    '-args_file[Read command-line arguments from file]:FileName:_files'
    '-async_shell_start[Do not wait for system boot before reading shell input]'
    '-boot[Specify the name of the boot file]:File:_files'
    '-boot_var[Set a boot path variable]:Var Dir'
    '-code_path_cache[Enable the code path cache of the code server]'
    '-compile[Compile the specified modules and then terminate]:modules'
    '-config[Specify the name of a configuration file]:Config:_files'
    '-connect_all[If false, global does not maintain a fully connected network]:boolean:(true false)'
    '-cookie[Obsolete flag, use -setcookie instead]:Cookie'
    '-detached[Start the Erlang runtime system detached from the system console]'
    '-emu_args[Print the arguments sent to the emulator]'
    '-emu_type[Start an emulator of a different type]:Type'
    '-env[Set an OS environment variable for the Erlang runtime]:Variable Value'
    '-epmd_module[Configure the module responsible to communicate to epmd]:Module'
    '-eval[Make init evaluate the expression]:Expr'
    '-extra[Everything following is considered plain arguments]:arguments'
    '-heart[Start heartbeat monitoring of the Erlang runtime system]'
    '-hidden[Start the Erlang runtime system as a hidden node]'
    '-hosts[Specify IP addresses for hosts with Erlang boot servers]:Hosts'
    '-id[Specify the identity of the Erlang runtime system]:Id'
    '-init_debug[Make init write debug information while interpreting the boot script]'
    '-loader[Specify the method used by erl_prim_loader to load Erlang modules]:Loader'
    '-make[Invoke make:all() in the current working directory and then terminate]'
    '-man[Display the manual page for the Erlang module]:Module'
    '-mode[Set auto-loading mode for modules]:mode:(interactive embedded)'
    '-name[Make the Erlang runtime system into a distributed node]:Name'
    '-noinput[Ensure the runtime system never tries to read any input]'
    '-noshell[Start an Erlang runtime system with no shell]'
    '-nostick[Disable the sticky directory facility of the code server]'
    '-oldshell[Invoke the old Erlang shell]'
    '-pa[Add directories to the beginning of the code path]:directories'
    '-pz[Add directories to the end of the code path]:directories'
    '-path[Replace the path specified in the boot script]:directories'
    '-proto_dist[Specify a protocol for Erlang distribution]:Proto:(inet_tcp inet_tls inet6_tcp inet6_tls)'
    '-remsh[Start with a remote shell connected to Node]:Node'
    '-rsh[Specify an alternative to ssh for starting a slave node]:Program'
    '-run[Make init call the specified function]:Mod Func Args'
    '-s[Make init call the specified function]:Mod Func Args'
    '-setcookie[Set the magic cookie of the node]:Cookie'
    '-shutdown_time[Specify how long init is allowed to spend shutting down]:Time'
    '-sname[Make the Erlang runtime system into a distributed node with short name]:Name'
    '-start_epmd[Specify whether Erlang should start epmd on startup]:boolean:(true false)'
    '-version[Make the emulator print its version number]'
    '*:filename:_files'
)
_arguments -s $arguments
