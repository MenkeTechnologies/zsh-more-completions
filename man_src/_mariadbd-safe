#compdef mariadbd-safe mysqld_safe

local arguments

arguments=(
    '--help[Display help and exit]'
    '--basedir[Path to the MariaDB installation directory]:path:_directories'
    '--core-file-size[Size of the core file that mysqld should be able to create]:size'
    '--crash-script[Script to call after mysqld crashes]:file:_files'
    '--datadir[Path to the data directory]:path:_directories'
    '--defaults-extra-file[Read this option file after the global files]:path:_files'
    '--defaults-file[Use only the specified option file]:file_name:_files'
    '--flush-caches[Flush and purge buffers/caches before starting the server]'
    '--ledir[Path to directory where server binary is located]:path:_directories'
    '--log-error[Write error log to the specified file]:file:_files'
    '--malloc-lib[Shared library for malloc instead of system malloc]:lib:_files'
    '--mysqld[Name of the server program to start]:prog_name'
    '--mysqld-version[Suffix to append to the mysqld server binary name]:version'
    '--nice[Set the scheduling priority of the server]:priority'
    '--no-auto-restart[Do not auto-restart the server if it dies]'
    '--no-defaults[Do not read any option files]'
    '--numa-interleave[Run mysqld with its memory interleaved on all CPUs]'
    '--open-files-limit[Number of files that mysqld should be able to open]:count'
    '--pid-file[Path to the process ID file]:file_name:_files'
    '--plugin-dir[Path to the plugin directory]:dir_name:_directories'
    '--port[Port number for TCP/IP connections]:port_num'
    '--skip-kill-mysqld[Do not kill stray mysqld processes at startup]'
    '--socket[Unix socket file to use for connections]:path:_files'
    '--syslog[Log error messages to syslog]'
    '--skip-syslog[Do not log error messages to syslog]'
    '--syslog-tag[Tag for syslog messages]:tag'
    '--timezone[Set the timezone]:timezone'
    '--user[Run mysqld as the specified user]:user'
    '*:filename:_files'
)
_arguments -s $arguments
