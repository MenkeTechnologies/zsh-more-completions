#compdef omp-dialog

local arguments

arguments=(
    {-h,--host}'[Connect to OpenVAS Manager on host]:host:_hosts'
    {-p,--port}'[Connect to OpenVAS Manager on port]:port'
    {-u,--username}'[Use the username to access the OpenVAS Manager]:user'
    {-w,--password}'[Use the password to access the OpenVAS Manager]:password'
    {-c,--configfile}'[Load connection configuration from file]:file:_files'
    {-d,--debug}'[Write debug output to omp-dialog.log]'
    {-\?,--help}'[Show help]'
    '*:filename:_files'
)
_arguments -s $arguments
