#compdef word-list-compress
# Documentation: https://man.archlinux.org/search?q=word-list-compress
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-c[Compress the plain text word list read from standard input]'
    '-d[Decompress the compressed word list read from standard input]'
    '*:filename:_files'
)
_arguments -s $arguments
