#compdef tracker3-export
# Documentation: https://man.archlinux.org/search?q=tracker3-export
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-o,--output-format}'[choose which RDF format to use for output]:format'
    {-g,--show-graphs}'[deprecated, same as --output-format trig]'
    '--2to3[helper for migrating data from Tracker 2.x databases]'
    '--keyfile[output the data in key file format (only with --2to3)]'
    '*:filename:_files'
)
_arguments -s $arguments
