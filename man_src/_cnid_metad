#compdef cnid_metad
# Documentation: https://man.archlinux.org/search?q=cnid_metad
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-d[Run in the foreground and leave stdin/stdout/stderr open]'
    '-F[Use the specified configuration file]:file:_files'
    {-v,-V}'[Show version and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
