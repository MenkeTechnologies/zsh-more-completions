#compdef crashinfo
# Documentation: https://man.archlinux.org/search?q=crashinfo
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-d[Specify an alternate core dump directory]:directory:_directories'
    '-n[Use the specified core dump]:vmcore number'
    '-k[Specify an explicit kernel file]:kernel:_files'
    '*:filename:_files'
)
_arguments -s $arguments
