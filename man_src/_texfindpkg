#compdef texfindpkg
# Documentation: https://man.archlinux.org/search?q=texfindpkg
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-f[query or install packages by file name]:name'
    '-c[query or install packages by command name]:name'
    '-e[query or install packages by environment name]:name'
    '*:filename:_files'
)
_arguments -s $arguments
