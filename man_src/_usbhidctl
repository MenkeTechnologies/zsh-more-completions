#compdef usbhidctl

local arguments

arguments=(
    '-a[Show all items and their current values if device returns]'
    '-f[Specify a path name for the device to operate on]:device:_files'
    '-l[Loop and dump the device data every time it changes]'
    '-n[Suppress printing of the item name]'
    '-r[Dump the report descriptor]'
    '-t[Specify a path name for the HID usage table file]:table:_files'
    '-v[Be verbose]'
    '-w[Change item values]:items'
    '-x[Dump data in hexadecimal as well as decimal]'
    '-z[Reset reports to zero before processing other arguments]'
    '*:filename:_files'
)
_arguments -s $arguments
