#compdef headerdoc2html
# Documentation: https://man.archlinux.org/search?q=headerdoc2html
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-H[Include the htmlHeader line as specified in the config file]'
    '-X[Switch from HTML to XML output]'
    '-d[Turn on extra debugging output]'
    '-h[Output an XML file containing metadata about the header]'
    '-p[Turn on the C preprocessor]'
    '-q[Quiet mode; suppress informational messages]'
    '-u[Produce unsorted output]'
    '-v[Print version information]'
    '*:filename:_files'
)
_arguments -s $arguments
