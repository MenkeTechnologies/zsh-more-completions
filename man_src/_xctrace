#compdef xctrace

local arguments

arguments=(
    '--output[Save the trace to the specified path]:path:_files'
    '--append-run[Target an existing trace file]:file:_files'
    '--template[Record using given trace template name or path]:template'
    '--device[Record on a device with the given name or UDID]:device'
    '--time-limit[Limit the recording to the specified time period]:duration'
    '--window[Configure trace to operate in windowed mode]:duration'
    '--all-processes[Record all processes running on the system]'
    '--attach[Attach and record running process with the given name or pid]:name_or_pid'
    '--launch[Launch and record process with the given name or path]:path:_files'
    '--package[Install the given Instruments Package temporarily]:package:_files'
    '--target-stdin[Redirect standard input stream of a launched process]:file:_files'
    '--target-stdout[Redirect standard output stream of a launched process]:file:_files'
    '--env[Set environment variable for a launched process]:var=value'
    '--no-prompt[Skip any prompts that would be otherwise presented]'
    '--input[Import data from a supported file format]:path:_files'
    '--toc[Export the table of contents of a trace file]'
    '--xpath[Perform XPath query on the table of contents]:xpath'
    '*:filename:_files'
)
_arguments -s $arguments
