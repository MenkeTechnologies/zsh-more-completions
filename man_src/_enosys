#compdef enosys

local arguments

arguments=(
    {-s,--syscall}'[Block the specified syscall]:syscall'
    {-i,--ioctl}'[Block the specified ioctl request]:ioctl'
    {-l,--list}'[List available syscalls]'
    {-m,--list-ioctl}'[List available ioctl requests]'
    {-h,--help}'[Display help]'
    {-V,--version}'[Display version information]'
    '*:filename:_files'
)
_arguments -s $arguments
