#compdef cvslock

local arguments

arguments=(
    '-q[Quiet mode, do not print diagnostic messages]'
    '-p[Set the process ID in lock files]:pid'
    '-d[Specify the CVS repository root]:root:_directories'
    '-R[Acquire a lock for safe reading of the repository]'
    '-W[Acquire a write lock on the repository]'
    '-s[Invoke the user login shell after acquiring the lock]'
    '-c[Execute the specified command after acquiring the lock]:command'
    '-u[Drop a previously created lock]'
    '-l[Lock only the specified directory]:directory:_directories'
    '*:filename:_files'
)
_arguments -s $arguments
