#compdef hivexregedit

local arguments

arguments=(
    '--help[Display help]'
    '--debug[Enable debugging in the hivex library]'
    '--merge[Merge a regedit file into a hive file]:hivefile:_files'
    '--export[Export a key from a hive file as a regedit file]:hivefile:_files'
    '--prefix[Set the prefix for the registry path]:prefix'
    '--encoding[Specify the encoding for strings when merging]:encoding:(UTF-16LE ASCII)'
    '--unsafe-printable-strings[Assume strings are UTF-16LE and print them as strings when exporting]'
    '--unsafe[Use heuristics to tolerate certain levels of corruption within hives]'
    '*:filename:_files'
)
_arguments -s $arguments
