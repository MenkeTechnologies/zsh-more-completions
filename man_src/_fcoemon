#compdef fcoemon
# Documentation: https://man.archlinux.org/search?q=fcoemon
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-f,--foreground}'[Run fcoemon in the foreground]'
    {-d,--debug}'[Enable debugging messages]'
    {-l,--legacy}'[Force fcoemon to use the legacy libfcoe parameters interface]'
    {-s,--syslog}'[Use syslogd for logging instead of stdout and stderr]'
    '(- * :)'{-h,--help}'[Show help message with basic usage instructions]'
    {-v,--version}'[Show the version of the fcoemon command]'
    '*:filename:_files'
)
_arguments -s $arguments
