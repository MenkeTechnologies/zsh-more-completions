#compdef fcoeadm

local arguments

arguments=(
    {-m,--mode}'[Control the FCoE mode of operation]:mode:(fabric vn2vn)'
    {-c,--create}'[Create an FCoE instance on the specified interface]:ethX'
    {-d,--destroy}'[Destroy the FCoE instance on the specified interface]:ethX'
    {-r,--reset}'[Reset the FCoE instance on the specified interface]:ethX'
    {-S,--Scan}'[Rescan for new targets on the specified interface]:ethX'
    {-i,--interface}'[Show information about the specified FCoE interface]:ethX'
    {-f,--fcf}'[Show information about discovered Fibre Channel Forwarders]:ethX'
    {-t,--target}'[Show information about discovered targets]:ethX'
    {-l,--lun}'[Show information about discovered LUNs]:ethX'
    {-s,--stats}'[Show statistics for the FCoE connection]'
    {-b,--lesb}'[Show the Link Error Status Block for the FCoE connection]'
    '(- * :)'{-h,--help}'[Show help message]'
    {-v,--version}'[Show version]'
    '*:filename:_files'
)
_arguments -s $arguments
