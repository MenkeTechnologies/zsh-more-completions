#compdef checkstyle

local arguments

arguments=(
    '-c[Specify the file that configures the checks to apply]:configuration file:_files'
    '-f[Specify the output format]:format:(plain xml)'
    '-p[Specify a properties file to use]:properties file:_files'
    '-o[Specify the file to output to]:output file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
