#compdef ipfs

local arguments

arguments=(
    '-d[Change the default directory used for saving state information]:dir:_directories'
    '-n[Do not actually take any action that would affect kernel information]'
    '-v[Provide a verbose description of the operation]'
    '-i[Change all instances of interface name ifname1 to ifname2 in the state save file]:ifname1,ifname2'
    '-N[Operate on NAT information]'
    '-S[Operate on filtering state information]'
    '-u[Unlock state tables in the kernel]'
    '-l[Lock state tables in the kernel]'
    '-r[Read information from the specified file and load it into the kernel]:file:_files'
    '-w[Write information out to the specified file from the kernel]:file:_files'
    '-R[Restore all saved state information from files]'
    '-W[Write all state information to files]'
    '*:filename:_files'
)
_arguments -s $arguments
