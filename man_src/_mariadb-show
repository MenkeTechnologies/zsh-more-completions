#compdef mariadb-show mysqlshow

local arguments

arguments=(
    {-\?,--help}'[Display help and exit]'
    '--character-sets-dir[Directory for character set files]:path:_directories'
    '--compress[Compress all information sent between client and server]'
    '--count[Show the number of rows per table]'
    {-\#,--debug}'[Write debugging log]:debug_options'
    '--debug-check[Check memory and open file usage at exit]'
    '--debug-info[Print debugging information at exit]'
    '--default-auth[Default authentication client-side plugin]:name'
    '--default-character-set[Set the default character set]:charset_name'
    '--defaults-extra-file[Read option file after the global option file]:filename:_files'
    '--defaults-file[Only read options from the given file]:filename:_files'
    {-h,--host}'[Connect to the specified host]:host_name:_hosts'
    {-i,--status}'[Show extra information about each table]'
    {-k,--keys}'[Show table indexes]'
    '--no-defaults[Do not read any option files]'
    {-p,--password}'[Password to use for connection]:password'
    {-W,--pipe}'[Connect using a named pipe]'
    '--plugin-dir[Directory for client-side plugins]:name:_directories'
    {-P,--port}'[Port number for connection]:port_num'
    '--print-defaults[Print the program argument list and exit]'
    '--protocol[Connection protocol to use]:protocol:(TCP SOCKET PIPE MEMORY)'
    '--show-table-type[Show the table type column]'
    {-S,--socket}'[Socket file for connection]:path:_files'
    '--ssl[Enable SSL for connection]'
    '--ssl-verify-server-cert[Verify server certificate]'
    {-t,--table}'[Deprecated synonym for --show-table-type]'
    {-u,--user}'[User for login]:user_name'
    {-v,--verbose}'[More verbose output]'
    {-V,--version}'[Output version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
