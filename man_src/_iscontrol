#compdef iscontrol

local arguments

arguments=(
    '-c[A file containing configuration key-options]:file:_files'
    '-d[Do a discovery session and exit]'
    '-n[Search for the block named nickname in the config file]:nickname'
    '-p[Write the process ID of the session to the specified pidfile]:pidfile:_files'
    '-t[The target IP address or name]:target:_hosts'
    '-v[Verbose mode]'
    '*:filename:_files'
)
_arguments -s $arguments
