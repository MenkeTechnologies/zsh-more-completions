#compdef mawk

local arguments

arguments=(
    '-f[Program text is read from file instead of from the command line]:file:_files'
    '-v[Assigns value to program variable]:var=value'
    '--[Indicates the unambiguous end of options]'
    '-W[Specify mawk options]:option:(dump exec interactive posix_space sprintf version)'
    '-F[Sets the field separator FS to value]:value'
    '*:filename:_files'
)
_arguments -s $arguments
