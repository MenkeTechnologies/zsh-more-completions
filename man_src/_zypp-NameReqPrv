#compdef zypp-NameReqPrv

local arguments

arguments=(
    '--root[Use alternative root directory]:directory:_directories'
    '--installed[Query only installed packages]'
    '-i[Show provides]'
    '-I[Do not show provides]'
    '-n[Show names]'
    '-N[Do not show names]'
    '-p[Show provides]'
    '-P[Do not show provides]'
    '-r[Show requires]'
    '-R[Do not show requires]'
    '-c[Show conflicts]'
    '-C[Do not show conflicts]'
    '-o[Show obsoletes]'
    '-O[Do not show obsoletes]'
    '-m[Show recommends]'
    '-M[Do not show recommends]'
    '-s[Show supplements]'
    '-S[Do not show supplements]'
    '-a[Query all repos]'
    '-A[Query all packages in all repos]'
    '-D[Dump info about specific package]:package'
    '*:filename:_files'
)
_arguments -s $arguments
