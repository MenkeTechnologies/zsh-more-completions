#compdef vgrind

local arguments

arguments=(
    '-W[Force output to the wide Versatec printer rather than the narrow Varian]'
    '-d[Specify an alternate language definitions file]:file:_files'
    '-f[Force filter mode]'
    '-h[Specify a particular header for every output page]:header'
    '-l[Specify the language to use]:language'
    '-n[Force no keyword bolding]'
    '-p[Use postproc to post-process the output]:postprocessor'
    '-s[Specify a point size to use on output]:pointsize'
    '-t[Send formatted text to standard output]'
    '-x[Output the index file in a pretty format]'
    '*:filename:_files'
)
_arguments -s $arguments
