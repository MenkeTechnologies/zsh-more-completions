#compdef mariadb-access mysqlaccess

local arguments

arguments=(
    {-\?,--help}'[Display help and exit]'
    {-b,--brief}'[Single-line tabular report]'
    '--commit[Copy the new access privileges from temporary tables to the original grant tables]'
    '--copy[Reload the temporary grant tables from original ones]'
    {-d,--db}'[Specify the database name]:db_name'
    '--debug[Set debug level]:N'
    {-h,--host}'[Connect to the specified host]:host_name:_hosts'
    '--howto[Display some examples of usage]'
    '--old_server[Connect to an old MySQL server that does not know how to handle full WHERE clauses]'
    {-p,--password}'[Use the specified password to connect]:password'
    '--plan[Display suggestions and ideas for future releases]'
    '--preview[Show the privilege differences after making changes to the temporary tables]'
    '--relnotes[Display the release notes]'
    {-H,--rhost}'[Connect to the specified MySQL server from the given remote host]:host_name:_hosts'
    '--rollback[Undo the most recent changes to the temporary grant tables]'
    {-P,--spassword}'[Use the specified password for the superuser]:password'
    {-U,--superuser}'[Specify the superuser name]:user_name'
    {-t,--table}'[Specify the table name]'
    {-u,--user}'[Specify the user name]:user_name'
    {-v,--version}'[Display version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
