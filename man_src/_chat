#compdef chat

local arguments

arguments=(
    '-f[Read the chat script from the chat file]:file:_files'
    '-t[Set the timeout for the expected string to be received]:timeout'
    '-r[Set the file for output of the report strings]:file:_files'
    '-e[Start with the echo option turned on]'
    '-E[Enable environment variable substitution within chat scripts]'
    '-v[Execute the chat script in verbose mode]'
    '-V[Execute the chat script in stderr verbose mode]'
    '-s[Use stderr]'
    '-S[Do not use the SYSLOG]'
    '-T[Pass in an arbitrary string for substitution]:phone number'
    '-U[Pass in a second string for substitution]:phone number'
    '*:filename:_files'
)
_arguments -s $arguments
