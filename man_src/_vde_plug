#compdef vde_plug
# Documentation: https://man.archlinux.org/search?q=vde_plug
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-p[Decide which port of the switch to use]:portnum'
    '-g[Group ownership of the communication socket]:group'
    '-m[Octal chmod like permissions for the comm sockets]:octal-mode'
    '--sock[Specify the directory which contains the UNIX socket]:socketdir:_directories'
    '*:filename:_files'
)
_arguments -s $arguments
