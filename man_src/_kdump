#compdef kdump

local arguments

arguments=(
    '-d[Display all numbers in decimal]'
    '-E[Display elapsed timestamps]'
    '-f[Display the specified file instead of ktrace.out]:file:_files'
    '-H[List the thread ID with each trace record if available]'
    '-l[Loop reading the trace file, waiting for more data at end-of-file]'
    '-m[Display at most maxdata bytes when decoding I/O]:maxdata'
    '-n[Suppress ad hoc translations]'
    '-p[Display only trace events that correspond to the specified process or thread]:pid'
    '-R[Display relative timestamps]'
    '-r[Display structure members such as UIDs and GIDs using raw numbers]'
    '-S[Display system call numbers]'
    '-s[Suppress display of I/O data]'
    '-T[Display absolute timestamps for each entry]'
    '-A[Display description of the ABI of traced process]'
    '-t[Specify the trace points to display]:trpoints'
    '*:filename:_files'
)
_arguments -s $arguments
