#compdef uefisign

local arguments

arguments=(
    '-V[Determine whether the file is signed]'
    '-k[Name of file containing the private key used to sign the binary]:keyfile:_files'
    '-c[Name of file containing the certificate used to sign the binary]:certfile:_files'
    '-o[Name of file to write the signed binary to]:outfile:_files'
    '-v[Be verbose]'
    '*:filename:_files'
)
_arguments -s $arguments
