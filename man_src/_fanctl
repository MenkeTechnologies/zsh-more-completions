#compdef fanctl

local arguments

arguments=(
    {-u,--underlay}'[Specify the underlay network address and mask]:underlay'
    {-o,--overlay}'[Specify the overlay network address and mask]:overlay'
    '--type[Set the encapsulation type for this Fan bridge]:type'
    '--mode[Set the bridge mode]:mode:(compact sliced)'
    '--dhcp[Turn on automatic address allocation for the Fan bridge]'
    '--host-reserve[Set the number of reserved host addresses]:count'
    '--bridge[Set a custom bridge name]:name'
    '--enable[Mark the Fan bridge to be automatically configured]'
    '*:filename:_files'
)
_arguments -s $arguments
