#compdef tpm2_evictcontrol

local arguments

arguments=(
    '-A[hierarchy to authorize the commands]:hierarchy'
    '-H[loaded transient or persistent object handle]:handle'
    '-S[input session handle]:session_handle'
    '-c[filename for object context]:file:_files'
    '-P[password for authorization]:password'
    '-h[display help information]'
    '-v[display version, supported tctis and exit]'
    '-V[increase verbosity of tool output]'
    '-Q[suppress informational output]'
    '-Z[enable errata fixups]'
    '-T[select the TCTI used for communication]:tcti'
    '*:filename:_files'
)
_arguments -s $arguments
