#compdef config

local arguments

arguments=(
    '-V[Print the config version number]'
    '-C[Process INCLUDE_CONFIG_FILE directives]'
    '-I[Search in path for any included files]:path:_directories'
    '-d[Use destdir as the output directory]:directory:_directories'
    '-s[Use srcdir as the source directory]:directory:_directories'
    '-m[Print the MACHINE and MACHINE_ARCH values and exit]'
    '-g[Configure a system for debugging]'
    '-x[Print kernel configuration file embedded into a kernel file]'
    '-p[Configure a system for profiling]'
    '*:filename:_files'
)
_arguments -s $arguments
