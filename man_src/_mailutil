#compdef mailutil

local arguments

arguments=(
    {-m,--merge}'[Perform a merging transfer]:mode:(strstrstrstrstrstr)'
    {-d,--debug}'[Print full debugging telemetry including protocol operations]'
    {-v,--verbose}'[Print verbose (non-error) telemetry]'
    {-u,--user}'[Attempt to become the indicated user]:userid'
    '--rw[Open source mailbox in readwrite mode rather than readonly]'
    '--kw[Create keywords of the source mailbox in the destination]'
    '--ig[Ignore the keywords of the source mailbox completely]'
    '*:filename:_files'
)
_arguments -s $arguments
