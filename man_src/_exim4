#compdef exim4

local arguments

arguments=(
    '--help[Output a brief description of what Exim is]'
    '--version[Alias for -bV, display version information]'
    '-bd[Run Exim as a daemon, awaiting incoming SMTP connections]'
    '-bdf[Same as -bd except it never disconnects from the controlling terminal]'
    '-be[Run Exim in expansion testing mode]'
    '-bem[Run expansion testing, reading message from file]:filename:_files'
    '-bF[Test a system filter file]:filename:_files'
    '-bf[Run Exim in user filter testing mode]:filename:_files'
    '-bh[Run a fake SMTP session as if from the given IP address]:address'
    '-bhc[Same as -bh but without callout verification]:address'
    '-bi[Rebuild alias file (Sendmail compatibility)]'
    '-bm[Accept an incoming locally-generated message on stdin]'
    '-bmalware[Scan the given file for malware]:filename:_files'
    '-bnq[Do not automatically qualify unqualified addresses]'
    '-bP[Print the values of all Exim main configuration options]'
    '-bp[List the contents of the mail queue]'
    '-bpc[Count the number of messages in the queue]'
    '-bpr[List queue unsorted]'
    '-bpu[List queue showing only undelivered addresses]'
    '-brt[Test retry rules]'
    '-brw[Test address rewriting rules]'
    '-bS[Accept batched SMTP input]'
    '-bs[Accept SMTP commands on stdin]'
    '-bt[Run Exim in address testing mode]'
    '-bV[Display the current version number and compilation details]'
    '-bv[Run Exim in address verification mode]'
    '-bvs[Verify address as a sender rather than a recipient]'
    '-C[Find the runtime configuration from the given file]:filelist:_files'
    '-E[Specify incoming message is a locally-generated delivery error]'
    '-F[Set the sender full name]:string'
    '-f[Set the envelope sender address]:address'
    '-G[Equivalent to an ACL applying submission control]'
    '-i[A dot on a line by itself does not terminate a non-SMTP message]'
    '-L[Set syslog process name tag]:tag'
    '-M[Run a delivery attempt on each specified message]'
    '-Mf[Mark each listed message as frozen]'
    '-Mg[Give up trying to deliver the listed messages]'
    '-Mrm[Remove the given messages from the queue]'
    '-Mt[Thaw any of the listed messages that are frozen]'
    '-N[Debugging option that inhibits delivery at the transport level]'
    '-odb[Deliver in background after accepting message]'
    '-odf[Deliver in foreground after accepting message]'
    '-odq[Queue the message instead of delivering]'
    '-oi[A dot on a line by itself does not terminate the message]'
    '-q[Start queue runner]'
    '-R[Deliver messages matching the given string in the recipient]:string'
    '-S[Deliver messages matching the given string in the sender]:string'
    '-t[Extract recipients from the message header]'
    '-ti[Equivalent to -t -i]'
    '--tls-on-connect[Start TLS immediately on connection]'
    '-v[Write verbose information to stderr during delivery]'
    '-X[Send debug information to the specified log file]:logfile:_files'
    '*:filename:_files'
)
_arguments -s $arguments
