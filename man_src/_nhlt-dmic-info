#compdef nhlt-dmic-info
# Documentation: https://man.archlinux.org/search?q=nhlt-dmic-info
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-h,--help}'[Print the help information]'
    {-f,--file}'[Input file with the binary ACPI NHLT table]:file:_files'
    {-o,--output}'[Output file for results]:file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
