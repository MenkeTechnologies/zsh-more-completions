#compdef fileop
# Documentation: https://man.archlinux.org/search?q=fileop
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-f[Specify the number of files]:count'
    '-l[Specify the file size]:size'
    '-u[Run using the unique directory mode]'
    '-s[Run using single file mode]'
    '-t[Run using thread mode]'
    '-v[Verbose output]'
    '-e[Execute operations]'
    '-b[Specify block size]:size'
    '-w[Write mode]'
    '*:filename:_files'
)
_arguments -s $arguments
