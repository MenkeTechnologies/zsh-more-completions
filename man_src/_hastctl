#compdef hastctl
# Documentation: https://man.archlinux.org/search?q=hastctl
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-e[Size of an extent used for synchronization]:extent_size'
    '-k[Maximum number of dirty extents to keep dirty all the time]:keepdirty'
    '-m[Size of the smaller provider used as backend storage on both nodes]:mediasize'
    '-c[Specify alternative location of the configuration file]:config:_files'
    '-d[Print debugging information]'
    '*:filename:_files'
)
_arguments -s $arguments
