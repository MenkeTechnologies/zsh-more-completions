#compdef vncconfig

local arguments

arguments=(
    '--connect[Tell Xvnc server to make a reverse connection to a listening VNC viewer]:host\:port'
    '--disconnect[Disconnect Xvnc from all viewers]'
    '--list[List all parameters supported by Xvnc]'
    '--get[Print the current value of the given Xvnc parameter]:param'
    '--nowin[Do not show the settings window on the desktop]'
    '--iconic[Start with the settings window iconified]'
    '--desc[Print a short description of the given Xvnc parameter]:param'
    '--set[Set a parameter]:param=value'
    '--display[Specify the Xvnc server to control]:display'
    '*:filename:_files'
)
_arguments -s $arguments
