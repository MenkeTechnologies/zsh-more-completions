#compdef fros
# Documentation: https://man.archlinux.org/search?q=fros
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Show help message and exit]'
    {-v,--verbose}'[More verbose/talkative output]'
    '--is-available[Check if the current environment supports screencasting]'
    '*:filename:_files'
)
_arguments -s $arguments
