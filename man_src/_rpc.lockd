#compdef rpc.lockd
# Documentation: https://man.archlinux.org/search?q=rpc.lockd
# Reference accessed: 2026-05-16

# Autogenerated from man page
# Updated with latest rpc.lockd options

local arguments

arguments=(
    '-d[enable debugging information to be written to syslog]:level'
    '-g[specify the grace period in seconds]:seconds'
    '-x[tell rpc.lockd to use extended NLM protocol]'
    '*:filename:_files'
)
_arguments -s $arguments
