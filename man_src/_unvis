#compdef unvis
# Documentation: https://man.archlinux.org/search?q=unvis
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-e[Do not decode \ escaped sequences]'
    '-H[Decode entity references and numeric character references from RFC 1866]'
    '-h[Decode using the URI encoding from RFC 1808]'
    '-m[Decode using mime style]'
    '*:filename:_files'
)
_arguments -s $arguments
