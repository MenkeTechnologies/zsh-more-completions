#compdef ts_print_mt

local arguments

arguments=(
    {-i,--idev}'[explicitly choose the input event device]:device:_files'
    {-r,--raw}'[do not use the filters, use ts_read_raw_mt instead]'
    {-n,--non-blocking}'[open the input device in non-blocking mode]'
    {-s,--samples}'[number of samples tslib should read before returning]:samples'
    {-j,--slots}'[override the number of concurrent touch contacts to allocate]:slots'
    '(- * :)'{-h,--help}'[display help information]'
    '*:filename:_files'
)
_arguments -s $arguments
