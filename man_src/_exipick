#compdef exipick

local arguments

arguments=(
    '--and[Display messages matching all criteria (default)]'
    '-b[Display messages in brief format]'
    {--bp,-l}'[Display messages in standard mailq format (default)]'
    '--bpa[Same as -bp, show generated addresses also]'
    '--bpc[Show a count of matching messages]'
    '--bpr[Same as -bp but output is not sorted]'
    '--bpra[Same as -bpa but unsorted]'
    '--bpru[Same as -bpu but unsorted]'
    '--bpu[Same as -bp, but only show undelivered messages]'
    {-C,--config}'[Use config to determine the proper spool directory]:file:_files'
    '-c[Show a count of matching messages]'
    '--caseful[Make operators involving = honor case]'
    '--charset[Override the default local character set for header decoding]:charset'
    '-f[Match sender address against regexp]:regexp'
    '--finput[Same as --input-dir Finput]'
    '--flatq[Use a single-line output format]'
    '--freeze[Save queue information in a quickly retrievable format]:file:_files'
    '--help[Display help]'
    '-i[Display only the message IDs]'
    '--input-dir[Set the name of the directory under the spool directory]:inputname'
    '--not[Negate all tests]'
    '-o[Match messages older than specified seconds]:seconds'
    '--or[Display messages matching any criteria]'
    '--queue[Name of the queue]:name'
    '-r[Match recipient address against regexp]:regexp'
    '--random[Display messages in random order]'
    {--reverse,-R}'[Display messages in reverse order]'
    '-s[Match shown_message_size against string]:string'
    '--spool[Set the path to the exim spool to use]:path:_directories'
    '--show-rules[Show the internal representation of each criterion]'
    '--show-tests[Show the result of each criterion on each message]'
    '--show-vars[Show the value for variable for each displayed message]:variables'
    '--size[Show the total bytes used by each displayed message]'
    '--thaw[Read queue information cached from a previous --freeze run]:file:_files'
    '--sort[Display matching messages sorted according to variable]:variables'
    '--unsorted[Do not apply any sorting to output]'
    '--version[Display the version of this command]'
    '-x[Only display non-frozen messages]'
    '-y[Match messages younger than specified seconds]:seconds'
    '*:filename:_files'
)
_arguments -s $arguments
