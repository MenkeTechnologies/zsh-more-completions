#compdef kismetdb_to_gpx
# Documentation: https://man.archlinux.org/search?q=kismetdb_to_gpx
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-i,--in}'[Input kismetdb file]:file:_files'
    {-o,--out}'[Output GPX file]:file:_files'
    {-f,--force}'[Force writing to the target file, even if it exists]'
    {-v,--verbose}'[Verbose output]'
    {-s,--skip-clean}'[Do not clean (SQL vacuum) input database]'
    {-e,--exclude}'[Exclude records within dist meters of the lat,lon]:lat,lon,dist'
    '--basic-location[Use basic average location information instead of computing]'
    '*:filename:_files'
)
_arguments -s $arguments
