#compdef trietool
# Documentation: https://man.archlinux.org/search?q=trietool
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-p,--path}'[set trie directory]:dir:_directories'
    '(- * :)'{-h,--help}'[show summary of options]'
    {-e,--encoding}'[specify character encoding of the list-file contents]:encoding'
    {-V,--version}'[show version of program]'
    '*:filename:_files'
)
_arguments -s $arguments
