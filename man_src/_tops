#compdef tops

local arguments

arguments=(
    '--help[display the tops syntax line]'
    '--verbose[print source code lines that are being changed]'
    '--nocontext[do not print the whole source code line being changed]'
    '--nofileinfo[do not print file name and line number information]'
    '--semiverbose[show how much of the file has been processed]'
    '--dont[show what changes would be made without performing them]'
    '--scriptfile[specify the script file containing the rules]:script_name:_files'
    '--classfile[specify a file that describes the class hierarchy]:classfile:_files'
    '*:filename:_files'
)
_arguments -s $arguments
