#compdef pod2text5.34

# Autogenerated from man page /usr/share/man/man1/pod2text5.34.1

local arguments

arguments=(
    {-a,--alt}'[Use an alternate output format that, among other things, uses a different]'
    '--code[Include any non-POD text from the input file in the output as well]'
    {-c,--color}'[Format the output with \ANSI\ color escape sequences]'
    '--errors[Set the error handling style.]:style'
    {-i,--indent}'[Set the number of spaces to indent regular text, and the default indentation]'
    {-h,--help}'[Print out usage information and exit]'
    {-l,--loose}'[Print a blank line after a \\=head1\\*(C\ heading]'
    {-m,--left-margin,--margin}'[The width of the left margin in spaces. Defaults to 0]'
    '--nourls[Normally, L<> formatting codes with a \URL\ but anchor text are]'
    {-o,--overstrike}'[Format the output with overstrike printing]'
    {-q,--quotes}'[Sets the quote marks used to surround C<> text to quotes]'
    {-s,--sentence}'[Assume each sentence ends with two spaces and try to preserve that spacing]'
    '--stderr[By default, pod2text dies if any errors are detected in the \POD\ input]'
    {-t,--termcap}'[Try to determine the width of the screen and the bold and underline]'
    {-u,--utf8}'[By default, pod2text tries to use the same output encoding as its input]'
    '*:filename:_files'
)
_arguments -s $arguments
