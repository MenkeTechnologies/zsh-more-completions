#compdef GetFileInfo

local arguments

arguments=(
    '-P[Act on a symlink file instead of the file the symlink resolves to]'
    '-a[Get a file attribute bit]:attribute-letter'
    '-t[Get the file type, a string of exactly four characters]'
    '-c[Get the file creator, a string of four characters]'
    '-d[Get the creation date]'
    '-m[Get the modification date]'
    '*:filename:_files'
)
_arguments -s $arguments
