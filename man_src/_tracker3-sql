#compdef tracker3-sql
# Documentation: https://man.archlinux.org/search?q=tracker3-sql
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-f,--file}'[use a file with SQL content to query]:file:_files'
    {-q,--query}'[use a SQL string to query the database]:sql'
    '*:filename:_files'
)
_arguments -s $arguments
