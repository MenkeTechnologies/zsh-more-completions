#compdef swtpm_ioctl

# Updated with fixes for descriptions

local arguments

arguments=(
    '--tpm-device[Use the given device (default is /dev/tpm0)]:device:_files'
    '--tcp[Connect to TPM on given host and port]:host\:port'
    '--unix[Connect to TPM using UnixIO socket]:path'
    '-c[Get ptm capabilities]'
    '-i[Do a hardware TPM_Init]'
    '--stop[Stop the TPM without exiting]'
    '-s[Shutdown the TPM, stop and exit]'
    '-e[Get the tpmEstablished bit]'
    '-r[Reset the tpmEstablished bit with the given locality]:locality'
    '-v[Store the TPM volatile data]'
    '-C[Cancel an ongoing TPM command]'
    '-l[Set the locality to the given number]:locality'
    '-h[Hash the given data (use - for stdin)]:data'
    '--save[Store the TPM state blob of given type in a file]:type,file'
    '--load[Load the TPM state blob of given type from a file]:type,file'
    '-g[Get configuration flags indicating which keys are in use]'
    '-b[Set the buffer size of the TPM]:size'
    '--info[Get TPM implementation specific information]:flags'
    '--version[Display version and exit]'
    '--help[Display help screen and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
