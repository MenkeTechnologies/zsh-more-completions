#compdef asip-status

# Updated with latest Netatalk asip-status options

local arguments

arguments=(
    '-4[Use IPv4 only]'
    '-6[Use IPv6 only]'
    '-d[Enable debug output]'
    '-i[Show icon if it exists]'
    '-x[Enable hex dump output]'
    {-v,--version}'[Show version]'
    '*:hostname:_hosts'
)
_arguments -s $arguments
