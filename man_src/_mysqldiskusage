#compdef mysqldiskusage

local arguments

arguments=(
    '--help[Display help and exit]'
    {-a,--all}'[Show all disk usage including logs]'
    {-b,--binlog}'[Show binary log disk usage]'
    {-m,--empty}'[Show empty databases]'
    '--format[Output format]:format:(grid csv tab vertical)'
    {-i,--innodb}'[Show InnoDB disk usage]'
    {-l,--logs}'[Show general and slow query log disk usage]'
    '--no-headers[Suppress column headers]'
    {-q,--quiet}'[Turn off all messages for quiet execution]'
    {-r,--relaylog}'[Show relay log disk usage]'
    '--server[Connection information for the server]:server'
    {-v,--verbose}'[Verbose output]'
    '--version[Display version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
