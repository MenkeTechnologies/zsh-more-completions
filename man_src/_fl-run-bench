#compdef fl-run-bench

local arguments

arguments=(
    '--version[Show program version number and exit]'
    {--help,-h}'[Show this help message and exit]'
    {--url,-u}'[Base URL to bench]:URL'
    {--cycles,-c}'[Cycles to bench, list of virtual concurrent users]:cycles'
    {--duration,-D}'[Duration of a cycle in seconds]:seconds'
    {--sleep-time-min,-m}'[Minimum sleep time between requests]:seconds'
    {--sleep-time-max,-M}'[Maximum sleep time between requests]:seconds'
    {--startup-delay,-s}'[Startup delay between threads]:seconds'
    '--no-color[Monochrome output]'
    '--accept-invalid-links[Do not fail if css/image links are not reachable]'
    '--simple-fetch[Do not load additional links like css or images]'
    '*:filename:_files'
)
_arguments -s $arguments
