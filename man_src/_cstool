#compdef cstool
# Documentation: https://man.archlinux.org/search?q=cstool
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-d[Show detailed information of the instructions]'
    '-s[Run in SKIPDATA mode]'
    '-u[Show immediates as unsigned]'
    '-v[Show version and Capstone core build info]'
    '*:filename:_files'
)
_arguments -s $arguments
