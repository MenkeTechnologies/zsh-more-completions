#compdef cryptsetup-ssh

local arguments

arguments=(
    '--debug[Show debug messages]'
    '--debug-json[Show debug messages including JSON metadata]'
    {-v,--verbose}'[Show more detailed error messages]'
    {-\?,--help}'[Show help]'
    '--key-slot[Keyslot to assign the token to]:number'
    '--ssh-keypath[Path to the SSH key for connecting to the remote server]:path:_files'
    '--ssh-path[Path to the key file on the remote server]:path'
    '--ssh-server[IP address/URL of the remote server for this token]:server:_hosts'
    '--ssh-user[Username for SSH authentication]:username'
    {-V,--version}'[Print program version]'
    '*:filename:_files'
)
_arguments -s $arguments
