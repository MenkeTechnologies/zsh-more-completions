#compdef timidity

local arguments

arguments=(
    '-A[set amplification to n percent]:n'
    '--amplification[set amplification to n percent]:n'
    '--drumpower[set drum power to m percent]:m'
    '--volume-compensation[multiply the master volume by n percent]'
    {-a,--anti-alias}'[turn on anti-aliasing]'
    {-B,--buffer-fragments}'[select number of buffer fragments]:fragments'
    {-C,--control-ratio}'[set ratio of sampling and control frequencies]:ratio'
    {-c,--config-file}'[read an extra configuration file]:file:_files'
    {-D,--drum-channel}'[mark channel as a drum channel]:channel'
    {-d,--interface-path}'[specify directory with dynamic-link interface modules]:directory:_directories'
    {-E,--ext}'[set TiMidity++ extend modes]:mode'
    '--mod-wheel[enable/disable modulation controlling]'
    '--portamento[enable/disable portamento controlling]'
    '--vibrato[enable/disable NRPN vibration]'
    '--ch-pressure[enable/disable channel pressure controlling]'
    '--trace-text-meta[enable/disable tracing all text meta events]'
    '--overlap-voice[accept/reject pronouncing multiple same notes]'
    '--temper-control[enable/disable temperament controlling]'
    '--default-mid[set the manufacturer ID]:id'
    '--system-mid[set the system manufacturer ID]:id'
    '--default-bank[use tone bank n as the default]:n'
    '--force-bank[set the bank number of all channels]:n'
    '--default-program[use the program number as the default instrument]:n'
    '--force-program[ignore all program changes and use specified program]:n'
    '--delay[set delay type]:type'
    '--chorus[set chorus type]:type'
    '--reverb[set reverb type]:type'
    '--voice-lpf[set voice low-pass filter]:type'
    '--noise-shaping[enable the nth degree noise shaping filter]:n'
    '--resample[set resample type]:type'
    {-e,--evil}'[make TiMidity++ evil]'
    {-F,--fast-panning}'[turn on fast panning]'
    {-f,--fast-decay}'[toggle fast envelopes]'
    {-g,--spectrogram}'[open the Sound-Spectrogram window]'
    {-H,--force-keysig}'[specify the key signature]:key'
    '(- * :)'{-h,--help}'[show the help message]'
    {-i,--interface}'[select user interface]:interface'
    '--realtime-priority[set realtime priority]:n'
    '--sequencer-ports[set sequencer ports]:n'
    {-j,--realtime-load}'[enable the loading of patch files during play]'
    {-K,--adjust-key}'[adjust key by n half tones]:n'
    {-k,--voice-queue}'[specify audio queue time limit to reduce voices]:time'
    {-L,--patch-path}'[add path to the library path]:path:_directories'
    {-M,--pcm-file}'[play a PCM file instead of a MIDI file]:file:_files'
    {-m,--decay-time}'[modify envelope volume decay time]:time'
    {-N,--interpolation}'[set interpolation parameter]:param'
    {-O,--output-mode}'[select the output mode]:mode'
    '--output-stereo[stereo output]'
    '--output-mono[monophonic output]'
    '--output-signed[signed output]'
    '--output-unsigned[unsigned output]'
    '--output-16bit[16-bit sample width]'
    '--output-24bit[24-bit sample width]'
    '--output-8bit[8-bit sample width]'
    '--output-linear[linear encoding]'
    '--output-ulaw[u-Law 8-bit encoding]'
    '--output-alaw[A-Law encoding]'
    '--output-swab[byte-swapped output]'
    {-o,--output-file}'[place output on file]:file:_files'
    {-P,--patch-file}'[use patch file for all programs]:file:_files'
    '-p[set polyphony to n]:n'
    '--polyphony[set polyphony to n]:n'
    '-Q[cause channel n to be quiet]:n'
    '--mute[cause channel n to be quiet]:n'
    {-q,--audio-buffer}'[specify audio buffer in seconds]:seconds'
    '-R[enable pseudo reverb mode with specified release in ms]:msec'
    {-S,--cache-size}'[set the re-sample cache size]:bytes'
    {-s,--sampling-freq}'[set the resampling frequency]:freq'
    {-T,--adjust-tempo}'[adjust tempo to n percent]:n'
    {-t,--output-charset}'[set output coding of Japanese text]:code'
    {-U,--unload-instruments}'[unload all instruments between MIDI files]'
    {-V,--volume-curve}'[set the power of volume curve]:power'
    {-v,--version}'[show the version string]'
    {-W,--wrd}'[play WRD file]:mode'
    {-x,--config-string}'[configure TiMidity++ with string]:str'
    {-Z,--freq-table}'[read the table of frequencies from file]:file:_files'
    {--Zpure,--pure-intonation}'[play in pure intonation by key signature]'
    '--module[simulate behavior of specific synthesizer module]:n'
    '*:filename:_files'
)
_arguments -s $arguments
