#compdef db_verify

local arguments

arguments=(
    '-h[Specify a home directory for the database environment]:directory:_directories'
    '-o[Skip the database checks for btree and duplicate sort order and hashing]'
    '-N[Do not acquire shared region mutexes while running]'
    '-P[Specify an environment password]:password'
    '-q[Suppress error descriptions, exit with success or failure code only]'
    '-V[Write the library version number and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
