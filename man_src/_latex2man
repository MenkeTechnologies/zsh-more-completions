#compdef latex2man

local arguments

arguments=(
    '-t[Translation for user defined LaTeX macros]:transfile:_files'
    '-c[Specify a file that contains CSS style sheets (use with -H)]:CSSfile:_files'
    '-M[Produce output suitable for the man command (default)]'
    '-H[Produce HTML code instead of man output]'
    '-T[Produce TexInfo code instead of man output]'
    '-L[Write the LaTeX source to the outfile]'
    '-C[Output the conditional text for name]:name'
    '-a[Specify a character used only in conjunction with -T]:char'
    '-h[Show a help text]'
    '-V[Show version information]'
    '*:filename:_files'
)
_arguments -s $arguments
