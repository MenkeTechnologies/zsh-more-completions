#compdef csdiagnose
# Documentation: https://man.archlinux.org/search?q=csdiagnose
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-h[Show help information]'
    '-f[Specify an output path for the generated file]:path:_files'
    '-v[Verbose mode, print every command invoked]'
    '*:filename:_files'
)
_arguments -s $arguments
