#compdef named-rrchecker

local arguments

arguments=(
    '-h[Print the help menu]'
    '-o[Specify an origin to use when interpreting the record]:origin'
    '-p[Print the resulting record in canonical form]'
    '-u[Print the resulting record in unknown record form]'
    '-C[Print the known class mnemonics]'
    '-T[Print the known standard type mnemonics]'
    '-P[Print the known private type mnemonics]'
    '*:filename:_files'
)
_arguments -s $arguments
