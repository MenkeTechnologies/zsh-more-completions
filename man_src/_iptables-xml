#compdef iptables-xml
# Documentation: https://man.archlinux.org/search?q=iptables-xml
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-c,--combine}'[Combine consecutive rules with the same matches but different targets]'
    {-v,--verbose}'[Output xml comments containing the iptables line from which the XML is derived]'
    '*:filename:_files'
)
_arguments -s $arguments
