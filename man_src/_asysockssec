#compdef asysockssec

# Updated with latest asysocks security check options

local arguments

arguments=(
    {-h,--help}'[Show help message and exit]'
    {-t,--timeout}'[Timeout]:timeout'
    {-v,--verbose}'[Verbosity]'
    '--ssl[Use SSL]'
    {-s,--silent}'[Silent mode]'
    '--verify-host[Destination host to test proxy on]:host'
    '--verify-port[Destination port to test proxy on]:port'
    '--verify-send[Data to send to destination to test the proxy]:data'
    '--verify-recv[Data expected to be received from the destination]:data'
    {-u,--username}'[Username for proxy auth]:username'
    {-p,--password}'[Password for proxy auth]:password'
    '*:filename:_files'
)
_arguments -s $arguments
