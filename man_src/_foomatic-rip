#compdef foomatic-rip

local arguments

arguments=(
    '-v[Verbose mode for debugging]'
    '-q[Quiet mode - minimal information output]'
    '-P[The configured printer to use for this job]:printer'
    '--ppd[The PPD file to apply for processing this job]:ppdfile:_files'
    '-o[Option settings for this job]:options'
    '*:filename:_files'
)
_arguments -s $arguments
