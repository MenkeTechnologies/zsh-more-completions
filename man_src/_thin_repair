#compdef thin_repair
# Documentation: https://man.archlinux.org/search?q=thin_repair
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '(- * :)'{-h,--help}'[print help and exit]'
    {-V,--version}'[print version information and exit]'
    {-i,--input}'[input file or device with binary data]:device or file:_files'
    {-o,--output}'[output file or device for binary data]:device or file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
