#compdef htags

local arguments

arguments=(
    {-a,--alphabet}'[Make an alphabetical index suitable for a large project]'
    '--auto-completion[Enable auto-completion facility for the input form]:limit'
    '--caution[Display a caution message on the top page]'
    '--cflow[Add a call tree by cflow]:cflowfile:_files'
    '--call-tree[Add a call tree by cflow]:callfile:_files'
    '--callee-tree[Add a callee tree by cflow]:calleefile:_files'
    '--colorize-warned-line[Use color to highlight warned lines]'
    '--cvsweb[Add a link to cvsweb]:url'
    '--cvsweb-cvsroot[Specify cvsroot in cvsweb URL]:cvsroot'
    {-D,--dynamic}'[Generate a tag list dynamically using CGI program]'
    {-d,--dbpath}'[Specify the directory in which GTAGS exists]:dbpath:_directories'
    '--disable-grep[Disable grep in the search form]'
    '--disable-idutils[Disable idutils in the search form]'
    {-F,--frame}'[Use frames for the top page]'
    {-f,--form}'[Add a search form using CGI program]'
    '--fixed-guide[Put a fixed guide at the bottom of the screen of the browser]'
    '--full-path[Use full path name in the file index]'
    {-g,--gtags}'[Execute gtags before starting job]'
    '--gtagsconf[Set environment variable GTAGSCONF to file]:file:_files'
    '--gtagslabel[Set environment variable GTAGSLABEL to label]:label'
    {-h,--func-header}'[Insert a function header for each function]:position'
    '--html-header[Insert a header record derived from file into the HTML header]:file:_files'
    {-I,--icon}'[Use icons instead of text for some links]'
    '--insert-footer[Insert custom footer derived from file before body closing tag]:file:_files'
    '--insert-header[Insert custom header derived from file after body tag]:file:_files'
    '--item-order[Specify the order of the items in the top page]:spec'
    {-m,--main-func}'[Specify startup function name; the default is main]:name'
    '--map-file[Generate file MAP]'
    {-n,--line-number}'[Print line numbers]:columns'
    '--no-order-list[Numbers are not given in list form]'
    {-o,--other}'[Pick up not only source files but also other files for the file index]'
    {-s,--symbol}'[Make anchors not only for definitions and references but also other symbols]'
    '--show-position[Print the position string per function definition]'
    '--statistics[Print statistics information]'
    '--suggest[Htags chooses popular options on behalf of beginners]'
    '--suggest2[Htags chooses popular options on behalf of beginners (more)]'
    {-T,--table-flist}'[Use table tag to display the file index]:rows'
    {-t,--title}'[Title of the hypertext]:title'
    '--tabs[Tab stops]:cols'
    '--table-list[Use table tag to display the tag list]'
    '--tree-view[Use treeview for the file index]:type'
    {-v,--verbose}'[Verbose mode]'
    {-w,--warning}'[Print warning messages]'
    '*:filename:_files'
)
_arguments -s $arguments
