local arguments

arguments=(
    '--version[Print version information]'
    '-i[Include a file]:file:_files'
    '-o[Specify output file]:file:_files'
    '--verbose[Enable verbose output]'
    '--quiet[Enable quiet output]'
    '-e[Change output format]'
    '-f[Set output format]'
    '-x[Enable cross-reference mode]'
    '(- * :)--help[Print help information]'
    '*:filename:_files'
)
_arguments -s $arguments
