#compdef vis

local arguments

arguments=(
    '-b[Turn off prepending of backslash before up-arrow control sequences and meta characters]'
    '-c[Display a small subset of the non-printable characters in C-style format]'
    '-F[Fold output lines to foldwidth columns (default 80)]:foldwidth'
    '-f[Same as -F]'
    '-l[Mark newlines with the visible sequence, followed by the newline]'
    '-n[Turn off any encoding, except for the fact that backslashes are still doubled]'
    '-o[Display non-printable characters as an octal number]'
    '-s[Only encode characters considered unsafe to send to a terminal]'
    '-t[Also encode tabs]'
    '-w[Also encode white space (space-tab-newline)]'
    '*:filename:_files'
)
_arguments -s $arguments
