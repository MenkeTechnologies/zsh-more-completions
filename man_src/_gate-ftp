#compdef gate-ftp

local arguments

arguments=(
    '-4[Force use of IPv4 addresses only]'
    '-6[Force use of IPv6 addresses only]'
    '-A[Force active mode ftp]'
    '-a[Bypass normal login and use anonymous login]'
    '-d[Enable debugging]'
    '-e[Disable command line editing]'
    '-f[Force a cache reload for transfers through proxies]'
    '-g[Disable file name globbing]'
    '-i[Turn off interactive prompting during multiple file transfers]'
    '-N[Use specified netrc file]:netrc:_files'
    '-n[Do not attempt auto-login upon initial connection]'
    '-o[When auto-fetching files, save contents in output]:output:_files'
    '-P[Set the port number]:port'
    '-p[Enable passive mode operation for use behind firewalls]'
    '-q[Quit if connection has stalled for specified seconds]:quittime'
    '-R[Restart all non-proxied auto-fetches]'
    '-r[Retry connection attempt if it failed, pausing for wait seconds]:wait'
    '-s[Use specified local IP address for all connections]:srcaddr'
    '-t[Enable packet tracing]'
    '-T[Set maximum transfer rate]:direction\:maximum'
    '-u[Upload files to URL]:URL'
    '-V[Disable verbose and progress]'
    '-v[Enable verbose and progress]'
    '*:filename:_files'
)
_arguments -s $arguments
