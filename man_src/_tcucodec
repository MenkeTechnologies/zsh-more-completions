#compdef tcucodec

local arguments

arguments=(
    '-d[decode mode]'
    '--br[break lines]'
    '--rs[specify record separator]:separator'
    '--en[specify encoding]:encoding'
    '-q[quiet mode]'
    '--on[output with newline]'
    '--bd[use binary data]'
    '--hd[use hexadecimal data]'
    '--part[partial mode]'
    '--bwt[apply Burrows-Wheeler transform]'
    '--gz[use GZIP compression]'
    '--crc[use CRC checking]'
    '--js[use JSON format]'
    '--un[use Unicode normalization]'
    '--kw[keyword extraction mode]'
    '--ch[character encoding conversion]'
    '--key[set key]:key'
    '--ds[set delimiter string]:delimiter'
    '--jl[set JSON lines mode]'
    '--wf[write to file]:file:_files'
    '--rf[read from file]:file:_files'
    '--var[set variable]:variable'
    '-v[verbose mode]'
    '-i[interactive mode]'
    '-l[set the limit number]:num'
    '-p[set precision]:num'
    '*:filename:_files'
)
_arguments -s $arguments
