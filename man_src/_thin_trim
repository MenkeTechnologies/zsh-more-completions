#compdef thin_trim
# Documentation: https://man.archlinux.org/search?q=thin_trim
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '(- * :)'{-h,--help}'[print help and exit]'
    {-V,--version}'[print version information and exit]'
    '--pool-inactive[indicates the pool should be inactive]'
    '*:filename:_files'
)
_arguments -s $arguments
