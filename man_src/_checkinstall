#compdef checkinstall

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Show summary of options]'
    '--version[Show version information]'
    '--copyright[Show Copyright information]'
    '--type[Choose packaging system]:type:(slackware debian rpm)'
    '-D[Create a Debian package]'
    '-R[Create a RPM package]'
    '-S[Create a Slackware Package]'
    '--install[Toggle installation of the created package]'
    '--fstrans[Enable/disable filesystem translation]'
    {-y,--default}'[Accept default answers to all questions]'
    '--pkgname[Set the package name]:name'
    '--pkgversion[Set package version]:version'
    {-A,--arch,--pkgarch}'[Set package architecture]:arch'
    '--pkgrelease[Set the package release]:release'
    '--pkglicense[Set package license]:license'
    '--pkggroup[Set the package group]:group'
    '--pkgsource[Set source location]:source'
    '--pkgaltsource[Set alternate source location]:source'
    '--pakdir[Where to save the new package]:directory:_directories'
    '--maintainer[Set the package maintainer]:maintainer'
    '--provides[Features provided by this package]:provides'
    '--requires[Dependencies required by this package]:requires'
    '--rpmflags[Pass these flags to the rpm installer]:flags'
    '--rpmi[Use the -i flag when installing a rpm]'
    '--rpmu[Use the -U flag when installing a rpm]'
    '--dpkgflags[Pass these flags to the dpkg installer]:flags'
    '--spec[Where the spec file is located]:file:_files'
    '--nodoc[Do not include documentation files]'
    '-d[Set debug level]:level:(0 1 2)'
    '--si[Run an interactive install command]'
    '--showinstall[Toggle interactive install command]'
    '--ss[Run an interactive Slackware installation script]'
    '--showslack[Toggle interactive Slackware installation script]'
    '--autodoinst[Toggle creation of a doinst.sh script]'
    '--strip[Toggle stripping any ELF binaries found inside the package]'
    '--stripso[Toggle stripping any ELF libraries found inside the package]'
    '--addso[Search for shared libs and add them to /etc/ld.so.conf]'
    '--reset-uids[Reset perms for all files/dirs to 755 and owner/group for dirs to root]'
    '--gzman[Compress any man pages found inside the package]'
    '--docdir[Where to put documentation files]:directory:_directories'
    '--umask[Set the umask value]:umask'
    '--exclude[Exclude these files/directories from the package]:pattern'
    '--include[Force the inclusion of files/dirs listed in the argument]:file:_files'
    '--inspect[Inspect the package file list]'
    '--review-spec[Review the spec file before creating a rpm]'
    '--review-control[Review the control file before creating a deb]'
    '--newslack[Use the new Slackware description format (implies -S)]'
    '--with-tar[Manually set the path to the tar binary]:path:_files'
    '--deldoc[Toggle deletion of doc-pak upon termination]'
    '--deldesc[Toggle deletion of description-pak upon termination]'
    '--delspec[Toggle deletion of spec file upon termination]'
    '--bk[Backup any overwritten files]'
    '*:filename:_files'
)
_arguments -s $arguments
