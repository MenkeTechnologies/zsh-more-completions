#compdef convert-ly

local arguments

arguments=(
    '--version[Show version number and exit]'
    '(- * :)'{-h,--help}'[Show help and exit]'
    {-f,--from}'[Start from specified version]:version'
    {-e,--edit}'[Edit in place]'
    {-l,--loglevel}'[Print log messages according to log level]:level:(NONE ERROR WARNING PROGRESS DEBUG)'
    {-n,--no-version}'[Do not add version command if missing]'
    {-c,--current-version}'[Force updating version number to current version]'
    {-d,--diff-version-update}'[Only update version number if file is modified]'
    {-s,--show-rules}'[Show conversion rules]'
    {-t,--to}'[Convert to specified version]:version'
    {-b,--backup-numbered}'[Make a numbered backup]'
    {-w,--warranty}'[Show warranty and copyright]'
    '*:filename:_files'
)
_arguments -s $arguments
