#compdef ecj

local arguments

arguments=(
    '-1.3[Set compliance level to 1.3]'
    '-1.4[Set compliance level to 1.4]'
    '-1.5[Set compliance level to 1.5]'
    '-1.6[Set compliance level to 1.6]'
    '-1.7[Set compliance level to 1.7]'
    '-1.8[Set compliance level to 1.8]'
    '-1.9[Set compliance level to 1.9]'
    '-source[Set source compatibility level]:version'
    '-target[Set class file target VM version]:version'
    '-release[Compile for specified Java SE release]:release'
    '-d[Set destination directory for generated class files]:directory:_directories'
    '-encoding[Set default source encoding]:encoding'
    '-cp[Set classpath]:classpath'
    '-classpath[Set classpath]:classpath'
    '-bootclasspath[Override location of bootstrap class files]:path'
    '-extdirs[Override location of installed extensions]:path'
    '-endorseddirs[Override location of endorsed standards path]:path'
    '-sourcepath[Specify where to find input source files]:path'
    '-module-path[Specify where to find application modules]:path'
    '-proc\:only[Only run annotation processors, do not compile]'
    '-proc\:none[Do not process annotations]'
    '-processor[Names of annotation processors to run]:processors'
    '-processorpath[Specify where to find annotation processors]:path'
    '-s[Specify directory for generated source files]:directory:_directories'
    '-g[Generate all debugging info]'
    '-g\:none[Generate no debugging info]'
    '-g\:lines[Generate only line number debug info]'
    '-preserveAllLocals[Preserve all local variables during code generation]'
    '-parameters[Generate metadata for reflection on method parameters]'
    '-warn\:none[Suppress all warnings]'
    '-nowarn[Suppress all warnings]'
    '-deprecation[Show deprecation warnings]'
    '-err[Treat specified warnings as errors]:warnings'
    '-properties[Set properties file for warnings configuration]:file:_files'
    '-log[Specify a log file for all compiler output]:filename:_files'
    '-maxProblems[Set max number of problems per compilation unit]:n'
    '-proceedOnError[Keep compiling in spite of errors]'
    '-verbose[Print accessed/processed compilation units]'
    '-referenceInfo[Compute reference info]'
    '-progress[Show progress (only in -log mode)]'
    '-time[Display speed information]'
    '-noExit[Do not call System.exit at end of compilation]'
    '-repeat[Repeat compilation process n times]:n'
    '-inlineJSR[Inline JSR bytecode]'
    '-enableJavadoc[Consider references in Javadoc]'
    '-missingNullDefault[Report missing default nullness annotation]'
    '-annotationpath[Specify external annotation path]:path:_directories'
    '-genericsignature[Preserve information about generic signature in class files]'
    '-Xemacs[Use emacs style to present errors and warnings]'
    '(- * :)'{-\?,--help}'[Print help message]'
    {-v,--version}'[Print version information]'
    '--showversion[Print version and continue]'
    '*:filename:_files'
)
_arguments -s $arguments
