#compdef cache_restore

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Print help and exit]'
    {-V,--version}'[Print version information and exit]'
    {-q,--quiet}'[Suppress output messages, return only exit code]'
    {-i,--input}'[Input xml]:file:_files'
    {-o,--output}'[Output file or device for restored binary metadata]:device or file:_files'
    '--metadata-version[Choose a metadata version]:version:(1 2)'
    '--debug-override-metadata-version[Override the version stored in the metadata]:integer'
    '--omit-clean-shutdown[Do not set the clean shutdown flag]'
    '*:filename:_files'
)
_arguments -s $arguments
