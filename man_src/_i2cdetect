#compdef i2cdetect

local arguments

arguments=(
    '-y[Disable interactive mode]'
    '-a[Force scanning of non-regular addresses]'
    '-q[Use SMBus quick write command for probing]'
    '-r[Use SMBus receive byte command for probing]'
    '-F[Display the list of functionalities implemented by the adapter and exit]'
    '-V[Display the version and exit]'
    '-l[Output a list of installed busses]'
    '*:filename:_files'
)
_arguments -s $arguments
