#compdef x11perfcomp
# Documentation: https://man.archlinux.org/search?q=x11perfcomp
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-r[Include relative server performance in the output]'
    '-ro[Include only relative server performance in the output]'
    '-l[Specify a label file to use]:label_file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
