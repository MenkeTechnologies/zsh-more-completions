#compdef light-locker-command

local arguments

arguments=(
    {-q,--query}'[Query the state of the locker]'
    {-t,--time}'[Query the length of time the locker has been active]'
    {-l,--lock}'[Tell the running locker process to lock the screen immediately]'
    {-a,--activate}'[Turn the screensaver on (blank the screen)]'
    {-d,--deactivate}'[If the screensaver is active then deactivate it (un-blank the screen)]'
    {-p,--poke}'[Poke the running locker to simulate user activity]'
    {-i,--inhibit}'[Inhibit the screensaver from activating]'
    {-n,--application-name}'[The calling application that is inhibiting the screensaver]:name'
    {-r,--reason}'[The reason for inhibiting the screensaver]:reason'
    {-V,--version}'[Show version of this application]'
    '*:filename:_files'
)
_arguments -s $arguments
