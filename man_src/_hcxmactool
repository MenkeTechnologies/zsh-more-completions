#compdef hcxmactool

local arguments

arguments=(
    '-o[Output file for matched entries]:file:_files'
    '-n[Filter by MAC address in AP field]:mac'
    '-m[Filter by MAC address in client field]:mac'
    '-a[Filter all by MAC address]:mac'
    '-O[Output file for unmatched entries]:file:_files'
    '-N[Exclude MAC address in AP field]:mac'
    '-M[Exclude MAC address in client field]:mac'
    '-A[Exclude all by MAC address]:mac'
    '-h[Show help]'
    '-v[Show version]'
    '--pmkideapolout[Output combined PMKID/EAPOL file]:file:_files'
    '--pmkidin[Input PMKID file]:file:_files'
    '--pmkidout[Output PMKID file]:file:_files'
    '--hccapxin[Input hccapx file]:file:_files'
    '--hccapxout[Output hccapx file]:file:_files'
    '--help[Show help]'
    '--version[Show version]'
    '*:filename:_files'
)
_arguments -s $arguments
