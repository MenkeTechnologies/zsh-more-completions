#compdef geod

local arguments

arguments=(
    '-I[Specifies that the inverse geodesic computation is to be performed]'
    '-a[Output latitude, longitudes, azimuths and distances in a single line]'
    '-le[List all selectable ellipsoids]'
    '-lu[List all selectable units]'
    '-f[Printf format string to control output of geographic coordinates]:format'
    '-F[Printf format string to control output of distances]:format'
    '-p[Output azimuthal values as unsigned DMS numbers between 0 and 360]'
    '*:filename:_files'
)
_arguments -s $arguments
