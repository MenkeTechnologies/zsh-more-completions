#compdef gcab

local arguments

arguments=(
    {-c,--create}'[Create a new cabinet archive]'
    {-x,--extract}'[Extract files from a cabinet archive]'
    {-t,--list}'[List files of a cabinet archive]'
    {-n,--nopath}'[Create files without pathnames]'
    {-C,--directory}'[Change or extract to directory DIR]:DIR:_directories'
    {-v,--verbose}'[Verbosely list files processed]'
    {-z,--zip}'[Use zip compression]'
    '*:filename:_files'
)
_arguments -s $arguments
