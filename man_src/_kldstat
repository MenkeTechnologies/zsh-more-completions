#compdef kldstat

local arguments

arguments=(
    '-h[Display the size field in a human-readable form]'
    '-v[Be more verbose]'
    '-d[Show the module specific data]'
    '-i[Display the status of only the file with this ID]:id'
    '-n[Display the status of only the file with this filename]:filename'
    '-q[Only check if module is loaded or compiled into the kernel]'
    '-m[Display the status of only the module with this name]:modname'
    '*:filename:_files'
)
_arguments -s $arguments
