#compdef top

local arguments

arguments=(
    {-h,-v}'[show library version and usage prompt, then quit]'
    '-b[start in batch mode]'
    '-c[start with command line/program name toggle reversed]'
    '-d[specify the delay between screen updates]:seconds'
    '-H[show individual threads]'
    '-i[start with idle process display toggled]'
    '-n[specify the maximum number of iterations]:iterations'
    '-o[specify the field on which tasks will be sorted]:field'
    '-O[output the available field names and exit]'
    '-p[monitor only processes with specified process IDs]:pid'
    '-s[start in secure mode]'
    '-S[start with cumulative time mode toggled]'
    '-u[display only processes with the specified user]:user'
    '-U[display only processes with the specified user (matches real/effective/saved/fs)]:user'
    '-w[set output width in batch mode]:width'
    '*:filename:_files'
)
_arguments -s $arguments
