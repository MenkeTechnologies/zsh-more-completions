#compdef unzipsfx
# Documentation: https://man.archlinux.org/search?q=unzipsfx
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-c[Extract files to stdout/screen]'
    '-f[Freshen existing files only]'
    '-l[List archive files]'
    '-n[Never overwrite existing files]'
    '-o[Overwrite files without prompting]'
    '-p[Extract files to pipe]'
    '-s[Operate on contained spaces]'
    '-j[Junk paths (do not make directories)]'
    '-V[Retain VMS version numbers]'
    '-X[Restore VMS owner/protection info]'
    '*:filename:_files'
)
_arguments -s $arguments
