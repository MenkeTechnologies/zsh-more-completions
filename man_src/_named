#compdef named

local arguments

arguments=(
    '-4[Use IPv4 only even if the host machine is capable of IPv6]'
    '-6[Use IPv6 only even if the host machine is capable of IPv4]'
    '-c[Use specified configuration file instead of the default]:config-file:_files'
    '-d[Set the daemon debug level]:debug-level'
    '-D[Specify a string used to identify a named instance in a process listing]:string'
    '-E[Specify the hardware to use for cryptographic operations]:engine-name'
    '-f[Run the server in the foreground (do not daemonize)]'
    '-g[Run the server in the foreground and force all logging to stderr]'
    '-L[Log to the specified file instead of the system log]:logfile:_files'
    '-M[Set the default memory context options]:option'
    '-m[Turn on memory usage debugging flags]:flag'
    '-n[Create specified number of worker threads]:#cpus'
    '-p[Listen for queries on specified port]:port'
    '-s[Write memory usage statistics to stdout on exit]'
    '-S[Allow named to use up to specified number of sockets]:#max-socks'
    '-t[Chroot to specified directory after processing command line arguments]:directory:_directories'
    '-U[Use specified number of worker threads to listen for incoming UDP packets]:#listeners'
    '-u[Setuid to specified user after completing privileged operations]:user'
    '-v[Report the version number and exit]'
    '-V[Report the version number and build options, and exit]'
    '-X[Acquire a lock on the specified file at runtime]:lock-file:_files'
    '-x[Load data from cache-file into the cache of the default view]:cache-file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
