#compdef dbiprof5.34
# Documentation: https://man.archlinux.org/search?q=dbiprof5.34
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--number[Produce this many items in the report]:N'
    '--sort[Sort results by the given field]:field'
    '--reverse[Reverse the selected sort]'
    '--match[Consider only items where the specified key matches the given value]:key=value'
    '--exclude[Remove items where the specified key matches the given value]:key=value'
    '--case-sensitive[Make --match and --exclude work case-sensitively]'
    '--delete[Delete the profile data files after reading them]'
    '--dumpnodes[Print the list of nodes as a Perl data structure]'
    '*:filename:_files'
)
_arguments -s $arguments
