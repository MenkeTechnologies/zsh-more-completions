#compdef e2undo

local arguments

arguments=(
    '-f[Force replay even if filesystem UUID or last mount time do not match]'
    '-h[Display usage message]'
    '-n[Dry-run; do not actually write blocks back to the filesystem]'
    '-o[Specify the filesystem offset in bytes from the beginning of the device]:offset'
    '-v[Report which block is currently being replayed]'
    '-z[Write old contents of overwritten blocks to an undo file]:undo_file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
