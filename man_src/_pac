#compdef pac

local arguments

arguments=(
    '-P[Accounting is done for the named printer]:printer'
    '-c[Sort the output by cost instead of alphabetically]'
    '-m[Ignore host name in the accounting file]'
    '-p[Use value as cost in dollars instead of the default]:price'
    '-r[Reverse the sorting order]'
    '-s[Summarize accounting information on the summary accounting file]'
    '*:filename:_files'
)
_arguments -s $arguments
