#compdef cpanel_json_xs
# Documentation: https://man.archlinux.org/search?q=cpanel_json_xs
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-v[Be slightly more verbose]'
    '-f[Read a file in the given format from stdin]:format:(json cbor storable dump yaml eval)'
    '-t[Output format]:format:(json cbor storable dump yaml eval)'
    '-e[Evaluate the given Perl expression]:expression'
    '*:filename:_files'
)
_arguments -s $arguments
