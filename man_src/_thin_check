#compdef thin_check

local arguments

arguments=(
    {-q,--quiet}'[suppress output messages, return only exit code]'
    '(- * :)'{-h,--help}'[print help and exit]'
    {-V,--version}'[output version information and exit]'
    '--super-block-only[only check the superblock]'
    '--skip-mappings[skip checking of the block mappings]'
    '--ignore-non-fatal-errors[only return non-zero exit code for fatal errors]'
    '--clear-needs-check-flag[clear the needs_check flag in the superblock]'
    '--override-mapping-root[specify a mapping root to use]:block'
    '*:filename:_files'
)
_arguments -s $arguments
