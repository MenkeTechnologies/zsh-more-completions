#compdef kbd_mode
# Documentation: https://man.archlinux.org/search?q=kbd_mode
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-s[Set scancode mode]'
    '-k[Set keycode (medium raw) mode]'
    '-a[Set XLATE (ASCII) mode]'
    '-u[Set UTF-8 mode]'
    '*:filename:_files'
)
_arguments -s $arguments
