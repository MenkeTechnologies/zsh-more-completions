#compdef tracker3-reset

local arguments

arguments=(
    {-s,--filesystem}'[remove data stored by tracker-miner-fs]'
    {-r,--rss}'[remove data stored by tracker-miner-rss]'
    {-f,--file}'[reset all indexed information about file (recursive for directories)]:file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
