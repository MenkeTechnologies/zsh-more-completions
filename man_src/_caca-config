#compdef caca-config

local arguments

arguments=(
    '--cflags[Print the compiler flags necessary to compile a program using libcaca]'
    '--exec-prefix[Use DIR instead of the installation exec prefix]:directory:_directories'
    '--libs[Print the linker flags necessary to link a program using libcaca]'
    '--prefix[Use PREFIX instead of the installation prefix]:directory:_directories'
    '--version[Print the currently installed version of libcaca]'
    '*:filename:_files'
)
_arguments -s $arguments
