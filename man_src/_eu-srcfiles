#compdef eu-srcfiles

local arguments

arguments=(
    '--core[Find addresses from signatures found in COREFILE]:COREFILE:_files'
    '--debuginfo-path[Search path for separate debuginfo files]:PATH:_directories'
    {-e,--executable}'[Find addresses in FILE]:FILE:_files'
    {-k,--kernel}'[Find addresses in the running kernel]'
    {-K,--offline-kernel}'[Kernel with all modules]:RELEASE'
    {-M,--linux-process-map}'[Find addresses in files mapped as read from FILE]:FILE:_files'
    {-p,--pid}'[Find addresses in files mapped into process PID]:PID'
    {-\?,--help}'[Give this help list]'
    '--usage[Give a short usage message]'
    {-V,--version}'[Print program version]'
    {-0,--null}'[Separate items by a null instead of a newline]'
    {-b,--no-backup}'[Disable local source file search when debuginfod fails]'
    {-c,--cu-only}'[Only list the CU (compilation unit) names]'
    {-v,--verbose}'[Increase verbosity of logging messages]'
    {-z,--zip}'[Zip all the source files and send to stdout]'
    '*:filename:_files'
)
_arguments -s $arguments
