#compdef tctmgr

local arguments

arguments=(
    '--tl[set the tuning leaf parameter]:num'
    '--td[set the tuning non-leaf parameter]:num'
    '--tb[set the bucket number]:num'
    '--tt[set the number of extra mapped memory]:size'
    '--tx[set the maximum number of cached leaf nodes]:num'
    '--nl[set the number of members in each leaf]:num'
    '--nb[set the number of members in each node]:num'
    '--sx[use suffix for keys]'
    '--dk[use decimal keys]'
    '--dc[use decimal for columns]'
    '--dai[use auto-increment for integer keys]'
    '--dad[use auto-increment for double keys]'
    '--px[print in hexadecimal]'
    '--pz[print with leading zeros]'
    '-m[set miscellaneous options]:options'
    '--pv[print values only]'
    '--fm[set format mode]:mode'
    '--ord[specify order]:order'
    '--sk[skip records]:num'
    '--kw[set keyword mode]'
    '--ph[print headers]'
    '--bt[set B-tree parameters]'
    '--rm[remove records]'
    '--ms[set max records to show]:num'
    '--tz[set alignment power]:num'
    '--df[set defragmentation step]:num'
    '--it[set index type]:type'
    '--cd[compare database files]'
    '--cv[set comparison value]'
    '--sc[perform search command]'
    '*:filename:_files'
)
_arguments -s $arguments
