#compdef ibping

local arguments

arguments=(
    {--count,-c}'[Stop after count packets]:count'
    {--flood,-f}'[Flood destination]'
    {--oui,-o}'[Use specified OUI number]:oui'
    {--Server,-S}'[Start in server mode]'
    {--config,-z}'[Use config file]:config:_files'
    {--Ca,-C}'[CA name to use]:ca_name'
    {--Port,-P}'[CA port number to use]:port'
    {--Lid,-L}'[Use LID address argument]'
    {--Guid,-G}'[Use GUID address argument]'
    {--timeout,-t}'[Timeout in ms]:timeout'
    {--sm_port,-s}'[SM port LID]:lid'
    {--errors,-e}'[Show send and receive errors]'
    {--verbose,-v}'[Increase verbosity level]'
    {--debug,-d}'[Raise debug level]'
    {--help,-h}'[Show help message]'
    {--version,-V}'[Show version]'
    '*:filename:_files'
)
_arguments -s $arguments
