#compdef fsirand
# Documentation: https://man.archlinux.org/search?q=fsirand
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-b[Use the default block size instead of the value from the superblock]'
    '-f[Force fsirand to run even if the file system is not marked as clean]'
    '-p[Print current generation numbers for all inodes instead of generating new ones]'
    '*:filename:_files'
)
_arguments -s $arguments
