#compdef i2c

local arguments

arguments=(
    '-a[7-bit address on the I2C device to operate on (hex)]:address'
    '-b[Binary mode - output read data as binary]'
    '-c[Number of bytes to transfer]:count'
    '-d[Transfer direction]:direction:(r w)'
    '-f[I2C bus to use]:bus:_files'
    '-m[Addressing mode]:mode'
    '-n[Skip address during bus scan]:address'
    '-o[Offset within the device for data transfer (hex)]:offset'
    '-r[Reset the controller]'
    '-s[Scan the bus for devices]'
    '-v[Be verbose]'
    '-w[Device addressing width in bits]:width'
    '*:filename:_files'
)
_arguments -s $arguments
