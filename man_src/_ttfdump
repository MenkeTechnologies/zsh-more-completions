#compdef ttfdump

local arguments

arguments=(
    '-h[print a help message and exit]'
    '-t[dump the specified table]:tablename'
    '-g[dump the glyph with specified index]:glyphnumber'
    '-c[select a TrueType font in a TrueType Collection]:collection'
    '-o[output of the dump]:dumpfile:_files'
    '-i[TrueType font file to be dumped]:ttfile:_files'
    '*:filename:_files'
)
_arguments -s $arguments
