#compdef iprinit

local arguments

arguments=(
    '--version[Print the version number of iprinit]'
    '--debug[Enable additional error logging]'
    '--daemon[Run as a daemon to handle adapters and devices being hotplugged]'
    '--use-polling[Do not use netlink/uevent notification, but rather poll for adapter and device configuration changes]'
    '--use-uevents[Use netlink/uevent notification rather than polling for adapter and device configuration changes]'
    '*:filename:_files'
)
_arguments -s $arguments
