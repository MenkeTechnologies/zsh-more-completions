#compdef hp-config_usb_printer
# Documentation: https://man.archlinux.org/search?q=hp-config_usb_printer
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-l,--logging}'[Set the logging level]:level:(none info error warn debug)'
    {-g,--ldebug}'[Run in debug mode]'
    '(- * :)'{-h,--help}'[Show help information]'
    '*:filename:_files'
)
_arguments -s $arguments
