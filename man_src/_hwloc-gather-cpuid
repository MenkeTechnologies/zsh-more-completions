#compdef hwloc-gather-cpuid
# Documentation: https://man.archlinux.org/search?q=hwloc-gather-cpuid
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-c[Only gather cpuid values for logical processor at the specified index]:idx'
    {-s,--silent}'[Do not show verbose messages]'
    '(- * :)'{-h,--help}'[Display help message and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
