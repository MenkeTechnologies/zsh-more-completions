#compdef zuluCrypt-cli

local arguments

arguments=(
    '-c[Create an encrypted volume]'
    '-o[Open an encrypted volume]:device:_files'
    '-O[Open an encrypted volume and mount it]:device:_files'
    '-m[Mount an opened volume]:mapper_path'
    '-q[Close an encrypted volume]:mapper_name'
    '-r[Remove an entry from /etc/crypttab and /etc/fstab]:device'
    '-a[Add an entry to /etc/crypttab and /etc/fstab]:device'
    '-i[Check if a device is a luks device]:device:_files'
    '-s[Check if a device is open]:device'
    '-b[Show open volumes and their mount points]'
    '-A[Add a key to a luks volume]:device:_files'
    '-N[Remove a key from a luks volume]:device:_files'
    '-T[Check the type of a device]:device:_files'
    '-S[Get information about a volume]:device:_files'
    '-Z[Write random data to a device]:device:_files'
    '-w[Create a new header backup for a LUKS device]:device:_files'
    '-P[Restore a header backup for a LUKS device]:device:_files'
    '-L[Print a list of partitions]'
    '-X[Open a file from a volume]:file:_files'
    '-d[Device path]:device:_files'
    '-W[Open a volume with a wallet]:device:_files'
    '-p[Passphrase source (pass -p to prompt or give passphrase)]:passphrase'
    '-f[Passphrase from file]:file:_files'
    '-U[Specify a UUID for the volume]:uuid'
    '-H[Header backup file to use]:file:_files'
    '-M[Mount point for the volume]:directory:_directories'
    '-J[Specify filesystem type for new volumes]:filesystem'
    '-B[Set the size of the LUKS header backup]:size'
    '-R[Random number source (e.g. /dev/urandom)]:source:_files'
    '-G[Specify passphrase from a gpg encrypted file]:file:_files'
    '-e[Encrypt/decrypt a file or directory]:file:_files'
    '-k[Specify a key file]:keyfile:_files'
    '-z[Specify the volume size]:size'
    '-t[Specify the encryption type]:type'
    '-g[Specify the key size in bits]:size'
    '-h[Show help]'
    '-F[Specify volume file system]:fs'
    '-V[Print version]'
    '-y[Specify cipher mode]:mode'
    '-u[Unmount a volume]:mount_point'
    '-l[List supported filesystems]'
    '-n[Do not mount after opening]'
    '*:filename:_files'
)
_arguments -s $arguments
