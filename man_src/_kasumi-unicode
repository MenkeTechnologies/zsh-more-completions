#compdef kasumi-unicode

local arguments

arguments=(
    {-h,--help}'[Show help message]'
    {-v,--version}'[Show version and copyright]'
    {-m,--manage}'[Run Kasumi in Manage mode]'
    {-a,--add}'[Run Kasumi in Add mode]'
    {-e,--exclusive}'[Run Kasumi in Exclusive mode]'
    '--sound[Set default sound entry (only in Add mode)]:sound'
    '--spelling[Set default spelling entry (only in Add mode)]:spelling'
    '--wordclass[Set default word class entry (only in Add mode)]:wordclass'
    {-i,--import}'[Import selected text as a spelling]'
    {-I,--ignore}'[Ignore selected text]'
    {-E,--eucjp}'[Use EUC-JP encoding for dictionary]'
    '*:filename:_files'
)
_arguments -s $arguments
