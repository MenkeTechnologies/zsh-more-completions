#compdef mysqlrplshow

local arguments

arguments=(
    '--help[Display help and exit]'
    '--discover-slaves-login[User and password for discovering slaves]:user:password'
    '--format[Output format]:format:(grid csv tab vertical)'
    '--master[Connection information for the master server]:source'
    '--max-depth[Maximum depth of replication topology to traverse]:N'
    '--num-retries[Number of retries for failed connections]:n'
    '--prompt[Prompt for user name and password for slave connections]'
    {-q,--quiet}'[Turn off all messages for quiet execution]'
    '--recurse[Recurse through slave connections]'
    '--show-list[Show replication topology as a list]'
    {-v,--verbose}'[Verbose output]'
    '--version[Display version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
