#compdef orbd

local arguments

arguments=(
    '-ORBInitialPort[Specify the port on which the name server should be started]:port'
    '-port[Specify the activation port where ORBD should be started]:port'
    '-defaultdb[Specify the base where the ORBD persistent storage directory is located]:directory:_directories'
    '-serverPollingTime[How often ORBD checks the health of persistent servers in milliseconds]:milliseconds'
    '-serverStartupDelay[How long ORBD waits before sending a location forward exception in milliseconds]:milliseconds'
    '-J[Pass option directly to the Java runtime environment]:option'
    '*:filename:_files'
)
_arguments -s $arguments
