#compdef indxbib

local arguments

arguments=(
    '-v[Print the version number]'
    '-w[Index whole files; each file is a separate record]'
    '-c[Read the list of common words from file]:file:_files'
    '-d[Use dir as the pathname of the current working directory to store in the index]:dir:_directories'
    '-f[Read the files to be indexed from file]:file:_files'
    '-i[Do not index the contents of fields whose names are in string]:string'
    '-h[Use the first prime greater than or equal to n for the size of the hash table]:n'
    '-k[Use at most n keys per input record]:n'
    '-l[Discard keys that are shorter than n]:n'
    '-n[Discard the n most common words]:n'
    '-o[The index should be named basename.i]:basename'
    '-t[Discard keys using specified options]'
    '*:filename:_files'
)
_arguments -s $arguments
