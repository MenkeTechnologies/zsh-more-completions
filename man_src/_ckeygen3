#compdef ckeygen3

local arguments

arguments=(
    {-C,--comment}'[Provide new comment]:comment'
    {-N,--newpass}'[Provide new passphrase]:passphrase'
    {-P,--pass}'[Provide old passphrase]:passphrase'
    {-b,--bits}'[Number of bits in the key to create]:bits'
    {-f,--filename}'[Filename of the key file]:filename:_files'
    '(- * :)--help[Display help and exit]'
    {-l,--fingerprint}'[Show fingerprint of key file]'
    '--no-passphrase[Create the key with no passphrase]'
    {-o,--format}'[Fingerprint format of key file]:format'
    {-p,--changepass}'[Change passphrase of private key file]'
    '--private-key-subtype[OpenSSH private key subtype to write]:subtype:(PEM v1)'
    {-q,--quiet}'[Quiet mode]'
    {-t,--type}'[Specify type of key to create]:type:(rsa dsa ecdsa ed25519)'
    '--version[Display version and exit]'
    {-y,--showpub}'[Read private key file and print public key]'
    '*:filename:_files'
)
_arguments -s $arguments
