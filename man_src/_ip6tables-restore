#compdef ip6tables-restore

local arguments

arguments=(
    {-c,--counters}'[Restore the values of all packet and byte counters]'
    '(- * :)'{-h,--help}'[Print a short option summary]'
    {-n,--noflush}'[Do not flush the previous contents of the table]'
    {-t,--test}'[Only parse and construct the ruleset, but do not commit it]'
    {-v,--verbose}'[Print additional debug info during ruleset processing]'
    {-M,--modprobe}'[Specify the path to the modprobe program]:modprobe:_files'
    {-T,--table}'[Restore only the named table even if the input stream contains other ones]:name'
    '*:filename:_files'
)
_arguments -s $arguments
