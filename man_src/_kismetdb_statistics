#compdef kismetdb_statistics
# Documentation: https://man.archlinux.org/search?q=kismetdb_statistics
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-i,--in}'[Input kismetdb file]:filename:_files'
    {-s,--skip-clean}'[Do not clean (SQL vacuum) input database]'
    {-j,--json}'[Dump stats as a JSON dictionary]'
    '*:filename:_files'
)
_arguments -s $arguments
