#compdef db_recover

local arguments

arguments=(
    '-c[Perform catastrophic recovery instead of normal recovery]'
    '-e[Retain the environment after running recovery]'
    '-h[Specify a home directory for the database environment]:directory:_directories'
    '-P[Specify an environment password]:password'
    '-t[Recover to the specified time]:time'
    '-V[Write the library version number and exit]'
    '-v[Run in verbose mode]'
    '*:filename:_files'
)
_arguments -s $arguments
