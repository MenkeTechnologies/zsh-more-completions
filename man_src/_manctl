#compdef manctl
# Documentation: https://man.archlinux.org/search?q=manctl
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--help[Print options and exit]'
    '--compress[Compress uncompressed man pages]'
    '--uncompress[Uncompress compressed man pages]'
    '--purge[Purge old formatted man pages]'
    '*:filename:_files'
)
_arguments -s $arguments
