#compdef vidfont

local arguments

arguments=(
    '-K[Run as command vidfont]'
    '-V[Run as command vidfont]'
    '-d[Use default language, ignore LANG environment variable]'
    '-h[Print options and exit]'
    '-l[Use language for description and menu]:language'
    '-p[Print description of available keymaps or fonts to stdout and exit]'
    '-r[Load default font from /etc/rc.conf]'
    '-s[Show currently supported languages and exit]'
    '-v[More warnings]'
    '*:filename:_files'
)
_arguments -s $arguments
