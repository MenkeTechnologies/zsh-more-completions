#compdef virt-qemu-run
# Documentation: https://man.archlinux.org/search?q=virt-qemu-run
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-h,--help}'[Show help options]'
    {-s,--secret}'[Load secret file]:file:_files'
    {-r,--root}'[Root directory]:directory:_directories'
    {-d,--debug}'[Debug output]'
    {-v,--verbose}'[Verbose output]'
    '*:filename:_files'
)
_arguments -s $arguments
