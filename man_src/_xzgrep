#compdef xzgrep

local arguments

arguments=(
    '-r[Search directories recursively]'
    '--recursive[Search directories recursively]'
    '-R[Search directories recursively, following symlinks]'
    '--dereference-recursive[Search directories recursively, following symlinks]'
    '-d[Specify how to handle directories]:action:(read skip recurse)'
    '--directories[Specify how to handle directories]:action:(read skip recurse)'
    '-Z[Print a zero byte after the file name]'
    '--null[Print a zero byte after the file name]'
    '-z[Treat the input as a set of lines separated by a zero byte]'
    '--null-data[Treat the input as a set of lines separated by a zero byte]'
    '--include[Search only files matching glob]:glob'
    '--exclude[Skip files matching glob]:glob'
    '--exclude-from[Skip files matching patterns in file]:file:_files'
    '--exclude-dir[Skip directories matching glob]:glob'
    '*:filename:_files'
)
_arguments -s $arguments
