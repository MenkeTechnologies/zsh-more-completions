#compdef j1939spy
# Documentation: https://man.archlinux.org/search?q=j1939spy
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-v,--verbose}'[Increase verbosity]'
    {-P,--promisc}'[Run in promiscuous mode (receive traffic not for this ECU)]'
    {-b,--block}'[Use a receive buffer of specified size]:size'
    {-t,--time}'[Show time format]:format:(a d z A)'
    '*:filename:_files'
)
_arguments -s $arguments
