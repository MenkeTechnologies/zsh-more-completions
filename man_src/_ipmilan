#compdef ipmilan
# Documentation: https://man.archlinux.org/search?q=ipmilan
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-c[Set the configuration file]:config_file:_files'
    '-n[Do not fork and detach from the controlling terminal]'
    '-d[Turn on debugging to standard output]'
    '*:filename:_files'
)
_arguments -s $arguments
