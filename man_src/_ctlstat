#compdef ctlstat

local arguments

arguments=(
    '-t[Total mode]'
    '-c[Display statistics this many times]:count'
    '-C[Disable CPU statistics display]'
    '-d[Display DMA operation time instead of overall I/O time]'
    '-D[Text dump mode]'
    '-h[Suppress display of the header]'
    '-j[JSON dump mode]'
    '-l[Request statistics for the specified LUN]:LUN'
    '-n[Display statistics for this many devices]:count'
    '-p[Request statistics for the specified port]:port'
    '-w[Wait this many seconds between displays]:seconds'
    '*:filename:_files'
)
_arguments -s $arguments
