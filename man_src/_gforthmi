#compdef gforthmi

local arguments

arguments=(
    '--help[Print help message and exit]'
    '--version[Print version and exit]'
    '--image-file[Use specified image file]:file:_files'
    '--path[Use specified path for finding image and source files]:path'
    '--dictionary-size[Specify dictionary size]:size'
    '--data-stack-size[Specify data stack size]:size'
    '--return-stack-size[Specify return stack size]:size'
    '--fp-stack-size[Specify floating-point stack size]:size'
    '--locals-stack-size[Specify locals stack size]:size'
    '--evaluate[Evaluate Forth expression]:expression'
    '*:filename:_files'
)
_arguments -s $arguments
