#compdef hp-logcapture
# Documentation: https://man.archlinux.org/search?q=hp-logcapture
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--user[Specify user name]:user'
    '(- * :)'{-h,--help}'[Show help information]'
    {-l,--logging}'[Set the logging level]:level:(none info error warn debug)'
    {-g,--ldebug}'[Run in debug mode]'
    '*:filename:_files'
)
_arguments -s $arguments
