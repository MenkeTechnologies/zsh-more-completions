#compdef taskpolicy

local arguments

arguments=(
    '-d[run program with IOPOL_TYPE_DISK set to IOPOL_THROTTLE]'
    '-g[run program with IOPOL_TYPE_DISK set to IOPOL_UTILITY]'
    '-c[run program using the specified QoS clamp]:clamp'
    '-p[change settings for the process specified by pid]:pid'
    '-b[run program with PRIO_DARWIN_BG priority]'
    '-B[move target process out of PRIO_DARWIN_BG]'
    '-t[set throughput tier of the process]:throughput_tier'
    '-l[set latency tier of the process]:latency_tier'
    '-a[run program with resource management policies given to applications]'
    '*:filename:_files'
)
_arguments -s $arguments
