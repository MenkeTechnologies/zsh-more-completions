#compdef ipmi_ui
# Documentation: https://man.archlinux.org/search?q=ipmi_ui
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--dmsg[Turn on message debugging, dump all messages to the log window]'
    '--dmem[Turn on memory debugging, cause memory allocation and deallocations to be audited]'
    '--snmp[Enable the SNMP trap handler]'
    '-c[Run the program in command-line mode for scripting]'
    '*:filename:_files'
)
_arguments -s $arguments
