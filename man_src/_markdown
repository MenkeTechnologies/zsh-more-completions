#compdef markdown

local arguments

arguments=(
    '-b[Links in source beginning with / will be prefixed with url-base in the output]:url-base'
    '-C[Use the given prefix for extra-style footnotes instead of the default]:prefix'
    '-d[Instead of writing html, dump a parse tree to stdout]'
    '-f[Set or clear various translation flags]:flags'
    '-F[Set translation flags]:flags'
    '-n[Do not write generated html]'
    '-o[Write the generated html to file]:file:_files'
    '-S[Output style blocks]'
    '-V[Show the version number and compile-time configuration data]'
    '--VV[Show the version, compile-time and run-time configuration]'
    '-t[Use mkd_text to format text instead of processing stdin]'
    '-T[Dump the table of contents before the document]'
    '-s[Use the markdown function to format text]'
    '*:filename:_files'
)
_arguments -s $arguments
