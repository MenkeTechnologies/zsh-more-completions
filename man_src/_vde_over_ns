#compdef vde_over_ns

local arguments

arguments=(
    '-s[Connect to the local vde socket]:vdeplug:_files'
    '-D[Detach console and send the process to background]'
    '-b[Bind the NS server only to the specified IP address]:ip'
    '-c[Enable client mode with specified server address]:server_addr'
    '*:filename:_files'
)
_arguments -s $arguments
