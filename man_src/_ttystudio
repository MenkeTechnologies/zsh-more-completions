#compdef ttystudio

local arguments

arguments=(
    {-l,--log}'[log status to stderr]'
    {-q,--quiet}'[do not log status to stderr]'
    {-f,--font}'[choose a BDF font in ttystudio JSON format]:font:_files'
    {-b,--font-bold}'[choose a bold BDF font in ttystudio JSON format]:font:_files'
    {-d,--delay}'[specify frame delay in ms]:delay'
    {-i,--interval}'[specify frame snapshot interval in ms]:interval'
    {-k,--key}'[choose a key combination to quit recording]:key'
    {-n,--num-plays}'[specify number of plays for the animation]:plays'
    {-r,--range}'[choose a range of frames to compile]:range'
    {-x,--ratio}'[choose pixel to cell ratio]:ratio'
    {-t,--term}'[choose the terminal name for terminfo]:term'
    '--palette[use a global palette for APNGs instead of RGBA]'
    {--no-palette,--rgba,--lct}'[use RGBA for APNGs instead of a global palette]'
    '--border[add a border around the animation]:width_rgba'
    '--play[replay a frames file in the terminal]'
    '--record[explicitly choose to record]'
    '--compile[explicitly choose to compile]'
    '--screenshot[start ttystudio in screenshot mode]'
    '--screenshot-key[set the screenshot key in screenshot mode]:key'
    '--version[display ttystudio version]'
    '(- * :)'{-h,--help}'[display help information]'
    '*:filename:_files'
)
_arguments -s $arguments
