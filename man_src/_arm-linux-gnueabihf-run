#compdef arm-linux-gnueabihf-run

# Updated with latest GDB simulator run options

local arguments

arguments=(
    '-v[Verbose output]'
    '-t[Enable trace mode]'
    '-p[Generate profile information for gprof]:freq'
    '-m[Set the memory size (power of 2)]:size'
    '--sysroot[Prepend filepath to all simulator system calls using absolute paths]:filepath:_directories'
    '*:filename:_files'
)
_arguments -s $arguments
