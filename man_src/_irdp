#compdef irdp
# Documentation: https://man.archlinux.org/search?q=irdp
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-i[Specify the interface]:interface'
    '-p[Preference value]'
    '-l[Lifetime value]'
    '-S[Act as a server]'
    '-D[Act as a daemon]'
    '*:filename:_files'
)
_arguments -s $arguments
