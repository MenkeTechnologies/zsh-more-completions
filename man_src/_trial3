#compdef trial3

local arguments

arguments=(
    {-j,--jobs}'[set the number of process workers to run]:number'
    {-b,--debug}'[run the tests in a debugger]'
    {-B,--debug-stacktraces}'[report Deferred creation and callback stack traces]'
    '--coverage[generate coverage information in the coverage subdirectory]'
    '--debugger[specify the debugger to use with --debug]:debugger'
    '--disablegc[disable the garbage collector for the test run]'
    {-e,--rterrors}'[print tracebacks to standard output as soon as they occur]'
    '--force-gc[run gc.collect() before and after each test case]'
    '(- * :)'{-h,--help}'[print a usage message and exit]'
    '--help-order[print a list of possible test method orders]'
    '--help-reporters[print a list of valid reporters]'
    '--help-reactors[print a list of possible reactors]'
    {-l,--logfile}'[direct the log to a different file]:logfile:_files'
    {-n,--dry-run}'[go through all tests without running them]'
    {-N,--no-recurse}'[do not recurse through packages to find test modules]'
    '--nopm[do not jump into debugger for post-mortem analysis]'
    '--order[specify what order to run test methods]:order'
    '--profile[run tests under the Python profiler]'
    {-r,--reactor}'[choose which reactor to use]:reactor'
    '--recursionlimit[set Python recursion limit]:limit'
    '--reporter[select the reporter for output]:reporter'
    {-x,--exitfirst}'[stop after the first test which does not succeed]'
    '--spew[print insanely verbose log of everything]'
    '--tbformat[format to display tracebacks with]:format'
    '--temp-directory[specify temporary directory]:directory:_directories'
    '--testmodule[look into filename for test specifications]:filename:_files'
    '--unclean-warnings[show unclean reactor warnings]'
    {-u,--until-failure}'[keep looping tests until one raises an error]'
    '--version[print the Twisted version number and exit]'
    '--without-module[simulate the lack of specified modules]:modulenames'
    {-z,--random}'[run tests in random order using the specified seed]:seed'
    '*:filename:_files'
)
_arguments -s $arguments
