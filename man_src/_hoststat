#compdef hoststat

local arguments

arguments=(
    '-B[Set the body type]:type:(7BIT 8BITMIME)'
    '-C[Use alternate configuration file]:file:_files'
    '-D[Send debugging output to the indicated log file]:logfile:_files'
    '-d[Set the debugging flag for category to level]:category.level'
    '-F[Set the full name of the sender]:fullname'
    '-f[Set the name of the from person]:name'
    '-G[Relay (gateway) submission of a message]'
    '-h[Set the hop count]:N'
    '-i[Do not strip a leading dot from lines in incoming messages]'
    '-L[Set the identifier used in syslog messages]:tag'
    '-N[Set delivery status notification conditions]:dsn'
    '-n[Do not do aliasing]'
    '-O[Set option to the specified value using long names]:option=value'
    '-o[Set option to the specified value]:xvalue'
    '-p[Set the name of the protocol used to receive the message]:protocol'
    '-q[Process saved messages in the queue at given intervals]:interval'
    '-Q[Quarantine or unquarantine queue items]:reason'
    '-R[Set the amount of the message to be returned if it bounces]:return'
    '-r[Alternate form of the -f flag]:name'
    '-t[Read message for recipients]'
    '-V[Set the original envelope id]:envid'
    '-v[Go into verbose mode]'
    '-X[Log all traffic in and out of mailers]:logfile:_files'
    '*:filename:_files'
)
_arguments -s $arguments
