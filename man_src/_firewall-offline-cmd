#compdef firewall-offline-cmd

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Print a short help text and exit]'
    {-V,--version}'[Print the version string of firewalld and exit]'
    {-q,--quiet}'[Do not print status messages]'
    '--enabled[Enable the firewall]'
    '--disabled[Disable the firewall by disabling the firewalld service]'
    '--migrate-system-config-firewall[Migrate system-config-firewall configuration from the given file]:file:_files'
    '--get-log-denied[Print the log denied setting]'
    '--set-log-denied[Set logging for denied packets]:value:(all unicast broadcast multicast off)'
    '--get-default-zone[Print default zone for connections and interfaces]'
    '--set-default-zone[Set default zone for connections and interfaces]:zone'
    '--get-zones[Print predefined zones as a space separated list]'
    '--get-services[Print predefined services as a space separated list]'
    '--get-icmptypes[Print predefined icmptypes as a space separated list]'
    '--new-zone[Add a new permanent zone]:zone'
    '--delete-zone[Delete an existing permanent zone]:zone'
    '--list-all[List everything added for or enabled in zone]'
    '--list-all-zones[List everything added for or enabled in all zones]'
    '--add-service[Add a service to the default zone]:service'
    '--remove-service[Remove a service from the default zone]:service'
    '--add-port[Add the port to the default zone]:port'
    '--remove-port[Remove the port from the default zone]:port'
    '--add-protocol[Add the protocol to the default zone]:protocol'
    '--remove-protocol[Remove the protocol from the default zone]:protocol'
    '--add-masquerade[Enable IPv4 masquerade for zone]'
    '--remove-masquerade[Disable IPv4 masquerade for zone]'
    '--add-forward-port[Add an IPv4 forward port for zone]:port'
    '--remove-forward-port[Remove an IPv4 forward port from zone]:port'
    '--add-rich-rule[Add rich language rule for zone]:rule'
    '--remove-rich-rule[Remove rich language rule from zone]:rule'
    '--add-interface[Bind interface to zone]:interface'
    '--remove-interface[Remove binding of interface from zone]:interface'
    '--add-source[Bind source to zone]:source'
    '--remove-source[Remove binding of source from zone]:source'
    '--lockdown-on[Enable lockdown]'
    '--lockdown-off[Disable lockdown]'
    '--query-lockdown[Query whether lockdown is enabled]'
    '*:filename:_files'
)
_arguments -s $arguments
