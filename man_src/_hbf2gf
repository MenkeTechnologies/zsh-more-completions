#compdef hbf2gf
# Documentation: https://man.archlinux.org/search?q=hbf2gf
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-q[Quiet mode; suppress informational output]'
    '-p[Do not create a PL file]'
    '-g[Do not create a GF file]'
    '-n[Use .nNN extension instead of .NN for subfont numbering]'
    '-t[Test mode for use with scripts like mktexpk]'
    '--version[Display the current version of hbf2gf]'
    '--help[Display help and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
