#compdef cmis-client

local arguments

arguments=(
    {-v,--verbose}'[Show detailed information about what is happening]'
    '(- * :)--help[Show help and exit]'
    '--url[URL to the CMIS service document]:url'
    {-r,--repository}'[Operate on the specified CMIS repository]:repo-id'
    {-u,--username}'[Connect as the specified user]:login'
    {-p,--password}'[Use the specified password to authenticate]:secret'
    '--no-ssl-check[Disable SSL certificate verifications]'
    '--proxy[Use the specified URL as the HTTP proxy]:url'
    '--proxy-username[Use login to authenticate on the HTTP proxy]:login'
    '--proxy-password[Use secret to authenticate on the HTTP proxy]:secret'
    '--noproxy[Proxy settings will not apply to the listed hostnames]:list'
    '--oauth2-client-id[Application client id for OAuth2 authentication]:client_id'
    '--oauth2-client-secret[Application client secret for OAuth2 authentication]:client_secret'
    '--oauth2-auth-url[Authentication service URL for OAuth2]:url'
    '--oauth2-token-url[Token service URL for OAuth2]:url'
    '--oauth2-redirect-uri[Redirect URI for OAuth2]:uri'
    '--oauth2-scope[Scope for OAuth2]:scope'
    '*:filename:_files'
)
_arguments -s $arguments
