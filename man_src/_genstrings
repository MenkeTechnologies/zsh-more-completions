#compdef genstrings

local arguments

arguments=(
    '-a[Allow output to be appended to old output files]'
    '--SwiftUI[Enable support for recognizing the SwiftUI Text initializer]'
    '-s[Recognize routine as equivalent to NSLocalizedString]:routine'
    '--skipTable[Skip over the file for the specified table]:table'
    '--noPositionalParameters[Turn off generation of positional parameters]'
    '-u[Allow unicode characters in the value of strings files]'
    '--encoding[Read source files using the given IANA charset name]:charset'
    '--macRoman[Read source files using Mac Roman encoding]'
    '-q[Turn off multiple key/value pairs warning]'
    '--bigEndian[Write output files with big-endian byte order]'
    '-o[Specify the directory for output string tables]:directory:_directories'
    '*:filename:_files'
)
_arguments -s $arguments
