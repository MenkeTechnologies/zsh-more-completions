#compdef tuned

local arguments

arguments=(
    {-c,--conffile}'[specify the name and path of the configuration file]:file:_files'
    {-d,--daemon}'[start tuned as a daemon]'
    {-D,--debug}'[set the highest logging level]'
    '(- * :)'{-h,--help}'[show help]'
    {-l,--log}'[log to a specified file]:file:_files'
    '--no-dbus[do not attach to DBus]'
    {-P,--pid}'[write process ID to the PID file]:file:_files'
    {-p,--profile}'[tuning profile to be activated]:profile'
    {-v,--version}'[show version information]'
    '*:filename:_files'
)
_arguments -s $arguments
