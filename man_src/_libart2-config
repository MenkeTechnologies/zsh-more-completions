#compdef libart2-config

local arguments

arguments=(
    '--prefix[Use PREFIX instead of the installation prefix that libart was built with]:PREFIX:_directories'
    '--exec-prefix[Use PREFIX instead of the installation exec prefix that libart was built with]:PREFIX:_directories'
    '--libs[Print the linker flags that are necessary to link a libart program]'
    '--cflags[Print the compiler flags that are necessary to compile a libart program]'
    '*:filename:_files'
)
_arguments -s $arguments
