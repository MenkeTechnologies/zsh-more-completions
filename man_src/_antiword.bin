#compdef antiword antiword.bin

# Autogenerated from man page
# Updated with latest antiword options

local arguments

arguments=(
    '-f[Use text output]'
    '-t[Use text output (default)]'
    '-a[Use Adobe PDF output with specified paper size]:paper size:(letter legal a3 a4 a5)'
    '-p[Use PostScript output with specified paper size]:paper size:(letter legal a3 a4 a5)'
    '-x[Use XML output]:dtd:(db list)'
    '-m[Use specified character mapping file]:mapping file:_files'
    '-w[Set width in characters of text output]:width'
    '-i[Set image level (PostScript only)]:level:(0 1 2)'
    '-L[Use landscape mode (PostScript only)]'
    '-r[Show removed text]'
    '-s[Show hidden (by Word) text]'
    '*:file:_files'
)
_arguments -s $arguments
