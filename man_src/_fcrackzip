#compdef fcrackzip

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Print version number and help]'
    {-v,--verbose}'[Each -v makes the program more verbose]'
    {-b,--brute-force}'[Select brute force mode]'
    {-D,--dictionary}'[Select dictionary mode]'
    {-c,--charset}'[Select the characters to use in brute-force cracking]:charset'
    {-p,--init-password}'[Set initial starting password for brute-force searching]:string'
    {-l,--length}'[Use passwords of length min to max]:min-max'
    {-u,--use-unzip}'[Try to decompress the first file by calling unzip with the guessed password]'
    {-m,--method}'[Use the specified cracking method]:name'
    {-2,--modulo}'[Calculate only r/m of the password]:r/m'
    {-B,--benchmark}'[Make a small benchmark]'
    {-V,--validate}'[Make basic checks whether the cracker works]'
    '*:filename:_files'
)
_arguments -s $arguments
