#compdef hivexsh
# Documentation: https://man.archlinux.org/search?q=hivexsh
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-d[Enable lots of debug messages]'
    '-f[Read commands from file instead of stdin]:filename:_files'
    '-u[Use heuristics to tolerate certain levels of corruption within hives]'
    '*:filename:_files'
)
_arguments -s $arguments
