#compdef opiepasswd

local arguments

arguments=(
    '-v[Display the version number and compile-time options, then exit]'
    '-h[Display a brief help message and exit]'
    '-c[Set console mode where the user has secure access to the system]'
    '-d[Disable OTP logins to the specified account]'
    '-f[Force opiepasswd to continue even where it normally would not]'
    '-n[Manually specify the initial sequence number]'
    '-s[Specify a non-random seed]'
    '*:filename:_files'
)
_arguments -s $arguments
