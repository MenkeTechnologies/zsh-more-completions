#compdef pg_ctlcluster

local arguments

arguments=(
    {-f,--force}'[Use fast mode which rolls back all active transactions]'
    {-m,--mode}'[Shutdown mode to use for stop and restart actions]:mode:(smart fast immediate)'
    '--foreground[Start postgres in foreground without daemonizing]'
    '--stdlog[When using --foreground, redirect stderr to standard logfile]'
    '--skip-systemctl-redirect[Do not redirect actions to systemctl when running as root]'
    '--bindir[Path to pg_ctl]:directory:_directories'
    {-o,--options}'[Pass option as command line option to postgres]:option'
    '*:filename:_files'
)
_arguments -s $arguments
