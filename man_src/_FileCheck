#compdef FileCheck

local arguments

arguments=(
    '--help[Print a summary of command line options]'
    '--check-prefix[Prefix to use from check file (defaults to CHECK)]:prefix'
    '--check-prefixes[Comma-separated list of check prefixes]:prefixes'
    '--input-file[File to check (defaults to stdin)]:filename:_files'
    '--match-full-lines[Require all positive matches to cover an entire input line]'
    '--strict-whitespace[Do not treat all horizontal whitespace as equivalent]'
    '--implicit-check-not[Add implicit negative checks for the specified patterns]:check-pattern'
    '--dump-input[Dump input to stderr with annotations]:mode:(help always fail never)'
    '--dump-input-on-failure[Dump all original input on check failure]'
    '--enable-var-scope[Enable scope for regex variables]'
    '--version[Show the version number of this program]'
    '-v[Print good directive pattern matches]'
    '--vv[Print verbose information for diagnosing internal issues]'
    '--allow-deprecated-dag-overlap[Enable overlapping among matches in consecutive CHECK-DAG directives]'
    '--allow-empty[Allow the input file to be empty]'
    '--ignore-case[Use case-insensitive matching]'
    '--color[Use colors in output (autodetected by default)]'
    '*:filename:_files'
)
_arguments -s $arguments
