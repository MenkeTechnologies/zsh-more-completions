#compdef homectl

local arguments

arguments=(
    {-h,--help}'[Show this help]'
    '--version[Show package version]'
    '--no-pager[Do not pipe output into a pager]'
    '--no-legend[Do not show the headers and footers]'
    '--no-ask-password[Do not ask for system passwords]'
    {-H,--host}'[Operate on remote host]:host:_hosts'
    {-M,--machine}'[Operate on local container]:machine'
    '--identity[Read JSON identity from file]:file:_files'
    '--json[Output inspection data in JSON]:format:(pretty short off)'
    '-j[Equivalent to --json=pretty on TTY or --json=short otherwise]'
    '--export-format[Strip JSON inspection data]:format:(full stripped minimal)'
    '-E[Equivalent to -j --export-format=stripped]'
    {-c,--real-name}'[Real name for user]:name'
    '--realm[Realm to create user in]:realm'
    '--email-address[Email address for user]:email'
    '--location[Set location of user on earth]:location'
    '--icon-name[Icon name for user]:icon'
    {-d,--home-dir}'[Home directory]:dir:_directories'
    {-u,--uid}'[Numeric UID for user]:uid'
    {-G,--member-of}'[Add user to group]:group:_groups'
    '--skel[Skeleton directory to use]:dir:_directories'
    '--shell[Shell for account]:shell:_files'
    '--setenv[Set an environment variable at log-in]:NAME=VALUE'
    '--timezone[Set a time-zone]:timezone'
    '--language[Set preferred language]:language'
    '--ssh-authorized-keys[Specify SSH public keys]:keys'
    '--pkcs11-token-uri[URI to PKCS#11 security token]:uri'
    '--fido2-device[Path to FIDO2 hidraw device with hmac-secret]:device:_files'
    '--recovery-key[Add a recovery key]:boolean:(yes no)'
    '--locked[Set locked account state]:boolean:(yes no)'
    '--not-before[Do not allow logins before]:timestamp'
    '--not-after[Do not allow logins after]:timestamp'
    '--rate-limit-interval[Login rate-limit interval in seconds]:seconds'
    '--rate-limit-burst[Login rate-limit attempts per interval]:count'
    '--password-hint[Set password hint]:hint'
    '--enforce-password-policy[Control whether to enforce password policy]:boolean:(yes no)'
    '-P[Equivalent to --enforce-password-policy=no]'
    '--password-change-now[Require the password to be changed on next login]:boolean:(yes no)'
    '--password-change-min[Require minimum time between password changes]:time'
    '--password-change-max[Require maximum time between password changes]:time'
    '--password-change-warn[How much time to warn before password expiry]:time'
    '--password-change-inactive[How much time to block password after expiry]:time'
    '--disk-size[Size to assign the user on disk]:size'
    '--access-mode[User home directory access mode]:mode'
    '--umask[Umask for user when logging in]:umask'
    '--nice[Nice level for user]:nice'
    '--rlimit[Set resource limit]:RLIMIT=VALUE'
    '--tasks-max[Set maximum number of per-user tasks]:max'
    '--memory-high[Set high memory threshold in bytes]:bytes'
    '--memory-max[Set maximum memory limit]:bytes'
    '--cpu-weight[Set CPU weight]:weight'
    '--io-weight[Set IO weight]:weight'
    '--storage[Storage type to use]:type:(luks fscrypt directory subvolume cifs)'
    '--image-path[Path to image file/directory]:path:_files'
    '--fs-type[File system type to use in case of luks]:type:(ext4 xfs btrfs)'
    '--luks-discard[Whether to use discard feature of file system]:boolean:(yes no)'
    '--luks-offline-discard[Whether to trim file on logout]:boolean:(yes no)'
    '--luks-cipher[Cipher to use for LUKS encryption]:cipher'
    '--luks-cipher-mode[Cipher mode to use for LUKS encryption]:mode'
    '--luks-volume-key-size[Volume key size to use for LUKS encryption]:bytes'
    '--luks-pbkdf-type[Password-based Key Derivation Function to use]:type'
    '--luks-pbkdf-hash-algorithm[PBKDF hash algorithm to use]:algorithm'
    '--luks-pbkdf-time-cost[Time cost for PBKDF in seconds]:seconds'
    '--luks-pbkdf-memory-cost[Memory cost for PBKDF in bytes]:bytes'
    '--luks-pbkdf-parallel-threads[Number of parallel threads for PBKDF]:threads'
    '--nosuid[Control the nosuid flag of the home mount]:boolean:(yes no)'
    '--nodev[Control the nodev flag of the home mount]:boolean:(yes no)'
    '--noexec[Control the noexec flag of the home mount]:boolean:(yes no)'
    '--cifs-domain[CIFS (Windows) domain]:domain'
    '--cifs-user-name[CIFS (Windows) user name]:user'
    '--cifs-service[CIFS (Windows) service to mount as home area]:service'
    '--stop-delay[How long to leave user services running after logout]:time'
    '--kill-processes[Whether to kill user processes when sessions end]:boolean:(yes no)'
    '--auto-login[Try to log this user in automatically]:boolean:(yes no)'
    '*:filename:_files'
)
_arguments -s $arguments
