#compdef kldxref
# Documentation: https://man.archlinux.org/search?q=kldxref
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-R[Recurse into subdirectories]'
    '-d[Do not generate a hint file, but print module metadata on standard output]'
    '-f[Specify a different name for the hints files]:name'
    '-v[Operate in verbose mode]'
    '*:filename:_files'
)
_arguments -s $arguments
