#compdef fusermount3
# Documentation: https://man.archlinux.org/search?q=fusermount3
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-h[Print help]'
    '-V[Print version]'
    '-o[Mount options]:options'
    '-u[Unmount]'
    '-q[Quiet]'
    '-z[Lazy unmount]'
    '*:filename:_files'
)
_arguments -s $arguments
