#compdef editmap

local arguments

arguments=(
    '-C[Use the specified sendmail configuration file]:file:_files'
    '-N[Include the null byte that terminates strings in the map]'
    '-f[Do not fold upper case letters to lower case]'
    '-q[Query the map for the specified key]:key'
    '-u[Update the record for key with value or insert a new record]:key'
    '-x[Delete the specific key from the map]:key'
    '*:filename:_files'
)
_arguments -s $arguments
