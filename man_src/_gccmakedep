#compdef gccmakedep

local arguments

arguments=(
    '-a[Append dependencies to the file instead of replacing existing ones]'
    '-f[Specify the makefile]:makefile:_files'
    '-s[Starting string delimiter]:string'
    '-D[Define a symbol for the preprocessor]:symbol'
    '-U[Undefine a symbol]:symbol'
    '-I[Set the include path]:directory:_directories'
    '*:filename:_files'
)
_arguments -s $arguments
