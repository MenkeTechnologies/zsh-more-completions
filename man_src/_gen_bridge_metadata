#compdef gen_bridge_metadata

local arguments

arguments=(
    '-f[Generate metadata for the given framework]:framework'
    '-p[Generate metadata based on private headers of the given frameworks]'
    '-F[Select the metadata format to generate]:format'
    '-e[Consider the given exception file when generating metadata]:exception_file:_files'
    '--64-bit[Generate 64-bit annotations (default)]'
    '--no-32-bit[Do not write 32-bit annotations]'
    '--no-64-bit[Do not write 64-bit annotations]'
    '-c[Custom flags to pass to the C compiler]:flags'
    '-C[Custom flags to pass to the C compiler for generating metadata]:flags'
    '-o[Write the output to the given file]:file:_files'
    '-h[Print a summary of the options]'
    '-d[Turn on debugging messages]'
    '-v[Show the version of the program]'
    '*:filename:_files'
)
_arguments -s $arguments
