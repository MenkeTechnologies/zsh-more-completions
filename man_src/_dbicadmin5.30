#compdef dbicadmin5.30

local arguments

arguments=(
    '--create[Create version diffs, needs preversion]'
    '--upgrade[Upgrade the database to the current schema]'
    '--install[Install the schema version tables to an existing database]'
    '--deploy[Deploy the schema to the database]'
    '--select[Select data from the schema]'
    '--insert[Insert data into the schema]'
    '--update[Update data in the schema]'
    '--delete[Delete data from the schema]'
    '--op[Compatibility option, supply action]:action'
    '(- * :)--help[Display this help]'
    {--config-file,--config}'[Supply the config file for parsing]:file:_files'
    '--connect-info[Supply the connect info as trailing options]'
    '--connect[Supply the connect info as a JSON-encoded structure]:json'
    '--schema-class[The class of the schema to load]:class'
    '--config-stanza[Where in the config to find the connection_info]:stanza'
    {--resultset,--resultset-class,--class}'[The resultset to operate on]:class'
    '--sql-dir[The directory where sql diffs will be created]:directory:_directories'
    '--sql-type[The RDBMS flavour you wish to use]:type'
    '--version[Supply a version to install]:version'
    '--preversion[The previous version to diff against]:version'
    '--set[JSON data used to perform data operations]:json'
    '--attrs[JSON string for the second argument for search]:json'
    '--where[JSON string for the where clause of search]:json'
    '--force[Be forceful with some operations]'
    '--trace[Turn on DBIx::Class trace output]'
    '--quiet[Be less verbose]'
    '*:filename:_files'
)
_arguments -s $arguments
