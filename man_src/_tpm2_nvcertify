#compdef tpm2_nvcertify

local arguments

arguments=(
    {-C,--signingkey-context}'[key object that signs the attestation structure]:object:_files'
    {-P,--signingkey-auth}'[authorization value for the signing key]:auth'
    {-c,--nvauthobj-context}'[authorization handle for the NV object]:object:_files'
    {-p,--nvauthobj-auth}'[authorization value for the NV auth object]:auth'
    {-g,--hash-algorithm}'[hash algorithm to use in signature generation]:algorithm'
    {-s,--scheme}'[signing scheme used to sign the attestation data]:algorithm'
    {-f,--format}'[format selection for signature output]:format'
    {-o,--signature}'[output file name for signature data]:file:_files'
    {-q,--qualification}'[policy qualifier data]:file_or_hex'
    '--size[size of data to be read in bytes]:size'
    '--offset[offset within the NV index to start reading from]:offset'
    '--cphash[file path to record command parameter hash]:file:_files'
    '--rphash[file path to record response parameter hash]:file:_files'
    {-S,--session}'[the session created using tpm2_startauthsession]:file:_files'
    {-n,--name}'[name of the NV index]:file:_files'
    '--signer-name[name of the signing key]:file:_files'
    '--attestation[file to save attestation data]:file:_files'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    {-V,--verbose}'[increase verbosity of tool output]'
    {-Q,--quiet}'[suppress informational output]'
    {-Z,--enable-errata}'[enable errata fixups]'
    {-R,--autoflush}'[autoflush objects created by the command]'
    '*:filename:_files'
)
_arguments -s $arguments
