#compdef gropdf
# Documentation: https://man.archlinux.org/search?q=gropdf
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-d[Include the file as a PDF include]:file:_files'
    '-e[Use exact positioning for text]'
    '-F[Prepend directory to the search path for font and device description files]:dir:_directories'
    '-l[Set the landscape flag]'
    '-p[Set the paper size]:paper-size'
    '-s[Append a comment at the end of each page]'
    '-v[Print version number]'
    '-y[Set PDF standard output]:year'
    '*:filename:_files'
)
_arguments -s $arguments
