#compdef thin_dump
# Documentation: https://man.archlinux.org/search?q=thin_dump
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '(- * :)'{-h,--help}'[print help and exit]'
    {-V,--version}'[print version information and exit]'
    {-f,--format}'[choose output format]:format:(xml human_readable custom)'
    {-r,--repair}'[repair the metadata whilst dumping it]'
    {-m,--metadata-snap}'[dump metadata snapshot]'
    '--dev-id[dump the specified device]:id'
    '--skip-mappings[do not dump the mappings]'
    '-o[specify a file for the output]:file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
