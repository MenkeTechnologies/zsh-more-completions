#compdef httpie
# Documentation: https://man.archlinux.org/search?q=httpie
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-h,--help}'[Show help message and exit]'
    '--debug[Print the exception traceback should one occur, as well as other information useful for debugging]'
    '--traceback[Print the exception traceback should one occur]'
    '--version[Show version and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
