#compdef cmospwd
# Documentation: https://man.archlinux.org/search?q=cmospwd
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-k[Kill CMOS passwords]'
    '-l[Display BIOS information]'
    '-d[Dump CMOS memory]'
    '-w[Write word to address in CMOS]:address word'
    '*:filename:_files'
)
_arguments -s $arguments
