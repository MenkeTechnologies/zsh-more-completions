#compdef vbnc

local arguments

arguments=(
    '--addmodule[Include the specified modules in the resulting assembly]:modules'
    '--codepage[Specify the code page used to process the input files]:id'
    '--define[Define the symbol listed by the semi-colon separated list]:symlist'
    '--debug[Specify the amount of debugging information to emit]:amount'
    '--imports[Declare global Imports for listed namespaces]:import-list'
    '--ignorewarn[Ignore warning number]:number'
    '--lib[Add directories to search for referenced assemblies]:pathlist'
    '--main[Specify which class or module contains the entry point]:class'
    '--nologo[Suppress printing copyright information on startup]'
    '--nostdlib[Do not reference the standard library]'
    '--noconfig[Disable the default compiler configuration from being loaded]'
    '--nowarn[Make the compiler ignore warnings]'
    '--optioncompare[Select between binary and text string comparisons]:mode:(binary text)'
    '--optionexplicit[Require explicit declaration of variables]'
    '--optionstrict[Enforce strict language semantics]'
    {--out,-o}'[Name the output file to be generated]:file:_files'
    {-q,--quiet}'[Show only error messages for syntax-related errors and warnings]'
    '--resource[Embed the given resource file]:resource:_files'
    '--linkresource[Link to the specified resource]:resource:_files'
    {--r,-r}'[Reference the named assemblies]:assembly'
    '--sdkpath[Set the path to the required framework assemblies]:path:_directories'
    '--removeintchecks[Remove integer checks]'
    '--rootnamespace[Specify the root namespace for all type declarations]:namespace'
    '--target[Specify the desired target]:kind:(exe winexe library module)'
    '--utf8output[Emit compiler output in UTF8 character encoding]'
    '--version[Show the compiler version]'
    '--warnaserror[Treat warnings as errors]'
    '*:filename:_files'
)
_arguments -s $arguments
