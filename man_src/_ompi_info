#compdef ompi_info

local arguments

arguments=(
    {-a,--all}'[Show all configuration options and MCA parameters]'
    '--arch[Show architecture on which Open MPI was compiled]'
    {-c,--config}'[Show configuration options]'
    '--gmca[Pass global MCA parameters applicable to all contexts]:value'
    '(- * :)'{-h,--help}'[Show help / usage message]'
    '--hostname[Show the hostname on which Open MPI was configured and built]'
    '--internal[Show internal MCA parameters not meant to be modified by users]'
    '--level[Show only variables with at most this level (1-9)]:level'
    '--mca[Pass context-specific MCA parameters]:value'
    '--param[Show MCA parameters]:component'
    {-t,--type}'[Show MCA parameters of the type specified]'
    '--parsable[Display output in a machine-parsable format]'
    '--path[Show paths that Open MPI was configured with]:type'
    '--pretty[Display output in a human-readable pretty format]'
    '--selected-only[Show only variables from selected components]'
    '--parseable[Synonym for --parsable]'
    {-V,--version}'[Show version of Open MPI]'
    '*:filename:_files'
)
_arguments -s $arguments
