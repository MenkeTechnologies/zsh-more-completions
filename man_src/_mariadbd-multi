#compdef mariadbd-multi mysqld_multi

local arguments

arguments=(
    '--help[Display help and exit]'
    '--example[Display a sample option file]'
    '--defaults-extra-file[Read this option file in addition to the usual files]:file_name:_files'
    '--defaults-file[Use only the specified option file]:file_name:_files'
    '--log[Specify the log file name]:file_name:_files'
    '--mysqladmin[The mysqladmin binary to use for stopping servers]:prog_name:_files'
    '--mysqld[The mysqld binary to use]:prog_name:_files'
    '--no-defaults[Do not read any option files]'
    '--no-log[Do not write to any log file]'
    '--password[The password of the MariaDB account to use for mysqladmin]:password'
    '--silent[Silent mode; disable warnings]'
    '--tcp-ip[Connect to each server via TCP/IP instead of Unix socket]'
    '--user[The MariaDB user name to use when invoking mysqladmin]:user_name'
    '--verbose[Be more verbose]'
    '--version[Display version information and exit]'
    '--wsrep-new-cluster[Bootstrap a cluster]'
    '*:filename:_files'
)
_arguments -s $arguments
