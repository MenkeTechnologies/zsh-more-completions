#compdef umount.nilfs2

local arguments

arguments=(
    '-V[Print version and exit]'
    '-i[Do not call umount.nilfs2]'
    '-n[Unmount without writing in /etc/mtab]'
    '-r[In case unmounting fails, try to remount read-only]'
    '-v[Verbose mode]'
    '*:filename:_files'
)
_arguments -s $arguments
