#compdef espeak-ng

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Show summary of options]'
    '--version[Print the espeak library version and voice data location]'
    '-f[Text file to speak]:file:_files'
    '--stdin[Read text input from stdin instead of a file]'
    '-d[Use the specified device to speak the audio on]:device'
    '-q[Quiet, do not produce any speech]'
    '-a[Set amplitude, 0 to 200, default is 100]:integer'
    '-g[Word gap, pause between words in units of 10ms]:integer'
    '-k[Indicate capital letters with: 1=sound, 2=the word "capitals"]:integer'
    '-l[Set line length]:integer'
    '-p[Pitch adjustment, 0 to 99, default is 50]:integer'
    '-s[Speed in words per minute, default is 160]:integer'
    '-v[Use voice file of this name]:name'
    '-w[Write output to this WAV file rather than speaking directly]:file:_files'
    '--split[Split the audio output into chunks of specified minutes]:minutes'
    '-b[Input text encoding, 1=UTF8, 2=8 bit, 4=16 bit]:encoding'
    '-m[Indicates that the text contains SSML tags]'
    '-x[Write phoneme mnemonics to stdout]'
    '-X[Write phoneme mnemonics and translation trace to stdout]'
    '-z[No final sentence pause at the end of the text]'
    '--stdout[Write speech output to stdout]'
    '--compile[Compile pronunciation rules and dictionary in current directory]:voicename'
    '--compile-debug[Compile pronunciation rules and dictionary with debug output]:voicename'
    '--ipa[Write phonemes to stdout using International Phonetic Alphabet]'
    '--tie[Character to use to join multi-letter phonemes in output]:character'
    '--path[Specify the directory containing espeak-ng-data]:path:_directories'
    '--pho[Write mbrola phoneme data to stdout or to --phonout file]'
    '--phonout[Write output from -x -X commands and mbrola data to this file]:filename:_files'
    '--punct[Speak the names of punctuation characters during speaking]:characters'
    '--sep[Character to separate phonemes from -x and --ipa output]:character'
    '--voices[List the available voices]:language_code'
    '*:filename:_files'
)
_arguments -s $arguments
