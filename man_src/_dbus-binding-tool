#compdef dbus-binding-tool

local arguments

arguments=(
    '--force[Overwrite the output file if it already exists]'
    '(- * :)--help[Display usage information]'
    '--ignore-unsupported[Ignore unsupported signatures for method parameters]'
    '--mode[Specify the binding mode]:mode:(pretty glib-client glib-server)'
    '--output[Specify the output file]:file:_files'
    '--prefix[Prefix functions in the generated output with the given value]:prefix'
    '--version[Display the version number]'
    '*:filename:_files'
)
_arguments -s $arguments
