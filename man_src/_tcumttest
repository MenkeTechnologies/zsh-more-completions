#compdef tcumttest
# Documentation: https://man.archlinux.org/search?q=tcumttest
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--rnd[use random keys]'
    '--nc[do not use compression]'
    '--rr[set the number of records]:num'
    '*:filename:_files'
)
_arguments -s $arguments
