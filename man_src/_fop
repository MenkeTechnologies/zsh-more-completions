#compdef fop

local arguments

arguments=(
    '--version[Print FOP version and exit]'
    '-d[Debug mode]'
    '-x[Dump configuration settings]'
    '-q[Quiet mode]'
    '-c[Use additional configuration file]:cfg.xml:_files'
    '-l[The language to use for user information]:lang'
    '--nocs[Disable complex script features]'
    '-r[Relaxed/less strict validation]'
    '--dpi[Target resolution in dots per inch]:dpi'
    '-s[For area tree XML, down to block areas only]'
    '-v[Run in verbose mode]'
    '-o[PDF owner password for encryption]:password'
    '-u[PDF user password for encryption]:password'
    '--noprint[Encrypt PDF without printing permission]'
    '--nocopy[Encrypt PDF without copy content permission]'
    '--noedit[Encrypt PDF without edit content permission]'
    '--noannotations[Encrypt PDF without edit annotation permission]'
    '--nofillinforms[Encrypt PDF without fill in forms permission]'
    '--noaccesscontent[Encrypt PDF without extract text and graphics permission]'
    '--noassembledoc[Encrypt PDF without assemble document permission]'
    '--noprinthq[Encrypt PDF without print high quality permission]'
    '-a[Enable accessibility features (Tagged PDF etc)]'
    '--pdfprofile[Generate PDF with specified profile]:profile'
    '--conserve[Enable memory-conservation policy]'
    '--cache[Specify a path for the font cache file]:path:_files'
    '--flush[Flush the current font cache file]'
    '--fo[XSL-FO input file]:infile:_files'
    '--xml[XML input file, must be used with -xsl]:infile:_files'
    '--atin[Area tree input file]:infile:_files'
    '--ifin[Intermediate format input file]:infile:_files'
    '--imagein[Image input file]:infile:_files'
    '--xsl[XSLT stylesheet]:stylesheet:_files'
    '--param[Set a parameter for the XSLT stylesheet]:name value'
    '--catalog[Use catalog resolver for input XML and XSLT files]'
    '--pdf[Render input as PDF]:outfile:_files'
    '--awt[Display input on screen]'
    '--rtf[Render input as RTF]:outfile:_files'
    '--pcl[Render input as PCL]:outfile:_files'
    '--ps[Render input as PostScript]:outfile:_files'
    '--afp[Render input as AFP]:outfile:_files'
    '--tiff[Render input as TIFF]:outfile:_files'
    '--png[Render input as PNG]:outfile:_files'
    '--txt[Render input as plain text]:outfile:_files'
    '--at[Render as area tree XML]:outfile:_files'
    '--if[Render as intermediate format XML]:outfile:_files'
    '--print[Render and send to the printer]'
    '--svg[Render as SVG slides]:outfile:_files'
    '--foout[Only XSL transform input]:outfile:_files'
    '*:filename:_files'
)
_arguments -s $arguments
