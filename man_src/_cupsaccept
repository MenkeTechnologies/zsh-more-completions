#compdef cupsaccept

local arguments

arguments=(
    '-E[Force encryption when connecting to the server]'
    '-U[Set the username for connecting to the server]:username:_users'
    '-h[Choose an alternate server]:hostname\:port:_hosts'
    '-r[Set the reason string for a printer that is rejecting jobs]:reason'
    '*:filename:_files'
)
_arguments -s $arguments
