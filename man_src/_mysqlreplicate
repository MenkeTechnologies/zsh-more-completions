#compdef mysqlreplicate

local arguments

arguments=(
    '--help[Display help and exit]'
    '--master[Connection information for the master server]:master'
    '--master-log-file[Master log file to start replication from]:file'
    '--master-log-pos[Master log file position to start replication from]:position'
    {-p,--pedantic}'[Require storage engines to be the same on master and slave]'
    '--rpl-user[Replication user and password]:user:password'
    '--slave[Connection information for the slave server]:slave'
    '--start-from-beginning[Start replication from the beginning of the master log]'
    {-b,--test-db}'[Test replication using the specified database]:database'
    {-v,--verbose}'[Verbose output]'
    '--version[Display version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
