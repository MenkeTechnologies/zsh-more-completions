#compdef wolfram
# Documentation: https://man.archlinux.org/search?q=wolfram
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--initfile[Execute the commands in the initialization file during startup]:file:_files'
    '--mathlink[Communicate via MathLink only]'
    '--noinit[Do not read any initialization files]'
    '*:filename:_files'
)
_arguments -s $arguments
