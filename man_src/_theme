#compdef theme

local arguments

arguments=(
    '-d[set the document root]:root:_directories'
    '-E[expand body and toc in the header section]'
    '-f[forcibly overwrite existing html files]'
    '-o[write the output to filename]:filename:_files'
    '-p[set the pagename to path]:path'
    '-t[use filename as the template file]:filename:_files'
    '*:filename:_files'
)
_arguments -s $arguments
