#compdef kdcsetup
# Documentation: https://man.archlinux.org/search?q=kdcsetup
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-v[Control the amount of output generated]:verbosity'
    '-a[Name of a directory administrator]:admin'
    '-p[The password for the admin]:password'
    '*:filename:_files'
)
_arguments -s $arguments
