#compdef fpaste

local arguments

arguments=(
    '--version[Show program version number and exit]'
    '(- * :)'{-h,--help}'[Show help message and exit]'
    {-t,--title}'[Title for paste; default is UNTITLED]:title'
    {-d,--password}'[Password for paste]:password'
    '-l[Language of content for syntax highlighting]:LANGUAGE'
    '-x[Time before paste is removed in seconds]:EXPIRES'
    {-U,--URL}'[URL of fpaste server]:URL'
    {-P,--private}'[Make paste private]:option:(yes no)'
    {-i,--clipin}'[Read paste text from current X clipboard selection]'
    {-o,--clipout}'[Save returned paste URL to all clipboards]'
    '--input-selection[Specify which X clipboard to use]:CLIPBOARD'
    '--fullpath[Use pathname instead of basename for file descriptions]'
    '--pasteself[Paste this script itself]'
    '--sysinfo[Paste system information]'
    '--printonly[Print paste, but do not send]'
    '*:filename:_files'
)
_arguments -s $arguments
