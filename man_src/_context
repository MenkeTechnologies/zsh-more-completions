#compdef context

local arguments

arguments=(
    '--run[Process one or more files (default action)]'
    '--make[Create context formats]'
    '--ctx[Use ctx file for process management specification]:name'
    '--noctx[Ignore ctx directives and flags]'
    '--interface[Use specified user interface]:interface'
    '--autopdf[Close pdf file in viewer and start pdf viewer afterwards]'
    '--purge[Purge files after a run]'
    '--purgeall[Purge all files after a run]'
    '--usemodule[Load the given module or style]:list'
    '--environment[Load the given environment file first]:list'
    '--mode[Enable given modes for conditional processing]:list'
    '--path[Also consult the given paths when files are looked for]:list'
    '--arguments[Set variables that can be consulted during a run]:list'
    '--randomseed[Set the random seed]:number'
    '--result[Rename the resulting output to the given name]:name'
    '--trackers[Set tracker variables]:list'
    '--directives[Set directive variables]:list'
    '--silent[Disable log categories]:list'
    '--noconsole[Disable logging to the console]'
    '--purgeresult[Purge result file before run]'
    '--forcexml[Force XML stub]'
    '--forcecld[Force CLD (context lua document) stub]'
    '--forcelua[Force Lua stub]'
    '--forcemp[Force MP stub]'
    '--arrange[Run extra imposition pass]'
    '--noarrange[Ignore imposition specifications in the style]'
    '--jit[Use LuaJITTeX with JIT turned off]'
    '--jiton[Use LuaJITTeX with JIT turned on]'
    '--once[Only run once, no multipass data file is produced]'
    '--runs[Process at most this many times]:count'
    '--forcedruns[Process this many times]:count'
    '--batchmode[Run without stopping and do not show messages on the console]'
    '--nonstopmode[Run without stopping]'
    '--synctex[Run with synctex enabled]:value'
    '--syncttx[Shortcut for --synctex=context]'
    '--nodates[Omit runtime dates in pdf file]'
    '--nocompression[Forcefully turn off compression in the backend]'
    '--trailerid[Alternative trailer id]'
    '--generate[Generate file database]'
    '--paranoid[Do not descend to parent directories]'
    '--version[Report installed context version]'
    '--global[Assume given file present elsewhere]'
    '--nofile[Use dummy file as jobname]'
    '--touch[Update context version number]'
    '--nostatistics[Omit runtime statistics at the end of the run]'
    '--update[Update context from website]'
    '--profile[Profile job]'
    '--timing[Generate timing and statistics overview]'
    '--keeptuc[Keep previous tuc files]'
    '--keeplog[Keep previous log files]'
    '--extra[Process extra files]:name'
    '--extras[Show extras]'
    '--pdftex[Process file with texexec using pdftex]'
    '--xetex[Process file with texexec using xetex]'
    '--mkii[Process file with texexec]'
    '--pipe[Do not check for file and enter scroll mode]'
    '--sandbox[Process file in a limited environment]'
    '*:filename:_files'
)
_arguments -s $arguments
