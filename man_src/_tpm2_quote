#compdef tpm2_quote

local arguments

arguments=(
    {-c,--key-context}'[context object for the quote signing key]:object:_files'
    {-p,--auth}'[authorization value for the signing key]:auth'
    {-l,--pcr-list}'[the list of PCR banks and selected PCR ids]:pcr_list'
    {-m,--message}'[message output file with the quote data]:file:_files'
    {-s,--signature}'[signature output file]:file:_files'
    {-f,--format}'[format selection for signature output]:format'
    {-o,--pcr}'[output file for the PCR values]:file:_files'
    {-q,--qualification}'[data to qualify the quote]:hex_string_or_path'
    {-g,--hash-algorithm}'[hash algorithm for the quote]:algorithm'
    '--scheme[signing scheme]:algorithm'
    '--cphash[file path to record command parameter hash]:file:_files'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    {-V,--verbose}'[increase verbosity of tool output]'
    {-Q,--quiet}'[suppress informational output]'
    {-Z,--enable-errata}'[enable errata fixups]'
    {-R,--autoflush}'[autoflush objects created by the command]'
    '*:filename:_files'
)
_arguments -s $arguments
