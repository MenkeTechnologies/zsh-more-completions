#compdef klogconsole
# Documentation: https://man.archlinux.org/search?q=klogconsole
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-l[Set the console log level]:level'
    '-r[Set the virtual console used by the kernel for messages]:console'
    '*:filename:_files'
)
_arguments -s $arguments
