#compdef winedbg-stable

local arguments

arguments=(
    '--command[Execute the command string as if it was keyed on winedbg command line]:string'
    '--file[Execute the list of commands contained in file]:filename:_files'
    '--no-start[Do not automatically start gdb]'
    '--port[Start the gdb server on the given port]:port'
    '--with-xterm[Run gdb in its own xterm]'
    '--gdb[Use winedbg as a proxy for gdb]'
    '--auto[Auto mode for AeDebug registry entry]'
    '--minidump[Generate a minidump instead of printing info]'
    '*:filename:_files'
)
_arguments -s $arguments
