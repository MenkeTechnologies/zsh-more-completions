#compdef convertgls2bib

local arguments

arguments=(
    {--help,-h}'[Display help message and exit]'
    {--version,-v}'[Display version information and exit]'
    '--silent[Suppress all messages except for errors]'
    '--verbose[Display messages]'
    '--debug[Display debugging messages]'
    '--texenc[Set the character encoding for input .tex files]:name'
    '--bibenc[Set the character encoding for output .bib files]:name'
    '--ignore-sort[Ignore the sort field]'
    '--no-ignore-sort[Do not ignore the sort field]'
    '--ignore-type[Omit the type field]'
    '--no-ignore-type[Do not omit the type field]'
    {--split-on-type,-t}'[Split entries into separate files according to the type field]'
    '--no-split-on-type[Do not split entries by type field]'
    '--ignore-category[Omit the category field]'
    '--no-ignore-category[Do not omit the category field]'
    '--split-on-category[Split entries into separate files according to the category field]'
    '--no-split-on-category[Do not split entries by category field]'
    {--ignore-fields,-f}'[Ignore all the fields in the comma-separated list]:fields'
    '--overwrite[Overwrite existing .bib files]'
    '--no-overwrite[Do not overwrite existing .bib files]'
    {--index-conversion,-i}'[Use @index instead of @entry for entries without descriptions]'
    '--no-index-conversion[Do not use @index instead of @entry]'
    '--absorb-see[Absorb glssee and glsxtrindexseealso into the description]'
    '--no-absorb-see[Do not absorb glssee into the description]'
    {--preamble-only,-p}'[Only parse the document preamble]'
    '--no-preamble-only[Parse the entire document]'
    {--space-sub,-s}'[Substitute spaces in labels with the specified value]:value'
    '*:filename:_files'
)
_arguments -s $arguments
