#compdef siggen
# Documentation: https://man.archlinux.org/search?q=siggen
# Reference accessed: 2026-05-16

# Updated with fixes for empty descriptions

local arguments

arguments=(
    {-t,--terse}'[Terse output]'
    {-h,--hexadecimal}'[Hexadecimal output]'
    {-a,--all}'[Compute all hash types]'
    {-C,--CRC32}'[Compute CRC32 hash]'
    {-M,--MD5}'[Compute MD5 hash]'
    {-S,--SHA}'[Compute SHA hash]'
    {-H,--HAVAL}'[Compute HAVAL hash]'
    '*:filename:_files'
)
_arguments -s $arguments
