#compdef compiz-boxmenu-dlist
# Documentation: https://man.archlinux.org/search?q=compiz-boxmenu-dlist
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-h[Show help options]'
    {-i,--images}'[Use images in the document list]'
    {-c,--command}'[Use specified command instead of xdg-open to open recent documents]:command'
    {-a,--age}'[Limit documents to specified number of days]:days'
    '--limit[Display up to specified number of items]:limit'
    {-s,--sort-type}'[Sort items according to sort type]:sort type'
    '*:filename:_files'
)
_arguments -s $arguments
