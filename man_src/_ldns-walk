#compdef ldns-walk

local arguments

arguments=(
    '-4[Use only IPv4]'
    '-6[Use only IPv6]'
    '-f[Do a full zone walk; by default only show names and types of NSEC records]'
    '-s[Start the walk with this owner name]:name'
    '-v[Verbosity level (1-5)]:verbosity'
    '*:filename:_files'
)
_arguments -s $arguments
