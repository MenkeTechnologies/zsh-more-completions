#compdef jack_netsource

local arguments

arguments=(
    '-H[Host name of the slave JACK]:host:_hosts'
    '-o[Number of audio playback channels]:channels'
    '-i[Number of audio capture channels]:channels'
    '-O[Number of MIDI playback channels]:channels'
    '-I[Number of MIDI capture channels]:channels'
    '-n[Network latency in JACK periods]:periods'
    '-p[UDP port that the slave is listening on]:port'
    '-r[UDP port that we are listening on]:port'
    '-B[Reply port for use in NAT environments]:port'
    '-b[Set transport to use 16bit or 8bit]:bitdepth'
    '-c[Use CELT encoding with specified bytes per period and channel]:bytes'
    '-m[Assume this MTU for the link]:mtu'
    '-R[Redundancy: send out packets N times]:N'
    '-e[Skip host-to-network endianness conversion]'
    '-N[Report a different client name to JACK]:name'
    {-s,--server}'[Connect to the JACK server named servername]:servername'
    '(- * :)'{-h,--help}'[Display help/usage message]'
    {-v,--version}'[Display version]'
    '*:filename:_files'
)
_arguments -s $arguments
