#compdef fonttosfnt
# Documentation: https://man.archlinux.org/search?q=fonttosfnt
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-v[Be verbose]'
    '-c[Do not crop glyphs]'
    '-b[Write byte-aligned glyph data]'
    '-r[Do not reencode fonts]'
    '-g[Set the type of scalable glyphs to write]:n'
    '-m[Set the type of scalable metrics to write]:n'
    '*:filename:_files'
)
_arguments -s $arguments
