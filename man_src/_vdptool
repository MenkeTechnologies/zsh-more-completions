#compdef vdptool

local arguments

arguments=(
    '-i[Specify the network interface to which the command applies]:ifname'
    '-V[Specify the VDP tlv identifier to be set or queried]:tlvid'
    '-n[Use neighbor option for commands which can use it]'
    '-c[Specify additional parameters for TLV queries and association commands]:params'
    '-r[Show raw client interface messages]'
    '-R[Show only raw client interface messages]'
    '-W[Wait for the bridge response message]'
    '-h[Show usage information]'
    '-v[Show version information]'
    '-t[Get VSI information for the specified interface]'
    '-T[Set VSI information for the specified interface]'
    '-p[Display the process identifier of the running lldpad process]'
    '-q[Exit from interactive mode]'
    '*:filename:_files'
)
_arguments -s $arguments
