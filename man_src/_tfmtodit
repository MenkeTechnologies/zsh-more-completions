#compdef tfmtodit
# Documentation: https://man.archlinux.org/search?q=tfmtodit
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-v[print the version number]'
    '-s[the font is special]'
    '-k[set the skewchar of this font at position n]:n'
    '-g[read groff font file]:file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
