#compdef mytop

local arguments

arguments=(
    {-u,--user}'[MySQL username]:user'
    {-p,--pass,--password}'[MySQL password]:password'
    {-h,--host}'[MySQL hostname]:host:_hosts'
    {-P,--port}'[MySQL port number]:port'
    {-s,--delay}'[Delay between screen updates in seconds]:seconds'
    {-d,--db,--database}'[Database to monitor]:database'
    {-b,--batch,--batchmode}'[Batch mode - produce output suitable for piping]'
    {-S,--socket}'[Path to MySQL socket]:socket:_files'
    '--header[Show column headers]'
    '--noheader[Do not show column headers]'
    '--color[Use ANSI colors]'
    '--nocolor[Do not use ANSI colors]'
    {-i,--idle}'[Show idle connections]'
    '--noidle[Do not show idle connections]'
    '--prompt[Prompt for login password]'
    '--noprompt[Do not prompt for password]'
    '--resolve[Resolve IP addresses to hostnames]'
    '*:filename:_files'
)
_arguments -s $arguments
