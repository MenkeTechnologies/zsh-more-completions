#compdef meinproc5
# Documentation: https://man.archlinux.org/search?q=meinproc5
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-h,--help}'[Display help and exit]'
    {-v,--version}'[Display version information and exit]'
    '--cache[Create a cache file for the document]:file:_files'
    '--check[Check the document for validity]'
    {-o,--output}'[Write output to file]:file:_files'
    '--stdout[Output the result to stdout]'
    '--stylesheet[Specify a custom XSL stylesheet]:xsl:_files'
    '--srcdir[Set the source directory]:dir:_directories'
    '--param[Set XSLT parameters]:value'
    '*:filename:_files'
)
_arguments -s $arguments
