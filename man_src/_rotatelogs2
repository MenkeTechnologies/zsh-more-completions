# Autogenerated from man page
# Updated with latest rotatelogs options

local arguments

arguments=(
    '-l[cause the use of local time rather than GMT as the base for the interval]'
    '-L[cause a hard link to be made from the current logfile to the specified link name]:linkname:_files'
    '-p[execute the specified program every time a new log file is opened]:program:_files'
    '-f[cause the logfile to be opened immediately, as soon as rotatelogs starts]'
    '-t[cause the logfile to be truncated instead of rotated]'
    '-v[produce verbose output on STDERR]'
    '-e[echo logs through to stdout]'
    '-c[create log file for each interval, even if empty]'
    '-n[use a circular list of filenames without timestamps]:number-of-files'
    '*:filename:_files'
)
_arguments -s $arguments
