#compdef waitpid

local arguments

arguments=(
    {-v,--verbose}'[Be verbose]'
    {-t,--timeout}'[Maximum time to wait in seconds]:seconds'
    {-e,--exited}'[Wait for processes that are already exited]'
    {-c,--count}'[Number of processes to wait for]:count'
    {-h,--help}'[Display help]'
    {-V,--version}'[Display version]'
    '*:pid:'
)
_arguments -s $arguments
