#compdef jack_load

local arguments

arguments=(
    {-i,--init}'[Initialization string passed to the in-process client]:init_string'
    {-s,--server}'[Name of JACK server to connect to]:servername'
    {-w,--wait}'[Wait for a signal and then unload the client]'
    '*:filename:_files'
)
_arguments -s $arguments
