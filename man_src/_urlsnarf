#compdef urlsnarf
# Documentation: https://man.archlinux.org/search?q=urlsnarf
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-n[Do not resolve IP addresses to hostnames]'
    '-i[Specify the interface to listen on]:interface'
    '-p[Process packets from the specified PCAP capture file]:pcapfile:_files'
    '-v[Invert the sense of matching, to select non-matching URLs]'
    '*:filename:_files'
)
_arguments -s $arguments
