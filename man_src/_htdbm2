#compdef htdbm htdbm2

local arguments

arguments=(
    '-b[Use batch mode; read password from command line]'
    '-i[Read the password from stdin without verification]'
    '-c[Create the password database file]'
    '-n[Display the results on standard output rather than updating a database]'
    '-m[Use MD5 encryption for passwords]'
    '-B[Use bcrypt encryption for passwords]'
    '-C[Set the computing time used for the bcrypt algorithm]:cost'
    '-d[Use crypt() encryption for passwords]'
    '-s[Use SHA encryption for passwords]'
    '-p[Use plaintext passwords]'
    '-l[Print each of the usernames and comments from the database on stdout]'
    '-v[Verify the username and password]'
    '-x[Delete user]'
    '-t[Interpret the final parameter as a comment]'
    '*:filename:_files'
)
_arguments -s $arguments
