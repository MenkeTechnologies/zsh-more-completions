#compdef asysocksproxy

# Updated with latest asysocks proxy options

local arguments

arguments=(
    {-h,--help}'[Show help message and exit]'
    '--listen-ip[Listen IP address]:ip'
    '--listen-port[Listen port]:port'
    '--cert[SSL certificate file]:file:_files'
    '--key[SSL key file]:file:_files'
    '--client-timeout[How much time to wait for the client to finish]:timeout'
    '--buffer-size[Proxy buffer size]:size'
    {-m,--monitor}'[Monitor mode]'
    {-v,--verbose}'[Verbosity]'
    {-s,--silent}'[Do not print banner]'
    '*:filename:_files'
)
_arguments -s $arguments
