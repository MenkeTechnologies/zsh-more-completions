#compdef tabbed

local arguments

arguments=(
    '-c[close tabbed when the last tab is closed]'
    '-d[detach from the terminal and print XID to stdout]'
    '-f[fill up tabbed by spawning command when the last tab is closed]'
    '-h[print usage information]'
    '-g[define the X11 geometry string]:geometry'
    '-n[set the WM_CLASS attribute to name]:name'
    '-p[set the position of where to start a new tab]'
    '-r[replace the narg-th argument in command with the window id]:narg'
    '-s[disable automatic spawning of the command]'
    '-t[define the selected background color]:color'
    '-T[define the selected foreground color]:color'
    '-u[define the normal background color]:color'
    '-U[define the normal foreground color]:color'
    '-v[print version information to stderr, then exit]'
    '*:filename:_files'
)
_arguments -s $arguments
