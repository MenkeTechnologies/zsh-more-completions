#compdef tss2_decrypt

local arguments

arguments=(
    {-p,--keyPath}'[identifies the decryption key]:path'
    {-i,--cipherText}'[the JSON-encoded ciphertext]:file:_files'
    {-f,--force}'[force overwriting the output file]'
    {-o,--plainText}'[returns the decrypted data]:file:_files'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
