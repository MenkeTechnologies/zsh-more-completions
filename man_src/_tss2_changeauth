#compdef tss2_changeauth
# Documentation: https://man.archlinux.org/search?q=tss2_changeauth
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-a,--authValue}'[the new UTF-8 password]:password'
    {-p,--entityPath}'[path identifying the entity to modify]:path'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
