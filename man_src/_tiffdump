#compdef tiffdump
# Documentation: https://man.archlinux.org/search?q=tiffdump
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-h[force numeric data to be printed in hexadecimal]'
    '-m[change the number of indirect data items that are printed]:items'
    '-o[dump the contents of the IFD at the specified offset]:offset'
    '*:filename:_files'
)
_arguments -s $arguments
