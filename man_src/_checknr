#compdef checknr
# Documentation: https://man.archlinux.org/search?q=checknr
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-a[Add additional pairs of macros to the list of known macros]:macro pairs'
    '-c[Define commands which would otherwise be complained about as undefined]:commands'
    '-f[Ignore font changes]'
    '-s[Ignore size changes]'
    '*:filename:_files'
)
_arguments -s $arguments
