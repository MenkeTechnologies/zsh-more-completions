#compdef tpm2_commit

local arguments

arguments=(
    '--basepoint-y[specify the y coordinate of the basepoint]:file:_files'
    '--eccpoint-P[specify a point on the curve used by sign handle]:file:_files'
    '--eccpoint-K[output ECC point K]:file:_files'
    '--eccpoint-L[output ECC point L]:file:_files'
    {-u,--public}'[output ECC point E]:file:_files'
    {-t,--counter}'[file path to save the least-significant 16 bits of commit count]:file:_files'
    {-p,--auth}'[authorization value for the created object]:auth'
    {-c,--context}'[context object for the signing key]:file:_files'
    '--cphash[file path to record command parameter hash]:file:_files'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    {-V,--verbose}'[increase verbosity of tool output]'
    {-Q,--quiet}'[suppress informational output]'
    {-Z,--enable-errata}'[enable errata fixups]'
    {-R,--autoflush}'[autoflush objects created by the command]'
    '*:filename:_files'
)
_arguments -s $arguments
