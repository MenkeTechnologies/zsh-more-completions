#compdef mysqlprocgrep

local arguments

arguments=(
    '--help[Display help and exit]'
    '--age[Filter processes by age]:age'
    '--format[Output format]:format:(grid csv tab vertical)'
    '--kill-connection[Kill matching connections]'
    '--kill-query[Kill matching queries]'
    '--match-command[Match processes by command type]:pattern'
    '--match-db[Match processes by database]:pattern'
    '--match-host[Match processes by host]:pattern'
    '--match-info[Match processes by info string]:pattern'
    '--match-state[Match processes by state]:pattern'
    '--match-time[Match processes by time]:time'
    '--match-user[Match processes by user]:pattern'
    '--print[Print matching processes]'
    {-G,--basic-regexp,--regexp}'[Use regular expression matching]'
    {-Q,--sql,--print-sql}'[Print the SQL statement rather than executing it]'
    '--sql-body[Print the body of the generated SQL]'
    '--server[Connection information for the server]:server'
    {-v,--verbose}'[Verbose output]'
    '--version[Display version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
