#compdef eepget

local arguments

arguments=(
    '-c[Continue a partial download]'
    '-e[Set the etag header value]:etag'
    '-h[Set a custom header value]:value'
    '-l[Set the line length for output]:lineLen'
    '-m[Set the mark size for progress display]:markSize'
    '-n[Set the number of retries]:retries'
    '-o[Write output to file]:file:_files'
    '-p[Use the specified proxy]:proxy_host\:port'
    '-t[Set the timeout in seconds]:seconds'
    '-u[Set the username for authentication]:username'
    '-x[Set the password for authentication]:password'
    '*:filename:_files'
)
_arguments -s $arguments
