#compdef tpm2_getmanufec

local arguments

arguments=(
    '-e[current endorsement password]:password'
    '-o[current owner password]:password'
    '-P[EK password when created]:password'
    '-H[handle used to make EK persistent]:handle'
    '-g[algorithm type of EK]:algorithm'
    '-f[file to save the public portion of EK]:file:_files'
    '-N[get EK public without making it persistent]'
    '-O[file containing EK from offline platform]:file:_files'
    '-E[file to save the endorsement credentials]:file:_files'
    '-U[allow connecting with SSL_NO_VERIFY]'
    '-S[input session handle]:session_handle'
    '-h[display help information]'
    '-v[display version, supported tctis and exit]'
    '-V[increase verbosity of tool output]'
    '-Q[suppress informational output]'
    '-Z[enable errata fixups]'
    '-T[select the TCTI used for communication]:tcti'
    '*:filename:_files'
)
_arguments -s $arguments
