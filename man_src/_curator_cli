#compdef curator_cli

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Show program usage and exit]'
    {-v,--version}'[Show program version number and exit]'
    '--host[Elasticsearch host]:host:_hosts'
    '--url_prefix[Elasticsearch HTTP url prefix]:prefix'
    '--port[Elasticsearch port]:port'
    '--use_ssl[Connect to Elasticsearch through SSL]'
    '--certificate[Path to certificate for SSL validation]:certificate:_files'
    '--client-cert[Path to SSL certificate for client auth]:certificate:_files'
    '--ssl-no-validate[Do not validate SSL certificate]'
    '--http_auth[Use Basic Authentication]:user\:pass'
    '--timeout[Connection timeout in seconds]:timeout'
    '--master-only[Verify that the node is the elected master before continuing]'
    '--dry-run[Do not perform any changes to the Elasticsearch indices]'
    '--loglevel[Log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)'
    '--logfile[Log file]:file:_files'
    '--logformat[Log output format]:format:(default logstash)'
    '*:filename:_files'
)
_arguments -s $arguments
