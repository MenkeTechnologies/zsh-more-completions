#compdef chacl

local arguments

arguments=(
    '-b[Change both file access ACL and default ACL]'
    '-d[Set only the default ACL of a directory]'
    '-R[Remove the file access ACL only]'
    '-D[Remove directory default ACL only]'
    '-B[Remove all ACLs]'
    '-l[List the access ACL and possibly the default ACL associated with the specified files]'
    '-r[Set the access ACL recursively for each subtree rooted at pathnames]'
    '*:filename:_files'
)
_arguments -s $arguments
