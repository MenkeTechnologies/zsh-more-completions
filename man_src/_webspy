#compdef webspy
# Documentation: https://man.archlinux.org/search?q=webspy
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-i[Specify the interface to listen on]:interface'
    '-p[Process packets from the specified PCAP capture file]:pcapfile:_files'
    '*:filename:_files'
)
_arguments -s $arguments
