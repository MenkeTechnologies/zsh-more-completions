#compdef mariadb-dumpslow mysqldumpslow

local arguments

arguments=(
    '-a[Do not abstract all numbers to N and strings to S]'
    '-n[Abstract numbers with at least N digits within names]:N'
    '--debug[Write debugging information]'
    '-g[Only consider statements that match the specified grep pattern]:pattern'
    '-h[Hostname for the slow log file name]:hostname'
    '-i[Name of the server instance]:name'
    '-l[Do not subtract lock time from total time]'
    '-r[Reverse the sort order]'
    '-s[Sort by the given type]:sort_type:(al ar at c l r t)'
    '-t[Display only the first num queries]:num'
    '--verbose[Verbose mode]'
    '*:filename:_files'
)
_arguments -s $arguments
