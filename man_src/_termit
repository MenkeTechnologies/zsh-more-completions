#compdef termit

local arguments

arguments=(
    {-h,--help}'[display help information]'
    {-v,--version}'[display version information]'
    {-e,--execute}'[execute command]:cmd'
    {-i,--init}'[use specified init file]:file:_files'
    {-n,--name}'[set window name]:name'
    {-c,--class}'[set window class]:class'
    {-r,--role}'[set window role]:role'
    {-T,--title}'[set window title]:title'
    '*:filename:_files'
)
_arguments -s $arguments
