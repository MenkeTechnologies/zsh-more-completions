#compdef makedepend

local arguments

arguments=(
    '-D[Define a symbol in the preprocessor]:name=value'
    '-I[Include directory for header files]:includedir:_directories'
    '-Y[Replace all standard include directories with the specified one]:includedir:_directories'
    '-a[Append the dependencies to the end of the file instead of replacing them]'
    '-f[Specify an alternate makefile]:makefile:_files'
    '--include[Process file as input before processing regular input]:file:_files'
    '-o[Object file suffix]:suffix'
    '-p[Object file prefix]:prefix'
    '-s[Starting string delimiter]:string'
    '-w[Line width]:width'
    '-v[Verbose operation]'
    '-m[Warn about multiple inclusion]'
    '*:filename:_files'
)
_arguments -s $arguments
