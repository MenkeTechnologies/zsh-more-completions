#compdef gtk-window-decorator
# Documentation: https://man.archlinux.org/search?q=gtk-window-decorator
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--minimal[Use minimal decorations]'
    '--replace[Replace existing window manager]'
    '--help[Display help]'
    '*:filename:_files'
)
_arguments -s $arguments
