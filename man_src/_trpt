#compdef trpt

local arguments

arguments=(
    '-a[print the values of the source and destination addresses]'
    '-f[follow the trace as it occurs, waiting for additional records]'
    '-j[list the protocol control block addresses for which there are saved records]'
    '-p[show only trace records associated with the given PCB address]:address'
    '-s[print a detailed description of the packet sequencing information]'
    '-t[print the values for all timers at each point]'
    '*:filename:_files'
)
_arguments -s $arguments
