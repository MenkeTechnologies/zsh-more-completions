#compdef tracker3-tag

local arguments

arguments=(
    {-t,--list}'[list all tags]'
    {-s,--show-files}'[show the files associated with each tag]'
    {-a,--add}'[add a tag with the specified name]:tag'
    {-d,--delete}'[delete a tag with the specified name]:tag'
    {-e,--description}'[provide a description when using --add]:description'
    {-l,--limit}'[limit search to N results]:n'
    {-o,--offset}'[offset the search results by N]:n'
    {-n,--and-operator}'[use AND operator for search terms instead of OR]'
    '*:filename:_files'
)
_arguments -s $arguments
