#compdef tpm2-abrmd

local arguments

arguments=(
    {-t,--tcti}'[provide TCTI configuration string]:tcti'
    {-o,--allow-root}'[allow daemon to run as root]'
    {-m,--max-connections}'[set upper bound on concurrent client connections]:connections'
    {-f,--flush-all}'[flush all objects and sessions when daemon is started]'
    {-l,--logger}'[direct logging output to named target]:target'
    {-e,--max-sessions}'[set upper bound on sessions per client connection]:sessions'
    {-r,--max-transients}'[set upper bound on transient objects per client connection]:transients'
    {-n,--dbus-name}'[claim the given name on dbus]:name'
    {-g,--prng-seed-file}'[read seed for PRNG from the provided file]:file:_files'
    {-s,--session}'[connect daemon to the session dbus]'
    {-v,--version}'[display version string]'
    '*:filename:_files'
)
_arguments -s $arguments
