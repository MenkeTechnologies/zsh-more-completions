#compdef irb2.1

local arguments

arguments=(
    '--version[Print the version of irb]'
    '-E[Set encoding]:encoding'
    '--encoding[Same as ruby -E, set encoding]:encoding'
    '-I[Specify $LOAD_PATH directory]:path:_directories'
    '-U[Same as ruby -U]'
    '-d[Same as ruby -d; sets $DEBUG to true]'
    '-f[Suppress reading of ~/.irbrc]'
    '-h[Print a summary of the options]'
    '--help[Print a summary of the options]'
    '-m[Bc mode (load mathn, fraction or matrix are available)]'
    '-r[Same as ruby -r; causes irb to load the library using require]:library'
    '--inspect[Use inspect for output (default except for bc mode)]'
    '--noinspect[Do not use inspect for output]'
    '--readline[Use Readline extension module]'
    '--noreadline[Do not use Readline extension module]'
    '--prompt[Switch prompt mode]:mode'
    '--prompt-mode[Switch prompt mode]:mode'
    '--inf-ruby-mode[Use prompt appropriate for inf-ruby-mode on emacs]'
    '--simple-prompt[Make prompts simple]'
    '--noprompt[No prompt mode]'
    '--tracer[Display trace for each execution of commands]'
    '--back-trace-limit[Display backtrace top n and tail n]:n'
    '--irb_debug[Set internal debug level]:n'
    '*:filename:_files'
)
_arguments -s $arguments
