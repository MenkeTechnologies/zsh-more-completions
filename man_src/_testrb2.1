#compdef testrb2

local arguments

arguments=(
    {-r,--runner}'[use the given runner]:runner:(tk console gtk fox)'
    {-a,--add}'[add to the list of things to run]:torun:_files'
    {-p,--pattern}'[match files to collect against pattern]:pattern'
    {-n,--name}'[run tests matching name]:name'
    {-t,--testcase}'[run tests in TestCases matching testcase]:testcase'
    {-v,--verbose}'[set the output level]:level'
    '(- * :)'{-h,--help}'[display help]'
    '*:filename:_files'
)
_arguments -s $arguments
