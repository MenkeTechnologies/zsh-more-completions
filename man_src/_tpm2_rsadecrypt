#compdef tpm2_rsadecrypt
# Documentation: https://man.archlinux.org/search?q=tpm2_rsadecrypt
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-c,--key-context}'[context of the key for decryption]:object:_files'
    {-p,--auth}'[authorization value for the key]:auth'
    {-o,--output}'[output file for the decrypted data]:file:_files'
    {-s,--scheme}'[the padding scheme]:scheme'
    {-l,--label}'[optional label string]:label'
    '--cphash[file path to record command parameter hash]:file:_files'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    {-V,--verbose}'[increase verbosity of tool output]'
    {-Q,--quiet}'[suppress informational output]'
    {-Z,--enable-errata}'[enable errata fixups]'
    {-R,--autoflush}'[autoflush objects created by the command]'
    '*:filename:_files'
)
_arguments -s $arguments
