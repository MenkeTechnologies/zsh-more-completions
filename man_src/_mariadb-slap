#compdef mariadb-slap mysqlslap

local arguments

arguments=(
    {-\?,--help}'[Display help and exit]'
    {-a,--auto-generate-sql}'[Generate SQL statements automatically]'
    '--auto-generate-sql-add-autoincrement[Add AUTO_INCREMENT column to auto-generated tables]'
    '--auto-generate-sql-execute-number[Specify number of queries to run]:number'
    '--auto-generate-sql-guid-primary[Add GUID-based primary keys to auto-generated tables]'
    '--auto-generate-sql-load-type[Type of test load]:type:(read write key update mixed)'
    '--auto-generate-sql-secondary-indexes[Number of secondary indexes in auto-generated tables]:number'
    '--auto-generate-sql-unique-query-number[Number of unique queries for auto-generated SQL]:number'
    '--auto-generate-sql-unique-write-number[Number of unique queries for auto-generated write SQL]:number'
    '--auto-generate-sql-write-number[Number of row inserts per thread]:number'
    '--character-sets-dir[Directory for character set files]:path:_directories'
    '--commit[Number of statements to execute before committing]:number'
    {-C,--compress}'[Compress all information sent between client and server]'
    '--concurrency[Number of clients to simulate]:number'
    '--create[SQL string or file containing SQL for creating the table]:string'
    '--create-schema[Schema in which to run the tests]:schema'
    '--csv[Output results in CSV format to the given file]:file:_files'
    {-\#,--debug}'[Write debugging log]:debug_options'
    '--debug-check[Check memory and open file usage at exit]'
    '--debug-info[Print debugging information at exit]'
    '--default-auth[Default authentication client-side plugin]:name'
    '--defaults-extra-file[Read option file after the global option file]:filename:_files'
    '--defaults-file[Only read options from the given file]:filename:_files'
    '--delimiter[Delimiter to use in SQL statements]:string'
    '--detach[Detach (close and reopen) connections after N statements]:N'
    '--engine[Storage engine to use for creating the table]:engine'
    {-h,--host}'[Connect to the specified host]:host_name:_hosts'
    '--init-command[SQL command to execute at connect]:command'
    {-i,--iterations}'[Number of times to run the tests]:number'
    '--no-defaults[Do not read any option files]'
    '--no-drop[Do not drop databases after the test]'
    '--number-char-cols[Number of VARCHAR columns]:number'
    '--number-int-cols[Number of INT columns]:number'
    '--number-of-queries[Limit each client to this number of queries]:number'
    '--only-print[Print statements without executing them]'
    {-p,--password}'[Password to use for connection]:password'
    {-W,--pipe}'[Connect using a named pipe]'
    '--plugin-dir[Directory for client-side plugins]:name:_directories'
    {-P,--port}'[Port number for connection]:port_num'
    '--post-query[SQL statement to execute after the tests]:string'
    '--post-system[System command to execute after the tests]:command'
    '--pre-query[SQL statement to execute before the tests]:string'
    '--pre-system[System command to execute before the tests]:command'
    '--print-defaults[Print the program argument list and exit]'
    '--protocol[Connection protocol to use]:protocol:(TCP SOCKET PIPE MEMORY)'
    '--query[SQL string or file containing SQL to execute]:string'
    {-s,--silent}'[Print only error messages]'
    {-S,--socket}'[Socket file for connection]:path:_files'
    '--ssl[Enable SSL for connection]'
    '--ssl-verify-server-cert[Verify server certificate]'
    {-u,--user}'[User for login]:user_name'
    {-v,--verbose}'[Verbose output]'
    {-V,--version}'[Output version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
