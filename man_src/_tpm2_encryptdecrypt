#compdef tpm2_encryptdecrypt

local arguments

arguments=(
    '-k[symmetric key used for encryption/decryption]:handle'
    '-c[filename of the key context]:file:_files'
    '-P[password for parent key]:password'
    '-D[perform decryption instead of encryption]'
    '-I[path containing data for decrypt or encrypt operation]:file:_files'
    '-S[input session handle]:session_handle'
    '-h[display help information]'
    '-v[display version, supported tctis and exit]'
    '-V[increase verbosity of tool output]'
    '-Q[suppress informational output]'
    '-Z[enable errata fixups]'
    '-T[select the TCTI used for communication]:tcti'
    '*:filename:_files'
)
_arguments -s $arguments
