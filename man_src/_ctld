#compdef ctld
# Documentation: https://man.archlinux.org/search?q=ctld
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-f[Specify the name of the configuration file]:file:_files'
    '-d[Debug mode]'
    '-u[Use UCL configuration file format instead of the traditional format]'
    '*:filename:_files'
)
_arguments -s $arguments
