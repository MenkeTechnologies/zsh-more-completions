#compdef zvbi-atsc-cc

local arguments

arguments=(
    {-h,--help,--usage}'[Print a short usage message]'
    {-q,--quiet}'[Suppress all progress and error messages]'
    {-v,--verbose}'[Increase verbosity]'
    '--adapter-num[Select a different DVB device to capture the signal]:number'
    '--frontend-id[Select a different frontend on the DVB device]:number'
    '--demux-id[Select a different demultiplexer on the DVB device]:number'
    '--dvr-id[Select a different DVR interface on the DVB device]:number'
    '--ts[Decode an MPEG-2 Transport Stream on standard input instead of opening a DVB device]'
    '--channel-conf[Channel configuration file to use for tuning]:name:_files'
    {-L,--list}'[List all stations in the channel configuration file]'
    '--station[The station to tune in]:name'
    {-c,--cc}'[Print any received caption on standard output]'
    '--cc-file[Append any received caption to the specified file]:name:_files'
    '--channel[Print NTSC Closed Caption channel on standard output]:number:(1 2 3 4)'
    '--cc1-file[Filter out NTSC Closed Caption channel CC1 to file]:file:_files'
    '--cc4-file[Filter out NTSC Closed Caption channel CC4 to file]:file:_files'
    '--t1-file[Filter out NTSC Text service T1 to file]:file:_files'
    '--t4-file[Filter out NTSC Text service T4 to file]:file:_files'
    '--s1-file[Filter out DTVCC service 1 and append text to file]:file:_files'
    '--s2-file[Filter out DTVCC service 2 and append text to file]:file:_files'
    {-b,--no-webtv}'[Do not print WebTV links]'
    {-m,--timestamps}'[Prepend timestamps to caption lines]'
    {-s,--sentences}'[Print caption one sentence at a time]'
    '--format[Output format type]:type:(plain ntsc-cc)'
    {-p,--plain}'[Same as --format plain]'
    {-x,--xds}'[Print all received XDS data on standard output]'
    '--xds-file[Filter out eXtended Data Service data to file]:name:_files'
    '--filter[Apply the specified filter type]:type'
    '*:filename:_files'
)
_arguments -s $arguments
