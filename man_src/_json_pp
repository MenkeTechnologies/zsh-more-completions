#compdef json_pp
# Documentation: https://man.archlinux.org/search?q=json_pp
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-f[Read data in the given format from STDIN]:format:(json)'
    '-t[Output data in the given format to STDOUT]:format:(json dumper)'
    '--json_opt[Set options for JSON encoding/decoding]:options'
    '-v[Verbose mode]'
    '-V[Print version and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
