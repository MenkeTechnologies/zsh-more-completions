#compdef cupsenable

local arguments

arguments=(
    '-E[Force encryption of the connection to the server]'
    '-U[Use the specified username when connecting to the server]:username:_users'
    '-c[Cancel all jobs on the named destination]'
    '-h[Use the specified server and port]:server\:port:_hosts'
    '--hold[Hold remaining jobs on the named printer]'
    '-r[Set the message associated with the stopped state]:reason'
    '--release[Release pending jobs for printing]'
    '*:filename:_files'
)
_arguments -s $arguments
