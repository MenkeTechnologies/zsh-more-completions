#compdef alt-java

# Updated with latest Java (OpenJDK) options

local arguments

arguments=(
    '-d32[Run in a 32-bit environment]'
    '-d64[Run in a 64-bit environment]'
    '-server[Select the Java HotSpot Server VM]'
    '-client[Select the Java HotSpot Client VM]'
    '-cp[Specify class search path]:classpath'
    '-classpath[Specify class search path]:classpath'
    '-D-[Set a system property]:property=value'
    '-verbose:class[Display information about each loaded class]'
    '-verbose:gc[Display information about each GC event]'
    '-verbose:jni[Display information about native methods and JNI activity]'
    '-version[Display version information and exit]'
    '-showversion[Display version information and continue]'
    '(- * :)'{-h,-help,--help,-\?}'[Display help message]'
    '-jar[Execute a program encapsulated in a JAR file]:jar file:_files'
    '-ea[Enable assertions]'
    '-da[Disable assertions]'
    '-esa[Enable system assertions]'
    '-dsa[Disable system assertions]'
    '-agentlib[Load native agent library]:library'
    '-agentpath[Load native agent library by full pathname]:path:_files'
    '-javaagent[Load Java agent]:jarpath:_files'
    '-splash[Show splash screen with specified image]:imagefile:_files'
    '-X[Display help for non-standard options]'
    '-Xms[Set initial Java heap size]:size'
    '-Xmx[Set maximum Java heap size]:size'
    '-Xss[Set Java thread stack size]:size'
    '-Xmn[Set size of young generation heap]:size'
    '-Xbatch[Disable background compilation]'
    '-Xcomp[Force compilation of methods on first invocation]'
    '-Xdebug[Provided for backward compatibility]'
    '-Xint[Run in interpreted-only mode]'
    '-Xmixed[Execute all bytecode by interpreter except for hot methods]'
    '-Xnoclassgc[Disable garbage collection of classes]'
    '-Xrs[Reduce use of operating system signals by the JVM]'
    '-Xprof[Profile the running program]'
    '-Xfuture[Enable strict class-file format checks]'
    '-Xshare:auto[Use shared class data if possible]'
    '-Xshare:off[Do not attempt to use shared class data]'
    '-Xshare:on[Require using shared class data, otherwise fail]'
    '*:class or jar:_files'
)
_arguments -s $arguments
