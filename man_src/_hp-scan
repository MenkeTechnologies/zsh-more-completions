#compdef hp-scan

local arguments

arguments=(
    {-d,--device}'[Specify device URI]:device_uri'
    {-p,--printer}'[Specify a CUPS printer]:printer'
    {-i,--interactive}'[Run in interactive mode]'
    {-l,--logging}'[Set the logging level]:level:(none info error warn debug)'
    {-g,--ldebug}'[Run in debug mode]'
    '(- * :)'{-h,--help}'[Show help information]'
    {-s,--dest}'[Scan destination]:dest:(file viewer editor email pdf fax printer)'
    {-m,--mode}'[Scan mode]:mode:(gray color lineart)'
    {-r,--res,--resolution}'[Scanning resolution in dpi]:resolution'
    '--resize[Image resize percentage]:percent'
    {-c,--contrast}'[Image contrast]:contrast'
    {-b,--brightness}'[Image brightness]:brightness'
    '--adf[Use automatic document feeder]'
    '--duplex[Duplex scanning with ADF]'
    {-t,--units}'[Specify the units for area/box measurements]:units:(mm cm in px pt)'
    {-a,--area}'[Scan area coordinates (tlx,tly,brx,bry)]:coordinates'
    '--box[Scan box (tlx,tly,width,height)]:box'
    '--tlx[Top left x coordinate]:tlx'
    '--tly[Top left y coordinate]:tly'
    '--brx[Bottom right x coordinate]:brx'
    '--bry[Bottom right y coordinate]:bry'
    '--size[Paper size name]:size:(3x5 4x6 5x7 a3 a4 a5 a6 b4 b5 letter legal)'
    {-o,-f,--output}'[Output file]:file:_files'
    '--pdf[PDF viewer application]:viewer'
    {-v,--viewer}'[Image viewer application]:viewer'
    {-e,--editor}'[Image editor application]:editor'
    '--email-from[From address for email destination]:email'
    '--email-to[To address for email destination]:email'
    '--email-subject[Email subject]:subject'
    '--email-msg[Email message body]:message'
    {-x,--compression}'[Set the scanner compression mode]:mode:(none jpeg)'
    '*:filename:_files'
)
_arguments -s $arguments
