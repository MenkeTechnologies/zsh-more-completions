#compdef tor

local arguments

arguments=(
    '(- * :)'{-h,--help}'[display help information]'
    '-f[specify configuration file]:file:_files'
    '--allow-missing-torrc[allow missing torrc file]'
    '--defaults-torrc[specify defaults torrc file]:file:_files'
    '--ignore-missing-torrc[ignore missing torrc file]'
    '--hash-password[generate hash of a password]:password'
    '--list-fingerprint[list the fingerprint of the relay]'
    '--verify-config[verify the configuration file and exit]'
    '--service[run as a Windows service]'
    '--nt-service[run as an NT service]'
    '--list-torrc-options[list available torrc options]'
    '--list-deprecated-options[list deprecated torrc options]'
    '--version[display version information]'
    {--quiet,--hush}'[suppress startup messages]'
    '--keygen[generate new relay identity keys]'
    '--newpass[change passphrase on identity key]'
    '--DataDirectory[specify data directory]:directory:_directories'
    '--SigningKeyLifetime[set signing key lifetime]:duration'
    '--passphrase-fd[read passphrase from file descriptor]:fd'
    '--key-expiration[check key expiration]:purpose'
    '*:filename:_files'
)
_arguments -s $arguments
