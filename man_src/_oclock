#compdef oclock

local arguments

arguments=(
    '-fg[Choose a different color for the hands and the jewel of the clock]:color'
    '-bg[Choose a different color for the background]:color'
    '-jewel[Choose a different color for the jewel on the clock]:color'
    '-minute[Choose a different color for the minute hand of the clock]:color'
    '-hour[Choose a different color for the hour hand of the clock]:color'
    '-backing[Select an appropriate level of backing store]'
    '-geometry[Define the initial window geometry]:geometry'
    '-display[Specify the display to use]:display'
    '-bd[Choose a different color for the window border]:color'
    '-bw[Choose a different width for the window border]:width'
    '-shape[Use the Shape extension to create an oval window]'
    '-noshape[Do not reshape the window to fit the outline of the clock]'
    '-transparent[Display only the jewel, the hands, and the border]'
    '*:filename:_files'
)
_arguments -s $arguments
