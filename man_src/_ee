#compdef ee
# Documentation: https://man.archlinux.org/search?q=ee
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-i[Turn off display of information window at top of terminal]'
    '-h[Turn off highlighting of borders of windows and menus]'
    '-e[Turn off expansion of tab character to spaces]'
    '*:filename:_files'
)
_arguments -s $arguments
