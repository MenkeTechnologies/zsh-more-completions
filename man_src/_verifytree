#compdef verifytree
# Documentation: https://man.archlinux.org/search?q=verifytree
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Display a help message and quit]'
    {-a,--checkall}'[Check all packages in the repository]'
    {-t,--testopia}'[Report results to the given testopia run number]:run_number'
    '*:filename:_files'
)
_arguments -s $arguments
