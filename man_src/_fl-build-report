#compdef fl-build-report
# Documentation: https://man.archlinux.org/search?q=fl-build-report
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--version[Show program version number and exit]'
    {--help,-h}'[Show a help message and exit]'
    {--html,-H}'[Produce an HTML report]'
    {--output-directory,-o}'[Parent directory to store reports]:OUTPUT_DIR:_directories'
    {--report-directory,-r}'[Directory name to store the report]:directory:_directories'
    '*:filename:_files'
)
_arguments -s $arguments
