#compdef cache_repair

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Print help and exit]'
    {-V,--version}'[Print version information and exit]'
    {-i,--input}'[Input file or device containing binary metadata]:device or file:_files'
    {-o,--output}'[Output file or device for repaired binary metadata]:device or file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
