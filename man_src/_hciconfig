#compdef hciconfig
# Documentation: https://man.archlinux.org/search?q=hciconfig
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Gives a list of possible commands]'
    {-a,--all}'[Print features, packet type, link policy, link mode, class, and version information in addition to basic info]'
    '*:filename:_files'
)
_arguments -s $arguments
