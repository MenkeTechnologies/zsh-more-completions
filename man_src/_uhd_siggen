#compdef uhd_siggen

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Show this help message and exit]'
    {-a,--args}'[UHD device address args]:args'
    '--spec[Subdevice of UHD device where appropriate]:spec'
    {-A,--antenna}'[Select Rx Antenna where appropriate]:antenna'
    {-s,--samp-rate}'[Set sample rate (bandwidth)]:rate'
    {-g,--gain}'[Set gain in dB (default is midpoint)]:gain'
    {-f,--tx-freq}'[Set carrier frequency]:freq'
    {-x,--waveform-freq}'[Set baseband waveform frequency]:freq'
    {-y,--waveform2-freq}'[Set 2nd waveform frequency]:freq'
    '--sine[Generate a carrier modulated by a complex sine wave]'
    '--const[Generate a constant carrier]'
    '--offset[Set waveform phase offset]:offset'
    '--gaussian[Generate Gaussian random output]'
    '--uniform[Generate Uniform random output]'
    '--2tone[Generate Two Tone signal for IMD testing]'
    '--sweep[Generate a swept sine wave]'
    '--amplitude[Set output amplitude (0.0-1.0)]:amplitude'
    {-v,--verbose}'[Use verbose console output]'
    '*:filename:_files'
)
_arguments -s $arguments
