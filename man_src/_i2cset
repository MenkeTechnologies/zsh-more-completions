#compdef i2cset

local arguments

arguments=(
    '-V[Display the version and exit]'
    '-f[Force access to the device even if it is already busy]'
    '-y[Disable interactive mode]'
    '-m[Mask describing which bits of value will be actually written]:mask'
    '-r[Read back the value right after writing it and compare the result]'
    '-a[Allow using addresses between 0x00-0x02 and 0x78-0x7f]'
    '*:filename:_files'
)
_arguments -s $arguments
