#compdef lighttpd

local arguments

arguments=(
    '-f[Load configuration file]:configfile:_files'
    '-m[Use moduledir as the directory that contains modules]:moduledir:_directories'
    '-p[Print the parsed configuration file in its internal form and exit]'
    '-t[Test the configuration file for syntax errors and exit]'
    '--tt[Test the configuration file, load and initialize modules, and exit]'
    '-D[Do not daemonize (stay in foreground)]'
    '-i[Trigger daemon graceful shutdown after secs of inactivity]:secs'
    '-1[Process single (one) request on stdin socket, then exit]'
    '-v[Show version and exit]'
    '-V[Show compile-time features and exit]'
    '-h[Show a brief help message and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
