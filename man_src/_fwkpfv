#compdef fwkpfv

local arguments

arguments=(
    '--appendlog[Append output logging to /tmp/fwkpf.log]'
    '--openlog[Open log file with Console.app]'
    '--newlog[Create a new log file rather than append]'
    '--prefix[Prefix logger machine ID to each log]'
    '--publish[Do not publish FireWire unit directory keys]'
    '--single[Use a single window even if multiple loggers are present]'
    '--buffer[Set the host pseudo address space queue buffer size in bytes]:size'
    '--file[Set the log file path]:path:_files'
    '--setargs[Set the nvram boot-args on the current machine]:boot-args'
    '--setpm[Set boot-args for power management debugging]'
    '--disable[Set boot-args to disable FireWire debugging]'
    '--erase[Delete the boot-args variable from nvram]'
    '--ioff[Turn off interactive mode]'
    '--restart[Automatically restart the machine after nvram modification]'
    '--help[Display usage info for fwkpfv]'
    '*:filename:_files'
)
_arguments -s $arguments
