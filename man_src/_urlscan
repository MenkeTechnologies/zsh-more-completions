#compdef urlscan

local arguments

arguments=(
    {-g,--genconf}'[Generate ~/.config/urlscan/config.json with default options]'
    {-c,--compact}'[Display a simple list of the extracted URLs]'
    {-H,--nohelp}'[Start with header menu hidden]'
    {-d,--dedupe}'[Remove duplicated URLs from the list of URLs]'
    {-n,--no-browser}'[Disable the selection interface and print the links to standard output]'
    {-r,--run}'[Execute expression in place of opening URL with a browser]:expression'
    {-p,--pipe}'[Pipe the selected URL to the command specified by --run]'
    '*:filename:_files'
)
_arguments -s $arguments
