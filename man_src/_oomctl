#compdef oomctl
# Documentation: https://man.archlinux.org/search?q=oomctl
# Reference accessed: 2026-05-16

local arguments

arguments=(
  {-h,--help}'[show this help]'
  '--version[show package version]'
  '--no-pager[do not pipe output into a pager]'
  '*:filename:_files'
)

_arguments -s $arguments
