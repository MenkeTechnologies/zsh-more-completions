#compdef numactl

local arguments

arguments=(
    '--cpudomain[Set the given CPU scheduling policy]:domain'
    '--get[Retrieve the NUMA policy for the given thread or process id]'
    '--set[Set the NUMA policy for the given thread or process id]'
    '--memdomain[Constrain the object to the given domain]:domain'
    '--mempolicy[Set the given memory allocation policy]:policy:(default preferred bind interleave local)'
    '--pid[Operate on the given pid]:pid'
    '--tid[Operate on the given tid]:tid'
    '--hardware[Show NUMA hardware information]'
    '--show[Show NUMA policy of the current process]'
    '--interleave[Interleave memory allocation across nodes]:nodes'
    '--preferred[Prefer memory allocations from given node]:node'
    '--membind[Only allocate memory from given nodes]:nodes'
    '--cpunodebind[Only execute process on CPUs of given nodes]:nodes'
    '--physcpubind[Only execute process on given CPUs]:cpus'
    '--localalloc[Always allocate memory on the current node]'
    '*:filename:_files'
)
_arguments -s $arguments
