#compdef mkdosfs mkfs.fat

local arguments

arguments=(
    '-a[Normally, for any filesystem except very small ones, align data structures to cluster size]'
    '-A[Use Atari variation of the MS-DOS filesystem]'
    '-b[Select the location of the backup boot sector for FAT32]:sector'
    '-c[Check the device for bad blocks before creating the filesystem]'
    '-C[Create the file given as DEVICE on the command line and write the filesystem to it]:size'
    '-D[Specify the BIOS drive number to be stored in the FAT boot sector]:drive_number'
    '-f[Specify the number of file allocation tables in the filesystem]:number'
    '-F[Specify the type of file allocation tables used (12, 16 or 32 bit)]:type:(12 16 32)'
    '-h[Select the number of hidden sectors in the volume]:sectors'
    '-i[Set the volume ID of the newly created filesystem]:volume_id'
    '-I[Normally you are not allowed to use mkfs.fat on a whole disk; use this to override]:ignored'
    '-l[Read the bad blocks list from the given file]:filename:_files'
    '-m[Set the message the user receives on attempts to boot this filesystem]:message_file:_files'
    '-M[Specify the media type to be stored in the FAT boot sector]:media_type'
    '-n[Set the volume name (label) of the filesystem]:volume_name'
    '-r[Select the number of entries available in the root directory]:entries'
    '-R[Select the number of reserved sectors]:sectors'
    '-s[Specify the number of disk sectors per cluster]:sectors_per_cluster'
    '-S[Specify the number of bytes per logical sector]:bytes'
    '-v[Verbose execution]'
    '--invariant[Use constants for normally randomly generated or time based data]'
    '--help[Display option summary and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
