#compdef thunar-volman-settings

local arguments

arguments=(
    {-h,--help}'[show help options]'
    '--help-all[show all help options]'
    '--help-gtk[show GTK+ options]'
    '--class[program class as used by the window manager]:class'
    '--name[program name as used by the window manager]:name'
    '--screen[X screen to use]:screen'
    '--sync[make X calls synchronous]'
    '--gtk-module[load additional GTK+ modules]:modules'
    '--g-fatal-warnings[make all warnings fatal]'
    '--display[X display to use]:display'
    '*:filename:_files'
)
_arguments -s $arguments
