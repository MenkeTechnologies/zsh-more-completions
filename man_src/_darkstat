#compdef darkstat

local arguments

arguments=(
    '-i[Capture traffic on the specified network interface]:interface'
    '-r[Read traffic from a pcap capture file instead of capturing live]:file:_files'
    '--snaplen[How many bytes to capture from the start of each packet]:bytes'
    '--pppoe[Expect PPPoE encapsulation]'
    '--syslog[Send errors, warnings, and verbose messages to syslog]'
    '--verbose[Produce more verbose debugging messages]'
    '--no-daemon[Do not detach from the controlling terminal]'
    '--no-promisc[Do not use promiscuous mode to capture]'
    '--no-dns[Do not resolve IPs to host names]'
    '--no-macs[Do not display MAC addresses in the hosts table]'
    '--no-lastseen[Do not display the last seen time in the hosts table]'
    '-p[Bind the web interface to the specified port]:port'
    '-b[Bind the web interface to the specified address]:address'
    '--base[Specify the path of the base URL]:path'
    '-f[Use the specified filter expression when capturing traffic]:filter'
    '-l[Define a local network]:network/netmask'
    '--local-only[Only display hosts on the local network]'
    '--chroot[Force darkstat to chroot into the specified directory]:directory:_directories'
    '--user[Force darkstat to drop privileges to the specified user]:username:_users'
    '--daylog[Log daily traffic statistics into the named file]:filename:_files'
    '--import[Import a darkstat database from the named file on startup]:filename:_files'
    '--export[Export the in-memory database to the named file on shutdown]:filename:_files'
    '--pidfile[Create a file containing the process ID]:filename:_files'
    '--hosts-max[Maximum number of hosts in the hosts table]:count'
    '--hosts-keep[Number of hosts to keep when table fills up]:count'
    '--ports-max[Maximum number of ports tracked for each host]:count'
    '--ports-keep[Number of ports to keep when table fills up]:count'
    '--highest-port[Ports higher than this will not appear in per-host port tables]:port'
    '--wait[Wait before capture]:seconds'
    '--hexdump[Show hex dumps of received traffic]'
    '*:filename:_files'
)
_arguments -s $arguments
