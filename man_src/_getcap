#compdef getcap
# Documentation: https://man.archlinux.org/search?q=getcap
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-r[Enable recursive search]'
    '-v[Display all searched entries, even without file-capabilities]'
    '-h[Print quick usage]'
    '*:filename:_files'
)
_arguments -s $arguments
