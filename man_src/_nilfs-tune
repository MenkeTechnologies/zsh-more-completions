#compdef nilfs-tune
# Documentation: https://man.archlinux.org/search?q=nilfs-tune
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-f[Force to modify even if the specified file system is mounted]'
    '-i[Set the commit interval of segment]:interval'
    '-m[Set the threshold of the data amount of the segment construction]:block-max'
    '-l[List the contents of the file system superblock]'
    '-L[Set the volume label of the file system]:volume-label'
    '-O[Set or clear the indicated filesystem features]:features'
    '-U[Set the universally unique identifier (UUID) of the file system]:UUID'
    '-h[Display help message and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
