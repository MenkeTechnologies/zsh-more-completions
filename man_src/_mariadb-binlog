#compdef mariadb-binlog mysqlbinlog

local arguments

arguments=(
    {-\?,--help}'[Display help and exit]'
    '--base64-output[Control base64 output]:mode:(auto never decode-rows)'
    '--character-sets-dir[Directory for character set files]:path:_directories'
    {-d,--database}'[List entries for just this database]:db_name'
    '--debug-check[Check memory and open file usage at exit]'
    '--debug-info[Print debugging information at exit]'
    '--default-auth[Default authentication client-side plugin]:plugin'
    '--defaults-extra-file[Read option file after the global option file]:filename:_files'
    '--defaults-file[Only read options from the given file]:filename:_files'
    '--disable-log-bin[Disable binary logging]'
    '--force-if-open[Force reading even if binlog was not properly closed]'
    {-F,--force-read}'[Force reading unknown binlog events]'
    {-H,--hexdump}'[Augment output with hexadecimal dump]'
    {-h,--host}'[Connect to the specified host]:host_name:_hosts'
    '--local-load[Prepare local temporary files for LOAD DATA in specified directory]:path:_directories'
    '--no-defaults[Do not read any option files]'
    {-o,--offset}'[Skip the first N entries]:N'
    {-p,--password}'[Password to use for connection]:password'
    {-P,--port}'[Port number for connection]:port_num'
    '--print-defaults[Print the program argument list and exit]'
    '--protocol[Connection protocol to use]:protocol:(TCP SOCKET PIPE MEMORY)'
    '--raw[Dump raw binlog data]'
    '--read-from-remote-server[Read binary logs from a MySQL server]'
    {-R,--read-from-remote-master}'[Read binary logs from a MySQL master]:type:(BINLOG-DUMP-NON-GTID BINLOG-DUMP-GTID)'
    {-r,--result-file}'[Direct output to the specified file]:file:_files'
    '--server-id[Set server_id for extracting only events created by the specified server]:id'
    '--set-charset[Add SET NAMES charset to the output]:charset'
    {-s,--short-form}'[Show only statements in the output]'
    {-S,--socket}'[Socket file for connection]:path:_files'
    '--ssl[Enable SSL for connection]'
    '--ssl-ca[CA file in PEM format]:name:_files'
    '--ssl-capath[CA directory]:name:_directories'
    '--ssl-cert[X509 cert in PEM format]:name:_files'
    '--ssl-cipher[SSL cipher to use]:name'
    '--ssl-key[X509 key in PEM format]:name:_files'
    '--start-datetime[Start reading binary log at specified datetime]:datetime'
    '--start-position[Start reading binary log at specified position]:pos'
    '--stop-datetime[Stop reading binary log at specified datetime]:datetime'
    '--stop-position[Stop reading binary log at specified position]:pos'
    '--stop-never[Continue reading binlog events from server indefinitely]'
    '--stop-never-slave-server-id[Slave server ID for stop-never mode]:id'
    {-t,--to-last-log}'[Continue printing until the end of the last log]'
    {-u,--user}'[User for login]:user_name'
    {-v,--verbose}'[Reconstruct row events as SQL statements]'
    {-V,--version}'[Display version information and exit]'
    '--verify-binlog-checksum[Verify checksums in binlog events]'
    '*:filename:_files'
)
_arguments -s $arguments
