#compdef xml-xread
# Documentation: https://man.archlinux.org/search?q=xml-xread
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-c[Specify catalog file]:catalogfile:_files'
    '-w[Enable warnings]'
    '-v[Enable validation (default)]'
    '-s[Enable schema validation]'
    '-n[Enable namespace processing]'
    '-N[Disable namespace processing (default)]'
    '-d[Set debug level]:integer'
    '-E[Set error level]:integer'
    '*:filename:_files'
)
_arguments -s $arguments
