#compdef tiffgt

local arguments

arguments=(
    '-c[force image display in a colormap window]'
    '-d[specify an image to display by directory number]:number'
    '-e[enable reporting of error messages from the TIFF library]'
    '-f[force tiffgt to run as a foreground process]'
    '-l[force the presumed bit ordering to be LSB to MSB]'
    '-m[force the presumed bit ordering to be MSB to LSB]'
    '-o[specify an image to display by directory offset]:offset'
    '-p[override the PhotometricInterpretation tag value]:photometric'
    '-r[force image display in a full color window]'
    '-s[stop on the first read error]'
    '-w[enable reporting of warning messages from the TIFF library]'
    '-v[place information in the title bar describing the window type]'
    '*:filename:_files'
)
_arguments -s $arguments
