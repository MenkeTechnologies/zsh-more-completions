#compdef x2x

local arguments

arguments=(
    '-to[Specify the display of the target machine]:display'
    '-from[Specify the display of the source machine]:display'
    '-north[Put the target display north of the source]'
    '-south[Put the target display south of the source]'
    '-east[Put the target display east of the source]'
    '-west[Put the target display west of the source]'
    '*:filename:_files'
)
_arguments -s $arguments
