#compdef ptx gptx

local arguments

arguments=(
    {-A,--auto-reference}'[Use automatic references]'
    {-G,--traditional}'[Behave more like System V ptx]'
    {-F,--flag-truncation}'[Use string for flagging line truncation]:string'
    {-M,--macro-name}'[Set the macro name]:name'
    {-O,--format}'[Select the output format]:format:(roff tex)'
    {-R,--right-side-refs}'[Put references at right]'
    {-S,--sentence-regexp}'[Use regexp for end of sentences]:regexp'
    {-T,--format}'[Use roff output format]:format'
    {-W,--word-regexp}'[Use regexp for input word]:regexp'
    {-b,--break-file}'[Use file as a list of break characters]:file:_files'
    {-f,--ignore-case}'[Fold lower case to upper case for sorting]'
    {-g,--gap-size}'[Set gap size between output fields]:number'
    {-i,--ignore-file}'[Read file and ignore its words]:file:_files'
    {-o,--only-file}'[Read file and only use its words]:file:_files'
    {-r,--references}'[First field of each input line is a reference]'
    {-t,--typeset-mode}'[Not implemented]'
    {-w,--width}'[Set output width]:columns'
    '--help[Display help and exit]'
    '--version[Output version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
