#compdef chirpw

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Show summary of options]'
    '--version[Print version and exit]'
    '--profile[Enable profiling]'
    '--quiet[Decrease verbosity]'
    {-v,--verbose}'[Increase verbosity]'
    '--log[Log messages to a file]:log file:_files'
    '--log-level[Log file verbosity level]:level:(critical error warn info debug)'
    '*:filename:_files'
)
_arguments -s $arguments
