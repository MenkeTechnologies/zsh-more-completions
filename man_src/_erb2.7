#compdef erb2.7

local arguments

arguments=(
    '--version[Print the version of erb]'
    '-E[Specify external and internal encoding]:encoding'
    '--encoding[Specify the default value(s) for external and internal encoding]:encoding'
    '-P[Disable ruby code evaluation for lines beginning with "%"]'
    '-S[Specify the safe level in which eRuby script will run]:level'
    '-T[Specify trim mode]:mode'
    '-r[Load a library]:library'
    '-U[Set the default value for internal encodings to UTF-8]'
    '-d[Turn on debug mode]'
    '--debug[Turn on debug mode]'
    '-h[Print a summary of options]'
    '--help[Print a summary of options]'
    '-n[Prepend the line number to each line in the output]'
    '-v[Enable verbose mode]'
    '-x[Convert the eRuby script into Ruby script and print it without line numbers]'
    '*:filename:_files'
)
_arguments -s $arguments
