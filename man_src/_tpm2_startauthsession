#compdef tpm2_startauthsession

local arguments

arguments=(
    {-S,--session}'[output file for the session context]:file:_files'
    {-g,--hash-algorithm}'[hash algorithm for the session]:algorithm'
    '--policy-session[start a policy session instead of HMAC]'
    '--audit-session[start an audit session]'
    '--hmac-session[start an HMAC session (default)]'
    {-c,--key-context}'[set the tpmkey context for salting the session]:object:_files'
    '--bind-context[set the bind entity for the session]:object:_files'
    '--bind-auth[set the authorization value for the bind entity]:auth'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    {-V,--verbose}'[increase verbosity of tool output]'
    {-Q,--quiet}'[suppress informational output]'
    {-Z,--enable-errata}'[enable errata fixups]'
    {-R,--autoflush}'[autoflush objects created by the command]'
    '*:filename:_files'
)
_arguments -s $arguments
