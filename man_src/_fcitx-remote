#compdef fcitx-remote

local arguments

arguments=(
    '-c[Inactivate input method]'
    '-o[Activate input method]'
    '-r[Reload fcitx config]'
    '-t[Switch between active/inactive]'
    '-s[Switch to the input method identified by imname]:imname'
    '-h[Display help and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
