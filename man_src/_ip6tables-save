#compdef ip6tables-save
# Documentation: https://man.archlinux.org/search?q=ip6tables-save
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-M,--modprobe}'[Specify the path to the modprobe program]:modprobe:_files'
    {-c,--counters}'[Include the current values of all packet and byte counters in the output]'
    {-t,--table}'[Restrict output to only one table]:tablename'
    '*:filename:_files'
)
_arguments -s $arguments
