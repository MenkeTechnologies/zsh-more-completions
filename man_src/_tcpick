#compdef tcpick

local arguments

arguments=(
    {-i,--interface}'[listen on selected interface]:interface'
    {-r,--readfile}'[read raw packets from a file written with tcpdump -w]:file:_files'
    '-a[display host names instead of IP addresses]'
    {-C,--colors}'[use terminal colors for output]'
    {-D,--dirs}'[create directories to store sniffed sessions]'
    '-e[exit when count packets have been sniffed]:count'
    '-E[exit when number connections are detected as CLOSED]:number'
    '--Ef[exit when the first number connections are detected as CLOSED]:number'
    {--F1,--F2,--filenaming}'[choose the filenaming system]'
    '-h[show source and destination IP and port with TCP flags]'
    '--help[display a short help summary]'
    '-p[do not put the network interface in promiscuous mode]'
    '-S[suppress the status of the connection banner]'
    '--separator[add a separator for the payloads displayed]'
    '-t[add timestamp in hour:minutes:seconds:microseconds format]'
    '--td[like -tFP with date timestamp in day-month-year format]'
    '-T[track number connections]:number'
    '--Tf[track only the first number connections]:number'
    '-v[set verbosity level]:verbosity'
    '-X[set connection expiry timeout]:timeout'
    '--version[display the tcpick version]'
    '--yH[view data in hexadecimal-spaced mode]'
    '--yX[view data in hexadecimal dump with ASCII]'
    '--yP[show data contained in the TCP packets]'
    '--yR[display all characters, printable and non-printable]'
    '--yx[show all data after the header in hexadecimal dump]'
    '--yU[show data with unprintable characters as dots]'
    '--wR[write raw data to file]'
    '--wP[write data with unprintable characters as dots]'
    '--wU[write data with unprintable characters as hex values]'
    '--wH[write the flow in hexadecimal-spaced mode]'
    '*:filename:_files'
)
_arguments -s $arguments
