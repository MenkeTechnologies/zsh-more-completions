#compdef trace-summary

local arguments

arguments=(
    '--version[show version number and exit]'
    {-h,--help}'[show help message and exit]'
    {-b,--bytes}'[count fractions in terms of bytes rather than packets/connections]'
    {-c,--conn-summaries}'[input file contains Zeek connection summaries]'
    '--conn-version[specify Bro version for connection summaries]:version'
    {-C,--chema}'[for packets: include only TCP, ignore when seq==0]'
    {-e,--external}'[ignore strictly internal traffic]'
    {-E,--exclude-nets}'[exclude CIDRs in file from analysis]:file:_files'
    {-i,--intervals}'[create summaries for time intervals of given length]:seconds'
    {-l,--local-nets}'[differentiate in/out based on CIDRs in file]:file:_files'
    {-n,--topn}'[show top n]:n'
    {-p,--ports}'[include only ports listed in file]:file:_files'
    {-P,--write-ports}'[write top ports into file]:file:_files'
    {-r,--resolve-host-names}'[resolve host names]'
    {-R,--R}'[write output suitable for R into files]:tag'
    {-s,--sample-factor}'[sample factor of input]:factor'
    {-S,--do-sample}'[sample input with probability]:prob'
    {-m,--save-mem}'[do not make memory-expensive statistics]'
    {-t,--tcp}'[include only TCP]'
    {-u,--udp}'[include only UDP]'
    {-U,--min-time}'[minimum time in ISO format]:time'
    {-v,--verbose}'[show top-n for every interval]'
    {-V,--max-time}'[maximum time in ISO format]:time'
    '*:filename:_files'
)
_arguments -s $arguments
