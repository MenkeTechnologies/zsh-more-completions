#compdef update-shells
# Documentation: https://man.archlinux.org/search?q=update-shells
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--no-act[Do not actually perform the changes to /etc/shells]'
    '--root[Operate on a chroot at ROOT]:root:_directories'
    '--verbose[Print the shells that are being added or removed]'
    '*:filename:_files'
)
_arguments -s $arguments
