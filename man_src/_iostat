#compdef iostat

local arguments

arguments=(
    '-c[Display the CPU utilization report]'
    '-d[Display the device utilization report]'
    '--debuginfo[Print debug output to stderr]'
    '-g[Display statistics for a group of devices]:group'
    '-h[Make the Device Utilization Report easier to read by a human]'
    '-j[Display persistent device names]:type:(ID LABEL PATH UUID)'
    '-k[Display statistics in kilobytes per second]'
    '-m[Display statistics in megabytes per second]'
    '-N[Display the registered device mapper names for device mapper devices]'
    '-p[Display statistics for block devices and all their partitions]:device'
    '-T[Only display global statistics for a device group]'
    '-t[Print the time for each report displayed]'
    '-V[Print version number then exit]'
    '-x[Display extended statistics]'
    '-y[Omit first report with statistics since system boot]'
    '-z[Omit output for any devices for which there was no activity]'
    '*:filename:_files'
)
_arguments -s $arguments
