#compdef ctm

local arguments

arguments=(
    '-b[Prepend the specified base directory to every filename]:directory:_directories'
    '-B[Backup all files that would be modified to the specified file]:backup file:_files'
    '-c[Check only, do not do anything]'
    '-e[Match names against the regular expression and include matching files]:regexp'
    '-F[Force mode]'
    '-k[Keep files and directories, do not remove them]'
    '-l[List files that would be modified and the actions taken]'
    '-q[Quiet mode]'
    '-t[Use the specified tar command]:tar command:_files'
    '-T[Put temporary files under the specified directory]:directory:_directories'
    '-u[Set modification time of files to the CTM delta creation time]'
    '-v[Verbose mode]'
    '-V[Verbose mode at specified level]:level'
    '-x[Match names against the regular expression and exclude matching files]:regexp'
    '*:filename:_files'
)
_arguments -s $arguments
