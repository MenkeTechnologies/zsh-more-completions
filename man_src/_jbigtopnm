#compdef jbigtopnm

local arguments

arguments=(
    '-x[Decode only up to the largest resolution layer not more than n pixels wide]:number'
    '-y[Decode only up to the largest resolution layer not more than n pixels high]:number'
    '-b[Use binary values instead of Gray code words to decode pixel values]'
    '-d[Diagnose a BIE]'
    '-p[If the input contains multiple bitplanes, extract only the specified single bitplane]:number'
    '*:filename:_files'
)
_arguments -s $arguments
