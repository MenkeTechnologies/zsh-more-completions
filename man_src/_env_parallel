#compdef env_parallel

local arguments

arguments=(
    '--end-session[Undo last --session]'
    '--record-env[Record all names currently defined to be ignored when running env_parallel]'
    '--session[Start a new session for tracking environment variables]'
    '--install[Install env_parallel into the shell startup file]'
    '*:filename:_files'
)
_arguments -s $arguments
