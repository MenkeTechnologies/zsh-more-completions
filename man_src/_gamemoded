#compdef gamemoded
# Documentation: https://man.archlinux.org/search?q=gamemoded
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-r,--request}'[Toggle gamemode for process]:pid'
    {-s,--status}'[Query the status of gamemode for process]:pid'
    {-d,--daemonize}'[Daemonize self after launch]'
    {-l,--log-to-syslog}'[Log to syslog]'
    {-t,--test}'[Run tests]'
    {-h,--help}'[Print this help]'
    {-v,--version}'[Print version]'
    '*:filename:_files'
)

_arguments -s $arguments
