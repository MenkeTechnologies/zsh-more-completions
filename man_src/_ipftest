#compdef ipftest

local arguments

arguments=(
    '-6[Use IPv6]'
    '-b[Cause the output to be a brief summary of the result of passing the packet through the filter]'
    '-C[Force the checksums to be recalculated for all packets being input]'
    '-d[Turn on filter rule debugging]'
    '-D[Dump internal tables before exiting]'
    '-F[Select which input format the input file is in]:format'
    '-i[Specify the filename from which to take input]:filename:_files'
    '-I[Set the interface name used in rule matching]:interface'
    '-l[Dump log messages generated during testing to the specified file]:filename:_files'
    '-N[Specify the filename from which to read NAT rules]:filename:_files'
    '-o[Save output packets that would have been written to each interface in a file]'
    '-P[Read IP pool configuration information from the specified file]:filename:_files'
    '-r[Specify the filename from which to read filter rules]:filename:_files'
    '-R[Do not attempt to convert IP addresses to hostnames]'
    '-S[Specify IP address used to determine whether a packet is inbound or outbound]:ip_address'
    '-T[Simulate run-time changing of IPFilter kernel variables]:optionlist'
    '-v[Verbose mode]'
    '-x[Print a hex dump of each packet before printing the decoded contents]'
    '*:filename:_files'
)
_arguments -s $arguments
