#compdef ebtables-legacy

local arguments

arguments=(
    {-t,--table}'[Specify the table to use]:table:(filter nat broute)'
    {-A,--append}'[Append a rule to the end of the selected chain]'
    {-D,--delete}'[Delete the specified rule from the selected chain]'
    {-I,--insert}'[Insert a rule into the selected chain at the specified position]'
    {-C,--change-counters}'[Change the counters of the specified rule]'
    {-P,--policy}'[Set the policy for the chain to the given target]:target:(ACCEPT DROP RETURN CONTINUE)'
    {-F,--flush}'[Flush the selected chain]'
    {-Z,--zero}'[Set the counters of the selected chain to zero]'
    {-L,--list}'[List all rules in the selected chain]'
    {-N,--new-chain}'[Create a new user-defined chain with the given name]'
    {-X,--delete-chain}'[Delete the specified user-defined chain]'
    {-E,--rename-chain}'[Rename the specified chain to a new name]'
    '--init-table[Replace the current table data by the initial table data]'
    '--atomic-init[Copy the kernel initial data of the table to the specified file]:file:_files'
    '--atomic-save[Copy the kernel current data of the table to the specified file]:file:_files'
    '--atomic-commit[Replace the kernel table data with the data in the specified file]:file:_files'
    '--atomic-file[Set the file for atomic operations]:file:_files'
    {-V,--version}'[Show the version of the ebtables userspace program]'
    '(- * :)'{-h,--help}'[Give a brief description of the command syntax]'
    {-j,--jump}'[The target of the rule]:target'
    {-M,--modprobe}'[Program to try to automatically load missing kernel modules]:program'
    '--concurrent[Use a file lock to support concurrent scripts updating the ebtables kernel tables]'
    {-p,--protocol}'[The protocol that was responsible for creating the frame]:protocol'
    {-i,--in-interface}'[The interface via which a frame is received]:interface'
    '--logical-in[The logical bridge interface via which a frame is received]:interface'
    {-o,--out-interface}'[The interface via which a frame is going to be sent]:interface'
    '--logical-out[The logical bridge interface via which a frame is going to be sent]:interface'
    {-s,--source}'[The source MAC address]:address'
    {-d,--destination}'[The destination MAC address]:address'
    {-c,--set-counter}'[Set packet and byte counters for the rule]'
    '--Lc[Show counters in list output]'
    '--Ln[Show rule numbers in list output]'
    '--Lx[Show rules in ebtables-save format]'
    '--Lmac2[Show MAC addresses with leading zeroes]'
    '--among-dst[Compare the MAC destination to the given list]:list'
    '--among-src[Compare the MAC source to the given list]:list'
    '--among-dst-file[Read MAC destination list from file]:file:_files'
    '--among-src-file[Read MAC source list from file]:file:_files'
    '--arp-opcode[Match the ARP opcode]:opcode'
    '--arp-htype[Match the hardware type]:type'
    '--arp-ptype[Match the protocol type]:type'
    '--arp-ip-src[Match the ARP IP source address]:address'
    '--arp-ip-dst[Match the ARP IP destination address]:address'
    '--arp-mac-src[Match the ARP MAC source address]:address'
    '--arp-mac-dst[Match the ARP MAC destination address]:address'
    '--ip-source[Match the source IP address]:address'
    '--ip-destination[Match the destination IP address]:address'
    '--ip-tos[Match the IP type of service]:tos'
    '--ip-protocol[Match the IP protocol]:protocol'
    '--ip-source-port[Match the source port or port range]:port'
    '--ip-destination-port[Match the destination port or port range]:port'
    '--ip6-source[Match the source IPv6 address]:address'
    '--ip6-destination[Match the destination IPv6 address]:address'
    '--ip6-tclass[Match the IPv6 traffic class]:class'
    '--ip6-protocol[Match the IPv6 protocol]:protocol'
    '--ip6-source-port[Match the IPv6 source port or port range]:port'
    '--ip6-destination-port[Match the IPv6 destination port or port range]:port'
    '--ip6-icmp-type[Match the ICMPv6 type and code]:type'
    '--log[Enable logging]'
    '--log-level[Set log level]:level'
    '--log-prefix[Set log prefix]:text'
    '--log-ip[Log IP information]'
    '--log-ip6[Log IPv6 information]'
    '--log-arp[Log ARP information]'
    '--limit[Set maximum average matching rate]:value'
    '--limit-burst[Set maximum initial number of packets to match]:number'
    '--mark[Match frames with the given unsigned mark value]:value'
    '--mark-set[Set the mark value]:value'
    '--mark-or[OR the mark value]:value'
    '--mark-and[AND the mark value]:value'
    '--mark-xor[XOR the mark value]:value'
    '--mark-target[Set the mark target]:target'
    '--pkttype-type[Match the Ethernet frame class]:type:(broadcast multicast host otherhost)'
    '--nflog[Log using nfnetlink_log]'
    '--nflog-group[Set netlink group for nflog]:nlgroup'
    '--nflog-prefix[Set log prefix for nflog]:prefix'
    '--nflog-range[Set number of bytes to copy for nflog]:size'
    '--nflog-threshold[Set message threshold for nflog]:size'
    '--redirect-target[Set the redirect target]:target'
    '--to-destination[Set destination MAC address for dnat]:address'
    '--dnat-target[Set the dnat target]:target'
    '--to-source[Set source MAC address for snat]:address'
    '--snat-target[Set the snat target]:target'
    '--snat-arp[Also change ARP source address in snat]'
    '--arpreply-mac[Set MAC address for ARP reply]:address'
    '--arpreply-target[Set the arpreply target]:target'
    '--string-algo[Set pattern matching algorithm]:algorithm:(bm kmp)'
    '--string-from[Set lowest offset for match start]:offset'
    '--string-to[Set highest offset for match start]:offset'
    '--string[Match the given pattern]:pattern'
    '--string-hex[Match the given pattern in hex notation]:pattern'
    '--string-icase[Ignore case when searching]'
    '--vlan-id[Match the VLAN identifier]:id'
    '--vlan-prio[Match the user priority field]:priority'
    '--vlan-encap[Match the encapsulated Ethernet frame type]:type'
    '--stp-type[Match the BPDU type]:type'
    '--stp-flags[Match the BPDU flags]:flags'
    '--stp-root-prio[Match the root priority range]:range'
    '--stp-root-addr[Match the root MAC address]:address'
    '--stp-root-cost[Match the root path cost range]:range'
    '--stp-sender-prio[Match the sender priority range]:range'
    '--stp-sender-addr[Match the sender MAC address]:address'
    '--stp-port[Match the port identifier range]:range'
    '--stp-msg-age[Match the message age timer range]:range'
    '--stp-max-age[Match the max age timer range]:range'
    '--stp-hello-time[Match the hello time timer range]:range'
    '--stp-forward-delay[Match the forward delay timer range]:range'
    '*:filename:_files'
)
_arguments -s $arguments
