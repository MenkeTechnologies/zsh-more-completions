#compdef tightvncpasswd
# Documentation: https://man.archlinux.org/search?q=tightvncpasswd
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-t[write passwords into /tmp/$USER-vnc/passwd]'
    '-f[read password from stdin (only first eight characters are significant)]'
    '*:filename:_files'
)
_arguments -s $arguments
