#compdef timed

local arguments

arguments=(
    '-d[enable debugging mode, do not detach from the terminal]'
    '-i[add network to the list of networks to ignore]:network'
    '-F[create a list of trusted hosts]:file:_files'
    '-M[allow this host to become a timed master if necessary]'
    '-n[add network to the list of allowed networks]:network'
    '-t[enable tracing of received messages to /var/log/timed.log]'
    '*:filename:_files'
)
_arguments -s $arguments
