#compdef exiqgrep

local arguments

arguments=(
    '-h[Print help]'
    '-f[Match sender address]:regexp'
    '-r[Match recipient address]:regexp'
    '-s[Match against the site field from long output]:regexp'
    '-y[Message younger than specified seconds]:seconds'
    '-o[Message older than specified seconds]:seconds'
    '-z[Frozen messages only]'
    '-x[Non-frozen messages only]'
    '-c[Display match count]'
    '-l[Long format (default)]'
    '-i[Message IDs only]'
    '-b[Brief format]'
    '-R[Reverse order]'
    '*:filename:_files'
)
_arguments -s $arguments
