#compdef text2ngram

local arguments

arguments=(
    {--output,-o}'[output file name]:file:_files'
    {--ngrams,-n}'[specify ngram cardinality]:n'
    {--format,-f}'[output file format]:format:(sqlite tsv)'
    {--append,-a}'[open output file in append mode]'
    {--help,-h}'[display help information]'
    {--lowercase,-l}'[convert to lowercase]'
    {--version,-v}'[show version information]'
    '*:filename:_files'
)
_arguments -s $arguments
