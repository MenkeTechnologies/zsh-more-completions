#compdef enscript

local arguments

arguments=(
    '-#[Print num copies of each page]:num'
    {-1,-2}'[Specify number of columns per page]'
    {-a,--pages}'[Specify which pages are printed]:pages'
    {-A,--file-align}'[Align separate input files to even page count]:align'
    {-b,--header}'[Use specified text as page header]:header'
    {-B,--no-header}'[Do not print page headers]'
    {-c,--truncate-lines}'[Cut lines that are too long for the page]'
    {-C,--line-numbers}'[Precede each line with its line number]:start_line'
    '-d[Spool output to the named printer]:name'
    {-D,--setpagedevice}'[Pass a page device definition to the generated PostScript output]:key:value'
    {-e,--escapes}'[Enable special escapes interpretation]:char'
    {-E,--highlight}'[Highlight source code]:lang'
    {-f,--font}'[Select a font for body text]:font'
    {-F,--header-font}'[Select a font for header text]:font'
    {-g,--print-anyway}'[Print document even if it is empty]'
    {-h,--no-job-header}'[Suppress the job header page]'
    {-H,--highlight-bars}'[Specify the height of highlight bars]:height'
    {-i,--indent}'[Indent every line]:num'
    {-I,--filter}'[Read input files through a filter]:filter'
    {-j,--borders}'[Print borders around columns]'
    {-J,--title}'[Set the job title]:title'
    {-l,--lineprinter}'[Emulate lineprinter]'
    {-L,--lines-per-page}'[Specify how many lines each page has]:lines'
    {-m,--mail}'[Send notification mail to the user after the print job has been completed]'
    {-M,--media}'[Select an output media]:name'
    {-n,--copies}'[Print num copies of each page]:num'
    {-N,--newline}'[Select the newline character]:char'
    {-o,--output}'[Leave output to file]:file:_files'
    {-O,--missing-characters}'[Print a listing of missing characters]'
    {-p,--output}'[Same as -o]:file:_files'
    {-P,--printer}'[Spool output to the named printer]:name'
    {-q,--quiet}'[Be quiet]'
    {-r,--landscape}'[Print in landscape mode]'
    {-R,--portrait}'[Print in portrait mode]'
    {-s,--baselineskip}'[Specify the baseline skip]:num'
    {-t,--title}'[Set the job title]:title'
    {-T,--tabsize}'[Set the tabulator size]:num'
    {-u,--underlay}'[Print the string under every page]:string'
    {-U,--nup}'[Print N pages on each sheet]:num'
    {-v,--verbose}'[Tell what is going on]'
    {-V,--version}'[Print version information]'
    {-w,--language}'[Set output language]:language'
    {-W,--option}'[Pass an option to the output language]:option'
    '*:filename:_files'
)
_arguments -s $arguments
