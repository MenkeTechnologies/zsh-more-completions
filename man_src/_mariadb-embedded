#compdef mariadb-embedded mysql_embedded

# Updated with latest MariaDB embedded options

local arguments

arguments=(
    {-?,--help}'[Display help message and exit]'
    '-I[Synonym for --help]'
    '--auto-rehash[Enable automatic rehashing]'
    '-A[Disable automatic rehashing]'
    '--auto-vertical-output[Automatically switch to vertical output mode]'
    {-B,--batch}'[Print results using tab as column separator]'
    '--character-sets-dir[Directory for character set files]:dir:_directories'
    '--column-type-info[Display column type information]'
    {-c,--comments}'[Preserve comments]'
    {-C,--compress}'[Use compression in server/client protocol]'
    {-#,--debug}'[Debug log]:debug_options'
    '--debug-check[Check memory and open file usage at exit]'
    '-T[Debug info, memory and CPU usage on exit]'
    '--default-character-set[Set the default character set]:charset'
    '--defaults-extra-file[Read defaults from file after global defaults]:file:_files'
    '--defaults-file[Only read defaults from file]:file:_files'
    '--defaults-group-suffix[Also read groups with suffix]:suffix'
    {-e,--execute}'[Execute command and quit]:command'
    {-f,--force}'[Continue even if an SQL error occurs]'
    {-h,--host}'[Connect to host]:host:_hosts'
    {-H,--html}'[Produce HTML output]'
    {-X,--xml}'[Produce XML output]'
    '--line-numbers[Write line numbers for errors]'
    {-L,--skip-line-numbers}'[Do not write line numbers for errors]'
    '--no-auto-rehash[Disable automatic rehashing]'
    '--no-beep[Turn off beep on error]'
    '--no-defaults[Do not read any option files]'
    {-o,--one-database}'[Only update the default database]'
    '--pager[Set pager]:pager'
    {-p,--password}'[Password to use]:password'
    {-P,--port}'[Port number]:port'
    '--print-defaults[Print defaults and exit]'
    '--prompt[Set the prompt]:prompt'
    '--protocol[Connection protocol]:protocol:(TCP SOCKET PIPE MEMORY)'
    {-q,--quick}'[Do not cache results, print each row]'
    {-r,--raw}'[Write fields without conversion]'
    '--reconnect[Reconnect if the connection is lost]'
    {-s,--silent}'[Be more silent]'
    {-S,--socket}'[Socket file to use]:socket:_files'
    '--ssl[Enable SSL]'
    '--ssl-ca[CA file in PEM format]:file:_files'
    '--ssl-capath[CA directory]:dir:_directories'
    '--ssl-cert[SSL certificate file]:file:_files'
    '--ssl-cipher[SSL cipher to use]:cipher'
    '--ssl-key[SSL key file]:file:_files'
    {-t,--table}'[Output in table format]'
    '--tee[Log to outfile]:file:_files'
    {-u,--user}'[User for login]:user'
    '--safe-updates[Only allow UPDATE and DELETE that use keys]'
    {-v,--verbose}'[Verbose mode]'
    {-V,--version}'[Output version information and exit]'
    {-w,--wait}'[Wait and retry if connection is down]'
    '--connect-timeout[Number of seconds before connection timeout]:seconds'
    '--max-allowed-packet[Maximum packet length]:bytes'
    '--max-join-size[Automatic limit for rows in a join]:rows'
    '--select-limit[Automatic limit for SELECT]:rows'
    '*:database:'
)
_arguments -s $arguments
