#compdef tack
# Documentation: https://man.archlinux.org/search?q=tack
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-i[do not send the reset and init strings to the terminal]'
    '-t[override the terminfo settings for basic terminal functions]'
    '-V[display version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
