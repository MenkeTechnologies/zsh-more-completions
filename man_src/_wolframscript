#compdef wolframscript

local arguments

arguments=(
    {-c,--code}'[Give Wolfram Language code to execute]:code'
    {-f,--file}'[Give a file containing Wolfram Language code to execute]:file:_files'
    {-s,--function,--fun}'[Use a function whose arguments are strings]'
    '--args[Arguments to pass to the function]'
    {-o,--cloud}'[Execute code in the cloud]:cloudbase'
    {-l,--local}'[Execute code locally]:kernelpath'
    '--api[Use an API at the specified URL]:url'
    '--format[Specify the format in which to give output]:type'
    '--linewise[Execute code on each line of standard input that is read]'
    '--print[Print the result from executing the last line of the script]:mode:(all)'
    '--timeout[Specify the number of seconds to allow for execution]:seconds'
    {-v,--verbose}'[Print additional information during execution]'
    '(- * :)'{-h,--help}'[Print help text]'
    '--auth[Authenticate with the cloud]:wolfram_id password'
    '--config[Configure wolframscript settings]:key=value'
    '--disconnect[Disconnect from the cloud]:cloudbase'
    '*:filename:_files'
)
_arguments -s $arguments
