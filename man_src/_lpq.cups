#compdef lpq.cups
# Documentation: https://man.archlinux.org/search?q=lpq.cups
# Reference accessed: 2026-05-16

local arguments

arguments=(
  '-a[show jobs on all destinations]'
  '-E[encrypt the connection to the server]'
  '-h[connect to the named server and port]'
  '-l[show verbose (long) output]'
  '-P[show status for the specified destination]'
  '-U[specify the username to use for authentication]'
  '*:filename:_files'
)

_arguments -s $arguments
