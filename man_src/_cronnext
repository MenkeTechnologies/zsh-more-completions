#compdef cronnext

local arguments

arguments=(
    '-i[Consider only the crontabs of the specified users]:users'
    '-e[Do not consider the crontabs of the specified users]:users'
    '-s[Do not consider the system crontab]'
    '-a[Use system crontabs in addition to the ones passed as files]'
    '-t[Determine the next job from this time instead of now]:time'
    '-q[Do not check jobs over this time]:time'
    '-l[Print the whole entries of the next jobs to be executed]'
    '-c[Print every entry in every crontab with the next execution time]'
    '-f[Print all jobs that are executed in the given interval (requires -q)]'
    '-h[Print usage output and exit]'
    '-V[Print version and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
