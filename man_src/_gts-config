#compdef gts-config
# Documentation: https://man.archlinux.org/search?q=gts-config
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--cflags[Print C compiler flags needed to compile with GTS]'
    '--libs[Print linker flags needed to link with GTS]'
    '--version[Print the installed version of GTS]'
    '--help[Print usage information]'
    '*:filename:_files'
)
_arguments -s $arguments
