#compdef ldapsearch

local arguments

arguments=(
    '-n[Show what would be done, but do not actually perform the operation]'
    '-v[Run in verbose mode, with many diagnostics written to standard output]'
    '-d[Set the LDAP debugging level]:debuglevel'
    '-x[Use simple authentication instead of SASL]'
    '-D[Use the Distinguished Name binddn to bind to the LDAP directory]:binddn'
    '-W[Prompt for simple authentication]'
    '-w[Use passwd as the password for simple authentication]:passwd'
    '-y[Use complete contents of passwdfile as the password]:passwdfile:_files'
    '-H[Specify URI(s) referring to the LDAP server(s)]:ldapuri'
    '-h[Specify an alternate host on which the LDAP server is running]:ldaphost:_hosts'
    '-p[Specify an alternate TCP port where the LDAP server is listening]:ldapport'
    '-O[Specify SASL security properties]:security-properties'
    '-I[Enable SASL Interactive mode; always prompt]'
    '-Q[Enable SASL Quiet mode; never prompt]'
    '-U[Specify the authentication ID for SASL bind]:authcid'
    '-R[Specify the realm of authentication ID for SASL bind]:realm'
    '-X[Specify the requested authorization ID for SASL bind]:authzid'
    '-Y[Specify the SASL mechanism to be used for authentication]:mech'
    '-Z[Issue StartTLS extended operation]'
    '-M[Enable manage DSA IT control]'
    '-P[Specify the LDAP protocol version to use]:version'
    '-e[Specify general extensions]:extensions'
    '-E[Specify search extensions]:extensions'
    '*:filename:_files'
)
_arguments -s $arguments
