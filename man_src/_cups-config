#compdef cups-config

local arguments

arguments=(
    '--api-version[Report the current API version]'
    '--build[Report a system-specific build number]'
    '--cflags[Report the necessary compiler options]'
    '--datadir[Report the default CUPS data directory]'
    '(- * :)--help[Report the program usage message]'
    '--image[When used with --libs, add the CUPS imaging library]'
    '--ldflags[Report the necessary linker options]'
    '--libs[Report the necessary libraries to link to]'
    '--serverbin[Report the default CUPS binary directory]'
    '--serverroot[Report the default CUPS configuration file directory]'
    '--static[When used with --libs, report static libraries]'
    '--version[Report the full version number of the CUPS installation]'
    '*:filename:_files'
)
_arguments -s $arguments
