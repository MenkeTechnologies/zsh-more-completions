#compdef ftp-proxy

local arguments

arguments=(
    '-6[IPv6 mode]'
    '-A[Only permit anonymous FTP connections]'
    '-a[Source address for the control connection to a server]:address'
    '-b[Address where the proxy will listen for redirected connections]:address'
    '-D[Debug level, ranging from 0 to 7]:level'
    '-d[Do not daemonize]'
    '-m[Maximum number of concurrent FTP sessions]:number'
    '-P[Fixed server port, only used with -R]:port'
    '-p[Port where the proxy will listen for redirected connections]:port'
    '-q[Create rules with queue appended]:queue'
    '-R[Fixed server address (reverse mode)]:address'
    '-r[Rewrite source port to 20 in active mode]'
    '-T[Add tag to data connections in filter rules]:tag'
    '-t[Idle timeout for the control connection in seconds]:seconds'
    '-v[Set the log flag on pf rules committed by ftp-proxy]'
    '*:filename:_files'
)
_arguments -s $arguments
