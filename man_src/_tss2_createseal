#compdef tss2_createseal

local arguments

arguments=(
    {-p,--path}'[path to the new key]:path'
    {-t,--type}'[identifies the intended usage]:type'
    {-P,--policyPath}'[policy to be associated with the new key]:path'
    {-a,--authValue}'[the new UTF-8 password]:password'
    {-i,--data}'[data to be sealed by the TPM]:data'
    {-s,--size}'[number of random bytes the TPM should generate and seal]:size'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
