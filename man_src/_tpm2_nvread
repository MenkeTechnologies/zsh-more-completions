#compdef tpm2_nvread

local arguments

arguments=(
    '-x[NV index to read from]:index'
    '-a[handle used to authorize]:handle'
    '-f[output file for the read data]:file:_files'
    '-P[password of the auth handle]:password'
    '-s[data size to be read in bytes]:size'
    '-o[offset within the NV index to start reading from]:offset'
    '-S[input session handle from a policy session]:session_handle'
    '-L[list of PCR banks and selected PCR ids]:pcr_list'
    '-F[file containing expected PCR values]:file:_files'
    '-h[display help information]'
    '-v[display version, supported tctis and exit]'
    '-V[increase verbosity of tool output]'
    '-Q[suppress informational output]'
    '-Z[enable errata fixups]'
    '-T[select the TCTI used for communication]:tcti'
    '*:filename:_files'
)
_arguments -s $arguments
