#compdef mariadbcheck mysqlcheck

local arguments

arguments=(
    {-\?,--help}'[Display help and exit]'
    {-A,--all-databases}'[Check all databases]'
    {-1,--all-in-1}'[Use one query per database instead of one per table]'
    {-a,--analyze}'[Analyze given tables]'
    '--auto-repair[Automatically fix corrupted tables]'
    '--character-sets-dir[Directory for character set files]:path:_directories'
    {-c,--check}'[Check table for errors]'
    {-C,--check-only-changed}'[Check only tables that have changed since last check]'
    {-g,--check-upgrade}'[Check tables for version-dependent changes]'
    '--compress[Compress all information sent between client and server]'
    {-B,--databases}'[Check several databases]'
    {-\#,--debug}'[Write debugging log]:debug_options'
    '--debug-check[Check memory and open file usage at exit]'
    '--debug-info[Print debugging information at exit]'
    '--default-auth[Default authentication client-side plugin]:name'
    '--default-character-set[Set the default character set]:charset_name'
    '--defaults-extra-file[Read option file after the global option file]:filename:_files'
    '--defaults-file[Only read options from the given file]:filename:_files'
    {-e,--extended}'[Perform extended check on a table]'
    {-F,--fast}'[Check only tables that have not been closed properly]'
    '--fix-db-names[Fix database names]'
    '--fix-table-names[Fix table names]'
    '--flush[Flush each table after check]'
    {-f,--force}'[Continue even if we get an SQL error]'
    {-h,--host}'[Connect to the specified host]:host_name:_hosts'
    {-m,--medium-check}'[Check tables using a medium check]'
    '--no-defaults[Do not read any option files]'
    {-o,--optimize}'[Optimize table]'
    {-p,--password}'[Password to use for connection]:password'
    {-Z,--persistent}'[Use PERSISTENT FOR ALL option for ANALYZE TABLE]'
    {-W,--pipe}'[Connect using a named pipe (Windows)]'
    '--plugin-dir[Directory for client-side plugins]:name:_directories'
    {-P,--port}'[Port number for connection]:port_num'
    '--print-defaults[Print the program argument list and exit]'
    '--process-tables[Perform the requested operation on tables]'
    '--process-views[Perform the requested operation on views]:val'
    '--protocol[Connection protocol to use]:protocol:(TCP SOCKET PIPE MEMORY)'
    {-q,--quick}'[Faster check; do not scan rows to check for incorrect links]'
    {-r,--repair}'[Perform a repair that can fix almost anything except unique keys that are not unique]'
    {-s,--silent}'[Print only error messages]'
    '--skip-database[Skip the specified database]:db_name'
    {-S,--socket}'[Socket file for connection]:path:_files'
    '--ssl[Enable SSL for connection]'
    '--ssl-ca[CA file in PEM format]:name:_files'
    '--ssl-capath[CA directory]:name:_directories'
    '--ssl-cert[X509 cert in PEM format]:name:_files'
    '--ssl-cipher[SSL cipher to use]:name'
    '--ssl-key[X509 key in PEM format]:name:_files'
    '--ssl-crl[Certificate revocation list]:name:_files'
    '--ssl-crlpath[Certificate revocation list path]:name:_directories'
    '--ssl-verify-server-cert[Verify server certificate]'
    '--tables[Override the --databases option]'
    '--use-frm[Get table structure from .frm file for repair]'
    {-u,--user}'[User for login]:user_name'
    {-v,--verbose}'[Print info about the various stages]'
    {-V,--version}'[Output version information and exit]'
    '--write-binlog[Log ANALYZE, OPTIMIZE and REPAIR TABLE commands to binary log]'
    '--skip-write-binlog[Do not write to binary log]'
    '*:filename:_files'
)
_arguments -s $arguments
