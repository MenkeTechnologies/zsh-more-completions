#compdef g-ir-doc-tool
# Documentation: https://man.archlinux.org/search?q=g-ir-doc-tool
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--help[Show help options]'
    '--output[Save the resulting output in DIRECTORY]:DIRECTORY:_directories'
    '--format[Output format]:FORMAT:(devdocs mallard sections)'
    '--language[Output language]:LANGUAGE:(c python gjs)'
    '--add-include-path[Add a directory to find GIR includes]:DIRECTORY:_directories'
    '--version[Show program version number and exit]'
    '--write-sections-file[Backwards-compatible equivalent to -f sections]'
    '*:filename:_files'
)
_arguments -s $arguments
