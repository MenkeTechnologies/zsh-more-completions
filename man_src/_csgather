#compdef csgather
# Documentation: https://man.archlinux.org/search?q=csgather
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-G[Gather all CoreStorage metadata and write into the specified directory]:directory:_directories'
    '-o[Specify the output file generated by the -r option]:file:_files'
    '-r[Find the CoreStorage logical volume identified by the given mount point]:mount point:_directories'
    '*:filename:_files'
)
_arguments -s $arguments
