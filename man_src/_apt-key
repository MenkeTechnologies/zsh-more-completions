#compdef apt-key

# Autogenerated from man page /usr/share/man/man8/apt-key.8.gz
# Updated with latest apt-key options (deprecated in favor of signed-by)

local arguments

arguments=(
    '--keyring[Specify a particular keyring file the command should operate on]:filename:_files'
    '*:: :->subcmd'
)

_arguments -s $arguments

case "$state" in
    subcmd)
        local -a commands
        commands=(
            'add:Add a new key to the list of trusted keys'
            'del:Remove a key from the list of trusted keys'
            'export:Output the key to stdout'
            'exportall:Output all trusted keys to stdout'
            'list:List trusted keys'
            'finger:List fingerprints of trusted keys'
            'adv:Pass advanced options to gpg'
            'update:Update the local keyring with the archive keyring'
            'net-update:Perform an update working similarly to the update command'
        )
        _describe 'command' commands
        ;;
esac
