#compdef tss2_quote

local arguments

arguments=(
    {-x,--pcrList}'[array holding the PCR indices to quote against]:pcr_list'
    {-Q,--qualifyingData}'[qualifying data for the quote]:data'
    {-l,--pcrLog}'[returns the PCR log for the chosen PCR]:file:_files'
    {-f,--force}'[force overwriting the output file]'
    {-p,--keyPath}'[identifies the signing key]:path'
    {-q,--quoteInfo}'[returns the JSON-encoded quote structure]:file:_files'
    {-o,--signature}'[returns the signature]:file:_files'
    {-c,--certificate}'[the certificate associated with keyPath in PEM format]:file:_files'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
