#compdef gtags-cscope

local arguments

arguments=(
    '-b[Build the cross-reference only]'
    '-C[Ignore letter case when searching]'
    '-d[Do not update the cross-reference]'
    '-e[Suppress the ctrl-e command prompt between files]'
    '-f[Use specified file as the cross-reference]:file:_files'
    '-F[Read symbol reference lines from specified file]:file:_files'
    '-i[Use the specified file as the list of source files]:file:_files'
    '-I[Look in the specified directory for #include files]:dir:_directories'
    '-k[Kernel Mode - turns off use of the default include dir]'
    '-L[Do a single search with specified pattern]:pattern'
    '-l[Line-oriented interface]'
    '-P[Prepend path to relative file names]:path:_directories'
    '-q[Build an inverted index for quick symbol searching]'
    '-R[Recurse directories for source files]'
    '-s[Look in additional directories for source files]:dir:_directories'
    '-T[Use only the first eight characters to match against C symbols]'
    '-U[Check file time stamps]'
    '-v[Be more verbose in line mode]'
    '*:filename:_files'
)
_arguments -s $arguments
