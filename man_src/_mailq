#compdef mailq

local arguments

arguments=(
    '--Ac[Show the mail submission queue specified in /etc/mail/submit.cf]'
    '--qL[Show the lost items in the mail queue instead of the normal queue items]'
    '--qQ[Show the quarantined items in the mail queue instead of the normal queue items]'
    '--qI[Limit processed jobs to those containing substr as a substring of the queue id]:substr'
    '--qR[Limit processed jobs to those containing substr as a substring of one of the recipients]:substr'
    '--qS[Limit processed jobs to those containing substr as a substring of the sender]:substr'
    '-v[Print verbose information]'
    '-q[Limit the processed jobs]'
    '*:filename:_files'
)
_arguments -s $arguments
