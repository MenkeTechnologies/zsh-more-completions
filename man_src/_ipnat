#compdef ipnat

local arguments

arguments=(
    '-C[Delete all entries in the current NAT rule listing]'
    '-d[Enable printing of some extra debugging information]'
    '-F[Delete all active entries in the current NAT translation table]'
    '-h[Print number of hits for each MAP/Redirect filter]'
    '-l[Show the list of current NAT table entry mappings]'
    '-n[No-change mode: prevent ipnat from making any ioctl calls]'
    '-p[Cause any active NAT sessions to be removed along with the rule]'
    '-r[Remove matching NAT rules rather than add them]'
    '-s[Retrieve and display NAT statistics]'
    '-v[Turn verbose mode on]'
    '*:filename:_files'
)
_arguments -s $arguments
