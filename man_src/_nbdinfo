#compdef nbdinfo

local arguments

arguments=(
    '--help[Display brief command line help and exit]'
    '--can[Test whether the server supports the specified flag]:flag'
    '--cannot[Test the negation of flag]:flag'
    '--color[Enable ANSI colours in output]'
    '--no-color[Disable ANSI colours in output]'
    '--content[Show content analysis]'
    '--no-content[Skip content analysis]'
    '--has[Test whether the server has the specified feature]:feature'
    '--is[Test whether the export has the specified property]:property'
    '--json[Display output in JSON format]'
    {-L,--list}'[List all the exports on an NBD server]'
    '--map[Show the block allocation map]'
    '--totals[Show totals in the block allocation map]'
    '--size[Display only the size in bytes of the export]'
    '--uri[Display only the canonical URI]'
    {-V,--version}'[Display the package name and version and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
