#compdef fdesetup

local arguments

arguments=(
    '--defer[Defer enabling FileVault until the user password is obtained]'
    '--user[Short user name]:username'
    '--uuid[User UUID in canonical form]:uuid'
    '--usertoadd[Additional user(s) to be added to FileVault]:username'
    '--inputplist[Acquire configuration information from stdin]'
    '--prompt[Always prompt for information]'
    '--forcerestart[Force a normal restart after FileVault has been successfully configured]'
    '--authrestart[Do an authenticated restart after a successful enable]'
    '--outputplist[Output the recovery key and system information to stdout in plist format]'
    '--keychain[Use the institutional recovery key stored in FileVaultMaster.keychain]'
    '--certificate[Use the certificate data located at the path]:path:_files'
    '--key[Use the keychain file located at the path]:path:_files'
    '--norecoverykey[Do not return a personal recovery key]'
    '--forceatlogin[When using -defer, prompt the designated user at login time]:max_cancel_attempts'
    '--dontaskatlogout[When using -defer, do not prompt at logout]'
    '--extended[Return extended output information for certain commands]'
    '--offline[Display the current offline and locked FileVault volumes]'
    '--device[Device location to be applied for the command]:device'
    '--delayminutes[Number of minutes to delay the authenticated restart]:minutes'
    '*:filename:_files'
)
_arguments -s $arguments
