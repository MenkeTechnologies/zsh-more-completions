#compdef git-cola
# Documentation: https://man.archlinux.org/search?q=git-cola
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--prompt[Prompt for a Git repository]'
    '--repo[Open the specified Git repository]:path:_directories'
    '--version[Print the git-cola version and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
