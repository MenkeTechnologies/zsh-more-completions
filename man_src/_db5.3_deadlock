#compdef db5.3_deadlock

local arguments

arguments=(
    '-a[When a deadlock is detected, abort the locker with the most or fewest locks]'
    '-h[Specify a home directory for the database environment]:directory:_directories'
    '-L[Log the execution to the specified file]:file:_files'
    '-t[Check the database environment at the specified interval]:sec.usec'
    '-V[Write the library version number and exit]'
    '-v[Run in verbose mode]'
    '*:filename:_files'
)
_arguments -s $arguments
