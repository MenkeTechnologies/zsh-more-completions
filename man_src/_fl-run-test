#compdef fl-run-test

local arguments

arguments=(
    '--version[Show program version number and exit]'
    {--help,-h}'[Show this help message and exit]'
    {--quiet,-q}'[Minimal output]'
    {--verbose,-v}'[Verbose output]'
    {--debug,-d}'[FunkLoad and doctest debug output]'
    '--debug-level[Debug level, 3 is more verbose]:level'
    {--url,-u}'[Base URL to bench]:URL'
    {--sleep-time-min,-m}'[Minimum sleep time between requests]:seconds'
    {--sleep-time-max,-M}'[Maximum sleep time between requests]:seconds'
    '--dump-directory[Directory to dump html pages]:directory:_directories'
    {--firefox-view,-V}'[Real time view using firefox]'
    '--no-color[Monochrome output]'
    {--loop-on-pages,-l}'[Loop on pages as fast as possible]:steps'
    {--loop-number,-n}'[Number of loops]:number'
    '--accept-invalid-links[Do not fail if css/image links are not reachable]'
    '--simple-fetch[Do not load additional links like css or images]'
    '--stop-on-fail[Stop tests on first failure or error]'
    {--regex,-e}'[Test names must match the regex]:REGEX'
    '--list[Just list the test names]'
    '*:filename:_files'
)
_arguments -s $arguments
