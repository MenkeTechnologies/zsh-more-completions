#compdef hexedit

local arguments

arguments=(
    {-s,--sector}'[Format the display to have entire sectors]'
    {-m,--maximize}'[Try to maximize the display]'
    '--color[Display colors]'
    {-l,--linelength}'[Set the number of bytes to display per line]:n'
    '(- * :)'{-h,--help}'[Show the usage]'
    '*:filename:_files'
)
_arguments -s $arguments
