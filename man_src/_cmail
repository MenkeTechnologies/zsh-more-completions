#compdef cmail

local arguments

arguments=(
    '-h[Display cmail usage information]'
    '-c[Show the conditions of the GNU General Public License]'
    '-w[Show the warranty notice of the GNU General Public License]'
    '-v[Verbose output]'
    '--remail[Resend the last mail message for that game]'
    '--game[The name of the game to be processed]:name'
    '--me[Your name]:name'
    '--opp[Opponent name]:name'
    '--dir[The directory in which cmail keeps its files]:directory:_directories'
    '--arcdir[The directory in which cmail archives completed games]:directory:_directories'
    '--mailprog[The program used by cmail to send email messages]:program:_files'
    '--logFile[A file in which to dump verbose debugging messages]:file:_files'
    '--event[The PGN Event tag]:event'
    '--site[The PGN Site tag]:site'
    '--round[The PGN Round tag]:round'
    '*:filename:_files'
)
_arguments -s $arguments
