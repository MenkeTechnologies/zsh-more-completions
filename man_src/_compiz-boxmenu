#compdef compiz-boxmenu
# Documentation: https://man.archlinux.org/search?q=compiz-boxmenu
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-h[Show help options]'
    {-m,--menu}'[Use specified file instead of the default menu file]:file:_files'
    {-p,--pin}'[Pin the root menu as soon as it is generated or retrieved]'
    '*:filename:_files'
)
_arguments -s $arguments
