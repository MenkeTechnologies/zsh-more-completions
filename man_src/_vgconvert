#compdef vgconvert

local arguments

arguments=(
    '--bootloaderareasize[Size of bootloader area]:size'
    '--commandprofile[Select command configuration profile]:profile'
    '--config[Override configuration settings]:string'
    {-d,--debug}'[Set debug level]'
    '--driverloaded[Specify whether device-mapper driver is loaded]:yn:(y n)'
    {-f,--force}'[Override checks]'
    '(- * :)'{-h,--help}'[Display help text]'
    '--labelsector[PV label sector number]:number'
    '--lockopt[Lock option string]:string'
    '--longhelp[Display long help text]'
    '--metadatasize[Size of metadata area]:size'
    {-M,--metadatatype}'[Metadata type]:type:(lvm2)'
    '--nolocking[Disable locking]'
    '--profile[Select metadata profile]:profile'
    '--pvmetadatacopies[Number of metadata copies on each PV]:copies:(0 1 2)'
    {-q,--quiet}'[Suppress output]'
    '--reportformat[Select report format]:format:(basic json)'
    {-t,--test}'[Run in test mode]'
    {-v,--verbose}'[Set verbose level]'
    '--version[Display version information]'
    {-y,--yes}'[Answer yes to all prompts]'
    '*:VG name:'
)
_arguments -s $arguments
