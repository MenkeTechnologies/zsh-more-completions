#compdef valadoc-0.48

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Show help options]'
    {-o,--directory}'[Output directory]:directory:_directories'
    {-b,--basedir}'[Base source directory]:directory:_directories'
    {-D,--define}'[Define symbol]:symbol'
    '--profile[Use the given profile instead of the default]:profile:(gobject posix)'
    '--enable-experimental[Enable experimental features]'
    '--enable-experimental-non-null[Enable experimental enhancements for non-null types]'
    '--metadatadir[Look for GIR .metadata files in directory]:directory:_directories'
    '--girdir[Look for .gir files in directory]:directory:_directories'
    '--vapidir[Look for package bindings in directory]:directory:_directories'
    '--pkg[Include binding for package]:package'
    '--driver[Name of a driver or path to a custom driver (DEPRECATED AND IGNORED)]'
    '--importdir[Look for external documentation in directory]:directory:_directories'
    '--import[Include binding for package]:package'
    '--alternative-resource-dir[Alternative resource directories]:directory:_directories'
    '--wiki[Wiki directory]:directory:_directories'
    '--deps[Add packages to the documentation]'
    '--doclet[Name of an included doclet or path to custom doclet]:plugin'
    {-X,--doclet-arg}'[Pass arguments to the doclet]:arg'
    '--no-protected[Remove protected elements from documentation]'
    '--internal[Add internal elements to documentation]'
    '--private[Add private elements to documentation]'
    '--use-svg-images[Generate SVG image charts instead of PNG]'
    '--package-name[Package name]:name'
    '--package-version[Package version]:version'
    '--gir[GObject-Introspection repository file name]:name'
    '--version[Display version number]'
    '--force[Force operation]'
    '--fatal-warnings[Treat warnings as fatal]'
    '--verbose[Show all warnings]'
    '--no-color[Disable colored output]'
    '--target-glib[Target version of glib for code generation]:version'
    '*:filename:_files'
)
_arguments -s $arguments
