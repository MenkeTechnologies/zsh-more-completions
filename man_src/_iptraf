#compdef iptraf

local arguments

arguments=(
    '-i[Immediately start the IP traffic monitor on the specified interface]:iface'
    '-g[Immediately start the general interface statistics]'
    '-d[Immediately start the detailed statistics on the indicated interface]:iface'
    '-s[Immediately monitor TCP and UDP traffic on the specified interface]:iface'
    '-z[Show packet counts by size on the specified interface]:iface'
    '-l[Start the LAN station monitor on the specified interface]:iface'
    '-t[Run the specified facility for only the specified number of minutes]:timeout'
    '-B[Redirect standard output to /dev/null, close standard input, and fork to background]'
    '-L[Specify an alternate log file name]:logfile:_files'
    '-f[Clear all locks and counters]'
    '-u[Allow use of unsupported interfaces as ethernet devices]'
    '-q[Maintained only for compatibility]'
    '-h[Show a command summary]'
    '*:filename:_files'
)
_arguments -s $arguments
