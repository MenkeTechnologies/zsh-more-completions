#compdef Wand-config
# Documentation: https://man.archlinux.org/search?q=Wand-config
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--cflags[Print the compiler flags that were used to compile libWand]'
    '--cppflags[Print the preprocessor flags needed to find the Wand C include files]'
    '--exec-prefix[Print the directory under which target specific binaries and executables are installed]'
    '--ldflags[Print the linker flags needed to link with the Wand library]'
    '--libs[Print the linker flags needed to link a program with libWand]'
    '--version[Print the version of the Wand distribution]'
    '*:filename:_files'
)
_arguments -s $arguments
