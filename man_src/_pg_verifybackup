#compdef pg_verifybackup

local arguments

arguments=(
    {-e,--exit-on-error}'[Exit as soon as a problem with the backup is detected]'
    {-i,--ignore}'[Ignore the specified file or directory]:path:_files'
    {-m,--manifest-path}'[Use the manifest file at the specified path]:path:_files'
    {-n,--no-parse-wal}'[Do not attempt to parse write-ahead log data]'
    {-q,--quiet}'[Do not print anything when a backup is successfully verified]'
    {-s,--skip-checksums}'[Do not verify data file checksums]'
    {-w,--wal-directory}'[Parse WAL files from the specified directory]:path:_directories'
    {-V,--version}'[Print version and exit]'
    {-\?,--help}'[Show help]'
    '*:filename:_files'
)
_arguments -s $arguments
