#compdef tcpnice
# Documentation: https://man.archlinux.org/search?q=tcpnice
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-A[inject TCP tiny window advertisements]'
    '-I[inject ICMP source quench replies]'
    '-M[inject ICMP fragmentation-needed replies with tiny next-hop MTUs]'
    '-i[specify the interface to listen on]:interface'
    '*:filename:_files'
)
_arguments -s $arguments
