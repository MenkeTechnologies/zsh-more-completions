#compdef mysqlrplcheck

local arguments

arguments=(
    '--help[Display help and exit]'
    '--master[Connection information for the master server]:source'
    '--master-info-file[Master info file to examine]:file:_files'
    {-q,--quiet}'[Turn off all messages for quiet execution]'
    '--show-slave-status[Show slave status]'
    '--slave[Connection information for the slave server]:source'
    '--suppress[Suppress warnings]'
    {-v,--verbose}'[Verbose output]'
    '--version[Display version information and exit]'
    '--width[Display width]:number'
    '*:filename:_files'
)
_arguments -s $arguments
