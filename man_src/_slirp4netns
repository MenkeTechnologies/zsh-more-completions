#compdef slirp4netns

# Updated with fixes for descriptions

local arguments

arguments=(
    {-c,--configure}'[Bring up the interface]'
    {-e,--exit-fd}'[Specify the FD for terminating slirp4netns]:fd'
    {-r,--ready-fd}'[Specify the FD to write to when the network is configured]:fd'
    {-m,--mtu}'[Specify MTU (default=1500, max=65521)]:mtu'
    {-6,--enable-ipv6}'[Enable IPv6 (experimental)]'
    {-a,--api-socket}'[Specify API socket path]:path'
    '--cidr[Specify network address CIDR (default=10.0.2.0/24)]:cidr'
    '--disable-host-loopback[Prohibit connecting to 127.0.0.1 on the host namespace]'
    '--netns-type[Specify network namespace type]:type:(path pid)'
    '--userns-path[Specify user namespace path]:path'
    '--enable-sandbox[Create a new mount namespace and drop capabilities]'
    '--enable-seccomp[Enable seccomp to limit syscalls (experimental)]'
    '--outbound-addr[Set outbound IPv4 address to bind to (experimental)]:addr'
    '--outbound-addr6[Set outbound IPv6 address to bind to (experimental)]:addr'
    '--disable-dns[Disable DNS redirect to host (experimental)]'
    '--macaddress[Specify the MAC address of the TAP (only valid with -c)]:mac'
    {-h,--help}'[Show help and exit]'
    {-v,--version}'[Show version and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
