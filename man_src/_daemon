#compdef daemon

local arguments

arguments=(
    '-c[Change the current working directory to root /]'
    '-f[Redirect stdin, stdout and stderr to /dev/null]'
    '-S[Enable syslog output]'
    '-o[Append output from the daemonized process to file]:output file:_files'
    '-m[Redirect output from the child process (1=stdout, 2=stderr, 3=both)]:mode:(1 2 3)'
    '-p[Write the ID of the created process into the pidfile]:pidfile:_files'
    '-P[Write the ID of the daemon process into the pidfile]:pidfile:_files'
    '-r[Supervise and restart the program after a one-second delay if terminated]'
    '-R[Supervise and restart the program after the specified delay]:delay'
    '-t[Set the title for the daemon process]:title'
    '-u[Login name of the user to execute the program under]:user:_users'
    '-s[Set the syslog priority]:priority:(emerg alert crit err warning notice info debug)'
    '-l[Set the syslog facility]:facility:(auth authpriv console cron daemon ftp kern lpr mail news security syslog user uucp local0 local1 local2 local3 local4 local5 local6 local7)'
    '-T[Set the tag appended to all syslog messages]:tag'
    '*:filename:_files'
)
_arguments -s $arguments
