#compdef lilypond-book

local arguments

arguments=(
    {-F,--filter}'[Pipe snippets through FILTER]:filter'
    {-f,--format}'[Use output format]:format:(texi texi-html latex html docbook)'
    '(- * :)'{-h,--help}'[Show this help and exit]'
    {-I,--include}'[Add DIR to include path]:dir:_directories'
    '--info-images-dir[Format Texinfo output so Info will look for images in DIR]:dir:_directories'
    '--left-padding[Pad left side of music to align despite uneven bar numbers (in mm)]:pad'
    '--lily-loglevel[Print lilypond log messages according to LOGLEVEL]:loglevel'
    '--lily-output-dir[Write lily-XXX files to DIR, link into --output dir]:dir:_directories'
    '--load-custom-package[Load additional python package]:package'
    {-l,--loglevel}'[Print log messages according to LOGLEVEL]:loglevel:(NONE ERROR WARNING PROGRESS DEBUG)'
    {-o,--output}'[Write output to DIR]:dir:_directories'
    {-P,--process}'[Process ly_files using COMMAND FILE]:command'
    '--redirect-lilypond-output[Redirect the lilypond output]'
    {-s,--safe}'[Compile snippets in safe mode]'
    '--skip-lily-check[Do not fail if no lilypond output is found]'
    '--skip-png-check[Do not fail if no PNG images are found for EPS files]'
    '--use-source-file-names[Write snippet output files with the same base name as their source file]'
    {-V,--verbose}'[Be verbose]'
    '--version[Show version number and exit]'
    {-w,--warranty}'[Show warranty and copyright]'
    '--latex-program[Run PROG instead of latex or pdflatex]:prog'
    '--texinfo-program[Run PROG instead of texi2pdf]:prog'
    '--pdf[Create PDF files for use with PDFTeX]'
    '*:filename:_files'
)
_arguments -s $arguments
