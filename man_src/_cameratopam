#compdef cameratopam

local arguments

arguments=(
    '--identify_only[Report the format of the input image but do not generate output]'
    '--verbose[Report processing details to standard error]'
    '--quick_interpolate[Use simple bilinear interpolation for quick results]'
    '--half_size[Half-size the output image]'
    '--four_color_rgb[Interpolate RGB as four colors]'
    '--document_mode[Show the raw data as a grayscale image with no interpolation]'
    '--balance_auto[Automatic color balance]'
    '--balance_camera[Use the color balance specified by the camera]'
    '--blue_scale[Adjust the color balance by multiplying the blue channel]:float'
    '--red_scale[Adjust the color balance by multiplying the red channel]:float'
    '--brightness[Change the output brightness, default is 1.0]:float'
    '--no_clip_color[Do not clip colors to prevent pink hues in highlights]'
    '--rgb[Write raw camera colors to the output file]'
    '--secondary[Use the secondary sensor for Fuji Super CCD SR cameras]'
    '--linear[Generate linear PAM output instead of gamma-corrected]'
    '*:filename:_files'
)
_arguments -s $arguments
