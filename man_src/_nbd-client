#compdef nbd-client

local arguments

arguments=(
    {-b,--block-size}'[Use the specified blocksize]:size'
    {-C,--connections}'[Use num connections to the server]:num'
    {-t,--timeout}'[Set the connection timeout]:seconds'
    {-c,--check}'[Check whether the specified nbd device is connected]'
    {-d,--disconnect}'[Disconnect the specified nbd device from the server]'
    {-l,--list}'[Ask the server for a list of available exports]'
    {-p,--persist}'[Immediately try to reconnect an nbd device if the connection is dropped]'
    {-S,--sdp}'[Connect to the server using the Socket Direct Protocol (SDP)]'
    {-s,--swap}'[Specifies that this NBD device will be used as swapspace]'
    {-m,--systemd-mark}'[Mark the process for systemd to avoid killing during shutdown]'
    {-n,--nofork}'[Do not detach and daemonize]'
    {-N,--name}'[Specify the name of the export to use]:name'
    {-u,--unix}'[Connect to the server over a unix domain socket]:path:_files'
    {-F,--certfile}'[Client certificate for TLS authentication]:file:_files'
    {-K,--keyfile}'[Private key for the client certificate]:file:_files'
    {-A,--cacertfile}'[CA certificate for TLS authentication]:file:_files'
    {-H,--tlshostname}'[Hostname for the TLS context]:hostname'
    '*:filename:_files'
)
_arguments -s $arguments
