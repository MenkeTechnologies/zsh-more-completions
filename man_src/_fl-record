#compdef fl-record

local arguments

arguments=(
    '--version[Show program version number and exit]'
    {--help,-h}'[Show a help message and exit]'
    {--verbose,-v}'[Verbose output]'
    {--port,-p}'[TCP port where the proxy listens (defaults to 8090)]:port'
    {--tcp-watch-input,-i}'[Path to an existing TCPWatch capture]:path:_files'
    '*:filename:_files'
)
_arguments -s $arguments
