#compdef htpasswd htpasswd2

local arguments

arguments=(
    '-b[Use batch mode; read password from the command line]'
    '-i[Read the password from stdin without verification]'
    '-c[Create the password file; if it exists, it is deleted first]'
    '-n[Display the results on standard output rather than updating a file]'
    '-m[Use MD5 encryption for passwords (default)]'
    '-B[Use bcrypt encryption for passwords]'
    '-C[Set the computing time used for the bcrypt algorithm]:cost'
    '-d[Use crypt() encryption for passwords]'
    '-s[Use SHA encryption for passwords]'
    '-p[Use plaintext passwords]'
    '-D[Delete user]'
    '-v[Verify password]'
    '*:filename:_files'
)
_arguments -s $arguments
