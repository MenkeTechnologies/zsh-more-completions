#compdef tpm2_hash
# Documentation: https://man.archlinux.org/search?q=tpm2_hash
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-H[hierarchy to use for the ticket]:hierarchy'
    '-g[hash algorithm to use]:algorithm'
    '-o[file to record the hash result]:file:_files'
    '-t[file to record the ticket result]:file:_files'
    '-h[display help information]'
    '-v[display version, supported tctis and exit]'
    '-V[increase verbosity of tool output]'
    '-Q[suppress informational output]'
    '-Z[enable errata fixups]'
    '-T[select the TCTI used for communication]:tcti'
    '*:filename:_files'
)
_arguments -s $arguments
