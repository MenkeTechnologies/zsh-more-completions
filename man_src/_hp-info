#compdef hp-info

local arguments

arguments=(
    {-d,--device}'[Specify device URI]:device_uri'
    {-p,--printer}'[Specify a CUPS printer]:printer'
    {-i,--interactive}'[Run in interactive mode]'
    {-l,--logging}'[Set the logging level]:level:(none info error warn debug)'
    {-g,--ldebug}'[Run in debug mode]'
    '(- * :)'{-h,--help}'[Show help information]'
    '--id[Device ID mode]'
    '-x[Allow device URIs of uninstalled printers]'
    '*:filename:_files'
)
_arguments -s $arguments
