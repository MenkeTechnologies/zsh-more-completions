#compdef fsdb
# Documentation: https://man.archlinux.org/search?q=fsdb
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-d[Enable additional debugging output]'
    '-f[Left for historical reasons, has no meaning]'
    '-r[Open the file system read/only]'
    '*:filename:_files'
)
_arguments -s $arguments
