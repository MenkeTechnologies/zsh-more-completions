#compdef hp-plugin

local arguments

arguments=(
    {-u,--gui}'[Run in GUI mode]'
    {-i,--interactive}'[Run in interactive mode]'
    '--required[Installation for required printer mode only]'
    '--optional[Installation for optional printer mode only]'
    '--lang[Set the language]:language'
    {-p,--path,--plugin}'[Specify the path to the plugin file]:path:_files'
    {-l,--logging}'[Set the logging level]:level:(none info error warn debug)'
    {-g,--ldebug}'[Run in debug mode]'
    '(- * :)'{-h,--help}'[Show help information]'
    '*:filename:_files'
)
_arguments -s $arguments
