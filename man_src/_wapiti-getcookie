#compdef wapiti-getcookie
# Documentation: https://man.archlinux.org/search?q=wapiti-getcookie
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-p,--proxy}'[URL to use as a proxy for HTTP and HTTPS requests]:proxy_url'
    {-d,--data}'[Data to send with the request]:data'
    '*:url:'
)
_arguments -s $arguments
