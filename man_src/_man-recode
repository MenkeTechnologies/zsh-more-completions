#compdef man-recode

local arguments

arguments=(
    {-t,--to-code}'[Convert manual pages to specified encoding]:encoding'
    '--suffix[Append suffix to the input file name to form the output file name]:suffix'
    '--in-place[Overwrite each input file with the output]'
    {-q,--quiet}'[Do not issue error messages when the page cannot be converted]'
    {-d,--debug}'[Print debugging information]'
    '(- * :)'{-h,--help}'[Print a help message and exit]'
    {-V,--version}'[Display version information]'
    '*:filename:_files'
)
_arguments -s $arguments
