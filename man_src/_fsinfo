#compdef fsinfo

local arguments

arguments=(
    '-a[Specify the directory name for automounter mount points]:directory:_directories'
    '-b[Specify the prefix for the bootparams file]:prefix'
    '-d[Specify the prefix for the dumpsets file]:prefix'
    '-e[Define the prefix for the exports files]:prefix'
    '-f[Define the prefix for the fstab files]:prefix'
    '-h[Define the hostname of the destination machine]:hostname'
    '-m[Define the prefix for the automounter files]:prefix'
    '-q[Select quiet mode]'
    '-v[Select verbose mode]'
    '-D[Define a symbol for the preprocessor]:name=string'
    '-I[Pass this option to the preprocessor for configuration files]:directory'
    '-U[Remove an initial definition of a symbol]:name'
    '*:filename:_files'
)
_arguments -s $arguments
