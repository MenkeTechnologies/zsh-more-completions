#compdef driverless-fax
# Documentation: https://man.archlinux.org/search?q=driverless-fax
# Reference accessed: 2026-05-16

local arguments

arguments=(
  '-h[show help]'
  '--help[show help]'
  '--version[show this usage message]'
  '-d[delete or directory]'
  {-v,--debug}'[debug/verbose mode]'
  '--std-ipp-uris[show URIS in standard form]'
  '*:filename:_files'
)

_arguments -s $arguments
