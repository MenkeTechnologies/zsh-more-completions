#compdef abrt-cli

# Autogenerated from man page /usr/share/man/man1/abrt-cli.1.gz
# Updated with latest abrt-cli options

local arguments

arguments=(
    {-v,--verbose}'[Be more verbose]'
    {-b,--bare}'[Print only the problem count]'
    '--detailed[Print detailed report]'
    '--delete[Remove matching problems]'
    {-n,--not-reported}'[List only not-yet-reported problems]'
    '--size[Text max size in kB (default: 1)]:SIZE'
    '--since[List only problems more recent than specified timestamp]:NUM'
    {-u,--unsafe}'[Operate on all problems, not just the current user problems]'
    '--until[List only problems older than specified timestamp]:NUM'
    '*:: :_abrt_cli_commands'
)

_abrt_cli_commands() {
    local -a commands
    commands=(
        'list:List problems'
        'report:Report a problem'
        'info:Print detailed info about a problem'
        'status:Print the count of recent crashes'
        'rm:Remove a problem directory'
    )
    _describe 'command' commands
}

_arguments -s $arguments
