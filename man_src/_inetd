#compdef inetd

local arguments

arguments=(
    '-d[Turn on debugging]'
    '-l[Turn on logging of successful connections]'
    '-w[Turn on TCP Wrapping for external services]'
    '-W[Turn on TCP Wrapping for internal services which are built in to inetd]'
    '-c[Specify the default maximum number of simultaneous invocations of each service]:max'
    '-C[Specify the default maximum number of times a service can be invoked from a single IP in one minute]:rate'
    '-R[Specify the maximum number of times a service can be invoked in one minute]:rate'
    '-s[Specify the default maximum number of simultaneous invocations per IP]:max'
    '-a[Specify one specific IP address to bind to]:address'
    '-p[Specify an alternate file in which to store the process ID]:file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
