#compdef e2image

local arguments

arguments=(
    '-r[Create a raw image file instead of a normal image file]'
    '-Q[Create a QCOW2-format image file]'
    '-f[Override safety checks when used with -r or -Q]'
    '-I[Install metadata from image file back to the device]'
    '-s[Scramble directory entries and zero data blocks for privacy]'
    '-a[Include all data in the image, not just metadata]'
    '-p[Show progress during image creation]'
    '-c[Check blocks before overwriting, skip unchanged blocks]'
    '-n[No-op mode, print blocks that would be written]'
    '-o[Offset to seek to in the source before reading]:offset'
    '-O[Offset to seek to in the destination before writing]:offset'
    '*:filename:_files'
)
_arguments -s $arguments
