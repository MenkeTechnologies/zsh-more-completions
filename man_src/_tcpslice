#compdef tcpslice

local arguments

arguments=(
    '-D[do not discard duplicate packets when merging multiple trace files]'
    '-d[dump the start and end times specified by the given range and exit]'
    '-l[when merging, merge on the basis of relative time]'
    '-R[dump the timestamps of the first and last packets as raw timestamps]'
    '-r[dump timestamps in human-readable format]'
    '-t[dump timestamps in tcpslice format]'
    '-w[write output to file]:file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
