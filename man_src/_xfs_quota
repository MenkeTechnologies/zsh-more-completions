#compdef xfs_quota

local arguments

arguments=(
    '-p[Set the program name for prompts and some error messages]:prog'
    '-x[Enable expert mode]'
    '-f[Enable foreign filesystem mode]'
    '-d[Specify project names or numeric identifiers]:project'
    '-D[Specify a file containing numeric project identifier to directory mappings]:projects_file:_files'
    '-P[Specify a file containing numeric project identifier to project name mappings]:projid_file:_files'
    '-c[Run the specified command instead of interactive mode]:cmd'
    '-V[Print the version number and exit]'
    '-g[Report on group quotas]'
    '-u[Report on user quotas]'
    '-h[Report in human-readable format]'
    '-n[Report numeric IDs rather than names]'
    '-N[Omit the header]'
    '-v[Output verbose information]'
    '-a[Report on all filesystems]'
    '-L[Specify lower ID bound to report on]:lower_id'
    '-U[Specify upper ID bound to report on]:upper_id'
    '-l[Translate IDs to names in lookup]'
    '-t[Perform a terse report]'
    '-C[Set up directory tree quota]'
    '-s[Maintain directory tree quota mechanism]'
    '*:filesystem:_files'
)
_arguments -s $arguments
