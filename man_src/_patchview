#compdef patchview

local arguments

arguments=(
    {-n,--line-number}'[Display the line number that each patch begins at]'
    {-N,--number-files}'[List file numbers beginning at 1 before each filename]'
    {-#,--hunks}'[Only list hunks within the specified range]:range'
    '--lines[Only list hunks containing lines from the original file within range]:range'
    {-F,--files}'[Only list files indicated by the specified range]:range'
    {-p,--strip-match}'[Ignore the first n components of the pathname when matching]:n'
    '--strip[Remove the first n components of the pathname before displaying]:n'
    '--addprefix[Prefix the pathname with PREFIX before displaying]:prefix'
    {-s,--status}'[Show file additions, modifications and removals]'
    {-E,--empty-files-as-removed}'[Treat empty files as absent for file status display]'
    {-i,--include}'[Include only files matching pattern]:pattern'
    {-x,--exclude}'[Exclude files matching pattern]:pattern'
    {-z,--decompress}'[Decompress files with .gz and .bz2 extensions]'
    {-H,--with-filename}'[Print the name of the patch file containing each patch]'
    {-h,--no-filename}'[Suppress the name of the patch file containing each patch]'
    {-v,--verbose}'[Verbose output]'
    '--help[Display a short usage message]'
    '--version[Display the version number of patchview]'
    '--filter[Behave like filterdiff instead]'
    '--grep[Behave like grepdiff instead]'
    '*:filename:_files'
)
_arguments -s $arguments
