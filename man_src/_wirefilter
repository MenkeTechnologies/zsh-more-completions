#compdef wirefilter

local arguments

arguments=(
    '-f[Use a startup configuration file]:rcfile:_files'
    '-l[Percentage of loss as a floating point number]:loss'
    '-L[Gilbert model for bursty errors]:lostburst'
    '-d[Extra delay in milliseconds]:delay'
    '-D[Percentage of dup packets]:dup'
    '-b[Channel bandwidth in Bytes/sec]:bandwidth'
    '-s[Interface speed in Bytes/sec]:speed'
    '-c[Channel buffer size in Bytes]:channel_bufsize'
    '-n[Number of bits damaged per megabyte]:factor'
    '-m[Packets longer than mtu_size are discarded]:size'
    '-N[Disable FIFO, allowing packets to be reordered]'
    '-M[UNIX socket for management parameters]:socket:_files'
    '-v[Set vde_plug paths]:vde_plug1\:vde_plug2'
    '--mgmtmode[Set the access mode of the mgmt socket]:mode'
    '--daemon[Run as a daemon]'
    '--pidfile[Save pid to file]:pathname:_files'
    '--blinkid[Define the id sent for each packet to the blink server]:name'
    '--blink[Send log messages to the specified socket]:socket:_files'
    '*:filename:_files'
)
_arguments -s $arguments
