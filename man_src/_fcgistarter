#compdef fcgistarter
# Documentation: https://man.archlinux.org/search?q=fcgistarter
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-c[FastCGI program command]:command'
    '-p[Port which the program will listen on]:port'
    '-i[Interface which the program will listen on]:interface'
    '*:filename:_files'
)
_arguments -s $arguments
