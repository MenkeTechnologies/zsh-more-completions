#compdef virtproxyd

local arguments

arguments=(
    {-h,--help}'[Display program help]'
    {-v,--verbose}'[Verbose messages]'
    {-d,--daemon}'[Run as a daemon and write PID file]'
    {-t,--timeout}'[Exit after timeout period]:seconds'
    {-f,--config}'[Configuration file]:file:_files'
    {-V,--version}'[Display version information]'
    {-p,--pid-file}'[Change name of PID file]:file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
