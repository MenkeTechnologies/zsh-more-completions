#compdef kismetdb_strip_packets

local arguments

arguments=(
    {-i,--in}'[Input kismetdb file]:filename:_files'
    {-o,--out}'[Output kismetdb file with packet content stripped]:filename:_files'
    {-v,--verbose}'[Verbose output]'
    {-f,--force}'[Force writing to the target file, even if it exists]'
    '*:filename:_files'
)
_arguments -s $arguments
