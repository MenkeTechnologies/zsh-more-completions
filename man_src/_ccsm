#compdef ccsm

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Show this help message and exit]'
    {-p,--plugin}'[Directly jump to the page of the specified plugin]:plugin'
    {-c,--category}'[Directly jump to the specified category]:category'
    {-v,--version}'[Show version]'
    '*:filename:_files'
)
_arguments -s $arguments
