#compdef rlog

# Autogenerated from man page
# Updated with latest rlog options

local arguments

arguments=(
    '-R[print only the name of the RCS file]'
    '-h[print only the RCS pathname, working pathname, head, default branch, access list, locks, symbolic names, and suffix]'
    '-t[print the same as -h, plus the descriptive text]'
    '-N[do not print the symbolic names]'
    '-b[print information about the revisions on the default branch]'
    '-d[print information about revisions with a checkin date/time in the ranges given]:"dates"'
    '-l[print information about locked revisions only]:lockers'
    '-r[print information about revisions given in the comma-separated list]:revisions'
    '-s[print information about revisions whose state attributes match one of the states]:states'
    '-w[print information about revisions checked in by users with specified login names]:logins'
    '-T[this option has no effect, present for compatibility]'
    '-V[print RCS version number]'
    '-x[use suffixes to characterize RCS files]:"suffixes"'
    '-z[use zone as the time zone for keyword substitution]:zone'
    '-L[ignore RCS files that have no locks set]'
    '*:filename:_files'
)
_arguments -s $arguments
