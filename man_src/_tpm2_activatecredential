#compdef tpm2_activatecredential

local arguments

arguments=(
    '-H[the object associated with the created certificate by CA]:handle'
    '-k[handle of loaded key used to decrypt the random seed]:key_handle'
    '-C[path to a key context file]:key_context_file:_files'
    '-P[authorization value for the key handle]:password'
    '-e[the endorsement password]:password'
    '-f[path containing the two structures needed by activate credential]:file:_files'
    '-o[path to record the secret to decrypt the certificate]:file:_files'
    '-h[display help information]'
    '-v[display version, supported tctis and exit]'
    '-V[increase verbosity of tool output]'
    '-Q[suppress informational output]'
    '-Z[enable errata fixups]'
    '-T[select the TCTI used for communication]:tcti'
    '*:filename:_files'
)
_arguments -s $arguments
