#compdef hcxpcapngtool

local arguments

arguments=(
    '-o[Output PMKID/EAPOL hash file (hashcat -m 22000)]:file:_files'
    '-E[Output wordlist with ESSIDs]:file:_files'
    '-I[Output unsorted identity list]:file:_files'
    '-U[Output unsorted username list]:file:_files'
    '--eapmd5[Output EAP MD5 CHALLENGE (hashcat -m 4800)]:file:_files'
    '-h[Show help]'
    '-v[Show version]'
    '--all[Show all hash lines including duplicates]'
    '--eapoltimeout[Set EAPOL timeout in milliseconds]:timeout'
    '--nonce-error-corrections[Set nonce error correction value]:value'
    '--ignore-ie[Ignore information elements]'
    '--max-essids[Maximum number of ESSIDs]:count'
    '-m[Filter by MAC address]:mac'
    '--eapmd5-john[Output EAP MD5 in John format]:file:_files'
    '--eapleap[Output EAP LEAP hashes]:file:_files'
    '--nmea[Output NMEA GPS data]:file:_files'
    '--log[Output log file]:file:_files'
    '--raw-out[Output raw capture data]:file:_files'
    '--raw-in[Input raw capture data]:file:_files'
    '--pmkid[Output deprecated PMKID file (hashcat -m 16800)]:file:_files'
    '--hccapx[Output in hccapx format]:file:_files'
    '--hccap[Output in hccap format]:file:_files'
    '--john[Output in John the Ripper format]:file:_files'
    '--prefix[Set output filename prefix]:prefix'
    '--help[Show help]'
    '--version[Show version]'
    '*:filename:_files'
)
_arguments -s $arguments
