#compdef ntop

local arguments

arguments=(
    {-p,--protocols}'[Specify protocols to monitor]:protocols:_files'
    {-m,--local-subnets}'[Local subnets]:subnets'
    '-h[Create a dump file of the network traffic]:dumpfile:_files'
    {-O,--output-packet-path}'[Specify output packet path]:path:_directories'
    '-W[Set the HTTP server port]:port'
    {-A,--set-admin-password}'[Set the admin password]:password'
    '-B[Set the capture filter expression]:filter'
    '--filter-expression[Set BPF filter expression]:expression'
    {-L,--use-syslog}'[Use syslog for logging]:facility'
    '--skip-version-check[Skip the online version check]:toggle:(yes no)'
    '*:filename:_files'
)
_arguments -s $arguments
