#compdef fish_key_reader

local arguments

arguments=(
    {-c,--continuous}'[Run in continuous mode, reading multiple key sequences]'
    {-d,--debug}'[Enable debug output]:category_glob'
    {-D,--debug-stack-frames}'[Specify how many stack frames to display for debug messages]:level'
    '(- * :)'{-h,--help}'[Display help and exit]'
    {-v,--version}'[Display version and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
