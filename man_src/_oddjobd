#compdef oddjobd

local arguments

arguments=(
    '-n[Do not fork and become a daemon process]'
    '-d[Print debugging messages to stderr, implies -n]'
    '-p[Store the daemon process ID in the named file]:pidfile:_files'
    '-c[Read the daemon configuration from the named file]:config file:_files'
    '-S[Connect to the session bus instead of the system bus]'
    '-t[Amount of time between attempts to reconnect to the bus]:timeout'
    '*:filename:_files'
)
_arguments -s $arguments
