#compdef captest

local arguments

arguments=(
    '--drop-all[Drop all capabilities and clear the bounding set]'
    '--drop-caps[Drop just traditional capabilities]'
    '--id[Change to uid and gid 99, drop supplemental groups, and clear the bounding set]'
    '--init-grp[Change to uid and gid 99 and add any supplemental groups for that account]'
    '--text[Output the effective capabilities in text rather than numerically]'
    '--lock[Prevent child processes from regaining privileges if the uid is 0]'
    '*:filename:_files'
)
_arguments -s $arguments
