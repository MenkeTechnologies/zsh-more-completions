#compdef vendstat

local arguments

arguments=(
    {-N,--N}'[Show IS3 or IS4 general information]'
    {-w,--w}'[Show IS3 port xmit wait counters]'
    {-i,--i}'[Show IS4 counter group info]'
    {-c,--c}'[Configure IS4 counter groups]:num'
    {-R,--Read}'[Read configuration space record at addr]:addr,mask'
    {-W,--Write}'[Write configuration space record at addr]:addr,val,mask'
    {-z,--config}'[Use config file]:file:_files'
    {-C,--Ca}'[CA name to use]:ca_name'
    {-P,--Port}'[CA port number to use]:port_num'
    {-L,--Lid}'[Use LID address argument]'
    {-G,--Guid}'[Use GUID address argument]'
    {-t,--timeout}'[Timeout in ms]:timeout'
    {-s,--sm_port}'[SM port lid]:lid'
    {-e,--errors}'[Show send and receive errors]'
    {-v,--verbose}'[Increase verbosity level]'
    {-d,--debug}'[Raise debug level]'
    {-h,--help}'[Show help message]'
    {-V,--version}'[Show version]'
    '*:filename:_files'
)
_arguments -s $arguments
