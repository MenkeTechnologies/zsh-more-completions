#compdef tpm2_load

local arguments

arguments=(
    '-H[the parent object handle]:handle'
    '-c[filename for parent context]:file:_files'
    '-P[password for parent key]:password'
    '-u[file containing the public portion of the object]:file:_files'
    '-r[file containing the sensitive portion of the object]:file:_files'
    '-n[file to save the name structure of the object]:file:_files'
    '-C[file to save the object context to]:file:_files'
    '-S[input session handle]:session_handle'
    '-h[display help information]'
    '-v[display version, supported tctis and exit]'
    '-V[increase verbosity of tool output]'
    '-Q[suppress informational output]'
    '-Z[enable errata fixups]'
    '-T[select the TCTI used for communication]:tcti'
    '*:filename:_files'
)
_arguments -s $arguments
