#compdef urxvtd

local arguments

arguments=(
    {-q,--quiet}'[Suppress the startup message]'
    {-o,--opendisplay}'[Force urxvtd to open a connection to the current display and keep it open]'
    {-f,--fork}'[Fork after binding to the control socket]'
    {-m,--mlock}'[Call mlockall on itself to lock all pages in memory]'
    '*:filename:_files'
)
_arguments -s $arguments
