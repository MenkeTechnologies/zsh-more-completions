#compdef vshadowinfo
# Documentation: https://man.archlinux.org/search?q=vshadowinfo
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-a[Show allocation information]'
    '-h[Show this help]'
    '-o[Specify the volume offset in bytes]:offset'
    '-v[Verbose output to stderr]'
    '-V[Print version]'
    '*:filename:_files'
)
_arguments -s $arguments
