#compdef thunar-volman

local arguments

arguments=(
    {-a,--device-added}'[manually tell Thunar about a device]:udi'
    {-c,--configure}'[configure management of removable drives and media]'
    {-v,--version}'[print version information and exit]'
    '--display[X display to use]:display'
    '*:filename:_files'
)
_arguments -s $arguments
