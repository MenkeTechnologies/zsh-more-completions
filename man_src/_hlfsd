#compdef hlfsd

local arguments

arguments=(
    '-a[Alternate directory]:dir:_directories'
    '-c[Caching interval in seconds]:interval'
    '-f[Force fast startup]'
    '-g[Set the special group HLFS_GID]:group'
    '-h[Print a brief help message and exit]'
    '-i[Map-reloading interval in seconds]:interval'
    '-l[Specify a log file for recording events]:logfile:_files'
    '-n[No verify]'
    '-o[Mount options]:options'
    '-p[Print PID]'
    '-v[Display version information]'
    '-x[Specify run-time logging options]:log_options'
    '-C[Force hlfsd to run on systems that cannot turn off the NFS attribute-cache]'
    '-D[Select from a variety of debugging options]:debug_options'
    '-P[Read user-name, user-id, and home directory info from the specified file]:password_file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
