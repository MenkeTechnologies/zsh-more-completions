#compdef ts_uinput

local arguments

arguments=(
    {-d,--daemonize}'[start ts_uinput as a daemon and return]'
    {-v,--verbose}'[print debug information to stdout and stderr]'
    {-n,--name}'[set the name of the new input event device]:name'
    {-i,--idev}'[explicitly choose the input event device]:device:_files'
    {-f,--fbdev}'[explicitly choose the framebuffer device]:device:_files'
    {-s,--slots}'[explicitly set the possible concurrent touch contacts]:slots'
    {-b,--nofb}'[read screen resolution values from the input device, not the framebuffer]'
    '*:filename:_files'
)
_arguments -s $arguments
