#compdef julia

local arguments

arguments=(
    {-v,--version}'[Display version information]'
    {-h,--help}'[Print help message]'
    '--project[Set dir as the home project/environment]:dir:_directories'
    {-J,--sysimage}'[Start up with the given system image file]:file:_files'
    '--sysimage-native-code[Use precompiled code from system image if available]:yn:(yes no)'
    {-H,--home}'[Set location of julia executable]:dir:_directories'
    '--startup-file[Load ~/.julia/config/startup.jl]:yn:(yes no)'
    '--handle-signals[Enable or disable default signal handlers]:yn:(yes no)'
    {-e,--eval}'[Evaluate expression]:expr'
    {-E,--print}'[Evaluate expression and display the result]:expr'
    {-L,--load}'[Load file immediately on all processors]:file:_files'
    {-t,--threads}'[Enable n threads]:n'
    {-p,--procs}'[Run n local processes]:n'
    '--machine-file[Run processes on hosts listed in file]:file:_files'
    '-i[Interactive mode; REPL runs and isinteractive() is true]'
    '--banner[Enable or disable startup banner]:yn:(yes no auto)'
    '--color[Enable or disable color text]:yn:(yes no auto)'
    '--history-file[Load or save history]:yn:(yes no)'
    '--compile[Enable or disable compiler]:yn:(yes no all min)'
    {-C,--cpu-target}'[Limit usage of CPU features up to target]:target'
    {-O,--optimize}'[Run time-intensive code optimizations]:level'
    '--min-optlevel[Set the minimum optimization level]:n'
    '-g[Enable generation of full debug info]:level'
    '--inline[Control whether inlining is permitted]:yn:(yes no)'
    '--check-bounds[Emit bounds checks always, never, or respect @inbounds declarations]:yn:(yes no auto)'
    '--math-mode[Always use IEEE semantics for math or adhere to declarations]:mode:(ieee user)'
    '--depwarn[Enable or disable syntax and method deprecation warnings]:yn:(yes no error)'
    '--warn-overwrite[Enable or disable method overwrite warnings]:yn:(yes no)'
    '--output-o[Generate an object file]:name:_files'
    '--output-ji[Generate a system image data file]:name:_files'
    '--output-bc[Generate LLVM bitcode]:name:_files'
    '--output-incremental[Generate an incremental output file]:yn:(yes no)'
    '--code-coverage[Count executions of source lines]:type:(user all none)'
    '--track-allocation[Count bytes allocated by each source line]:type:(user all none)'
    '*:filename:_files'
)
_arguments -s $arguments
