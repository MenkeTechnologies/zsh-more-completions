#compdef ippeveprinter

local arguments

arguments=(
    '--help[Show program usage]'
    '--no-web-forms[Disable the web interface forms used to update the media and supply levels]'
    '--version[Show the CUPS version]'
    '-2[Report support for two-sided (duplex) printing]'
    '-D[Set the device URI for print output]:device_uri'
    '-F[Specify the output MIME media type]:output_type'
    '-M[Set the manufacturer of the printer]:manufacturer'
    '-P[Load printer attributes from the specified PPD file]:filename:_files'
    '-V[Specify the maximum IPP version to report]:version'
    '-c[Run the specified command for each document that is printed]:command'
    '-d[Specify the directory that will hold the print files]:spool_dir:_directories'
    '-f[Specify a list of MIME media types that the server will accept]:types'
    '-i[Specify the printer icon file for the server]:iconfile:_files'
    '-k[Keep the print documents in the spool directory rather than deleting them]'
    '-l[Specify the human-readable location string]:location'
    '-m[Specify the model name of the printer]:model'
    '-n[Specify the hostname that is reported by the server]:hostname:_hosts'
    '-p[Specify the port number to listen on]:port'
    '-r[Specify the DNS-SD subtype(s) to advertise]:subtype'
    '-s[Specify the printer speed in pages per minute]:speed'
    '-v[Be very verbose when logging activity to standard error]'
    '*:filename:_files'
)
_arguments -s $arguments
