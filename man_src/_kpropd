#compdef kpropd

local arguments

arguments=(
    '-r[Specify the realm of the master server]:realm'
    '-A[Specify the server to be contacted for incremental updates]:admin_server'
    '-f[Specify the filename where the dumped principal database file is stored]:file:_files'
    '-p[Specify the pathname to the kdb5_util program]:path:_files'
    '-d[Turn on debug mode]'
    '-t[In standalone mode, exit after one dump file is received]'
    '-P[Allow for an alternate port number for kpropd to listen on]:port'
    '-a[Specify the path to the kpropd ACL file]:acl_file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
