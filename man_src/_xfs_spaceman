#compdef xfs_spaceman

local arguments

arguments=(
    '-c[Run the specified command]:cmd'
    '-a[Collect free space information from this allocation group]:agno'
    '-b[Establish that histogram bin sizes are successive powers of two]'
    '-e[Print extent counts per AG]'
    '-h[Print histogram of free space]'
    '-m[Limit the number of extents]'
    '-d[Print debugging information such as the raw free space extent information]'
    '-g[Print the free space block and extent counts for each AG]'
    '-r[Query the realtime device for free space information]'
    '-s[Display a summary of the free space information found]'
    '-u[Report on unwritten extents]'
    '-p[Report on preallocation]'
    '-f[Trim free space]'
    '*:filesystem:_files'
)
_arguments -s $arguments
