#compdef fuse-overlayfs
# Documentation: https://man.archlinux.org/search?q=fuse-overlayfs
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-h,--help}'[Print help]'
    {-V,--version}'[Print version]'
    '-d[Enable debug output (implies -f)]'
    '-f[Foreground operation]'
    '-s[Disable multi-threaded operation]'
    '-o[Mount options]:options'
    '*:filename:_files'
)

_arguments -s $arguments
