#compdef fitstopnm

local arguments

arguments=(
    '--image[Specify which image in the FITS file to read]:number'
    '--min[Override the min value from the FITS header]:value'
    '--max[Override the max value from the FITS header]:value'
    '--scanmax[Force the program to scan the data for min and max]'
    '--printmax[Print the min and max values and exit]'
    '--noraw[Force the program to produce an ASCII portable anymap]'
    '*:filename:_files'
)
_arguments -s $arguments
