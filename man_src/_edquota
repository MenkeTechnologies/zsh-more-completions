#compdef edquota

local arguments

arguments=(
    {-r,--remote}'[Edit also non-local quota using rpc.rquotad on remote server]'
    {-m,--no-mixed-pathnames}'[Do not use mixed pathnames for NFSv4 mountpoints]'
    {-u,--user}'[Edit the user quota (default)]'
    {-g,--group}'[Edit the group quota]'
    {-p,--prototype}'[Duplicate the quotas of the prototypical user for each specified user]:protoname'
    '--always-resolve[Always try to translate user/group name to uid/gid]'
    {-F,--format}'[Edit quota for specified format]:format-name'
    {-f,--filesystem}'[Perform operations only for given filesystem]:filesystem'
    {-t,--edit-period}'[Edit the soft time limits for each filesystem]'
    {-T,--edit-times}'[Edit time for the user/group when softlimit is enforced]'
    '*:filename:_files'
)
_arguments -s $arguments
