#compdef genl
# Documentation: https://man.archlinux.org/search?q=genl
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Show summary of options]'
    {-V,--Version}'[Show version of program]'
    {-s,--stats,--statistics}'[Show object statistics]'
    {-d,--details}'[Show object details]'
    {-r,--raw}'[Dump raw output only]'
    '*:filename:_files'
)
_arguments -s $arguments
