#compdef ippool

local arguments

arguments=(
    '-i[Set the IP address for the operation]:ipaddr/netmask'
    '-m[Set the pool name for the current operation]:name'
    '-M[Specify an alternative path to /dev/kmem]:core:_files'
    '-N[Specify an alternative path to lookup symbol name information]:namelist:_files'
    '-o[Set the role with which this pool is to be used]:role'
    '-S[Set the hashing seed to the number specified]:seed'
    '-t[Set the type of pool being defined]:type'
    '-T[Set the expiration of the node being added]:ttl'
    '-d[Toggle debugging of processing the configuration file]'
    '-n[No-change mode: prevent ippool from making any ioctl calls]'
    '-v[Turn verbose mode on]'
    '-a[Add a new data node to an existing pool in the kernel]'
    '-A[Add a new empty pool to the kernel]'
    '-f[Read IP pool configuration information from the file]:file:_files'
    '-F[Flush loaded pools from the kernel]'
    '-l[Display a list of pools currently loaded into the kernel]'
    '-r[Remove an existing data node from a pool in the kernel]'
    '-R[Remove an existing pool from within the kernel]'
    '-s[Display IP pool statistical information]'
    '-u[When parsing a configuration file, remove pool data from the kernel]'
    '*:filename:_files'
)
_arguments -s $arguments
