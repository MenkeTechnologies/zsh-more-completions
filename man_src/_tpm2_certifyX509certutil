#compdef tpm2_certifyX509certutil

local arguments

arguments=(
    {-o,--outcert}'[file where the certificate will be written]:file:_files'
    {-d,--days}'[number of days the certificate will be valid]:days'
    {-i,--issuer}'[the issuer of the certificate]:issuer'
    {-s,--subject}'[the subject of the certificate]:subject'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    {-V,--verbose}'[increase verbosity of tool output]'
    {-Q,--quiet}'[suppress informational output]'
    {-Z,--enable-errata}'[enable errata fixups]'
    {-R,--autoflush}'[autoflush objects created by the command]'
    '*:filename:_files'
)
_arguments -s $arguments
