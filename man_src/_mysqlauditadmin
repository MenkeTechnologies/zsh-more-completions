#compdef mysqlauditadmin

local arguments

arguments=(
    '--help[Display help and exit]'
    '--audit-log-name[Full path and filename of the audit log file]:file:_files'
    '--copy-to[Destination path for the copied audit log]:path:_files'
    '--remote-login[User name and host for remote login]:user@host'
    '--show-options[Show all options]'
    '--server[Connection information for the server]:server'
    '--value[Value for the audit log rotate command]:value'
    '--file-stats[Display audit log file statistics]'
    {-v,--verbose}'[Verbose output]'
    '--version[Display version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
