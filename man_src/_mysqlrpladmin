#compdef mysqlrpladmin

local arguments

arguments=(
    '--help[Display help and exit]'
    '--candidates[Connection information for candidate slave servers]:connections'
    '--demote-master[Make the old master a slave after switchover]'
    '--discover-slaves-login[User and password for discovering slaves]:user:password'
    '--exec-after[External script to execute after failover]:script:_files'
    '--exec-before[External script to execute before failover]:script:_files'
    '--force[Override slave eligibility checks]'
    {-f,--format}'[Health report display format]:format:(grid csv tab vertical)'
    '--log[Log file path]:file:_files'
    '--log-age[Days to keep log entries]:days'
    '--master[Connection information for the master server]:connection'
    '--max-position[Max position difference for slave election]:position'
    '--new-master[Connection information for the new master]:connection'
    '--no-health[Do not display health report]'
    '--ping[Number of seconds for ping timeout]:seconds'
    {-q,--quiet}'[Turn off all messages for quiet execution]'
    '--rpl-user[Replication user and password]:user:password'
    '--script-threshold[Return code threshold for exec scripts]:return_code'
    '--seconds-behind[Maximum seconds behind master for health check]:seconds'
    '--slaves[Connection information for slave servers]:connections'
    '--timeout[Timeout for waiting on slaves]:seconds'
    {-v,--verbose}'[Verbose output]'
    '--version[Display version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
