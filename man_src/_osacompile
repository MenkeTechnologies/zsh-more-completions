#compdef osacompile

local arguments

arguments=(
    '-l[Override the language for any plain text files]:language'
    '-e[Enter one line of a script]:statement'
    '-o[Place the output in the specified file]:file:_files'
    '-x[Save the resulting script as execute-only]'
    '-s[Create a stay-open applet]'
    '-u[Use startup screen]'
    '-a[Create the applet for the specified target architecture]:arch'
    '-d[Place the resulting script in the data fork of the output file]'
    '-r[Place the resulting script in the resource fork of the output file]'
    '-t[Set the output file type]:type'
    '-c[Set the output file creator]:creator'
    '*:filename:_files'
)
_arguments -s $arguments
