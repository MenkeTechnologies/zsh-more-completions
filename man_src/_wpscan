#compdef wpscan

local arguments

arguments=(
    '--url[The URL of the blog to scan]:URL'
    '(- * :)'{-h,--help}'[Display the simple help and exit]'
    '--hh[Display the full help and exit]'
    '--version[Display the version and exit]'
    {-v,--verbose}'[Verbose mode]'
    '--banner[Whether or not to display the banner]'
    {-o,--output}'[Output to file]:file:_files'
    {-f,--format}'[Output results in the format supplied]:format:(cli-no-colour cli-no-color cli json)'
    '--detection-mode[Set detection mode]:mode:(mixed passive aggressive)'
    {--random-user-agent,--rua}'[Use a random user-agent for each scan]'
    {-t,--max-threads}'[The max threads to use]:value'
    '--throttle[Milliseconds to wait before doing another web request]:ms'
    '--request-timeout[The request timeout in seconds]:seconds'
    '--connect-timeout[The connection timeout in seconds]:seconds'
    '--disable-tls-checks[Disable SSL/TLS certificate verification]'
    '--proxy[Proxy to use]:proxy'
    '--cookie-string[Cookie string to use in requests]:cookie'
    '--cookie-jar[File to read and write cookies]:file:_files'
    '--force[Do not check if the target is running WordPress]'
    '--update[Update the database]'
    {-e,--enumerate}'[Enumeration process options]:opts'
    '--exclude-content-based[Exclude all responses matching the regexp]:regexp'
    '--plugins-detection[Use the supplied mode to enumerate plugins]:mode:(mixed passive aggressive)'
    '--plugins-version-detection[Use the supplied mode to check plugins versions]:mode:(mixed passive aggressive)'
    {-P,--passwords}'[List of passwords to use during the password attack]:file:_files'
    {-U,--usernames}'[List of usernames to use during the password attack]:list'
    '--multicall-max-passwords[Maximum number of passwords to send per request with XMLRPC multicall]:max'
    '--password-attack[Force the supplied attack to be used]:attack'
    {--user-agent,--ua}'[Set user agent]:value'
    '--http-auth[HTTP authentication]:login\:password'
    '--proxy-auth[Proxy authentication]:login\:password'
    '--wp-content-dir[WordPress content directory]:dir'
    '--wp-plugins-dir[WordPress plugins directory]:dir'
    '--stealthy[Alias for --random-user-agent --detection-mode passive --plugins-version-detection passive]'
    '*:filename:_files'
)
_arguments -s $arguments
