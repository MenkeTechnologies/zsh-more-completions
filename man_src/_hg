#compdef hg

local arguments

arguments=(
    {-R,--repository}'[Repository root directory or name of overlay bundle file]:repository:_directories'
    '--cwd[Change working directory]:dir:_directories'
    {-y,--noninteractive}'[Do not prompt, automatically pick the first choice for all prompts]'
    {-q,--quiet}'[Suppress output]'
    {-v,--verbose}'[Enable additional output]'
    '--color[When to colorize]:type:(boolean always auto never debug)'
    '--config[Set/override config option (use section.name=value)]:config'
    '--debug[Enable debugging output]'
    '--debugger[Start debugger]'
    '--encoding[Set the charset encoding]:encoding'
    '--encodingmode[Set the charset encoding mode]:mode:(strict)'
    '--traceback[Always print a traceback on exception]'
    '--time[Time how long the command takes]'
    '--profile[Print command execution profile]'
    '--version[Output version information and exit]'
    '(- * :)'{-h,--help}'[Display help and exit]'
    '--hidden[Consider hidden changesets]'
    '--pager[When to paginate]:type:(boolean always auto never)'
    '*:filename:_files'
)
_arguments -s $arguments
