#compdef tpm2_createak

local arguments

arguments=(
    {-P,--eh-auth}'[authorization value for the endorsement hierarchy]:auth'
    {-p,--ak-auth}'[authorization value for the attestation key object]:auth'
    {-C,--ek-context}'[the endorsement key object]:object:_files'
    {-c,--ak-context}'[file path to save the attestation key object context]:file:_files'
    {-G,--key-algorithm}'[specify the attestation key algorithm]:algorithm'
    {-g,--hash-algorithm}'[specify the digest algorithm for signing]:algorithm'
    {-s,--signing-algorithm}'[the signing algorithm]:algorithm'
    {-u,--public}'[file to save the public portion of the attestation key]:file:_files'
    {-n,--ak-name}'[file to save the attestation key name]:file:_files'
    {-r,--private}'[output file for the sensitive portion of the object]:file:_files'
    {-f,--format}'[format selection for the public key output file]:format'
    {-q,--ak-qualified-name}'[the qualified name of the attestation key object]:file:_files'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    {-V,--verbose}'[increase verbosity of tool output]'
    {-Q,--quiet}'[suppress informational output]'
    {-Z,--enable-errata}'[enable errata fixups]'
    {-R,--autoflush}'[autoflush objects created by the command]'
    '*:filename:_files'
)
_arguments -s $arguments
