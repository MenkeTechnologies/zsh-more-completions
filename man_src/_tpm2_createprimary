#compdef tpm2_createprimary

local arguments

arguments=(
    '-H[hierarchy under which the object is created]:hierarchy'
    '-P[authorization string for the hierarchy]:password'
    '-K[authorization string for the newly created object]:password'
    '-g[hash algorithm to use]:algorithm'
    '-G[algorithm for generated key]:algorithm'
    '-C[file to store the object context]:file:_files'
    '-L[file containing the policy digest]:file:_files'
    '-A[object attributes]:attributes'
    '-S[input session handle]:session_handle'
    '-h[display help information]'
    '-v[display version, supported tctis and exit]'
    '-V[increase verbosity of tool output]'
    '-Q[suppress informational output]'
    '-Z[enable errata fixups]'
    '-T[select the TCTI used for communication]:tcti'
    '*:filename:_files'
)
_arguments -s $arguments
