#compdef gtags

local arguments

arguments=(
    '--accept-dotfiles[Accept files and directories whose names begin with a dot]'
    '-c[Make tag files in compact format]'
    '--compact[Make tag files in compact format]'
    '-d[Print directories which are selected by the configuration file]'
    '--dump[Dump a tag file]:tag_file:_files'
    '-f[Give a list of candidates of target files]:file:_files'
    '--file[Give a list of candidates of target files]:file:_files'
    '--gtagsconf[Set the path of configuration file]:file:_files'
    '--gtagslabel[Set the label of configuration file]:label'
    '-I[Read a list of files]:file:_files'
    '-i[Incremental update]'
    '--incremental[Incremental update]'
    '--explain[Explain the filter and exit]'
    '-O[Use objdir for the tag files]'
    '--objdir[Use objdir for the tag files]'
    '-q[Quiet mode]'
    '--quiet[Quiet mode]'
    '-v[Verbose mode]'
    '--verbose[Verbose mode]'
    '--version[Show version number]'
    '-w[Print warning messages]'
    '--warning[Print warning messages]'
    '*:filename:_files'
)
_arguments -s $arguments
