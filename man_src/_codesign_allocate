#compdef codesign_allocate

local arguments

arguments=(
    '-i[Specify the input file]:file:_files'
    '-o[Specify the output file]:file:_files'
    '-a[Specify architecture and code signing data size]:arch size'
    '-A[Specify architecture as cputype,cpusubtype pair and size]:cputype cpusubtype size'
    '-r[Remove the code signature data and LC_CODE_SIGNATURE load command]'
    '-p[Page align the code signature data by padding string table]'
    '*:filename:_files'
)
_arguments -s $arguments
