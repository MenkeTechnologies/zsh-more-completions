#compdef mariadb-client-test-embedded mysql_client_test_embedded

local arguments

arguments=(
    {-\?,--help}'[Display help and exit]'
    {-b,--basedir}'[Base directory for tests]:dir_name:_directories'
    {-t,--count}'[Number of times to run the tests]:count'
    {-D,--database}'[Database to use]:db_name'
    {-\#,--debug}'[Write debugging log]:debug_options'
    {-g,--getopt-ll-test}'[Option for getopt testing]:option'
    {-h,--host}'[Connect to host]:host_name:_hosts'
    {-p,--password}'[Password to use for connection]:password'
    {-P,--port}'[Port number for connection]:port_num'
    {-A,--server-arg}'[Argument passed to embedded server]:arg'
    {-T,--show-tests}'[Show all available test cases]'
    {-s,--silent}'[Be more silent]'
    {-S,--socket}'[Socket file for connection]:path:_files'
    {-c,--testcase}'[Also write test output to a file]'
    {-u,--user}'[User name for login]:user_name'
    {-v,--vardir}'[Data directory for tests]:dir_name:_directories'
    '*:filename:_files'
)
_arguments -s $arguments
