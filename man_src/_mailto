#compdef mailto
# Documentation: https://man.archlinux.org/search?q=mailto
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-a[Indicate additional attributes for the mail message]'
    '-c[Specify carbon copy recipients]:recipients'
    '-r[Specify a reply-to address]:address'
    '-s[Specify the subject of the message]:subject'
    '*:filename:_files'
)
_arguments -s $arguments
