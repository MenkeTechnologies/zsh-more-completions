#compdef invgeod

local arguments

arguments=(
    '-I[Specifies that the inverse geodesic computation is to be performed]'
    '-a[Output latitude and longitudes of the initial and terminal points]'
    '-f[Printf format string to control the output form of the geographic coordinates]:format'
    '-F[Printf format string to control the output form of the distance]:format'
    '-p[Output azimuthal values as unsigned DMS numbers between 0 and 360 degrees]'
    '-le[Give a listing of all the ellipsoids that may be selected]'
    '-lu[Give a listing of all the units that may be selected]'
    '*:filename:_files'
)
_arguments -s $arguments
