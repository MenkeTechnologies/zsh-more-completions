#compdef vtool

local arguments

arguments=(
    '--arch[Specify the architecture to operate on]:arch'
    '-h[Print full usage]'
    '-o[Write output to the specified file]:out_file:_files'
    '-r[Replace existing version when using set-build-version or set-version-min]'
    '--remove-build-tool[Remove tool from the platform build version]:platform tool'
    '--remove-build-version[Remove the build version for the specified platform]:platform'
    '--remove-source-version[Remove the source version from the Mach-O file]'
    '--set-build-tool[Update the build version load command for platform]:platform tool version'
    '--set-build-version[Create or update the LC_BUILD_VERSION load command]:platform minos sdk'
    '--set-source-version[Create or update the source version load command]:version'
    '--set-version-min[Create or update an LC_VERSION_MIN_* load command]:platform minos sdk'
    '--show[Display the build and source versions]'
    '--show-build[Display the build versions]'
    '--show-source[Display the source version]'
    '--show-space[Show the space consumed by the mach header and load commands]'
    '*:filename:_files'
)
_arguments -s $arguments
