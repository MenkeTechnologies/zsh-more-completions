#compdef opt

local arguments

arguments=(
    '-f[Enable binary output on terminals]'
    '--help[Print a summary of command line options]'
    '-o[Specify the output filename]:filename:_files'
    '-S[Write output in LLVM intermediate language instead of bitcode]'
    '--disable-inlining[Remove the inlining pass from the standard list]'
    '--disable-opt[Only meaningful when -std-link-opts is given]'
    '--strip-debug[Strip debug information from the module before applying other optimizations]'
    '--verify-each[Add a verify pass after every pass otherwise specified]'
    '--stats[Print statistics]'
    '--time-passes[Record the amount of time needed for each pass and print to stderr]'
    '--debug[Enable debug printouts from passes in debug builds]'
    '--load[Load the dynamic object plugin]:plugin:_files'
    '-p[Print module after each transformation]'
    '*:filename:_files'
)
_arguments -s $arguments
