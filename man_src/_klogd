#compdef klogd

local arguments

arguments=(
    '-c[Set the default log level of console messages]:n'
    '-d[Enable debugging mode]'
    '-f[Log messages to the specified filename rather than to the syslog facility]:file:_files'
    {-i,-I}'[Signal the currently executing klogd daemon]'
    '-n[Avoid auto-backgrounding]'
    '-o[Execute in one-shot mode]'
    '-p[Enable paranoia]'
    '-s[Force klogd to use the system call interface to the kernel message buffers]'
    '-k[Use the specified file as the source of kernel symbol information]:file:_files'
    '-v[Print version and exit]'
    '-x[Omit EIP translation]'
    '-2[When symbols are expanded, print the line twice]'
    '*:filename:_files'
)
_arguments -s $arguments
