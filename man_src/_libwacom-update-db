#compdef libwacom-update-db
# Documentation: https://man.archlinux.org/search?q=libwacom-update-db
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-h,--help}'[Show help message and exit]'
    '--buildsystem-mode[For use by the build system only]'
    '--skip-systemd-hwdb-update[Do not run systemd-hwdb --update]'
    '--udev-base-dir[The udev base directory]:dir:_directories'
    '*:filename:_files'
)
_arguments -s $arguments
