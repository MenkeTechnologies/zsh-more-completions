#compdef winicontoppm
# Documentation: https://man.archlinux.org/search?q=winicontoppm
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--writeands[For each icon written, also write the transparency mask as a separate PBM file]'
    '--allicons[Extract all images from the .ico file]'
    '--bestqual[Extract only the best quality image from the .ico file]'
    '--multippm[Write all images as a multi-image PPM file]'
    '*:filename:_files'
)
_arguments -s $arguments
