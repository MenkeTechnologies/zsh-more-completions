#compdef ssvnc tsvnc

local arguments

arguments=(
    {--help,-h}'[print a brief description and options]'
    '--cmd[launch the ssvnc_cmd utility command directly]:args'
    '--viewer[shorthand for ssvnc -cmd -viewer]:viewer-args'
    '--profiles[list the saved SSVNC profiles]'
    '--list[same as --profiles]'
    '--ssh[start in SSH Only Mode]'
    '--ts[start in Terminal Services Mode]'
    '--tso[start in Terminal Services Mode, never let user leave this mode]'
    '--ssl[force the full GUI Mode with both SSL and SSH]'
    '--nv[toggle the Verify All Certs button to be off at startup]'
    '--nvb[never show the Verify All Certs button]'
    '--bigger[make the Profile Selection Dialog window bigger]'
    '--noenc[start in a mode where a No Encryption check button is present]'
    '--killstunnel[automatically terminate STUNNEL process when the viewer exits]'
    '--nokillstunnel[disable -killstunnel mode]'
    '--mycert[set the default MyCert]:path:_files'
    '--cacert[set the default ServerCert]:path:_files'
    '--crl[set the default Certificate Revocation List]:path:_files'
    '*:filename:_files'
)
_arguments -s $arguments
