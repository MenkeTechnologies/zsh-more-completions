#compdef tpm2_makecredential

local arguments

arguments=(
    '-e[key used to wrap the seed]:file:_files'
    '-s[secret to be protected by the derived key]:secret'
    '-n[name of the object for which certificate is created]:name'
    '-o[output file for the credential structures]:file:_files'
    '-h[display help information]'
    '-v[display version, supported tctis and exit]'
    '-V[increase verbosity of tool output]'
    '-Q[suppress informational output]'
    '-Z[enable errata fixups]'
    '-T[select the TCTI used for communication]:tcti'
    '*:filename:_files'
)
_arguments -s $arguments
