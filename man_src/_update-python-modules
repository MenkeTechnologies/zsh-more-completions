#compdef update-python-modules
# Documentation: https://man.archlinux.org/search?q=update-python-modules
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Show summary of options]'
    {-v,--verbose}'[Detail all actions while they are performed]'
    {-b,--bytecompile}'[Only accept to work on private modules]'
    {-i,--install}'[Only accept to work on public modules]'
    {-c,--clean}'[Clean modules instead of installing them]'
    {-a,--rebuild-all}'[Rebuild all private modules]'
    {-f,--force-rebuild-all}'[Clean all modules (public and private), and rebuild them]'
    '*:filename:_files'
)
_arguments -s $arguments
