#compdef tss2_createnv
# Documentation: https://man.archlinux.org/search?q=tss2_createnv
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-p,--path}'[path of the new NV space]:path'
    {-t,--type}'[identifies the intended usage]:type'
    {-s,--size}'[size in bytes of the NV index to be created]:size'
    {-P,--policyPath}'[policy to be associated with the new NV space]:path'
    {-a,--authValue}'[the new UTF-8 password]:password'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
