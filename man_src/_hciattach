#compdef hciattach
# Documentation: https://man.archlinux.org/search?q=hciattach
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-b[Send break]'
    '-n[Do not detach from controlling terminal]'
    '-p[Print the PID when detaching]'
    '-t[Specify an initialization timeout in seconds]:timeout'
    '-s[Specify an initial speed instead of the hardware default]:speed'
    '-l[List all available configurations]'
    '-r[Set the HCI device into raw mode]'
    '*:filename:_files'
)
_arguments -s $arguments
