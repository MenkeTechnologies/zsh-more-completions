#compdef cancel

local arguments

arguments=(
    '-a[Cancel all jobs on the named destination, or all jobs on all destinations]'
    '-E[Force encryption when connecting to the server]'
    '-h[Specify an alternate server]:hostname\:port:_hosts'
    '-U[Specify the username to use when connecting to the server]:username:_users'
    '-u[Cancel jobs owned by username]:username:_users'
    '-x[Delete job data files in addition to canceling]'
    '*:filename:_files'
)
_arguments -s $arguments
