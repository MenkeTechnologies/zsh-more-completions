#compdef jcat-tool

local arguments

arguments=(
    {-h,--help}'[Show help options]'
    '--version[Print the version number]'
    {-v,--verbose}'[Print verbose debug statements]'
    '--basename[Only consider the basename for the ID]'
    '--disable-time-checks[Disable time checks when verifying]'
    '--public-key[Location of public key used for verification]:key:_files'
    '--public-keys[Location of public key directories used for verification]:dir:_directories'
    '--prefix[Prefix for import and output files]:prefix'
    '--kind[Kind for blob]:kind:(gpg pkcs7 sha256)'
    '--appstream-id[AppStream ID for blob]:id'
    '--keyring[Keyring location]:dir:_directories'
    '*:filename:_files'
)
_arguments -s $arguments
