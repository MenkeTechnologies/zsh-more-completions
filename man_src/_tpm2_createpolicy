#compdef tpm2_createpolicy

local arguments

arguments=(
    '-f[save the policy digest]:file:_files'
    '-P[password for policy creation]:password'
    '-g[hash algorithm used in policy digest computation]:algorithm'
    '-L[PCR banks and selected PCR ids for each bank]:pcr_list'
    '-F[file containing expected PCR values]:file:_files'
    '-e[end session at the end of operation]'
    '-a[use policy session type instead of trial session]'
    '-h[display help information]'
    '-v[display version, supported tctis and exit]'
    '-V[increase verbosity of tool output]'
    '-Q[suppress informational output]'
    '-Z[enable errata fixups]'
    '-T[select the TCTI used for communication]:tcti'
    '*:filename:_files'
)
_arguments -s $arguments
