#compdef instaloader

local arguments

arguments=(
    '--slide[Set what image/interval of a sidecar to download]:slide'
    '--no-pictures[Do not download post pictures]'
    {-V,--no-videos}'[Do not download videos]'
    '--no-video-thumbnails[Do not download thumbnails of videos]'
    {-G,--geotags}'[Download geotags when available]'
    {-C,--comments}'[Download and update comments for each post]'
    '--no-captions[Do not create txt files]'
    '--post-metadata-txt[Template to write in txt file for each Post]:template'
    '--storyitem-metadata-txt[Template to write in txt file for each StoryItem]:template'
    '--no-metadata-json[Do not create a JSON file containing the metadata of each post]'
    '--no-compress-json[Do not xz compress JSON files, create pretty printed JSON instead]'
    '--no-posts[Do not download regular posts]'
    '--no-profile-pic[Do not download profile picture]'
    {-s,--stories}'[Also download stories of each profile that is downloaded]'
    '--highlights[Also download highlights of each profile that is downloaded]'
    '--tagged[Also download posts where each profile is tagged]'
    '--igtv[Also download IGTV videos]'
    {-F,--fast-update}'[For each target, stop when encountering the first already-downloaded post]'
    '--latest-stamps[Store the timestamps of latest media scraped for each profile]:file:_files'
    {--post-filter,--only-if}'[Expression that must evaluate to True for a post to be downloaded]:expression'
    '--storyitem-filter[Expression that must evaluate to True for a story item to be downloaded]:expression'
    {-c,--count}'[Do not attempt to download more than COUNT posts]:count'
    {-l,--login}'[Login name for your Instagram account]:login'
    {-f,--sessionfile}'[Path for loading and storing session key file]:file:_files'
    {-p,--password}'[Password for your Instagram account]:password'
    '--dirname-pattern[Name of directory where to store posts]:pattern'
    '--filename-pattern[Prefix of filenames for posts and stories]:pattern'
    '--title-pattern[Prefix of filenames for profile pics and hashtag profile pics]:pattern'
    '--resume-prefix[Prefix for filenames used to save the resume state]:prefix'
    '--no-resume[Do not resume a previously-aborted download iteration]'
    '--user-agent[User Agent to use for HTTP requests]:user_agent'
    '--max-connection-attempts[Maximum number of connection attempts until a request is aborted]:count'
    '--request-timeout[Seconds to wait before timing out a connection]:seconds'
    '--abort-on[Comma-separated list of HTTP status codes that cause Instaloader to abort]:codes'
    '--no-iphone[Do not attempt to download iPhone version of images]'
    {-q,--quiet}'[Disable user interaction, do not print messages to terminal]'
    {-h,--help}'[Show help message and exit]'
    '--version[Show version number and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
