#compdef combinedeltarpm
# Documentation: https://man.archlinux.org/search?q=combinedeltarpm
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-v[Make combinedeltarpm more verbose about its work]'
    '-V[Specify a different version]:version'
    '-z[Specify a different compression method]:method:(gzip bzip2 xz)'
    '-S[Specify a signature reference file]:file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
