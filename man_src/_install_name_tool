#compdef install_name_tool

local arguments

arguments=(
    '-change[Change the dependent shared library install name old to new]:old new'
    '-id[Change the shared library identification name]:name'
    '-rpath[Change the rpath path name old to new]:old new'
    '-add_rpath[Add the rpath path name]:new'
    '-delete_rpath[Delete the rpath path name]:old'
    '-headerpad_max_install_names[Automatically add maximum padding for install names]'
    '*:filename:_files'
)
_arguments -s $arguments
