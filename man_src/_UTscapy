#compdef UTscapy

local arguments

arguments=(
    '-t[Provide test files (can be used many times)]:file:_files'
    '-T[If -t is used with *, remove a specific file]:file:_files'
    '-l[Generate local .js and .css files]'
    '-F[Expand only failed tests]'
    '-b[Do not stop at the first failed campaign]'
    '-d[Dump campaign]'
    '-D[Dump campaign and stop]'
    '-R[Dump campaign as reStructuredText]'
    '-C[Do not calculate CRC and SHA]'
    '-c[Load a .utsc config file]:config:_files'
    '-i[Drop into Python interpreter if test failed]'
    '-q[Quiet mode]'
    '-qq[Silent mode]'
    '-x[Use pyannotate]'
    '-n[Only tests whose numbers are given (e.g. 1,3-7,12)]:numbers'
    '-N[Force non root]'
    '-m[Additional module to put in the namespace]:module'
    '-k[Include only tests with one of those keywords]:keywords'
    '-K[Remove tests with one of those keywords]:keywords'
    '-P[Roles for testsets]'
    '*:filename:_files'
)
_arguments -s $arguments
