#compdef update_dyld_shared_cache

local arguments

arguments=(
    '--root[Specify the root of an OS installation for which to generate the shared cache]:path:_directories'
    '--overlay[Specify the root of a sparse directory tree]:path:_directories'
    '--arch[Generate cache files only for the specified architecture]:arch'
    '--force[Regenerate the shared cache files even if they appear to be already up-to-date]'
    '--debug[Print additional information about the work being done]'
    '--universal_boot[Build caches for all machines]'
    '*:filename:_files'
)
_arguments -s $arguments
