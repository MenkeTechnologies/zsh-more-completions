#compdef tbl
# Documentation: https://man.archlinux.org/search?q=tbl
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-C[enable compatibility mode to recognize .TS and .TE]'
    '-t[produce only the table, no enclosing .TS/.TE pair]'
    '-v[print the version number]'
    '*:filename:_files'
)
_arguments -s $arguments
