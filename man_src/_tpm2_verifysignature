#compdef tpm2_verifysignature

local arguments

arguments=(
    {-c,--key-context}'[context of the key for verification]:object:_files'
    {-g,--hash-algorithm}'[hash algorithm used to digest the message]:algorithm'
    {-m,--message}'[the message file to verify]:file:_files'
    {-d,--digest}'[the digest to verify]:file:_files'
    {-s,--signature}'[the signature file]:file:_files'
    {-f,--format}'[input signature format]:format'
    {-t,--ticket}'[output ticket file]:file:_files'
    '--scheme[signing scheme]:algorithm'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    {-V,--verbose}'[increase verbosity of tool output]'
    {-Q,--quiet}'[suppress informational output]'
    {-Z,--enable-errata}'[enable errata fixups]'
    {-R,--autoflush}'[autoflush objects created by the command]'
    '*:filename:_files'
)
_arguments -s $arguments
