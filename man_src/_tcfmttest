#compdef tcfmttest
# Documentation: https://man.archlinux.org/search?q=tcfmttest
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--nl[set the number of members in each leaf]:num'
    '--nb[set the number of members in each node]:num'
    '--rnd[use random keys]'
    '--wb[use write-behind caching]'
    '--nc[do not use compression]'
    '--rr[set the number of records]:num'
    '*:filename:_files'
)
_arguments -s $arguments
