#compdef db_dump185

local arguments

arguments=(
    '-b[Specify the directory where BLOB data is stored]:directory:_directories'
    '-d[Dump in a debugging format]'
    '-D[Specify the maximum number of bytes to dump per key/data item]:bytes'
    '-f[Write to the specified output file instead of stdout]:file:_files'
    '-h[Specify a home directory for the database environment]:directory:_directories'
    '-k[Dump record numbers from Queue and Recno databases as keys]'
    '-l[List the databases stored in the file]'
    '-N[Do not acquire shared region mutexes while running]'
    '-P[Specify an environment password]:password'
    '-p[Print printable characters as themselves]'
    '-R[Aggressively salvage data from a possibly corrupt file]'
    '-r[Salvage data from a possibly corrupt file]'
    '-s[Specify a single database to dump]:database'
    '-V[Write the library version number and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
