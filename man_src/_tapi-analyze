#compdef tapi-analyze

local arguments

arguments=(
    '--target[specify target triple]:target'
    '-o[specify output file]:output file:_files'
    '--sdkdb[specify SDK database path]:path:_files'
    '-v[enable verbose output]'
    '--app-info-output[specify app info output path]:path:_files'
    '--pretty-json[output formatted JSON]'
    '*:filename:_files'
)
_arguments -s $arguments
