#compdef icedax

local arguments

arguments=(
    '--device[Use device as the source for CDDA reading]:device'
    '--auxdevice[Use auxdevice as CDROM drive for ioctl usage]:auxdevice'
    '--interface[Specify the interface for CDROM access]:interface:(generic_scsi cooked_ioctl)'
    {-c,--channels}'[Set channels: 1 for mono, 2 for stereo, s for stereo swapped]:channels'
    {-s,--stereo}'[Set to stereo recording]'
    {-m,--mono}'[Set to mono recording]'
    {-x,--max}'[Set maximum (CD) quality]'
    {-b,--bits-per-sample}'[Set bits per sample per channel]:bits:(8 12 16)'
    {-r,--rate}'[Set rate in samples per second]:rate'
    {-a,--divider}'[Set rate to 44100Hz divided by the specified value]:divider'
    {-R,--dump-rates}'[Show a list of all sample rates and their dividers]'
    {-P,--set-overlap}'[Set the initial number of overlap sectors for jitter correction]:sectors'
    {-n,--sectors-per-request}'[Read specified number of sectors per request]:sectors'
    {-l,--buffers-in-ring}'[Use a ring buffer with the specified total buffers]:buffers'
    {-t,--track}'[Select start track and optionally end track]:track'
    {-i,--index}'[Select the start index]:index'
    {-o,--offset}'[Start offset sectors behind start track]:offset'
    {-O,--output-format}'[Set output format]:format:(wav aiff aifc au cdr)'
    {-C,--cdrom-endianess}'[Set endianness of the input samples]:endian:(little big guess)'
    {-E,--output-endianess}'[Set endianness of the output samples]:endian:(little big)'
    {-d,--duration}'[Set recording time in seconds or frames]:duration'
    {-B,--bulk,--alltracks}'[Copy each track into a separate file]'
    {-w,--wait}'[Wait for signal, then start recording]'
    {-F,--find-extremes}'[Find extreme amplitudes in samples]'
    {-G,--find-mono}'[Find if input samples are in mono]'
    {-T,--deemphasize}'[Undo the effect of pre-emphasis in the input samples]'
    {-e,--echo}'[Copy audio data to sound device]'
    {-p,--set-pitch}'[Change pitch of audio data copied to sound device]:pitch'
    {-v,--verbose-level}'[Print verbose information about the CD]:level'
    {-N,--no-write}'[Do not write to a file, just read for debugging purposes]'
    {-J,--info-only}'[Do not write to a file, just give information about the disc]'
    {-L,--cddb}'[Do a CDDB album and track title lookup]'
    {-H,--no-infofile}'[Do not write an info file and a cddb file]'
    {-g,--gui}'[Format the output to be better parsable by GUI frontends]'
    {-M,--md5}'[Enable calculation of MD5 checksum]:count'
    {-S,--speed}'[Set the CDROM device to one of the selectable speeds for reading]:speed'
    {-q,--quiet}'[Quiet operation, no screen output]'
    {-V,--verbose-SCSI}'[Enable SCSI command logging to the console]'
    {-Q,--silent-SCSI}'[Suppress SCSI command error reports to the console]'
    '--scanbus[Scan all SCSI devices on all SCSI busses and print the inquiry strings]'
    '--devices[Like --scanbus but works in a more native way]'
    '--paranoia[Use the paranoia library instead of icedax routines for reading]'
    {-h,--help}'[Display help and version of icedax]'
    '*:filename:_files'
)
_arguments -s $arguments
