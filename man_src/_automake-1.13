#compdef automake-1.13

# Autogenerated from man page
# Updated with latest automake-1.13 options

local arguments

arguments=(
    '(- * :)--help[Print help, then exit]'
    '--version[Print version number, then exit]'
    {-v,--verbose}'[Verbosely list files processed]'
    '--no-force[Only update Makefile.in that are out of date]'
    {-W,--warnings}'[Report the warnings falling in CATEGORY]:CATEGORY:(syntax unsupported)'
    {-i,--ignore-deps}'[Disable dependency tracking code]'
    '--include-deps[Enable dependency tracking code]'
    '--foreign[Set strictness to foreign]'
    '--gnits[Set strictness to gnits]'
    '--gnu[Set strictness to gnu]'
    {-a,--add-missing}'[Add missing standard files to package]'
    '--libdir[Set directory storing library files]:DIR:_directories'
    '--print-libdir[Print directory storing library files]'
    {-c,--copy}'[With -a, copy missing files (default is symlink)]'
    {-f,--force-missing}'[Force update of standard files]'
    '*:filename:_files'
)
_arguments -s $arguments
