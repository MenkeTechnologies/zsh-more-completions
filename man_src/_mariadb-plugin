#compdef mariadb-plugin mysql_plugin

local arguments

arguments=(
    {-\?,--help}'[Display help and exit]'
    '--basedir[Path to the server base directory]:path:_directories'
    '--datadir[Path to the data directory]:path:_directories'
    '--my-print-defaults[Path to my_print_defaults executable]:path:_files'
    '--mysqld[Path to the server]:path:_files'
    '--no-defaults[Do not read any default option files]'
    '--plugin-dir[Path to the plugin directory]:path:_directories'
    '--plugin-ini[Path to the plugin configuration file]:file:_files'
    '--print-defaults[Print the program argument list and exit]'
    {-v,--verbose}'[Verbose output]'
    {-V,--version}'[Output version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
