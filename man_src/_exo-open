#compdef exo-open
# Documentation: https://man.archlinux.org/search?q=exo-open
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--launch[Launch the preferred application for a certain category]:category'
    {-\?,--help}'[Show help options]'
    {-v,--version}'[Show version information]'
    '--working-directory[Set the working directory]:directory:_directories'
    '*:filename:_files'
)
_arguments -s $arguments
