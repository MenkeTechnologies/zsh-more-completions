#compdef tss2_encrypt

local arguments

arguments=(
    {-p,--keyPath}'[identifies the encryption key]:path'
    {-f,--force}'[force overwriting the output file]'
    {-i,--plainText}'[the data to be encrypted]:file:_files'
    {-o,--cipherText}'[returns the JSON-encoded ciphertext]:file:_files'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
