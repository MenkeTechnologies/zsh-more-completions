#compdef wsdl

local arguments

arguments=(
    '--urlkey[Specify that the URL for services should be read from appsettings]:key'
    '--baseurl[Specify a base URL for the service]:url'
    {--language,-l}'[Language of the code to generate]:language'
    {--namespace,-n}'[The namespace of the generated classes]:name'
    {--out,-o}'[The target file for generated code]:filename:_files'
    {--protocol,-p}'[The protocol for which to generate code]:protocol'
    '--sample[Display XML request and reply of sample invocations]:method'
    '--server[Generate a server skeleton instead of a client proxy]'
    '--nologo[Suppress the startup logo]'
    {--user,-u}'[The user name to use when connecting to the server]:username'
    {--password,-p}'[The password to use when connecting to the server]:password'
    '--type[Generate a proxy for a compiled web service class]:typename'
    {--domain,-d}'[The domain to use when connecting to the server]:domain'
    '*:filename:_files'
)
_arguments -s $arguments
