#compdef mysqldbcompare

local arguments

arguments=(
    '--help[Display help and exit]'
    '--server1[Connection information for first server]:source'
    '--server2[Connection information for second server]:source'
    '--changes-for[Specify the server to show transformations]:server:(server1 server2)'
    '--difftype[Specify the type of diff]:type:(unified context differ sql)'
    '--disable-binary-logging[Disable binary logging during the operation]'
    '--format[Specify the output display format]:format:(grid csv tab vertical)'
    {-q,--quiet}'[Turn off all messages for quiet execution]'
    '--run-all-tests[Run all tests regardless of their end state]'
    '--show-reverse[Show reverse transformations]'
    '--skip-data-check[Skip data consistency check]'
    '--skip-diff[Skip the object definition diff]'
    '--skip-object-compare[Skip the object comparison step]'
    '--skip-row-count[Skip the row count check]'
    '--span-key-size[Max key size for comparison]:size'
    {-v,--verbose}'[Verbose output]'
    '--version[Display version information and exit]'
    '--width[Display width]:number'
    '*:filename:_files'
)
_arguments -s $arguments
