#compdef tpm2_sessionconfig

local arguments

arguments=(
    {-S,--session}'[the session to configure]:file:_files'
    '--enable-encrypt[enable parameter encryption]'
    '--enable-decrypt[enable parameter decryption]'
    '--enable-audit[enable audit]'
    '--disable-encrypt[disable parameter encryption]'
    '--disable-decrypt[disable parameter decryption]'
    '--disable-audit[disable audit]'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    {-V,--verbose}'[increase verbosity of tool output]'
    {-Q,--quiet}'[suppress informational output]'
    {-Z,--enable-errata}'[enable errata fixups]'
    {-R,--autoflush}'[autoflush objects created by the command]'
    '*:filename:_files'
)
_arguments -s $arguments
