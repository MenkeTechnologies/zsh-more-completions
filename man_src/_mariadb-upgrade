#compdef mariadb-upgrade mysql_upgrade

local arguments

arguments=(
    {-\?,--help}'[Display help and exit]'
    '--all-databases[Process all tables in all databases]'
    '--check-upgrade[Check tables for version-dependent changes]'
    '--force[Force execution even if mysql_upgrade has already been run for the current version]'
    {-b,--basedir}'[Path to installation base directory]:path:_directories'
    '--character-sets-dir[Directory for character set files]:path:_directories'
    '--datadir[Path to the data directory]:path:_directories'
    {-\#,--debug}'[Write debugging log]:path'
    '--debug-check[Check memory and open file usage at exit]'
    '--debug-info[Print debugging information at exit]'
    '-T[Check and upgrade system tables only]'
    '--default-character-set[Set the default character set]:name'
    '--host[Connect to the specified host]:host_name:_hosts'
    {-p,--password}'[Password to use for connection]:password'
    {-P,--port}'[Port number for connection]:port_num'
    '--protocol[Connection protocol to use]:protocol:(TCP SOCKET PIPE MEMORY)'
    {-s,--silent}'[Print less information]'
    {-S,--socket}'[Socket file for connection]:path:_files'
    '--ssl[Enable SSL for connection]'
    '--ssl-ca[CA file in PEM format]:name:_files'
    '--ssl-capath[CA directory]:name:_directories'
    '--ssl-cert[X509 cert in PEM format]:name:_files'
    '--ssl-cipher[SSL cipher to use]:name'
    '--ssl-key[X509 key in PEM format]:name:_files'
    '--ssl-crl[Certificate revocation list]:name:_files'
    '--ssl-crlpath[Certificate revocation list path]:name:_directories'
    '--ssl-verify-server-cert[Verify server certificate]'
    {-t,--tmpdir}'[Temporary directory]:path:_directories'
    '--upgrade-system-tables[Only upgrade the system tables, do not check or repair user tables]'
    {-u,--user}'[User name for login]:user_name'
    {-v,--verbose}'[Write more information]'
    {-V,--version}'[Display version information and exit]'
    {-k,--version-check}'[Run a version check against the server]'
    '--write-binlog[Write ANALYZE, OPTIMIZE and REPAIR TABLE commands to the binary log]'
    '*:filename:_files'
)
_arguments -s $arguments
