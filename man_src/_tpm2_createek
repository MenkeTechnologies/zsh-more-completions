#compdef tpm2_createek

local arguments

arguments=(
    {-P,--eh-auth}'[authorization value for the endorsement hierarchy]:auth'
    {-w,--owner-auth}'[authorization value for the owner hierarchy]:auth'
    {-c,--ek-context}'[file path or persistent handle to save the endorsement key]:context:_files'
    {-G,--key-algorithm}'[the endorsement key algorithm]:algorithm'
    '--public[optional input file to save the public portion of endorsement key]:file:_files'
    {-t,--template}'[manufacturer defined endorsement key template and nonce]:file:_files'
    {-f,--format}'[format selection for the public key output file]:format'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    {-V,--verbose}'[increase verbosity of tool output]'
    {-Q,--quiet}'[suppress informational output]'
    {-Z,--enable-errata}'[enable errata fixups]'
    {-R,--autoflush}'[autoflush objects created by the command]'
    '*:filename:_files'
)
_arguments -s $arguments
