#compdef gxditview
# Documentation: https://man.archlinux.org/search?q=gxditview
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-backingStore[Set the backing store type]:type:(WhenMapped Always NotUseful)'
    '-filename[Use the specified file as input]:file:_files'
    '-page[Display the specified page]:number'
    '-printCommand[Set the print command]:command'
    '-resolution[Set the resolution in dots per inch]:dpi'
    '*:filename:_files'
)
_arguments -s $arguments
