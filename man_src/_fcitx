#compdef fcitx

local arguments

arguments=(
    '-r[Replace existing fcitx instance]'
    '-d[Run as daemon (default)]'
    '-D[Do not run as daemon]'
    '-s[Override delay start time in config file, 0 for immediate start]:time'
    {-u,--ui}'[Force to use specified user interface]:name'
    '--enable[Specify a comma separated list for addons to enable]:addons'
    '--disable[Specify a comma separated list for addons to explicitly disable]:addons'
    '-v[Display version information and exit]'
    '-h[Display help and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
