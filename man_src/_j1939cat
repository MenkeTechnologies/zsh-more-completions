#compdef j1939cat

local arguments

arguments=(
    '-i[Input file (default stdin)]:infile:_files'
    '-s[Set maximal transfer size in bytes]:size'
    '-r[Receive data]'
    '-P[Poll timeout in milliseconds before sending data]:timeout'
    '-R[Set send repeat count]:count'
    '*:filename:_files'
)
_arguments -s $arguments
