#compdef fips-mode-setup
# Documentation: https://man.archlinux.org/search?q=fips-mode-setup
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--enable[Enable FIPS mode]'
    '--disable[Disable FIPS mode]'
    '--check[Check if FIPS mode is enabled]'
    '--no-bootcfg[Do not modify the boot configuration]'
    '*:filename:_files'
)
_arguments -s $arguments
