#compdef ibcacheedit
# Documentation: https://man.archlinux.org/search?q=ibcacheedit
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--switchguid[Specify before and after switchguid]:old,new'
    '--caguid[Specify before and after caguid to edit]:old,new'
    '--sysimgguid[Specify before and after sysimgguid]:old,new'
    '--portguid[Specify before and after portguid]:old,new'
    {--config,-z}'[Use config file]:config:_files'
    {--help,-h}'[Show help message]'
    {--version,-V}'[Show version]'
    '*:filename:_files'
)
_arguments -s $arguments
