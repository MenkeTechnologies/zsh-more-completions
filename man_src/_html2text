#compdef html2text

local arguments

arguments=(
    '--ascii[Use ASCII for the output instead of ISO 8859-1]'
    '--check[Only parse the HTML document and check for errors, do not format]'
    '--debug-parser[Report on the tokens being shifted and rules being applied]'
    '--debug-scanner[Report on each lexical token scanned while scanning the HTML document]'
    '--help[Print command line summary and exit]'
    '--nobs[Do not render underlined or bold text using backspace sequences]'
    '-o[Write the output to the specified file instead of standard output]:output_file:_files'
    '--rcfile[Attempt to read the specified file as RC file]:path:_files'
    '--style[Change some of the default values of the formatting parameters]:style:(pretty compact)'
    '--unparse[Instead of formatting the parsed document, reproduce the input document]'
    '--version[Print program version and exit]'
    '--width[Format the HTML document for the given screen width]:width'
    '*:filename:_files'
)
_arguments -s $arguments
