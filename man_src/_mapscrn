#compdef mapscrn
# Documentation: https://man.archlinux.org/search?q=mapscrn
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-o[Save the old map in the specified file]:mapfile:_files'
    '-V[Print version number and exit]'
    '-v[Be verbose]'
    '*:filename:_files'
)
_arguments -s $arguments
