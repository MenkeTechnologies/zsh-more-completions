#compdef lam

local arguments

arguments=(
    '-f[Print line fragments according to the format string]:format'
    '-p[Like -f, but pad this field when end-of-file is reached and other files still have data]:format'
    '-s[Print sepstring before printing line fragments from the next file]:sepstring'
    '-t[The input line terminator is the specified character instead of a newline]:char'
    '*:filename:_files'
)
_arguments -s $arguments
