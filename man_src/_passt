#compdef passt

local arguments

arguments=(
    {-d,--debug}'[Be verbose, log to stderr instead of system logger]'
    '--trace[Be extra verbose, show single packets, implies --debug]'
    {-q,--quiet}'[Do not print informational messages]'
    {-f,--foreground}'[Do not run in background]'
    {-e,--stderr}'[No effect, maintained for compatibility only]'
    {-l,--log-file}'[Log to file instead of the system logger]:path:_files'
    '--log-size[Limit log file size in bytes]:size'
    '--runas[Change to given UID/GID or username after start]:uid'
    {-h,--help}'[Display a help message and exit]'
    '--version[Show version and exit]'
    {-p,--pcap}'[Capture tap-facing network packets to file]:file:_files'
    {-P,--pid}'[Write PID to file once initialisation is done]:file:_files'
    {-m,--mtu}'[Assign MTU via DHCP and NDP]:mtu'
    {-a,--address}'[Assign address via DHCP or DHCPv6]:addr'
    {-n,--netmask}'[Assign IPv4 netmask via DHCP]:mask'
    {-M,--mac-addr}'[Use source MAC address for guest or namespace communication]:addr'
    {-g,--gateway}'[Assign default gateway via DHCP or NDP]:addr'
    {-i,--interface}'[Use host interface to derive addresses and routes]:name'
    {-o,--outbound}'[Use address as source for outbound connections]:addr'
    '--outbound-if4[Bind IPv4 outbound sockets to host interface]:name'
    '--outbound-if6[Bind IPv6 outbound sockets to host interface]:name'
    {-D,--dns}'[Use address for DHCP, DHCPv6, NDP or DNS forwarding]:addr'
    '--dns-forward[Map address as seen from guest to first configured DNS]:addr'
    {-S,--search}'[Use space-separated domain search list for DHCP and NDP]:list'
    '--no-dhcp-dns[Do not assign DNS addresses via DHCP or DHCPv6]'
    '--dhcp-dns[Assign DNS addresses via DHCP or DHCPv6]'
    '--no-dhcp-search[Do not send DNS domain search list via DHCP]'
    '--dhcp-search[Send DNS domain search list via DHCP]'
    '--no-tcp[Disable the TCP protocol handler]'
    '--no-udp[Disable the UDP protocol handler]'
    '--no-icmp[Disable the ICMP/ICMPv6 echo handler]'
    '--no-dhcp[Disable the DHCP server]'
    '--no-ndp[Disable NDP responses]'
    '--no-dhcpv6[Disable the DHCPv6 server]'
    '--no-ra[Disable Router Advertisements]'
    '--no-map-gw[Do not remap traffic with gateway address to host]'
    {-4,--ipv4-only}'[Enable IPv4-only operation]'
    {-6,--ipv6-only}'[Enable IPv6-only operation]'
    {-s,--socket}'[Path for UNIX domain socket to connect to passt]:path:_files'
    {-F,--fd}'[Pass a pre-opened connected socket to passt]:fd'
    {-1,--one-off}'[Quit after handling a single client connection]'
    {-t,--tcp-ports}'[Configure TCP port forwarding to guest]:spec'
    {-u,--udp-ports}'[Configure UDP port forwarding to guest]:spec'
    {-I,--ns-ifname}'[Name of tap interface in target namespace]:name'
    {-T,--tcp-ns}'[Configure TCP port forwarding from namespace to init namespace]:spec'
    {-U,--udp-ns}'[Configure UDP port forwarding from namespace to init namespace]:spec'
    '--userns[Target user namespace to join]:path:_files'
    '--netns[Target network namespace to join]:path'
    '--netns-only[Join only target network namespace, not user namespace]'
    '--no-netns-quit[Do not exit when target namespace reference is removed]'
    '--config-net[Configure networking in the namespace]'
    '--no-copy-routes[Do not copy routes associated to the interface]'
    '--no-copy-addrs[Do not copy addresses associated to the interface]'
    '--ns-mac-addr[Configure MAC address on the tap interface in namespace]:addr'
    '*:filename:_files'
)
_arguments -s $arguments
