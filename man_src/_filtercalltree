#compdef filtercalltree

local arguments

arguments=(
    '--invertCallTree[Print the call tree from hottest to coldest stack frame]'
    '--pruneCount[Remove branches with count less than specified]:count'
    '--pruneMallocSize[Remove branches with malloc size less than specified]:size'
    '--chargeSystemLibraries[Remove stack frames from /System and /usr, charging cost to callers]'
    '--chargeLibrary[Remove stack frames from specified library, charging cost to callers]:library-name'
    '--keepBoundaries[Keep the top call into excluded libraries when charging to callers]'
    '*:filename:_files'
)
_arguments -s $arguments
