#compdef cloud-init

local arguments

arguments=(
    {-h,--help}'[Show help message and exit]'
    {-d,--debug}'[Show additional pre-action logging]'
    {-f,--files}'[Additional YAML configuration files to use]:file:_files'
    '--force[Force running even if no datasource is found]'
    {-v,--version}'[Show program version number and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
