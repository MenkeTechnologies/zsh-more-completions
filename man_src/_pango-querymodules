#compdef pango-querymodules

local arguments

arguments=(
    {-\?,--help}'[Print a short help text and exit]'
    '--version[Print version information]'
    '--system[Do not load user-specific configuration]'
    '--update-cache[Update the Pango module cache file directly instead of printing to stdout]'
    '*:filename:_files'
)
_arguments -s $arguments
