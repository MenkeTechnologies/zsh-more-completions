#compdef swtpm_setup

# Updated with fixes for descriptions

local arguments

arguments=(
    '--runas[Run this program under the given user account]:user'
    '--tpm-state[Path to directory where TPM state will be written]:dir:_directories'
    '--tpmstate[Alias for --tpm-state]:dir:_directories'
    '--tpm[Path to the TPM executable]:executable:_files'
    '--swtpm_ioctl[Path to the swtpm_ioctl executable]:executable:_files'
    '--tpm2[Setup a TPM 2 (default is TPM 1.2)]'
    '--createek[Create the EK]'
    '--allow-signing[Create an EK that can be used for signing]'
    '--decryption[Create an EK that can be used for key encipherment]'
    '--ecc[Create a TPM 2 ECC key as storage primary key]'
    '--take-ownership[Take ownership (implies --createek)]'
    '--ownerpass[Owner password]:password'
    '--owner-well-known[Use well-known owner password]'
    '--srkpass[Provide custom SRK password]:password'
    '--srk-well-known[Use well-known SRK password]'
    '--create-ek-cert[Create an EK certificate (implies --createek)]'
    '--create-platform-cert[Create a platform certificate (implies --create-ek-cert)]'
    '--create-spk[Create storage primary key (requires --tpm2)]'
    '--lock-nvram[Lock NVRAM access]'
    '--display[Display as much info as possible about the TPM at the end]'
    '--config[Configuration file]:file:_files'
    '--logfile[Path to log file (default is logging to stderr)]:file:_files'
    '--keyfile[Path to a file containing the encryption key]:file:_files'
    '--keyfile-fd[File descriptor to read the encryption key from]:fd'
    '--pwdfile[Path to a file containing a passphrase for key derivation]:file:_files'
    '--pwdfile-fd[File descriptor to read the passphrase from]:fd'
    '--cipher[The cipher to use]:cipher:(aes-128-cbc aes-256-cbc)'
    '--overwrite[Overwrite existing TPM state by re-initializing it]'
    '--not-overwrite[Do not overwrite existing TPM state, silently end]'
    '--pcr-banks[Set of PCR banks to activate (comma separated list)]:banks'
    '--rsa-keysize[The RSA key size of the EK key]:keysize'
    '--print-capabilities[Print JSON formatted capabilities and exit]'
    '--version[Display version and exit]'
    {--help,-h}'[Display help screen]'
    '*:filename:_files'
)
_arguments -s $arguments
