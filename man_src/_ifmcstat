#compdef ifmcstat

local arguments

arguments=(
    '-i[Specify the interface to be displayed]:interface'
    '-f[Specify the address family to be displayed]:family:(inet inet6 link)'
    '-v[Print link-layer memberships which are suppressed by default]'
    '-K[Attempt to use kvm to retrieve the multicast group information]'
    '-M[Extract values associated with the name list from the specified core]:core:_files'
    '-N[Extract the name list from the specified kernel]:kernel:_files'
    '*:filename:_files'
)
_arguments -s $arguments
