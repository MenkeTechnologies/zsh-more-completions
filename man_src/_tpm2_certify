#compdef tpm2_certify

local arguments

arguments=(
    '-H[handle of the object to be certified]:handle'
    '-C[file for providing the object context]:file:_files'
    '-k[the key used to sign the attestation structure]:key_handle'
    '-c[key context used to sign the attestation structure]:file:_files'
    '-P[authorization value for the object]:password'
    '-K[authorization value for the signing key]:password'
    '-a[file name for the attestation data]:file:_files'
    '-s[file name for the signature data]:file:_files'
    '-f[format for the signature output file]:format'
    '-h[display help information]'
    '-v[display version, supported tctis and exit]'
    '-V[increase verbosity of tool output]'
    '-Q[suppress informational output]'
    '-Z[enable errata fixups]'
    '-T[select the TCTI used for communication]:tcti'
    '*:filename:_files'
)
_arguments -s $arguments
