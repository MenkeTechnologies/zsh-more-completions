#compdef vacation

local arguments

arguments=(
    '-a[Handle messages for alias in the same manner as those received for the user]:alias'
    '-C[Specify pathname of the sendmail configuration file]:cfpath:_files'
    '-d[Send error/debug messages to stderr instead of syslog]'
    '-f[Use filename as name of the database]:filename:_files'
    '-i[Initialize the vacation database files]'
    '-I[Same as -i (for backwards compatibility)]'
    '-j[Respond to the message regardless of whether the login is listed as a recipient]'
    '-l[List the content of the vacation database file]'
    '-m[Use filename as name of the file containing the message to send]:filename:_files'
    '-R[Set the reply envelope sender address]:returnaddr'
    '-r[Set the reply interval in days (default: one week)]:interval'
    '-s[Use address instead of the incoming message sender address on the From line]:address'
    '-t[Ignored, available only for compatibility with Sun vacation program]:time'
    '-U[Do not attempt to lookup login in the password file]'
    '-x[Read an exclusion list from stdin (one address per line)]'
    '-z[Set the sender of the vacation message to empty instead of the user]'
    '*:filename:_files'
)
_arguments -s $arguments
