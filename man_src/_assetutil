#compdef assetutil

# Updated with latest macOS assetutil options

local arguments

arguments=(
    '-V[Print version information]'
    '-I[Produce a JSON description of the named asset catalog object]'
    '-i[Keep all assets with the specified idiom]:idiom'
    '-s[Keep all assets with the specified scale factor]:scale'
    '-p[Keep all assets with the specified display gamut]:gamut'
    '-M[Keep all assets with the specified memory class]:memory'
    '-g[Keep all assets with the specified graphics class]:graphics'
    '-h[Process the hosted idioms list]:idioms'
    '-t[Subtype to keep (integer)]:subtype'
    '-c[Main Assets car file]:car_file:_files'
    '-o[Output file name (default: overwrite input)]:output:_files'
    '-T[Compare thinning attributes]:attributes'
    '*:car file:_files'
)
_arguments -s $arguments
