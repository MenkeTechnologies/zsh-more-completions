#compdef emond
# Documentation: https://man.archlinux.org/search?q=emond
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-r[Look for rules files in the specified path]:path:_directories'
    '-c[Look in specified path for the config file]:path:_directories'
    '*:filename:_files'
)
_arguments -s $arguments
