#compdef cob-config
# Documentation: https://man.archlinux.org/search?q=cob-config
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--prefix[Echo the package-prefix of libcob]'
    '--exec-prefix[Echo the executable-prefix of libcob]'
    '--cflags[Echo the C compiler flags needed to compile with libcob]'
    '--libs[Echo the libraries needed to link with libcob]'
    '--version[Echo the version of libcob]'
    '--bindir[Echo the directory containing libcob programs]'
    '--datadir[Echo the directory containing libcob data]'
    '--includedir[Echo the directory containing libcob header files]'
    '--libdir[Echo the directory containing libcob libraries]'
    '--mandir[Echo the directory containing libcob manpages]'
    '(- * :)--help[Print this help message]'
    '*:filename:_files'
)
_arguments -s $arguments
