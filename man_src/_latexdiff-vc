#compdef latexdiff-vc

local arguments

arguments=(
    '--rcs[Use RCS as the version control system]'
    '--svn[Use SVN as the version control system]'
    '--cvs[Use CVS as the version control system]'
    '--git[Use git as the version control system]'
    '--hg[Use Mercurial as the version control system]'
    {-r,--revision}'[Choose revision]:revision'
    {-d,--dir}'[Put diff output in a separate directory]:dir:_directories'
    '--flatten[Flatten the document by replacing \\input and \\include commands]'
    '--fast[Use latexdiff-fast for faster processing]'
    '--so[Use latexdiff-so]'
    '--ps[Generate postscript output from difference file]'
    '--postscript[Generate postscript output from difference file]'
    '--pdf[Generate pdf output from difference file using pdflatex]'
    '--only-changes[Post-process output so only pages with changes are displayed]'
    '--force[Overwrite existing diff files without asking for confirmation]'
    {--help,-h}'[Show help text]'
    '*:filename:_files'
)
_arguments -s $arguments
