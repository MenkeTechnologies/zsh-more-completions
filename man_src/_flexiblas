#compdef flexiblas

local arguments

arguments=(
    {-u,--user}'[Edit the user flexiblasrc configuration]'
    {-g,--global}'[Edit the global flexiblasrc configuration]'
    {-E,--environment}'[Edit the configuration file given by the environment]'
    {-H,--host}'[Edit the host flexiblasrc configuration]'
    {-p,--pipe}'[Pipe/script compatible output]'
    {-h,--help}'[Print this information and exit]'
    {-v,--version}'[Print the version information and exit]'
    '*:filename:_files'
)

_arguments -s $arguments
