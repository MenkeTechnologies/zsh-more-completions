#compdef vtfontcvt
# Documentation: https://man.archlinux.org/search?q=vtfontcvt
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-h[Set font height (default: 16)]:height'
    '-v[Display verbose statistics about the converted font]'
    '-w[Set font width (default: 8)]:width'
    '*:filename:_files'
)
_arguments -s $arguments
