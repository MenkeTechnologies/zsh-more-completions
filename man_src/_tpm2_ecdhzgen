#compdef tpm2_ecdhzgen

local arguments

arguments=(
    {-c,--key-context}'[context object pointing to ECC key]:file:_files'
    {-p,--key-auth}'[authorization value for the ECC key object]:auth'
    {-u,--public}'[input ECC point Q]:file:_files'
    {-k,--public-key}'[input ECC public key with point Q]:file:_files'
    {-o,--output}'[file path to save the calculated ECDH secret]:file:_files'
    '--cphash[file path to record command parameter hash]:file:_files'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    {-V,--verbose}'[increase verbosity of tool output]'
    {-Q,--quiet}'[suppress informational output]'
    {-Z,--enable-errata}'[enable errata fixups]'
    {-R,--autoflush}'[autoflush objects created by the command]'
    '*:filename:_files'
)
_arguments -s $arguments
