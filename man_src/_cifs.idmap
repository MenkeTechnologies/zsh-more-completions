#compdef cifs.idmap
# Documentation: https://man.archlinux.org/search?q=cifs.idmap
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {--help,-h}'[Print the usage message and exit]'
    {--timeout,-t}'[Set the expiration timer in seconds on the key]:seconds'
    {--version,-v}'[Print version number and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
