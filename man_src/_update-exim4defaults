#compdef update-exim4defaults

local arguments

arguments=(
    {--help,-h}'[Print short usage instructions and exit]'
    '--qflags[Set qflags, special flags given to exim directly after the -q]:flags'
    '--queuerunner[Set queue runner mode]:mode:(combined queueonly separate ppp no nodaemon)'
    '--queuetime[Set intervals for running the queue]:time'
    '--commonoptions[Options passed both to queue-running and listening instances of Exim]:options'
    '--queuerunneroptions[Options only passed to the instance of Exim running the queue]:options'
    '--smtplisteneroptions[Options only passed to the instance of Exim listening on the SMTP port]:options'
    {--force,-f}'[Force changes even if options have been hand-edited]'
    '--remove-common[Try to remove the given option from COMMONOPTIONS]:option'
    '--remove-queue[Try to remove the given option from QUEUERUNNEROPTIONS]:option'
    '--remove-smtp[Try to remove the given option from SMTPLISTENEROPTIONS]:option'
    '--init[Create a default /etc/default/exim4 file and exit immediately]'
    '*:filename:_files'
)
_arguments -s $arguments
