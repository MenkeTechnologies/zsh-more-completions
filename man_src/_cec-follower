#compdef cec-follower

local arguments

arguments=(
    {-d,--device}'[Use device as the CEC device]:device:_files'
    {-D,--driver}'[Use a CEC device that has the given driver name]:driver'
    {-a,--adapter}'[Use a CEC device that has the given adapter name]:adapter name'
    {-v,--verbose}'[Turn on verbose reporting]'
    {-w,--wall-clock}'[Show timestamps as wall-clock time, also turns on verbose reporting]'
    {-T,--trace}'[Trace all called ioctls, useful for debugging]'
    '(- * :)'{-h,--help}'[Print the help message]'
    {-n,--no-warnings}'[Turn off warning messages]'
    {-m,--show-msgs}'[Show received messages]'
    {-s,--show-state}'[Show state changes from the emulated device]'
    '*:filename:_files'
)
_arguments -s $arguments
