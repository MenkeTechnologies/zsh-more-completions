#compdef pcap-config

local arguments

arguments=(
    '--cflags[Write compiler flags to include libpcap header files]'
    '--libs[Write linker flags required to link with libpcap]'
    '--additional-libs[Write additional libraries needed to link with libpcap]'
    '--static[Write flags for compiling with a statically-linked libpcap]'
    '*:filename:_files'
)
_arguments -s $arguments
