#compdef kbdcontrol

local arguments

arguments=(
    '-A[Detach the keyboard specified by device name from the keyboard multiplexer]:device'
    '-a[Attach the keyboard specified by device name to the keyboard multiplexer]:device'
    '-b[Set keyboard bell duration and pitch]'
    '-r[Set keyboard repeat delay and rate]'
    '-l[Install keyboard map file]:keymap_file:_files'
    '-d[Dump the current keyboard map onto stdout]'
    '-f[Set function key number to send string]:key string'
    '-F[Set function keys back to the standard definitions]'
    '-x[Use hexadecimal numbers in keyboard map dump]'
    '-i[Print brief information about the keyboard]'
    '-K[Disconnect the keyboard from the console]'
    '-k[Use the specified device as the console keyboard]:device'
    '-L[Load keyboard map file and write compiled version]:keymap_file:_files'
    '-P[Search for the keymap file in path]:path:_directories'
    '*:filename:_files'
)
_arguments -s $arguments
