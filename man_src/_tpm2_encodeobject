#compdef tpm2_encodeobject

local arguments

arguments=(
    {-C,--parent-context}'[the parent object]:object:_files'
    {-P,--auth}'[authorization value of the parent object]:auth'
    {-u,--public}'[file containing the public portion of the object]:file:_files'
    {-r,--private}'[file containing the sensitive portion of the object]:file:_files'
    {-p,--key-auth}'[indicates if an authorization value is needed for the object]'
    {-o,--output}'[output file path for the encoded object]:file:_files'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    {-V,--verbose}'[increase verbosity of tool output]'
    {-Q,--quiet}'[suppress informational output]'
    {-Z,--enable-errata}'[enable errata fixups]'
    {-R,--autoflush}'[autoflush objects created by the command]'
    '*:filename:_files'
)
_arguments -s $arguments
