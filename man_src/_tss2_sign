#compdef tss2_sign

local arguments

arguments=(
    {-p,--keyPath}'[path to the signing key]:path'
    {-s,--padding}'[the padding scheme used]:padding'
    {-c,--certificate}'[the certificate associated with keyPath in PEM format]:file:_files'
    {-d,--digest}'[data to be signed, already hashed]:file:_files'
    {-f,--force}'[force overwriting the output file]'
    {-k,--publicKey}'[the public key in PEM format]:file:_files'
    {-o,--signature}'[returns the signature in binary form]:file:_files'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
