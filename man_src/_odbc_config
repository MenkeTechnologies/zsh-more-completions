#compdef odbc_config

local arguments

arguments=(
    '--prefix[Prefix for architecture-independent file tree]'
    '--exec-prefix[Prefix for architecture-dependent file tree]'
    '--include-prefix[Directory with C header files for unixODBC]'
    '--lib-prefix[Directory with object code libraries]'
    '--bin-prefix[Location of user executables]'
    '--version[unixODBC version]'
    '--libs[Compiler flags for linking dynamic libraries]'
    '--static-libs[Absolute file name of static unixODBC library]'
    '--libtool-libs[Absolute file name of libtool unixODBC library]'
    '--cflags[Compiler flags to find include files and critical defines used by unixODBC]'
    '--odbcversion[Version of the ODBC specification used by unixODBC]'
    '--odbcini[Absolute file name of the system-wide DSN configuration file odbc.ini]'
    '--odbcinstini[Absolute file name of the driver configuration file odbcinst.ini]'
    '--header[Definitions of used C preprocessor constants]'
    '--ulen[Compiler flag for defining SIZEOF_SQLULEN]'
    '*:filename:_files'
)
_arguments -s $arguments
