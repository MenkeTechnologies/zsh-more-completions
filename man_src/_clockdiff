local arguments

arguments=(
    '-o[Use IP timestamp with ICMP echo instead of ICMP timestamp messages]'
    '-o1[Use three-term IP timestamp with prespecified hop addresses]'
    '*:host:_hosts'
)
_arguments -s $arguments
