#compdef db_tuner
# Documentation: https://man.archlinux.org/search?q=db_tuner
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-c[Specify a value of the cache size]:cache size'
    '-d[Display database statistics for the specified file]:file:_files'
    '-h[Specify a home directory for the database environment]:directory:_directories'
    '-s[Display page size recommendation for the specified database]:database'
    '-v[Display verbose information]'
    '*:filename:_files'
)
_arguments -s $arguments
