#compdef x11vnc

local arguments

arguments=(
    '-display[X display to serve]:display'
    '-auth[Set the X authority file]:file:_files'
    '-N[If the X display is :N, try to set the VNC display to also be :N]'
    '-autoport[Automatically probe for a free VNC port starting at n]:port'
    '-rfbport[The VNC port to listen on]:port'
    '-no6[Disable IPv6 listening support]'
    '-noipv6[Do not try to use IPv6]'
    '-noipv4[Do not try to use IPv4]'
    '-passwd[Specify VNC password]:password'
    '-storepasswd[Store a VNC password to a file]'
    '-usepw[Look for ~/.vnc/passwd or prompt for password if no other method supplied]'
    '-nopw[Disable the big warning message when running without a password]'
    '-viewpasswd[Supply a 2nd password for view-only logins]:password'
    '-accept[Run command to accept or reject incoming clients]:command'
    '-gone[Run command when a client disconnects]:command'
    '-localhost[Only allow VNC connections from localhost]'
    '-ssl[Enable SSL encrypted connections]:pem:_files'
    '-stunnel[Use stunnel for SSL encrypted connections]:pem:_files'
    '-http[Try to serve Java VNC viewer applet via HTTP]'
    '-connect[Connect to a VNC viewer in listening mode]:host\:port'
    '-shared[Allow multiple VNC clients to connect simultaneously]'
    '-forever[Keep listening for more connections rather than exiting]'
    '-once[Exit after the first successfully connected viewer disconnects]'
    '-loop[Create an outer loop restarting x11vnc whenever it terminates]'
    '-timeout[Exit unless a client connects within n seconds]:seconds'
    '-viewonly[All VNC clients can only watch]'
    '-scale[Scale the display by the fraction]:fraction'
    '-clip[Only show the sub-region of the full display]:WxH+X+Y'
    '-id[Show only the window corresponding to windowid]:windowid'
    '-sid[Like -id but shift a root view to it]:windowid'
    '-ncache[Client-side caching]:size'
    '-wireframe[Use wireframe for window moves]'
    '-scrollcopyrect[Use copyrect encoding for scroll detection]:mode'
    '-noxdamage[Do not use the XDAMAGE extension]'
    '-cursor[Set cursor display mode]:mode'
    '-nocursor[Do not display any cursor]'
    '-noxfixes[Do not use the XFIXES extension for cursor shapes]'
    '-solid[Set solid background color when clients are connected]:color'
    '-xrandr[Handle XRANDR screen size changes]:mode'
    '-rotate[Rotate and/or flip the framebuffer]:string'
    '-o[Write stderr messages to log file]:logfile:_files'
    '-rc[Use specified file instead of ~/.x11vncrc]:filename:_files'
    '-norc[Do not process any .x11vncrc file]'
    '-bg[Fork into the background after setup]'
    '-noshm[Do not use the MIT-SHM extension for polling]'
    '-rawfb[Use raw framebuffer instead of X display]:string'
    '-find[Find the user display automatically]'
    '-create[Create a virtual display with Xvfb]'
    '-users[Switch to user after connections]:list'
    '-wait[Time in ms to pause between screen polls]:ms'
    '-defer[Time in ms to delay sending updates to clients]:ms'
    '-nap[Take longer naps between screen polls when activity is low]'
    '-gui[Start the tkx11vnc GUI]:opts'
    '-remote[Run a remote command on a running x11vnc]:command'
    '-query[Query the value of a parameter in a running x11vnc]:variable'
    '(- * :)'{-h,--help}'[Print help text]'
    {-V,--version}'[Print version and last modification date]'
    {-v,--verbose}'[Print more information to stderr]'
    '*:filename:_files'
)
_arguments -s $arguments
