#compdef firewalld
# Documentation: https://man.archlinux.org/search?q=firewalld
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Print a short help text and exit]'
    '--debug[Set the debug level for firewalld]:level'
    '--debug-gc[Print garbage collector leak information]'
    '--nofork[Turn off daemon forking]'
    '--nopid[Disable writing pid file]'
    '*:filename:_files'
)
_arguments -s $arguments
