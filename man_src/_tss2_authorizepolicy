#compdef tss2_authorizepolicy
# Documentation: https://man.archlinux.org/search?q=tss2_authorizepolicy
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-P,--policyPath}'[path to the policy]:path'
    {-p,--keyPath}'[path to the key]:path'
    {-r,--policyRef}'[byte buffer to be included in the signature]:policy_ref'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
