#compdef package-cleanup

local arguments

arguments=(
    '-c[Use alternative config file]:file:_files'
    '(- * :)'{-h,--help}'[Display a help message and quit]'
    {-q,--quiet}'[Print out nothing unnecessary]'
    {-v,--version}'[Report program version and exit]'
    '-y[Agree to anything asked]'
    '--leaves[List leaf nodes in the local RPM database]'
    '--orphans[List installed packages not available from configured repositories]'
    '--oldkernels[Remove old kernel and kernel-devel packages]'
    '--problems[List dependency problems in the local RPM database]'
    '--dupes[Scan for duplicates in the local RPM database]'
    '--cleandupes[Scan for duplicates and clean out the older versions]'
    '--removenewestdupes[Remove newest dupes instead of oldest when cleaning duplicates]'
    '--noscripts[Disable rpm scriptlets from running when cleaning duplicates]'
    '--count[Number of duplicate/kernel packages to keep on the system]:count'
    '--all[When listing leaf nodes also list leaf nodes that are not libraries]'
    '--leaf-regex[A package name matching this regex will be considered a leaf]:regex'
    '--exclude-devel[When listing leaf nodes do not list development packages]'
    '--exclude-bin[When listing leaf nodes do not list packages with files in bin directories]'
    '--keepdevel[Do not remove kernel-devel packages when removing kernels]'
    '*:filename:_files'
)
_arguments -s $arguments
