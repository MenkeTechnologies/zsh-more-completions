#compdef matchpathcon

local arguments

arguments=(
    '-m[Force file type for the lookup]:type'
    '-n[Do not display path]'
    '-N[Do not use translations]'
    '-f[Use alternate file_context file]:file_context_file:_files'
    '-p[Use prefix to speed translations]:prefix'
    '-P[Use alternate policy root path]:policy_root_path:_directories'
    '-V[Verify file context on disk matches defaults]'
    '*:filename:_files'
)
_arguments -s $arguments
