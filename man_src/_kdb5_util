#compdef kdb5_util

local arguments

arguments=(
    '-r[Specify the Kerberos realm of the database]:realm'
    '-d[Specify the name under which the principal database is stored]:dbname'
    '-k[Specify the key type of the master key in the database]:mkeytype'
    '-M[Principal name for the master key in the database]:mkeyname'
    '-m[Read the master database password from the keyboard]'
    '-P[Specify the master database password]:password'
    '--sf[Specify the stash filename of the master database password]:stash_file:_files'
    '--b7[Cause the dump to be in the Kerberos 5 Beta 7 format]'
    '--ov[Cause the dump to be in ovsec_adm_export format]'
    '--r13[Cause the dump to be in the Kerberos 5 1.3 format]'
    '--r18[Cause the dump to be in the Kerberos 5 1.8 format]'
    '--verbose[Print the name of each principal and policy as it is dumped]'
    '--mkey_convert[Prompt for a new master key]'
    '--new_mkey_file[Specify the filename of a stash file]:mkey_file:_files'
    '--rev[Dump in reverse order]'
    '--recurse[Walk the database recursively (btree only)]'
    '--hash[Require the database to be stored as a hash]'
    '--update[Add or update records from the dump file in the existing database]'
    '-f[Do not prompt for confirmation]'
    '-n[Perform a dry run, showing master keys that would be purged]'
    '-v[Give more verbose output]'
    '-H[Suppress writing the field names in a header line]'
    '-c[Use CSV format with minimal quoting]'
    '-e[Write empty hexadecimal string fields as empty fields]'
    '-o[Write the dump to the specified output file]:outfile:_files'
    '*:filename:_files'
)
_arguments -s $arguments
