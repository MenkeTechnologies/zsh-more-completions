#compdef fido2-assert

local arguments

arguments=(
    '-G[Obtain a new assertion from device]'
    '-V[Verify an assertion using the PEM-encoded public key in the given file]'
    '-b[Request the credential largeBlobKey]'
    '-h[Enable the FIDO2 hmac-secret extension when obtaining an assertion]'
    '-d[Emit debugging output on stderr]'
    '-i[Read the parameters of the assertion from input_file instead of stdin]:input_file:_files'
    '-o[Write output on output_file instead of stdout]:output_file:_files'
    '-p[Request user presence when obtaining an assertion]'
    '-r[Obtain an assertion using a resident credential]'
    '-t[Toggle a key/value option]:option'
    '-u[Obtain an assertion using U2F]'
    '-v[Prompt the user for a PIN and request user verification]'
    '*:filename:_files'
)
_arguments -s $arguments
