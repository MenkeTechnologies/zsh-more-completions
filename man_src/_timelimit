#compdef timelimit

local arguments

arguments=(
    '-p[propagate the signal if the child is terminated by a signal]'
    '-q[quiet operation, do not output diagnostic messages]'
    '-S[specify the kill signal number]:signal'
    '-s[specify the warning signal number]:signal'
    '-T[specify the kill timeout in seconds after warning signal]:seconds'
    '-t[specify the maximum execution time before sending warning signal]:seconds'
    '*:filename:_files'
)
_arguments -s $arguments
