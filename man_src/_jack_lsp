#compdef jack_lsp
# Documentation: https://man.archlinux.org/search?q=jack_lsp
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-s,--server}'[Connect to the JACK server named servername]:servername'
    {-A,--aliases}'[List aliases for each port]'
    {-c,--connections}'[List connections to/from each port]'
    {-l,--latency}'[Display per-port latency in frames at each port]'
    '-L[Display total latency in frames at each port]'
    {-p,--properties}'[Display port properties]'
    {-t,--type}'[Display port type]'
    '(- * :)'{-h,--help}'[Display help/usage message]'
    {-v,--version}'[Display version]'
    '*:filename:_files'
)
_arguments -s $arguments
