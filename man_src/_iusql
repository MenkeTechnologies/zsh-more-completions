#compdef iusql

local arguments

arguments=(
    '-b[Run isql in non-interactive batch mode]'
    '-d[Delimit columns with the specified delimiter]:delimiter'
    '-x[Delimit columns with the character represented in hexadecimal]:hex'
    '-w[Format the result as an HTML table]'
    '-c[Output the names of the columns on the first row]'
    '-m[Limit the column display width to NUM characters]:num'
    '-l[Set the character locale]:locale'
    '-q[Wrap the character fields in double quotes]'
    '-3[Use calls from ODBC version 3]'
    '-n[Process multiple lines of SQL, terminated with the GO command]'
    '-e[Use SQLExecDirect instead of Prepare]'
    '-k[Use SQLDriverConnect]'
    '-v[Enable verbose mode, fully describing all errors]'
    '--version[Display the program version]'
    '-L[Set the maximum number of characters displayed from a character field]:num'
    '*:filename:_files'
)
_arguments -s $arguments
