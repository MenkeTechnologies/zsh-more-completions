#compdef xdelta3

local arguments

arguments=(
    '-0[Compression level 0 (no compression)]'
    '-9[Compression level 9 (best compression)]'
    '-c[Use stdout]'
    '-d[Decompress]'
    '-e[Compress]'
    '-f[Force overwrite]'
    '-h[Show help]'
    '-q[Be quiet]'
    '-v[Be verbose (max 2)]'
    '-V[Show version]'
    '-B[Source window size in bytes]:bytes'
    '-W[Input window size in bytes]:bytes'
    '-P[Compression duplicates window size]:size'
    '-I[Instruction buffer size (0 = unlimited)]:size'
    '-s[Source file to copy from]:source:_files'
    '-S[Enable/disable secondary compression]:method:(djw fgk lzma none)'
    '-N[Disable small string-matching compression]'
    '-D[Disable external decompression]'
    '-R[Disable external recompression]'
    '-n[Disable checksum]'
    '-C[Soft config]'
    '-A[Disable/provide application header]:apphead'
    '-J[Disable output (check/compute only)]'
    '-T[Use alternate code table (test)]'
    '*:filename:_files'
)
_arguments -s $arguments
