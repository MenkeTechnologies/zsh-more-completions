#compdef usbconfig

local arguments

arguments=(
    '-u[Limit device range to USB devices connected to the given USBUS unit]:unit'
    '-a[Limit device range to the given USB device index]:address'
    '-d[Limit device range to USB devices connected to the given unit and address]:unit.address'
    '-h[Show help and available commands]'
    '*:filename:_files'
)
_arguments -s $arguments
