#compdef xcscontrol

local arguments

arguments=(
    {-h,--help,--usage}'[Print basic usage information]'
    '--version[Display version information]'
    '--preflight[Preflight the Xcode Server service]'
    '--initialize[Initialize Xcode Server]'
    '--reset[Reset Xcode Server, removing all service data]'
    '--restart[Restart Xcode Server without removing any service data]'
    '--shutdown[Stop Xcode Server]'
    '*:filename:_files'
)
_arguments -s $arguments
