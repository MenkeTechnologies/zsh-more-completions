#compdef cdparanoia

local arguments

arguments=(
    {-A,--analyze-drive}'[Run and log a complete analysis of drive caching, timing and reading behavior]'
    {-v,--verbose}'[Be absurdly verbose about the autosensing and reading process]'
    {-q,--quiet}'[Do not print any progress or error information during the reading process]'
    {-e,--stderr-progress}'[Force output of progress information to stderr]'
    {-l,--log-summary}'[Save result summary to file]:file:_files'
    {-L,--log-debug}'[Save detailed device autosense and debugging output to a file]:file:_files'
    {-V,--version}'[Print the program version and quit]'
    {-Q,--query}'[Perform CDROM drive autosense, query and print the CDROM table of contents]'
    {-s,--search-for-drive}'[Force a complete search for a cdrom drive]'
    '(- * :)'{-h,--help}'[Print a brief synopsis of cdparanoia usage and options]'
    {-p,--output-raw}'[Output headerless data as raw 16 bit PCM data with interleaved samples in host byte order]'
    {-r,--output-raw-little-endian}'[Output headerless data as raw 16 bit PCM data in LSB first byte order]'
    {-R,--output-raw-big-endian}'[Output headerless data as raw 16 bit PCM data in MSB first byte order]'
    {-w,--output-wav}'[Output data in Microsoft RIFF WAV format]'
    {-f,--output-aiff}'[Output data in Apple AIFF format]'
    {-a,--output-aifc}'[Output data in uncompressed Apple AIFF-C format]'
    {-B,--batch}'[Batch output flag, split output into multiple files by track]'
    {-c,--force-cdrom-little-endian}'[Force cdparanoia to treat the drive as a little endian device]'
    {-C,--force-cdrom-big-endian}'[Force cdparanoia to treat the drive as a big endian device]'
    {-n,--force-default-sectors}'[Force the interface backend to do atomic reads of n sectors per read]:sectors'
    {-d,--force-cdrom-device}'[Force the interface backend to read from the specified device]:device:_files'
    {-k,--force-cooked-device}'[Force use of the old cooked ioctl kernel interface]:device:_files'
    {-g,--force-generic-device}'[Force use of the old generic scsi kernel interface]:device:_files'
    {-S,--force-read-speed}'[Set the read rate of the CD drive]:speed'
    {-t,--toc-offset}'[Force the entire disc LBA addressing to shift by the given amount]:offset'
    {-T,--toc-bias}'[Compensate for track beginning offset reported by some drives]'
    {-O,--sample-offset}'[Force the entire disc to shift sample position output by the given amount]:offset'
    {-Z,--disable-paranoia}'[Disable all data verification and correction features]'
    {-z,--never-skip}'[Do not accept any skips, retry forever if needed]:max retries'
    {-Y,--disable-extra-paranoia}'[Disable intra-read data verification, only overlap checking at read boundaries]'
    {-X,--abort-on-skip}'[If the read skips due to imperfect data, abort reading]'
    '*:filename:_files'
)
_arguments -s $arguments
