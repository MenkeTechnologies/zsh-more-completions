#compdef ctfdump

local arguments

arguments=(
    '-d[Show the data object section]'
    '-f[Show the function section]'
    '-h[Show the header]'
    '-l[Show the label section]'
    '-s[Show the string table]'
    '-S[Show statistics]'
    '-t[Show the type section]'
    '-u[Write the uncompressed CTF data to a raw CTF file]:file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
