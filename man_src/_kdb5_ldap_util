#compdef kdb5_ldap_util

local arguments

arguments=(
    '-r[Specify the realm to be operated on]:realm'
    '-D[Specify the Distinguished Name of the user]:user_dn'
    '-w[Specify the password of user_dn]:passwd'
    '-H[Specify the URI of the LDAP server]:ldapuri'
    '--subtrees[Specify the list of subtrees containing the principals of a realm]:subtree_dn_list'
    '--sscope[Specify the scope for searching the principals under the subtree]:search_scope'
    '--containerref[Specify the DN of the container object]:container_reference_dn'
    '-k[Specify the key type of the master key]:mkeytype'
    '-M[Specify the principal name for the master key]:mkeyname'
    '-m[Read the master database password from the TTY]'
    '-P[Specify the master database password]:password'
    '-s[Create the stash file]'
    '--maxtktlife[Specify maximum ticket life for principals in this realm]:max_ticket_life'
    '--maxrenewlife[Specify maximum renewable life of tickets for principals in this realm]:max_renewable_ticket_life'
    '-f[Do not prompt the user for confirmation]'
    '--force[Force the deletion of the policy object]'
    '*:filename:_files'
)
_arguments -s $arguments
