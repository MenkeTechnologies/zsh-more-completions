#compdef invproj

local arguments

arguments=(
    '-b[Binary coordinate data input and output through standard input and output]'
    '-i[Select binary input only]'
    '-I[Alternate method to specify inverse projection]'
    '-o[Select binary output only]'
    '-e[Arbitrary string to be output if an error is detected]:string'
    '-E[Copy the input coordinates to the output line prior to printing the converted values]'
    '-l[List projection identifiers]:id'
    '-lp[List of all projection ids that can be used with +proj]'
    '-lP[Expanded description of all projections]'
    '-le[List of all ellipsoids that can be selected with +ellps]'
    '-lu[List of all distance units that can be selected with +units]'
    '-ld[List of datums that can be selected with +datum]'
    '-r[Reverse the order of the expected input from longitude-latitude to latitude-longitude]'
    '-s[Reverse the order of the output from x-y to y-x]'
    '-S[Cause estimation of meridional and parallel scale factors]'
    '-m[Scale cartesian data by the mult parameter]:mult'
    '-f[Printf format string to control the form of the output values]:format'
    '-v[Display information relating to cartographic control parameters]'
    '-V[Display an expanded annotated listing of the characteristics of the cartographic projection]'
    '*:filename:_files'
)
_arguments -s $arguments
