#compdef sensortag

# Updated with fixes for empty descriptions

local arguments

arguments=(
    {-h,--help}'[Show this help message and exit]'
    '-n[Number of times to loop data]:count'
    '-t[Time between polling]:seconds'
    {-T,--temperature}'[Enable temperature sensor]'
    {-A,--accelerometer}'[Enable accelerometer sensor]'
    {-H,--humidity}'[Enable humidity sensor]'
    {-M,--magnetometer}'[Enable magnetometer sensor]'
    {-B,--barometer}'[Enable barometer sensor]'
    {-G,--gyroscope}'[Enable gyroscope sensor]'
    {-K,--keypress}'[Enable keypress sensor]'
    {-L,--light}'[Enable light sensor]'
    {-P,--battery}'[Enable battery sensor]'
    '--all[Enable all sensors]'
    '*:filename:_files'
)
_arguments -s $arguments
