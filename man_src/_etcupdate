#compdef etcupdate

local arguments

arguments=(
    '-A[Always install the new version of files matching the given patterns]:patterns'
    '-B[Do not build generated files in a private object tree]'
    '-D[Specify an alternate destination directory as the target of a merge]:directory:_directories'
    '-d[Specify an alternate directory to use as the work directory]:directory:_directories'
    '-F[Ignore changes in the FreeBSD ID string when comparing files]'
    '-I[Ignore files matching the given patterns]:patterns'
    '-L[Specify an alternate path for the log file]:path:_files'
    '-M[Pass options as additional parameters to make when building]:options'
    '-n[Enable dry-run mode, do not merge any changes]'
    '-p[Enable pre-world mode]'
    '-r[Do not update the current and previous trees during a merge]'
    '-s[Specify an alternate source tree]:directory:_directories'
    '-t[Extract a new current tree from a tarball]:tarball:_files'
    '*:filename:_files'
)
_arguments -s $arguments
