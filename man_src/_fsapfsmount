#compdef fsapfsmount

local arguments

arguments=(
    '-f[Mount a specific file system or "all"]:filesystem'
    '-h[Show this help]'
    '-o[Specify the volume offset in bytes]:offset'
    '-p[Specify the password]:password'
    '-r[Specify the recovery password]:password'
    '-v[Verbose output to stderr]'
    '-V[Print version]'
    '-X[Extended options to pass to sub system]:options'
    '*:filename:_files'
)
_arguments -s $arguments
