#compdef tpm2_pcrlist

local arguments

arguments=(
    '-g[output PCR banks with the given algorithm]:algorithm'
    '-o[write the PCR values in binary format]:file:_files'
    '-L[list of PCR banks and selected PCR ids]:pcr_list'
    '-s[show all supported algorithms]'
    '-h[display help information]'
    '-v[display version, supported tctis and exit]'
    '-V[increase verbosity of tool output]'
    '-Q[suppress informational output]'
    '-Z[enable errata fixups]'
    '-T[select the TCTI used for communication]:tcti'
    '*:filename:_files'
)
_arguments -s $arguments
