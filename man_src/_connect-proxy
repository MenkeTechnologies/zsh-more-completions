#compdef connect-proxy

local arguments

arguments=(
    '-H[Specify hostname and port of the HTTP proxy server]:host\:port'
    '-S[Specify hostname and port of the SOCKS server]:host\:port'
    '-4[Use SOCKS version 4]'
    '-R[Method to resolve the hostname]:method'
    '-p[Forward a local TCP port instead of using stdin/stdout]:port'
    '-P[Same as -p except keep remote session]:port'
    '-w[Timeout in seconds for making connection with target host]:seconds'
    '*:filename:_files'
)
_arguments -s $arguments
