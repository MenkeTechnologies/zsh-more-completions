#compdef coredumpctl

# Updated with latest systemd coredumpctl options

local arguments

arguments=(
    '--no-legend[Do not print column headers]'
    '-1[Show information of the most recent coredump only]'
    '-S[Show coredumps since the specified date/time]:since'
    '-U[Show coredumps until the specified date/time]:until'
    {-r,--reverse}'[Show the newest entries first]'
    {-F,--field}'[Print all possible data values the specified field takes]:field'
    {-o,--output}'[Write the core to FILE]:FILE:_files'
    {-D,--directory}'[Use the journal files in the specified directory]:DIR:_directories'
    {-q,--quiet}'[Suppress informational messages]'
    '--debugger[Use the specified debugger]:debugger:_command_names'
    '--debugger-arguments[Pass extra arguments to the debugger]:arguments'
    '--json[Show coredump information in JSON]:format:(short pretty off)'
    '(- * :)'{-h,--help}'[Print a short help text and exit]'
    '--version[Print a short version string and exit]'
    '--no-pager[Do not pipe output into a pager]'
    '*:: :->subcmd'
)

_arguments -s $arguments

case "$state" in
    subcmd)
        local -a commands
        commands=(
            'list:List available coredumps'
            'info:Show detailed information about coredumps'
            'dump:Print coredump to stdout or save to file'
            'debug:Start a debugger for a coredump'
        )
        _describe 'command' commands
        ;;
esac
