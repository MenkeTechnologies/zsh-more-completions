#compdef winicontopam
# Documentation: https://man.archlinux.org/search?q=winicontopam
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--allimages[Convert all images in the input]'
    '--image[Convert image number index (starting with zero)]:index'
    '--andmasks[Include AND masks in the output]'
    '--verbose[Print more messages]'
    '*:filename:_files'
)
_arguments -s $arguments
