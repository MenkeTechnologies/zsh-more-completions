#compdef enchant-lsmod
# Documentation: https://man.archlinux.org/search?q=enchant-lsmod
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--lang[Show dictionary to be used for given language tag]:language_tag'
    '--list-dicts[List preferred dictionaries for language tags]'
    '-h[Show help info and exit]'
    '-v[Show version and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
