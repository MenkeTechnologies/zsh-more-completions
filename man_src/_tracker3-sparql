#compdef tracker3-sparql

local arguments

arguments=(
    {-b,--dbus-service}'[connect to a SPARQL endpoint at a D-Bus name]:service_name'
    {-d,--database-path}'[connect to a database by filesystem location]:database_path:_directories'
    {-r,--remote-service}'[connect to a HTTP SPARQL endpoint]:url'
    {-f,--file}'[use a file with SPARQL content to query or update]:file:_files'
    {-q,--query}'[use a SPARQL string to query the database]:sparql'
    {-u,--update}'[use with --query to perform an update]'
    {-a,--arg}'[provide an argument for a parameter in the SPARQL query]:arg'
    {-c,--list-classes}'[return a list of classes describing the ontology]'
    {-x,--list-class-prefixes}'[return a list of prefixes in shortened and long form]'
    {-p,--list-properties}'[return a list of properties pertaining to a class]:class'
    {-n,--list-notifies}'[return a list of classes notified over D-Bus about changes]:class'
    {-i,--list-indexes}'[return a list of indexed properties]:property'
    {-g,--list-graphs}'[list all the named graphs in the database]'
    {-t,--tree}'[print a tree showing all parent classes]:class'
    {-s,--search}'[return classes and properties matching needle]:needle'
    '--get-shorthand[return the shorthand for a class given by URL]:class'
    '--get-longhand[return the longhand for a class given in CLASS:PROPERTY form]:class'
    '*:filename:_files'
)
_arguments -s $arguments
