#compdef kismetdb_to_pcap

local arguments

arguments=(
    {-i,--in}'[Input kismetdb file]:file:_files'
    {-o,--out}'[Output file name]:file:_files'
    {-f,--force}'[Overwrite any existing output files]'
    {-v,--verbose}'[Verbose output]'
    {-s,--skip-clean}'[Do not clean (SQL vacuum) input database]'
    '--old-pcap[Create a traditional pcap file]'
    '--dlt[Limit pcap to a single DLT (link type)]:dlt'
    '--list-datasources[List datasources in kismetdb; do not create a pcap file]'
    '--datasource[Include packets from this datasource]:datasource'
    '--split-datasource[Split output into multiple files by datasource]'
    '--split-packets[Split output into multiple files by packet count]:count'
    '--split-size[Split output into multiple files by size]:size'
    '--skip-gps[Do not include GPS information when generating pcapng logs]'
    '--skip-gps-track[Do not include GPS movement when generating pcapng logs]'
    '*:filename:_files'
)
_arguments -s $arguments
