#compdef xcodebuild

local arguments

arguments=(
    '-project[Build the project specified by name]:name'
    '-target[Build the target specified by targetname]:targetname'
    '-alltargets[Build all the targets in the specified project]'
    '-workspace[Build the workspace specified by name]:name'
    '-scheme[Build the scheme specified by schemename]:schemename'
    '-destination[Use the destination device described by destinationspecifier]:destinationspecifier'
    '-destination-timeout[Timeout when searching for a destination device]:timeout'
    '-configuration[Use the build configuration specified by configurationname]:configurationname'
    '-arch[Use the specified architecture when building each target]:architecture'
    '-sdk[Build against the specified SDK]:sdkname'
    '-showsdks[List all available SDKs]'
    '-showBuildSettings[List the build settings in a project or workspace and scheme]'
    '-showdestinations[List the valid destinations for a project or workspace and scheme]'
    '-showBuildTimingSummary[Display a report of the timings of all commands invoked during the build]'
    '-showTestPlans[List the test plans associated with the specified scheme]'
    '-list[List the targets and configurations in a project, or the schemes in a workspace]'
    '-enableAddressSanitizer[Turn the address sanitizer on or off]:yn:(YES NO)'
    '-enableThreadSanitizer[Turn the thread sanitizer on or off]:yn:(YES NO)'
    '-enableUndefinedBehaviorSanitizer[Turn the undefined behavior sanitizer on or off]:yn:(YES NO)'
    '-enableCodeCoverage[Turn code coverage on or off during testing]:yn:(YES NO)'
    '-testLanguage[Specify ISO 639-1 language during testing]:language'
    '-testRegion[Specify ISO 3166-1 region during testing]:region'
    '-derivedDataPath[Override the folder for derived data]:path:_directories'
    '-resultBundlePath[Write a bundle to the specified path with results]:path:_files'
    '-allowProvisioningUpdates[Allow xcodebuild to communicate with the Apple Developer website]'
    '-allowProvisioningDeviceRegistration[Allow xcodebuild to register your destination device]'
    '-exportArchive[Distribute an archive]'
    '-exportNotarizedApp[Export an archive that has been notarized by Apple]'
    '-archivePath[Specify the path for the archive]:path:_files'
    '-exportPath[Specify the destination for the exported product]:path:_directories'
    '-exportOptionsPlist[Specify options for exportArchive]:plist:_files'
    '-exportLocalizations[Export localizations to XLIFF files]'
    '-importLocalizations[Import localizations from an XLIFF file]'
    '-localizationPath[Specify a path to a directory or a single XLIFF localization file]:path:_files'
    '-exportLanguage[Specify optional ISO 639-1 languages included in a localization export]:language'
    '-xcconfig[Load the build settings defined in filename]:filename:_files'
    '-xctestrun[Specify test run parameters]:path:_files'
    '-testPlan[Specify which test plan to use for testing]:testPlanName'
    '-skip-testing[Constrain test targets, classes, or methods in test actions]:identifier'
    '-skip-test-configuration[Constrain test configurations in test actions]:configuration'
    '-disable-concurrent-destination-testing[Do not run tests on specified destinations concurrently]'
    '-maximum-concurrent-test-device-destinations[Maximum number of device destinations to test on concurrently]:number'
    '-maximum-concurrent-test-simulator-destinations[Maximum number of simulator destinations to test on concurrently]:number'
    '-parallel-testing-enabled[Override per-target setting for running tests in parallel]:yn:(YES NO)'
    '-parallel-testing-worker-count[Spawn exactly this many test runners]:number'
    '-maximum-parallel-testing-workers[Limit the number of test runners]:number'
    '-parallelize-tests-among-destinations[Distribute tests among destinations]'
    '-test-timeouts-enabled[Enable or disable test timeout behavior]:yn:(YES NO)'
    '-default-test-execution-time-allowance[Default execution time for individual tests]:seconds'
    '-maximum-test-execution-time-allowance[Maximum execution time for individual tests]:seconds'
    '-dry-run[Print the commands that would be executed, but do not execute them]'
    '-skipUnavailableActions[Skip actions that cannot be performed instead of failing]'
    '-toolchain[Use a given toolchain]:identifier'
    '-quiet[Do not print any output except for warnings and errors]'
    '-verbose[Provide additional status output]'
    '-version[Display version information]'
    '-license[Show the Xcode and SDK license agreements]'
    '-checkFirstLaunchStatus[Check if any First Launch tasks need to be performed]'
    '-runFirstLaunch[Install packages and agree to the license]'
    '-usage[Display usage information]'
    '*:filename:_files'
)
_arguments -s $arguments
