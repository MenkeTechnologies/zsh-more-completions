#compdef lv2bench
# Documentation: https://man.archlinux.org/search?q=lv2bench
# Reference accessed: 2026-05-16

local arguments

arguments=(
  '-b[specify block size, in audio frames]'
  {-f,--full}'[full plottable output]'
  {-h,--help}'[display this help and exit]'
  '-n[total number of audio frames to process]'
  '--version[display version information and exit]'
  '*:filename:_files'
)

_arguments -s $arguments
