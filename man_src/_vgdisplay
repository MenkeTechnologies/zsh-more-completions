#compdef vgdisplay

local arguments

arguments=(
    {-A,--activevolumegroups}'[Only select active volume groups]'
    '--aligned[Use aligned output]'
    '--binary[Use binary values for yes/no columns]'
    {-c,--colon}'[Colon-separated output]'
    {-C,--columns}'[Display output in columns]'
    '--commandprofile[Select command configuration profile]:profile'
    '--config[Override configuration settings]:string'
    '--configreport[Select report configuration]:report:(log vg lv pv pvseg seg)'
    {-d,--debug}'[Set debug level]'
    '--driverloaded[Specify whether device-mapper driver is loaded]:yn:(y n)'
    '--foreign[Report or display foreign VGs]'
    '(- * :)'{-h,--help}'[Display help text]'
    '--ignorelockingfailure[Allow operations that normally require locking]'
    '--lockopt[Lock option string]:string'
    '--logonly[Suppress command report]'
    '--longhelp[Display long help text]'
    '--noheadings[Suppress headings]'
    '--nolocking[Disable locking]'
    '--nosuffix[Suppress suffix for sizes]'
    {-o,--options}'[Comma-separated list of fields to display]:fields'
    '--profile[Select metadata profile]:profile'
    {-q,--quiet}'[Suppress output]'
    '--readonly[Run in read-only mode]'
    '--reportformat[Select report format]:format:(basic json)'
    {-S,--select}'[Select objects for processing or reporting]:selection'
    '--separator[Column separator]:separator'
    '--shared[Report/display shared VGs]'
    {-s,--short}'[Give a short listing]'
    {-O,--sort}'[Sort output by fields]:fields'
    {-t,--test}'[Run in test mode]'
    '--unbuffered[Produce output immediately without buffering]'
    '--units[Output size units]:units:(r R h H b B s S k K m M g G t T p P e E)'
    {-v,--verbose}'[Set verbose level]'
    '--version[Display version information]'
    {-y,--yes}'[Answer yes to all prompts]'
    '*:VG name:'
)
_arguments -s $arguments
