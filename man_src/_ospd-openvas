#compdef ospd-openvas

local arguments

arguments=(
    {-s,--config-file}'[Use alternate configuration file]:file:_files'
    '--version[Print the version number and exit]'
    '(- * :)'{-h,--help}'[Show a summary of the commands]'
    {-p,--port}'[TCP port to listen on]:port'
    {-b,--bind-address}'[Address to listen on]:address'
    {-u,--unix-socket}'[Unix file socket to listen on]:socket:_files'
    {-m,--socket-mode}'[Unix file socket mode]:mode'
    '--pid-file[Location of the file for the process ID]:pid_file:_files'
    '--lock-file-dir[Directory where the feed lock file is placed]:dir:_directories'
    {-k,--key-file}'[Server key file]:key_file:_files'
    {-c,--cert-file}'[Server cert file]:cert_file:_files'
    '--ca-file[CA cert file]:ca_file:_files'
    {-L,--log-level}'[Desired level of logging]:level:(DEBUG INFO WARNING ERROR CRITICAL)'
    {-f,--foreground}'[Run in foreground and log all messages to console]'
    {-l,--log-file}'[Path to the logging file]:log_file:_files'
    '--stream-timeout[Set a timeout on socket operations in seconds]:timeout'
    '--niceness[Start the scan with the given niceness]:niceness'
    '--scaninfo-store-time[Time in hours a scan is stored before being deleted]:hours'
    '*:filename:_files'
)
_arguments -s $arguments
