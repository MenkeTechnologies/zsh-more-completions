#compdef tracker3-search

local arguments

arguments=(
    {-l,--limit}'[limit search to specified number of results]:limit'
    {-o,--offset}'[offset the search results by specified number]:offset'
    {-r,--or-operator}'[use OR for search terms instead of AND]'
    {-d,--detailed}'[show the unique URN associated with each search result]'
    {-a,--all}'[show results which might not be available]'
    '--disable-snippets[disable result snippets]'
    '--disable-fts[disable Full Text Search]'
    '--disable-color[disable ANSI color use]'
    '--folders[search for folders]'
    {-f,--files}'[search for files]'
    '-s[search for software]'
    {-m,--music}'[search for music]'
    '--music-albums[search for music albums]'
    '--music-artists[search for music artists]'
    {-i,--images}'[search for images]'
    {-v,--videos}'[search for videos]'
    {-t,--documents}'[search for documents]'
    '--software[search for software]'
    '--software-categories[search for software categories]'
    '--feeds[search for feeds]'
    '*:filename:_files'
)
_arguments -s $arguments
