#compdef etherwake

local arguments

arguments=(
    '-b[Send the wake-up packet to the broadcast address]'
    '-D[Increase the debug level]'
    '-i[Use interface ifname instead of the default]:ifname'
    '-p[Append a four or six byte password to the packet]:passwd'
    '-V[Show the program version information]'
    '*:filename:_files'
)
_arguments -s $arguments
