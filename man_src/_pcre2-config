#compdef pcre2-config

local arguments

arguments=(
    '--prefix[Write the directory prefix used in the PCRE2 installation]'
    '--exec-prefix[Write the directory prefix for architecture-dependent files]'
    '--version[Write the version number of the installed PCRE2 libraries]'
    '--libs8[Write linker flags for linking with the 8-bit PCRE2 library]'
    '--libs16[Write linker flags for linking with the 16-bit PCRE2 library]'
    '--libs32[Write linker flags for linking with the 32-bit PCRE2 library]'
    '--libs-posix[Write linker flags for linking with the POSIX PCRE2 wrapper library]'
    '--cflags[Write compiler flags for compiling with PCRE2]'
    '--cflags-posix[Write compiler flags for compiling with the POSIX PCRE2 wrapper]'
    '*:filename:_files'
)
_arguments -s $arguments
