#compdef dbus-launch

local arguments

arguments=(
    '--auto-syntax[Choose --csh-syntax or --sh-syntax based on the SHELL environment variable]'
    '--binary-syntax[Write bus address and PID in binary to stdout]'
    '--close-stderr[Close the standard error output stream before starting the D-Bus daemon]'
    '--config-file[Pass the specified config file to the bus daemon]:file:_files'
    '--csh-syntax[Emit csh compatible code to set up environment variables]'
    '--exit-with-x11[Exit when the X11 connection is lost]'
    '--exit-with-session[Exit when the login session ends]'
    '--autolaunch[Scan for a previously-started session bus]:machine id'
    '--sh-syntax[Emit Bourne-shell compatible code to set up environment variables]'
    '--version[Print the version of dbus-launch]'
    '(- * :)--help[Print the help info of dbus-launch]'
    '*:filename:_files'
)
_arguments -s $arguments
