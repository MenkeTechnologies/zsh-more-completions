#compdef compiz-boxmenu-vplist
# Documentation: https://man.archlinux.org/search?q=compiz-boxmenu-vplist
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-h[Show help options]'
    {-i,--images}'[Use images in the viewport list]'
    {-v,--viewport-icon}'[Use specified icon as the viewport icon]:icon'
    {-w,--wrap}'[Turn on viewport wrap navigation]'
    '*:filename:_files'
)
_arguments -s $arguments
