#compdef watchdogd

local arguments

arguments=(
    '-I[Write the process ID to the specified file]:pidfile:_files'
    '-d[Do not fork]'
    '-S[Do not send a message to the system logger when the watchdog command takes long]'
    '-w[Complain when the watchdog script takes too long]'
    '--pretimeout[Set a pretimeout watchdog]:seconds'
    '--pretimeout-action[Set the timeout action for the pretimeout]:action'
    '--softtimeout[Use basic software watchdog instead of hardware]'
    '--softtimeout-action[Set the timeout action for the softtimeout]:action'
    '*:filename:_files'
)
_arguments -s $arguments
