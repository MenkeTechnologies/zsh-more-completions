#compdef compton-trans
# Documentation: https://man.archlinux.org/search?q=compton-trans
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-w[Specify the window id of the target window]:window id'
    '-n[Specify and try to match a window name]:window name'
    '-c[Specify the currently active window as target]'
    '-s[Select target window with mouse cursor]'
    '-o[Specify the new opacity value for the window]:opacity'
    '*:filename:_files'
)
_arguments -s $arguments
