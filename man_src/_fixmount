#compdef fixmount

local arguments

arguments=(
    '-a[Work like showmount, filtering entries for the host]'
    '-r[Remove remote mount entries that do not correspond to current mounts]'
    '-v[Verify remote mounts]'
    '-A[Declare all file systems have been unmounted]'
    '-q[Be quiet]'
    '-h[Pretend the local hostname is this name]:name'
    '*:filename:_files'
)
_arguments -s $arguments
