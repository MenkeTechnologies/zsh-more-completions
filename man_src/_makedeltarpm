#compdef makedeltarpm

local arguments

arguments=(
    '-v[Be more verbose about the work (use it twice for even more)]'
    '-r[Create a rpm-only delta, not containing the rpm payload diff]'
    '-V[Specify a different version for the delta]'
    '-z[Specify a different compression method]:compression:(gzip bzip2 lzma xz zstd)'
    '-s[Write out the sequence id to the specified file]:seqfile:_files'
    '-p[Specify the rpm-print of oldrpm and the created patch rpm]'
    '-u[Create an applydeltarpm-only compatible delta from a single rpm]'
    '-m[Enable a sliding block algorithm that needs mbytes megabytes of memory]:mbytes'
    '*:filename:_files'
)
_arguments -s $arguments
