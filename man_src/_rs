#compdef rs

# Autogenerated from man page
# Updated with latest rs options

local arguments

arguments=(
    '-c[input columns are delimited by the single character x]:x'
    '-s[like -c, but maximal strings of x are delimiters]:x'
    '-C[output columns are delimited by the single character x]:x'
    '-S[like -C, but padded strings of x are delimiters]:x'
    '-t[fill in the rows of the output array using the columns of the input array (transpose)]'
    '-T[print the pure transpose of the input]'
    '-k[ignore the first N lines of input]:N'
    '-K[like -k, but print the ignored lines]:N'
    '-g[set the gutter width (inter-column space), normally 2]:N'
    '-G[add N percent of the maximum column width to the gutter width]:N'
    '-e[consider each line of input as an array entry]'
    '-n[on lines having fewer entries than the first line, use null entries to pad out]'
    '-y[pad the output with empty entries if there are too few entries]'
    '-h[print the shape of the input array and do nothing else]'
    '-H[like -h, but also print the length of each line]'
    '-j[right adjust entries within columns]'
    '-w[set the width of the display (normally 80)]:N'
    '-m[do not trim excess delimiters from the ends of the output array]'
    '-z[adapt column widths to fit the largest entries appearing in them]'
    '*:filename:_files'
)
_arguments -s $arguments
