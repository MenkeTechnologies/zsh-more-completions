#compdef kgdb

local arguments

arguments=(
    '-a[Increase the annotation level]'
    '-b[Set the baudrate]:rate'
    '-q[Suppress printing of the banner when the debugger starts]'
    '-v[Increase verbosity]'
    '-w[Open kmem-based targets in read-write mode]'
    '-d[Use crashdir instead of the default to locate kernel core dump files]:crashdir:_directories'
    '-c[Explicitly use core as the core dump file]:core:_files'
    '-n[Use the kernel core dump file numbered dumpnr for debugging]:dumpnr'
    '-r[Use device to connect kgdb to for a remote debugging session]:device'
    '*:filename:_files'
)
_arguments -s $arguments
