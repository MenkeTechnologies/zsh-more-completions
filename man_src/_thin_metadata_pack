#compdef thin_metadata_pack
# Documentation: https://man.archlinux.org/search?q=thin_metadata_pack
# Reference accessed: 2026-05-16

local arguments

arguments=(
  {-h,--help}'[prints help information]'
  {-V,--version}'[prints version information]'
  '-i[specify thinp metadata binary device/file]'
  '-o[specify packed output file]'
  '*:filename:_files'
)

_arguments -s $arguments
