#compdef papstatus

local arguments

arguments=(
    '-A[Connect to the printer at Appletalk address]:address'
    '-c[Take cuts]'
    '-d[Enable debug output]'
    '-e[Send printer messages to stderr instead of stdout]'
    '-E[Do not wait for EOF from the printer]'
    '-p[Connect to the printer named]:nbpname'
    '-s[Update the status file with the most recent status message]:statusfile:_files'
    '-w[Wait for printer status to contain "waiting" before sending]'
    '-W[Wait for printer status to contain "idle" before sending the job]'
    '*:filename:_files'
)
_arguments -s $arguments
