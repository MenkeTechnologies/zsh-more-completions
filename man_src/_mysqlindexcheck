#compdef mysqlindexcheck

local arguments

arguments=(
    '--help[Display help and exit]'
    '--best[Limit index statistics to the best N indexes]:N'
    '--format[Output format]:format:(grid csv tab vertical sql)'
    '--server[Connection information for the server]:source'
    {-d,--show-drops}'[Show DROP statements for redundant indexes]'
    {-i,--show-indexes}'[Show existing indexes]'
    {-s,--skip}'[Skip tables with storage engines that do not support indexes]'
    '--stats[Display index performance statistics]'
    '--worst[Limit index statistics to the worst N indexes]:N'
    {-v,--verbose}'[Verbose output]'
    '--version[Display version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
