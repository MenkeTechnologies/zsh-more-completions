#compdef kldconfig

local arguments

arguments=(
    '-d[Remove the specified paths from the module search path]'
    '-f[Do not display a diagnostic message if a path specified for adding is already in the path]'
    '-i[Add the specified paths to the beginning of the search path]'
    '-m[Merge specified paths instead of replacing the module search path]'
    '-n[Do not actually change the module search path]'
    '-r[Display the current search path]'
    '-S[Specify the sysctl name to use instead of the default]:sysctl'
    '-U[Unique-ify the current search path by removing duplicate directories]'
    '-v[Verbose output: display the new module search path]'
    '*:filename:_files'
)
_arguments -s $arguments
