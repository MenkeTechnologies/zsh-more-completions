#compdef genpmda

local arguments

arguments=(
    '-c[Input config file]:config:_files'
    '-i[PMDA name]:IAM'
    '-d[Generate an Install script for a daemon PMDA (default is DSO)]'
    '-t[Use topdir in generated GNUmakefile]:topdir:_directories'
    '-n[Use pmns as root of the namespace]:pmns'
    '-D[Use domain number in the generated pmns and domain]:domain'
    '-s[Path to stdpmid]:stdpmid:_files'
    '-o[Use dir for generated source code]:dir:_directories'
    '-v[Print verbose messages about what genpmda is doing]'
    '*:filename:_files'
)
_arguments -s $arguments
