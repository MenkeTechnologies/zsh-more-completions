#compdef tchtest

local arguments

arguments=(
    '--mt[perform multi-thread test]'
    '--tl[set the tuning leaf parameter]:num'
    '--td[set the tuning non-leaf parameter]:num'
    '--tb[set the bucket number]:num'
    '--tt[set the number of extra mapped memory]:size'
    '--tx[set the maximum number of leaf nodes cached]:num'
    '--rc[set the record cache limit]:num'
    '--xm[set the size of the extra mapped memory]:size'
    '--df[set defragmentation step]:num'
    '--nl[set the number of members in each leaf]:num'
    '--nb[set the number of members in each node]:num'
    '--as[use asynchronous writing]'
    '--rnd[use random keys]'
    '--wb[use write-behind caching]'
    '--pn[set the number of patterns]:num'
    '--dai[use auto-increment for integer keys]'
    '--dad[use auto-increment for double keys]'
    '--rl[set record locking]'
    '--ru[set record unlocking]'
    '*:filename:_files'
)
_arguments -s $arguments
