#compdef tpm2_policycphash
# Documentation: https://man.archlinux.org/search?q=tpm2_policycphash
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-L,--policy}'[file to save the compounded policy digest]:file:_files'
    {-S,--session}'[the policy session file]:file:_files'
    '--cphash-input[file containing the command parameter hash]:file:_files'
    '--cphash[file path to record command parameter hash (deprecated, use --cphash-input)]:file:_files'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    {-V,--verbose}'[increase verbosity of tool output]'
    {-Q,--quiet}'[suppress informational output]'
    {-Z,--enable-errata}'[enable errata fixups]'
    {-R,--autoflush}'[autoflush objects created by the command]'
    '*:filename:_files'
)
_arguments -s $arguments
