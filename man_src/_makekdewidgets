#compdef makekdewidgets

local arguments

arguments=(
    '-o[Output file]:file:_files'
    '-n[Name of the plugin class to generate]:name'
    '-g[Default widget group name to display in designer]:group'
    '-p[Embed pixmaps from a source directory]:dir:_directories'
    '--help[Show help about options]'
    '--help-qt[Show Qt specific options]'
    '--help-kde[Show KDE specific options]'
    '--help-all[Show all options]'
    '--author[Show author information]'
    {-v,--version}'[Show version information]'
    '--license[Show license information]'
    '--caption[Use specified caption as name in the titlebar]:caption'
    '--icon[Use specified icon as the application icon]:icon'
    '--config[Use alternative configuration file]:filename:_files'
    '--nocrashhandler[Disable crash handler to get core dumps]'
    '--waitforwm[Wait for a WM_NET compatible windowmanager]'
    '--style[Set the application GUI style]:style'
    '--geometry[Set the client geometry of the main widget]:geometry'
    '--display[Use the X-server display]:displayname'
    '--session[Restore the application for the given session]:sessionId'
    '--cmap[Install a private color map on an 8-bit display]'
    '--ncols[Limit the number of colors allocated in the color cube on an 8-bit display]:count'
    '--nograb[Tell Qt to never grab the mouse or the keyboard]'
    '--sync[Switch to synchronous mode for debugging]'
    {--fn,--font}'[Define the application font]:fontname'
    {--bg,--background}'[Set the default background color]:color'
    {--fg,--foreground}'[Set the default foreground color]:color'
    {--btn,--button}'[Set the default button color]:color'
    '--name[Set the application name]:name'
    '--title[Set the application title (caption)]:title'
    '--visual[Force the application to use a TrueColor visual on an 8-bit display]:TrueColor'
    '--inputstyle[Set XIM (X Input Method) input style]:inputstyle'
    '--im[Set XIM server]:server'
    '--noxim[Disable XIM]'
    '--reverse[Mirror the whole layout of widgets]'
    '*:filename:_files'
)
_arguments -s $arguments
