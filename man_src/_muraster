#compdef muraster

local arguments

arguments=(
    '-p[Password for the PDF document]:password'
    '-o[Output file name]:file:_files'
    '-F[Output format (default inferred from output file name)]:format'
    '-s[Show extra information]:info'
    '-R[Rotation angle]:angle:(0 90 180 270)'
    '-r[Resolution in dpi (default: 300x300)]:resolution'
    '-w[Printable width in inches (default: 8.27)]:width'
    '-h[Printable height in inches (default: 11.69)]:height'
    '-f[Fit file to page if too large]'
    '-B[Minimum band height]:height'
    '-M[Max band memory]:bytes'
    '-T[Number of threads to use for rendering]:threads'
    '-P[Parallel interpretation/rendering]'
    '-W[Page width for EPUB layout]:width'
    '-H[Page height for EPUB layout]:height'
    '-S[Font size for EPUB layout]:size'
    '-U[File name of user stylesheet for EPUB layout]:stylesheet:_files'
    '-X[Disable document styles for EPUB layout]'
    '-A[Number of bits of antialiasing (0 to 8)]:bits'
    '*:filename:_files'
)
_arguments -s $arguments
