#compdef tpm2_checkquote

local arguments

arguments=(
    {-u,--public}'[file input for the public portion of the verification key]:file:_files'
    {-g,--hash-algorithm}'[hash algorithm used to digest the message]:algorithm'
    {-m,--message}'[the quote message that makes up the signed data]:file:_files'
    {-s,--signature}'[the input signature file to be validated]:file:_files'
    {-f,--pcr}'[PCR input file with the list of PCR values]:file:_files'
    {-l,--pcr-list}'[the list of PCR banks and selected PCR ids]:pcr_list'
    {-q,--qualification}'[qualification data for the quote]:hex_string_or_path'
    {-F,--format}'[signature format (deprecated)]:format'
    '-n[expected name for the signing key]:name'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    {-V,--verbose}'[increase verbosity of tool output]'
    {-Q,--quiet}'[suppress informational output]'
    {-Z,--enable-errata}'[enable errata fixups]'
    {-R,--autoflush}'[autoflush objects created by the command]'
    '*:filename:_files'
)
_arguments -s $arguments
