#compdef inetd2rlinetd

local arguments

arguments=(
    '-f[File in inetd.conf format which will be converted]:file:_files'
    '-l[A single line in inetd.conf format to convert]:entry'
    '--force-overwrite[Force overwriting existing files with new version]'
    '--print-file-names[Print to standard output list of generated files]'
    '--add-from-comment[Add a special comment with original inetd entry]'
    '*:filename:_files'
)
_arguments -s $arguments
