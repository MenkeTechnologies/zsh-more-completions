#compdef faillock
# Documentation: https://man.archlinux.org/search?q=faillock
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--dir[The directory where the user files with failure records are kept]:directory:_directories'
    '--user[The user whose failure records should be displayed or cleared]:username:_users'
    '--reset[Clear the user failure records instead of displaying them]'
    '*:filename:_files'
)
_arguments -s $arguments
