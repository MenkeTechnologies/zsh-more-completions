#compdef wspsearch

local arguments

arguments=(
    '--query[A query specified in simplified AQS-like syntax]:query'
    '--search[A simple phrase that is searched across the index]:phrase'
    '--kind[Kind of result to search for]:kind'
    '--limit[A limit on the number of results returned]:number'
    {-\?,--help}'[Print a summary of command line options]'
    '--usage[Display brief usage message]'
    {-d,--debuglevel}'[Debug level (0-10)]:level'
    '--debug-stdout[Redirect debug output to stdout]'
    '--configfile[Configuration file]:file:_files'
    '--option[Set an smb.conf option]:name=value'
    {-l,--log-basename}'[Base directory name for log/debug files]:directory:_directories'
    '--leak-report[Enable talloc leak reporting on exit]'
    '--leak-report-full[Enable full talloc leak reporting on exit]'
    {-V,--version}'[Print the program version number]'
    {-U,--user}'[Set the SMB username or username and password]:user'
    {-N,--no-pass}'[Suppress the normal password prompt]'
    '--password[Specify the password on the commandline]:password'
    '--pw-nt-hash[The supplied password is the NT hash]'
    {-A,--authentication-file}'[File from which to read username and password]:file:_files'
    {-P,--machine-pass}'[Use stored machine account password]'
    '--simple-bind-dn[DN to use for a simple bind]:dn'
    '--use-kerberos[Kerberos authentication mode]:mode:(desired required off)'
    '--use-krb5-ccache[Specify the credential cache location for Kerberos]:ccache'
    '--use-winbind-ccache[Try to use the credential cache by winbind]'
    '--client-protection[Set connection protection]:mode:(sign encrypt off)'
    '*:filename:_files'
)
_arguments -s $arguments
