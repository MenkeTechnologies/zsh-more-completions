#compdef swtpm_bios

# Updated with fixes for descriptions

local arguments

arguments=(
    '--tpm-device[Use the given device (default is /dev/tpm0)]:device:_files'
    '--tcp[Connect to TPM on given host and port]:host\:port'
    '--unix[Connect to TPM using UnixIO socket]:path'
    '--tpm2[Initialize a TPM 2]'
    '-c[Startup clear (default)]'
    '-s[Startup state]'
    '-d[Startup deactivate (no effect on TPM2)]'
    '-n[No startup]'
    '-o[Startup only]'
    '-cs[Run TPM_ContinueSelfTest on TPM1.2]'
    '-ea[Make sure that the TPM 1.2 is activated]'
    '-u[Give up physical presence]'
    '-v[Display version and exit]'
    '-h[Display help screen and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
