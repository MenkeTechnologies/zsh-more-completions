#compdef kadmind

local arguments

arguments=(
    '-r[Specify the realm that kadmind will serve]:realm'
    '-m[Cause the master database password to be fetched from the keyboard]'
    '--nofork[Remain in the foreground and stay associated to the terminal]'
    '--proponly[Only listen and respond to Kerberos slave incremental propagation requests]'
    '--port[Specify the port on which the administration server listens]:port'
    '-P[Specify the file to which the PID of kadmind process should be written]:pid_file:_files'
    '-p[Specify the path to the kdb5_util command]:kdb5_util_path:_files'
    '-K[Specify the path to the kprop command]:kprop_path:_files'
    '-k[Specify the port by which kprop connects to slaves]:kprop_port'
    '-F[Specify the file path for dumping the KDB]:dump_file:_files'
    '-x[Specify database-specific arguments]:db_args'
    '*:filename:_files'
)
_arguments -s $arguments
