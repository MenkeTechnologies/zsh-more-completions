#compdef eqn

local arguments

arguments=(
    '-d[Specify delimiters for left and right end of inline equations]:xy'
    '-C[Recognize .EQ and .EN even when followed by a character other than space or newline]'
    '-N[Do not allow newlines within delimiters]'
    '-v[Print the version number]'
    '-r[Only one size reduction]'
    '-m[Set the minimum point-size]:n'
    '-T[Set the output device name]:name'
    '-M[Search dir for eqnrc before the default directories]:dir:_directories'
    '-R[Do not load eqnrc]'
    '-f[Set the font for equations]:F'
    '-s[Set the point size for equations]:n'
    '-p[Set subscript/superscript size reduction in points]:n'
    '*:filename:_files'
)
_arguments -s $arguments
