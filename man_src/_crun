#compdef crun
# Documentation: https://man.archlinux.org/search?q=crun
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--cgroup-manager[Cgroup manager to use]:manager'
    '--debug[Produce verbose output]'
    '--log[Set log file]:file:_files'
    '--log-format[Set log format]:format'
    '--root[Set root directory for storage of container state]:directory:_directories'
    '--rootless[Use rootless mode]:value'
    '--systemd-cgroup[Use systemd cgroups]'
    '--usage[Give a short usage message]'
    {-V,--version}'[Print program version]'
    '*:filename:_files'
)
_arguments -s $arguments
