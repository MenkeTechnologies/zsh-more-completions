#compdef transicc

local arguments

arguments=(
    '-b[black point compensation]'
    '-c[precalculate transform (0=Off, 1=Normal, 2=Hi-res, 3=LoRes)]:num'
    '-d[observer adaptation state for absolute colorimetric]:num'
    '-e[use encoded representation of numbers (not float)]'
    '-g[mark out-of-gamut colors on softproof]'
    '-i[input profile]:profile:_files'
    '-l[transform by device-link profile]:profile:_files'
    '-m[softproof intent (0,1,2,3)]:intent'
    '-n[terse output, intended for pipe usage]'
    '-o[output profile]:profile:_files'
    '-q[quantize CGATS to 8 bits]'
    '-s[bounded mode]'
    '-t[rendering intent (0=Perceptual, 1=Relative colorimetric, 2=Saturation, 3=Absolute colorimetric)]:intent'
    '-v[verbosity level (0=None, 1=Normal, 2=High, 3=Very High)]:verbosity'
    '-w[use 16 bits]'
    '-x[hexadecimal output]'
    '*:filename:_files'
)
_arguments -s $arguments
