#compdef toe

local arguments

arguments=(
    '-a[report on all terminal databases which ncurses would search]'
    '-s[sort the output by the entry names]'
    '-u[write a report listing dependencies in the given file]:file:_files'
    '-U[write a report listing reverse dependencies in the given file]:file:_files'
    '-v[specify verbosity level]:n'
    '-V[report version of ncurses and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
