#compdef indent

local arguments

arguments=(
    '-bacc[Force a blank line around every conditional compilation block]'
    '-bad[Force a blank line after every block of declarations]'
    '-bap[Force a blank line after every procedure body]'
    '-bbb[Force a blank line before every block comment]'
    '-bc[Force a newline after each comma in a declaration]'
    '-br[Put braces on right of compound statements]'
    '-bl[Put braces on left (next line) of compound statements]'
    '-c[Column in which comments on code start]:column'
    '-cd[Column in which comments on declarations start]:column'
    '-cdb[Enable placement of comment delimiters on blank lines]'
    '-ce[Enable forcing of else to cuddle up to the preceding closing brace]'
    '-ci[Set the continuation indent]:n'
    '-cli[Indent case labels by specified tab stops]:n'
    '-d[Control placement of comments not to the right of code]:n'
    '-di[Specify indentation of global variable names and type declarations]:n'
    '-dj[Left justify declarations]'
    '-ei[Enable special else-if processing]'
    '-eei[Enable extra indentation on continuation lines of expressions in if/while]'
    '-fbs[Enable splitting the function declaration and opening brace across two lines]'
    '-fc1[Enable formatting of comments that start in column 1]'
    '-fcb[Enable formatting of block comments]'
    '-i[Number of spaces for one indentation level]:n'
    '-ip[Enable indentation of parameter declarations from the left margin]'
    '-l[Maximum length of an output line]:length'
    '-ldi[Specify indentation of local variable names]:n'
    '-lp[Line up code surrounded by parenthesis in continuation lines]'
    '-npro[Ignore profile files .indent.pro]'
    '-pcs[Insert space between procedure name and parenthesis in calls]'
    '-psl[Place names of procedures being defined in column 1]'
    '-sc[Enable placement of asterisks at the left edge of all comments]'
    '-sob[Swallow optional blank lines]'
    '-st[Take input from stdin and put output to stdout]'
    '-ta[Automatically add all identifiers ending in _t to the list of type keywords]'
    '-T[Add typename to the list of type keywords]:typename'
    '-troff[Format the program for processing by troff]'
    '-ut[Enable the use of tab characters in the output]'
    '-v[Turn on verbose mode]'
    '*:filename:_files'
)
_arguments -s $arguments
