#compdef fstobdf
# Documentation: https://man.archlinux.org/search?q=fstobdf
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--server[Specify the server from which the font should be read]:servername'
    '--fn[Specify the font for which a BDF file should be generated]:fontname'
    '--version[Print the program version and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
