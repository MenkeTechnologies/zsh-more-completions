#compdef ijs-config

local arguments

arguments=(
    '--help[Show summary of options]'
    '--version[Show installed libijs version]'
    '--libs[Print the linker flags that are necessary to link an IJS program]'
    '--cflags[Print the compiler flags that are necessary to compile an IJS program]'
    '--prefix[Use PREFIX instead of the installation prefix]:prefix:_directories'
    '--exec-prefix[Use PREFIX instead of the installation exec prefix]:prefix:_directories'
    '*:filename:_files'
)
_arguments -s $arguments
