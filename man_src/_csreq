#compdef csreq
# Documentation: https://man.archlinux.org/search?q=csreq
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-b[Write the requirement in binary form to the specified path]:path:_files'
    '-r[Specify the input requirement]:requirement'
    '-t[Write the requirement as text to standard output]'
    '-v[Increase the verbosity of output]'
    '*:filename:_files'
)
_arguments -s $arguments
