#compdef hcxhashtool

local arguments

arguments=(
    '-i[Input hash file]:file:_files'
    '-o[Output hash file]:file:_files'
    '-E[Output ESSID list]:file:_files'
    '-d[Download IEEE OUI list and save to ~/.hcxtools/oui.txt]'
    '-h[Show help]'
    '-v[Show version]'
    '--essid-group[Group output by ESSID]'
    '--oui-group[Group output by OUI]'
    '--mac-group-ap[Group output by AP MAC address]'
    '--mac-group-client[Group output by client MAC address]'
    '--type[Filter by hash type]:type:(1 2)'
    '--essid-len[Filter by exact ESSID length]:length'
    '--essid-min[Filter by minimum ESSID length]:length'
    '--essid-max[Filter by maximum ESSID length]:length'
    '--essid[Filter by ESSID name]:essid'
    '--essid-part[Filter by partial ESSID match]:essid'
    '--mac-ap[Filter by AP MAC address]:mac'
    '--mac-client[Filter by client MAC address]:mac'
    '--oui-ap[Filter by AP OUI]:oui'
    '--oui-client[Filter by client OUI]:oui'
    '--vendor[Filter by vendor name]:vendor'
    '--authorized[Show only authorized handshakes]'
    '--notauthorized[Show only not-authorized handshakes]'
    '--rc[Filter by replay counter value]:rc'
    '--apless[Show only AP-less (PMKID) entries]'
    '--info[Show information summary]'
    '--vendorlist[Show vendor list]'
    '--psk[Test PSK against hash]:psk'
    '--pmk[Test PMK against hash]:pmk'
    '--hccapx[Output in hccapx format]:file:_files'
    '--hccap[Output in hccap format]:file:_files'
    '--hccap-single[Output each hash in single hccap file]:file:_files'
    '--john[Output in John the Ripper format]:file:_files'
    '--help[Show help]'
    '--version[Show version]'
    '*:filename:_files'
)
_arguments -s $arguments
