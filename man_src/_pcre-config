#compdef pcre-config

local arguments

arguments=(
    '--prefix[Write the directory prefix used in the PCRE installation]'
    '--exec-prefix[Write the directory prefix for architecture-dependent files]'
    '--version[Write the version number of the installed PCRE libraries]'
    '--libs[Write linker flags for linking with the 8-bit PCRE library]'
    '--libs16[Write linker flags for linking with the 16-bit PCRE library]'
    '--libs32[Write linker flags for linking with the 32-bit PCRE library]'
    '--libs-cpp[Write linker flags for linking with the C++ PCRE wrapper library]'
    '--libs-posix[Write linker flags for linking with the POSIX PCRE wrapper library]'
    '--cflags[Write compiler flags for compiling with PCRE]'
    '--cflags-posix[Write compiler flags for compiling with the POSIX PCRE wrapper]'
    '*:filename:_files'
)
_arguments -s $arguments
