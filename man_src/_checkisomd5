#compdef checkisomd5
# Documentation: https://man.archlinux.org/search?q=checkisomd5
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--md5sumonly[Do not check the target, only print the MD5 sum]'
    '--verbose[Display human-readable progress as the target is checked]'
    '*:filename:_files'
)
_arguments -s $arguments
