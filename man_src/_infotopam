#compdef infotopam
# Documentation: https://man.archlinux.org/search?q=infotopam
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--forcecolor[Force conversion of 1 bit-plane icons to color PAM images instead of bitmap]'
    '--numcolors[Specify how many colors to override]:numcolors'
    '--selected[Use the selected (second) image from the icon instead of the normal image]'
    '*:filename:_files'
)
_arguments -s $arguments
