#compdef ctfmerge

local arguments

arguments=(
    '-f[Match global symbols to global CTF data]'
    '-g[Do not delete the original debugging sections]'
    '-s[Use the .dynsym ELF section instead of .symtab]'
    '-t[Make sure that all object files have a CTF section]'
    '-v[Enable verbose mode]'
    '-l[Set the label]:label'
    '-L[Read the label from the specified environment variable]:env var'
    '-o[Output file for the merged CTF data]:file:_files'
    '-d[Uniquify against the specified file]:file:_files'
    '-w[Additive merge with the specified file]:file:_files'
    '-c[Copy CTF data from source to destination]:srcfile destfile'
    '*:filename:_files'
)
_arguments -s $arguments
