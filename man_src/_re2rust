#compdef re2rust

# Autogenerated from man page
# Updated with latest re2rust options

local arguments

arguments=(
    {-\?,-h,--help}'[show help message]'
    {--api,--input}'[specify the API used by generated code to interface with user-defined code]'
    {--bit-vectors,-b}'[optimize conditional jumps using bit masks (implies --nested-ifs)]'
    '--case-insensitive[treat single-quoted and double-quoted strings as case-insensitive]'
    '--case-inverted[invert the meaning of single-quoted and double-quoted strings]'
    '--case-ranges[collapse consecutive cases in switch statements into a range]'
    {--computed-gotos,-g}'[optimize conditional jumps using non-standard computed goto extension]'
    {--conditions,--start-conditions,-c}'[enable support of Flex-like conditions]'
    '--depfile[write dependency information to FILE in Makefile rule format]:FILE:_files'
    {--ebcdic,--ecb,-e}'[generate a lexer that reads input in EBCDIC encoding]'
    '--empty-class[define the way re2c treats empty character classes]'
    '--encoding-policy[define the way re2c treats Unicode surrogates]'
    {--flex-syntax,-F}'[partial support for Flex syntax]'
    {--header,--type-header,-t}'[generate a HEADER file]:HEADER:_files'
    '-I[add PATH to the list of include file search locations]:PATH:_directories'
    '--input-encoding[specify the way re2c parses regular expressions]'
    '--lang[specify the output language (supported: C, Go, Rust)]:language:(C Go Rust)'
    '--location-format[specify location format in messages]'
    '--loop-switch[encode DFA in a form of a loop over a switch statement]'
    {--nested-ifs,-s}'[use nested if statements instead of switch statements]'
    {--no-debug-info,-i}'[do not output line directives]'
    '--no-generation-date[suppress date output in the generated file]'
    '--no-version[suppress version output in the generated file]'
    '--no-unsafe[do not generate unsafe wrapper over YYPEEK (Rust-specific)]'
    {--output,-o}'[specify the OUTPUT file]:OUTPUT:_files'
    {--posix-captures,-P}'[enable submatch extraction with POSIX-style capturing groups]'
    {--reusable,-r}'[deprecated since version 2.2 (reusable blocks are allowed by default)]'
    {--skeleton,-S}'[ignore user-defined interface code and generate a self-contained skeleton program]'
    {--storable-state,-f}'[generate a lexer which can store its inner state]'
    {--tags,-T}'[enable submatch extraction with tags]'
    {--ucs2,--wide-chars,-w}'[generate a lexer that reads UCS2-encoded input]'
    {--utf8,--utf-8,-8}'[generate a lexer that reads input in UTF-8 encoding]'
    {--utf16,--utf-16,-x}'[generate a lexer that reads UTF16-encoded input]'
    {--utf32,--unicode,-u}'[generate a lexer that reads UTF32-encoded input]'
    '--verbose[output a short message in case of success]'
    {--vernum,-V}'[show version information in MMmmpp format]'
    {--version,-v}'[show version information]'
    {--single-pass,-1}'[deprecated, does nothing]'
    {--debug-output,-d}'[emit YYDEBUG invocations in the generated code]'
    '--dump-adfa[debug option: output DFA after tunneling in .dot format]'
    '--dump-cfg[debug option: output control flow graph of tag variables in .dot format]'
    '--dump-closure-stats[debug option: output statistics on the number of states in closure]'
    '--dump-dfa-det[debug option: output DFA immediately after determinization in .dot format]'
    '--dump-dfa-min[debug option: output DFA after minimization in .dot format]'
    '--dump-dfa-tagopt[debug option: output DFA after tag optimizations in .dot format]'
    '--dump-dfa-tree[debug option: output DFA under construction with states as tag history trees]'
    '--dump-dfa-raw[debug option: output DFA under construction with expanded state-sets]'
    '--dump-interf[debug option: output interference table produced by liveness analysis of tag variables]'
    '--dump-nfa[debug option: output NFA in .dot format]'
    {--emit-dot,-D}'[instead of normal output generate lexer graph in .dot format]'
    '--dfa-minimization[internal option: DFA minimization algorithm]'
    '--eager-skip[internal option: make the generated lexer advance the input position eagerly]'
    '--no-lookahead[internal option: use TDFA(0) instead of TDFA(1)]'
    '--no-optimize-tags[internal option: suppress optimization of tag variables]'
    '--posix-closure[internal option: specify shortest-path algorithm for POSIX closure construction]'
    '--posix-prectable[internal option: specify the algorithm for computing POSIX precedence table]'
    '--stadfa[internal option: use staDFA algorithm for submatch extraction]'
    '--fixed-tags[internal option: specify whether the fixed-tag optimization should be applied]'
    '-W[turn on all warnings]'
    '--Werror[turn warnings into errors]'
    '--Wcondition-order[warn about implicit assumptions about condition numbering]'
    '--Wempty-character-class[warn about empty character classes in regular expressions]'
    '--Wmatch-empty-string[warn if a rule is nullable (matches an empty string)]'
    '--Wswapped-range[warn if the lower bound of a range is greater than its upper bound]'
    '--Wundefined-control-flow[warn about undefined control flow in the lexer]'
    '--Wunreachable-rules[warn about rules shadowed by other rules that will never match]'
    '--Wuseless-escape[warn about unnecessarily escaped symbols]'
    '--Wnondeterministic-tags[warn about nondeterministic tags]'
    '--Wsentinel-in-midrule[warn if the sentinel symbol occurs in the middle of a rule]'
    '*:filename:_files'
)
_arguments -s $arguments
