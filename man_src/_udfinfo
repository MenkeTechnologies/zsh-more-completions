#compdef udfinfo

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Display the usage and the list of options]'
    {-b,--blocksize}'[Specify the size of blocks in bytes]:blocksize'
    '--vatblock[Specify the block location of the Virtual Allocation Table]:block'
    '--locale[Encode UDF string identifiers on output according to current locale settings]'
    '--u8[Encode UDF string identifiers on output to 8-bit OSTA Compressed Unicode format]'
    '--u16[Encode UDF string identifiers on output to 16-bit OSTA Compressed Unicode format]'
    '--utf8[Encode UDF string identifiers on output to UTF-8]'
    '*:filename:_files'
)
_arguments -s $arguments
