#compdef kwboot
# Documentation: https://man.archlinux.org/search?q=kwboot
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-b[Handshake then upload file image over TTY]:image:_files'
    '-p[Patch the header in image prior to upload to enable UART boot]'
    '-t[Run a terminal program, connecting standard input and output to TTY]'
    '*:filename:_files'
)
_arguments -s $arguments
