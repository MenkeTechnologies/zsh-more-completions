#compdef pg_amcheck

local arguments

arguments=(
    {-a,--all}'[Check all databases]'
    {-d,--database}'[Check databases matching the specified pattern]:pattern'
    {-D,--exclude-database}'[Exclude databases matching the given pattern]:pattern'
    {-i,--index}'[Check indexes matching the specified pattern]:pattern'
    {-I,--exclude-index}'[Exclude indexes matching the specified pattern]:pattern'
    {-r,--relation}'[Check relations matching the specified pattern]:pattern'
    {-R,--exclude-relation}'[Exclude relations matching the specified pattern]:pattern'
    {-s,--schema}'[Check tables and indexes in schemas matching the specified pattern]:pattern'
    {-S,--exclude-schema}'[Exclude tables and indexes in schemas matching the specified pattern]:pattern'
    {-t,--table}'[Check tables matching the specified pattern]:pattern'
    {-T,--exclude-table}'[Exclude tables matching the specified pattern]:pattern'
    '--no-dependent-indexes[Do not check btree indexes of checked tables]'
    '--no-dependent-toast[Do not check toast tables of checked tables]'
    '--no-strict-names[Do not require patterns to match objects]'
    '--exclude-toast-pointers[Do not verify toast pointers]'
    '--on-error-stop[Stop checking after the first corruption on each page]'
    '--skip[Skip checking certain pages]:option:(all-frozen all-visible)'
    '--startblock[Start checking at the specified block number]:block'
    '--endblock[End checking at the specified block number]:block'
    '--heapallindexed[Verify the presence of all heap tuples as index tuples]'
    '--parent-check[Use bt_index_parent_check for btree indexes]'
    '--rootdescend[Re-find tuples on the leaf level by performing a new search from the root]'
    {-h,--host}'[Database server host]:hostname:_hosts'
    {-p,--port}'[Database server port]:port'
    {-U,--username}'[Connect as the specified user]:username'
    {-w,--no-password}'[Never prompt for password]'
    {-W,--password}'[Force password prompt]'
    '--maintenance-db[Alternate maintenance database]:dbname'
    {-e,--echo}'[Echo server commands]'
    {-j,--jobs}'[Number of parallel connections]:num'
    {-P,--progress}'[Report progress]'
    {-v,--verbose}'[Verbose output]'
    {-V,--version}'[Output version information then exit]'
    '--install-missing[Install missing extensions]'
    {-\?,--help}'[Show help]'
    '*:filename:_files'
)
_arguments -s $arguments
