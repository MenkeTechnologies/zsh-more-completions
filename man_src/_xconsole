#compdef xconsole

local arguments

arguments=(
    '-file[Specify the device name to monitor]:file:_files'
    '-notify[When new data are received, raise the window]'
    '-nonotify[Do not raise the window when new data are received]'
    '-daemon[Place xconsole in the background]'
    '-verbose[Display an informative message in the first line of the text buffer]'
    '-exitOnFail[Exit when unable to redirect console output]'
    '-saveLines[Only preserve this many lines of message history]:count'
    '*:filename:_files'
)
_arguments -s $arguments
