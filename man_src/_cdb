#compdef cdb

local arguments

arguments=(
    '-n[Find and write a record with a given number starting with 1]:number'
    '-m[Add newline after every value printed]'
    '-t[Use given tmpname as temporary file]:tmpname:_files'
    '-p[Permissions for the newly created file]:permissions'
    '-w[Warn about duplicate keys]'
    '-e[Abort on duplicate keys (implies -w)]'
    '-r[Replace existing key with new one in case of duplicate]'
    '-0[Zero-fill existing records when duplicate records are added]'
    '-u[Do not add duplicate records]'
    '-c[Create mode]'
    '-d[Dump mode]'
    '-h[Print short help and exit]'
    '-l[List mode]'
    '-q[Query mode]'
    '-s[Statistics mode]'
    '*:filename:_files'
)
_arguments -s $arguments
