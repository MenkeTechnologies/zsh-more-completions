#compdef trust

local arguments

arguments=(
    {-v,--verbose}'[increase verbosity of output]'
    {-q,--quiet}'[suppress non-error output]'
    '--filter[filter by type of trust]:what'
    '--purpose[filter by purpose of trust]:usage'
    '--store[specify trust store to operate on]'
    '--remove[remove specified trust anchor]'
    '--format[specify the format of input/output]'
    '--comment[add a comment to the trust anchor]'
    '--overwrite[overwrite existing trust anchor]'
    '*:filename:_files'
)
_arguments -s $arguments
