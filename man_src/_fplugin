#compdef fplugin

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Show this help message and exit]'
    {-i,--interactive}'[Run in interactive mode]'
    {-w,--workspace}'[Workspace to use]:workspace'
    {-u,--url}'[Faraday Server URL]:URL'
    '--username[Faraday username]:USERNAME'
    '--password[Faraday password]:PASSWORD'
    '*:filename:_files'
)
_arguments -s $arguments
