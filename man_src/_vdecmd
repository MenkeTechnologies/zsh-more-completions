#compdef vdecmd
# Documentation: https://man.archlinux.org/search?q=vdecmd
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-s[Management socket path (default is /var/run/unixcmd)]:sockname:_files'
    '-f[Configuration path (default is /etc/unixcmd)]:rcfile:_files'
    '-v[Run parse machine in debug mode]'
    '*:filename:_files'
)
_arguments -s $arguments
