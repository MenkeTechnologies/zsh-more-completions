#compdef thin_ls

local arguments

arguments=(
    '(- * :)'{-h,--help}'[print help and exit]'
    {-V,--version}'[print version information and exit]'
    {-o,--format}'[give a comma separated list of fields to output]:fields'
    '--no-headers[do not output headers]'
    {-m,--metadata-snap}'[use metadata snapshot]'
    '*:filename:_files'
)
_arguments -s $arguments
