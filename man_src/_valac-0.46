#compdef valac-0.46

local arguments

arguments=(
    {-h,--help}'[Show help options]'
    '--vapidir[Look for package bindings in directory]:directory:_directories'
    '--girdir[Look for .gir files in directory]:directory:_directories'
    '--metadatadir[Look for GIR .metadata files in directory]:directory:_directories'
    '--pkg[Include binding for package]:package'
    '--vapi[Output VAPI file name]:file:_files'
    '--library[Library name]:name'
    '--shared-library[Shared library name used in generated gir]:name'
    '--gir[GObject-Introspection repository file name]:name'
    {-b,--basedir}'[Base source directory]:directory:_directories'
    {-d,--directory}'[Change output directory from current working directory]:directory:_directories'
    '--version[Display version number]'
    '--api-version[Display API version number]'
    {-C,--ccode}'[Output C code]'
    {-H,--header}'[Output C header file]:file:_files'
    '--use-header[Use C header file]'
    '--includedir[Directory used to include the C header file]:directory:_directories'
    '--internal-header[Output internal C header file]:file:_files'
    '--internal-vapi[Output vapi with internal api]:file:_files'
    '--fast-vapi[Output vapi without performing symbol resolution]'
    '--use-fast-vapi[Use --fast-vapi output during this compile]'
    '--vapi-comments[Include comments in generated vapi]'
    '--deps[Write make-style dependency information to this file]'
    '--depfile[Write make-style external dependency information for build systems]'
    '--list-sources[Output a list of all source and binding files which are used]'
    '--symbols[Output symbols file]:file:_files'
    {-c,--compile}'[Compile but do not link]'
    {-o,--output}'[Place output in file]:file:_files'
    {-g,--debug}'[Produce debug information]'
    '--thread[Enable multithreading support (DEPRECATED AND IGNORED)]'
    '--enable-mem-profiler[Enable GLib memory profiler]'
    {-D,--define}'[Define symbol]:symbol'
    '--main[Use symbol as entry point]:symbol'
    '--nostdpkg[Do not include standard packages]'
    '--disable-assert[Disable assertions]'
    '--enable-checking[Enable additional run-time checks]'
    '--enable-deprecated[Enable deprecated features]'
    '--hide-internal[Hide symbols marked as internal]'
    '--enable-experimental[Enable experimental features]'
    '--disable-warnings[Disable warnings]'
    '--fatal-warnings[Treat warnings as fatal]'
    '--disable-since-check[Do not check whether used symbols exist in local packages]'
    {-k,--keep-going}'[Continue as much as possible after an error]'
    '--enable-experimental-non-null[Enable experimental enhancements for non-null types]'
    '--enable-gobject-tracing[Enable GObject creation tracing]'
    '--cc[Use command as C compiler command]:command'
    {-X,--Xcc}'[Pass option to the C compiler]:option'
    '--pkg-config[Use command as pkg-config command]:command'
    '--dump-tree[Write code tree to file]:file:_files'
    '--save-temps[Keep temporary files]'
    '--profile[Use the given profile instead of the default]:profile:(gobject posix)'
    {-q,--quiet}'[Do not print messages to the console]'
    {-v,--verbose}'[Print additional messages to the console]'
    '--no-color[Disable colored output]'
    '--color[Enable color output]:when:(always never auto)'
    '--target-glib[Target version of glib for code generation]:version'
    '--gresources[XML of gresources]:file:_files'
    '--gresourcesdir[Look for resources in directory]:directory:_directories'
    '--enable-version-header[Write vala build version in generated files]'
    '--disable-version-header[Do not write vala build version in generated files]'
    '--run-args[Arguments passed to directly compiled executable]:args'
    '--abi-stability[Enable support for ABI stability]'
    '*:filename:_files'
)
_arguments -s $arguments
