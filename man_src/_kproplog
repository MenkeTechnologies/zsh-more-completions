#compdef kproplog
# Documentation: https://man.archlinux.org/search?q=kproplog
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-R[Reset the update log, forcing full resynchronization]'
    '-h[Display a summary of the update log]'
    '-e[Display the last num update entries in the log]:num'
    '-v[Display individual attributes per update]'
    '*:filename:_files'
)
_arguments -s $arguments
