#compdef j1939sr

local arguments

arguments=(
    {-v,--verbose}'[Increase verbosity]'
    {-p,--priority}'[J1939 priority (0-7, default 6)]:value'
    {-S,--serialize}'[Strictly serialize outgoing packets]'
    {-s,--size}'[Packet size, default autodetected]:size'
    '*:filename:_files'
)
_arguments -s $arguments
