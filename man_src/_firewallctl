#compdef firewallctl
# Documentation: https://man.archlinux.org/search?q=firewallctl
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Print a short help text and exit]'
    {-v,--verbose}'[Be more verbose while printing]'
    {-q,--quiet}'[Do not print status messages]'
    '*:filename:_files'
)
_arguments -s $arguments
