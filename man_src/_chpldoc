#compdef chpldoc

local arguments

arguments=(
    {-o,--output-dir}'[Specify the directory for documentation output]:directory:_directories'
    '--author[Documentation author string]:author'
    '--comment-style[Specify the opening comment character sequence for documentation comments]:string'
    '--process-used-modules[Generate documentation for used modules as well]'
    '--save-sphinx[Save generated Sphinx project in directory]:directory:_directories'
    '--text-only[Generate text-based documentation instead of HTML]'
    '--html[Generate HTML documentation]'
    '--project-version[Set the documentation version]:version'
    '--print-commands[Print the system commands that chpldoc executes]'
    {-h,--help}'[Print a list of the command line options]'
    '--help-env[Print help with environment variable equivalents]'
    '--help-settings[Print help with current settings]'
    '--version[Print chpldoc version number]'
    '--copyright[Print chpldoc copyright information]'
    '--license[Print chpldoc license information]'
    '*:filename:_files'
)
_arguments -s $arguments
