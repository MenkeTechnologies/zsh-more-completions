#compdef f2py3

local arguments

arguments=(
    '-h[Write signatures of the fortran routines to file and exit]:filename:_files'
    '-m[Name of the module to generate]:modulename'
    '--lower[Do not lower the cases in fortran files]'
    '--build-dir[Directory for generated files; default is tempfile]:dirname:_directories'
    '--overwrite-signature[Overwrite existing signature file]'
    '--latex-doc[Create LaTeX documentation; default is --no-latex-doc]'
    '--short-latex[Create incomplete LaTeX document]'
    '--rest-doc[Create reStructuredText documentation]'
    '--debug-capi[Create C/API code that reports wrapper state during runtime]'
    '--include[Add CPP #include statement to the C/API code]:includefile'
    '--wrap-functions[Create Fortran subroutine wrappers to Fortran 77 functions]'
    '--quiet[Run quietly]'
    '--verbose[Run with extra verbosity]'
    '-v[Print f2py version ID and exit]'
    '--include_paths[Search include files from the given directories]:paths'
    '--help-compiler[List available Fortran compilers]'
    '--fcompiler[Specify Fortran compiler type by vendor]:name'
    '--compiler[Specify C compiler type as defined by distutils]:name'
    '--help-fcompiler[List available Fortran compilers and exit]'
    '--f77exec[Specify the path to F77 compiler]:path:_files'
    '--f90exec[Specify the path to F90 compiler]:path:_files'
    '--f77flags[Specify F77 compiler flags]:flags'
    '--f90flags[Specify F90 compiler flags]:flags'
    '--opt[Specify optimization flags]:flags'
    '--arch[Specify architecture specific optimization flags]:flags'
    '--noopt[Compile without optimization]'
    '--noarch[Compile without arch-dependent optimization]'
    '--debug[Compile with debugging information]'
    '*:filename:_files'
)
_arguments -s $arguments
