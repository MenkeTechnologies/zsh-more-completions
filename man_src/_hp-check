#compdef hp-check

local arguments

arguments=(
    {-c,--compile}'[Compile-time check only]'
    {-r,--run,--runtime}'[Run-time check only]'
    {-b,--both}'[Compile and run-time checks]'
    {-l,--logging}'[Set the logging level]:level:(none info error warn debug)'
    {-g,--ldebug}'[Run in debug mode]'
    '-t[Output plain text only]'
    '(- * :)'{-h,--help}'[Show help information]'
    '*:filename:_files'
)
_arguments -s $arguments
