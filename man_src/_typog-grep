#compdef typog-grep

local arguments

arguments=(
    {-a,--all,--any}'[ID-discovery mode: show all typog-inspect elements]'
    '--color[colorize specific log contents for matching ids]:when:(always auto never)'
    {-C,--config}'[set configuration key-value pairs]:key=value'
    '--debug[turn on debug output on stderr]'
    {-h,--help}'[display brief help then exit]'
    {-i,--id}'[print the actual id name that matched the regexp]'
    {-y,--ignore-case}'[match ids while ignoring case distinctions]'
    {-j,--job-name}'[print the jobname that TeX associated with the input file]'
    {-n,--line-number}'[print the line number where the typog-inspect environment was entered]'
    {-N,--log-line-number}'[print the line number of the log-file where the current line was encountered]'
    {-p,--page-number}'[print page number where the typog-inspect environment was found]'
    {-P,--pager}'[redirect output from stdout to the configured pager]'
    '--show-config[show the default configuration and exit]'
    {-V,--version}'[show version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
