#compdef fsapfsinfo

local arguments

arguments=(
    '-B[Output file system information as a bodyfile]'
    '-E[Show information about a specific file system entry or "all"]:entry'
    '-f[Show information about a specific file system or "all"]:filesystem'
    '-F[Show information about a specific file entry path]:path'
    '-h[Show this help]'
    '-H[Show the file system hierarchy]'
    '-o[Specify the volume offset]:offset'
    '-p[Specify the password]:password'
    '-r[Specify the recovery password]:password'
    '-v[Verbose output to stderr]'
    '-V[Print version]'
    '*:filename:_files'
)
_arguments -s $arguments
