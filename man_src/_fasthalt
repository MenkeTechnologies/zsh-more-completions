#compdef fasthalt

local arguments

arguments=(
    '-d[Request the system to create a crash dump]'
    '-k[Boot the specified kernel on the next system boot]:kernel'
    '-l[Do not log the halt or reboot to the system log]'
    '-N[Do not flush the file system cache during initial clean-up]'
    '-n[Do not flush the file system cache]'
    '-p[Turn off the power if the system can]'
    '-q[Halt or restart quickly and ungracefully]'
    '-r[Kill all processes, unmount filesystems, and reboot]'
    '*:filename:_files'
)
_arguments -s $arguments
