#compdef tctmttest

local arguments

arguments=(
    '--tl[set the tuning leaf parameter]:num'
    '--td[set the tuning non-leaf parameter]:num'
    '--tb[set the bucket number]:num'
    '--tt[set the number of extra mapped memory]:size'
    '--tx[set the maximum number of cached leaf nodes]:num'
    '--rc[set the record cache limit]:num'
    '--lc[set the leaf cache limit]:num'
    '--nc[do not use compression]'
    '--xm[set the size of extra mapped memory]:size'
    '--df[set defragmentation step]:num'
    '--ip[set index parameters]'
    '--is[set index string type]'
    '--in[set index number type]'
    '--it[set index type]:type'
    '--if[set index file]:file:_files'
    '--ix[set index expression]'
    '--nl[set the number of members in each leaf]:num'
    '--nb[set the number of members in each node]:num'
    '--rnd[use random keys]'
    '--rr[set the number of records]:num'
    '*:filename:_files'
)
_arguments -s $arguments
