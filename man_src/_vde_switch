#compdef vde_switch

local arguments

arguments=(
    '--hub[Turn off the switch engine, operate as a hub]'
    '--sock[Specify the directory where comm sockets are created]:path:_directories'
    '--mod[Specify the octal permissions for the comm sockets]:octalmode'
    '--group[Specify the group owner for the comm socket]:name'
    '--tap[Connect the specified tuntap interface to this vde_switch]:interface'
    '--daemon[Run as a daemon, use syslog for logging]'
    '-f[RC file to set the initial switch configuration]:rcfile:_files'
    '--nostdin[Allow stdin to be closed]'
    '-h[Show help]'
    '*:filename:_files'
)
_arguments -s $arguments
