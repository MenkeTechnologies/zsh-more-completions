#compdef vde_router

local arguments

arguments=(
    '-d[Daemonize the process and put in background]'
    '-r[Parse configuration parameters from configfile at startup]:configfile:_files'
    '-M[UNIX socket for management parameters]:mgmt_socket:_files'
    '-m[Specify the permission for access to mgmt_socket]:mgmt_mode'
    '-p[Save the process id to pidfile]:pidfile:_files'
    '*:filename:_files'
)
_arguments -s $arguments
