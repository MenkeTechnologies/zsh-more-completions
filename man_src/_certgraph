#compdef certgraph

local arguments

arguments=(
    '-cdn[Include certificates from CDNs]'
    '-ct-expired[Include expired certificates in certificate transparency search]'
    '-ct-subdomains[Include sub-domains in certificate transparency search]'
    '-depth[Maximum BFS depth to go]:depth'
    '-details[Print details about the domains crawled]'
    '-dns[Check for DNS records to determine if domain is registered]'
    '-driver[Driver to use]:driver:(crtsh google http smtp)'
    '-json[Print the graph as JSON, can be used for graph in web UI]'
    '-parallel[Number of certificates to retrieve in parallel]:number'
    '-sanscap[Maximum number of unique TLD+1 domains in certificate to include, 0 for no limit]:number'
    '-save[Save certs to folder in PEM format]:folder:_directories'
    '-timeout[TCP timeout in seconds]:seconds'
    '-tldplus1[For every domain found, add tldPlus1 of the parent domain]'
    '-updatepsl[Update the default Public Suffix List]'
    '-verbose[Enable verbose logging]'
    '-version[Print version and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
