#compdef irqbalance

local arguments

arguments=(
    {-o,--oneshot}'[Run once then exit]'
    {-d,--debug}'[Print extra debug information; implies --foreground]'
    {-f,--foreground}'[Run in the foreground without --debug]'
    {-j,--journal}'[Enable log output optimized for systemd-journal]'
    {-p,--powerthresh}'[Set the threshold at which we attempt to move a CPU into powersave mode]:threshold'
    {-i,--banirq}'[Add the specified IRQ to the set of banned IRQs]:irqnum'
    '--deepestcache[Specify the cache level at which irqbalance partitions cache domains]:level'
    {-l,--policyscript}'[When specified, the referenced script will execute once for each discovered IRQ]:script:_files'
    {-s,--pid}'[Have irqbalance write its process id to the specified file]:file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
