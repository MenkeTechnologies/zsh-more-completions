#compdef xml-resolver

local arguments

arguments=(
    '-c[Specify catalog file]:catalogfile:_files'
    '-n[Specify name]:name'
    '-p[Specify public ID]:publicId'
    '-s[Specify system ID]:systemId'
    '-a[Show all catalog entries]'
    '-u[Specify URI]:uri'
    '-d[Set debug level]:integer'
    '*:filename:_files'
)
_arguments -s $arguments
