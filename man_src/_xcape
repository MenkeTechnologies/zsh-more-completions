#compdef xcape
# Documentation: https://man.archlinux.org/search?q=xcape
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-d[Debug mode, run as a foreground process]'
    '-t[Timeout in milliseconds]:timeout'
    '-e[Use the specified expression(s)]:expression'
    '*:filename:_files'
)
_arguments -s $arguments
