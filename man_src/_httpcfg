#compdef httpcfg

local arguments

arguments=(
    '--add[Add a new certificate/private key combination for a given port]'
    {--del,--delete}'[Delete the certificates associated for the specified port]'
    '--list[List all known certificates]'
    '--port[Specify the port to add certificates to, or remove certificates from]:port'
    '--pvk[Specify the Private Key file]:file:_files'
    '--cert[Specify the certificate file to use]:cert:_files'
    '*:filename:_files'
)
_arguments -s $arguments
