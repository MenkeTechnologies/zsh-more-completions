#compdef tripwire

function __mode() {
    local -a modes=(i:init c:check u:update p:policy t:test)
    _describe -t mode mode modes
}

local arguments

arguments=(
    '-m[mode selector]: :__mode'
    '(-s)'{-v,--verbose}'[verbose output mode]'
    '(-v)'{-s,--silent,--quiet}'[silent output mode]'
    {-c,--cfgfile}'[use the specified configuration file]:cfgfile:_files'
    {-p,--polfile}'[use the specified policy file]:polfile:_files'
    {-d,--dbfile}'[write to the specified database file]:database:_files'
    {-S,--site-keyfile}'[use the specified site key file]:sitekey:_files'
    {-L,--local-keyfile}'[use the specified local key file]:localkey:_files'
    {-P,--local-passphrase}'[passphrase to be used with local key]:passphrase'
    {-e,--no-encryption}'[do not sign the database being stored]'
    {-I,--interactive}'[open the resulting report in an editor at the end of integrity checking]'
    {-r,--twrfile}'[write the specified report file]:file:_files'
    {-n,--no-tty-output}'[suppress the report from being printed at the console]'
    {-V,--visual}'[use the specified editor to edit the update ballot boxes]:editor'
    {-E,--signed-report}'[specify that the Tripwire report will be signed]'
    {-i,--ignore}'[do not compute or compare the properties specified in list]:list'
    {-l,--severity}'[check only policy rules with severity greater than or equal to the given level]:level'
    {-R,--rule-name}'[check only the specified policy rule]:rule'
    {-x,--section}'[only check the rules in the specified section of the policy file]:section'
    {-M,--email-report}'[email reports to recipients designated in the policy file]'
    {-t,--email-report-level}'[specify the detail level of email reports]:level:(0 1 2 3 4)'
    {-h,--hexadecimal}'[display hash values as hexadecimal in email reports]'
    {-a,--accept-all}'[update all entries in the report file without prompting]'
    {-Z,--secure-mode}'[specify the security level]:mode:(low high)'
    {-Q,--site-passphrase}'[passphrase to be used with site key]:passphrase'
    '--check[mode selector]'
    '--update[mode selector]'
    '--update-policy[mode selector]'
    '--test[mode selector]'
    '--init[mode selector]'
    '(-)--help[print help]:mode:(mode all)'
    '*:filename:_files'
)
_arguments -s $arguments
