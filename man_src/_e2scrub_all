#compdef e2scrub_all

local arguments

arguments=(
    '-n[Print what commands would be executed without running them]'
    '-r[Remove e2scrub snapshots but do not check anything]'
    '-A[Scrub all ext2/3/4 filesystems even if they are not mounted]'
    '-V[Print version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
