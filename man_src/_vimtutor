#compdef vimtutor

local arguments

arguments=(
    {-l,--language}'[Set the two or three letter language code]:language'
    {-c,--chapter}'[Set the chapter number (defaults to chapter one)]:chapter'
    {-g,--gui}'[Start vimtutor in the GUI version of vim if available]'
    {-h,--help}'[Display usage information]'
    '--list[Display chapters and languages]'
    '*:filename:_files'
)
_arguments -s $arguments
