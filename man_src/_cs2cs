#compdef cs2cs

local arguments

arguments=(
    '-I[Inverse translation, convert from +to coordinate system to the primary]'
    '-d[Specify number of decimals in output]:decimals'
    '-e[String to output if an error is detected]:string'
    '-E[Copy input coordinates to the output line before printing]'
    '--lp[List of all projection ids]'
    '--lP[Expanded description of all projections]'
    '--le[List of all ellipsoids]'
    '--lu[List of all distance units]'
    '--ld[List of datums]'
    '-r[Reverse the order of the expected input from longitude-latitude to latitude-longitude]'
    '-s[Reverse the order of the output]'
    '-f[Printf format string to control the form of the output values]:format'
    '-v[List cartographic control parameters]'
    '*:filename:_files'
)
_arguments -s $arguments
