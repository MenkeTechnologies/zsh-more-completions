#compdef valgrind.bin

local arguments

arguments=(
    '--tool[Use the Valgrind tool named name]:name:(memcheck cachegrind callgrind helgrind drd massif dhat lackey none exp-bbv)'
    {-h,--help}'[Show this message]'
    '--help-debug[Show this message, plus debugging options]'
    '--help-dyn-options[Show the dynamically changeable options]'
    '--version[Show version]'
    {-q,--quiet}'[Run silently; only print error msgs]'
    {-v,--verbose}'[Be more verbose -- show misc extra info]'
    '--trace-children[Valgrind-ise child processes (follow execve)]:yn:(yes no)'
    '--trace-children-skip[Specifies a list of executables to skip when tracing children]:patterns'
    '--trace-children-skip-by-arg[Same as --trace-children-skip but match on arguments]:patterns'
    '--child-silent-after-fork[Omit child output between fork and exec]:yn:(yes no)'
    '--vgdb[Activate gdbserver]:yn:(yes no full)'
    '--vgdb-error[Invoke gdbserver after this many errors]:number'
    '--vgdb-stop-at[Invoke gdbserver for given events]:events'
    '--track-fds[Track open file descriptors]:yn:(yes no all)'
    '--time-stamp[Add timestamps to log messages]:yn:(yes no)'
    '--log-fd[Log messages to file descriptor]:fd'
    '--log-file[Log messages to file]:file:_files'
    '--log-socket[Log messages to socket]:ipaddr\:port'
    '--xml[Emit error output in XML]:yn:(yes no)'
    '--xml-fd[XML output to file descriptor]:fd'
    '--xml-file[XML output to file]:file:_files'
    '--xml-socket[XML output to socket]:ipaddr\:port'
    '--xml-user-comment[Copy string verbatim into XML output]:string'
    '--demangle[Automatically demangle C++ names]:yn:(yes no)'
    '--num-callers[Show this many callers in stack traces]:number'
    '--error-limit[Stop showing new errors if too many]:yn:(yes no)'
    '--exit-on-first-error[Exit on the first error found]:yn:(yes no)'
    '--error-exitcode[Exit code to return if errors found]:number'
    '--error-markers[Add lines with begin/end markers before/after error messages]:begin,end'
    '--show-error-list[Show detected errors list and suppression counts at exit]:yn:(yes no)'
    '-s[Same as --show-error-list=yes]'
    '--keep-debuginfo[Keep symbols etc for unloaded code]:yn:(yes no)'
    '--show-below-main[Continue stack traces below main()]:yn:(yes no)'
    '--default-suppressions[Load default suppressions]:yn:(yes no)'
    '--suppressions[Suppress errors described in filename]:file:_files'
    '--gen-suppressions[Print suppressions for errors]:yn:(yes no all)'
    '--input-fd[File descriptor for input]:fd'
    '--dsymutil[Run dsymutil on Mac OS X when helpful]:yn:(yes no)'
    '--max-stackframe[Assume stack switch for SP changes larger than this]:number'
    '--main-stacksize[Set size of main thread stack (in bytes)]:size'
    '--alignment[Set minimum alignment of heap allocations]:number'
    '--redzone-size[Set minimum size of redzones added before/after heap blocks]:size'
    '--xtree-memory[Profile heap memory in an xtree]:mode:(none allocs full)'
    '--xtree-memory-file[Xtree memory report file]:file:_files'
    '--fullpath-after[Show source paths after the specified string]:string'
    '--extra-debuginfo-path[Absolute path to search for additional debug info]:path:_directories'
    '--debuginfo-server[Also query this server for debug info]:ipaddr\:port'
    '--allow-mismatched-debuginfo[Allow mismatched debug info]:yn:(yes no)'
    '--smc-check[Self-modifying code check]:mode:(none stack all all-non-file)'
    '--read-inline-info[Read debug info about inlined function calls]:yn:(yes no)'
    '--read-var-info[Read debug info on stack and global variables]:yn:(yes no)'
    '--vgdb-poll[Gdbserver poll max every this many basic blocks]:number'
    '--vgdb-shadow-registers[Let gdb see the shadow registers]:yn:(yes no)'
    '--vgdb-prefix[Prefix for vgdb FIFOs]:prefix'
    '--run-libc-freeres[Free up glibc memory at exit on Linux]:yn:(yes no)'
    '--run-cxx-freeres[Free up libstdc++ memory at exit on Linux]:yn:(yes no)'
    '--sim-hints[Activate unusual sim behaviours]:hints'
    '--fair-sched[Schedule threads fairly on multicore systems]:yn:(yes no try)'
    '--kernel-variant[Handle non-standard kernel variants]:variants'
    '--merge-recursive-frames[Merge frames between identical program counters]:number'
    '--num-transtab-sectors[Size of translated code cache]:number'
    '--avg-transtab-entry-size[Avg size in bytes of a translated basic block]:size'
    '--aspace-minaddr[Avoid mapping memory below this address]:addr'
    '--valgrind-stacksize[Size of valgrind (host) threads stack]:size'
    '--show-emwarns[Show warnings about emulation limits]:yn:(yes no)'
    '--require-text-symbol[Abort run if the specified text symbol is not found]:pattern'
    '--soname-synonyms[Synonym soname specifications]:synonyms'
    '--sigill-diagnostics[Warn about illegal instructions]:yn:(yes no)'
    '--unw-stack-scan-thresh[Enable stack-scan unwind if fewer than this many frames]:number'
    '--unw-stack-scan-frames[Max number of frames that can be recovered by stack scanning]:number'
    '--resync-filter[Filter for resyncing]:yn:(yes no)'
    '--max-threads[Maximum number of threads that valgrind can handle]:number'
    '--leak-check[Search for memory leaks at exit]:mode:(no summary yes full)'
    '--leak-resolution[Differentiation of leak stack traces]:level:(low med high)'
    '--show-leak-kinds[Which leak kinds to show]:kinds'
    '--errors-for-leak-kinds[Which leak kinds are errors]:kinds'
    '--leak-check-heuristics[Which heuristics to use for improving leak search]:heuristics'
    '--show-reachable[Same as --show-leak-kinds=all]:yn:(yes no)'
    '--show-possibly-lost[Show possibly lost blocks]:yn:(yes no)'
    '--xtree-leak[Output leak result in xtree format]:yn:(yes no)'
    '--xtree-leak-file[Xtree leak report file]:file:_files'
    '--undef-value-errors[Check for undefined value errors]:yn:(yes no)'
    '--track-origins[Show origins of undefined values]:yn:(yes no)'
    '--partial-loads-ok[Allow partial loads]:yn:(yes no)'
    '--expensive-definedness-checks[Use extra-precise definedness tracking]:mode:(auto yes no)'
    '--freelist-vol[Volume of freed blocks queue]:bytes'
    '--freelist-big-blocks[Release first blocks with size greater than this]:bytes'
    '--ignore-ranges[Assume given address ranges are OK]:ranges'
    '--ignore-range-below-sp[Do not report errors for accesses below SP]:offset-size'
    '--malloc-fill[Fill malloced areas with given value]:hexvalue'
    '--free-fill[Fill freed areas with given value]:hexvalue'
    '--keep-stacktraces[Stack traces to keep for malloced/freed areas]:mode:(alloc free alloc-and-free alloc-then-free none)'
    '--show-mismatched-frees[Show frees that dont match the allocator]:yn:(yes no)'
    '*:filename:_files'
)
_arguments -s $arguments
