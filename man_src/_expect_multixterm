#compdef expect_multixterm

local arguments

arguments=(
    '-xa[Arguments to pass to xterm]:arguments'
    '-xc[Command to be run in each named xterm]:command'
    '-xd[Directory to search for files that will be sourced]:directory:_directories'
    '-xf[File to be read at startup]:file:_files'
    '-xn[Name for each xterm]:name'
    '-xv[Enable verbose mode]'
    '*:filename:_files'
)
_arguments -s $arguments
