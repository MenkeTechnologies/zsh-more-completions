#compdef mysqldbcopy

local arguments

arguments=(
    '--help[Display help and exit]'
    '--all[Copy all databases]'
    '--destination[Connection information for the destination server]:destination'
    '--exclude[Exclude specific objects]:pattern'
    '--force[Drop each database before copying]'
    '--locking[Locking type]:type:(no-locks lock-all snapshot)'
    '--new-storage-engine[New storage engine for all tables]:engine'
    '--default-storage-engine[Default storage engine for tables]:engine'
    {-q,--quiet}'[Turn off all messages for quiet execution]'
    {-G,--basic-regexp}'[Use basic regular expression matching]'
    '--regexp[Patterns use REGEXP matching]'
    '--rpl[Include replication commands]:mode:(master slave)'
    '--rpl-user[Replication user and password]:user:password'
    '--skip[Skip specific objects]:objects'
    '--skip-gtid[Skip GTID statements]'
    '--source[Connection information for the source server]:source'
    '--threads[Number of threads to use]:count'
    {-v,--verbose}'[Verbose output]'
    '--version[Display version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
