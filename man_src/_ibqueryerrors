#compdef ibqueryerrors

local arguments

arguments=(
    {--suppress,-s}'[Suppress errors listed]:errors'
    {--suppress-common,-c}'[Suppress some of the common counters]'
    '--node-name-map[Node name map file]:file:_files'
    {--port-guid,-G}'[Report the node containing the port]:guid'
    {--Direct,-D}'[Report the node containing the port specified by directed route]:dr_path'
    '--skip-sl[Do not obtain SL to all destinations]'
    {--report-port,-r}'[Report port link information]'
    '--threshold-file[Specify an alternate threshold file]:file:_files'
    '--data[Include data counters for ports with errors]'
    '--switch[Print data for switches only]'
    '--ca[Print data for CAs only]'
    '--router[Print data for routers only]'
    '--details[Include transmit discard details]'
    '--counters[Print data counters only]'
    {--clear-errors,-k}'[Clear error counters after read]'
    {--clear-counts,-K}'[Clear data counters after read]'
    '--load-cache[Filename of ibnetdiscover cache to load]:file:_files'
    {--outstanding_smps,-o}'[Specify the number of outstanding SMPs]:val'
    {--config,-z}'[Use config file]:config:_files'
    {--Ca,-C}'[CA name to use]:ca_name'
    {--Port,-P}'[CA port number to use]:port'
    {--timeout,-t}'[Timeout in ms]:timeout'
    {--m_key,-y}'[M_Key to use in request]:key'
    {--errors,-e}'[Show send and receive errors]'
    {--verbose,-v}'[Increase verbosity level]'
    {--debug,-d}'[Raise debug level]'
    {--help,-h}'[Show help message]'
    {--version,-V}'[Show version]'
    '*:filename:_files'
)
_arguments -s $arguments
