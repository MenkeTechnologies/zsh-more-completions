#compdef makeindex

local arguments

arguments=(
    '-c[Compress intermediate blanks (ignoring leading and trailing blanks and tabs)]'
    '-g[Employ German word ordering in the index]'
    '-i[Take input from stdin]'
    '-l[Letter ordering; by default, word ordering is used]'
    '-o[Employ ind as the output index file]:ind:_files'
    '-p[Set the starting page number of the output index file]:num'
    '-q[Quiet mode; send no messages to stderr]'
    '-r[Disable implicit page range formation]'
    '-s[Employ sty as the style file]:sty:_files'
    '-t[Employ log as the transcript file]:log:_files'
    '-L[Sort based on locale settings]'
    '-T[Special support for Thai documents]'
    '*:filename:_files'
)
_arguments -s $arguments
