#compdef th-cmd

local arguments

arguments=(
    '--socket[the socket file opened by the running triggerhappy daemon]:socket:_files'
    '--add[instruct the running daemon to open the input devices]:devices'
    '--remove[remove specified devices from the running daemon]:devices'
    '--clear[remove all devices from the running daemon]'
    '--udev[deduce operation and device name from udev environment]'
    '--disable[disable the execution of triggers]'
    '--enable[re-enable the execution of triggers]'
    '--mode[change the mode of the triggerhappy daemon]:newmode'
    '--quit[terminate the triggerhappy daemon]'
    '--passfd[open the device and pass the file descriptor to the daemon]'
    '--grab[grab the device for exclusive access]'
    '*:filename:_files'
)
_arguments -s $arguments
