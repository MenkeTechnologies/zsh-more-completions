#compdef jack_metro

local arguments

arguments=(
    {-n,--name}'[Specify a name for this instance of the metronome]:name'
    {-f,--frequency}'[Define the frequency of the tick in Hz]:Hz'
    {-D,--duration}'[Define the duration of the tick in milliseconds]:msecs'
    {-a,--attack}'[Define the duration of the attack phase as a percentage of the total duration]:percent'
    {-d,--decay}'[Define the duration of the decay phase as a percentage of the total duration]:percent'
    {-b,--bpm}'[Set beats per minute]:bpm'
    '*:filename:_files'
)
_arguments -s $arguments
