#compdef tpm2_takeownership

local arguments

arguments=(
    '-o[new owner password]:password'
    '-e[new endorsement password]:password'
    '-l[new lockout password]:password'
    '-O[old owner password]:password'
    '-E[old endorsement password]:password'
    '-L[old lockout password]:password'
    '-c[clear the three authorization values]'
    '-h[display help information]'
    '-v[display version, supported tctis and exit]'
    '-V[increase verbosity of tool output]'
    '-Q[suppress informational output]'
    '-Z[enable errata fixups]'
    '-T[select the TCTI used for communication]:tcti'
    '*:filename:_files'
)
_arguments -s $arguments
