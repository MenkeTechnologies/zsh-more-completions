#compdef nimpretty

local arguments

arguments=(
    '--out[Set the output file (default: overwrite the input file)]:file:_files'
    '--outDir[Set the output directory (default: overwrite the input files)]:dir:_directories'
    '--indent[Set the number of spaces for indentation (0 means autodetect)]:N'
    '--maxLineLen[Set the desired maximum line length (default: 80)]:N'
    '--version[Show the version]'
    '--help[Show this help]'
    '*:filename:_files'
)
_arguments -s $arguments
