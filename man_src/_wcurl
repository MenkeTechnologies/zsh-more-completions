#compdef wcurl

local arguments

arguments=(
    '--curl-options[Specify extra options to be passed when invoking curl]:options'
    {-o,-O,--output}'[Use the provided output path instead of getting it from the URL]:path:_files'
    '--no-decode-filename[Do not percent-decode the output filename]'
    '--dry-run[Do not actually execute curl, just print what would be invoked]'
    {-V,--version}'[Print version information]'
    {-h,--help}'[Print usage message]'
    '*:url:'
)
_arguments -s $arguments
