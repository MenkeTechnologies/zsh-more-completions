#compdef chcat
# Documentation: https://man.archlinux.org/search?q=chcat
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-d[Delete the category from each file or user]'
    '-L[List available categories]'
    '-l[Operate on users instead of files]'
    '*:filename:_files'
)
_arguments -s $arguments
