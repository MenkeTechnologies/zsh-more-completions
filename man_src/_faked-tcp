#compdef faked-tcp

local arguments

arguments=(
    '--debug[Print debugging information on stderr]'
    '--foreground[Do not fork into the background]'
    '--cleanup[Cleanup the semaphores]:number'
    '--key[Use the specified communication channel key]:key-number'
    '--save-file[Save the environment to save-file on exit]:save-file:_files'
    '--load[Load a previously saved environment from standard input]'
    '--unknown-is-real[Use real ownership of previously-unknown files instead of setting them to root]'
    '--port[Use the specified TCP port]:tcp-port'
    '*:filename:_files'
)
_arguments -s $arguments
