#compdef texindy

local arguments

arguments=(
    {--version,-V}'[print version information]'
    {--help,-h,-\?}'[display help information]'
    {--quiet,-q}'[suppress informational messages]'
    {--verbose,-v}'[enable verbose output]'
    {--debug,-d}'[enable debug output]'
    {--out-file,-o}'[specify output file]:file:_files'
    {--log-file,-t}'[specify log file]:file:_files'
    {--language,-L}'[specify language]:language'
    {--codepage,-C}'[specify codepage]:codepage'
    {--module,-M}'[specify module]:module'
    {--input-markup,-I}'[specify input markup]:markup:(latex xindy omega)'
    '*:filename:_files'
)
_arguments -s $arguments
