#compdef myisamlog

local arguments

arguments=(
    '-\?[Display help]'
    '-I[Display extra information]'
    '-c[Execute only N commands]:N'
    '-f[Maximum number of open files]:N'
    '-F[Read log from the specified filepath]:filepath:_files'
    '-i[Display extra information]'
    '-o[Start reading log from the specified offset]:offset'
    '-p[Remove N components from path]:N'
    '-r[Recovery mode]'
    '-R[Reposition in file with specified record position]:record_pos'
    '-u[Update mode]'
    '-v[Verbose mode]'
    '-w[Write modified records to specified file]:write_file:_files'
    '-V[Display version information]'
    '*:filename:_files'
)
_arguments -s $arguments
