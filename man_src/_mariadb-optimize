#compdef mariadb-optimize

local arguments

arguments=(
    '--print-defaults[Print the program argument list and exit]'
    '--no-defaults[Do not read default options from any option file]'
    '--defaults-file[Only read default options from the given file]:file:_files'
    '--defaults-extra-file[Read this file after the global files are read]:file:_files'
    '--defaults-group-suffix[Read default groups with the specified suffix]:suffix'
    {-A,--all-databases}'[Check all databases]'
    {-a,--analyze}'[Analyze given tables]'
    {-1,--all-in-1}'[Use one query per database instead of one per table]'
    '--auto-repair[Automatically fix corrupted tables]'
    '--character-sets-dir[Directory for character set files]:dir:_directories'
    {-c,--check}'[Check table for errors]'
    {-C,--check-only-changed}'[Check only tables that have changed since last check]'
    {-g,--check-upgrade}'[Check tables for version-dependent changes]'
    '--compress[Compress all information sent between client and server]'
    {-B,--databases}'[Check several databases]'
    '--debug-check[Check memory and open file usage at exit]'
    '--debug-info[Print some debug info at exit]'
    '--default-character-set[Set the default character set]:charset'
    '--default-auth[Default authentication client-side plugin to use]:plugin'
    {-F,--fast}'[Check only tables that have not been closed properly]'
    '--fix-db-names[Fix database names]'
    '--fix-table-names[Fix table names]'
    {-f,--force}'[Continue even if we get an SQL error]'
    {-e,--extended}'[Perform extended check on a table]'
    '--flush[Flush each table after check]'
    {-h,--host}'[Connect to host]:host:_hosts'
    {-m,--medium-check}'[Faster than extended-check but only finds 99.99% of all errors]'
    '--write-binlog[Log ANALYZE, OPTIMIZE and REPAIR TABLE commands]'
    '--skip-write-binlog[Do not log commands to binary log]'
    {-o,--optimize}'[Optimize table]'
    {-p,--password}'[Password to use when connecting to server]:password'
    {-Z,--persistent}'[Use PERSISTENT FOR ALL option for ANALYZE TABLE]'
    '--plugin-dir[Directory for client-side plugins]:dir:_directories'
    {-P,--port}'[Port number to use for connection]:port'
    '--protocol[The protocol to use for connection]:protocol:(tcp socket pipe)'
    {-q,--quick}'[Faster check]'
    {-r,--repair}'[Perform a repair]'
    {-s,--silent}'[Print only error messages]'
    '--skip-database[Do not process the specified database]:database'
    {-S,--socket}'[The socket file to use for connection]:socket:_files'
    '--ssl[Enable SSL for connection]'
    '--ssl-ca[CA file in PEM format]:file:_files'
    '--ssl-capath[CA directory]:dir:_directories'
    '--ssl-cert[X509 cert in PEM format]:file:_files'
    '--ssl-cipher[SSL cipher to use]:cipher'
    '--ssl-key[X509 key in PEM format]:file:_files'
    '--ssl-crl[Certificate revocation list]:file:_files'
    '--ssl-crlpath[Certificate revocation list path]:dir:_directories'
    '--tls-version[TLS protocol version for secure connection]:version'
    '--ssl-verify-server-cert[Verify server certificate]'
    '--tables[Overrides option --databases (-B)]'
    '--use-frm[Get table structure from .frm file for repair]'
    {-u,--user}'[User for login]:user'
    {-v,--verbose}'[Print info about the various stages]'
    {-V,--version}'[Output version information and exit]'
    '--process-views[Perform the requested operation on views]:option'
    '--process-tables[Perform the requested operation on tables]'
    '*:filename:_files'
)
_arguments -s $arguments
