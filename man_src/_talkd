#compdef talkd

local arguments

arguments=(
    {-a,--acl}'[read site-wide ACLs from FILE]:FILE:_files'
    {-d,--debug}'[enable debugging]'
    {-l,--logging}'[enable more syslog reporting]'
    {-r,--request-ttl}'[set request time-to-live value to SECONDS]:SECONDS'
    {-S,--strict-policy}'[apply strict ACL policy]'
    {-t,--timeout}'[set timeout value to SECONDS]:SECONDS'
    {-\?,--help}'[give this help list]'
    '--usage[give a short usage message]'
    {-i,--idle-timeout}'[set idle timeout]'
    {-V,--version}'[print program version]'
    '*:filename:_files'
)
_arguments -s $arguments
