#compdef mariadb-test mysqltest

local arguments

arguments=(
    {-\?,--help}'[Display help and exit]'
    {-b,--basedir}'[Base directory for tests]:dir_name:_directories'
    '--character-sets-dir[Directory for character set files]:path:_directories'
    {-C,--compress}'[Compress all information sent between client and server]'
    '--connect-timeout[Connection timeout]:num'
    '--continue-on-error[Continue test even if a query fails]'
    '--cursor-protocol[Use cursors for prepared statements]'
    {-D,--database}'[Database to use]:db_name'
    {-\#,--debug}'[Write debugging log]:debug_options'
    '--debug-check[Check memory and open file usage at exit]'
    '--debug-info[Print debugging information at exit]'
    {-h,--host}'[Connect to host]:host_name:_hosts'
    '--logdir[Directory for log files]:dir_name:_directories'
    '--mark-progress[Write line number and elapsed time to test progress file]'
    '--max-connect-retries[Maximum number of connection attempts]:num'
    '--max-connections[Maximum number of simultaneous server connections]:num'
    '--no-defaults[Do not read default options from any option file]'
    '--non-blocking-api[Use the non-blocking client API]'
    '--overlay-dir[Directory for overlay test files]:dir_name:_directories'
    {-p,--password}'[Password to use for connection]:password'
    '--plugin-dir[Directory for client-side plugins]:dir_name:_directories'
    {-P,--port}'[Port number for connection]:port_num'
    '--prologue[SQL file to include before each test]:name:_files'
    '--protocol[Connection protocol to use]:protocol:(TCP SOCKET PIPE MEMORY)'
    '--ps-protocol[Use prepared-statement protocol]'
    '--quiet[Suppress warnings]'
    {-r,--record}'[Record output of test]'
    {-R,--result-file}'[Read expected results from file]:file_name:_files'
    '--result-format-version[Version of the result file format to use]:#'
    {-A,--server-arg}'[Argument passed to embedded server]:value'
    {-F,--server-file}'[Read arguments for embedded server from file]:file_name:_files'
    {-s,--silent}'[Suppress all normal output]'
    {-T,--sleep}'[Sleep specified number of seconds after each command]:num'
    {-S,--socket}'[Socket file to use for connection]:path:_files'
    '--sp-protocol[Execute DML statements with stored procedures]'
    '--ssl[Enable SSL for connection]'
    '--ssl-ca[CA file in PEM format]:name:_files'
    '--ssl-capath[CA directory]:name:_directories'
    '--ssl-cert[X509 cert in PEM format]:name:_files'
    '--ssl-cipher[SSL cipher to use]:name'
    '--ssl-key[X509 key in PEM format]:name:_files'
    '--ssl-verify-server-cert[Verify server certificate]'
    '--suite-dir[Suite directory]:dir_name:_directories'
    '--tail-lines[Number of lines of the result to include in output]:nn'
    {-x,--test-file}'[Read test input from this file]:file_name:_files'
    {-m,--timer-file}'[File for timing data]:file_name:_files'
    {-t,--tmpdir}'[Temporary directory]:dir_name:_directories'
    {-u,--user}'[User for login]:user_name'
    {-v,--verbose}'[Write more output]'
    {-V,--version}'[Output version information and exit]'
    '--view-protocol[Create a view to execute all SELECT statements]'
    '*:filename:_files'
)
_arguments -s $arguments
