#compdef kdesu

local arguments

arguments=(
    '-c[Specify the command to run as root]:command'
    '-d[Show debug information]'
    '-f[Allow efficient use of kdesu in .desktop files]:file:_files'
    '-i[Specify icon to use in the password dialog]:name'
    '-n[Do not keep the password]'
    '-p[Set priority value]:priority'
    '-r[Use realtime scheduling]'
    '-s[Stop the kdesu daemon]'
    '-t[Enable terminal output; this disables password keeping]'
    '-u[Run the command as a user other than root]:user'
    '--noignorebutton[Do not display an ignore button]'
    '--attach[Make the dialog transient for an X app specified by winid]:winid'
    '*:filename:_files'
)
_arguments -s $arguments
