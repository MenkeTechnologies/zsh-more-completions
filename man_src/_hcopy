#compdef hcopy
# Documentation: https://man.archlinux.org/search?q=hcopy
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-m[Use MacBinary II format for binary file transfer]'
    '-b[Use BinHex format for ASCII file transfer]'
    '-t[Perform end-of-line translation (Text mode)]'
    '-r[Raw Data mode; perform no translation]'
    '-a[Automatic mode; choose a mode automatically for each file based on a set of predefined rules]'
    '*:filename:_files'
)
_arguments -s $arguments
