#compdef libmikmod-config

local arguments

arguments=(
    '--version[Print the currently installed version of libmikmod on standard output]'
    '--libs[Print the linker flags that are necessary to link a libmikmod program]'
    '--ldadd[Print the extra linker flags that are necessary to link a libmikmod program in certain configurations]'
    '--cflags[Print the compiler flags that are necessary to compile a libmikmod program]'
    '--prefix[Use PREFIX instead of the installation prefix that libmikmod was built with]:PREFIX:_directories'
    '--exec-prefix[Use PREFIX instead of the installation exec prefix that libmikmod was built with]:PREFIX:_directories'
    '*:filename:_files'
)
_arguments -s $arguments
