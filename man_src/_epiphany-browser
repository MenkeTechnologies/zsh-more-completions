#compdef epiphany-browser

local arguments

arguments=(
    {-\?,--help}'[Show help options]'
    {-n,--new-tab}'[Open a new tab in an existing browser window]'
    '--new-window[Open a new browser window]'
    {-b,--bookmarks-editor}'[Launch the bookmarks editor]'
    '--import-bookmarks[Import bookmarks from the given file]:FILE:_files'
    {-l,--load-session}'[Load the given session file]:FILE:_files'
    {-t,--add-bookmark}'[Add a bookmark]:URL'
    '--private-instance[Start a private instance]'
    '--profile[Profile directory to use in the private instance]:FILE:_directories'
    '--display[X display to use]:DISPLAY'
    '--version[Show version]'
    '*:filename:_files'
)
_arguments -s $arguments
