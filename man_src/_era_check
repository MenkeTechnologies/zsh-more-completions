#compdef era_check

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Print help and exit]'
    {-V,--version}'[Print version information and exit]'
    {-q,--quiet}'[Suppress output messages, return only exit code]'
    '--super-block-only[Only check the superblock is present]'
    '*:filename:_files'
)
_arguments -s $arguments
