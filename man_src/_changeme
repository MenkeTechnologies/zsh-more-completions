#compdef changeme

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Show this help message and exit]'
    {--all,-a}'[Scan for all protocols]'
    {--category,-c}'[Category of default creds to scan for]:category'
    '--contributors[Display cred file contributors]'
    {--debug,-d}'[Debug output]'
    {--delay,--dl}'[Specify a delay in milliseconds to avoid 429 status codes]:delay'
    '--dump[Print all of the loaded credentials]'
    '--dryrun[Print urls to be scanned, but do not scan them]'
    {--fingerprint,-f}'[Fingerprint targets, but do not check creds]'
    '--fresh[Flush any previous scans and start fresh]'
    {--log,-l}'[Write logs to logfile]:log file:_files'
    '--mkcred[Make cred file]'
    {--name,-n}'[Narrow testing to the supplied credential name]:name'
    '--noversion[Do not perform a version check]'
    {--proxy,-p}'[HTTP(S) Proxy]:proxy URL'
    {--output,-o}'[Name of result file (csv, html, json based on extension)]:output file:_files'
    '--oa[Output results files in csv, html and json formats]'
    '--protocols[Comma separated list of protocols to test]:protocols'
    '--portoverride[Scan all protocols on all specified ports]'
    '--redishost[Redis server host]:host:_hosts'
    '--redisport[Redis server port]:port'
    {--resume,-r}'[Resume previous scan]'
    {--shodan_query,-q}'[Shodan query]:query'
    {--shodan_key,-k}'[Shodan API key]:key'
    '--ssl[Force cred to SSL and fall back to non-SSL on SSLError]'
    {--threads,-t}'[Number of threads]:threads'
    '--timeout[Timeout in seconds for a request]:timeout'
    {--useragent,--ua}'[User agent string to use]:user agent'
    '--validate[Validate creds files]'
    {--verbose,-v}'[Verbose output]'
    '*:filename:_files'
)
_arguments -s $arguments
