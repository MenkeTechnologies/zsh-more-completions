#compdef lilymidi
# Documentation: https://man.archlinux.org/search?q=lilymidi
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--version[Show version number and exit]'
    '(- * :)'{-h,--help}'[Show help message and exit]'
    '--filter-tracks[Display only tracks matching REGEXP]:REGEXP'
    '--prefix-tracks[Prefix filtered track numbers with PREFIX]:PREFIX'
    '--dump[Just dump parsed contents of the MIDI file]'
    '--pretty[Dump parsed contents in human-readable form (implies --dump)]'
    '*:filename:_files'
)
_arguments -s $arguments
