#compdef oracle

local arguments

arguments=(
    '--cpuprofile[Write CPU profile to file]:file:_files'
    '--format[Output format]:format:(plain json xml)'
    '--pos[Filename and byte offset or extent of a syntax element to query]:position'
    '--ptalog[Location of the points-to analysis log file, or empty to disable logging]:file:_files'
    '--reflect[Analyze reflection soundly (slow)]'
    '*:filename:_files'
)
_arguments -s $arguments
