#compdef msgs

# Autogenerated from man page /usr/share/man/man1/msgs.1

local arguments

arguments=(
    '-y[Type the rest of the message. RETURN Synonym for y.]'
    '-n[Skip this message and go on to the next message.]'
    '-q[Drop out of msgs; the next time msgs will pick up where it last left off.]'
    '-s[Append the current message to the file "Messages" in the current directory; strstr strstr if the file does not exist, create it.]'
    '-m[A copy of the specified message is placed in a temporary mailbox and mail is invoked to read it.]'
    '-f[Do not say "No new messages". This is useful in a login script.]'
    '-h[Print the first part of messages only.]'
    '-l[Cause only locally originated messages to be reported.]'
    '-p[Pipe long messages through more.]'
    '*:filename:_files'
)
_arguments -s $arguments
