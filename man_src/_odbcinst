#compdef odbcinst

local arguments

arguments=(
    '-i[Install new object by adding section to config file]'
    '-u[Uninstall existing object by removing section from config file]'
    '-q[Query config files and print options for specified object]'
    '-j[Print current configuration of unixODBC including paths]'
    '-c[Call SQLCreateDataSource]'
    '-m[Call SQLManageDataSources]'
    '--version[Print program version and exit]'
    '-d[Action affects drivers and the odbcinst.ini configuration file]'
    '-s[Action affects data sources and the user or system odbc.ini]'
    '-f[Template file describing the configuration of installed object]:file:_files'
    '-r[Same as -f but take standard input as the template file]'
    '-n[Specify the name of the object]:name'
    '-v[Turn off verbose mode]'
    '-l[The specified data source is system-wide]'
    '-h[The specified data source is user-specific]'
    '*:filename:_files'
)
_arguments -s $arguments
