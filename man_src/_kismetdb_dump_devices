#compdef kismetdb_dump_devices

local arguments

arguments=(
    {-i,--in}'[Input kismetdb file]:filename:_files'
    {-o,--out}'[Output file]:filename:_files'
    {-f,--force}'[Force writing to the target file, even if it exists]'
    {-e,--ekjson}'[Write as ekjson records, one device per line]'
    {-v,--verbose}'[Verbose output]'
    {-s,--skip-clean}'[Do not clean (SQL vacuum) input database]'
    '*:filename:_files'
)
_arguments -s $arguments
