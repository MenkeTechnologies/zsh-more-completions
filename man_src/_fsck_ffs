#compdef fsck_ffs

local arguments

arguments=(
    '-B[Check the specified and possibly active file system]'
    '-b[Use the specified block as the super block]:block'
    '-C[Check if file system was dismounted cleanly]'
    '-c[Convert the file system to the specified level]:level'
    '-d[Enable debugging messages]'
    '-E[Clear unallocated blocks, notifying the device they are not used]'
    '-F[Determine whether the file system needs cleaning in foreground]'
    '-f[Force checking of clean file systems when preening]'
    '-m[Use the mode specified in octal as the permission for lost+found]:mode'
    '-n[Assume a no response to all questions except CONTINUE]'
    '-p[Preen file systems]'
    '-R[Restart if certain errors are encountered]'
    '-r[Free up excess unused inodes]'
    '-S[Surrender on error]'
    '-y[Assume a yes response to all questions]'
    '-Z[Overwrite unused blocks with zeroes]'
    '*:filename:_files'
)
_arguments -s $arguments
