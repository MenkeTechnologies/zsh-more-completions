#compdef Magick++-config

local arguments

arguments=(
    '--cppflags[Print the preprocessor flags needed to find the ImageMagick C and C++ include files]'
    '--cxxflags[Print the compiler flags that were used to compile libMagick++]'
    '--exec-prefix[Print the directory under which target specific binaries and executables are installed]'
    '--ldflags[Print the linker flags needed to link with the libMagick++ library]'
    '--libs[Print the linker flags needed to link a program with libMagick++]'
    '--prefix[Print the directory under which the package is installed]'
    '--version[Print the version of the ImageMagick distribution]'
    '*:filename:_files'
)
_arguments -s $arguments
