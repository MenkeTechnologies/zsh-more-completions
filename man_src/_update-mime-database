#compdef update-mime-database
# Documentation: https://man.archlinux.org/search?q=update-mime-database
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-h[Print out a command summary]'
    '-v[Print out the version information]'
    '-V[Be verbose]'
    '-n[Only update if packages directory or a file in it is newer than the database]'
    '*:directory:_directories'
)
_arguments -s $arguments
