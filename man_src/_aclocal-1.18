#compdef aclocal-1.18

# Autogenerated from man page /opt/homebrew/share/man/man1/aclocal-1.18.1
# Updated with latest aclocal options

local arguments

arguments=(
    '--automake-acdir[Directory holding automake-provided m4 files]:DIR:_directories'
    '--aclocal-path[Colon-separated list of directories to search for third-party local files]:PATH'
    '--system-acdir[Directory holding third-party system-wide files]:DIR:_directories'
    '--diff[Run COMMAND on M4 files that would be changed (implies --install and --dry-run)]:COMMAND'
    '--dry-run[Pretend to, but do not actually update any file]'
    '--force[Always update output file]'
    '(- * :)--help[Print help, then exit]'
    '-I[Add directory to search list for .m4 files]:DIR:_directories'
    '--install[Copy third-party files to the first -I directory]'
    '--output[Put output in FILE (default aclocal.m4)]:FILE:_files'
    '--print-ac-dir[Print name of directory holding system-wide third-party m4 files, then exit]'
    '--verbose[Be verbose]'
    '--version[Print version number, then exit]'
    {-W,--warnings}'[Report the warnings falling in CATEGORY]:CATEGORY:(syntax unsupported)'
    '*:filename:_files'
)
_arguments -s $arguments
