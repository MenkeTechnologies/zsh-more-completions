#compdef kf5-config
# Documentation: https://man.archlinux.org/search?q=kf5-config
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--expandvars[Expand \${prefix} and \${exec_prefix} in output]'
    '--prefix[Compiled in prefix for Frameworks libraries]'
    '--exec-prefix[Compiled in exec_prefix for Frameworks libraries]'
    '--libsuffix[Compiled in library path suffix]'
    '--localprefix[Prefix in \$HOME used to write files]'
    '--version[Version of Qt and compiled in version string for Frameworks libraries]'
    '--kde-version[Compiled in version string for Frameworks libraries]'
    '--types[Print a list of all available KDE resource types]'
    '--path[Search path for the specified type]:type'
    '--userpath[User paths for the specified type]:type'
    '--install[Prefix to install resource files to]:type'
    '--qt-prefix[Installation prefix for Qt]'
    '--qt-binaries[Location of installed Qt binaries]'
    '--qt-libraries[Location of installed Qt libraries]'
    '--qt-plugins[Location of installed Qt plugins]'
    '*:filename:_files'
)
_arguments -s $arguments
