#compdef corelist5.34

local arguments

arguments=(
    '-a[List all versions of the given module]'
    '-d[Find the first perl version where a module was released by date]'
    '--diff[Print a table of all module changes between two perl versions]'
    {-\?,--help}'[Show help message]'
    '--man[Show full documentation]'
    '-v[List all perl release versions in CoreList]'
    '-r[List all perl releases and when they were released]'
    '--utils[List the first version of perl each named utility was released with]'
    {--feature,-f}'[List the first version bundle of each named feature]'
    '*:filename:_files'
)
_arguments -s $arguments
