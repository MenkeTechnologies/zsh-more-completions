#compdef cdcontrol
# Documentation: https://man.archlinux.org/search?q=cdcontrol
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-s[Silent mode, do not print table headers and human readable comments]'
    '-v[Verbose mode, print as much information as possible]'
    '-f[Specify a device]:device:_files'
    '*:filename:_files'
)
_arguments -s $arguments
