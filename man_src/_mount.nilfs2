#compdef mount.nilfs2

local arguments

arguments=(
    '-V[Output version]'
    '-f[Fake mounting the file system, do not call the actual system call]'
    '-i[Do not call mount.nilfs2 helper]'
    '-n[Mount without writing in /etc/mtab]'
    '-r[Mount the file system read-only]'
    '-v[Verbose mode]'
    '-w[Mount the file system read/write (default)]'
    '-o[Mount options]:options'
    '*:filename:_files'
)
_arguments -s $arguments
