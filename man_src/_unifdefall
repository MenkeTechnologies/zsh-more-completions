#compdef unifdefall

local arguments

arguments=(
    '-D[Specify that a symbol is defined to a given value]:name=value'
    '-U[Specify that a symbol is undefined]:name'
    '-b[Replace removed lines with blank lines instead of deleting them]'
    '-B[Compress blank lines around a deleted section]'
    '-c[Complement the operation of unifdefall]'
    '-d[Turn on printing of debugging messages]'
    '-e[Process C preprocessor directives that span multiple lines]'
    '-K[Always treat the result of && and || operators as unknown]'
    '-k[Process #if and #elif lines with constant expressions]'
    '-n[Add #line directives to the output following any deleted lines]'
    '-o[Write output to the specified file]:outfile:_files'
    '-s[Print a list of symbols used in preprocessor directives]'
    '-S[Like -s, but also print nesting depth of each symbol]'
    '-t[Disable parsing for C comments and line continuations]'
    '-I[Specify additional directory to look for #include files]:directory:_directories'
    '-V[Print version details]'
    '*:filename:_files'
)
_arguments -s $arguments
