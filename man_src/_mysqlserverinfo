#compdef mysqlserverinfo

local arguments

arguments=(
    '--help[Display help and exit]'
    '--basedir[Display the base directory of the server]'
    '--datadir[Display the data directory of the server]'
    '--format[Output format]:format:(grid csv tab vertical)'
    '--no-headers[Suppress column headers]'
    '--port-range[Port range for checking]:start:end'
    '--server[Connection information for the server]:server'
    '--show-defaults[Show server default variable values]'
    '--show-servers[Show all server instances on the local machine]'
    '--start[Start the server if offline]'
    '--start-timeout[Seconds to wait for server to start]:timeout'
    {-v,--verbose}'[Verbose output]'
    '--version[Display version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
