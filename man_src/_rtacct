#compdef rtacct

# Autogenerated from man page
# Updated with latest rtacct options

local arguments

arguments=(
    {-V,--version}'[print version]'
    {-z,--zeros}'[dump zero counters too (by default they are not shown)]'
    {-r,--reset}'[reset history]'
    {-n,--nooutput}'[do not display anything, only update history]'
    {-a,--ignore}'[dump absolute values of counters]'
    {-s,--noupdate}'[do not update history, so next time you see counters including values from this time]'
    {-j,--json}'[display results in JSON format]'
    {-p,--pretty}'[when combined with --json, pretty print the output]'
    {-d,--scan}'[run in daemon mode collecting statistics]:INTERVAL'
    '(- * :)'{-h,--help}'[print help]'
    {-t,--interval}'[time interval to average rates (default 60 seconds)]:INTERVAL'
    '*:filename:_files'
)
_arguments -s $arguments
