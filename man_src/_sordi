#compdef sordi
# Documentation: https://man.archlinux.org/search?q=sordi
# Reference accessed: 2026-05-16

# Updated with fixes

local arguments

arguments=(
    '-h[Display help and exit]'
    '-i[Input syntax]:syntax:(turtle ntriples)'
    '-o[Output syntax]:syntax:(turtle ntriples)'
    '-s[Parse INPUT as string (terminates options)]:input'
    '-v[Display version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
