#compdef vala-gen-introspect

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Show help options]'
    {-v,--verbose}'[Be verbose]'
    {-o,--output}'[Write output here instead of stdout]:file:_files'
    {-n,--namespace}'[Namespace of the module]:namespace'
    '--shared-library[Shared library which contains the symbols]:file:_files'
    '--include-idl[Other gidls to include]:idl:_files'
    '*:filename:_files'
)
_arguments -s $arguments
