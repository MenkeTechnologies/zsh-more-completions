#compdef saquery

# Updated with fixes for reversed option format and truncated descriptions

local arguments

arguments=(
    {-p,--p}'[Get PathRecord info]'
    {-N,--N}'[Get NodeRecord info]'
    {-L,--L}'[Return the LIDs of the name specified]'
    {-l,--l}'[Return the unique LID of the name specified]'
    {-G,--G}'[Return the GUIDs of the name specified]'
    {-O,--O}'[Return name for the LID specified]'
    {-U,--U}'[Return name for the GUID specified]'
    {-s,--s}'[Return PortInfoRecords with isSM capability]'
    {-g,--g}'[Get multicast group info]'
    {-m,--m}'[Get multicast member info]'
    {-x,--x}'[Get LinkRecord info]'
    {-c,--c}'[Get the SA class port info]'
    {-S,--S}'[Get ServiceRecord info]'
    {-I,--I}'[Get InformInfoRecord (subscription) info]'
    {-D,--list}'[Show the node desc of the CAs]'
    '--src-to-dst[Get a PathRecord for source to destination]:src\:dst'
    '--sgid-to-dgid[Get a PathRecord for source GID to destination GID]:sgid-dgid'
    '--node-name-map[Specify a node name map file]:file:_files'
    '--smkey[SA SM_Key value for the query]:key'
    '--slid[Source LID (PathRecord)]:lid'
    '--dlid[Destination LID (PathRecord)]:lid'
    '--mlid[Multicast LID (MCMemberRecord)]:lid'
    '--sgid[Source GID in IPv6 format (PathRecord)]:gid'
    '--dgid[Destination GID in IPv6 format (PathRecord)]:gid'
    '--gid[Port GID (MCMemberRecord)]:gid'
    '--mgid[Multicast GID (MCMemberRecord)]:gid'
    {-r,--reversible}'[Reversible path (PathRecord)]'
    {-n,--numb_path}'[Number of paths (PathRecord)]:val'
    '--pkey[P_Key (PathRecord, MCMemberRecord)]:val'
    {-Q,--qos_class}'[QoS Class (PathRecord)]:val'
    '--sl[Service level (PathRecord, MCMemberRecord)]:val'
    {-M,--mtu}'[MTU and selector (PathRecord, MCMemberRecord)]:val'
    {-R,--rate}'[Rate and selector (PathRecord, MCMemberRecord)]:val'
    '--pkt_lifetime[Packet lifetime and selector (PathRecord, MCMemberRecord)]:val'
    {-q,--qkey}'[Q_Key (MCMemberRecord)]:val'
    {-T,--tclass}'[Traffic class (PathRecord, MCMemberRecord)]:val'
    {-F,--flow_label}'[Flow label (PathRecord, MCMemberRecord)]:val'
    {-H,--hop_limit}'[Hop limit (PathRecord, MCMemberRecord)]:val'
    '--scope[Scope (MCMemberRecord)]:val'
    {-J,--join_state}'[Join state (MCMemberRecord)]:val'
    {-X,--proxy_join}'[Proxy join (MCMemberRecord)]:val'
    '--service_id[ServiceID (PathRecord)]:val'
    {-z,--config}'[Use config file]:file:_files'
    {-C,--Ca}'[CA name to use]:ca'
    {-P,--Port}'[CA port number to use]:port'
    {-t,--timeout}'[Timeout in ms]:ms'
    {-K,--show_keys}'[Display security keys in output]'
    {-e,--errors}'[Show send and receive errors]'
    {-v,--verbose}'[Increase verbosity level]'
    {-d,--debug}'[Raise debug level]'
    {-h,--help}'[Help message]'
    {-V,--version}'[Show version]'
    '*:filename:_files'
)
_arguments -s $arguments
