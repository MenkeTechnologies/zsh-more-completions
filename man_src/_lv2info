#compdef lv2info
# Documentation: https://man.archlinux.org/search?q=lv2info
# Reference accessed: 2026-05-16

local arguments

arguments=(
  '-p[write Turtle description of plugin to FILE]'
  '-m[add record of plugin to manifest FILE]'
  '--help[display this help and exit]'
  '--version[display version information and exit]'
  '*:filename:_files'
)

_arguments -s $arguments
