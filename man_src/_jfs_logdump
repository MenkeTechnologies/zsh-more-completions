#compdef jfs_logdump
# Documentation: https://man.archlinux.org/search?q=jfs_logdump
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-a[Dump the entire contents of the journal log instead of just the committed transactions]'
    '-v[Verbose mode]'
    '*:filename:_files'
)
_arguments -s $arguments
