#compdef cherryd3

local arguments

arguments=(
    {-c,--config}'[Specify a config file to read and merge into the CherryPy site config]:config file:_files'
    '-d[Run the server as a daemon]'
    {-e,--environment}'[Specify the name of an environment to be applied]:environment'
    '-f[Start a FastCGI server instead of the default HTTP server]'
    '-s[Start a SCGI server instead of the default HTTP server]'
    {-i,--import}'[Specify a module to import]:module'
    {-p,--pidfile}'[Store the process id in the specified file]:pid file:_files'
    {-P,--Path}'[Specify a directory to insert at the head of sys.path]:directory:_directories'
    '*:filename:_files'
)
_arguments -s $arguments
