#compdef openvas-nasl

local arguments

arguments=(
    '-T[Write verbose trace of script execution to file]:tracefile:_files'
    '-t[Apply the NASL script to the specified target host]:target:_hosts'
    '-e[Specify the network interface for established connections]:iface'
    '-s[Set the return value of safe_checks() to 1]'
    '-D[Only run the description part of the script]'
    '-B[Run in description mode before running the script]'
    '-L[Lint the script with extended checks]'
    '-X[Run the script with disabled signature verification]'
    '-h[Show help]'
    '-v[Show the version of NASL]'
    '-d[Output debug information to stderr]'
    '-k[Set KB key to value, can be used multiple times]:key=value'
    '*:filename:_files'
)
_arguments -s $arguments
