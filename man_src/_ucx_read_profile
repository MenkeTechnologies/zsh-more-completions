#compdef ucx_read_profile
# Documentation: https://man.archlinux.org/search?q=ucx_read_profile
# Reference accessed: 2026-05-16

local arguments

arguments=(
  '-r[show raw output]'
  '-T[comma-separated list of threads to show, e.g. "1,2,3", or "all" to show all threads]'
  '-t[select time units to use:]'
  '-h[show this help message]'
  '*:filename:_files'
)

_arguments -s $arguments
