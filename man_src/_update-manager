#compdef update-manager

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Show help message]'
    {-V,--version}'[Show version]'
    '--data-dir[Directory that contains the data files]:directory:_directories'
    {-c,--check-dist-upgrades}'[Check if a new distribution release is available]'
    {-d,--devel-release}'[If using the latest supported release, upgrade to the development release]'
    {-p,--proposed}'[Upgrade using the latest proposed version of the release upgrader]'
    '--no-focus-on-map[Do not focus on map when starting]'
    '*:filename:_files'
)
_arguments -s $arguments
