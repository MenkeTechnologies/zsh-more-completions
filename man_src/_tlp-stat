#compdef tlp-stat

local arguments

arguments=(
    {-b,--battery}'[show battery data]'
    {-c,--config}'[show configuration]'
    {-d,--disk}'[show disk data]'
    {-e,--pcie}'[show PCI(e) device data]'
    {-g,--graphics}'[show graphics card data]'
    {-p,--processor}'[show processor data]'
    {-r,--rfkill}'[show radio device data]'
    {-s,--system}'[show system information]'
    {-t,--temp}'[show temperatures and fan speed]'
    {-u,--usb}'[show USB device data]'
    {-w,--warn}'[show warnings]'
    {-P,--pev}'[monitor power supply udev events]'
    '--psup[show power supply diagnostic]'
    {-T,--trace}'[show trace output]'
    {-v,--verbose}'[be more verbose]'
    '*:filename:_files'
)
_arguments -s $arguments
