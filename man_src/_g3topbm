#compdef g3topbm
# Documentation: https://man.archlinux.org/search?q=g3topbm
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--kludge[Ignore the first few lines of the file]'
    '--reversebits[Interpret bits least-significant first]'
    '--stretch[Stretch the image vertically by duplicating each row]'
    '*:filename:_files'
)
_arguments -s $arguments
