#compdef j1939acd
# Documentation: https://man.archlinux.org/search?q=j1939acd
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-v,--verbose}'[Increase verbosity]'
    {-r,--range}'[Ranges of source addresses e.g. 80,50-100,200-210 (defaults to 0-253)]:range'
    {-c,--cache}'[Cache file to save/restore the source address]:file:_files'
    {-a,--address}'[Specify the source address]:address'
    {-p,--prefix}'[Prefix to use when logging]:string'
    '*:filename:_files'
)
_arguments -s $arguments
