#compdef update-texmf
# Documentation: https://man.archlinux.org/search?q=update-texmf
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-v,--verbose}'[Show verbose messages]'
    {-d,--debug}'[Show debugging information, and do not delete temporary files]'
    {-o,--output}'[Generate output in FILE instead of /etc/texmf/web2c/texmf.cnf]:file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
