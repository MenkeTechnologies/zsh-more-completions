#compdef testament

local arguments

arguments=(
    '--print[print results to the console]'
    '--verbose[print commands (compiling and running tests)]'
    '--simulate[see what tests would be run but do not run them]'
    '--failing[only show failing/ignored tests]'
    '--nim[use a particular nim executable]:path:_files'
    '--directory[change to directory before reading the tests]:dir:_directories'
    '--colors[turn messages coloring on or off]:state:(on off)'
    '--backendLogging[disable or enable backend logging]:state:(on off)'
    '--megatest[enable or disable megatest]:state:(on off)'
    '--valgrind[enable or disable valgrind support]:state:(on off)'
    '--skipFrom[read tests to skip from file]:file:_files'
    '--targets[specify target backends]:targets'
    '*:filename:_files'
)
_arguments -s $arguments
