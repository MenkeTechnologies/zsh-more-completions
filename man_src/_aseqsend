#compdef aseqsend

# Updated with latest ALSA aseqsend options

local arguments

arguments=(
    '-h[Print a list of options]'
    '-V[Print the current version]'
    '-l[Print a list of possible output ports]'
    '-v[Print number of bytes actually sent]'
    '-p[Target port by number or name]:port'
    '-s[Send raw binary data from given file]:file:_files'
    '-i[Interval between SysEx messages in milliseconds]:interval'
    '*:filename:_files'
)
_arguments -s $arguments
