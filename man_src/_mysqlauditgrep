#compdef mysqlauditgrep

local arguments

arguments=(
    '--help[Display help and exit]'
    '--end-date[End date for filtering events]:date'
    '--event-type[Type of event to filter]:type'
    '--file-stats[Display file statistics]'
    '--format[Output format]:format:(grid csv tab vertical raw)'
    '--pattern[Pattern to search for in audit log entries]:pattern'
    '--query-type[Type of query to filter]:type'
    {-G,--basic-regexp}'[Use basic regular expression matching]'
    '--regexp[Use regular expression matching]'
    '--start-date[Start date for filtering events]:date'
    '--status[Filter by status value]:status'
    {-u,--users}'[Filter by user name]:users'
    {-v,--verbose}'[Verbose output]'
    '--version[Display version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
