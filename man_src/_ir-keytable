#compdef ir-keytable

local arguments

arguments=(
    {-a,--auto-load}'[Auto-load keymaps based on a configuration file]:cfgfile:_files'
    {-c,--clear}'[Clear the scancode to keycode mappings]'
    {-D,--delay}'[Set the delay before repeating a keystroke]:delay'
    {-k,--set-key}'[Set scancode to keycode mapping]:scankey'
    {-p,--protocol}'[Comma separated list of kernel protocols or BPF protocol to enable]:protocol'
    {-e,--parameter}'[Comma separated list of parameters for the BPF protocol]:parameter'
    {-P,--period}'[Set the period to repeat a keystroke]:period'
    {-r,--read}'[Read and show the current scancode to keycode mapping]'
    {-s,--sysdev}'[RC device to control]:sysdev'
    {-t,--test}'[Test if the RC device is generating events]'
    {-v,--verbose}'[Enable debug messages]'
    {-w,--write}'[Read the protocols and scancode to keycode mapping from the keymap file]:keymap:_files'
    {-\?,--help}'[Print the help message]'
    '--usage[Give a short usage message]'
    {-V,--version}'[Print the v4l2-utils version]'
    '*:filename:_files'
)
_arguments -s $arguments
