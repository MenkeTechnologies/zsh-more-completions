#compdef mandoc_soelim

local arguments

arguments=(
    '-C[Recognise .so when not followed by a space character]'
    '-r[Compatibility with GNU groff soelim (does nothing)]'
    '-t[Compatibility with GNU groff soelim (does nothing)]'
    '-v[Compatibility with GNU groff soelim (does nothing)]'
    '-I[Specify directories to search for files]:directory:_directories'
    '*:filename:_files'
)
_arguments -s $arguments
