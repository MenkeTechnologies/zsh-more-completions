#compdef texlogsieve

local arguments

arguments=(
    {--page-delay,--no-page-delay}'[enable/disable grouping messages by page before display]'
    {--summary,--no-summary}'[enable/disable final summary]'
    '--only-summary[no messages, show only the final summary]'
    {--shipouts,--no-shipouts}'[enable/disable reporting shipouts]'
    {--repetitions,--no-repetitions}'[allow/prevent repeated messages]'
    {--heartbeat,--no-heartbeat}'[enable/disable progress gauge in page-delay mode]'
    {-l,--minlevel}'[filter out messages with severity level lower than level]:level'
    {-u,--unwrap-only}'[do not filter messages, only unwrap long wrapped lines]'
    '--silence-package[filter out messages from the given package]:pkgname'
    '--silence-string[filter out messages containing the given string]:string'
    '--silence-file[filter out messages generated while the given file was being processed]:file:_files'
    '--semisilence-file[like silence-file but non-recursive]:file:_files'
    {-c,--config-file}'[read options from the given configuration file]:file:_files'
    {-h,--help}'[show concise options description]'
    '--version[print program version]'
    '*:filename:_files'
)
_arguments -s $arguments
