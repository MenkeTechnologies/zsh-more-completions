#compdef conntrack

local arguments

arguments=(
    {-L,--dump}'[List connection tracking or expectation table]'
    {-G,--get}'[Search for and show a particular matching entry]'
    {-D,--delete}'[Delete an entry from the given table]'
    {-I,--create}'[Create a new entry from the given table]'
    {-U,--update}'[Update an entry from the given table]'
    {-E,--event}'[Display a real-time event log]'
    {-F,--flush}'[Flush the whole given table]'
    {-C,--count}'[Show the table counter]'
    {-S,--stats}'[Show the in-kernel connection tracking system statistics]'
    {-z,--zero}'[Atomically zero counters after reading them]'
    {-o,--output}'[Display output in a certain format]:format'
    {-e,--event-mask}'[Set the bitmask of events to be generated]:bitmask'
    {-b,--buffer-size}'[Set the Netlink socket buffer size in bytes]:size'
    {-s,--src,--orig-src}'[Match entries whose source address in the original direction matches]:address'
    {-d,--dst,--orig-dst}'[Match entries whose destination address in the original direction matches]:address'
    {-r,--reply-src}'[Match entries whose source address in the reply direction matches]:address'
    {-q,--reply-dst}'[Match entries whose destination address in the reply direction matches]:address'
    {-p,--proto}'[Specify layer four protocol]:protocol'
    {-f,--family}'[Specify layer three protocol]:family:(ipv4 ipv6)'
    {-t,--timeout}'[Specify the timeout]:timeout'
    {-m,--mark}'[Specify the conntrack mark]:mark'
    {-l,--label}'[Specify a conntrack label]:label'
    '--label-add[Specify the conntrack label to add]:label'
    '--label-del[Specify the conntrack label to delete]:label'
    {-c,--secmark}'[Specify the conntrack selinux security mark]:mark'
    {-u,--status}'[Specify the conntrack status]:status'
    {-n,--src-nat}'[Filter source NAT connections]'
    {-g,--dst-nat}'[Filter destination NAT connections]'
    {-j,--any-nat}'[Filter any NAT connections]'
    {-w,--zone}'[Filter by conntrack zone]:zone'
    '--orig-zone[Filter by conntrack zone in original direction]:zone'
    '--reply-zone[Filter by conntrack zone in reply direction]:zone'
    '--tuple-src[Specify the tuple source address of an expectation]:address'
    '--tuple-dst[Specify the tuple destination address of an expectation]:address'
    '--mask-src[Specify the source address mask]:address'
    '--mask-dst[Specify the destination address mask]:address'
    {--sport,--orig-port-src}'[Source port in original direction]:port'
    {--dport,--orig-port-dst}'[Destination port in original direction]:port'
    '--reply-port-src[Source port in reply direction]:port'
    '--reply-port-dst[Destination port in reply direction]:port'
    '--state[TCP state]:state:(NONE SYN_SENT SYN_RECV ESTABLISHED FIN_WAIT CLOSE_WAIT LAST_ACK TIME_WAIT CLOSE LISTEN)'
    '--icmp-type[ICMP Type]:type'
    '--icmp-code[ICMP Code]:code'
    '--icmp-id[ICMP Id]:id'
    '--orig-vtag[Verification tag in the original direction]:value'
    '--reply-vtag[Verification tag in the reply direction]:value'
    '--role[Role that the original conntrack tuple is tracking]:role:(client server)'
    {--srckey,--orig-key-src}'[Source key in original direction]:key'
    {--dstkey,--orig-key-dst}'[Destination key in original direction]:key'
    '--reply-key-src[Source key in reply direction]:key'
    '--reply-key-dst[Destination key in reply direction]:key'
    '*:filename:_files'
)
_arguments -s $arguments
