#compdef fsck_msdos
# Documentation: https://man.archlinux.org/search?q=fsck_msdos
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-q[Quickly check whether the volume was unmounted cleanly]'
    '-f[Force check (ignored, present for compatibility)]'
    '-n[Assume no as the answer to all operator questions]'
    '-p[Preen the specified file systems]'
    '-y[Assume yes as the answer to all operator questions]'
    '*:filename:_files'
)
_arguments -s $arguments
