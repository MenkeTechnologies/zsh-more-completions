#compdef mariadb-hotcopy mysqlhotcopy

local arguments

arguments=(
    {-\?,--help}'[Display help and exit]'
    '--addtodest[Do not rename target directory (if it exists), instead copy to it]'
    '--allowold[Do not abort if a target directory already exists, rename it]'
    '--checkpoint[Insert checkpoint entry into the specified database table]:db.table'
    '--chroot[Base directory of the chroot jail]:path:_directories'
    '--debug[Enable debug output]'
    '--dryrun[Report actions without executing them]'
    '--flushlog[Flush log files on the server after locking all tables]'
    {-h,--host}'[Connect to the specified host]:host_name:_hosts'
    '--keepold[Do not delete previous (renamed) target directory]'
    '--method[Method for copying files]:method:(cp scp)'
    '--noindices[Do not include full index files for MyISAM tables]'
    '--old-server[Assume server is old and does not support FLUSH TABLES WITH READ LOCK]'
    {-p,--password}'[Password to use for connection]:password'
    {-P,--port}'[Port number for connection]:port_num'
    {-q,--quiet}'[Be silent except for errors]'
    '--record_log_pos[Record slave and master status in specified table]:db.table'
    '--regexp[Copy databases that match the regular expression]:pattern'
    '--resetmaster[Reset the binary log after locking all tables]'
    '--resetslave[Reset slave after locking all tables]'
    {-S,--socket}'[Socket file for connection]:path:_files'
    '--suffix[Suffix for names of copied databases]:suffix'
    '--tmpdir[Temporary directory for temporary files]:dir:_directories'
    {-u,--user}'[User name for login]:user_name'
    '*:filename:_files'
)
_arguments -s $arguments
