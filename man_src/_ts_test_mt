#compdef ts_test_mt

local arguments

arguments=(
    {-r,--rotate}'[rotate the screen]:value'
    {-v,--verbose}'[print the input sample values to the console]'
    {-j,--slots}'[override the number of concurrent touch contacts to allocate]:slots'
    {-i,--idev}'[explicitly choose the input event device]:device:_files'
    {-n,--samples}'[automatically exit after having read n samples]:n'
    {-a,--altcross}'[show an alternative crosshair symbol at the touch points]'
    '*:filename:_files'
)
_arguments -s $arguments
