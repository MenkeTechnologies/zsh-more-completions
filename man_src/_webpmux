#compdef webpmux
# Documentation: https://man.archlinux.org/search?q=webpmux
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--loop[Loop the frames n number of times]:n'
    '--bgcolor[Background color of the canvas]:ARGB'
    '--duration[Set the duration for the whole animation]:duration'
    '*:filename:_files'
)
_arguments -s $arguments
