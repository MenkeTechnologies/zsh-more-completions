#compdef fisql

local arguments

arguments=(
    '-a[The client charset name]:charset'
    '-A[Set protocol packet size]:size'
    '-c[Command terminator, defaults to "go"]:terminator'
    '-D[Database name on the server to use]:database'
    '-e[Echo SQL input]'
    '-E[Specify an editor to invoke]:editor'
    '-F[FIPS mode ON]'
    '-g[Display a brief help message]'
    '-h[Number of rows after which to repeat column headers]:rows'
    '-H[Hostname of the client machine]:hostname'
    '-I[Name of the interfaces file to use]:file:_files'
    '-i[Name of script file containing SQL]:file:_files'
    '-J[Client character set (not implemented)]'
    '-l[How long to wait for a login attempt]:seconds'
    '-m[Minimum severity level to print only the message number]:level'
    '-n[Suppress line numbers in echoed output]'
    '-o[Name of output file]:file:_files'
    '-p[Print performance statistics]'
    '-P[Database server password]:password'
    '-s[Column separator]:separator'
    '-S[Database server to connect to]:server'
    '-t[Query timeout in seconds]:seconds'
    '-U[Database server login name]:username'
    '-v[Display version and copyright]'
    '-w[How many characters wide to print the output]:width'
    '-X[Use encrypted login]'
    '-y[Set the SYBASE environment variable]:path'
    '-Y[Use chained transactions]'
    '-z[Language for prompts and messages]:language'
    '*:filename:_files'
)
_arguments -s $arguments
