#compdef FileCheck-10

local arguments

arguments=(
    '--color[Use colors in output (default=autodetect)]'
    '--allow-deprecated-dag-overlap[Enable overlapping among matches in consecutive CHECK-DAG directives]'
    '--allow-empty[Allow the input file to be empty]'
    '--check-prefix[Prefix to use from check file (defaults to CHECK)]:prefix'
    '--check-prefixes[Comma-separated list of check prefixes]:prefixes'
    '--dump-input[Dump input to stderr with annotations]:mode'
    '--dump-input-on-failure[Dump original input to stderr before failing]'
    '--enable-var-scope[Enable scope for regex variables]'
    '--ignore-case[Use case-insensitive matching]'
    '--implicit-check-not[Add an implicit negative check with this pattern]:pattern'
    '--input-file[File to check (defaults to stdin)]:file:_files'
    '--match-full-lines[Require all positive matches to cover an entire input line]'
    '--strict-whitespace[Do not treat all horizontal whitespace as equivalent]'
    '-v[Print directive pattern matches]'
    '--vv[Print information helpful in diagnosing internal FileCheck issues]'
    '--help[Display available options]'
    '--help-list[Display list of available options]'
    '--version[Display the version of this program]'
    '*:filename:_files'
)

_arguments -s $arguments
