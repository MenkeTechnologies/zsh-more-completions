#compdef ctfconvert

local arguments

arguments=(
    '-l[Set the label]:label'
    '-L[Read the label from the specified environment variable]:env var'
    '-g[Do not delete the original debugging section]'
    '-i[Ignore object files built from other languages than C]'
    '-s[Use the .dynsym ELF section instead of .symtab]'
    '-o[Write the output to the specified file]:file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
