#compdef ifstatus
# Documentation: https://man.archlinux.org/search?q=ifstatus
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-a,--auto}'[Enable interface automatically]'
    {-q,--quiet}'[Quiet behaviour]'
    {-v,--verbose}'[Enable verbosity]'
    {-h,--help}'[Show this help]'
    {-V,--version}'[Show version number]'
    '*:filename:_files'
)
_arguments -s $arguments
