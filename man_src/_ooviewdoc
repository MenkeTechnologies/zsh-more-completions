#compdef ooviewdoc

local arguments

arguments=(
    '--accept[Specify a UNO connect-string to create a UNO acceptor]:accept-string'
    '--base[Start the wizard for a new Base document]'
    '--calc[Start with a new Calc document]'
    '--convert-to[Batch convert files to the given format]:format'
    '--outdir[Specify output directory for batch conversion]:directory:_directories'
    '--display[Specify the X server to use]:display'
    '--draw[Start with a new Draw document]'
    '--global[Start with a new Global document]'
    '--headless[Start in headless mode without user interface]'
    {--help,-h,-\?}'[List LibreOffice command line parameters]'
    '--impress[Start with a new Impress document]'
    '--invisible[Start in invisible mode]'
    '--infilter[Force an input filter type if possible]:filter'
    '--math[Start with a new Math document]'
    '--minimized[Keep the splash screen minimized]'
    '-n[Create a new document from the given template]:template:_files'
    '--nodefault[Start without creating a new document]'
    '--nolockcheck[Disable the check for remote instances using the installation]'
    '--nologo[Disable the splash screen at program start]'
    '--norestore[Disable restart and file recovery after a system crash]'
    '--nosplash[Disable the splash screen at program start]'
    '-o[Open the given files for editing, even templates]:file:_files'
    '-p[Print the given files to the default printer and exit]:file:_files'
    '--print-to-file[Batch print files to file]'
    '--printer-name[Specify printer name for batch printing]:printer'
    '--pt[Print the given files to the specified printer and exit]:printer'
    '--quickstart[Start with the quick starter]'
    '--show[Open Impress files, start presentation and quit after]:file:_files'
    '--unaccept[Close an acceptor created with --accept]:accept-string'
    '--terminate_after_init[Start and terminate after registering UNO services]'
    '--view[Open the given files read-only]:file:_files'
    '--web[Start with a new HTML document]'
    '--writer[Start with a new Writer document]'
    '*:filename:_files'
)
_arguments -s $arguments
