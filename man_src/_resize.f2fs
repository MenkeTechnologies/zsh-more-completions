#compdef resize.f2fs

# Autogenerated from man page
# Updated with latest resize.f2fs options

local arguments

arguments=(
    '-t[specify the size in sectors]:sectors'
    '-d[specify the level of debugging options]:debug-level'
    '-o[specify the percentage of the volume for overprovision area]:overprovision-ratio-percentage'
    '-i[enable extended node bitmap]'
    '-s[enable safe resize]'
    '-V[print the version number and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
