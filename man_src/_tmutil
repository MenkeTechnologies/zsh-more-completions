#compdef tmutil

local arguments

arguments=(
    '--auto[run the backup in a mode similar to system-scheduled backups]'
    '--block[wait until the backup is finished before exiting]'
    '--rotation[allow automatic destination rotation during the backup]'
    '--destination[perform the backup to the destination corresponding to the specified ID]:id'
    '-a[compare all supported metadata]'
    '-n[no metadata comparison]'
    '-@[compare extended attributes]'
    '-c[compare creation times]'
    '-d[compare file data forks]'
    '-e[compare ACLs]'
    '-f[compare file flags]'
    '-g[compare GIDs]'
    '-m[compare file modes]'
    '-s[compare sizes]'
    '-t[compare modification times]'
    '-u[compare UIDs]'
    '-D[limit traversal depth to depth levels]:depth'
    '-E[do not take exclusions into account when comparing items]'
    '-I[ignore paths with a path component equal to name]:name'
    '-U[ignore logical volume identity when comparing]'
    '-X[print output in XML property list format]'
    '*:filename:_files'
)
_arguments -s $arguments
