#compdef zypper-log
# Documentation: https://man.archlinux.org/search?q=zypper-log
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--help[Display help]'
    '--version[Display version]'
    '-d[Set date range for the log]:date'
    '-n[Limit the number of entries]:count'
    '*:filename:_files'
)
_arguments -s $arguments
