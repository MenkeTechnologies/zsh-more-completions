#compdef hccontrol
# Documentation: https://man.archlinux.org/search?q=hccontrol
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-h[Display usage message and exit]'
    '-N[Show Bluetooth addresses as numbers]'
    '-n[Connect to the specified HCI Netgraph node]:node'
    '*:filename:_files'
)
_arguments -s $arguments
