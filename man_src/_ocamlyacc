local arguments

arguments=(
    '-b[Name the output files prefix.ml, prefix.mli, prefix.output]:prefix'
    '-q[This option has no effect]'
    '--strict[Reject grammars with conflicts]'
    '-v[Generate a description of the parsing tables and a report on conflicts]'
    '--version[Print version string and exit]'
    '--vnum[Print short version number and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
