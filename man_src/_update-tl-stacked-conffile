#compdef update-tl-stacked-conffile
# Documentation: https://man.archlinux.org/search?q=update-tl-stacked-conffile
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--check[Execute additional checks that all necessary files are present]'
    '--quiet[Do not write anything to standard output during normal operation]'
    '--help[Print a summary of the command-line usage and exit]'
    '--version[Output version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
