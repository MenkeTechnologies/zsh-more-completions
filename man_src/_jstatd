#compdef jstatd

local arguments

arguments=(
    '-nr[Do not attempt to create an internal RMI registry within the jstatd process]'
    '-p[Port number where the RMI registry is expected to be found]:port'
    '-n[Name to which the remote RMI object is bound in the RMI registry]:rminame'
    '-J[Pass option to the Java launcher]:option'
    '*:filename:_files'
)
_arguments -s $arguments
