#compdef kprop

local arguments

arguments=(
    '-r[Specify the realm of the master server]:realm'
    '-f[Specify the filename where the dumped principal database file is found]:file:_files'
    '-P[Specify the port to use to contact the kpropd server]:port'
    '-d[Print debugging information]'
    '-s[Specify the location of the keytab file]:keytab:_files'
    '*:filename:_files'
)
_arguments -s $arguments
