#compdef kunittestmodrunner

local arguments

arguments=(
    '--query[Only run modules whose filenames match the regexp]:regexp'
    '--folder[Only run tests modules found in the folder]:folder:_directories'
    '--help[Show help about options]'
    '--help-qt[Show Qt specific options]'
    '--help-kde[Show KDE specific options]'
    '--help-all[Show all options]'
    '--author[Show author information]'
    {-v,--version}'[Show version information]'
    '--license[Show license information]'
    '--enable-dbgcap[Disable debug capturing for GUI mode]'
    '*:filename:_files'
)
_arguments -s $arguments
