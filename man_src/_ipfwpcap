#compdef ipfwpcap
# Documentation: https://man.archlinux.org/search?q=ipfwpcap
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-d[Turn on extra debugging messages]'
    '-r[Write packets back to the divert socket]'
    '-b[Stop dumping after maxbytes bytes]:maxbytes'
    '-p[Stop dumping after maxpkt packets]:maxpkt'
    '-P[File to store PID number in]:pidfile:_files'
    '*:filename:_files'
)
_arguments -s $arguments
