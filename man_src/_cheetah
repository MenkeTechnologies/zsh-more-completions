#compdef cheetah

local arguments

arguments=(
    '--idir[Input directories]:directory:_directories'
    '--odir[Output directories]:directory:_directories'
    '--iext[Input extension]:extension'
    '--oext[Output extension]:extension'
    '-R[Recurse subdirectories looking for input files]'
    '--debug[Print lots of diagnostic output to standard error]'
    '--env[Print the environment in the searchList]'
    '--flat[No destination subdirectories]'
    '--nobackup[Do not make backups]'
    '--pickle[Unpickle FILE and put that output in the searchList]:file:_files'
    {--stdout,-p}'[Output to standard output]'
    '*:filename:_files'
)
_arguments -s $arguments
