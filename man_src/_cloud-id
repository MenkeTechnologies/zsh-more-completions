#compdef cloud-id
# Documentation: https://man.archlinux.org/search?q=cloud-id
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-h,--help}'[Show help message and exit]'
    {-j,--json}'[Report all standardized cloud-id information as JSON]'
    {-l,--long}'[Report extended cloud-id information as tab-delimited string]'
    {-i,--instance-data}'[Path to instance-data.json file]:file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
