#compdef telnetd
# Documentation: https://man.archlinux.org/search?q=telnetd
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-D,--debug}'[set debugging level]:level'
    {-E,--exec-login}'[set program to be executed instead of /usr/bin/login]:program:_files'
    {-h,--no-hostinfo}'[do not print host information before login has been completed]'
    {-l,--linemode}'[set line mode]:mode'
    {-n,--no-keepalive}'[disable TCP keep-alives]'
    {-U,--reverse-lookup}'[refuse connections from addresses that cannot be mapped back]'
    {-\?,--help}'[give this help list]'
    '--usage[give a short usage message]'
    {-V,--version}'[print program version]'
    '*:filename:_files'
)
_arguments -s $arguments
