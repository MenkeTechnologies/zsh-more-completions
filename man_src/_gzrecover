#compdef gzrecover
# Documentation: https://man.archlinux.org/search?q=gzrecover
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-o[Write output to the specified file]:file:_files'
    '-s[Skip to the specified offset before starting recovery]:offset'
    '-p[Split output into separate files]'
    '-v[Verbose mode]'
    '-h[Print help]'
    '*:filename:_files'
)
_arguments -s $arguments
