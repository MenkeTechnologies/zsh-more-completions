#compdef scrontab
# Documentation: https://man.archlinux.org/search?q=scrontab
# Reference accessed: 2026-05-16

# Updated with fixes for missing descriptions

local arguments

arguments=(
    '-e[Edit user crontab (default action if stdin is a TTY)]'
    '-l[List user crontab]'
    '-r[Delete user crontab]'
    '-u[User to edit crontab for]:user'
    '*:filename:_files'
)
_arguments -s $arguments
