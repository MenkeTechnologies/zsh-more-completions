#compdef ctanify

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Output basic usage information and exit]'
    {-V,--version}'[Output version number and exit]'
    {-p,--pkgname}'[Specify explicitly a package name]:name'
    '--noauto[Do not automatically add files to the tarball]'
    '*:filename:_files'
)
_arguments -s $arguments
