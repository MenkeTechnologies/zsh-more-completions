#compdef getextattr

local arguments

arguments=(
    '-f[Force output even if attribute is not defined]'
    '-h[Do not follow symbolic links]'
    '-i[Read attribute data from stdin instead of as an argument]'
    '-n[NUL-terminate the extent content written out]'
    '-q[Quiet mode, do not print pathname and suppress error messages]'
    '-s[Escape nonprinting characters and put quotes around output]'
    '-x[Print the output in hexadecimal]'
    '*:filename:_files'
)
_arguments -s $arguments
