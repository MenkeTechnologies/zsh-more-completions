#compdef vidcontrol

local arguments

arguments=(
    '-b[Set border color]:color'
    '-C[Clear the history buffer]'
    '-c[Change the cursor appearance]:appearance'
    '-d[Print out current output screen map]'
    '-g[Set the geometry of the text mode]:geometry'
    '-h[Set the size of the history buffer]:lines'
    '-i[Show the active vty number]'
    '-l[Install screen output map file]:screen_map:_files'
    '-L[Install default screen output map]'
    '-M[Set base character used to render the mouse pointer]:char'
    '-m[Switch the mouse pointer on or off]:state:(on off)'
    '-p[Capture current video buffer contents]'
    '-P[Capture video buffer contents in plain text format]'
    '-H[Dump full history buffer]'
    '-r[Change reverse mode colors]:foreground background'
    '-S[Turn vty switching on or off]:state:(on off)'
    '-s[Set the active vty]:number'
    '-T[Switch terminal emulation style]:style:(xterm cons25)'
    '-t[Set the screensaver timeout in seconds]:seconds'
    '-x[Use hexadecimal digits for output]'
    '*:filename:_files'
)
_arguments -s $arguments
