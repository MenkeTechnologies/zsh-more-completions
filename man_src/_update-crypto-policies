#compdef update-crypto-policies
# Documentation: https://man.archlinux.org/search?q=update-crypto-policies
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '--show[Show the currently applied crypto policy]'
    '--is-applied[Check whether the currently configured policy is applied]'
    '--set[Set the policy to the specified value]:policy'
    '--no-check[Do not check the generated config files for errors]'
    '--no-reload[Do not reload the running daemons after policy change]'
    '*:filename:_files'
)
_arguments -s $arguments
