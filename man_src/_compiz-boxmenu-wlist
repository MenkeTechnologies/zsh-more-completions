#compdef compiz-boxmenu-wlist

local arguments

arguments=(
    '-h[Show help options]'
    {-i,--images}'[Use images in the window list]'
    {-m,--minimized}'[Show only minimized windows in the window list]'
    {-c,--current-viewport}'[Show only windows in current viewport]'
    '*:filename:_files'
)
_arguments -s $arguments
