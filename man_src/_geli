#compdef geli

local arguments

arguments=(
    '-a[Enable data integrity verification using the given algorithm]:algorithm'
    '-b[Try to decrypt this partition during boot]'
    '-B[File name to use for metadata backup]:file:_files'
    '-d[Echo dots instead of nothing when entering the passphrase]'
    '-e[Encryption algorithm to use]:algorithm'
    '-g[Enable booting from this encrypted root filesystem]'
    '-i[Number of iterations for PKCS#5v2 key derivation]:iterations'
    '-J[File containing the passphrase component of the User Key]:file:_files'
    '-K[File containing the keyfile component of the User Key]:file:_files'
    '-l[Data Key length to use with the given algorithm]:keylength'
    '-P[Do not use a passphrase as a component of the User Key]'
    '-s[Change decrypted provider sector size]:sectorsize'
    '-T[Do not pass through BIO_DELETE calls (TRIM/UNMAP)]'
    '-v[Be verbose]'
    '*:filename:_files'
)
_arguments -s $arguments
