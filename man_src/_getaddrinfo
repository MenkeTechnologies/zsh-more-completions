#compdef getaddrinfo

local arguments

arguments=(
    '-c[Look up a canonical name]'
    '-f[Specify an address family]:family'
    '-N[Treat the service as numeric, do not attempt name resolution]'
    '-n[Treat the hostname as a numeric address, do not attempt resolution]'
    '-P[Return socket addresses intended for use with bind]'
    '-p[Specify a protocol]:protocol'
    '-s[Specify a service to look up]:service'
    '-t[Specify a socket type]:type'
    '*:filename:_files'
)
_arguments -s $arguments
