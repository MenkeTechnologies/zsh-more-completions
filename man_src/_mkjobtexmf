#compdef mkjobtexmf

local arguments

arguments=(
    '--jobname[Name of the job]:jobname'
    '--texname[Name of the TeX input file, if it differs from jobname.tex]:name'
    '--texopt[Additional option for the TeX compiler]:opt'
    '--destdir[Name of the destination directory where the result is collected]:directory:_directories'
    '--output[Also add output files]'
    '--strace[Use method with program strace]'
    '--copy[Files are copied instead of creating symbolic links]'
    '--flat[Files are linked or copied without path elements]'
    '--exclude-ext[Files with specified extension are excluded]:ext'
    '--cmd-tex[Command for the TeX compiler (default: pdflatex)]:cmd'
    '--cmd-kpsewhich[Command for kpsewhich]:cmd'
    '--cmd-texhash[Command for updating the file name database]:cmd'
    '--cmd-strace[Command for strace]:cmd'
    '--verbose[Verbose messages]'
    '--help[Display help screen]'
    '*:filename:_files'
)
_arguments -s $arguments
