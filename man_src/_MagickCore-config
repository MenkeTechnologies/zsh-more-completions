#compdef MagickCore-config

local arguments

arguments=(
    '--cppflags[Print the compiler flags needed to find the ImageMagick C include files]'
    '--prefix[Print the directory under which the package is installed]'
    '--exec-prefix[Print the directory under which target specific binaries and executables are installed]'
    '--ldflags[Print the linker flags needed to link with the ImageMagick library]'
    '--libs[Print the linker flags needed to link a program with libMagickCore]'
    '--version[Print the version of the ImageMagick distribution]'
    '--coder-path[Print the path where the ImageMagick coder modules are installed]'
    '--filter-path[Print the path where the ImageMagick filter modules are installed]'
    '*:filename:_files'
)
_arguments -s $arguments
