#compdef x0vncserver

local arguments

arguments=(
    '--display[X display to serve]:display'
    '--rfbport[TCP port to listen for VNC connections]:port'
    '--SecurityTypes[Specify which security schemes to use]:types'
    '--passwd[Password file for VNC authentication]:file:_files'
    '--Log[Configure debug log settings]:logname\:dest\:level'
    '*:filename:_files'
)
_arguments -s $arguments
