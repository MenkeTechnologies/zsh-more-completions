#compdef iscsiadm

local arguments

arguments=(
    {-a,--ip}'[IP address (IPv4 or IPv6), valid for ping submode]:ipaddr:_hosts'
    {-A,--portal_type}'[Specify the portal type for the new flash node entry]:type:(ipv4 ipv6)'
    {-b,--packetsize}'[Specify the ping packet size]:packetsize'
    {-c,--count}'[Specify number of ping iterations]:count'
    {-C,--submode}'[Specify the submode for mode]:op'
    {-d,--debug}'[Print debugging information]:debug_level'
    '(- * :)'{-h,--help}'[Display help text and exit]'
    {-H,--host}'[Specify the SCSI host to use for the operation]:hostno'
    {-i,--interval}'[Specify delay between two ping iterations]:interval'
    {-I,--interface}'[Specify the iSCSI interface to use for the operation]:iface'
    {-k,--killiscsid}'[Kill iscsid process]:priority'
    {-D,--discover}'[Discover targets using the discovery record with the specified recid]'
    {-l,--login}'[Login to a specified record]'
    {-L,--loginall}'[Login all sessions with the node or conn startup values]:mode:(all manual automatic)'
    {-m,--mode}'[Specify the mode]:op:(discovery node session host iface fw)'
    {-n,--name}'[Specify a field name in a record]:name'
    {-o,--op}'[Specify a database operator]:op:(new delete update show nonpersistent)'
    {-p,--portal}'[Use target portal with ip-address and port]:ip\:port:_hosts'
    {-P,--print}'[Print nodes in tree format]:level'
    {-T,--targetname}'[Use target targetname]:targetname'
    {-r,--sid}'[Use session ID]:sid'
    {-R,--rescan}'[Rescan the session]'
    {-s,--stats}'[Display session statistics]'
    {-S,--show}'[Do not hide masked values when displaying records]'
    {-t,--type}'[Discovery type]:type:(sendtargets slp isns fw)'
    {-u,--logout}'[Logout for a specified record]'
    {-U,--logoutall}'[Logout all sessions]:mode:(all manual automatic)'
    {-v,--value}'[Specify a value for use with the update operator]:value'
    {-V,--version}'[Display version and exit]'
    {-x,--index}'[Specify the index of the entity to operate on]:index'
    '*:filename:_files'
)
_arguments -s $arguments
