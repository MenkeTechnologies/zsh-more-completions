#compdef tpm2_getpubak

local arguments

arguments=(
    '-e[current endorsement password]:password'
    '-P[AK password when created]:password'
    '-o[current owner password]:password'
    '-E[handle used to make EK persistent]:handle'
    '-k[handle used to make AK persistent]:handle'
    '-g[algorithm type of AK]:algorithm'
    '-f[file to save the public portion of AK]:file:_files'
    '-n[file to save the AK name]:file:_files'
    '-h[display help information]'
    '-v[display version, supported tctis and exit]'
    '-V[increase verbosity of tool output]'
    '-Q[suppress informational output]'
    '-Z[enable errata fixups]'
    '-T[select the TCTI used for communication]:tcti'
    '*:filename:_files'
)
_arguments -s $arguments
