#compdef tpm2_getekcertificate

local arguments

arguments=(
    {-o,--ek-certificate}'[file to save the endorsement key certificate]:file:_files'
    {-X,--allow-unverified}'[allow connecting with unverified TPM manufacturer server]'
    {-u,--ek-public}'[file path for the endorsement key public portion]:file:_files'
    {-x,--offline}'[operate in offline mode]'
    {-E,--encoding}'[specify the encoding format]:encoding:(pem der)'
    {-h,--help}'[display help information]'
    {-v,--version}'[display version, supported tctis and exit]'
    {-V,--verbose}'[increase verbosity of tool output]'
    {-Q,--quiet}'[suppress informational output]'
    {-Z,--enable-errata}'[enable errata fixups]'
    {-R,--autoflush}'[autoflush objects created by the command]'
    '*:filename:_files'
)
_arguments -s $arguments
