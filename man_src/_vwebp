#compdef vwebp

local arguments

arguments=(
    '-h[Print usage summary]'
    '--version[Print version number and exit]'
    '--noicc[Do not use the ICC profile if present]'
    '--nofancy[Do not use the fancy YUV420 upscaler]'
    '--nofilter[Disable in-loop filtering]'
    '--dither[Specify a dithering strength between 0 and 100]:strength'
    '--noalphadither[Disable dithering of quantized transparency planes]'
    '--usebgcolor[Fill transparent areas with the background color from the bitstream]'
    '--mt[Use multi-threading for decoding, if possible]'
    '--info[Display image information on top of the decoded image]'
    '*:filename:_files'
)
_arguments -s $arguments
