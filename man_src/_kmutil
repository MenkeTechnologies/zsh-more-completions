#compdef kmutil

local arguments

arguments=(
    '-n[Specify one or more of boot, sys, or aux to build collections]:collection:(boot sys aux)'
    '-s[Specify none, all, or allkexts to strip symbol information]:strip:(none all allkexts)'
    '-k[When building the boot kext collection, specify the path to the kernel]:kernel:_files'
    '-x[Only consider explicitly specified bundle identifiers and paths]'
    '-p[If the extension is not already in the auxiliary collection, add and load it]'
    '-P[Send the named personality to the catalog]:personality_name'
    '-e[Do not use the default repositories for kexts]'
    '-c[Terminate all instances of the IOService class]:class_name'
    '-Z[Do not resolve kext dependencies]'
    '-D[Recursively diagnose all kext dependencies]'
    '-C[Compress the custom boot object]'
    '-v[Install the custom boot object for the specified volume]:volume:_directories'
    '-a[Specify the architecture to use]:arch'
    '-V[Specify a variant suffix]:variant'
    '-z[Disable staging and validation of extensions]'
    '-r[Paths to directories containing extensions]:repository:_directories'
    '-R[Specify the target volume to operate on]:volume_root:_directories'
    '-b[Search for and/or include this identifier in the results]:bundle_identifier'
    '-f[Specify a filter in predicate syntax]:filter'
    '-F[Specify a filter that must match all properties]:filter'
    '-B[The path to the boot kext collection]:boot_path:_files'
    '-S[The path to the system kext collection]:system_path:_files'
    '-A[The path to the auxiliary kext collection]:aux_path:_files'
    '-M[Recover gracefully if a collection is missing]'
    '*:filename:_files'
)
_arguments -s $arguments
