#compdef dbus-daemon

local arguments

arguments=(
    '--config-file[Use the given configuration file]:file:_files'
    '--fork[Force the message bus to fork and become a daemon]'
    '--nofork[Force the message bus not to fork]'
    '--print-address[Print the address of the message bus to stdout or to a file descriptor]:descriptor'
    '--print-pid[Print the process ID of the message bus to stdout or to a file descriptor]:descriptor'
    '--session[Use the standard configuration for the per-login-session message bus]'
    '--system[Use the standard configuration for the systemwide message bus]'
    '--version[Print the version of the daemon]'
    '--introspect[Print the introspection information for all D-Bus internal interfaces]'
    '--address[Set the address to listen on]:address'
    '--systemd-activation[Enable systemd-style service activation]'
    '--nopidfile[Do not write a PID file even if one is configured]'
    '--syslog[Force the message bus to use the system log for messages]'
    '--syslog-only[Force the message bus to use only the system log for messages]'
    '--nosyslog[Force the message bus to use only standard error for messages]'
    '*:filename:_files'
)
_arguments -s $arguments
