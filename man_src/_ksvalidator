#compdef ksvalidator
# Documentation: https://man.archlinux.org/search?q=ksvalidator
# Reference accessed: 2026-05-16

local arguments

arguments=(
    {-e,--firsterror}'[Halt after the first error or warning]'
    {-i,--followincludes}'[Parse include files when %include is seen]'
    {-l,--listversions}'[List the available versions of kickstart syntax]'
    {-v,--version}'[Version of kickstart syntax to validate against]:version'
    {-h,--help}'[Show help message and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
