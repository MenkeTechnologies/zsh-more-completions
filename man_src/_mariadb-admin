#compdef mariadb-admin mysqladmin

local arguments

arguments=(
    {-\?,--help}'[Display help and exit]'
    '--character-sets-dir[Directory for character set files]:path:_directories'
    {-C,--compress}'[Compress all information sent between the client and the server]'
    '--connect-timeout[Connection timeout in seconds]:timeout'
    {-c,--count}'[Number of iterations to make]:N'
    '--sleep[Delay between iterations when using count]:seconds'
    {-\#,--debug}'[Write debugging log]:debug_options'
    '--debug-check[Check memory and open file usage at exit]'
    '--debug-info[Print debugging information and memory and CPU usage statistics when exiting]'
    '--default-auth[Default authentication client-side plugin to use]'
    '--default-character-set[Set the default character set]:charset_name'
    '--defaults-extra-file[Read this option file after the global option file]:filename:_files'
    '--defaults-file[Use only the given option file]:filename:_files'
    {-f,--force}'[Do not ask for confirmation for the drop database command]'
    {-h,--host}'[Connect to the specified host]:host_name:_hosts'
    {-l,--local}'[Suppress the SQL command(s) from being written to the binary log]'
    {-b,--no-beep}'[Do not beep when an error occurs]'
    '--no-defaults[Do not read any option files]'
    {-p,--password}'[Password to use when connecting to server]:password'
    {-W,--pipe}'[On Windows, connect to the server using a named pipe]'
    {-P,--port}'[TCP/IP port number for connection]:port_num'
    '--print-defaults[Print the program argument list and exit]'
    '--protocol[Connection protocol to use]:protocol:(TCP SOCKET PIPE MEMORY)'
    {-r,--relative}'[Show the difference between the current and previous values]'
    '--shutdown-timeout[Maximum number of seconds to wait for server shutdown]:timeout'
    {-s,--silent}'[Exit silently if a connection cannot be established]'
    {-i,--sleep}'[Execute commands repeatedly, sleeping for delay seconds in between]:delay'
    {-S,--socket}'[For localhost connections, the Unix socket file to use]:path:_files'
    '--ssl[Enable SSL for connection]'
    '--ssl-ca[CA file in PEM format]:name:_files'
    '--ssl-capath[CA directory]:name:_directories'
    '--ssl-cert[X509 cert in PEM format]:name:_files'
    '--ssl-cipher[SSL cipher to use]:name'
    '--ssl-key[X509 key in PEM format]:name:_files'
    '--ssl-crl[Certificate revocation list]:name:_files'
    '--ssl-crlpath[Certificate revocation list path]:name:_directories'
    '--ssl-verify-server-cert[Verify server certificate Common Name value against host name]'
    '--tls-version[TLS protocol version for secure connection]:name'
    {-u,--user}'[User name for login]:user_name'
    {-v,--verbose}'[Write more information]'
    {-V,--version}'[Display version information and exit]'
    {-E,--vertical}'[Print output vertically]'
    {-w,--wait}'[If the connection cannot be established, wait and retry]:count'
    '--wait-for-all-slaves[Wait for the last binlog event to be sent to all connected slaves]'
    '*:filename:_files'
)
_arguments -s $arguments
