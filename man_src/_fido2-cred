#compdef fido2-cred

local arguments

arguments=(
    '-M[Make a new credential on device]'
    '-V[Verify a credential]'
    '-b[Request the credential largeBlobKey]'
    '-c[Set the credential protection level]:cred_protect'
    '-d[Emit debugging output on stderr]'
    '-h[Enable the FIDO2 hmac-secret extension when making a credential]'
    '-i[Read the parameters of the credential from input_file instead of stdin]:input_file:_files'
    '-o[Write output on output_file instead of stdout]:output_file:_files'
    '-q[Be quiet]'
    '-r[Create a resident credential]'
    '-u[Create a U2F credential]'
    '-v[Request user verification when making a credential]'
    '*:filename:_files'
)
_arguments -s $arguments
