#compdef pagestuff
# Documentation: https://man.archlinux.org/search?q=pagestuff
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-arch[Specify the architecture of the file to operate on]:arch_type'
    '-a[Display all pages, all other arguments are ignored]'
    '-p[Print a list of sections of the Mach-O file with offsets and lengths]'
    '*:filename:_files'
)
_arguments -s $arguments
