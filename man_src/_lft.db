#compdef lft.db

local arguments

arguments=(
    '--help[Print help info and exit]'
    {-4,-6}'[Explicitly force IPv4 or IPv6 tracerouting]'
    {-I,--icmp}'[Use ICMP ECHO for probes]'
    {-T,--tcp}'[Use TCP SYN for probes]'
    {-d,--debug}'[Enable socket level debugging]'
    {-F,--dont-fragment}'[Do not fragment probe packets]'
    {-f,--first}'[Specify the starting TTL]:ttl'
    {-g,--gateway}'[Add an IP source routing option to the outgoing packet]:gateway'
    {-i,--interface}'[Specify the interface through which to send packets]:interface'
    {-m,--max-hops}'[Specify the maximum number of hops]:max_ttl'
    {-N,--sim-queries}'[Specify the number of probe packets sent out simultaneously]:num'
    '-n[Do not try to map IP addresses to host names]'
    {-p,--port}'[Specify the destination port base]:port'
    {-t,--tos}'[Set the Type of Service and Precedence value]:tos'
    {-l,--flowlabel}'[Use specified flow_label for IPv6 packets]:flow_label'
    {-w,--wait}'[Determine how long to wait for a response to a probe]:waittime'
    {-q,--queries}'[Set the number of probe packets per hop]:nqueries'
    '-r[Bypass the normal routing tables and send directly to a host on an attached network]'
    {-s,--source}'[Choose an alternative source address]:src_addr'
    {-z,--sendwait}'[Minimal time interval between probes]:sendwait'
    {-e,--extensions}'[Show ICMP extensions (rfc4884)]'
    {-A,--as-path-lookups}'[Perform AS path lookups in routing registries and print results]'
    {-V,--version}'[Print the version and exit]'
    '--sport[Choose the source port to use]:port'
    '--fwmark[Set the firewall mark for outgoing packets]:mark'
    {-M,--module}'[Use specified method for traceroute operations]:method'
    {-O,--options}'[Specify some method-specific option]:options'
    {-U,--udp}'[Use UDP to particular destination port for tracerouting]:port'
    '--UL[Use UDPLITE for tracerouting]'
    {-D,--dccp}'[Use DCCP Requests for probes]'
    {-P,--protocol}'[Use raw packet of specified protocol for tracerouting]:protocol'
    '--mtu[Discover MTU along the path being traced]'
    '--back[Print the number of backward hops when different from the forward direction]'
    '*:filename:_files'
)
_arguments -s $arguments
