#compdef otp-md5

local arguments

arguments=(
    '-v[Display the version number and compile-time options, then exit]'
    '-h[Display a brief help message and exit]'
    '-4[Select MD4 as the response generation algorithm]'
    '-5[Select MD5 as the response generation algorithm]'
    '-f[Force opiekey to continue even where it normally would not]'
    '-a[Allow input of an arbitrary secret pass phrase]'
    '-n[Number of one-time access passwords to print]:count'
    '-x[Output the OTPs as hexadecimal numbers instead of six words]'
    '-t[Generate an extended response of the specified type]:type'
    '*:filename:_files'
)
_arguments -s $arguments
