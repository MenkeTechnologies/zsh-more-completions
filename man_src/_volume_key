#compdef volume_key

local arguments

arguments=(
    '--save[Save volume encryption keys]'
    '--restore[Restore volume encryption keys]'
    '--setup-volume[Set up a volume using keys from a packet]'
    '--reencrypt[Re-encrypt a packet]'
    '--dump[Dump a packet]'
    '--secrets[Dump packet secrets]'
    '--help[Show usage information]'
    '--version[Show version of volume_key]'
    {-b,--batch}'[Run in batch mode]'
    {-d,--nss-dir}'[Use private keys in NSS database in directory]:directory:_directories'
    {-o,--output}'[Write the default secret to packet]:packet:_files'
    '--output-data-encryption-key[Write the data encryption key to packet]:packet:_files'
    '--output-passphrase[Write a passphrase that can be used to access the volume]:packet:_files'
    '--create-random-passphrase[Generate a random alphanumeric passphrase]:packet:_files'
    {-c,--certificate}'[Load a certificate from file and encrypt all output packets]:cert:_files'
    '--output-format[Use format for all output packets]:format'
    '--unencrypted[Only dump the unencrypted parts of the packet]'
    '--with-secrets[Include secrets in the output of --dump]'
    '*:filename:_files'
)
_arguments -s $arguments
