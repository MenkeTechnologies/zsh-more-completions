#compdef figlet-figlet

local arguments

arguments=(
    '-f[Select the font]:fontfile'
    '-d[Change the default font directory]:fontdirectory:_directories'
    '-c[Center-justify output]'
    '-l[Left-justify output]'
    '-r[Right-justify output]'
    '-x[Use default justification of the font]'
    '-w[Set the output width]:outputwidth'
    '-n[Normal smush mode (default)]'
    '-s[Smushed mode]'
    '-S[Force smushing]'
    '-k[Kerning mode]'
    '-W[Full-width character spacing]'
    '-o[Overlap mode]'
    '-m[Specify an explicit layout mode between -1 and 63]:layoutmode'
    '-t[Set output width to terminal width]'
    '-p[Put FIGlet into paragraph mode]'
    '-D[Switch to the German character set]'
    '-E[Switch to the English character set]'
    '-N[Clear any loaded control files]'
    '-C[Load a control file]:controlfile:_files'
    '-L[Left-to-right printing]'
    '-R[Right-to-left printing]'
    '-X[Use default printing direction]'
    '-I[Print information and exit]:infocode'
    '-v[Print version and copyright information]'
    '*:filename:_files'
)
_arguments -s $arguments
