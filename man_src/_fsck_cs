#compdef fsck_cs

local arguments

arguments=(
    '-q[Perform a quick check for corruptions]'
    '-p[Operate in preen mode, repair MLV mirror blocks]'
    '-y[Assume yes as the answer to all questions]'
    '-n[Assume no as the answer to all questions]'
    '-x[Produce output in XML-like (plist) format]'
    '-g[Produce output in GUI-compatible form]'
    '-l[Reproduce all console output plus additional status messages]'
    '--pv[Check the component CoreStorage physical volumes directly]'
    '--uuid[Specify the CoreStorage logical volume group UUID]:uuid'
    '--lv[Specify a CoreStorage logical volume]:device'
    '*:filename:_files'
)
_arguments -s $arguments
