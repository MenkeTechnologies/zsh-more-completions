#compdef sqfstar

# Updated with fixes for descriptions

local arguments

arguments=(
    '-comp[Select compression algorithm]:comp:(gzip lzo lz4 xz zstd)'
    '-b[Set data block size (default 128 Kbytes)]:block_size'
    '-reproducible[Build images that are reproducible (default)]'
    '-not-reproducible[Build images that are not reproducible]'
    '-mkfs-time[Set mkfs time]:time'
    '-all-time[Set all inode times]:time'
    '-exports[Make the filesystem exportable via NFS]'
    '-no-sparse[Do not detect sparse files]'
    '-no-xattrs[Do not store extended attributes]'
    '-xattrs[Store extended attributes (default)]'
    '-noI[Do not compress inode table]'
    '-noId[Do not compress the uid/gid table]'
    '-noD[Do not compress data blocks]'
    '-noF[Do not compress fragment blocks]'
    '-noX[Do not compress extended attributes]'
    '-no-fragments[Do not use fragments]'
    '-no-tailends[Do not pack tail ends into fragments]'
    '-no-duplicates[Do not perform duplicate checking]'
    '-no-hardlinks[Do not hardlink files, store duplicates instead]'
    '-all-root[Make all files owned by root]'
    '-root-time[Set root directory time]:time'
    '-root-mode[Set root directory permissions to octal mode]:mode'
    '-root-uid[Set root directory owner]:uid'
    '-root-gid[Set root directory group]:gid'
    '-force-uid[Set all file uids]:uid'
    '-force-gid[Set all file gids]:gid'
    '-nopad[Do not pad filesystem to a multiple of 4K]'
    '-ef[List of exclude dirs/files, one per line]:file:_files'
    '-regex[Allow POSIX regular expressions in exclude]'
    '-version[Print version, licence and copyright message]'
    '-force[Force write to block device or file]'
    '-exit-on-error[Treat normally ignored errors as fatal]'
    '-quiet[No verbose output]'
    '-info[Print files written to filesystem]'
    '-no-progress[Do not display the progress bar]'
    '-progress[Display progress bar when using the -info option]'
    '-throttle[Throttle the I/O input rate by the given percentage]:percent'
    '-limit[Limit the I/O input rate to the given percentage]:percent'
    '-processors[Use specified number of processors]:number'
    '-mem[Use specified physical memory]:size'
    '-offset[Skip offset bytes at the beginning of destination]:offset'
    '-o[Synonym for -offset]:offset'
    {-help,-h}'[Output options text to stdout]'
    '-Xhelp[Print compressor options for selected compressor]'
    '*:filename:_files'
)
_arguments -s $arguments
