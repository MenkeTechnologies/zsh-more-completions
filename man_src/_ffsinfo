#compdef ffsinfo
# Documentation: https://man.archlinux.org/search?q=ffsinfo
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-g[Path to cylinder group]:cg'
    '-i[Inode number]:inode'
    '-l[Level of detail]:level'
    '-o[Output file]:file:_files'
    '*:filename:_files'
)
_arguments -s $arguments
