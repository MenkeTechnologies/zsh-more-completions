#compdef geany

local arguments

arguments=(
    '--column[Set initial column number for the first opened file]:column'
    {-c,--config}'[Use an alternate configuration directory]:directory:_directories'
    '--ft-names[Print a list of internal filetype names]'
    {-g,--generate-tags}'[Generate a global tags file]:file:_files'
    {-P,--no-preprocessing}'[Do not preprocess C/C++ files when generating tags]'
    {-i,--new-instance}'[Force opening a new instance instead of using a running one]'
    {-l,--line}'[Set initial line number for the first opened file]:line'
    '--list-documents[Return a list of open documents in a running Geany instance]'
    {-m,--no-msgwin}'[Do not show the message window]'
    {-n,--no-ctags}'[Do not load symbol completion and call tip data]'
    {-p,--no-plugins}'[Do not load plugin support]'
    '--print-prefix[Print installation prefix and data directories]'
    {-r,--read-only}'[Open all files given on the command line in read-only mode]'
    {-s,--no-session}'[Do not load the previous session files]'
    {-t,--no-terminal}'[Do not load terminal support]'
    {-v,--verbose}'[Be verbose]'
    {-V,--version}'[Print version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
