#compdef ifrename

local arguments

arguments=(
    '-c[Set the configuration file to be used]:configfile:_files'
    '-p[Probe (load) kernel modules before renaming interfaces]'
    '-d[Enable various Debian specific hacks]'
    '-i[Only rename the specified interface]:interface'
    '-n[When used with -i, specify the new name]:newname'
    '-t[Enable name takeover support]'
    '-u[Enable udev output mode]'
    '-D[Dry-run mode]'
    '-V[Verbose mode]'
    '*:filename:_files'
)
_arguments -s $arguments
