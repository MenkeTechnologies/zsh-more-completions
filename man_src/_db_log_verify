#compdef db_log_verify

local arguments

arguments=(
    '-C[Specify the cache size in megabytes]:cache size'
    '-b[Specify the starting log record by lsn]:start lsn'
    '-c[Continue the verification after an error is detected]'
    '-D[Specify a database name]:database name'
    '-d[Specify a database file name]:database file:_files'
    '-e[Specify the ending log record by lsn]:end lsn'
    '-h[Specify a home directory of the database environment to verify]:directory:_directories'
    '-H[Specify a home directory for the temporary database environment]:directory:_directories'
    '-N[Do not acquire shared region mutexes while running]'
    '-P[Specify an environment password]:password'
    '-s[Specify the starting log record by time]:start time'
    '-V[Write the library version number and exit]'
    '-v[Enable verbose mode]'
    '*:filename:_files'
)
_arguments -s $arguments
