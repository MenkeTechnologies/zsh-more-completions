#compdef mysqlfrm

local arguments

arguments=(
    '--help[Display help and exit]'
    '--basedir[Base directory for the server]:basedir:_directories'
    '--diagnostic[Read the frm files byte-by-byte to form the CREATE statement]'
    '--new-storage-engine[Change ENGINE clause to use this engine]:engine'
    '--port[Port to use for the spawned server]:port'
    {-s,--show-stats}'[Show file statistics and general table information]'
    '--server[Connection information for the server]:server'
    '--user[User account to launch spawned server]:user'
    '--start-timeout[Number of seconds to wait for spawned server to start]:timeout'
    {-v,--verbose}'[Verbose output]'
    {-q,--quiet}'[Turn off all messages for quiet execution]'
    '--version[Display version information and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
