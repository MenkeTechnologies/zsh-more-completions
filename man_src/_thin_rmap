#compdef thin_rmap
# Documentation: https://man.archlinux.org/search?q=thin_rmap
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '(- * :)'{-h,--help}'[print help and exit]'
    {-V,--version}'[print version information and exit]'
    '--region[specify range of blocks on the data device]:range'
    '*:filename:_files'
)
_arguments -s $arguments
