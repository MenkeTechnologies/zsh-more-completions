#compdef nbdcopy

local arguments

arguments=(
    '--help[Display brief command line help and exit]'
    '--allocated[Copy all blocks even if they are sparse]'
    {-C,--connections}'[Number of connections to use]:N'
    '--destination-is-zero[Assume the destination is already zeroed]'
    '--flush[Flush writes to ensure everything is written to persistent storage]'
    '--no-extents[Do not use extent metadata to skip over sparse parts]'
    {-p,--progress}'[Display a progress bar]'
    '--queue-size[Maximum number of bytes to queue for in-flight requests]:N'
    '--request-size[Maximum request size in bytes]:N'
    {-R,--requests}'[Maximum number of in-flight requests per connection]:N'
    {-S,--sparse}'[Minimum block size to consider for sparsification]:N'
    '--synchronous[Force synchronous copying]'
    {-T,--threads}'[Use up to N threads for copying]:N'
    {-v,--verbose}'[Verbose output]'
    {-V,--version}'[Display the package name and version and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
