#compdef pw-jack
# Documentation: https://man.archlinux.org/search?q=pw-jack
# Reference accessed: 2026-05-16

local arguments

arguments=(
  '-h[show brief help]'
  '-r[remote daemon name]'
  '-v[verbose debug info]'
  '-s[samplerate (default "48000")]'
  '-p[period in samples]'
  '*:filename:_files'
)

_arguments -s $arguments
