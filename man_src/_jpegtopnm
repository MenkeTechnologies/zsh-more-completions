#compdef jpegtopnm

local arguments

arguments=(
    '--dct[Use specified DCT method]:method:(int fast float)'
    '--nosmooth[Use a faster, lower-quality upsampling routine]'
    '--maxmemory[Set limit on the amount of memory used in processing large images]:N'
    '--notadobe[Do not use Adobe-compatible CMYK color space interpretation]'
    '--adobe[Use Adobe-compatible CMYK color space interpretation]'
    '--dumpexif[Print the interpreted contents of any Exif header in the input file]'
    '--exif[Extract the contents of the EXIF header and write to file]:file:_files'
    '--comments[Print any comments in the input file to standard error]'
    '--verbose[Print details about the conversion to standard error]'
    '--tracelevel[Turn on the JPEG library trace messages at the specified level]:n'
    '*:filename:_files'
)
_arguments -s $arguments
