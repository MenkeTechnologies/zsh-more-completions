#compdef gifbuild
# Documentation: https://man.archlinux.org/search?q=gifbuild
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-v[Verbose mode]'
    '-d[Dump mode, output GIF data in text format]'
    '-t[Read text input and generate a GIF file]'
    '-h[Print help and exit]'
    '*:filename:_files'
)
_arguments -s $arguments
