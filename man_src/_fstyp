#compdef fstyp
# Documentation: https://man.archlinux.org/search?q=fstyp
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-l[Also print filesystem label if available]'
    '-s[Ignore file type]'
    '-u[Include filesystems and devices that cannot be mounted directly]'
    '*:filename:_files'
)
_arguments -s $arguments
