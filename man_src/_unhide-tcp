#compdef unhide-tcp

local arguments

arguments=(
    '(- * :)'{-h,--help}'[Display help]'
    '--brief[Do not display warning messages (default behavior)]'
    {-f,--fuser}'[Display fuser output for the hidden port]'
    {-l,--lsof}'[Display lsof output for the hidden port]'
    {-n,--netstat}'[Use /bin/netstat instead of /sbin/ss]'
    {-s,--server}'[Use a very quick strategy of scanning]'
    {-o,--log}'[Write a log file in the current directory]'
    {-V,--version}'[Show version and exit]'
    {-v,--verbose}'[Be verbose, display warning messages]'
    '*:filename:_files'
)
_arguments -s $arguments
