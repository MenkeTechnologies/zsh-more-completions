#compdef winpr-hash

local arguments

arguments=(
    '-u[The username to use]:username'
    '-p[Password to use]:password'
    '-d[Specify the domain of the user]:domain'
    '-f[Specify the output format]:format'
    '-v[Specify the NTLM version to use]:version'
    '*:filename:_files'
)
_arguments -s $arguments
