#compdef hp-setup

local arguments

arguments=(
    {-u,--gui}'[Run in GUI mode]'
    {-i,--interactive}'[Run in interactive mode]'
    {-a,--auto}'[Automatic mode]'
    '--port[Specify the port on a multi-port JetDirect]:port'
    '-x[No testpage in automatic mode]'
    {-p,--printer}'[Specify a CUPS printer queue name]:printer'
    {-f,--fax}'[Specify a CUPS fax queue name]:fax'
    {-t,--type}'[Type of queue(s) to install]:type'
    {-d,--device}'[Specify the device URI to install]:device_uri'
    {-r,--rm,--remove}'[Remove printers or faxes instead of setting-up]'
    '--lang[Set the language]:language'
    {-l,--logging}'[Set the logging level]:level:(none info error warn debug)'
    {-g,--ldebug}'[Run in debug mode]'
    '(- * :)'{-h,--help}'[Show help information]'
    '*:filename:_files'
)
_arguments -s $arguments
