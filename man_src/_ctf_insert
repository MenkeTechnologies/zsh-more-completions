#compdef ctf_insert
# Documentation: https://man.archlinux.org/search?q=ctf_insert
# Reference accessed: 2026-05-16

local arguments

arguments=(
    '-o[Specify the output file]:output file:_files'
    '--arch[Specify the architecture and CTF data file]:arch file'
    '*:filename:_files'
)
_arguments -s $arguments
