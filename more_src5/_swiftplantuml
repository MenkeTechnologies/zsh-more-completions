#compdef swiftplantuml
# Documentation: https://github.com/MarcoEidinger/SwiftPlantUML
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--verbose[enable verbose logging]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    local -a cmds=(
      'classdiagram:generate class diagram (default)'
    )
    _describe -t cmds 'swiftplantuml command' cmds
    _arguments \
      '--config=[custom configuration file]:file:_files' \
      '*--exclude=[ignore source path]:path:_files' \
      '--output=[output format]:format:(browser browserImageOnly consoleOnly)' \
      '--sdk=[macOS SDK path for type inference]:path:_files -/' \
      '--hide-extensions[hide Swift extensions]' \
      '--merge-extensions[merge extensions into their type]' \
      '--show-extensions[show extensions separately (default)]' \
      '*:Swift source path:_files' && ret=0
    ;;
  (args)
    _arguments \
      '--config=[custom configuration file]:file:_files' \
      '*--exclude=[ignore source path]:path:_files' \
      '--output=[output format]:format:(browser browserImageOnly consoleOnly)' \
      '--sdk=[macOS SDK path for type inference]:path:_files -/' \
      '--hide-extensions[hide Swift extensions]' \
      '--merge-extensions[merge extensions into their type]' \
      '--show-extensions[show extensions separately (default)]' \
      '*:Swift source path:_files' && ret=0
    ;;
esac

return ret
