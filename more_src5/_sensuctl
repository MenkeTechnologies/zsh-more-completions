#compdef sensuctl
# Documentation: https://docs.sensu.io/sensu-go/latest/sensuctl/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'api-key:manage API keys'
  'asset:manage assets'
  'auth:manage authentication providers'
  'check:manage checks'
  'cluster:manage cluster members'
  'cluster-role:manage cluster roles'
  'cluster-role-binding:manage cluster role bindings'
  'command:manage commands'
  'completion:generate shell completion'
  'configure:configure CLI'
  'create:create resources from file'
  'delete:delete resources from file'
  'describe-type:describe a resource type'
  'edit:edit resource'
  'entity:manage entities'
  'env:print env settings'
  'event:manage events'
  'filter:manage filters'
  'handler:manage handlers'
  'help:help about any command'
  'hook:manage hooks'
  'license:manage license'
  'login:log in'
  'logout:log out'
  'mutator:manage mutators'
  'namespace:manage namespaces'
  'pipeline:manage pipelines'
  'prune:prune stale resources'
  'role:manage roles'
  'role-binding:manage role bindings'
  'secret:manage secrets'
  'silenced:manage silenced entries'
  'tessen:manage tessen'
  'user:manage users'
  'version:print version'
)

_arguments -C \
  '--api-key=[API key for authentication]:key:' \
  '--api-url=[host URL of Sensu installation]:url:' \
  '--cache-dir=[cache & temporary files directory]:dir:_files -/' \
  '--config-dir=[configuration files directory]:dir:_files -/' \
  '--insecure-skip-tls-verify[skip TLS certificate verification]' \
  '--namespace=[namespace in which to perform actions]:ns:' \
  '--timeout=[timeout communicating with sensu backend]:duration:' \
  '--trusted-ca-file=[TLS CA certificate bundle PEM]:file:_files' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'sensuctl subcommand' subcommands && ret=0
    ;;
esac

return ret
