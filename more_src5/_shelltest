#compdef shelltest
# Documentation: https://github.com/simonmichael/shelltestrunner
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for shelltest (shelltestrunner)

_arguments -s -S \
  '(-l --list)'{-l,--list}'[display names of all discovered tests]' \
  '(-i --include)'{-i+,--include=}'[select tests matching glob pattern]:pattern:' \
  '(-x --exclude)'{-x+,--exclude=}'[skip test files containing text]:text:' \
  '(-a --all)'{-a,--all}'[display full output without truncation]' \
  '(-c --color)'{-c,--color}'[enable colored terminal output]' \
  '(-d --diff)'{-d,--diff}'[show diff between expected and actual]' \
  '(-p --precise)'{-p,--precise}'[display output with exact quoting]' \
  '--hide-successes[report only failures]' \
  '(-f --fail-fast)'{-f,--fail-fast}'[stop on first failure (hspec only)]' \
  '--xmlout=[export results in XML format]:file:_files' \
  '(-D --defmacro)'{-D+,--defmacro=}'[define macro replacements]:macro:' \
  '--execdir[run tests from within each file directory]' \
  '--extension=[test file suffix (default .test)]:ext:' \
  '(-w --with)'{-w+,--with=}'[substitute first command word with executable]:exe:_command_names' \
  '(-o --timeout)'{-o+,--timeout=}'[max execution duration per test (seconds)]:seconds:' \
  '(-j --threads)'{-j+,--threads=}'[parallel execution threads]:n:' \
  '--shell=[shell interpreter path]:shell:_command_names' \
  '--debug[display diagnostic information]' \
  '--debug-parse[show parsing results and exit]' \
  '--print=[output tests in specified format]:format:' \
  '--hspec[use hspec test runner]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--numeric-version[print version number only]' \
  '*:shelltest file:_files' && return 0
