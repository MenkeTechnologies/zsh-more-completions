#compdef storm-dft
# Documentation: https://github.com/moves-rwth/storm/tree/master/src/storm-dft-cli
# Reference accessed: 2026-05-27
# Verified: upstream moves-rwth/storm option registrations in
#   src/storm-dft/settings/modules/{DftIOSettings,FaultTreeSettings,
#   DftGspnSettings}.cpp plus shared GeneralSettings/IOSettings/CoreSettings/
#   DebugSettings/ResourceSettings/TransformationSettings.
#
# Coverage: full DFT-specific option set plus the shared option groups storm
# uses across all CLIs. Engine-internal solver knobs intentionally omitted.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show available options]:filter (optional):' \
  '--version[print version information]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(-eps --precision)'{-eps,--precision}'[internal numerical precision]:double:' \
  '(-c --config)'{-c+,--config=}'[read additional options from config file]:file:_files' \
  '--parametric[enable parametric analysis]' \
  '--exact[enable exact analysis]:mode:(rationals floats)' \
  '--sound[force sound analysis]' \
  '(-e --engine)'{-e+,--engine=}'[underlying engine]:engine:(sparse hybrid dd exploration)' \
  '(-stats --statistics)'{-stats,--statistics}'[display statistics]' \
  '--debug[enable debug logging]' \
  '--trace[enable trace logging]' \
  '(-l --logfile)'{-l+,--logfile=}'[write log to file]:file:_files' \
  '(-t --timeout)'{-t+,--timeout=}'[abort after N seconds]:seconds:' \
  '(-tm --timemem)'{-tm,--timemem}'[print CPU time and memory at end]' \
  '(-prop --prop)'{-prop+,--prop=}'[temporal logic property]:property:' \
  '(-const --constants)'{-const+,--constants=}'[constant definitions]:assignments:' \
  '(-dft --dftfile)'{-dft+,--dftfile=}'[parse DFT in Galileo format]:file:_files -g "*.(dft|galileo)"' \
  '(-dftjson --dftfile-json)'{-dftjson+,--dftfile-json=}'[parse DFT in Cytoscape JSON format]:file:_files -g "*.json"' \
  '(-mttf --expectedtime)'{-mttf,--expectedtime}'[compute expected time of system failure]' \
  '--probability[compute probability of system failure]' \
  '--timebound=[compute probability up to timebound]:time:' \
  '--timepoints=[compute probability for set of timepoints]:list:' \
  '--min[compute minimal value over non-determinism]' \
  '--max[compute maximal value over non-determinism]' \
  '--bdd[use BDDs for analysis]' \
  '--mcs[compute minimal cut sets]' \
  '--export-json=[export DFT as Cytoscape JSON]:file:_files' \
  '--export-smt=[export DFT as SMT encoding]:file:_files' \
  '--export-bdd-dot=[export BDD as dot graph]:file:_files' \
  '(-dftstats --dft-statistics)'{-dftstats,--dft-statistics}'[display DFT statistics]' \
  '--importance=[compute importance measure for basic events]:measure:' \
  '--be-order=[BDD variable ordering file]:file:_files' \
  '(-nosymred --noSymmetryReduction)'{-nosymred,--noSymmetryReduction}'[disable symmetry reduction]' \
  '--modularisation[apply modularisation]' \
  '--disabledc[disable don'\''t-care propagation]' \
  '--firstdep[break dependency ties by first-listed event]' \
  '--relevantevents=[restrict analysis to listed events]:events:' \
  '--allowdcrelevant[allow DC propagation for relevant events]' \
  '--labels-claiming[generate labels for claimings]' \
  '(-approx --approximation)'{-approx+,--approximation=}'[approximation error bound]:error:' \
  '--approximationheuristic=[approximation heuristic]:heuristic:(depth probability bounddifference)' \
  '--maxdepth=[maximum exploration depth]:depth:' \
  '--uniquefailedbe[require unique failed BE]' \
  '--smt[enable SMT-based analysis (requires Z3)]' \
  '--chunksize=[chunk size for approximation]:n:' \
  '--mttf-precision=[MTTF precision]:double:' \
  '--mttf-stepsize=[MTTF integration step size]:double:' \
  '--mttf-algorithm=[MTTF algorithm]:alg:(proceeding variableChange)' \
  '--to-gspn[transform DFT to GSPN]' \
  '--disable-smart[disable smart GSPN transformation]' \
  '--merge-dc-failed[merge DC and FAILED states in GSPN]' \
  '--extend-priorities[extend transition priorities in GSPN]' \
  '--to-jani=[export transformed model as JANI]:file:_files' \
  '*:DFT file:_files' && ret=0

return ret
