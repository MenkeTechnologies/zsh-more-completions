#compdef ssh-vault
# Documentation: https://ssh-vault.com + github.com/ssh-vault/ssh-vault
# Source: cmd/ssh-vault/main.go (Go std flag package)
# Reference accessed: 2026-05-30
# ssh-vault — Nicolas Bigaouette's SSH-key based asymmetric encryption tool.
# Encrypt small secrets to a SSH public key (file or GitHub user); decrypt
# with the corresponding private key. Single-letter flags via Go `flag` pkg.

local curcontext="$curcontext" state line ret=1

local -a _ops
_ops=(
  'create:create a new vault (alias: c)'
  'c:create a new vault'
  'edit:edit an existing vault (alias: e)'
  'e:edit an existing vault'
  'view:view an existing vault (alias: v)'
  'v:view an existing vault'
  'fingerprint:print the fingerprint of a public ssh key (alias: f)'
  'f:print the fingerprint of a public ssh key'
)

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-v[print version]' \
  '-f[create using key matching fingerprint, or print fingerprint]' \
  '-k+[public ssh key path or numerical index (default ~/.ssh/id_rsa.pub)]:key-or-index:_files -g "*.pub"' \
  '-o+[write output to file (view only)]:file:_files' \
  '-u+[GitHub username or URL — fetch their pubkeys]:user:' \
  '1:operation:->op' \
  '2:vault file:_files -g "*.(vault|sshv)"' \
  && ret=0

case $state in
  op)
    _describe -t commands 'ssh-vault operation' _ops && ret=0
    ;;
esac

return ret
