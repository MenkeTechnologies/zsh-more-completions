#compdef simh
# Documentation: https://github.com/open-simh/simh
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: SIMH simulator binaries (each system has its own binary like
# pdp11, vax, etc.) accept an optional script filename argument; CLI
# flag set is not documented as a stable surface — control happens
# inside the simulator REPL via DO/SET/ATT commands. Falling back to
# script file completion.

local curcontext="$curcontext" ret=1

_arguments -C \
  '*:script:_files -g "*.{ini,simh,sim}"' && ret=0

return ret
