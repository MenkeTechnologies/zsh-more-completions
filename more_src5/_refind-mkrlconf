#compdef refind-mkrlconf
# Documentation: https://man.archlinux.org/man/extra/refind/mkrlconf.8.en
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Removed from prior file: fabricated --help and --outfile flags
# (mkrlconf man page documents only --force).

# refind-mkrlconf: scan /proc/cmdline and emit /boot/refind_linux.conf
local curcontext="$curcontext" ret=1
_arguments -C \
  '--force[overwrite existing /boot/refind_linux.conf]' && ret=0
return ret
