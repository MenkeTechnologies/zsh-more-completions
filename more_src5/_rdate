#compdef rdate
# _rdate — OpenBSD rdate (display + set the local clock from an RFC 5905 SNTP/NTP server; -a uses adjtime(2) for gradual slewing, -p print only, -s set only)
# upstream: https://github.com/openbsd/src (usr.sbin/rdate)
# Flags from usr.sbin/rdate/rdate.8 on tip.

_rdate() {
    _arguments \
        '-4[IPv4 only]' \
        '-6[IPv6 only]' \
        '-a[gradual slew via adjtime(2)]' \
        '-n[use SNTP instead of RFC 868]' \
        '-p[print only (no set)]' \
        '-s[set only (no print)]' \
        '-v[verbose]' \
        '1:host:_hosts'
}

_rdate "$@"
