#compdef qhold
# _qhold-pbs — PBS qhold (place a hold on a queued PBS job preventing it from being selected for execution; -h hold type (u user, o operator, s system, comma combine), -t array selector (e.g. 1-100,200), -W <wait-type> additional hold/release semantics; positional jobIDs)
# upstream: https://github.com/openpbs/openpbs
# Flags from openpbs src/cmds/qhold.c on tip.

_qhold-pbs() {
    _arguments \
        '-h+[hold type]:type:(u o s us uo os uos)' \
        '-t+[array selector]:range:' \
        '-W+[wait spec]:wait:' \
        '*:jobID:'
}

_qhold-pbs "$@"
