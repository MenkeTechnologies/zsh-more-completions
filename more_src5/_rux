#compdef rux
# ============================================================================
# _rux — zsh completion for the Rux programming language compiler driver
#         — Rux is "a fast, compiled, strongly typed, multi-paradigm,
#         general-purpose programming language" (165th programming language
#         entry)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/rux-lang/Rux
#   Maintainer : Rux Contributors (rux-lang)
#   Website    : https://rux-lang.dev
#   License    : MIT
#   Stars      : 256
#   Language   : C++ (CMake; project(Rux VERSION 0.3.0 LANGUAGES CXX))
#   Module     : github.com/rux-lang/Rux
#   Binary     : rux  (CMakeLists.txt add_executable(rux ...))
#   Source ext : .rux
#   Last push  : 2026-06-02
#
# WHAT IT IS
#   Rux is "a fast, compiled, strongly typed, multi-paradigm,
#   general-purpose programming language" — actively developed
#   across DragonFly BSD, FreeBSD, Illumos, Linux, macOS, NetBSD,
#   OpenBSD, and Windows (one CI badge per platform).  The
#   compiler driver `rux` ships a cargo-style workflow:  `init`
#   / `new` scaffold a project, `build` / `run` / `test` operate
#   on the local manifest, `add` / `remove` manage dependencies,
#   `install` / `uninstall` / `update` manage the global package
#   set under `~/.rux/packages`, `fmt` formats sources, `doc`
#   builds API docs, and `check` validates a manifest without
#   building.  The build pipeline pumps source through Lexer →
#   Parser → Sema → HIR → LIR → Asm → Linker stages, each of
#   which can be dumped via `--dump-<stage>` flags for compiler
#   internals work.
#
# CLI ARGUMENT GRAMMAR  (verbatim from Source/Cli.cpp — the driver
#                       is a hand-rolled C++ argument parser, not
#                       a third-party library)
#   rux [GLOBAL OPTIONS] <SUBCOMMAND> [args...]
#
#   Global options:
#     -h, --help                     Show help
#     -V, --version                  Show version
#     -q, --quiet                    Suppress non-error output
#     -v, --verbose                  Verbose output
#     --color[=<MODE>]               Color output control
#
#   Project / lifecycle subcommands:
#     init [<NAME>]                  Initialize a Rux project in
#                                    the current directory
#       --check                        Validate manifest only
#       --manifest <PATH>              Manifest file path
#     new <NAME>                     Create a new project directory
#       --bin                          Generate a binary crate
#       --lib                          Generate a library crate
#     build                          Compile the local project
#     run                            Build and run the local
#                                    project (forwards trailing
#                                    args after `--` to the
#                                    compiled program)
#     test                           Run the local project's tests
#     clean                          Remove build artifacts
#     check                          Type-check without producing
#                                    binaries
#     fmt                            Format Rux source files in
#                                    place
#     doc                            Generate API documentation
#       --open                         Open docs in the default
#                                      browser after generation
#     info                           Print project / toolchain info
#
#   Common build / run / test options:
#     --release                      Release profile
#     --debug                        Debug profile
#     --profile <NAME>               Custom profile name
#     --target <TRIPLE>              Target triple
#                                    (linux-x64|windows-x64|
#                                     macos-x64|macos-arm64|
#                                     freebsd-x64|openbsd-x64|
#                                     netbsd-x64|dragonfly-x64|
#                                     illumos-x64)
#     --stats                        Print per-stage compilation
#                                    statistics + executable size
#                                    + peak memory
#     --dump-tokens                  Dump lexer tokens
#     --dump-ast                     Dump parser AST
#     --dump-sema                    Dump semantic analyzer output
#     --dump-hir                     Dump high-level IR
#     --dump-lir                     Dump low-level IR
#     --dump-asm                     Dump generated assembly
#     --dump-rcu                     Dump RCU IR
#
#   Dependency subcommands:
#     add <PACKAGE>                  Add a dependency
#       --dev                          Add to dev-dependencies
#     remove <PACKAGE>               Remove a dependency
#     update                         Update locked dependencies
#     list                           List local + global packages
#
#   Global package subcommands:
#     install <PACKAGE>              Install a package
#       --global                       Install globally under
#                                      `~/.rux/packages`
#       --bin                          Install only the binary
#                                      target
#     uninstall <PACKAGE>            Uninstall a package
#       --global                       Operate on the global set
#
#   help [<COMMAND>]                  Show help (general or for one
#                                     subcommand)
#   version                           Show version
#
# LANGUAGE-CORPUS POSITION
#   Rux is the 165th programming language entry in this completion
#   corpus, completing the 3+1 micro-cycle that began at R929
#   (_fungi / enbop Rust=140 OPENS Axis 85 P2P/libp2p Networking
#   Stack) and continued through R930 (_ipget / IPFS Project
#   Go=140 — round-number R930 commit landmark) and R931 (_voyager
#   / orbitdb TS-Node=140 CLOSES Axis 85 at 1/1/1 three-language
#   symmetry — triple-140 landmark and 78th axis closed).  Rux
#   joins Jule (R928 164th), Nevalang (R924 163rd), Corvid (R920
#   162nd — round-number R920 commit landmark), Soppo (R916 161st),
#   Cyrus (R912 160th — round-number language milestone), Lumina
#   (R908 159th), Penne (R904 158th), EndBASIC (R900 157th — R900
#   TRIPLE-9 commit landmark), goboscript (R896 156th), Alan (R892
#   155th), Mech (R888 154th — triple-8 landmark), Lisette (R884
#   153rd), Bril (R880 152nd), Vyxal (R876 151st), EYG (R872 150th —
#   round-number language milestone), Roto (R868 149th), Pipefish
#   (R864 148th), Mochi (R860 147th), Oden (R856 146th), Hop (R852
#   145th), Lustre via Kind 2 (R848 144th), Ravi (R844 143rd),
#   ZetZ (R840 142nd), Granule (R836 141st), Sixten (R832 140th),
#   Imba (R828 139th), Tao (R824 138th), Dada (R820 137th), Acton
#   (R816 136th), and Stanza (R812 135th).
#
#   No completion for `rux` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_rux() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-q --quiet)'{-q,--quiet}'[suppress non-error output]' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '--color=[color output control]:mode:(auto always never)' \
        '1: :_rux_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                build|run|test)
                    _arguments \
                        '--release[release profile]' \
                        '--debug[debug profile]' \
                        '--profile=[custom profile name]:profile:' \
                        '--target=[target triple]:triple:(linux-x64 windows-x64 macos-x64 macos-arm64 freebsd-x64 openbsd-x64 netbsd-x64 dragonfly-x64 illumos-x64)' \
                        '--stats[print per-stage compilation statistics]' \
                        '--dump-tokens[dump lexer tokens]' \
                        '--dump-ast[dump parser AST]' \
                        '--dump-sema[dump semantic analyzer output]' \
                        '--dump-hir[dump high-level IR]' \
                        '--dump-lir[dump low-level IR]' \
                        '--dump-asm[dump generated assembly]' \
                        '--dump-rcu[dump RCU IR]' \
                        '*::trailing args:' && ret=0 ;;
                new)
                    _arguments \
                        '--bin[generate a binary crate]' \
                        '--lib[generate a library crate]' \
                        ':project name:' && ret=0 ;;
                init)
                    _arguments \
                        '--check[validate manifest only]' \
                        '--manifest=[manifest file path]:path:_files' \
                        '::project name:' && ret=0 ;;
                doc)
                    _arguments \
                        '--open[open docs in default browser]' && ret=0 ;;
                add)
                    _arguments \
                        '--dev[add to dev-dependencies]' \
                        ':package:' && ret=0 ;;
                remove)
                    _arguments \
                        ':package:' && ret=0 ;;
                install)
                    _arguments \
                        '--global[install globally]' \
                        '--bin[install only the binary target]' \
                        ':package:' && ret=0 ;;
                uninstall)
                    _arguments \
                        '--global[operate on the global set]' \
                        ':package:' && ret=0 ;;
                help)
                    _arguments \
                        '::command:(help version build run test clean check fmt doc init new add remove install uninstall update list info)' && ret=0 ;;
                clean|fmt|update|list|info|version|check)
                    _arguments && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_rux_commands] )) ||
_rux_commands() {
    local -a commands
    commands=(
        'help:show help (general or per-command)'
        'version:show version'
        'init:initialize a Rux project in current directory'
        'new:create a new project directory'
        'build:compile the local project'
        'run:build and run the local project'
        'test:run the local project tests'
        'clean:remove build artifacts'
        'check:type-check without producing binaries'
        'fmt:format Rux source files in place'
        'doc:generate API documentation'
        'info:print project / toolchain info'
        'add:add a dependency'
        'remove:remove a dependency'
        'update:update locked dependencies'
        'list:list local + global packages'
        'install:install a package'
        'uninstall:uninstall a package'
    )
    _describe -t commands 'rux command' commands
}

_rux "$@"
