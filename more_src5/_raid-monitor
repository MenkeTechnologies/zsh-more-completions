#compdef raid-monitor
# Documentation: https://www.man7.org/linux/man-pages/man8/mdadm.8.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# raid-monitor: not a standard upstream binary; STUB.
# Some distros ship a thin wrapper around `mdadm --monitor`; no canonical CLI.
local curcontext="$curcontext" ret=1
_arguments -C \
  '*::raid-monitor args:_files' && ret=0
return ret
