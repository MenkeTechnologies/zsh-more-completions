#compdef spatialite_gml
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/spatialite_gml.1.html
# Reference accessed: 2026-05-21
# Verified: Ubuntu trusty spatialite_gml(1) manpage.

# spatialite_gml: import GML-XML data into a spatialite database
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-g --gml-path)'{-g+,--gml-path=}'[GML-XML file path]:file:_files' \
  '(-d --db-path)'{-d+,--db-path=}'[spatialite database file]:file:_files' \
  '(-t --table-name)'{-t+,--table-name=}'[table name]:table:' \
  '(-m --in-memory)'{-m,--in-memory}'[use in-memory database]' \
  '(-n --no-spatial-index)'{-n,--no-spatial-index}'[suppress R*Tree generation]' && ret=0
return ret
