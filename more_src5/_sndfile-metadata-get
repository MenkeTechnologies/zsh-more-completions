#compdef sndfile-metadata-get
# Documentation: sndfile-metadata-get usage (libsndfile)
# Source: libsndfile sndfile-metadata-get — print BEXT or string metadata fields from audio files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--bext-description[print BEXT description]' \
    '--bext-originator[print BEXT originator info]' \
    '--bext-orig-ref[print BEXT origination reference]' \
    '--bext-umid[print BEXT UMID]' \
    '--bext-orig-date[print BEXT origination date]' \
    '--bext-orig-time[print BEXT origination time]' \
    '--bext-loudness-value[print BEXT loudness value]' \
    '--bext-loudness-range[print BEXT loudness range]' \
    '--bext-max-truepeak[print BEXT max true-peak level]' \
    '--bext-max-momentary[print BEXT max momentary loudness]' \
    '--bext-max-shortterm[print BEXT max short-term loudness]' \
    '--bext-coding-hist[print BEXT coding history]' \
    '--str-title[print title metadata]' \
    '--str-copyright[print copyright metadata]' \
    '--str-artist[print artist metadata]' \
    '--str-comment[print comment metadata]' \
    '--str-date[print creation date metadata]' \
    '--str-album[print album metadata]' \
    '--str-license[print license metadata]' \
    '--str-software[print software metadata]' \
    '--str-tracknumber[print tracknumber metadata]' \
    '--str-genre[print genre metadata]' \
    '*:audio file:_files' \
    && ret=0

return ret
