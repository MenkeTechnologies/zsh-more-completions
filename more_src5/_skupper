#compdef skupper
# Documentation: https://github.com/skupperproject/skupper/tree/main/internal/cmd/skupper
# Reference accessed: 2026-05-21
# Verified: upstream skupper v2 source tree (cmd packages: site, connector,
# listener, link, token, debug, manifest, system, version, root).
# Removed v1-only subcommands not present in v2 (expose, unexpose, gateway,
# network, revoke-access, service, init, status, update). Removed
# associated fabricated --site-name/--ingress/--router-mode/etc flags.

local -a _skupper_commands
_skupper_commands=(
  'site:manage Skupper sites'
  'connector:expose a workload to the network'
  'listener:consume an exposed service'
  'link:manage site-to-site links'
  'token:issue or redeem access tokens'
  'debug:debug commands'
  'manifest:manifest commands'
  'system:system-level subcommands'
  'version:show version'
)

local -a _skupper_subactions=(create update delete status get generate issue redeem)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n,--namespace}'[Kubernetes namespace]:namespace:' \
  '--context[kubeconfig context]:context:' \
  '--kubeconfig[kubeconfig file]:file:_files' \
  '--platform[platform]:platform:(kubernetes podman docker linux)' \
  '1:command:->cmds' \
  '*::arg:->args'

case "$state" in
  cmds)
    _describe -t commands 'skupper commands' _skupper_commands
    ;;
  args)
    case "$words[1]" in
      site|connector|listener|link|token)
        _values 'action' $_skupper_subactions
        ;;
      debug)
        _values 'debug action' dump events
        ;;
      manifest)
        _values 'manifest action' generate
        ;;
      system)
        _values 'system action' install uninstall setup teardown start stop reload status
        ;;
    esac
    ;;
esac
