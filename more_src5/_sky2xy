#compdef sky2xy
# _sky2xy — convert sky coordinates to FITS image pixel coordinates (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from sky2xy.c (single-letter getopt-style).

_sky2xy() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-v[verbose output]' \
        '-a+[initial rotation angle (degrees)]:deg:' \
        '-b+[image ref coords on command line (B1950)]:coords:' \
        '-e[Ecliptic coordinates]' \
        '-g[Galactic coordinates]' \
        '-j+[image ref coords on command line (J2000)]:coords:' \
        '-n+[decimal places in output]:n:' \
        '-o+[part of coordinates to output]:part:(x y both)' \
        '-p+[initial plate scale (arcsec/pixel)]:scale:' \
        '-s+[size of image in X and Y pixels]:size:' \
        '-x+[X,Y of reference pixel]:xy:' \
        '-y+[image epoch (FITS date)]:date:' \
        '-z[use AIPS classic WCS]' \
        '1:FITS image:_files -g "*.(fits|fit|fts)"' \
        '*:RA Dec [system]:'
}

_sky2xy "$@"
