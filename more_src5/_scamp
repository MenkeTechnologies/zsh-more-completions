#compdef scamp
# Documentation: https://scamp.readthedocs.io/
# Documentation: https://github.com/astromatic/scamp/blob/master/src/main.c
# Documentation: https://github.com/astromatic/scamp/blob/master/src/preflist.h
# Reference accessed: 2026-05-27
# Verified: upstream src/main.c argument loop and src/preflist.h keystruct (astromatic/scamp)

# Zsh completion for SCAMP (astrometric and photometric calibration)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show syntax/help]' \
  '-v[show version information]' \
  '-d[dump default configuration file to stdout]' \
  '-dd[dump extended default configuration file]' \
  '-c[specify configuration file]:config:_files -g "*.scamp"' \
  '*-'{AHEADER_GLOBAL,AHEADER_NAME,AHEADER_SUFFIX,AIRMASS_KEY,ASTR_ACCURACY,ASTR_FLAGSMASK,ASTR_IMAFLAGSMASK,ASTRACCURACY_KEY,ASTRACCURACY_TYPE,ASTRCLIP_NSIGMA}'[override SCAMP parameter]:value:' \
  '*-'{ASTREF_BAND,ASTREF_CATALOG,ASTREF_EPOCH,ASTREF_WEIGHT,ASTREFCAT_NAME,ASTREFCENT_KEYS,ASTREFEPOCH_TYPE,ASTREFERR_KEYS,ASTREFPROP_KEYS,ASTREFPROPERR_KEYS}'[override SCAMP parameter]:value:' \
  '*-'{ASTREFMAG_KEY,ASTREFMAGERR_KEY,ASTREFOBSDATE_KEY,ASTREFMAG_LIMITS,ASTREFREGUL_TYPE,ASTRINSTRU_KEY,CENTROID_KEYS,CENTROIDERR_KEYS,CHECKIMAGE_NAME,CHECKIMAGE_TYPE}'[override SCAMP parameter]:value:' \
  '*-'{CHECKPLOT_ANTIALIAS,CHECKPLOT_CKEY,CHECKPLOT_DEV,CHECKPLOT_NAME,CHECKPLOT_RES,CHECKPLOT_TYPE,COMPUTE_PARALLAXES,COMPUTE_PROPERMOTIONS,CORRECT_COLOURSHIFTS,CROSSID_RADIUS}'[override SCAMP parameter]:value:' \
  '*-'{DGEOMAP_NAME,DGEOMAP_NNEAREST,DGEOMAP_STEP,DISTORT_DEGREES,DISTORT_GROUPS,DISTORT_KEYS,ELLIPTICITY_MAX,EXPOTIME_KEY,EXTINCT_KEY,FIXFOCALPLANE_NMIN,FLAGS_MASK}'[override SCAMP parameter]:value:' \
  '*-'{FOCDISTORT_DEGREE,FULLOUTCAT_NAME,FULLOUTCAT_TYPE,FWHM_THRESHOLDS,HEADER_NAME,HEADER_SUFFIX,HEADER_TYPE,IMAFLAGS_MASK,INCLUDE_ASTREFCATALOG}'[override SCAMP parameter]:value:' \
  '*-'{MAGZERO_INTERR,MAGZERO_KEY,MAGZERO_OUT,MAGZERO_REFERR,MATCH,MATCH_FLIPPED,MATCH_NMAX,MATCH_RESOL,MERGEDOUTCAT_NAME,MERGEDOUTCAT_TYPE,MOSAIC_TYPE,NTHREADS}'[override SCAMP parameter]:value:' \
  '*-'{PHOT_ACCURACY,PHOT_FLAGSMASK,PHOT_IMAFLAGSMASK,PHOTCLIP_NSIGMA,PHOTFLUX_KEY,PHOTFLUXERR_KEY,PHOTINSTRU_KEY,PHOTOMFLAG_KEY,PIXSCALE_MAXERR,POSANGLE_MAXERR,POSITION_MAXERR}'[override SCAMP parameter]:value:' \
  '*-'{PROJECTION_TYPE,REF_SERVER,REF_TIMEOUT,REFOUT_CATPATH,SAVE_DGEOMAP,SAVE_REFCATALOG,SN_THRESHOLDS,SOLVE_ASTROM,SOLVE_PHOTOM,STABILITY_TYPE,VERBOSE_TYPE,WEIGHTFLAGS_MASK,WRITE_XML,XML_NAME,XSL_URL}'[override SCAMP parameter]:value:' \
  '*:catalog:_files -g "*.(cat|ldac|fits|FITS)"' && ret=0

return ret
