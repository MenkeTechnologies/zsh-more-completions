#compdef sherif
# Documentation: https://github.com/QuiiBz/sherif
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-f --fix)'{-f,--fix}'[auto-fix issues]' \
  '(-s --select)'{-s+,--select=}'[autofix version selection]:strategy:(highest lowest)' \
  '--no-install[skip package manager install after autofix]' \
  '--fail-on-warnings[exit 1 if warnings found]' \
  '*'{-r+,--ignore-rule=}'[ignore a linting rule]:rule:' \
  '*'{-p+,--ignore-package=}'[ignore a package]:package:' \
  '*'{-i+,--ignore-dependency=}'[ignore a dependency version mismatch]:dependency:' \
  '*:path:_files -/' && ret=0

return ret
