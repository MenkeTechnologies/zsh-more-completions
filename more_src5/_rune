#compdef rune
# =============================================================================
# rune — udoprog/rune-rs's "Rune Language" — an
#        embeddable dynamic programming language for
#        Rust, designed to be hosted inside a parent
#        Rust application and run scripts against
#        types installed from the host.  Compiles
#        source down to a compact bytecode
#        representation and runs it on top of an
#        efficient STACK-BASED VIRTUAL MACHINE with
#        REFERENCE-COUNTED memory management,
#        first-class async/await + generators, hot
#        reloading, and a clean Rust-host integration
#        story.  Distinguishing from other corpus
#        embeddable scripting languages by:
#          - RUST-NATIVE EMBED — Rune is engineered
#            primarily as a guest language for Rust
#            host applications.  The compiler and
#            runtime are both Rust libraries
#            (`rune`, `rune-modules`) that ship with
#            a bundled CLI driver (`rune-cli` →
#            installed as `rune`).  Distinguishes
#            from Lua (C-host primary, mlua/rlua are
#            wrappers), Wren (C-host, ruwren wrapper),
#            Python (C-host with PyO3 bindings),
#            Janet (C-host, janetrs wrapper), and
#            Roc (R529; Roc's host story is "ABI to
#            any language" but it is not designed
#            specifically around Rust embedding).
#            Closest comparable is Rhai (Rust-native
#            embedded scripting) but Rhai is
#            expression-oriented + AST-walking; Rune
#            is statement-oriented + bytecode-VM
#          - WORKSPACE/MANIFEST MODEL — Rune adopts
#            a Cargo-shaped workspace model: every
#            Rune project may have a `Rune.toml`
#            manifest declaring [package] + [[bin]] +
#            [[lib]] + [[test]] + [[example]] +
#            [[bench]] targets.  The `--workspace`,
#            `--package`, `--bin`, `--lib`, `--test`,
#            `--example`, `--bench`, `--all-targets`
#            shared flags propagate through every
#            subcommand.  No other embeddable
#            scripting language in the corpus
#            replicates the Cargo manifest taxonomy
#            verbatim
#          - SUBCOMMAND ARCHITECTURE — unlike Lua,
#            Rhai, Janet, Wren whose CLIs take a
#            script path and run it, the `rune`
#            driver exposes a Cargo-shaped
#            subcommand surface:
#              * check          — parse + typecheck
#                                without executing
#              * doc            — build HTML
#                                documentation
#              * ace            — emit Ace editor
#                                autocompletion JS
#              * test           — run all #[test]
#                                functions
#              * bench          — run benchmarks
#              * run            — execute a script
#              * fmt            — format sources
#              * languageserver — speak LSP over
#                                stdio
#              * hash           — generate type
#                                hashes
#            Each subcommand inherits a shared
#            block of build flags (--recursive,
#            --warnings, --verbose, --workspace,
#            -O <compiler-option>, --list-options,
#            --bin/--lib/--test/--example/--bench
#            target filters, --package, --
#            all-targets, --path)
#          - COMPILER-OPTION SURFACE (-O) — Rune
#            exposes its compiler internals via a
#            `-O <key>=<value>` Cargo-like flag.
#            Available keys are listed by
#            `--list-options`: byte-code,
#            link-checks, memoize-instance-fn,
#            debug-info, function-body-stack,
#            link-checks, lowering, language-version,
#            macros, function-body, function-body-
#            stack, debug-instructions, function-
#            body-debug-info, function-body-debug-
#            instructions, etc.  Other corpus
#            embeddables expose compiler tunables
#            via env vars or runtime APIs, not via
#            a Cargo-style `-O` slot
#          - ACE EDITOR AUTOCOMPLETION EMIT —
#            the `rune ace` subcommand is unique
#            in the corpus: it emits a JS
#            autocompletion extension for the Ace
#            web editor based on the compiled
#            workspace's exported items + their
#            documentation.  No other scripting
#            language CLI in the corpus generates
#            web-editor completion data as a
#            first-class subcommand
#          - HASH-BASED ITEM RESOLUTION — Rune
#            resolves items (types, functions,
#            constants) at runtime via a stable
#            `Hash` derived from the item's path.
#            The `rune hash` subcommand is a
#            debugging utility that takes an item
#            path and prints its `Hash`, useful
#            for resolving cross-module references
#            in host code without paying the
#            string-interning cost at runtime.
#            Distinct from Lua (string-keyed
#            metatables), Python (qualname strings),
#            Janet (interned-symbol resolution)
#          - LANGUAGE SERVER BUILT-IN — `rune
#            languageserver` speaks the Microsoft
#            Language Server Protocol over stdio.
#            Other embeddables either ship LSP as
#            a separate binary (Lua: lua-language-
#            server) or have no first-party LSP
#            (Wren, Rhai, Janet, Roc)
#          - RUST 1.92+ MSRV — current 0.14.x line
#            requires Rust 1.92 (per `rune-cli/
#            Cargo.toml`'s `rust-version = "1.92"`).
#            Bytecode + VM internals exploit modern
#            Rust features (GATs, async traits,
#            `let-else`, `try` blocks); the project
#            tracks recent stable closely instead
#            of pinning a wide MSRV window
#
# DISTINCT FROM OTHER EMBEDDABLE / DYNAMIC SCRIPTING
# LANGUAGES IN THE CORPUS:
#   - LUA (`_lua`)            : C-host primary,
#                               tagged-union values,
#                               coroutines (no async/
#                               await); Rune is Rust-
#                               host primary, tagged
#                               values, native async
#   - RHAI (`_rhai`)          : Rust-host, AST-walk
#                               interpreter, no
#                               bytecode VM; Rune
#                               compiles to bytecode
#                               + runs on a stack VM
#   - JANET (`_janet`)        : C-host, tree-shaking
#                               GC, fibers; Rune is
#                               Rust-host, RC-based,
#                               async tasks
#   - WREN (`_wren`)          : C-host, class-based
#                               OOP, single inheritance;
#                               Rune is struct/enum-
#                               based, pattern-matching
#   - PYTHON (`_python`)      : C-host, dict-based
#                               objects, GIL; Rune is
#                               Rust-host, struct-
#                               based, no GIL
#   - ERG (`_erg`)            : Rust-implemented but
#                               compiles TO Python
#                               bytecode for Python
#                               compatibility; Rune
#                               compiles TO its own
#                               bytecode for Rust-
#                               host embedding
#   - GLEAM (`_gleam`)        : Erlang/JS target;
#                               compile-to runtimes
#                               Rune is its own VM
#   - GRAIN (`_grain`)        : WebAssembly target
#                               Rune is its own VM
#   - HELIX (host-side, not
#     embedded)
#
# 126TH LANGUAGE ENTRY — Rune marks the 126th
# distinct programming language documented in this
# corpus.  Closes the 3+1 micro-cycle started after
# Axis 46 (GraphQL Server) closed at 1/1/1 three-
# language symmetry in R775 (`_houdini`) +
# R774 (`_stash`) + R773 (`_tailcall`).  The
# preceding 125 languages, in rough order of
# appearance in the corpus, span:
#   * mainstream + popular: C, C++, Rust, Go, Java,
#     Kotlin, Scala, Swift, JavaScript, TypeScript,
#     Python, Ruby, Perl, PHP, Lua, Haskell, OCaml,
#     F#, Clojure, Elixir, Erlang
#   * theorem provers + verification: Coq, Lean 4,
#     Agda, Idris, Dafny, F*, Stainless (R756),
#     Bosque (R748), Cogent (R772)
#   * concatenative + stack: Forth, Factor, Joy,
#     Cat, Mlatu
#   * Lisps: Common Lisp, Scheme, Racket, Janet,
#     Fennel, Hy, Chez, Carp
#   * static + systems: Zig, Hare, V, Nim, Crystal,
#     Odin, Vale, Cone, Carbon, Hylo, Mojo
#   * functional research: Roc, Koka, Unison,
#     Lamdera, Frege, PureScript, Elm, Eta, Bend,
#     HVM, Bosque, Hazel (R752), Stainless (R756),
#     Verona (R760), Ante (R764)
#   * markup-as-language: HVML/PurC (R768)
#   * Australian sel4-affiliated: Cogent (R772)
#   * concatenative array: APL, J, K, Kona, Q, BQN
#   * mathematical: Julia, R, Octave, Maxima
#   * domain-specific: SQL, GraphQL, Cypher, AQL
#   * smart-contract: Tact, Solidity, Move, Sway,
#     Vyper, Ink!
#   * AND NOW (R776): Rune — embeddable dynamic
#     programming language for Rust, compact bytecode
#     VM with reference-counted memory, native
#     async/await + generators, Cargo-shaped
#     workspace model, ace-editor autocompletion
#     emit, LSP first-party, hash-based item
#     resolution, Rust 1.92+ MSRV.  No prior corpus
#     entry is a Rust-host primary scripting
#     language with a bytecode VM and a Cargo-
#     shaped manifest taxonomy — closest neighbour
#     is Rhai (AST-walking) but Rhai is not in this
#     niche.  Rune occupies a unique slot:
#       (a) Rust-native embed (not C-native or self-
#           hosted)
#       (b) bytecode + stack VM (not AST-walking)
#       (c) Cargo-shaped workspace (not single-file)
#       (d) ace + LSP + hash-resolution tooling out
#           of the box
#
# UPSTREAM:
#   * Site               : https://rune-rs.github.io
#   * Book               : https://rune-rs.github.io/book/
#   * Source             : https://github.com/rune-rs/rune
#   * CLI crate          : https://crates.io/crates/rune-cli
#   * Discord            : https://discord.gg/v5AeNkT
#   * License            : MIT OR Apache-2.0
#
# INSTALL:
#   cargo install --locked rune-cli
#
#   # Or from a checkout:
#   cargo run --bin rune -- run scripts/hello_world.rn
#
# USAGE EXAMPLES:
#
#   # Run a script
#   rune run scripts/hello_world.rn
#
#   # Run with detailed instruction trace
#   rune run scripts/hello.rn --trace --dump
#
#   # Run a workspace binary by name
#   rune run --workspace --bin my-tool
#
#   # Check (parse + typecheck) without executing
#   rune check src/main.rn
#
#   # Run all tests in the workspace
#   rune test --workspace --all-targets
#
#   # Run only tests whose name matches a pattern
#   rune test --workspace -- some_test_name
#
#   # Benchmarks with custom warmup + iterations
#   rune bench --workspace --warmup 10 --iter 20
#
#   # Format the workspace, fail if any file needed changes
#   rune fmt --workspace --check
#
#   # Build HTML docs and open in browser
#   rune doc --workspace --output target/doc --open
#
#   # Emit Ace editor autocompletion JS
#   rune ace --workspace --output ./ace-ext --extensions
#
#   # Speak LSP over stdio
#   rune languageserver
#
#   # Print a hash for an item path (debugging host code)
#   rune hash std::vec::Vec
#
#   # Generate a random hash, 5 of them
#   rune hash --random --count 5
#
#   # Set a compiler option (see --list-options for keys)
#   rune run script.rn -O byte-code=true
#
#   # List compiler options
#   rune check --list-options
#
#   # Recursive load of a directory as a build root
#   rune check -R ./src
#
#   # Pick a specific package in a workspace
#   rune run -p my-pkg --bin my-bin
#
# OPTIONS (sourced directly from
# https://github.com/rune-rs/rune/tree/main/crates/rune/src/cli):
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _rune_commands
_rune_commands=(
    'check:Run checks but do not execute'
    'doc:Build documentation'
    'ace:Build ace editor autocompletion'
    'test:Run all tests but do not execute (use bare run otherwise)'
    'bench:Run the given program as a benchmark'
    'run:Run the designated script'
    'fmt:Format the provided file'
    'languageserver:Run a language server speaking LSP over stdio'
    'hash:Helper command to generate type hashes'
)

local -a _rune_color_choices
_rune_color_choices=(
    'always:always emit colored output'
    'ansi:emit colored output using ANSI escapes regardless of terminal'
    'auto:detect terminal and emit color if stdin is a TTY (default)'
    'never:never emit colored output'
)

_rune_shared_args=(
    '(- *)--version[print the version of the command]'
    '(-C --color)'{-C+,--color=}'[control if output is colored]:choice:->color'
    '(-R --recursive)'{-R,--recursive}'[recursively load all files if a build path is a directory]'
    '--warnings[display warnings]'
    '--verbose[display verbose output]'
    '--workspace[use a workspace manifest to resolve assets]'
    '*-O+[set the given compiler option (key=value, see --list-options)]:compiler option: '
    '--list-options[list available compiler options]'
    '--bin=[Rune.toml binary asset name]:bin name: '
    '--lib=[Rune.toml library asset name]:lib name: '
    '--test=[Rune.toml test asset name]:test name: '
    '--example=[Rune.toml example asset name]:example name: '
    '--bench=[Rune.toml bench asset name]:bench name: '
    '(-p --package)'{-p+,--package=}'[Rune.toml workspace package name]:package: '
    '--all-targets[include all targets relevant to current command]'
    '*--path=[extra paths to use as build inputs]:path:_files'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[print version]' \
    '(-C --color)'{-C+,--color=}'[control colored output]:choice:->color' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    color)
        _describe -t colors 'color choice' _rune_color_choices && ret=0
        ;;
    command)
        _describe -t commands 'rune command' _rune_commands && ret=0
        ;;
    args)
        case $line[1] in
            check)
                _arguments -C \
                    "${_rune_shared_args[@]}" \
                    '--warnings-are-errors[exit non-zero even for warnings]' \
                    '*:Rune source path:_files -g "*.rn"' \
                    && ret=0
                ;;
            doc)
                _arguments -C \
                    "${_rune_shared_args[@]}" \
                    '--warnings-are-errors[exit non-zero even for warnings]' \
                    '--output=[output directory to write documentation to]:dir:_files -/' \
                    '--open[open the generated documentation in a browser]' \
                    '*:Rune source path:_files -g "*.rn"' \
                    && ret=0
                ;;
            ace)
                _arguments -C \
                    "${_rune_shared_args[@]}" \
                    '--output=[output directory to write ace extensions to]:dir:_files -/' \
                    '--extensions[generate .await and ? extension for functions]' \
                    '--no-mode[do not include rune-mode.js]' \
                    '--warnings-are-errors[exit non-zero even for warnings]' \
                    '*:Rune source path:_files -g "*.rn"' \
                    && ret=0
                ;;
            test)
                _arguments -C \
                    "${_rune_shared_args[@]}" \
                    '--warnings-are-errors[exit non-zero even for warnings]' \
                    '(-q --quiet)'{-q,--quiet}'[display one character per test instead of one line]' \
                    '--fail-fast[break on the first test failed]' \
                    '--skip-lib-tests[skip building dynamic lib tests from entrypoints]' \
                    '--filter=[filter tests by name]:pattern: ' \
                    '*:Rune source path:_files -g "*.rn"' \
                    && ret=0
                ;;
            bench)
                _arguments -C \
                    "${_rune_shared_args[@]}" \
                    '--warmup=[rounds of warmup to perform]:rounds: ' \
                    '--iter=[iterations to run of the benchmark]:iters: ' \
                    '*:Rune source path:_files -g "*.rn"' \
                    && ret=0
                ;;
            run)
                _arguments -C \
                    "${_rune_shared_args[@]}" \
                    '(-t --trace)'{-t,--trace}'[provide detailed tracing for each instruction executed]' \
                    '--without-source[when tracing, do not include source references]' \
                    '--time[time how long the script took to execute]' \
                    '(-d --dump)'{-d,--dump}'[perform a default dump]' \
                    '--dump-return[dump return value]' \
                    '--dump-all[dump everything available (very verbose)]' \
                    '--dump-unit[dump default information about unit]' \
                    '--dump-constants[dump constants from the unit]' \
                    '--emit-instructions[dump unit instructions]' \
                    '--dump-stack[dump the state of the stack after completion]' \
                    '--dump-functions[dump dynamic functions]' \
                    '--dump-types[dump dynamic types]' \
                    '--dump-native-functions[dump native functions]' \
                    '--dump-native-types[dump native types]' \
                    '--experimental[enable experimental language features]' \
                    '*:Rune source path:_files -g "*.rn"' \
                    && ret=0
                ;;
            fmt)
                _arguments -C \
                    "${_rune_shared_args[@]}" \
                    '--warnings-are-errors[exit non-zero even for warnings]' \
                    '--check[check formatting; non-zero exit if changes needed]' \
                    '*:Rune source path:_files -g "*.rn"' \
                    && ret=0
                ;;
            languageserver)
                _arguments -C \
                    '--version[print version]' \
                    '(-C --color)'{-C+,--color=}'[control colored output]:choice:->color' \
                    && ret=0
                ;;
            hash)
                _arguments -C \
                    '--random[generate a random hash]' \
                    '--count=[when generating random hashes, generate the given number]:n: ' \
                    '*:item path: ' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
