#compdef scstadmin
# Documentation: https://github.com/SCST-project/scst/blob/master/scstadmin/scstadmin.sysfs/scstadmin
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# scstadmin: SCST (SCSI Target Subsystem for Linux) admin tool
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-help[show help]' \
  '-config=[apply configuration from file]:file:_files' \
  '-check_config=[validate configuration file]:file:_files' \
  '-write_config=[save current settings to file]:file:_files' \
  '-clear_config[reset all SCST configuration]' \
  '-list_handler[display available handlers]' \
  '-list_device[show open devices]' \
  '-list_dgrp[list device groups]' \
  '-list_tgrp[list target groups]' \
  '-list_driver[list available drivers]' \
  '-list_target[list targets]' \
  '-list_group[list configured groups]' \
  '-list_sessions[display active initiator sessions]' \
  '-list_scst_attr[list SCST attributes]' \
  '-list_hnd_attr[list handler attributes]' \
  '-list_dev_attr[list device attributes]' \
  '-list_dgrp_attr[list device group attributes]' \
  '-list_tgrp_attr[list target group attributes]' \
  '-list_ttgt_attr[list target-group target attributes]' \
  '-list_drv_attr[list driver attributes]' \
  '-list_tgt_attr[list target attributes]' \
  '-list_grp_attr[list group attributes]' \
  '-list_lun_attr[list LUN attributes]' \
  '-list_init_attr[list initiator attributes]' \
  '-set_scst_attr[set SCST attribute]' \
  '-set_hnd_attr[set handler attribute]' \
  '-set_dev_attr[set device attribute]' \
  '-set_dgrp_attr[set device-group attribute]' \
  '-set_tgrp_attr[set target-group attribute]' \
  '-set_ttgt_attr[set target-group target attribute]' \
  '-set_drv_attr[set driver attribute]' \
  '-set_tgt_attr[set target attribute]' \
  '-set_grp_attr[set group attribute]' \
  '-set_lun_attr[set LUN attribute]' \
  '-set_init_attr[set initiator attribute]' \
  '-add_drv_attr[add dynamic driver attribute]' \
  '-add_tgt_attr[add dynamic target attribute]' \
  '-rem_drv_attr[remove dynamic driver attribute]' \
  '-rem_tgt_attr[remove dynamic target attribute]' \
  '-open_dev[open device]' \
  '-close_dev[close device]' \
  '-resync_dev[resync device size]' \
  '-add_dgrp[add device group]' \
  '-rem_dgrp[remove device group]' \
  '-add_dgrp_dev[add device to device group]' \
  '-rem_dgrp_dev[remove device from device group]' \
  '-add_tgrp[add target group]' \
  '-rem_tgrp[remove target group]' \
  '-add_tgrp_tgt[add target to target group]' \
  '-rem_tgrp_tgt[remove target from target group]' \
  '-add_target[add target to driver]' \
  '-rem_target[remove target from driver]' \
  '-enable_target[enable target]' \
  '-disable_target[disable target]' \
  '-add_group[add security group]' \
  '-rem_group[remove security group]' \
  '-add_init[add initiator to group]' \
  '-rem_init[remove initiator from group]' \
  '-move_init[move initiator between groups]' \
  '-clear_inits[clear initiators from group]' \
  '-add_lun[add LUN to group/target]' \
  '-rem_lun[remove LUN]' \
  '-replace_lun[replace LUN]' \
  '-clear_luns[clear all LUNs]' \
  '-issue_lip[issue LIP]' \
  '-lip[enable LIP]' \
  '-no_lip[disable LIP]' \
  '-handler=[handler name]:handler:' \
  '-attributes=[attribute list (p=v,...)]:attributes:' \
  '-driver=[driver name]:driver:' \
  '-target=[target name]:target:' \
  '-group=[group name]:group:' \
  '-to=[destination group]:group:' \
  '-device=[device name]:device:' \
  '-dev_group=[device group]:group:' \
  '-tgt_group=[target group]:group:' \
  '-nonkey[include non-key attributes in output]' \
  '-force[override safety checks]' \
  '-noprompt[suppress confirmations]' \
  '-cont_on_err[continue despite errors]' \
  '-debug[dry-run mode]' && ret=0

return ret
