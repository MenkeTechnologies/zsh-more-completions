#compdef sbigtopgm
# Documentation: man sbigtopgm (Netpbm)
# Source: convert an SBIG CCD camera image to PGM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:sbig file:_files' \
    && ret=0

return ret
