#compdef systemd-localed
# _systemd-localed (systemd locale + keymap configuration daemon backing localectl(1); reads /etc/locale.conf and /etc/vconsole.conf to expose locale/keymap settings over the system bus; daemon binary accepts only standard systemd unit args)
# upstream: https://github.com/systemd/systemd (src/locale)
# Argument shape from systemd src/locale/localed.c on tip.

_systemd-localed() {
    _arguments \
        '--help[show help]' \
        '--version[show version]'
}

_systemd-localed "$@"
