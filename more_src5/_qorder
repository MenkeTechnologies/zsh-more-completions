#compdef qorder
# Documentation: https://docs.adaptivecomputing.com/torque/4-0-2/Content/topics/commands/qorder.htm
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# qorder: swap the order of two PBS jobs in a queue.
# Synopsis: qorder job_identifier1 job_identifier2  -- no flags.

local ret=1
_arguments \
  '1:job_identifier1:' \
  '2:job_identifier2:' && ret=0
return ret
