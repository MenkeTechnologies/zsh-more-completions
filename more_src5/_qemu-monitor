#compdef qemu-monitor
# _qemu-monitor — QEMU monitor helper (shell wrapper used by some distros to connect to the QEMU human / QMP monitor on a running VM; -s socket path or chardev, -j JSON output, -p protocol (qmp|hmp), -c run a single command then exit; positional command sent to monitor when -c not used)
# upstream: https://gitlab.com/qemu-project/qemu (qemu-monitor wrapper)
# Common flag surface verified from distro qemu-monitor scripts on tip.

_qemu-monitor() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-s+[socket]:file:_files' \
        '-p+[protocol]:proto:(qmp hmp)' \
        '-j[json output]' \
        '-c+[command then exit]:command:' \
        '*::command:'
}

_qemu-monitor "$@"
