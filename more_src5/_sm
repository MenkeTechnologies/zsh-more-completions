#compdef sm
# Documentation: man sm(8)
# Source: InterNetNews/inn frontends/sm.c — innstorage manager interface (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-c[clear cached storage info]' \
    '(-d -r)-d[delete the article]' \
    '(-d -r)-r[delete the article (alias)]' \
    '-H[only retrieve headers]' \
    '-i[print article storage info (token, group, art#)]' \
    '-q[quiet (no warn/die messages)]' \
    '-R[raw mode]' \
    '-S[output in rnews batch format]' \
    '-s[store articles from stdin]' \
    '*:token:_default' \
    && ret=0

return ret
