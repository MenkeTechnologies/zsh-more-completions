#compdef superstream-kafka-analyzer
# =============================================================================
# superstream-kafka-analyzer — superstreamlabs's
#   Node.js INTERACTIVE CLI that connects to a
#   running APACHE KAFKA / Confluent Cloud / AWS
#   MSK / Aiven / etc. cluster, fetches its
#   topic + partition + broker + consumer-group
#   metadata, audits the cluster's CONFIGURATION
#   against industry best-practice rules
#   (replication factor, min.insync.replicas,
#   uncommitted-leader semantics, segment
#   sizing, ACL hygiene, etc.) and emits a
#   structured HEALTH REPORT.  Built on top of
#   the pure-JS `kafkajs` v2.2.4 Kafka client +
#   Confluent's `@confluentinc/kafka-javascript`
#   v1.0.0 hybrid client.  TS-Node=102 leader
#   bump CLOSING Axis 47 (Apache Kafka Client)
#   at 1/1/1 three-language symmetry.
#
# AXIS 47 — APACHE KAFKA CLIENT — CLOSES @ R779
# =============================================
# Closes the three-language Kafka-client axis at
# 1/1/1 symmetry:
#   * Rust       (R777): rdkafka 0.37
#                — librdkafka FFI shim, async via
#                  tokio.  Bundled in `kafka-
#                  delta-ingest` (Delta Lake
#                  ingest daemon)
#   * Go         (R778): IBM/sarama v1.45.2
#                — pure-Go Kafka protocol
#                  implementation.  Bundled in
#                  `wal-listener` (PG WAL →
#                  Kafka/NATS/RabbitMQ/PubSub
#                  publisher)
#   * TS-Node    (R779, THIS ROUND): kafkajs v2.2.4
#                — pure-JS Kafka protocol
#                  implementation, no librdkafka
#                  FFI.  Bundled in `superstream-
#                  kafka-analyzer` (interactive
#                  cluster health auditor)
#
# kafkajs (tulios/kafkajs) is the canonical
# pure-JavaScript Kafka client in the Node
# ecosystem — npm package `kafkajs`, 3.6k+ stars
# on GitHub, MIT-licensed.  Distinguishes from:
#   - `@confluentinc/kafka-javascript`  — Confluent's
#                                         hybrid native-
#                                         binding +
#                                         pure-JS shim
#                                         (FFI to
#                                         librdkafka on
#                                         install)
#   - `node-rdkafka`                    — older
#                                         librdkafka FFI
#                                         binding,
#                                         install-time
#                                         C++ build
#                                         requirement
#   - `kafka-node`                      — older pure-JS,
#                                         less actively
#                                         maintained,
#                                         missing
#                                         transactions
#                                         + idempotent
#                                         producer
#
# This entry uses both kafkajs (PRIMARY) and
# @confluentinc/kafka-javascript (FALLBACK FOR
# CONFLUENT-CLOUD-SPECIFIC AUTH) — package.json
# direct deps:
#   "kafkajs": "^2.2.4"
#   "@confluentinc/kafka-javascript": "^1.0.0"
#
# Distinguishing superstream-kafka-analyzer from
# other corpus Kafka tools (e.g. R777
# kafka-delta-ingest is a DAEMON not auditor;
# R778 wal-listener is a CDC PUBLISHER not
# auditor; existing _kaf, _kafkactl, _kt,
# _kafkacat, _kcat are GENERIC PRODUCER/CONSUMER
# CLIs; _confluent is the Confluent Cloud admin
# CLI not a health auditor; _kafka-topics et al.
# are the JVM-shipped admin scripts) by:
#   - INTERACTIVE WIZARD MODE — inquirer-driven
#     TTY prompts walk the operator through
#     broker selection, auth type (SASL/PLAIN,
#     SASL/SCRAM-SHA-256, SASL/SCRAM-SHA-512,
#     SASL/OAUTHBEARER, SASL/AWS_MSK_IAM, TLS
#     client cert), and report destination
#     (local files vs NATS publish).  No
#     headless-only mode — meant for an SRE
#     debugging session
#   - HEALTH-CHECK RULE ENGINE — the audit
#     comprises a fixed set of best-practice
#     rules.  Each rule has a SEVERITY (info,
#     warn, error, critical), a DESCRIPTION,
#     and a remediation HINT.  Output rolls up
#     into a per-topic score + a cluster-level
#     score
#   - AWS MSK + IAM SUPPORT — `aws-msk-iam-
#     sasl-signer-js` direct dep + `@aws-sdk/
#     signature-v4` enables SASL/AWS_MSK_IAM
#     auth against MSK without manual SigV4
#     signing.  AWS credentials resolved via
#     standard `@aws-sdk/credential-providers`
#     chain (env vars, instance metadata,
#     EKS pod identity, SSO, etc.)
#   - CONFLUENT CLOUD OAUTH — `simple-oauth2`
#     + `jwks-rsa` + `jsonwebtoken` deps
#     enable OAUTHBEARER auth against
#     Confluent Cloud's IDP — bearer tokens
#     auto-refreshed against the JWKS
#     endpoint
#   - NATS PUBLISH BACKEND — `--nats-config
#     <path>` switches the report destination
#     from local files to a NATS subject.
#     Direct `nats` v2.19.0 dep.  Useful when
#     plumbing audits into a Superstream-
#     orchestrated control plane
#   - CONFIG VALIDATION via joi — `joi`
#     v17.11 enforces the cluster-config YAML
#     schema before connection, catching typos
#     (e.g. `boostrap_servers` instead of
#     `bootstrap_servers`) before any broker
#     round-trip
#   - DOTENV — `.env` file auto-loaded via
#     `dotenv` v16.3 — auth secrets / cluster
#     endpoints can live outside the YAML
#     config
#   - ORA SPINNERS + CHALK COLOURS — long-
#     running phases (broker metadata fetch,
#     topic enumeration, ACL replay) show
#     animated spinners with structured
#     phase names — ora v5.4 + chalk v4.1
#
# CRITICAL DIRECT DEPENDENCIES (from package.json):
#   - kafkajs ^2.2.4
#                              — PRIMARY Kafka
#                                client; pure JS,
#                                no native build
#                                requirement
#                                [AXIS 47 LIBRARY]
#   - @confluentinc/kafka-javascript ^1.0.0
#                              — secondary
#                                Confluent-Cloud-
#                                aware Kafka
#                                client
#   - @aws-sdk/client-kafka ^3.835.0
#                              — AWS MSK control-
#                                plane API
#                                (DescribeCluster,
#                                ListClusters, etc.)
#   - @aws-sdk/credential-providers ^3.835.0
#                              — AWS credential
#                                resolution chain
#   - @aws-sdk/signature-v4 ^3.370.0
#                              — SigV4 signer for
#                                IAM-authenticated
#                                MSK requests
#   - aws-msk-iam-sasl-signer-js ^1.0.0
#                              — SASL/AWS_MSK_IAM
#                                token generator
#   - simple-oauth2 ^5.1.0     — OAUTHBEARER token
#                                acquisition
#                                (Confluent Cloud)
#   - jsonwebtoken ^9.0.2      — JWT decoding for
#                                token-claim
#                                introspection
#   - jwks-rsa ^3.1.0          — JWKS public-key
#                                fetcher
#   - nats ^2.19.0             — NATS publish
#                                backend
#   - commander ^11.1.0        — CLI argument
#                                parser (program.
#                                option() surface)
#   - inquirer ^8.2.4          — interactive
#                                prompts
#   - joi ^17.11.0             — config schema
#                                validation
#   - chalk ^4.1.2             — terminal colour
#   - ora ^5.4.1               — terminal spinners
#   - axios ^1.7.2             — REST calls to
#                                Confluent Cloud +
#                                MSK admin APIs
#   - dotenv ^16.3.1           — .env loader
#
# Node 16+ MSRV per package.json `engines.node
# = ">=16.0.0"`.
#
# UPSTREAM:
#   * Source             : https://github.com/superstreamlabs/kafka-analyzer
#   * npm package        : https://www.npmjs.com/package/superstream-kafka-analyzer
#   * kafkajs            : https://github.com/tulios/kafkajs
#   * Confluent Kafka JS : https://github.com/confluentinc/confluent-kafka-javascript
#   * License            : MIT
#   * Maintainer         : Superstream Labs (superstream.ai)
#
# INSTALL:
#   # Global npm install — installs the
#   # `superstream-kafka-analyzer` binary
#   npm install -g superstream-kafka-analyzer
#
#   # Or npx
#   npx superstream-kafka-analyzer --help
#
#   # Or pin in a project
#   npm install superstream-kafka-analyzer
#
# USAGE EXAMPLES:
#
#   # Interactive mode — wizard prompts for
#   # broker + auth + report destination
#   superstream-kafka-analyzer
#
#   # Connect to a Kafka cluster directly via
#   # bootstrap-servers flag (still interactive
#   # for auth)
#   superstream-kafka-analyzer \
#       -b broker1:9092,broker2:9092
#
#   # Use a YAML config file
#   superstream-kafka-analyzer \
#       -c ./cluster.yml
#
#   # Use a config file AND publish report to NATS
#   superstream-kafka-analyzer \
#       -c ./cluster.yml \
#       --nats-config ./nats.yml
#
#   # Verbose logging (shows kafkajs debug events,
#   # full stack traces on errors)
#   superstream-kafka-analyzer \
#       -c ./cluster.yml \
#       -v
#
#   # Longer connect timeout for high-latency
#   # cross-region links (default 30s)
#   superstream-kafka-analyzer \
#       -b broker.eu-west-1.example.com:9094 \
#       -t 120
#
#   # Print version
#   superstream-kafka-analyzer --version
#
#   # Help
#   superstream-kafka-analyzer --help
#
# OPTIONS (sourced directly from
# https://github.com/superstreamlabs/kafka-analyzer/blob/main/bin/index.js):
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '(-c --config)'{-c+,--config=}'[path to YAML configuration file]:config:_files -g "*.(yml|yaml|json)"' \
    '--nats-config=[path to NATS configuration file (uploads report to NATS instead of files)]:nats config:_files -g "*.(yml|yaml|json)"' \
    '(-b --bootstrap-servers)'{-b+,--bootstrap-servers=}'[comma-separated list of Kafka bootstrap servers]:host:port,host:port,...: ' \
    '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
    '(-t --timeout)'{-t+,--timeout=}'[connection timeout in seconds (default 30)]:seconds: ' \
    && ret=0

return ret
