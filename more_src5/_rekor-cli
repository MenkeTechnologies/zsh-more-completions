#compdef rekor-cli
# Documentation: https://github.com/sigstore/rekor/tree/main/cmd/rekor-cli
# Reference accessed: 2026-05-20
# Verified: upstream rekor-cli root.go at the URL above.
# Added documented persistent globals --config/--store_tree_state/
# --timeout/--retry that were missing from prior file.

# Zsh completion for rekor-cli - Rekor transparency log CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--config=[config file]:file:_files' \
  '--store_tree_state[store tree state between invocations]' \
  '--rekor_server=[Rekor server URL]:URL' \
  '--format=[output format]:format:(json default)' \
  '--timeout=[HTTP timeout]:duration:' \
  '--retry=[number of retry attempts]:count' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'get:get an entry from the log'
      'search:search the log'
      'upload:upload an entry to the log'
      'verify:verify an entry in the log'
      'loginfo:get log information'
      'logproof:get a consistency proof'
      'version:print version'
    )
    _describe -t commands 'rekor-cli command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      get)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--rekor_server=[Rekor server URL]:URL' \
          '--format=[output format]:format:(json default)' \
          '--uuid=[entry UUID]:UUID' \
          '--log-index=[log index]:index' && ret=0
        ;;
      search)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--rekor_server=[Rekor server URL]:URL' \
          '--format=[output format]:format:(json default)' \
          '--pki-format=[PKI format]:format:(x509 minisign ssh pgp)' \
          '--artifact=[path to artifact]:artifact:_files' \
          '--public-key=[path to public key]:key:_files' \
          '--sha=[SHA hash of artifact]:sha' \
          '--email=[email address to search for]:email' \
          '--operator=[search operator]:operator:(and or)' && ret=0
        ;;
      upload)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--rekor_server=[Rekor server URL]:URL' \
          '--format=[output format]:format:(json default)' \
          '--pki-format=[PKI format]:format:(x509 minisign ssh pgp)' \
          '--artifact=[path to artifact]:artifact:_files' \
          '--signature=[path to signature]:signature:_files' \
          '--public-key=[path to public key]:key:_files' \
          '--entry=[entry JSON file]:file:_files' \
          '--type=[entry type]:type:(rekord hashedrekord intoto jar rfc3161 rpm cose alpine helm tuf dsse)' && ret=0
        ;;
      verify)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--rekor_server=[Rekor server URL]:URL' \
          '--format=[output format]:format:(json default)' \
          '--pki-format=[PKI format]:format:(x509 minisign ssh pgp)' \
          '--artifact=[path to artifact]:artifact:_files' \
          '--signature=[path to signature]:signature:_files' \
          '--public-key=[path to public key]:key:_files' \
          '--entry=[entry JSON file]:file:_files' \
          '--type=[entry type]:type' \
          '--uuid=[entry UUID]:UUID' \
          '--log-index=[log index]:index' && ret=0
        ;;
      loginfo)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--rekor_server=[Rekor server URL]:URL' \
          '--format=[output format]:format:(json default)' && ret=0
        ;;
      logproof)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--rekor_server=[Rekor server URL]:URL' \
          '--format=[output format]:format:(json default)' \
          '--first-size=[first tree size]:size' \
          '--last-size=[last tree size]:size' \
          '--tree-id=[tree ID]:id' && ret=0
        ;;
      *)
        _arguments -s -S '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
