#compdef sensors-conf-convert
# Documentation: man sensors-conf-convert(8)
# Source: lm-sensors/lm-sensors etc/sensors-conf-convert (master) — convert old sensors.conf to new format (Perl -pi).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '*:sensors.conf file:_files -g "sensors.conf*"' \
    && ret=0

return ret
