#compdef slot
# _slot — Cartridge slot CLI for managing Katana service deployments and Starknet ephemeral infrastructure (cartridge-gg team, Rust); clap-derive
# upstream: https://github.com/cartridge-gg/slot

_slot() {
    local -a sub=(
        'auth:authentication subcommands'
        'deployments:deployment subcommands'
        'create:create a deployment'
        'delete:delete a deployment'
        'list:list deployments'
        'describe:describe a deployment'
        'update:update a deployment'
        'logs:show deployment logs'
        'transfer:transfer ownership'
        'fork:fork a deployment'
        'paymaster:paymaster subcommands'
        'controller:controller subcommands'
        'completions:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--api-url=+[api url]:url:_urls' \
        '--team=+[team name]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'slot subcommand' sub ;;
        args)
            case $words[1] in
                auth) _arguments '1:auth cmd:(login logout info)' ;;
                deployments|create|delete|list|describe|update|logs|fork) _arguments \
                    '--service=+[service]:s:(katana torii saya madara madara-rpc anvil tracer)' \
                    '--version=+[image version]:str:' \
                    '--region=+[region]:r:(us-east1 us-west1 europe-west1 asia-east1)' \
                    '--tier=+[tier]:t:(basic common pro elite epic)' \
                    '*:project:' ;;
                paymaster) _arguments '1:paymaster cmd:(create list delete update show fund)' ;;
                controller) _arguments '1:controller cmd:(list create delete describe)' ;;
                completions) _arguments '1:shell:(bash zsh fish elvish powershell)' ;;
            esac
            ;;
    esac
}

_slot "$@"
