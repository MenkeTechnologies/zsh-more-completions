#compdef rosnode
# Documentation: http://wiki.ros.org/rosnode
# Source: ros/ros_comm noetic-devel tools/rosnode/src/rosnode/__init__.py — ROS1 node management CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '1:subcommand:((
        ping\:"test connectivity to node"
        list\:"list active nodes"
        info\:"print information about node"
        machine\:"list nodes on a machine, or list machines"
        kill\:"kill a running node"
        cleanup\:"purge unreachable nodes from master"
    ))' \
    '*::args:_default' \
    && ret=0

return ret
