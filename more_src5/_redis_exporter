#compdef redis_exporter
# Documentation: https://github.com/oliver006/redis_exporter
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--web.listen-address=[address to listen on]:address:' \
  '--web.telemetry-path=[path for metrics]:path:' \
  '--log.level=[log level]:level:(debug info warn error)' \
  '--log.format=[log format]:format:(logfmt json)' \
  '--redis.addr=[address of the Redis instance]:address:' \
  '--redis.password=[password of the Redis instance]:password:' \
  '--redis.password-file=[path to file containing the Redis password]:file:_files' \
  '--redis.user=[user for Redis ACL authentication]:user:' \
  '--namespace=[namespace for metrics]:namespace:' \
  '--check-keys=[comma-separated list of key patterns to export]:patterns:' \
  '--check-single-keys=[comma-separated list of single keys to export]:keys:' \
  '--check-streams=[comma-separated list of stream key patterns to export]:patterns:' \
  '--check-single-streams=[comma-separated list of single stream keys to export]:keys:' \
  '--check-keys-batch-size=[batch size for key checks]:size:' \
  '--count-keys=[comma-separated list of key patterns to count]:patterns:' \
  '--script=[comma-separated list of Lua scripts to run]:scripts:_files' \
  '--debug[enable debug output]' \
  '--connection-timeout=[timeout for connecting to Redis]:duration:' \
  '--tls-client-key-file=[client key file for mutual TLS]:file:_files' \
  '--tls-client-cert-file=[client cert file for mutual TLS]:file:_files' \
  '--tls-ca-cert-file=[CA cert file for TLS]:file:_files' \
  '--tls-server-key-file=[server key file for TLS]:file:_files' \
  '--tls-server-cert-file=[server cert file for TLS]:file:_files' \
  '--tls-server-ca-cert-file=[server CA cert file for TLS]:file:_files' \
  '--is-tile38[connect to a Tile38 instance]' \
  '--is-cluster[connect to a Redis cluster]' \
  '--export-client-list[export client list metrics]' \
  '--export-client-port[export client port metrics]' \
  '--skip-tls-verification[skip TLS certificate verification]' \
  '--redis-only-metrics[export only Redis metrics without exporter metrics]' \
  '--ping-on-connect[ping Redis on connect]' \
  '--set-client-name[set a client name on the Redis connection]' && ret=0

return ret
