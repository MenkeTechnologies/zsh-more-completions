#compdef recdel
# Documentation: https://www.gnu.org/software/recutils/
# Reference accessed: 2026-06-10

# Zsh completion for recdel (GNU Recutils)

_arguments -s -S \
  '-t+[select record type]:record type:' \
  '-e+[selection expression]:expression:' \
  '-n+[record number to delete]:record number:' \
  '-c[comment out records instead of deleting]' \
  '-i[case-insensitive matching]' \
  '--force[force operation even if errors exist]' \
  '--no-auto[do not generate auto fields]' \
  '--verbose[print verbose output]' \
  '*:file:_files'
