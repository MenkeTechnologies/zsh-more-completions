#compdef sfbandpass
# Documentation: http://www.ahay.org/RSF/sfbandpass.html
# Source: ahay/src system/generic/Mbandpass.c — Butterworth bandpass filter.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'flo=[low cutoff frequency (default 0)]: :_default' \
    'fhi=[high cutoff frequency (default Nyquist)]: :_default' \
    'phase=[(y/n) minimum-phase (y) vs zero-phase (n)]: :(y n)' \
    'verb=[(y/n) verbose]: :(y n)' \
    'nplo=[number of poles for low cutoff]: :_default' \
    'nphi=[number of poles for high cutoff]: :_default' \
    '*:RSF file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
