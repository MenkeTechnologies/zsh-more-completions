#compdef qiskit-nature qnat
# _qiskit-nature — IBM Qiskit Nature module for quantum-chemistry electronic structure and condensed-matter calculations on quantum computers (qiskit-community team, Python); argparse
# upstream: https://github.com/qiskit-community/qiskit-nature

_qiskit-nature() {
    local -a sub=(
        'simulate:run quantum chemistry simulation'
        'solve:solve electronic structure problem'
        'vqe:run VQE algorithm'
        'adapt-vqe:run ADAPT-VQE'
        'qpe:run Quantum Phase Estimation'
        'pds:run perturbative drug screening'
        'mapper:fermionic-to-qubit mapping'
        'driver:driver subcommands'
        'molecule:molecule subcommands'
        'lattice:lattice subcommands'
        'transformer:transformer subcommands'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--driver=+[driver]:d:(pyscf psi4 qiskit_nature_pyscf gaussian psi4 sto-3g 6-31g cc-pvdz)' \
        '--basis=+[basis set]:b:(sto-3g sto-6g 6-31g 6-31g* 6-311g cc-pvdz cc-pvtz cc-pvqz cc-pv5z aug-cc-pvdz def2-svp def2-tzvp def2-qzvp)' \
        '--method=+[method]:m:(rhf uhf rohf rks uks roks mp2 ccsd ccsdt fci casci casscf scf)' \
        '--charge=+[N]:n:' \
        '--spin=+[N]:n:' \
        '--mapper=+[mapper]:m:(JordanWigner ParityMapper BravyiKitaev BravyiKitaevSuperFast LinearMapper LogarithmicMapper)' \
        '--two-qubit-reduction[two qubit reduction]' \
        '--num-orbitals=+[N]:n:' \
        '--num-electrons=+[N]:n:' \
        '--initial-point=+[strategy]:s:(zeros random fixed_value mp2_t2_amplitudes hf_initial_point)' \
        '--ansatz=+[ansatz]:a:(UCCSD UCC PUCCD SUCCD HVA EvolutionaryAnsatz EfficientSU2 PauliTwoDesign)' \
        '--optimizer=+[optimizer]:o:(SLSQP L_BFGS_B COBYLA Powell SPSA NFT NELDER_MEAD CG ADAM)' \
        '--max-iter=+[N]:n:' \
        '--shots=+[shots]:n:' \
        '--seed=+[seed]:n:' \
        '--backend=+[backend]:str:' \
        '--no-progress-bar[no progress bar]' \
        '--verbose[verbose]' \
        '-V[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'qiskit-nature subcommand' sub ;;
        args)
            case $words[1] in
                simulate|solve|vqe|adapt-vqe|qpe) _arguments \
                    '*:molecule file:_files -g "*.xyz *.mol *.pdb *.json *.yaml"' ;;
                driver) _arguments '1:driver cmd:(list pyscf psi4 gaussian)' ;;
                molecule) _arguments '1:molecule cmd:(load show convert)' ;;
                lattice) _arguments '1:lattice cmd:(hyper hubbard ising heisenberg fermi-hubbard line square triangular hexagonal)' ;;
                transformer) _arguments '1:transformer cmd:(freeze-core active-space symmetry-reduction)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_qiskit-nature "$@"
