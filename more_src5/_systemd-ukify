#compdef systemd-ukify
# _systemd-ukify — build and inspect Unified Kernel Images
# upstream: https://github.com/systemd/systemd (src/ukify)

_systemd_ukify() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'build:build a UKI'
                'genkey:generate keys for signing'
                'inspect:inspect a UKI'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                build)
                    _arguments \
                        '--linux=[Linux kernel image]:file:_files' \
                        '--initrd=[initrd image]:file:_files' \
                        '--cmdline=[kernel command line]:cmdline:' \
                        '--os-release=[os-release file]:file:_files' \
                        '--devicetree=[device tree blob]:file:_files' \
                        '--splash=[boot splash image]:file:_files' \
                        '--pcrpkey=[PCR public key]:file:_files' \
                        '--uname=[kernel version string]:version:' \
                        '--efi-arch=[EFI architecture]:arch:(x64 ia32 aa64 arm riscv64)' \
                        '--stub=[EFI stub]:file:_files' \
                        '--sbat=[SBAT metadata]:file:_files' \
                        '--section=[additional PE section]:name\:file:' \
                        '--pcr-banks=[PCR hash algorithms]:banks:' \
                        '--pcr-private-key=[PCR signing private key]:file:_files' \
                        '--pcr-public-key=[PCR signing public key]:file:_files' \
                        '--phases=[boot phases for PCR policy]:phases:' \
                        '--secureboot-private-key=[Secure Boot signing key]:file:_files' \
                        '--secureboot-certificate=[Secure Boot certificate]:file:_files' \
                        '--sign-kernel[sign the embedded kernel]' \
                        '--tools=[tool directories]:directory:_directories' \
                        '(-o --output)'{-o,--output=}'[output UKI file]:file:_files' \
                        '--measure[measure and show PCR values]' \
                        '--json=[JSON output mode]:mode:(short pretty off)'
                    ;;
                genkey)
                    _arguments \
                        '--pcr-private-key=[output PCR private key]:file:_files' \
                        '--pcr-public-key=[output PCR public key]:file:_files' \
                        '--secureboot-private-key=[output SB private key]:file:_files' \
                        '--secureboot-certificate=[output SB certificate]:file:_files' \
                        '--common-name=[certificate common name]:name:' \
                        '--valid-days=[certificate validity period]:days:'
                    ;;
                inspect)
                    _arguments \
                        '--json=[JSON output mode]:mode:(short pretty off)' \
                        '1:UKI file:_files'
                    ;;
            esac
            ;;
    esac
}

_systemd_ukify "$@"
