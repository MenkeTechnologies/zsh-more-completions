#compdef sffft1
# Documentation: http://www.ahay.org/RSF/sffft1.html
# Source: ahay/src system/generic/Mfft1.c — 1-D fast Fourier transform along the 1st axis.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'verb=[(y/n) verbose]: :(y n)' \
    'inv=[(y/n) inverse transform]: :(y n)' \
    'sym=[(y/n) symmetric scaling for Hermitian FFT]: :(y n)' \
    'opt=[(y/n) pick optimal size for efficiency]: :(y n)' \
    'ot=[time origin value]: :_default' \
    'memsize=[usable memory (MB, default 1000)]: :_default' \
    '*:RSF file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
