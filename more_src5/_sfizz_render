#compdef sfizz_render
# _sfizz_render — offline render of MIDI → wav via an SFZ patch (sfztools/sfizz)
# upstream: https://github.com/sfztools/sfizz
# Flags from clients/sfizz_render.cpp (cxxopts).

_sfizz_render() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '--sfz=[SFZ file]:file:_files -g "*.sfz"'
        '--midi=[input MIDI file]:file:_files -g "*.{mid,midi}"'
        '--wav=[output WAV file]:file:_files -g "*.wav"'
        '(-b --blocksize)'{-b+,--blocksize=}'[callback block size (samples)]:samples:'
        '(-s --samplerate)'{-s+,--samplerate=}'[output sample rate]:rate:'
        '(-q --quality)'{-q+,--quality=}'[resampling quality (0-10)]:quality:'
        '(-p --polyphony)'{-p+,--polyphony=}'[max polyphony]:n:'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--log=[write rendering logs to file]:file:_files'
        '--use-eot[stop at the last End-of-Track MIDI event]'
    )
    _arguments -s $args
}

_sfizz_render "$@"
