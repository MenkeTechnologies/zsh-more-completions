#compdef rook
# _rook — Rook storage orchestrator (CLI for ceph operator/cleanup/osd/mgr)
# upstream: https://github.com/rook/rook
# Subcommands from cmd/rook/main.go addCommands() on tip.

_rook() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--log-level=[logging level]:level:(ERROR WARNING INFO DEBUG)' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'version:show Rook version'
                'discover:discover storage devices on the host'
                'ceph:Ceph backend commands (operator, osd, mgr, cleanup, config-init)'
                'key-management:KMS subcommands'
                'multus:Multus CNI network helpers'
                'userfacing:user-facing helper subcommands'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                ceph)
                    local -a sub=(
                        'operator:run the Ceph operator'
                        'osd:OSD-related subcommands (init/provision/start/remove)'
                        'mgr:Ceph manager sidecar (watch-active)'
                        'clean:cluster cleanup helpers (host/CephFilesystemSubVolumeGroup/CephBlockPoolRadosNamespace)'
                        'config-init:initialize Ceph config'
                    )
                    _describe -t commands 'ceph subcommand' sub
                    ;;
                discover)
                    _arguments \
                        '--discover-interval=[device discovery interval]:dur:' \
                        '--use-ceph-volume=[use ceph-volume inventory]:bool:(true false)'
                    ;;
            esac
            ;;
    esac
}

_rook "$@"
