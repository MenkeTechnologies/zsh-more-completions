#compdef smithy4s smithy4s-codegen-cli
# ============================================================================
#  _smithy4s — Smithy4s: Disney Streaming's Smithy code generator for Scala
#
#  Source-direct extraction from
#    https://github.com/disneystreaming/smithy4s/blob/main/modules/codegen-cli/src/smithy4s/codegen/cli/Main.scala
#    https://github.com/disneystreaming/smithy4s/blob/main/modules/codegen-cli/src/smithy4s/codegen/cli/CodegenCommand.scala
#    https://github.com/disneystreaming/smithy4s/blob/main/modules/codegen-cli/src/smithy4s/codegen/cli/DumpModelCommand.scala
#    https://github.com/disneystreaming/smithy4s/blob/main/modules/codegen-cli/src/smithy4s/codegen/cli/Options.scala
#    https://github.com/bkirwi/decline (the decline library by Ben Kirwin)
#
#  Maintained by Disney Streaming (disneystreaming/smithy4s).  398
#  GH stars.  Smithy4s is the Smithy code generator for Scala — reads
#  AWS Smithy IDL files (.smithy) and generates type-safe Scala code
#  + OpenAPI specs.  Smithy is AWS's interface definition language
#  for declaring services, operations, structures, and shapes —
#  AWS Lambda, AWS SDK v3, AWS App Mesh, and AWS API Gateway are all
#  defined in Smithy.  Smithy4s makes Scala microservices on http4s
#  and fs2 directly from Smithy specifications.  Sister tools: smithy
#  (AWS Smithy CLI, in corpus via _smithy), smithy-build (Smithy
#  builder), scala-cli (in corpus, also caseapp-based), almond (in
#  corpus, also caseapp-based).
#
#  CLI library taxonomy update: 5th Scala CLI library — Ben Kirwin's
#  **decline** (com.monovore.decline / bkirwi/decline).  Scala
#  ecosystem now has 5 documented CLI libraries (R346 mainargs +
#  R360 scopt + earlier scallop + R370 case-app + R372 decline) —
#  tying Java (5) and OCaml (5) at the third-most-documented tier.
#
#  decline (bkirwi/decline) is Ben Kirwin's FUNCTIONAL APPLICATIVE
#  Scala CLI library — the Scala counterpart to Haskell's
#  optparse-applicative (R270).  Built on top of Cats applicative
#  functors — composes parsers via `(a, b, c).mapN(...)` Cats
#  applicative syntax.  Used by Disney Smithy4s (398 stars),
#  johnynek/bosatsu (Scala-like functional language), windymelt/zmm
#  (markdown-to-video), Constellation-Labs/tessellation (Hypergraph
#  network), input-output-hk/mantis (Ethereum Scala client),
#  scodec/hexdump4s, fosskers/scalaz-and-cats, Iltotore/iron, and
#  many functional Scala tools that prefer functional applicative
#  style over annotation/DSL style.
#
#  decline API:
#    import com.monovore.decline._
#    import cats.implicits._
#
#    val verboseOpt: Opts[Boolean] =
#      Opts.flag("verbose", "Enable verbose output").orFalse
#
#    val outputOpt: Opts[Option[Path]] =
#      Opts.option[Path]("output", "Output file", short = "o", metavar = "FILE")
#        .orNone
#
#    val inputsArg: Opts[List[String]] =
#      Opts.arguments[String]("input").map(_.toList)
#
#    val tagsOpts: Opts[List[String]] =
#      Opts.options[String]("tag", "Tag (repeatable)")
#        .map(_.toList).orEmpty
#
#    val opts: Opts[Args] = (verboseOpt, outputOpt, inputsArg, tagsOpts)
#      .mapN(Args.apply)
#
#    val command = Command("mytool", "Description")(opts)
#
#    def main(args: Array[String]): Unit = {
#      command.parse(args.toList) match {
#        case Left(help)    => System.err.println(help); sys.exit(1)
#        case Right(parsed) => run(parsed)
#      }
#    }
#
#  decline distinctive features:
#    - FUNCTIONAL APPLICATIVE COMBINATOR style (Scala counterpart to
#      Haskell's optparse-applicative — same paradigm, different
#      language)
#    - `Opts[T]` ABSTRACT TYPE — the type of "a parser that produces
#      a T value" — opaque, composable
#    - `Opts.option[T](long, help, short=?, metavar=?)` — declare an
#      OPTION that takes a value (returns `Opts[T]`)
#    - `Opts.options[T](long, help)` — declare a REPEATABLE option
#      (returns `Opts[NonEmptyList[T]]`)
#    - `Opts.flag(long, help)` — boolean FLAG (returns `Opts[Unit]`,
#      compose with `.orFalse`/`.orTrue` for booleans)
#    - `Opts.argument[T](metavar)` — POSITIONAL arg (returns `Opts[T]`)
#    - `Opts.arguments[T]()` — REPEATED POSITIONAL (returns
#      `Opts[NonEmptyList[T]]`)
#    - `Opts.subcommand(cmd)` — NESTED SUBCOMMAND (returns
#      `Opts[A]` for the subcommand's result type)
#    - `Opts.subcommands(cmd1, cmd2, ...)` — multiple subcommands
#    - `.orNone` — make optional → `Opts[Option[T]]`
#    - `.orFalse` / `.orTrue` — boolean defaults for flag Opts
#    - `.orEmpty` — empty default for list Opts → `Opts[List[T]]`
#    - `.map(A => B)` — TRANSFORMATION
#    - `.mapValidated(A => ValidatedNel[String, B])` — VALIDATION
#      with error accumulation (Cats Validated)
#    - `.withDefault(value)` — fallback default
#    - `(a, b, c).mapN(...)` — Cats APPLICATIVE TUPLE COMBINATOR for
#      composing multiple Opts into one
#    - `Argument[T]` TYPECLASS — for custom type parsing; instances
#      provided for `String`, `Int`, `Long`, `Float`, `Double`,
#      `BigInt`, `BigDecimal`, `java.nio.file.Path`, etc.
#    - Custom `Argument[T]` via `new Argument[T] { def defaultMetavar
#      = "..."; def read(s: String) = ValidatedNel[String, T] ... }`
#    - `Command[T](name, header)(opts)` — top-level command definition
#    - `command.parse(args.toList)` — RETURNS `Either[Help, T]`
#      (NO process exit — caller decides what to do with errors)
#    - `Help` rich error/help class with `command.parse` output
#    - `CommandIOApp` base trait (decline-effect module) — for
#      cats-effect IO main entry points
#    - PARSER IS A FIRST-CLASS VALUE — `Opts[T]` and `Command[T]` are
#      ordinary values that can be passed around, stored, composed
#    - PURE FUNCTIONAL — NO MUTATION, NO REFLECTION, NO ANNOTATIONS,
#      NO MACROS (decline is pure Scala — no compile-time macro
#      magic; relies entirely on standard Cats applicative typeclass)
#    - `reduceMapK(Opts.subcommand(_))` Cats helper for combining
#      `NonEmptyList[Command[X]]` into `Opts[X]`
#  Distinct from R346 Scala lihaoyi/mainargs (PARAMETER BINDING via
#  `@main` method parameters), R360 Scala scopt (DSL BUILDER
#  `OptionParser` with chained `.opt[X]("name").action`/`.text`),
#  Scala scallop (DSL with `val opt = opt[X](...)` inside ScallopConf),
#  R370 Scala case-app (ANNOTATION-DRIVEN CASE CLASS DERIVATION with
#  Scala macros), R270 Haskell optparse-applicative (CLOSEST analog —
#  both functional applicative with applicative combinator parsing,
#  but different language; decline is to Scala what optparse-applicative
#  is to Haskell), R275 Rust clap-derive (struct + clap-derive macro),
#  R322 Java JCommander (Java annotations).  decline's approach:
#  FUNCTIONAL APPLICATIVE COMBINATOR + Opts[T] FIRST-CLASS VALUE
#  + Cats `(a, b, c).mapN(...)` APPLICATIVE TUPLE + `Argument[T]`
#  TYPECLASS + `Command[T]` FIRST-CLASS + `Either[Help, T]` RESULT
#  (NO process exit) + NO MUTATION + NO REFLECTION + NO ANNOTATIONS
#  + NO MACROS — corpus's **first documented functional-applicative-
#  for-Scala CLI library**.  Brings cross-language CLI library
#  taxonomy variant count to 111; Scala ecosystem now has 5
#  documented CLI libraries.
#
#  Surface (verbatim from Main.scala + CodegenCommand.scala +
#  DumpModelCommand.scala + Options.scala):
#
#  Subcommands:
#    generate                     Generate Scala code + OpenAPI specs
#                                 from Smithy specs
#    dump-model                   Output JSON view of the Smithy models
#    version                      Show smithy4s version
#
#  Options for `generate` subcommand:
#    -o, --output PATH            Output path for generated Scala code
#                                 (default: pwd)
#    --resource-output PATH       Output path for non-Scala files
#                                 (default: pwd)
#    --skip TYPE                  Skip file types during generation
#                                 (repeatable)
#    --discover-models            Discover models in classpath
#    --allowed-ns NS              Comma-delimited namespaces to process
#                                 (DEPRECATED: use smithy4sCodegen
#                                 metadata key)
#    --excluded-ns NS             Comma-delimited namespaces to exclude
#                                 (DEPRECATED)
#    --repositories REPO          Comma-delimited Maven repositories
#                                 for resolving dependencies
#    --dependencies DEP           Comma-delimited dependencies containing
#                                 smithy files (Maven coords)
#    --transformers NAME          Comma-delimited transformer names
#                                 to apply to smithy files
#    --local-jars JAR             Comma-delimited local JARs with smithy
#                                 files
#    --smithy-build FILE          Path of smithy-build.json file
#    --no-default-repositories    Disable coursier's default repositories
#                                 (Maven Central, ivy2Local)
#    INPUTS...                    Smithy spec file paths (positional,
#                                 0-or-more)
#
#  Options for `dump-model` subcommand:
#    --repositories REPO          Maven repositories (comma-delimited)
#    --dependencies DEP           Dependencies (comma-delimited)
#    --transformers NAME          Transformer names (comma-delimited)
#    --local-jars JAR             Local JARs (comma-delimited)
#    --no-default-repositories    Disable default repositories
#    INPUTS...                    Smithy spec file paths
#
#  Decline built-in flags (always present on every Command):
#    --help                       Show help message
#
#  Dup-skipped neighbors during hunt (in corpus, may also use decline
#  but already documented under different attribution):
#    - bosatsu (johnynek/bosatsu — Scala-like functional language;
#      smaller user base, future round candidate)
#    - zmm (windymelt/zmm — markdown-to-video; smaller user base)
#    - mantis (input-output-hk/mantis — Ethereum Scala client;
#      large project but architecturally heavy)
#    - mdoc (scalameta/mdoc 403 stars — uses moped internally, NOT
#      decline despite being in the same ecosystem)
#    - tessellation (Constellation-Labs/tessellation — Hypergraph
#      network protocol; specialized infrastructure)
# ============================================================================

_smithy4s() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '1: :->cmd' \
    '*:: :->subargs'

  case $state in
    cmd)
      local -a verbs
      verbs=(
        'generate:generate Scala code + OpenAPI specs from Smithy specs'
        'dump-model:output JSON view of the Smithy models'
        'version:show smithy4s version'
        '--help:show help message'
      )
      _describe -t commands 'smithy4s subcommand' verbs
      ;;
    subargs)
      case $line[1] in
        generate)
          _arguments -s -S \
            '(-o --output)'{-o,--output}'=[output path for generated Scala code]:path:_directories' \
            '--resource-output=[output path for non-Scala files]:path:_directories' \
            '*--skip=[skip file types during generation]:type' \
            '--discover-models[discover models in classpath]' \
            '--allowed-ns=[comma-delimited namespaces to process (DEPRECATED)]:namespaces' \
            '--excluded-ns=[comma-delimited namespaces to exclude (DEPRECATED)]:namespaces' \
            '--repositories=[comma-delimited Maven repositories]:repos' \
            '--dependencies=[comma-delimited dependencies (Maven coords)]:deps' \
            '--transformers=[comma-delimited transformer names]:names' \
            '--local-jars=[comma-delimited local JAR files]:jars:_files -g "*.jar"' \
            '--smithy-build=[path of smithy-build.json file]:file:_files -g "*.json"' \
            '--no-default-repositories[disable coursier default repositories]' \
            '--help[show help message]' \
            '*:smithy spec file:_files -g "*.smithy"'
          ;;
        dump-model)
          _arguments -s -S \
            '--repositories=[comma-delimited Maven repositories]:repos' \
            '--dependencies=[comma-delimited dependencies]:deps' \
            '--transformers=[comma-delimited transformer names]:names' \
            '--local-jars=[comma-delimited local JAR files]:jars:_files -g "*.jar"' \
            '--no-default-repositories[disable coursier default repositories]' \
            '--help[show help message]' \
            '*:smithy spec file:_files -g "*.smithy"'
          ;;
        version)
          _arguments '--help[show help message]'
          ;;
      esac
      ;;
  esac
}

_smithy4s "$@"
