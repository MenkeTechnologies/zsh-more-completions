#compdef rotatelogs
# Documentation: rotatelogs usage (Apache httpd)
# Source: piped logging program that rotates the log file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-v[verbose operation (stderr)]' \
    '-l[base rotation on local time]' \
    '-L+[hard link from current log to PATH]:path:_files' \
    '-p+[run program after opening new log]:prog:_command_names -e' \
    '-f[force opening of log on startup]' \
    '-D[create parent directories of log file]' \
    '-t[truncate logfile instead of rotating]' \
    '-T[truncate rotated logs but not initial]' \
    '-e[echo log to stdout]' \
    '-c[create log file even on no traffic]' \
    '-n+[use N files, rotating round-robin]:n:' \
    ':logfile:_files' \
    ':rotation time or size:' \
    '::offset minutes from UTC:' \
    && ret=0

return ret
