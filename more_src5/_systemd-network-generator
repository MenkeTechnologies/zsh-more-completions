#compdef systemd-network-generator
# Documentation: https://github.com/systemd/systemd/blob/main/src/network/generator/network-generator-main.c
# Reference accessed: 2026-05-21
# Verified: upstream systemd source parse_argv() in network-generator-main.c.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--root=[operate on alternate filesystem root]:dir:_files -/' \
  '*:kernel command line item:' && ret=0

return ret
