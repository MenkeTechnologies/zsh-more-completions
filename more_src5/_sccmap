#compdef sccmap
# Documentation: man sccmap(1) (graphviz)
# Source: GraphViz sccmap — extract strongly connected components.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d[preserve single-node degenerate components]' \
    '(-s -S)-s[suppress graph output; print stats only]' \
    '(-s -S)-S[output graphs without stats]' \
    '-v[verbose (extended SCC metrics)]' \
    '-o+[output file]:file:_files' \
    '*:DOT file:_files -g "*.{dot,gv}"' \
    && ret=0

return ret
