#compdef setsebool
# Documentation: https://linux.die.net/man/8/setsebool
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for setsebool

_setsebool_bools() {
  [[ -z $words[CURRENT] ]] && PREFIX+='-'
  local -a bools
  bools=( ${(f)"$(getsebool -a 2>/dev/null | awk '{print $1}')"} )
  (( ${#bools} )) && _describe 'SELinux boolean' bools || _message 'SELinux boolean name'
}

_setsebool() {
  [[ -z $words[CURRENT] ]] && PREFIX+='-'
  _arguments -s -S \
    '-P[make the change persistent across reboots]' \
    '-N[do not reload policy after committing change]' \
    '-V[verbose output]' \
    '*:boolean and value:->boolval'

  if [[ $state == boolval ]]; then
    case $(( ${#words} % 2 )) in
      0) _setsebool_bools ;;
      1) _values 'boolean value' on off 1 0 true false ;;
    esac
  fi
}

_setsebool "$@"
