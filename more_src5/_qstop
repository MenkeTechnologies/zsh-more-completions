#compdef qstop
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man8/qstop.8B.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# qstop: stop PBS batch job processing at a destination.
# Upstream documents only destination operands (queue, @server, queue@server); no flags.
local curcontext="$curcontext" ret=1

_arguments -C \
  '*:destination (queue, @server, or queue@server):' && ret=0

return ret
