#compdef sliver-client sliver-server
# Documentation: https://github.com/BishopFox/sliver
# Reference accessed: 2026-05-21
# Verified: client/cli/cli.go (sliver-client) and server/cli/cli.go (sliver-server).

local curcontext="$curcontext" state line ret=1
local -a commands

case "$service" in
  sliver-client)
    commands=(
      'import:import a client configuration file'
      'console:start the sliver client console'
      'mcp:start the MCP stdio server'
      'implant:run sliver implant commands from system shell'
      'version:show version'
    )

    _arguments -C \
      '--rc-script=[path to rc script file]:file:_files' \
      '--wg=[connect to multiplayer through WireGuard wrapper]' \
      '1: :->cmd' \
      '*::arg:->args' && ret=0

    case $state in
      (cmd) _describe -t cmds 'sliver-client command' commands && ret=0 ;;
      (args)
        case ${line[1]} in
          (import)
            _arguments '*:config file:_files' && ret=0 ;;
          (console)
            _arguments \
              '--rc-script=[path to rc script file]:file:_files' && ret=0 ;;
          (mcp)
            _arguments \
              '--config=[path to client config file]:file:_files' && ret=0 ;;
          (implant)
            _arguments \
              '(-s --use)'{-s+,--use=}'[interact with a session]:session' && ret=0 ;;
        esac ;;
    esac
    ;;
  sliver-server)
    commands=(
      'daemon:force start server in daemon mode'
      'unpack:unpack assets and exit'
      'operator:generate operator configuration files'
      'import-ca:import certificate authority'
      'export-ca:export certificate authority'
      'builder:start the process as an external builder'
      'version:print version and exit'
    )

    _arguments -C \
      '1: :->cmd' \
      '*::arg:->args' && ret=0

    case $state in
      (cmd) _describe -t cmds 'sliver-server command' commands && ret=0 ;;
    esac
    ;;
esac

return ret
