#compdef swayr
# Documentation: https://docs.rs/swayr/latest/swayr/cmds/enum.SwayrCommand.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for swayr (Sway window switcher and more)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'nop:no operation'
      'switch-to-urgent-or-lru-window:switch to urgent or LRU window'
      'switch-to-app-or-urgent-or-lru-window:switch to app or urgent/LRU window'
      'switch-to-mark-or-urgent-or-lru-window:switch to marked or urgent/LRU window'
      'switch-to-matching-or-urgent-or-lru-window:switch to matching or urgent/LRU window'
      'switch-window:switch to a window'
      'steal-window:steal a window to current workspace'
      'steal-window-or-container:steal a window or container'
      'switch-workspace:switch to a workspace'
      'switch-output:switch to an output'
      'switch-workspace-or-window:switch to workspace or window'
      'switch-workspace-container-or-window:switch workspace, container, or window'
      'switch-to:switch to output/workspace/container/window'
      'quit-window:quit a window'
      'quit-workspace-or-window:quit workspace or window'
      'quit-workspace-container-or-window:quit workspace, container, or window'
      'next-window:focus next window in LRU order'
      'prev-window:focus previous window in LRU order'
      'next-tiled-window:focus next tiled window'
      'prev-tiled-window:focus previous tiled window'
      'next-tabbed-or-stacked-window:focus next tabbed/stacked window'
      'prev-tabbed-or-stacked-window:focus previous tabbed/stacked window'
      'next-floating-window:focus next floating window'
      'prev-floating-window:focus previous floating window'
      'next-window-of-same-layout:focus next window of same layout'
      'prev-window-of-same-layout:focus previous window of same layout'
      'next-matching-window:focus next matching window'
      'prev-matching-window:focus previous matching window'
      'move-focused-to-workspace:move focused window to workspace'
      'move-focused-to:move focused window to output/workspace/container'
      'swap-focused-with:swap focused window with another'
      'toggle-tab-shuffle-tile-workspace:toggle tab/shuffle-tile layout'
      'tile-workspace:apply tile layout to workspace'
      'tab-workspace:apply tab layout to workspace'
      'shuffle-tile-workspace:apply shuffle-tile layout to workspace'
      'execute-swaymsg-command:execute swaymsg command'
      'execute-swayr-command:execute swayr command'
      'configure-outputs:configure outputs'
      'get-windows-as-json:return windows as JSON'
      'for-each-window:execute shell command for each matching window'
      'print-config:print current configuration'
      'print-default-config:print default configuration'
      'reload-config:reload configuration file'
      'merge-config:merge external config file with current config'
    )
    _describe -t commands 'swayr command' commands && ret=0
    ;;
esac

return ret
