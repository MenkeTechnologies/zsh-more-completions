#compdef repoctl
# _repoctl — manage local Arch Linux pacman repositories (cassava/repoctl)
# upstream: https://github.com/cassava/repoctl
# Subcommands from cmd files (cobra).

_repoctl() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '--profile=[configuration profile to use]:profile:' \
        '--config=[config file]:file:_files' \
        '--debug[enable debug output]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'add:copy and add packages to the repository'
                'list:list packages in the managed repository'
                'update:update repository database'
                'remove:remove and delete packages from the database'
                'down:download and extract tarballs from AUR'
                'status:show pending changes and upgradable packages'
                'query:query AUR for package information'
                'search:search AUR for packages'
                'reset:re-create repository database'
                'host:host repository on a network'
                'completion:generate shell completion scripts'
                'help:show help for any command'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                add) _arguments '*:package file:_files -g "*.pkg.tar.*"' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_repoctl "$@"
