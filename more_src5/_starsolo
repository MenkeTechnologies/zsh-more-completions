#compdef STARsolo starsolo STAR-solo
# _starsolo — Alexander Dobin STARsolo single-cell RNA-seq mode of STAR aligner with cell barcode UMI deduplication and quantification (alexdobin team, C++); custom argparse
# upstream: https://github.com/alexdobin/STAR

_starsolo() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--runMode=+[mode]:m:(alignReads soloCellFiltering genomeGenerate inputAlignmentsFromBAM liftOver)' \
        '--soloType=+[type]:t:(CB_UMI_Simple CB_UMI_Complex CB_samTagOut SmartSeq)' \
        '--soloCBwhitelist=+[whitelist file]:file:_files' \
        '--soloCBstart=+[N]:n:' \
        '--soloCBlen=+[N]:n:' \
        '--soloUMIstart=+[N]:n:' \
        '--soloUMIlen=+[N]:n:' \
        '--soloUMIdedup=+[strategy]:s:(1MM_All 1MM_Directional 1MM_Directional_UMItools Exact 1MM_CR NoDedup)' \
        '--soloUMIfiltering=+[strategy]:s:(- MultiGeneUMI MultiGeneUMI_All MultiGeneUMI_CR)' \
        '--soloFeatures=+[features csv]:str:' \
        '--soloMultiMappers=+[strategy]:str:' \
        '--soloCBmatchWLtype=+[type]:t:(Exact 1MM 1MM_multi 1MM_multi_pseudocounts 1MM_multi_Nbase_pseudocounts EditDist_2)' \
        '--soloStrand=+[strand]:s:(Unstranded Forward Reverse)' \
        '--soloCellFilter=+[strategy]:str:' \
        '--soloOutFileNames=+[name csv]:str:' \
        '--soloAdapterSequence=+[adapter]:str:' \
        '--soloAdapterMismatchesNmax=+[N]:n:' \
        '--soloCBposition=+[positions]:str:' \
        '--soloUMIposition=+[positions]:str:' \
        '--soloBarcodeReadLength=+[N]:n:' \
        '--soloBarcodeMate=+[N]:n:' \
        '--soloInputSAMattrBarcodeSeq=+[attributes csv]:str:' \
        '--soloInputSAMattrBarcodeQual=+[attributes csv]:str:' \
        '--readFilesIn=+[reads files]:file:_files -g "*.fq *.fq.gz *.fastq *.fastq.gz"' \
        '--readFilesType=+[type]:t:(Fastx SAM)' \
        '--readFilesCommand=+[command]:str:' \
        '--readMapNumber=+[N]:n:' \
        '--runThreadN=+[N]:n:' \
        '--genomeDir=+[STAR index dir]:dir:_files -/' \
        '--genomeLoad=+[mode]:m:(LoadAndKeep LoadAndRemove LoadAndExit NoSharedMemory)' \
        '--outFileNamePrefix=+[prefix]:str:' \
        '--outTmpDir=+[tmp dir]:dir:_files -/' \
        '--outStd=+[stream]:s:(Log SAM BAM_Unsorted BAM_SortedByCoordinate BAM_Quant)' \
        '--outSAMtype=+[type]:t:(SAM BAM Unsorted SortedByCoordinate)' \
        '--outSAMunmapped=+[mode]:m:(None Within KeepPairs)' \
        '--outFilterType=+[type]:t:(Normal BySJout)' \
        '--outFilterMultimapNmax=+[N]:n:' \
        '--limitOutSJcollapsed=+[N]:n:' \
        '--limitBAMsortRAM=+[bytes]:n:' \
        '--sjdbGTFfile=+[gtf file]:file:_files -g "*.gtf *.gff *.gff3"' \
        '--sjdbOverhang=+[N]:n:' \
        '--quantMode=+[mode]:m:(- TranscriptomeSAM GeneCounts)' \
        '--clipAdapterType=+[type]:t:(Hamming CellRanger4 None)' \
        '--outFilterScoreMin=+[N]:n:' \
        '--alignIntronMin=+[N]:n:' \
        '--alignIntronMax=+[N]:n:' \
        '--alignMatesGapMax=+[N]:n:'
}

_starsolo "$@"
