#compdef reg_transform
# Documentation: https://github.com/KCL-BMEIS/niftyreg
# Source: KCL-BMEIS/niftyreg reg-apps/reg_transform.cpp — transformation manipulation utility (C++; single-dash long opts).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(- *)-help[show help]' \
    '(- *)-v[print version]' \
    '(- *)-version[print version]' \
    '(-omp --omp)'{-omp+,--omp=}'[OpenMP threads]:n:_default' \
    '(-ref --ref -target)'{-ref+,--ref=,-target+}'[reference image]:file:_files -g "*.{nii,nii.gz,hdr,img}"' \
    '(-ref2 --ref2 -target2)'{-ref2+,--ref2=,-target2+}'[second reference (composed transforms)]:file:_files' \
    '(-def --def)'{-def+,--def=}'[output deformation field]:file:_files' \
    '(-disp --disp)'{-disp+,--disp=}'[output displacement field]:file:_files' \
    '(-flow --flow)'{-flow+,--flow=}'[output flow field]:file:_files' \
    '(-comp --comp)'{-comp+,--comp=}'[compose with another transform]:file:_files' \
    '(-land --land)'{-land+,--land=}'[apply transform to landmark file]:file:_files' \
    '(-updSform --updSform)'{-updSform+,--updSform=}'[update affine in sform header]:file:_files' \
    '(-half --half)'{-half+,--half=}'[output half-way transform]:file:_files' \
    '(-invAff --invAff -invAffine --invAffine)'{-invAff,--invAff,-invAffine,--invAffine}'[invert affine transformation]' \
    '(-invNrr --invNrr)'{-invNrr,--invNrr}'[invert non-rigid transformation]' \
    '(-makeAff --makeAff)'{-makeAff,--makeAff}'[create affine matrix from rotations]' \
    '(-aff2rig --aff2rig)'{-aff2rig,--aff2rig}'[convert affine to rigid (drop scale/shear)]' \
    '(-flirtAff2NR --flirtAff2NR)'{-flirtAff2NR,--flirtAff2NR}'[convert FLIRT affine to NiftyReg]' \
    && ret=0

return ret
