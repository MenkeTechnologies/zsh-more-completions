#compdef subtable
# Documentation: https://astrometry.net
# Source: dstndstn/astrometry.net man/subtable.1 — extract columns from a FITS table (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-i+[input FITS table]:file:_files -g "*.{fits,fit,fts}"' \
    '-o+[output FITS table]:file:_files' \
    '*-c+[column name to keep (repeatable)]:col:_default' \
    && ret=0

return ret
