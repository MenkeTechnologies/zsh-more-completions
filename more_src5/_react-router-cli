#compdef react-router-cli react-router
# _react-router-cli — Remix Software React Router framework mode CLI alias (remix-run team, TypeScript); custom argparse
# upstream: https://github.com/remix-run/react-router

_react-router-cli() {
    local -a sub=(
        'build:build the app for production'
        'dev:start dev server'
        'start:run production server'
        'reveal:show entry server/client files'
        'routes:print routes'
        'typegen:generate types'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'react-router subcommand' sub ;;
        args)
            case $words[1] in
                build) _arguments \
                    '1:project dir:_files -/' \
                    '--config=+[config file]:file:_files' \
                    '-c+[config file]:file:_files' \
                    '--assetsInlineLimit=+[bytes]:n:' \
                    '--clearScreen=+[bool]:b:(true false)' \
                    '--debug[debug]' \
                    '--logLevel=+[level]:l:(info warn error silent)' \
                    '-l+[level]:l:(info warn error silent)' \
                    '--mode=+[mode]:m:(development production)' \
                    '-m+[mode]:m:(development production)' \
                    '--profile[profile]' \
                    '--sourcemap[generate sourcemap]' ;;
                dev) _arguments \
                    '1:project dir:_files -/' \
                    '--config=+[config file]:file:_files' \
                    '-c+[config file]:file:_files' \
                    '--clearScreen=+[bool]:b:(true false)' \
                    '--cors[enable cors]' \
                    '--force[force re-optimize]' \
                    '--host=+[host]:host:_hosts' \
                    '-H+[host]:host:_hosts' \
                    '--logLevel=+[level]:l:(info warn error silent)' \
                    '-l+[level]:l:(info warn error silent)' \
                    '--mode=+[mode]:m:(development production)' \
                    '-m+[mode]:m:(development production)' \
                    '--open=+[bool/path]:str:' \
                    '-o+[bool/path]:str:' \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--strictPort[strict port]' \
                    '--debug[debug]' ;;
                routes) _arguments \
                    '1:project dir:_files -/' \
                    '--config=+[config file]:file:_files' \
                    '-c+[config file]:file:_files' \
                    '--json[json output]' ;;
                start) _arguments \
                    '1:server build path:_files' \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' ;;
                reveal) _arguments \
                    '--config=+[config file]:file:_files' \
                    '-c+[config file]:file:_files' \
                    '--no-typescript[no typescript]' \
                    '1:entry:(client server)' ;;
                typegen) _arguments \
                    '--config=+[config file]:file:_files' \
                    '-c+[config file]:file:_files' \
                    '--watch[watch]' ;;
            esac
            ;;
    esac
}

_react-router-cli "$@"
