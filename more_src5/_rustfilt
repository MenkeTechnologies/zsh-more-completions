#compdef rustfilt
# Documentation: https://github.com/luser/rustfilt
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (README + src/main.rs).

local -a arguments

arguments=(
  '--include-hash[include the hashes in the demangled names]'
  '--hash[include the hashes in the demangled names]'
  '(-i --input)'{-i,--input}'=[input file containing mangled symbols (- for stdin)]:file:_files'
  '(-o --output)'{-o,--output}'=[output file for demangled results (- for stdout)]:file:_files'
  '(- *)'{-h,--help}'[show help]'
  '(- *)'{-V,--version}'[show version]'
  '*:mangled name:'
)

_arguments -s -S $arguments
