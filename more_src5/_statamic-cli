#compdef statamic-cli
# _statamic-cli — Jack McDade Statamic flat-file Laravel CMS CLI alias (statamic team, PHP); artisan-based
# upstream: https://github.com/statamic/cms

_statamic-cli() {
    local -a sub=(
        'statamic:install:install statamic'
        'statamic:assets:meta:rebuild asset meta'
        'statamic:assets:generate-presets:regenerate preset images'
        'statamic:auth:migration:create auth migration'
        'statamic:install-cli:install statamic cli globally'
        'statamic:install-collaboration:install collaboration'
        'statamic:install-eloquent-driver:install eloquent driver'
        'statamic:install-pro:install pro features'
        'statamic:install-ssg:install static site generator'
        'statamic:multisite:enable multisite'
        'statamic:peak:install Peak starter kit'
        'statamic:rss:generate rss feed'
        'statamic:search:update:rebuild search indexes'
        'statamic:site:set-url:set site url'
        'statamic:starter-kit:export:export starter kit'
        'statamic:starter-kit:init:scaffold starter kit'
        'statamic:starter-kit:install:install a starter kit'
        'statamic:static:clear:clear static cache'
        'statamic:static:warm:warm static cache'
        'statamic:stache:clear:clear stache'
        'statamic:stache:doctor:check stache health'
        'statamic:stache:refresh:refresh stache'
        'statamic:stache:warm:warm stache'
        'statamic:support:zip:bundle support archive'
        'statamic:updates:fetch updates'
        'statamic:upgrade:run upgrade tasks'
        'statamic:user:change-password:change user password'
        'statamic:user:make:create user'
        'statamic:user:make:super:create super user'
        'statamic:make:action:scaffold action'
        'statamic:make:addon:scaffold addon'
        'statamic:make:dictionary:scaffold dictionary'
        'statamic:make:fieldtype:scaffold fieldtype'
        'statamic:make:filter:scaffold filter'
        'statamic:make:modifier:scaffold modifier'
        'statamic:make:scope:scaffold scope'
        'statamic:make:tag:scaffold tag'
        'statamic:make:widget:scaffold widget'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--env=+[env]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'statamic subcommand' sub ;;
        args)
            case $words[1] in
                statamic:install) _arguments '--force[force]' ;;
                statamic:starter-kit:install) _arguments '1:package:' '--with-config[include config]' '--clear-site[clear site]' '--without-dependencies[no deps]' '--without-cleanup[no cleanup]' ;;
                statamic:multisite) _arguments '--dry-run[dry run]' ;;
            esac
            ;;
    esac
}

_statamic-cli "$@"
