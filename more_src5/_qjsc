#compdef qjsc
# Documentation: https://github.com/quickjs-ng/quickjs (qjsc.c argv parser)
# Reference accessed: 2026-05-29
# QuickJS-NG bytecode/C compiler. Manual argv scan (not getopt). Long options not supported.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-b[output raw bytecode instead of C code]' \
  '-e[output main() and bytecode in a C file]' \
  '-o+[output filename]:file:_files' \
  '-n+[script name for stack traces]:name:' \
  '-N+[C name of generated data]:name:' \
  '-C[compile as classic JS script]' \
  '-m[compile as ES module]' \
  '*-D+[compile dynamically loaded module/worker]:module:' \
  '*-M+[init code for external C module]:module:' \
  '-p+[prefix for generated C names]:prefix:' \
  '-P[do not add default system modules]' \
  '*-s[strip source code (repeat for debug info)]' \
  '-S+[maximum stack size in bytes]:bytes:' \
  '*:input file:_files -g "*.(js|ts|mjs|cjs)"' && ret=0

return ret
