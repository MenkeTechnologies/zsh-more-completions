#compdef sshx
# Documentation: https://github.com/ekzhang/sshx/blob/main/crates/sshx/src/main.rs
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for sshx - secure web-based collaborative terminal.

_arguments -s -S \
  '--server=[address of remote sshx server]:server URL:' \
  '--shell=[local shell command to run]:shell:_command_names' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode (only print URL to stdout)]' \
  '--name=[session name in title (default user@hostname)]:name:' \
  '--enable-readers[enable read-only access mode]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]'
