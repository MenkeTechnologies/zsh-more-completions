#compdef sfdisk
# _sfdisk-bin — util-linux scriptable partition table editor; non-interactive MBR/GPT editor used by Anaconda, kickstart, cloud-init
# upstream: https://github.com/util-linux/util-linux

_sfdisk-bin() {
    _arguments \
        '(-A --activate)'{-A,--activate}'+[set bootable MBR partition]:partnum:' \
        '--backup[backup current table]' \
        '--backup-file+[backup file basename]:file:_files' \
        '--bytes[print in bytes]' \
        '(--color)--color=+[color]:when:(auto always never)' \
        '(-d --dump)'{-d,--dump}'[dump in script]' \
        '--delete+[delete partitions]:partnum:' \
        '(-f --force)'{-f,--force}'[do not check device usage]' \
        '(-F --list-free)'{-F,--list-free}'[list free unpartitioned space]' \
        '(-g --show-geometry)'{-g,--show-geometry}'[show geometry]' \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-J --json)'{-J,--json}'[JSON output]' \
        '(-l --list)'{-l,--list}'[list partitions]' \
        '(-n --no-act)'{-n,--no-act}'[no actual write]' \
        '(-N --partno)'{-N,--partno}'+[partition number]:n:' \
        '(--no-reread)--no-reread[do not re-read after change]' \
        '(--no-tell-kernel)--no-tell-kernel[do not tell kernel]' \
        '(-o --output)'{-o,--output}'+[output columns]:cols:' \
        '(-O --backup-pt-sectors)'{-O,--backup-pt-sectors}'+[backup]:file:_files' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '(--part-attrs)--part-attrs+[set part attrs]:attrs:' \
        '(--part-label)--part-label+[set part label]:label:' \
        '(--part-type)--part-type+[set part type]:type:' \
        '(--part-uuid)--part-uuid+[set part UUID]:uuid:' \
        '(-r --reorder)'{-r,--reorder}'[fix partition order]' \
        '(-s --show-size)'{-s,--show-size}'+[print size]:partnum:' \
        '(-T --list-types)'{-T,--list-types}'[list partition types]' \
        '(-u --unit)'{-u,--unit}'+[unit]:unit:(S)' \
        '(--verify)--verify[verify partition layout]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-w --wipe)'{-w,--wipe}'+[wipe FS signatures]:mode:(auto always never)' \
        '(-W --wipe-partitions)'{-W,--wipe-partitions}'+[wipe partition FS signatures]:mode:(auto always never)' \
        '(-X --label)'{-X,--label}'+[label]:label:(dos gpt sgi sun)' \
        '(-Y --label-nested)'{-Y,--label-nested}'+[nested label]:label:(dos)' \
        '*:device:_files'
}

_sfdisk-bin "$@"
