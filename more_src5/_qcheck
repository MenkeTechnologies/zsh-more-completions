#compdef qcheck
# Documentation: https://github.com/gentoo/portage-utils
# Source: gentoo/portage-utils qcheck.c — verify installed-file integrity (size/mtime/checksum).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-F --format)'{-F+,--format=}'[custom output format]:fmt:_default' \
    '(-s --skip)'{-s+,--skip=}'[ignore files matching regex]:regex:_default' \
    '(-u --update)'{-u,--update}'[update missing files / chksum / mtimes]' \
    '(-a --noafk)'{-a,--noafk}'[ignore missing files]' \
    '(-B --badonly)'{-B,--badonly}'[only print pkgs with bad files]' \
    '(-A --nohash)'{-A,--nohash}'[ignore differing/unknown chksums]' \
    '(-T --nomtime)'{-T,--nomtime}'[ignore differing mtimes]' \
    '(-C --skip-protected)'{-C,--skip-protected}'[ignore CONFIG_PROTECT-ed paths]' \
    '(-p --prelink)'{-p,--prelink}'[undo prelink when computing chksum]' \
    '*:package atom:_default' \
    && ret=0

return ret
