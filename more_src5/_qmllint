#compdef qmllint
# Documentation: qmllint --help (Qt)
# Source: QML syntax verifier and analyzer.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--help-all[show help including generic Qt options]' \
    '(- *)'{-v,--version}'[show version]' \
    {-s,--silent}'[do not output syntax errors]' \
    '--json=[write output as JSON]:file:_files' \
    '--write-defaults[write defaults to .qmllint.ini and exit]' \
    '--ignore-settings[ignore all settings files]' \
    {-M,--module}'[lint modules instead of files]' \
    '--resource=[QML resource file]:file:_files -g "*.qrc"' \
    '*'{-I+,--qmldirs=}'[QML module search dirs]:dir:_files -/' \
    '-E[use QML_IMPORT_PATH env var]' \
    '--bare[do not include default imports]' \
    '*'{-i+,--qmltypes=}'[import qmldir file]:file:_files' \
    '--list-plugins[list available plugins]' \
    '--plugin=[load plugin]:plugin:' \
    '*:qml file:_files -g "*.qml"' \
    && ret=0

return ret
