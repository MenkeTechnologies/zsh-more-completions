#compdef retdec-decompiler

_retdec() {
    local curcontext="$curcontext" state line ret=1

    _arguments \
        '(- *)--help[show help message and exit]' \
        '(-o --output)'{-o,--output}'[output file path]:output file:_files' \
        '--backend-no-debug[disable debug output from backend]' \
        '--backend-no-debug-comments[disable debug comments in output]' \
        '--cleanup[remove temporary files after decompilation]' \
        '--select-decode-only[decode the input without decompilation]' \
        '--select-functions=[decompile only selected functions]:function names:' \
        '--select-ranges=[decompile only selected address ranges]:address ranges:' \
        '(-k --keep-unreachable-funcs)'{-k,--keep-unreachable-funcs}'[keep unreachable functions in output]' \
        '(-l --target-language)'{-l,--target-language}'[target high-level language]:language:(c py)' \
        '--ar-index=[index of object file in archive to decompile]:index:' \
        '--ar-name=[name of object file in archive to decompile]:name:' \
        '--max-memory=[limit maximum memory in bytes]:bytes:' \
        '--no-memory-limit[disable memory limit]' \
        '--static-code-archive=[path to static code archive]:archive:_files' \
        '--static-code-sigfile=[path to static code signature file]:sigfile:_files' \
        '(-f --output-format)'{-f,--output-format}'[output format]:format:(plain json json-human)' \
        '--raw-section-vma=[virtual memory address of raw section]:address:' \
        '--raw-entry-point=[entry point address for raw binary]:address:' \
        '1:input file:_files' && ret=0

    return ret
}

_retdec "$@"
