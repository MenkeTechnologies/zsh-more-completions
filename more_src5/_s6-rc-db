#compdef s6-rc-db
# Documentation: https://skarnet.org/software/s6-rc/s6-rc-db.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c+[examine a compiled service database in directory]:database directory:_files -/' \
  '-l+[live state location]:live directory:_files -/' \
  '-u[select "up" data (default)]' \
  '-d[select "down" data]' \
  '-b[blocking lock]' \
  '1:command:(help check list type timeout contents dependencies pipeline script flags atomics all-dependencies)' \
  '*:service name' && ret=0

return ret
