#compdef qiskit qiskit-cli qiskit-aer
# _qiskit — IBM Qiskit open-source SDK for working with quantum computers at the level of circuits pulses and algorithms (qiskit team, Python); argparse
# upstream: https://github.com/Qiskit/qiskit

_qiskit() {
    local -a sub=(
        'transpile:transpile a circuit'
        'run:run a circuit on a backend'
        'estimate:run with Estimator primitive'
        'sample:run with Sampler primitive'
        'visualize:render circuit or histogram'
        'qasm:QASM subcommands'
        'optimize:run optimization algorithms'
        'simulate:simulate with Aer backend'
        'backend:backend subcommands'
        'job:job subcommands'
        'auth:authentication subcommands'
        'aer:Aer simulator subcommands'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--backend=+[backend name]:str:' \
        '-b+[backend name]:str:' \
        '--shots=+[shots]:n:' \
        '-s+[shots]:n:' \
        '--optimization-level=+[level]:l:(0 1 2 3)' \
        '-o+[level]:l:(0 1 2 3)' \
        '--seed=+[seed]:n:' \
        '--token=+[IBM token]:str:' \
        '--channel=+[channel]:c:(ibm_quantum ibm_cloud)' \
        '--instance=+[instance]:str:' \
        '--verbose[verbose]' \
        '--quiet[quiet]' \
        '--no-color[disable color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'qiskit subcommand' sub ;;
        args)
            case $words[1] in
                transpile|run|simulate) _arguments \
                    '--input=+[circuit file]:file:_files -g "*.qasm *.qpy *.json *.py"' \
                    '--output=+[output file]:file:_files' \
                    '--coupling-map=+[coupling map json]:str:' \
                    '--basis-gates=+[gates csv]:str:' \
                    '--layout-method=+[method]:m:(trivial dense noise_adaptive sabre)' \
                    '--routing-method=+[method]:m:(basic lookahead stochastic sabre none)' \
                    '--scheduling-method=+[method]:m:(asap alap)' ;;
                qasm) _arguments '1:qasm cmd:(parse export validate optimize)' '*:file:_files -g "*.qasm"' ;;
                backend) _arguments '1:backend cmd:(list status properties config)' ;;
                job) _arguments '1:job cmd:(get list cancel result status)' ;;
                auth) _arguments '1:auth cmd:(login logout save status)' ;;
                aer) _arguments '1:aer cmd:(simulators noise-model fake-backend)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_qiskit "$@"
