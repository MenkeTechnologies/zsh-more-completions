#compdef slapcat
# _slapcat — OpenLDAP slapcat (offline export of the live SLAPD database to LDIF; -F config dir, -f slapd.conf, -b suffix, -l output file, -n database number, -g do not include glue records, -s subtree filter DN, -a search filter, -H base URL, -V version, -v verbose, -d debug level)
# upstream: https://git.openldap.org/openldap/openldap (servers/slapd/slapcat)
# Flags from OpenLDAP servers/slapd/slapcommon.c on tip.

_slapcat() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-F+[config dir]:dir:_files -/' \
        '-f+[slapd.conf]:file:_files' \
        '-b+[suffix]:dn:' \
        '-l+[output file]:file:_files' \
        '-n+[database number]:n:' \
        '-g[skip glue records]' \
        '-s+[subtree filter DN]:dn:' \
        '-a+[search filter]:filter:' \
        '-H+[base URL]:url:' \
        '-d+[debug level]:level:' \
        '-v[verbose]'
}

_slapcat "$@"
