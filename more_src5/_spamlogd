#compdef spamlogd
# Documentation: man spamlogd(8)
# Source: openbsd/src libexec/spamlogd — spamd whitelist updating daemon (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-D[debugging mode, stay attached to terminal]' \
    '-I[whitelist only inbound SMTP connections]' \
    '-i+[monitor packets on interface]:interface:_net_interfaces' \
    '-l+[pflog interface (default pflog0)]:pflog interface:_net_interfaces' \
    '-W+[whitelist expiry in hours (default 864, max 2160)]:whiteexp:_default' \
    '*-Y+[whitelist sync target (repeatable)]:synctarget:_hosts' \
    && ret=0

return ret
