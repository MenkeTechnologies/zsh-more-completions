#compdef recins
# Documentation: https://www.gnu.org/software/recutils/
# Reference accessed: 2026-06-10

# Zsh completion for recins (GNU Recutils)

_arguments -s -S \
  '-t+[select record type]:record type:' \
  '*-f+[field name]:field name:' \
  '*-v+[field value]:field value:' \
  '-n[dry run, do not modify file]' \
  '-p[print inserted record]' \
  '-S[write result to stdout instead of modifying file]' \
  '-P+[password for encrypted fields]:password:' \
  '-e+[selection expression for insertion point]:expression:' \
  '--force[force operation even if errors exist]' \
  '--no-auto[do not generate auto fields]' \
  '--verbose[print verbose output]' \
  '*:file:_files'
