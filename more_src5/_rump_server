#compdef rump_server rump_allserver
# Documentation: man rump_server(1)
# Source: netbsd/src usr.bin/rump_server — rump kernel service provider (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-c+[number of virtual CPUs]:ncpu:_default' \
    '-d+[map host file into rump namespace (name=value,...)]:drivespec:_default' \
    '-l+[dlopen library before rump kernel init]:library:_files' \
    '-m+[load kernel module after init]:module:_files' \
    '-r+[kernel memory allocation limit]:total_ram:_default' \
    '-s[do not detach from terminal]' \
    '-v[set AB_VERBOSE in boothowto]' \
    '1:service URL:_default' \
    && ret=0

return ret
