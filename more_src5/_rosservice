#compdef rosservice
# Documentation: http://wiki.ros.org/rosservice
# Source: ros/ros_comm noetic-devel tools/rosservice/src/rosservice/__init__.py — ROS1 service introspection CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '1:subcommand:((
        args\:"print service arguments"
        call\:"call the service with provided args"
        find\:"find services by service type"
        info\:"print information about service"
        list\:"list active services"
        type\:"print service type"
        uri\:"print service ROSRPC uri"
    ))' \
    '*::args:_default' \
    && ret=0

return ret
