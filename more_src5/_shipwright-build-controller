#compdef shipwright-build-controller
# _shipwright-build-controller — Shipwright Build controller (reconciles Build / BuildRun / BuildStrategy)
# upstream: https://github.com/shipwright-io/build
# Flags from cmd/shipwright-build-controller/main.go on tip + ctxlog CustomZapFlagSet + controller-runtime zap flags.

_shipwright-build-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version=[version label of the build controller]:version:' \
        '--zap-devel[zap development-mode encoder]' \
        '--zap-encoder=[zap log encoder]:enc:(json console)' \
        '--zap-log-level=[zap log level]:level:(debug info warn error dpanic panic fatal)' \
        '--zap-stacktrace-level=[zap log level that triggers a stacktrace]:level:(info error panic)' \
        '--zap-time-encoding=[zap time encoding]:enc:(epoch millis nano iso8601 rfc3339 rfc3339nano)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_shipwright-build-controller "$@"
