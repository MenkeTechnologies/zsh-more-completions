#compdef sealert
# Documentation: https://manpages.opensuse.org/Tumbleweed/setroubleshoot-server/sealert.8.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-b --browser)'{-b,--browser}'[launch the browser]' \
  '(-s --service)'{-s,--service}'[start sealert service (used by dbus)]' \
  '(-S --noservice)'{-S,--noservice}'[start sealert without dbus service as stand alone app]' \
  '(-l --lookupid)'{-l,--lookupid}'+[lookup alert by id (wildcard * returns all)]:id:' \
  '(-a --analyze)'{-a,--analyze}'+[scan a log file, analyze its AVCs]:file:_files' \
  '(-f --fix)'{-f,--fix}'+[execute the fix command for the avc with given uuid and plugin]:uuid:' \
  '(-u --user)'{-u,--user}'+[logon as user]:user:_users' \
  '(-p --password)'{-p,--password}'+[set user password]:password:' \
  '(-P --plugin)'{-P,--plugin}'+[set plugin name associated with --fix option]:plugin:' && ret=0

return ret
