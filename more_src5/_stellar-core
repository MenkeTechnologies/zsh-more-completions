#compdef stellar-core
# _stellar-core — Stellar Development Foundation stellar-core C++ implementation of the Stellar Consensus Protocol full validator and history-archive node (stellar team, C++); custom argparse
# upstream: https://github.com/stellar/stellar-core

_stellar-core() {
    local -a sub=(
        'run:run a node'
        'new-db:create new ledger db'
        'new-hist:create new history archive'
        'catchup:catch up to network'
        'check-quorum:check quorum'
        'force-scp:force SCP'
        'http-command:send HTTP command'
        'load-xdr:load XDR file'
        'maintenance:run maintenance'
        'manualclose:manual close'
        'offline-info:print offline info'
        'print-xdr:print XDR file'
        'publish:publish to history'
        'rebuild-ledger-from-buckets:rebuild ledger'
        'report-last-history-checkpoint:report last history checkpoint'
        'sec-to-pub:convert seed to public'
        'self-check:self check'
        'sign-transaction:sign transaction'
        'test:run tests'
        'upgrade-db:upgrade db schema'
        'verify-checkpoints:verify checkpoints'
        'write-quorum:write quorum'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c+[config file]:file:_files -g "*.cfg *.toml"' \
        '--conf=+[config file]:file:_files -g "*.cfg *.toml"' \
        '-l+[log file]:file:_files' \
        '--log-file=+[log file]:file:_files' \
        '--log-format=+[fmt]:f:(text json)' \
        '--ll=+[log level]:l:(TRACE DEBUG INFO WARNING ERROR FATAL)' \
        '--logLevel=+[log level]:l:(TRACE DEBUG INFO WARNING ERROR FATAL)' \
        '--metric=+[name]:str:' \
        '-w[wait for consensus]' \
        '--wait[wait for consensus]' \
        '-D[disable bucket gc]' \
        '--no-bucket-gc[disable bucket gc]' \
        '--in-memory[in memory]' \
        '--start-at-ledger=+[N]:n:' \
        '--start-at-hash=+[hash]:str:' \
        '--ignore-last-modified-time[ignore last modified]' \
        '--filter-query=+[query]:str:' \
        '--last-modified-ledger-seq=+[N]:n:' \
        '--filter-pred=+[predicate]:str:' \
        '--include-all-versions[include all versions]' \
        '--report=+[fmt]:f:(text json)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'stellar-core subcommand' sub ;;
        args)
            case $words[1] in
                catchup) _arguments '*:ledgerNum/count:' ;;
                publish) _arguments '*:archive:' ;;
                sign-transaction) _arguments '*:tx XDR file:_files' ;;
            esac
            ;;
    esac
}

_stellar-core "$@"
