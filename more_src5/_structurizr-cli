#compdef structurizr-cli
# Documentation: https://docs.structurizr.com/cli
# Reference accessed: 2026-05-21
# Verified: docs.structurizr.com/cli subcommand reference (push, pull,
# lock, unlock, export, list, validate, inspect, merge, version).
# Per-command flag surface (-id, -key, -secret, -url, -workspace,
# -format, -output, -branch, -passphrase, -merge, -archive, -layout,
# -view) verified against docs.structurizr.com/cli/<cmd> pages.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'push:Upload a DSL or JSON workspace'
      'pull:Download remote workspace JSON'
      'lock:Acquire workspace edit lock'
      'unlock:Release workspace edit lock'
      'export:Render diagrams locally'
      'list:List elements within a workspace'
      'validate:Validate a JSON or DSL workspace'
      'inspect:Inspect the contents of a workspace'
      'merge:Merge layout information between workspaces'
      'version:Print CLI version'
      'help:Help about any command'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    case $words[1] in
      (push)
        _arguments \
          '-id=[workspace ID]:id:' \
          '-key=[workspace API key]:key:' \
          '-secret=[workspace API secret]:secret:' \
          '-url=[Structurizr API URL]:url:' \
          '-workspace=[workspace JSON/DSL path or URL]:file:_files' \
          '-branch=[branch name]:branch:' \
          '-passphrase=[client-side encryption passphrase]:passphrase:' \
          '-merge=[merge layout from remote workspace]:bool:(true false)' \
          '-archive=[archive previous remote workspace]:bool:(true false)' && ret=0 ;;
      (pull)
        _arguments \
          '-id=[workspace ID]:id:' \
          '-key=[workspace API key]:key:' \
          '-secret=[workspace API secret]:secret:' \
          '-url=[Structurizr API URL]:url:' \
          '-branch=[branch name]:branch:' \
          '-passphrase=[client-side decryption passphrase]:passphrase:' && ret=0 ;;
      (lock|unlock)
        _arguments \
          '-id=[workspace ID]:id:' \
          '-key=[workspace API key]:key:' \
          '-secret=[workspace API secret]:secret:' \
          '-url=[Structurizr API URL]:url:' && ret=0 ;;
      (export)
        _arguments \
          '-workspace=[workspace JSON/DSL path or URL]:file:_files' \
          '-format=[output format]:format:(plantuml plantuml/structurizr plantuml/c4plantuml mermaid websequencediagrams dot ilograph d2 json theme static)' \
          '-output=[output directory]:dir:_files -/' && ret=0 ;;
      (list|validate|inspect)
        _arguments \
          '-workspace=[workspace JSON/DSL path or URL]:file:_files' && ret=0 ;;
      (merge)
        _arguments \
          '-workspace=[workspace JSON/DSL path or URL]:file:_files' \
          '-layout=[workspace JSON with layout info]:file:_files' \
          '-view=[view to merge]:view:' \
          '-output=[output file]:file:_files' && ret=0 ;;
      *) _default && ret=0 ;;
    esac
    ;;
esac

return ret
