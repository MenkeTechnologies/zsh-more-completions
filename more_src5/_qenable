#compdef qenable
# Documentation: https://github.com/openpbs/openpbs/blob/master/doc/man8/qenable.8B
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# qenable: enable PBS queues; accepts only --version plus destination operands
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--version[return PBS version information and exit]' \
  '*:destination (queue|@server|queue@server):' && ret=0
return ret
