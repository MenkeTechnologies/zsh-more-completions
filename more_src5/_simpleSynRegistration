#compdef simpleSynRegistration
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/simpleSynRegistration.cxx — minimal SyN registration example binary (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:FixedImage:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '2:MovingImage:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3:InitialTransform:_files -g "*.{txt,mat,h5}"' \
    '4:OutputPrefix:_default' \
    && ret=0

return ret
