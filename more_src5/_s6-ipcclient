#compdef s6-ipcclient s6-ipcserver s6-ipcserver-access s6-ipcserver-socketbinder s6-ipcserverd
# Documentation: source-direct extraction from upstream skarnet/s6
# src/conn-tools/s6-ipc{client,server,server-access,
# server-socketbinder,serverd}.c USAGE strings + subgetopt_r option
# specs + case-arm decoding for -P/-p (peer-credentials lookup),
# -d/-D (SO_REUSEADDR flag), -M/-m (stream xor datagram socket),
# -B (bind only / no listen).
# Reference accessed: 2026-05-30 via gh api.
# Skarnet s6 ipcserver family R121 — 5-stem multi-binary harvest of
# the s6 UCSPI UNIX-domain client+server framework. Sister tools to
# R117/R118/R119/R120 s6-fdholder + s6-envdir + s6-ftrig +
# s6-fdholder-daemon multi-stems. Carryforward from R118/R119/R120
# hunt-skip log.

case $service in

  s6-ipcclient)
    # Connect to a UNIX-domain socket and chain-load prog with the
    # connection wrapped as UCSPI protocol fds (typically 6/7).
    _arguments -s -S \
      '(-q -Q -v)-q[quiet; suppress informational messages]' \
      '(-q -Q -v)-Q[very quiet; suppress error messages too]' \
      '(-q -Q -v)-v[verbose; print connection info to stderr]' \
      '-p+[local socket path to bind from before connecting]:bindpath:_files' \
      '-l+[local name to set in PROTO_LOCAL environment]:localname:_hosts' \
      '1:server socket path:_files' \
      '*:program and arguments:_command_names -e'
    ;;

  s6-ipcserver)
    # All-in-one UNIX-domain UCSPI server superdaemon: binds, listens,
    # accepts, and spawns prog per connection. Composes the work of
    # s6-ipcserver-socketbinder + s6-ipcserverd in a single binary.
    _arguments -s -S \
      '(-q -Q -v)-q[quiet; suppress informational messages]' \
      '(-q -Q -v)-Q[very quiet; suppress error messages too]' \
      '(-q -Q -v)-v[verbose; print connection info to stderr]' \
      '(-D)-d[set SO_REUSEADDR on listen socket (default)]' \
      '(-d)-D[do NOT set SO_REUSEADDR on listen socket]' \
      '(-p)-P[do NOT look up peer credentials (no PROTO_REMOTE*)]' \
      '(-P)-p[look up peer credentials and set PROTO_REMOTE* (default)]' \
      '-1[notify readiness by writing newline + closing fd 1]' \
      '-c+[total max simultaneous connections (default 40)]:maxconn:' \
      '-C+[max simultaneous connections per peer uid (default 40)]:localmaxconn:' \
      '-b+[listen() backlog (default 20)]:backlog:' \
      '-a+[socket file octal permissions (default 0700)]:perms:' \
      '-u+[drop uid before serving]:uid:_users' \
      '-g+[drop gid before serving]:gid:_groups' \
      '-G+[supplementary group ids (comma-separated)]:gid,gid,...:' \
      '-U[ucspi mode: zero uid/gid + read socket fds from env]' \
      '1:socket path:_files' \
      '*:program and arguments:_command_names -e'
    ;;

  s6-ipcserver-access)
    # Access-control filter: invoked under s6-ipcserver (or any UCSPI
    # server) to consult an access-rules db, deny or allow the peer,
    # then chain-load prog if allowed. Designed to layer between
    # s6-ipcserverd and the real service prog.
    _arguments -s -S \
      '-v+[verbosity level (default 1)]:level:' \
      '(-E -e)-e[default-allow if rule lookup is inconclusive]' \
      '(-E -e)-E[default-deny if rule lookup is inconclusive (default)]' \
      '-l+[local name override for PROTO_LOCAL lookup]:localname:_hosts' \
      '(-i -x)-i+[access-rules directory tree (s6-accessrules-cdb-from-fs)]:rulesdir:_directories' \
      '(-i -x)-x+[access-rules CDB file]:rulesfile:_files' \
      '*:program and arguments:_command_names -e'
    ;;

  s6-ipcserver-socketbinder)
    # Socket-binding half of the s6-ipcserver pipeline: binds path,
    # (optionally) listens, then chain-loads prog with the bound
    # socket on fd 0. Designed to pipeline into s6-ipcserverd.
    _arguments -s -S \
      '(-D)-d[set SO_REUSEADDR on the socket (default)]' \
      '(-d)-D[do NOT set SO_REUSEADDR on the socket]' \
      '(-m)-M[create a stream socket (SOCK_STREAM; default)]' \
      '(-M)-m[create a datagram socket (SOCK_DGRAM)]' \
      '-B[bind only; do NOT call listen() on the socket]' \
      '-b+[listen() backlog (default 20)]:backlog:' \
      '-a+[socket file octal permissions]:perms:' \
      '1:socket path:_files' \
      '*:program and arguments:_command_names -e'
    ;;

  s6-ipcserverd)
    # Accept-loop half of the s6-ipcserver pipeline: expects a bound
    # listen() socket on fd 0 (typically piped in from
    # s6-ipcserver-socketbinder) and spawns prog per connection.
    _arguments -s -S \
      '-v+[verbosity level]:level:' \
      '-1[notify readiness by writing newline + closing fd 1]' \
      '(-p)-P[do NOT look up peer credentials (no PROTO_REMOTE*)]' \
      '(-P)-p[look up peer credentials and set PROTO_REMOTE* (default)]' \
      '-c+[total max simultaneous connections (default 40)]:maxconn:' \
      '-C+[max simultaneous connections per peer uid (default 40)]:localmaxconn:' \
      '*:program and arguments:_command_names -e'
    ;;

esac
