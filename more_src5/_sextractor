#compdef sextractor sex source-extractor
# Documentation: https://sextractor.readthedocs.io/
# Documentation: https://github.com/astromatic/sextractor/blob/master/src/main.c
# Documentation: https://github.com/astromatic/sextractor/blob/master/src/preflist.h
# Reference accessed: 2026-05-27
# Verified: upstream src/main.c argument loop and src/preflist.h keystruct (astromatic/sextractor)

# Zsh completion for SExtractor (source extraction from astronomical images)

local curcontext="$curcontext" state line ret=1

local -a _sex_params
_sex_params=(
  ANALYSIS_THRESH
  ASSOC_DATA
  ASSOC_NAME
  ASSOC_PARAMS
  ASSOC_RADIUS
  ASSOC_TYPE
  ASSOCCOORD_TYPE
  ASSOCSELEC_TYPE
  BACK_FILTERSIZE
  BACK_FILTTHRESH
  BACK_PEARSON
  BACK_SIZE
  BACK_TYPE
  BACK_VALUE
  BACKPHOTO_THICK
  BACKPHOTO_TYPE
  CATALOG_NAME
  CATALOG_TYPE
  CHECKIMAGE_NAME
  CHECKIMAGE_TYPE
  CLEAN
  CLEAN_PARAM
  DEBLEND_MINCONT
  DEBLEND_NTHRESH
  DETECT_MAXAREA
  DETECT_MINAREA
  DETECT_THRESH
  DETECT_TYPE
  DGEO_IMAGE
  DGEO_TYPE
  FILTER
  FILTER_NAME
  FILTER_THRESH
  FITS_UNSIGNED
  FLAG_IMAGE
  FLAG_TYPE
  GAIN
  GAIN_KEY
  HEADER_SUFFIX
  INTERP_MAXXLAG
  INTERP_MAXYLAG
  INTERP_TYPE
  MAG_GAMMA
  MAG_ZEROPOINT
  MASK_TYPE
  MEMORY_BUFSIZE
  MEMORY_OBJSTACK
  MEMORY_PIXSTACK
  NTHREADS
  PARAMETERS_NAME
  PATTERN_TYPE
  PHOT_APERTURES
  PHOT_AUTOAPERS
  PHOT_AUTOPARAMS
  PHOT_FLUXFRAC
  PHOT_PETROPARAMS
  PIXEL_SCALE
  PSF_NAME
  PSF_NMAX
  RESCALE_WEIGHTS
  SATUR_KEY
  SATUR_LEVEL
  SEEING_FWHM
  SOM_NAME
  STARNNW_NAME
  THRESH_TYPE
  VERBOSE_TYPE
  WEIGHT_GAIN
  WEIGHT_IMAGE
  WEIGHT_THRESH
  WEIGHT_TYPE
  WRITE_XML
  XML_NAME
  XSL_URL
)

_arguments -C \
  '-h[show syntax/help]' \
  '-v[show version information]' \
  '-d[dump default configuration file to stdout]' \
  '-dd[dump extended default configuration file]' \
  '-dp[dump full list of measurement parameters]' \
  '-c[specify configuration file]:config:_files -g "*.sex"' \
  '*-'{ANALYSIS_THRESH,ASSOC_DATA,ASSOC_NAME,ASSOC_PARAMS,ASSOC_RADIUS,ASSOC_TYPE,ASSOCCOORD_TYPE,ASSOCSELEC_TYPE,BACK_FILTERSIZE,BACK_FILTTHRESH,BACK_PEARSON,BACK_SIZE,BACK_TYPE,BACK_VALUE,BACKPHOTO_THICK,BACKPHOTO_TYPE}'[override SExtractor parameter]:value:' \
  '*-'{CATALOG_NAME,CATALOG_TYPE,CHECKIMAGE_NAME,CHECKIMAGE_TYPE,CLEAN,CLEAN_PARAM,DEBLEND_MINCONT,DEBLEND_NTHRESH,DETECT_MAXAREA,DETECT_MINAREA,DETECT_THRESH,DETECT_TYPE,DGEO_IMAGE,DGEO_TYPE}'[override SExtractor parameter]:value:' \
  '*-'{FILTER,FILTER_NAME,FILTER_THRESH,FITS_UNSIGNED,FLAG_IMAGE,FLAG_TYPE,GAIN,GAIN_KEY,HEADER_SUFFIX,INTERP_MAXXLAG,INTERP_MAXYLAG,INTERP_TYPE}'[override SExtractor parameter]:value:' \
  '*-'{MAG_GAMMA,MAG_ZEROPOINT,MASK_TYPE,MEMORY_BUFSIZE,MEMORY_OBJSTACK,MEMORY_PIXSTACK,NTHREADS,PARAMETERS_NAME,PATTERN_TYPE}'[override SExtractor parameter]:value:' \
  '*-'{PHOT_APERTURES,PHOT_AUTOAPERS,PHOT_AUTOPARAMS,PHOT_FLUXFRAC,PHOT_PETROPARAMS,PIXEL_SCALE,PSF_NAME,PSF_NMAX,RESCALE_WEIGHTS}'[override SExtractor parameter]:value:' \
  '*-'{SATUR_KEY,SATUR_LEVEL,SEEING_FWHM,SOM_NAME,STARNNW_NAME,THRESH_TYPE,VERBOSE_TYPE,WEIGHT_GAIN,WEIGHT_IMAGE,WEIGHT_THRESH,WEIGHT_TYPE,WRITE_XML,XML_NAME,XSL_URL}'[override SExtractor parameter]:value:' \
  '*:image:_files -g "*.(fits|fit|fts|FITS|FIT|FTS)"' && ret=0

return ret
