#compdef ruby
# Documentation: https://docs.ruby-lang.org/en/master/ruby/options_md.html
# Source: ruby/ruby ruby.c — Ruby interpreter (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-0-[input record separator (octal)]::octal:_default' \
    '-a[split each input line into fields ($F)]' \
    '-c[check syntax only, no execution]' \
    '-C+[execute program in directory]:dir:_files -/' \
    '(-d --debug)'{-d,--debug}'[debug + verbose mode]' \
    '*-e+[execute Ruby code]:code:_default' \
    {-E+,--encoding=}'[default external[:internal] encoding]:enc[:int]:_default' \
    '-F+[input field separator pattern]:pattern:_default' \
    '-i-[in-place edit mode]::extension:_default' \
    '*-I+[prepend dir to $LOAD_PATH]:dir:_files -/' \
    '-l[set output record separator to $/]' \
    '-n[run program in gets loop]' \
    '-p[like -n with printing added]' \
    '*-r+[require library]:library:_default' \
    '-s[define globals from switches following program path]' \
    '-S[search PATH for script]' \
    '-v[print version + verbose]' \
    '-w[synonym for -W1]' \
    '-W+[warning level (0|1|2) or :category]:level:_default' \
    '-x-[execute Ruby code starting from #!ruby line]::dirpath:_files -/' \
    '--jit[enable default JIT]' \
    '--yjit[enable YJIT in-process JIT]' \
    '--zjit[enable method-based JIT]' \
    '-h[short help]' \
    '--backtrace-limit=-[backtrace limit]:n:_default' \
    '--copyright[print copyright]' \
    '--crash-report=-[crash report file template]:template:_default' \
    '--disable=-[disable features]:features:(gems rubyopt did_you_mean error_highlight syntax_suggest)' \
    '--dump=-[dump items]:items:(insns parsetree parsetree_with_comment yydebug)' \
    '--enable=-[enable features]:features:(gems rubyopt did_you_mean error_highlight syntax_suggest)' \
    '--external-encoding=-[default external encoding]:enc:_default' \
    '--help[long help]' \
    '--internal-encoding=-[default internal encoding]:enc:_default' \
    '--parser=-[Ruby parser]:parser:(parse.y prism)' \
    '--verbose[set $VERBOSE to true, ignore stdin]' \
    '--version[print version]' \
    '(-y --yydebug)'{-y,--yydebug}'[print parser log]' \
    '1::ruby script:_files -g "*.{rb,ruby,rake}"' \
    '*::script args:_default' \
    && ret=0

return ret
