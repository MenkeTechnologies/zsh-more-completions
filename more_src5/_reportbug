#compdef reportbug
# Documentation: https://manpages.debian.org/reportbug
# Source: reportbug-team/reportbug bin/reportbug — Debian bug reporter (Python, optparse).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '--version[show version]' \
    '(-c --no-config-files)'{-c,--no-config-files}'[do not read config files]' \
    '(-C --class)'{-C+,--class=}'[report class]:class:(sw hw soft no-debian unrep doc)' \
    '(-d --debug)'{-d,--debug}'[debug mode]' \
    '--test[test mode]' \
    '(-e --editor)'{-e+,--editor=}'[editor command]:editor:_command_names' \
    '(-f --filename)'{-f+,--filename=}'[filename causing the problem]:file:_files' \
    '--from-buildd=-[generate report from buildd]:opts:_default' \
    '--path[search PATH for issue]' \
    '(-g --gnupg)'{-g,--gnupg}'[sign with gnupg]' \
    '(-G --gnus)'{-G,--gnus}'[use gnus mail-reader]' \
    '--pgp[sign with PGP]' \
    '(-K --keyid)'{-K+,--keyid=}'[GPG key id]:keyid:_default' \
    '(-H --header)'{-H+,--header=}'[extra mail header]:header:_default' \
    '(-P --pseudo-header)'{-P+,--pseudo-header=}'[pseudo-header]:header:_default' \
    '--license[show license info]' \
    '(-m --maintonly)'{-m,--maintonly}'[send only to maintainer]' \
    '(-M --mutt)'{-M,--mutt}'[use mutt mail-reader]' \
    '--mirror=-[mirror URL]:url:_urls' \
    '(-n --mh)'{-n,--mh}'[use MH/nmh mail-reader]' \
    '(-N --bugnumber)'{-N+,--bugnumber=}'[reference an existing bug]:bug:_default' \
    '--mua=-[mail user agent]:mua:_command_names' \
    '--mta=-[mail transfer agent]:mta:_command_names' \
    '--list-cc=-[Cc list of mailing list]:list:_default' \
    '--list-cc-me[Cc myself]' \
    '(-p --print)'{-p,--print}'[just print message and exit]' \
    '--report-quiet[suppress acknowledgments]' \
    '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
    '(-s --subject)'{-s+,--subject=}'[subject]:subject:_default' \
    '(-x --no-cc)'{-x,--no-cc}'[do not Cc submitter]' \
    '(-z --no-compress)'{-z,--no-compress}'[do not compress report]' \
    '(-o --output)'{-o+,--output=}'[save report to file]:file:_files' \
    '(-O --offline)'{-O,--offline}'[work offline]' \
    '*'{-i+,--include=}'[include file]:file:_files' \
    '*'{-A+,--attach=}'[attach file]:file:_files' \
    '(-b --no-query-bts)'{-b,--no-query-bts}'[do not query BTS]' \
    '*'{-T+,--tag=}'[tag bug]:tag:(patch wontfix moreinfo unreproducible help security upstream pending fixed-upstream confirmed l10n a11y ipv6 lfs newcomer)' \
    '--http_proxy=-[HTTP proxy]:url:_urls' \
    '--email=-[email]:email:_default' \
    '--realname=-[real name]:name:_default' \
    '--smtphost=-[SMTP host]:host:_hosts' \
    '--tls[use TLS]' \
    '(--source --src)--source[report source package bug]' \
    '(--source --src)--src[report source package bug]' \
    '--smtpuser=-[SMTP user]:user:_users' \
    '--smtppasswd=-[SMTP password]:pass:_default' \
    '(--replyto --reply-to)--replyto=-[Reply-To address]:email:_default' \
    '--reply-to=-[Reply-To address]:email:_default' \
    '(--no-query-source)--query-source[query source]' \
    '(--query-source)--no-query-source[do not query source]' \
    '(--no-security-team)--security-team[send to security team]' \
    '(--security-team)--no-security-team[do not send to security team]' \
    '(-j --justification)'{-j+,--justification=}'[justification for severity]:reason:_default' \
    '(-V --package-version)'{-V+,--package-version=}'[package version]:version:_default' \
    '(-u --interface)'{-u+,--interface=}'[user interface]:ui:(text gtk2 urwid)' \
    '(-Q --query-only)'{-Q,--query-only}'[query bug status and exit]' \
    '(-t --type)'{-t+,--type=}'[bug type]:type:(gnats debbugs)' \
    '(-B --bts)'{-B+,--bts=}'[BTS]:bts:(debian ubuntu kde freedesktop gnome reactos clarinet help2man)' \
    '(-S --severity)'{-S+,--severity=}'[severity]:sev:(wishlist minor normal important serious grave critical)' \
    '(-v --verify)'{-v,--verify}'[verify integrity of installed package]' \
    '(-k --kudos)'{-k,--kudos}'[send kudos instead of bug report]' \
    '--body-file=-[body file]:file:_files' \
    '--bodyfile=-[body file]:file:_files' \
    '(-r --resume-saved)'{-r,--resume-saved}'[resume previously saved report]' \
    '(-I --no-check-installed)'{-I,--no-check-installed}'[do not check if installed]' \
    '*:package or filename:_default' \
    && ret=0

return ret
