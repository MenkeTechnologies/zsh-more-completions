#compdef softhsm2-util
# Documentation: https://manpages.debian.org/bookworm/softhsm2/softhsm2-util.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream Debian bookworm softhsm2-util(1) manpage.
# Removed from prior file: fabricated --export, --mechanism,
# --force-pin-change flags (none exist in the manpage).

# Zsh completion for softhsm2-util - SoftHSM2 utility

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--init-token[initialize a token]' \
  '--show-slots[display all slots and status]' \
  '--delete-token[delete token at slot]' \
  '--import=[import key pair from PKCS#8 file]:path:_files' \
  '--aes[(deprecated) import file as AES]' \
  '--file-pin=[PIN to decrypt PKCS#8 file]:pin:' \
  '--force[override warnings]' \
  '--free[use first free/uninitialized token]' \
  '--id=[hex object ID]:hex:' \
  '--label=[object or token label]:label:' \
  '--module=[alternate PKCS#11 library]:file:_files' \
  '--no-public-key[do not import public key]' \
  '--pin=[user PIN]:pin:' \
  '--serial=[token serial number]:serial:' \
  '--slot=[slot number]:n:' \
  '--so-pin=[Security Officer PIN]:pin:' \
  '--token=[token label]:label:' && ret=0

return ret
