#compdef st-util
# Documentation: https://github.com/stlink-org/stlink/blob/develop/src/st-util/gdb-server.c
# Reference accessed: 2026-05-21
# Verified: upstream C source getopt_long table.

local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)'{-V,--version}'[show version]'
  '(-v --verbose)'{-v,--verbose}'+[verbose level (0-99)]:level:'
  '(-p --listen_port)'{-p+,--listen_port=}'[GDB server listen port (default 4242)]:port:'
  '(-m --multi)'{-m,--multi}'[extended mode for persistent connections]'
  '(-n --no-reset --hot-plug)'{-n,--no-reset,--hot-plug}'[skip board reset on connection]'
  '(-u --connect-under-reset)'{-u,--connect-under-reset}'[connect under reset]'
  '(-F --freq)'{-F+,--freq=}'[SWD/JTAG frequency in kHz]:freq:'
  '--semihosting[enable ARM semihosting]'
  '--serial=[device serial number]:serial:'
)

_arguments -s -S $arguments
