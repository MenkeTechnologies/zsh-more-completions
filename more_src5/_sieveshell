#compdef sieveshell cyrus-sieveshell
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/usercommands/sieveshell.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed: bogus -p/--port (upstream -p is --password, not port).
# Removed: -h short for --help (upstream uses bare --help).

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(-u --user)'{-u+,--user=}'[authorization user]:user:_users' \
  '(-a --authname)'{-a+,--authname=}'[authentication user]:user:_users' \
  '(-r --realm)'{-r+,--realm=}'[auth realm]:realm:' \
  '(-p --password)'{-p+,--password=}'[password (visible in process list)]:pw:' \
  '(-e --exec)'{-e+,--exec=}'[run script then exit]:script:' \
  '(-f --execfile)'{-f+,--execfile=}'[run commands from file]:file:_files' \
  '*:server:_hosts' && ret=0

return ret
