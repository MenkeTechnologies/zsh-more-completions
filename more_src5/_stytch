#compdef stytch stytch-cli
# Documentation: https://pkg.go.dev/github.com/stytchauth/stytch-cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_stytch() {
    local line state
    local -a commands
    commands=(
        'demoapps:Demo application management'
        'emailtemplates:Manage email templates'
        'jwttemplates:Manage JWT templates'
        'passwordstrengthconfig:Password strength configuration'
        'projects:Manage Stytch projects'
        'publictokens:Manage public tokens'
        'redirecturls:Manage redirect URLs'
        'secrets:Manage project secrets'
        'sdks:Manage SDK configurations'
    )

    _arguments -C \
        '(-h --help)'{-h,--help}'[Show help]' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'stytch-cli command' commands
            ;;
        args)
            case $line[1] in
                sdks)
                    _arguments \
                        '1:subcommand:(b2b consumer)' \
                        '*::arg:_files'
                    ;;
            esac
            ;;
    esac
}

_stytch "$@"
