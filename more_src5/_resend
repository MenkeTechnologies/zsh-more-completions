#compdef resend
# Documentation: https://github.com/resend/resend-cli
# Reference accessed: 2026-05-20
# Verified: upstream README at the URL above.

_resend() {
    local line state
    local -a commands
    commands=(
        'login:Authenticate and store API key'
        'logout:Remove saved API key'
        'auth:Manage authentication profiles'
        'doctor:Run diagnostics'
        'emails:Manage and send emails'
        'webhooks:Manage webhooks'
        'domains:Manage domains'
        'api-keys:Manage API keys'
        'commands:Print CLI command tree as JSON'
    )

    _arguments -C \
        '--api-key=[Override API key]:key' \
        '(-p --profile)'{-p+,--profile=}'[Specify a profile]:profile' \
        '--json[Force JSON output]' \
        '(-q --quiet)'{-q,--quiet}'[Suppress status output]' \
        '--version[Print version]' \
        '--help[Show help]' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'resend command' commands
            ;;
        args)
            case $line[1] in
                login)
                    _arguments '--key=[API key to store]:key'
                    ;;
                doctor)
                    _arguments '--json[JSON output]'
                    ;;
                auth)
                    _arguments '1:subcommand:(switch)'
                    ;;
                emails)
                    _arguments '1:subcommand:(send)' '*::arg:->emails_args'
                    case $state in
                        emails_args)
                            case $line[1] in
                                send)
                                    _arguments \
                                        '--from=[sender email]:address' \
                                        '*--to=[recipient address]:address' \
                                        '--subject=[subject line]:subject' \
                                        '--text=[plain text body]:text' \
                                        '--html=[HTML body string]:html' \
                                        '--html-file=[path to HTML file]:file:_files' \
                                        '*--cc=[CC recipient]:address' \
                                        '*--bcc=[BCC recipient]:address' \
                                        '--reply-to=[reply-to address]:address' \
                                        '--dry-run[validate without sending]'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                webhooks)
                    _arguments '1:subcommand:(list ls create get update delete rm listen)'
                    ;;
                domains)
                    _arguments '1:subcommand:(list get create delete verify)'
                    ;;
                api-keys)
                    _arguments '1:subcommand:(list create delete)'
                    ;;
            esac
            ;;
    esac
}

_resend "$@"
