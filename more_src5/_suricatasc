#compdef suricatasc
# Documentation: https://docs.suricata.io/en/latest/manpages/suricatasc.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# suricatasc: socket client to running Suricata IDS via unix-socket
local curcontext="$curcontext" ret=1
local -a unix_commands=(
  shutdown command-list help version uptime running-mode capture-mode
  conf-get dump-counters reload-rules ruleset-reload-rules
  ruleset-reload-nonblocking ruleset-reload-time ruleset-stats
  ruleset-failed-rules
  register-tenant-handler unregister-tenant-handler
  register-tenant reload-tenant reload-tenants unregister-tenant
  add-hostbit remove-hostbit list-hostbit
  reopen-log-files memcap-set memcap-show memcap-list
  get-flow-stats-by-id
  pcap-file pcap-file-continuous pcap-file-number pcap-file-list
  pcap-last-processed pcap-interrupt pcap-current
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --command)'{-c+,--command=}'[execute command and return JSON]:command:($unix_commands)' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*:socket file:_files' && ret=0
return ret
