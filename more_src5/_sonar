#compdef sonar
# Documentation: https://github.com/RasKrebs/sonar
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_sonar() {
    local curcontext="$curcontext" line state
    typeset -A opt_args
    local -a commands
    commands=(
        'kill:terminate process by port number'
        'kill-all:stop multiple processes at once'
        'list:list everything listening on localhost'
        'info:detailed inspection of a specific port'
        'open:open localhost:port in browser'
        'logs:tail logs for the process on a port'
        'wait:block until ports accept connections'
        'attach:shell into Docker container or TCP connect'
        'watch:poll for port changes with optional notifications'
        'graph:display dependency graph of service connections'
        'profile:manage saved port snapshots'
        'up:verify expected ports from a profile are running'
        'down:stop all ports in a saved profile'
        'map:proxy traffic between ports'
        'next:find available free ports'
        'completion:generate shell completions'
        'tray:launch the menu bar app (macOS)'
    )

    _arguments -C \
        '--version[show version]' \
        '--no-color[disable colored output]' \
        '--json[structured JSON output]' \
        '--host=[scan remote machine via SSH]:user@host:' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'sonar command' commands
            ;;
        args)
            case $line[1] in
                kill)
                    _arguments \
                        '-f[send SIGKILL instead of SIGTERM]' \
                        '1:port:'
                    ;;
                kill-all)
                    _arguments \
                        '--filter=[filter target group]:filter:(docker user)' \
                        '--project=[Compose project name]:project:' \
                        '-y[skip confirmation prompt]'
                    ;;
                list|watch)
                    _arguments \
                        '--stats[fetch CPU/memory usage]' \
                        '-a[include desktop apps]' \
                        '--filter=[filter results]:filter:' \
                        '--sort=[sort by column]:column:' \
                        '--json[JSON output]' \
                        '-c+[custom columns]:columns:' \
                        '--health[run HTTP health checks]' \
                        '--host=[scan remote machine via SSH]:user@host:'
                    ;;
                wait)
                    _arguments \
                        '--http[wait for HTTP 200-399]' \
                        '--http=[wait for HTTP at endpoint]:endpoint:' \
                        '--timeout=[fail after duration]:duration:' \
                        '-i+[polling interval]:interval:' \
                        '-q[silent mode, exit code only]' \
                        '*:port:'
                    ;;
                attach)
                    _arguments \
                        '--shell=[shell type]:shell:(bash sh zsh ash)' \
                        '1:port:'
                    ;;
                profile)
                    local -a prof_subs=(
                        'create:save current ports as profile'
                        'list:view saved profiles'
                        'show:display profile details'
                    )
                    _describe -t commands 'profile subcommand' prof_subs
                    ;;
            esac
            ;;
    esac
}

_sonar "$@"
