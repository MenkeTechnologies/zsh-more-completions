#compdef slurmdbd
# Documentation: source-direct extraction from upstream
# SchedMD/slurm src/slurmdbd/slurmdbd.c getopt argstring
# `"Dhn:R::suvV"` + the case-arm switch decoded source-direct
# from `_usage(char *prog_name)`.
# Reference accessed: 2026-05-30 via gh api.
# SchedMD slurm R162a — slurmdbd is the Slurm Database Daemon
# that brokers accounting RPCs between slurmctld and a SQL
# backend (MySQL/MariaDB).  Sister daemon to slurmctld + slurmd
# (already covered) in the Slurm scheduler family.

_arguments -s -S \
  '-D[run daemon in foreground (do not fork)]' \
  '-h[print help and exit]' \
  '-n+[run daemon at the given nice value]:nice:' \
  '-R[(deprecated 23.11+) re-roll lft/rgt]' \
  '-s[chdir to LogFile dirname or /var/tmp/]' \
  '-u[print Slurm DB version and exit 1 if conversion needed]' \
  '*-v[verbose mode - repeat to raise verbosity]' \
  '-V[print version info and exit]'
