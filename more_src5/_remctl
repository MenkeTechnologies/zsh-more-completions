#compdef remctl
# Documentation: https://www.eyrie.org/~eagle/software/remctl/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Kerberos-authenticated remote execution client.

_arguments -s -S \
  '-b[source IP address for connection]:ip:' \
  '-d[enable debug output]' \
  '-h[print usage]' \
  '-p[server port]:port:' \
  '-s[service principal]:service:' \
  '-v[print version]' \
  '1:host:_hosts' \
  '*::command:_normal' && return 0
