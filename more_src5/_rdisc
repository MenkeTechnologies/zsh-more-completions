#compdef rdisc
# Documentation: man rdisc(8)
# Source: dgibson/iputils rdisc.c (master) — ICMP router discovery daemon (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d[debug]' \
    '-t[trace messages (no daemonize)]' \
    '*-v[verbose (stackable)]' \
    '-s[send solicitation messages on startup]' \
    '-r[run as a router (responder)]' \
    '(-a -b)-a[any preference (default)]' \
    '(-a -b)-b[best preference only]' \
    '-f[forever (do not give up on startup)]' \
    '-V[show version]' \
    '-T+[max advertisement interval (s)]:seconds:_default' \
    '-p+[advertisement preference]:preference:_default' \
    '1::send address:_default' \
    '2::receive address:_default' \
    && ret=0

return ret
