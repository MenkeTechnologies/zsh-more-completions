#compdef smbios-token-ctl
# Documentation: https://man.archlinux.org/man/extra/libsmbios/smbios-token-ctl.1.en
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# smbios-token-ctl: list, query, and modify Dell SMBIOS tokens
local curcontext="$curcontext" ret=1
_arguments -C \
  '--version[show program version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --dump-tokens)'{-d,--dump-tokens}'[dump token table]' \
  '--dump-tokens-csv[dump token table in CSV format]' \
  '--import-token-settings-csv[restore token settings from CSV]' \
  '--is-string[determine if token is a string type]' \
  '--is-bool[determine if token is a boolean type]' \
  '--is-active[check if boolean token is active]' \
  '--get-string[retrieve string token value]' \
  '--activate[enable specified boolean token]' \
  '--set-string=[modify string token value]:value:' \
  '(-i --token-id --token)'{-i,--token-id,--token}'=[filter by token ID]:token id:' \
  '(-n --token-name)'{-n,--token-name}'=[filter by token name]:name:' \
  '(-s --token-setting)'{-s,--token-setting}'=[filter by token setting]:setting:' \
  '--token-csv=[token.csv file path]:file:_files' \
  '--token-blacklist-csv=[token blacklist CSV path]:file:_files' \
  '--logconfig=[alternate config log]:file:_files' \
  '--memory-dat=[memory dump file]:file:_files' \
  '--cmos-dat=[CMOS dump file]:file:_files' \
  '--password=[BIOS Setup password]:password:' \
  '(-r --rawpassword)'{-r,--rawpassword}'[do not auto-convert password to scancodes]' \
  '(-v --verbose)'{-v,--verbose}'[display more verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[minimize program output]' \
  '--trace[enable verbose function tracing]' && ret=0
return ret
