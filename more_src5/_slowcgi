#compdef slowcgi
# _slowcgi — OpenBSD slowcgi (FastCGI to CGI bridge for httpd(8); execs traditional CGI scripts on each FastCGI request, translating output back to the FastCGI wire protocol)
# upstream: https://github.com/openbsd/src (usr.sbin/slowcgi)
# Flags from usr.sbin/slowcgi/slowcgi.8 on tip.

_slowcgi() {
    _arguments \
        '-d[debug (foreground + stderr)]' \
        '-v[verbose]' \
        '-p+[chroot path]:dir:_files -/' \
        '-s+[FastCGI socket]:file:_files' \
        '-t+[script timeout (seconds)]:seconds:' \
        '-U+[socket owner user]:user:_users' \
        '-u+[run-as user]:user:_users'
}

_slowcgi "$@"
