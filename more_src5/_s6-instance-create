#compdef s6-instance-create
# _s6-instance-create — s6 instance s6-instance-create (create a new instance of an instance-template service; allocates a dedicated subdirectory and starts supervising it)
# upstream: https://github.com/skarnet/s6
# Flags from src/instance/s6-instance-create.c on tip.

_s6-instance-create() {
    _arguments \
        '(-d -D)-d[bring instance down after creation]' \
        '(-d -D)-D[do not touch up/down state]' \
        '-f[force: replace existing instance]' \
        '-P[do not wait for supervise]' \
        '-t+[timeout (ms)]:ms:' \
        '1:service:_files -/' \
        '2:instance-name:'
}

_s6-instance-create "$@"
