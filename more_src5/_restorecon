#compdef restorecon
# _restorecon — SELinux restorecon (restore SELinux security contexts on files to match policy default; -R recursive, -F force reset (even if matches), -i ignore non-existing files, -n no change (preview), -v verbose, -p progress, -W warn on no matching context, -e exclude path, -f input file list, -m no resolve mountpoints; positional argument is the file/dir list)
# upstream: https://github.com/SELinuxProject/selinux
# Flags from SELinuxProject/selinux policycoreutils/setfiles/restorecon.8 on tip.

_restorecon() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-R[recursive]' \
        '-r[recursive]' \
        '-F[force reset]' \
        '-i[ignore missing files]' \
        '-n[no change (preview)]' \
        '-v[verbose]' \
        '-p[progress]' \
        '-W[warn on no match]' \
        '*-e+[exclude path]:path:_files' \
        '-f+[input file list]:file:_files' \
        '-m[no resolve mountpoints]' \
        '-T+[threads]:n:' \
        '*:path:_files'
}

_restorecon "$@"
