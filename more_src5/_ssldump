#compdef ssldump
# _ssldump — Eric Rescorla ssldump (libpcap-based SSL/TLS protocol analyzer; -i interface, -r pcap input, -w write decrypted pcap, -n no dns, -k PEM private key to attempt decryption, -p password, -a show certificate chain, -A all records, -X hex dump payload, -Y verbose, -d debug, positional argument is BPF filter)
# upstream: https://github.com/adulau/ssldump
# Flags from ssldump src/main.c on tip.

_ssldump() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-i+[interface]:interface:_net_interfaces' \
        '-r+[pcap input]:file:_files -g "*.(pcap|pcapng|cap)"' \
        '-w+[pcap output]:file:_files -g "*.(pcap|pcapng)"' \
        '-n[no DNS lookups]' \
        '-k+[PEM private key]:file:_files -g "*.(pem|key)"' \
        '-p+[password]:password:' \
        '-a[show certificate chain]' \
        '-A[show all records]' \
        '-X[hex dump payload]' \
        '-Y[verbose]' \
        '-d[debug]' \
        '-N[no ssl version display]' \
        '-S+[snaplen]:bytes:' \
        '-T[print TCP only]' \
        '*:BPF filter:'
}

_ssldump "$@"
