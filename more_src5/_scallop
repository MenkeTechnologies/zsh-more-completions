#compdef scallop scallop2
# _scallop — Mingfu Shao Carl Kingsford scallop CLI accurate reference-based transcript assembler from RNA-Seq read alignments BAM SAM CRAM constructing isoform-level GTF outputs through phasing-path enumeration min-cost-flow optimization producing per-transcript abundance estimates (Mingfu Shao team, C++); getopt
# upstream: https://github.com/Kingsford-Group/scallop

_scallop() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-i+[input BAM]:file:_files -g "*.bam *.sam *.cram"' \
        '--input=+[file]:file:_files -g "*.bam *.sam *.cram"' \
        '-o+[output GTF]:file:_files -g "*.gtf *.gff"' \
        '--output=+[file]:file:_files -g "*.gtf *.gff"' \
        '-c+[config file]:file:_files -g "*.conf *.cfg"' \
        '--config=+[file]:file:_files -g "*.conf *.cfg"' \
        '-l+[library type]:l:(empty unstranded first second)' \
        '--library_type=+[l]:l:(empty unstranded first second)' \
        '--min_transcript_length_increase=+[N]:n:' \
        '--min_transcript_length_base=+[N]:n:' \
        '--min_transcript_coverage=+[N]:n:' \
        '--min_single_exon_coverage=+[N]:n:' \
        '--min_transcript_numreads=+[N]:n:' \
        '--min_mapping_quality=+[N]:n:' \
        '--max_num_cigar=+[N]:n:' \
        '--min_flank_length=+[N]:n:' \
        '--min_bundle_gap=+[N]:n:' \
        '--min_subregion_gap=+[N]:n:' \
        '--min_subregion_length=+[N]:n:' \
        '--min_subregion_overlap=+[N]:n:' \
        '--min_max_boundary_score=+[N]:n:' \
        '--min_splice_boundary_hits=+[N]:n:' \
        '--max_dp_table_size=+[N]:n:' \
        '--max_num_exons=+[N]:n:' \
        '--max_intron_contamination_coverage=+[N]:n:' \
        '--algo=+[a]:a:(scallop scallop2)' \
        '--preview[preview mode]' \
        '--verbose=+[level]:l:(0 1 2 3)' \
        '*::'
}

_scallop "$@"
