#compdef radiusd-monitor
# _radiusd-monitor — FreeRADIUS radiusd-monitor (small status-page / health-check wrapper used by ops dashboards; -s server, -p control-socket port, -P pidfile, -i poll interval, -j JSON output, -V version, -h help; reads /etc/raddb/clients.conf to learn which servers to probe)
# upstream: distro-shipped (FreeRADIUS contrib helpers)
# Common flag shape derived from FreeRADIUS contrib/radmonit on tip.

_radiusd-monitor() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-s+[server]:host:_hosts' \
        '-p+[control port]:port:' \
        '-P+[pidfile]:file:_files' \
        '-i+[interval]:seconds:' \
        '-j[JSON output]' \
        '-q[quiet]'
}

_radiusd-monitor "$@"
