#compdef storm storm-cli
# Documentation: https://github.com/moves-rwth/storm/tree/master/src/storm-cli-utilities
# Reference accessed: 2026-05-27
# Verified: upstream moves-rwth/storm option registrations in
#   src/storm/settings/modules/{GeneralSettings,IOSettings,CoreSettings,
#   DebugSettings,ResourceSettings,BuildSettings,ModelCheckerSettings,
#   HintSettings,TransformationSettings}.cpp
#
# Coverage: core/general/IO/build/model/debug/resource/transformation option
# groups consumed by storm-cli. Engine-specific tuning (Eigen/Gmm/Native LP
# solver internals, sylvan/cudd DD options, abstraction refinement knobs) is
# intentionally omitted — those modules expose hundreds of additional flags
# and are routinely tuned via configuration files (--config).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show available options]:filter (optional):' \
  '--version[print version information]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '--progress[print progress information at interval]:seconds:' \
  '(-eps --precision)'{-eps,--precision}'[internal numerical precision]:double:' \
  '(-c --config)'{-c+,--config=}'[read additional options from config file]:file:_files' \
  '(-bisim --bisimulation)'{-bisim,--bisimulation}'[perform bisimulation minimization]' \
  '--parametric[enable parametric model checking]' \
  '--exact[enable exact model checking]:mode:(rationals floats)' \
  '--sound[force sound model checking]' \
  '(-e --engine)'{-e+,--engine=}'[model checking engine]:engine:(sparse hybrid dd dd-to-sparse exploration abstraction-refinement automatic)' \
  '--eqsolver=[linear equation solver]:solver:(eigen gmm++ native elimination topological acyclic)' \
  '--ddlib=[decision diagram library]:lib:(cudd sylvan)' \
  '--lpsolver=[LP solver]:solver:(gurobi glpk z3 soplex)' \
  '--smtsolver=[SMT solver]:solver:(z3 mathsat)' \
  '(-stats --statistics)'{-stats,--statistics}'[display statistics if available]' \
  '--debug[enable debug-level logging]' \
  '--trace[enable trace-level logging]' \
  '--additional-checks[enable extra (expensive) sanity checks]' \
  '(-l --logfile)'{-l+,--logfile=}'[write log output to file]:file:_files' \
  '--test[enable test mode]' \
  '(-t --timeout)'{-t+,--timeout=}'[abort after N seconds]:seconds:' \
  '(-tm --timemem)'{-tm,--timemem}'[print CPU time and memory at end]' \
  '--signal-timeout=[grace period after termination signal]:seconds:' \
  '--prism=[parse PRISM input model]:file:_files -g "*.(nm|pm|sm|prism)"' \
  '--jani=[parse JANI input model]:file:_files -g "*.jani"' \
  '--prism2jani[transform PRISM input to JANI]' \
  '(-prop --prop)'{-prop+,--prop=}'[property/properties to check]:property:' \
  '*--janiproperty=[JANI property filter]:filter:' \
  '*-jprop[JANI property filter]:filter:' \
  '(-const --constants)'{-const+,--constants=}'[constant definitions, e.g. N=5,K=2]:assignments:' \
  '--transrew=[transition reward file]:file:_files' \
  '--staterew=[state reward file]:file:_files' \
  '--choicelab=[choice labels file]:file:_files' \
  '--steadystate[compute steady-state probabilities]' \
  '--expvisittimes[compute expected number of visits per state]' \
  '--propsasmulti[interpret properties as a single multi-objective query]' \
  '--uncertainty-resolution=[how to resolve interval/uncertain transitions]:mode:(minimum maximum)' \
  '(-qvbs --qvbs)'{-qvbs+,--qvbs=}'[QVBS benchmark identifier]:id:' \
  '--qvbsroot=[QVBS benchmark root directory]:directory:_files -/' \
  '--explicit=[parse explicit model from .tra/.lab files]:tra+lab:' \
  '(-exp --explicit)'{-exp+,--explicit=}'[parse explicit model]:tra+lab:' \
  '(-drn --explicit-drn)'{-drn+,--explicit-drn=}'[parse model in DRN format]:file:_files' \
  '(-imca --explicit-imca)'{-imca+,--explicit-imca=}'[parse model in IMCA format]:file:_files' \
  '(-umb --explicit-umb)'{-umb+,--explicit-umb=}'[parse upper bound MDP file]:file:_files' \
  '--no-drn-placeholders[do not emit placeholders in DRN export]' \
  '--exportdot=[export model as Graphviz dot]:file:_files' \
  '--dot-maxwidth=[maximum width for dot label]:width:' \
  '--exportbuild=[export build information]:file:_files' \
  '--compression=[compression level for exports]:level:' \
  '--digits=[significant digits in output]:n:' \
  '--exportjanidot=[export JANI model as dot]:file:_files' \
  '(-cdf --exportcdf)'{-cdf,--exportcdf}'[export CDF of bounded-until results]' \
  '--exportscheduler=[export computed scheduler]:file:_files' \
  '--exportresult=[export model checking result]:file:_files' \
  '--exportexplicit=[export model in explicit format]:prefix:' \
  '--exportdd=[export decision diagram]:file:_files' \
  '(-pc --prismcompat)'{-pc,--prismcompat}'[PRISM compatibility mode]' \
  '(-ndl --nofixdl)'{-ndl,--nofixdl}'[do not fix deadlocks in input]' \
  '--buildfull[build full model including unreachable states]' \
  '--nomaxprog[disable maximum progress assumption]' \
  '--buildchoicelab[build choice labels]' \
  '--buildchoiceorig[build choice origins]' \
  '--buildstateval[build state valuations]' \
  '--buildobsval[build observation valuations]' \
  '--build-all-labels[build all model labels]' \
  '--nobuild[do not build the model]' \
  '(-eo --explorder)'{-eo+,--explorder=}'[exploration order]:order:(bfs dfs)' \
  '(-ec --explchecks)'{-ec,--explchecks}'[enable extra exploration consistency checks]' \
  '--build-out-of-bounds-state[add explicit out-of-bounds state]' \
  '--build-overlapping-guards-label[label states with overlapping guards]' \
  '--no-simplify[disable model simplification]' \
  '--int-bits=[bits used for unbounded integer variables]:n:' \
  '--location-elimination[eliminate redundant locations during build]' \
  '--state-limit=[abort exploration after N states]:n:' \
  '--filterrewzero[filter zero-reward results]' \
  '--ltl2datool=[external LTL-to-DA tool path]:command:_command_names -e' \
  '--states=[hint estimate of number of reachable states]:n:' \
  '--eliminate-chains[eliminate non-Markovian chains during transformation]' \
  '--ec-label-behavior=[chain elimination label behavior]:mode:' \
  '--to-nondet[transform deterministic model to nondeterministic]' \
  '--to-discrete[discretize continuous-time model]' \
  '--permute=[apply state permutation]:mode:' \
  '*:input model:_files' && ret=0

return ret
