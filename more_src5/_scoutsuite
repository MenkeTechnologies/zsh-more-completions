#compdef scoutsuite scout-suite
# Documentation: https://github.com/nccgroup/ScoutSuite/blob/master/ScoutSuite/core/cli_parser.py
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Note: ScoutSuite's primary CLI binary is `scout`; see _scout for the
# full completion. This file aliases the alternate package names
# `scoutsuite` and `scout-suite` to the same completion function.

local curcontext="$curcontext" state line ret=1

if (( $+functions[_scout] )); then
  _scout "$@"
  return
fi

_arguments -s -S '*:argument:' && ret=0
return ret
