#compdef qdbus6 qdbus
# _qdbus6 — Qt 6 qdbus (introspect/call D-Bus services from the shell; positional args are service name -> object path -> method [args]; --system uses system bus, --bus picks an explicit bus address)
# upstream: https://github.com/qt/qttools (src/qdbus/qdbus)
# Flags from qttools src/qdbus/qdbus/qdbus.cpp on tip.

_qdbus6() {
    _arguments \
        '--help[show help]' \
        '--system[use the system bus]' \
        '--bus+[D-Bus address]:bus:' \
        '--literal[print results without formatting]' \
        '*:service/object/method/args:'
}

_qdbus6 "$@"
