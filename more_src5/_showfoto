#compdef showfoto
# Documentation: https://www.digikam.org/ (Showfoto is part of digiKam)
# Reference accessed: 2026-05-21
# Verified: docs.kde.org/stable5/en/digikam/showfoto returned 404; no canonical
# CLI documentation page. Showfoto is a KDE/Qt GUI image viewer/editor that
# accepts file arguments and inherits standard KDE/Qt options.
# STUB: file argument only; per-app CLI flags not documented upstream.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:image:_files -g "*.{jpg,jpeg,png,gif,bmp,tif,tiff,svg,webp,cr2,nef,arw,dng,raw,heic,heif,psd,xcf}"' && ret=0

return ret
