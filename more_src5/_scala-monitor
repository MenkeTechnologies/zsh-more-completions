#compdef scala-monitor
# ============================================================================
#  _scala-monitor — Scala process monitor (Scala-native; mainargs)
#
#  Source-direct extraction from
#    https://github.com/polyvariant/scala-monitor/blob/main/ScalaMonitor.scala
#    https://github.com/com-lihaoyi/mainargs (the mainargs library)
#
#  Maintained by Polyvariant (polyvariant/scala-monitor).  27 GH stars.
#  Discovers running Scala/JVM-related processes (sbt, bloop, metals,
#  scalac, scala-cli, mill, coursier, scalafmt, scalafix, etc.) and
#  displays a formatted table with PID, type, memory usage (RSS/VSZ/
#  SWAP), thread count, mem%, and project path.  Distributed as a
#  Scala-Native compiled binary via `cs install --contrib scala-monitor`
#  or downloadable from GitHub Releases.
#
#  CLI library taxonomy update: 2nd Scala CLI library — Li Haoyi's
#  com-lihaoyi/mainargs.  Scala ecosystem now has 2 documented CLI
#  libraries (R278 Scala decline + R346 Scala mainargs) joining the
#  multi-library club.
#
#  mainargs is fundamentally different from decline (R278):
#    - decline (R278): IMMUTABLE FUNCTIONAL combinator-based using cats
#      Applicative — `(opt1, opt2, opt3).mapN((a, b, c) => ...)`.
#    - mainargs (R346): ANNOTATION-BASED on METHOD signatures —
#      `@main def run(@arg(short = 'X') name: T = default)`.
#  Used by mill, ammonite, scala-cli scripts, geny, requests, os-lib.
#  Distinct from R275 clap-derive (struct + proc-macro), R322 JCommander
#  (field annotations + reflection), R340 oclif (class + static fields),
#  R345 cyclopts (PEP 593 Annotated[]).  mainargs uses Scala 2/3
#  REFLECTION via PROC-MACRO at compile time on method signatures —
#  parameter types become flag types, parameter defaults become flag
#  defaults, `@arg(...)` per-parameter annotations attach metadata.
#  Multiple `@main`-annotated methods become SUBCOMMANDS named after
#  the method.  Brings cross-language CLI library taxonomy variant
#  count to 85; Scala ecosystem now has 2 documented CLI libraries.
#
#  Surface (verbatim from ScalaMonitor.scala `@main def run`):
#  Single subcommand `run` (default since only one @main):
#    -o, --output {full|pid}     Output format (default: full)
#    -f, --filter <key=value>    Filter processes (repeatable)
#                                Keys: type, project
#                                Use * for wildcard contains matching
#                                (case insensitive)
#    -d, --debug                 Enable verbose debug logging to stderr
#    -l, --debug-log <path>      Debug log file (replaces stderr)
#    -w, --tui                   Interactive TUI mode (like top)
#    -D, --dumps-dir <path>      Directory for thread/heap dump files
#                                (default: $XDG_CACHE_HOME/scala-monitor/dumps)
#
#  Note: mainargs auto-derives kebab-case long names from camelCase
#        parameter names: `debugLog` → `--debug-log`, `dumpsDir` →
#        `--dumps-dir`.
#
#  Dup-skipped neighbors during hunt (smaller surface or different lib):
#    - LISA TPTP (epfl-lara/lisa 69 stars — small 2-subcommand surface)
#    - scala-repl-pp (mpollmeier 26 stars — uses SCOPT not mainargs)
#    - bleep (oyvindberg 178 stars — uses DECLINE not mainargs)
# ============================================================================

_scala-monitor() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-o --output)'{-o,--output}'=[output format]:format:(full pid)' \
    '*'{-f,--filter}'=[filter processes (key=value)]:filter (type=X or project=X)' \
    '(-d --debug)'{-d,--debug}'[enable verbose debug logging to stderr]' \
    '(-l --debug-log)'{-l,--debug-log}'=[debug log file destination]:log file:_files' \
    '(-w --tui)'{-w,--tui}'[interactive TUI mode (like top)]' \
    '(-D --dumps-dir)'{-D,--dumps-dir}'=[directory for thread/heap dump files]:dir:_directories'
}

_scala-monitor "$@"
