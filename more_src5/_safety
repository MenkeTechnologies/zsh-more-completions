#compdef safety
# Documentation: https://docs.safetycli.com/safety-docs/safety-cli-3
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# zsh completion for 'safety' (Python dependency vulnerability scanner)

_safety() {
  local curcontext="$curcontext" state line ret=1
  typeset -A opt_args

  local -a subcommands
  subcommands=(
    'scan:scan a project directory for vulnerabilities'
    'system-scan:scan the entire development machine'
    'check:legacy vulnerability check (deprecated, use scan)'
    'auth:authenticate with the Safety platform'
    'configure:set up Safety configuration'
    'validate:validate a Safety policy file'
    'generate:generate baseline files (e.g. policy)'
    'license:scan packages for license compliance'
    'firewall:firewall (package-manager protection)'
    'codebase:codebase project tracking'
  )

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '--debug[enable debug mode]' \
    '--key=[Safety API key]:key:' \
    '--stage=[development lifecycle stage]:stage:(development production)' \
    '--disable-optional-telemetry-data[opt out of telemetry]' \
    '1: :->cmd' \
    '*:: :->args' && ret=0

  case $state in
    cmd) _describe -t commands 'safety command' subcommands && ret=0 ;;
    args)
      case $line[1] in
        scan)
          _arguments -s -S \
            '(- *)'{-h,--help}'[show help]' \
            '--target=[target directory to scan]:dir:_directories' \
            '--output=[output format]:format:(screen json html spdx)' \
            '--policy-file=[Safety policy file]:file:_files' \
            '--apply-fixes[auto-update vulnerable dependencies]' \
            '--detailed-output[detailed reporting]' && ret=0 ;;
        auth)
          _arguments -s -S \
            '(- *)'{-h,--help}'[show help]' \
            '1:subcommand:(login logout status)' && ret=0 ;;
        configure)
          _arguments -s -S \
            '(- *)'{-h,--help}'[show help]' \
            '--proxy-host=[proxy host]:host:_hosts' \
            '--proxy-port=[proxy port]:port:' \
            '--proxy-protocol=[proxy protocol]:proto:(http https)' && ret=0 ;;
        license)
          _arguments -s -S \
            '(- *)'{-h,--help}'[show help]' \
            '(-r --file)'{-r+,--file=}'[requirements file]:file:_files' \
            '--output=[output format]:format:(screen json bare)' && ret=0 ;;
        firewall)
          _arguments -s -S \
            '(- *)'{-h,--help}'[show help]' \
            '1:subcommand:(init uninstall)' && ret=0 ;;
        codebase)
          _arguments -s -S \
            '(- *)'{-h,--help}'[show help]' \
            '1:subcommand:(init)' && ret=0 ;;
        validate)
          _arguments -s -S \
            '(- *)'{-h,--help}'[show help]' \
            '*:policy file:_files' && ret=0 ;;
        generate)
          _arguments -s -S \
            '(- *)'{-h,--help}'[show help]' \
            '1:type:(policy_file)' && ret=0 ;;
        *) _arguments -s -S '(- *)'{-h,--help}'[show help]' && ret=0 ;;
      esac
      ;;
  esac
  return ret
}

_safety "$@"
