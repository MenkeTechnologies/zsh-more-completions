#compdef sleuthkit
# _sleuthkit — Brian Carrier The Sleuth Kit forensic CLI toolkit alias (sleuthkit team, C); custom argparse for tsk_recover/fsstat/etc.
# upstream: https://github.com/sleuthkit/sleuthkit

_sleuthkit() {
    local -a sub=(
        'mmls:list partitions'
        'mmstat:show media management info'
        'mmcat:cat partition contents'
        'fls:list files in image'
        'icat:cat file by inode'
        'ils:list inodes'
        'fcat:cat file by name'
        'fsstat:show filesystem stats'
        'tsk_recover:recover deleted files'
        'tsk_loaddb:load image into SQLite db'
        'tsk_gettimes:gather MAC times'
        'tsk_comparedir:compare a dir tree to a fs image'
        'tsk_imageinfo:show image info'
        'srch_strings:strings extraction'
        'sigfind:find signatures in file'
        'sorter:sort files by category'
        'jcat:cat journal blocks'
        'jls:list journal entries'
        'blkstat:show block info'
        'blkls:list blocks'
        'blkcat:cat blocks'
        'blkcalc:calc block layout'
        'istat:show inode info'
        'ifind:find inode by file'
        'hfind:hash database lookup'
        'img_stat:image stats'
        'img_cat:image cat'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'sleuthkit subcommand' sub ;;
        args)
            case $words[1] in
                fls|icat|ils|fcat|fsstat|tsk_recover|mmls|mmstat|mmcat|jls|jcat|blkls|blkcat|blkstat|istat) _arguments \
                    '-i+[image type]:t:(aff afd afm afflib ewf raw split vmdk vhd)' \
                    '-f+[fs type]:t:(ext2 ext3 ext4 fat12 fat16 fat32 hfs hfs+ iso9660 ntfs swap raw yaffs2)' \
                    '-o+[offset sectors]:n:' \
                    '-b+[bytes per sector]:n:' \
                    '-z+[time zone]:str:' \
                    '-s+[time skew]:n:' \
                    '-l[long format]' \
                    '-v[verbose]' \
                    '*:image:_files' ;;
                tsk_recover) _arguments \
                    '-e[recover all files including allocated]' \
                    '-a[recover allocated files]' \
                    '-v[verbose]' \
                    '-V[show version]' \
                    '1:image:_files' \
                    '2:output dir:_files -/' ;;
                hfind) _arguments \
                    '-c[create db]' \
                    '-q[quick mode]' \
                    '-e[extended]' \
                    '*:hash db:_files' ;;
            esac
            ;;
    esac
}

_sleuthkit "$@"
