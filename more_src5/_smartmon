#compdef smartd
# _smartmon — smartmontools smartd daemon (background process that polls every ATA / SCSI / NVMe drive listed in /etc/smartd.conf and emails or syslogs on degraded SMART self-test or attribute thresholds; -c config file, -d daemonize, -i poll interval seconds, -p pidfile, -A directive prefix, -B drive-DB file, -l facility, -n disable powermode wakeups, -q test-mode, -V version, -h help)
# upstream: https://github.com/smartmontools/smartmontools
# Flags from smartmontools/smartmontools smartmontools/smartd.cpp on tip.

_smartmon() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[config file]:file:_files' \
        '-d[debug + foreground]' \
        '-i+[poll interval seconds]:seconds:' \
        '-p+[pidfile]:file:_files' \
        '-A+[directive prefix]:prefix:' \
        '-B+[drive DB file]:file:_files' \
        '-l+[syslog facility]:facility:(daemon local0 local1 local2 local3 local4 local5 local6 local7)' \
        '-n+[powermode disable]:mode:(never sleep standby idle)' \
        '-q+[test mode]:mode:(nodev errors nodev0 onecheck showtests)' \
        '-r+[redirect debug]:type:(stdout stderr)' \
        '-w+[warning email]:email:'
}

_smartmon "$@"
