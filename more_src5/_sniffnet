#compdef sniffnet
# Documentation: https://github.com/GyulyVGC/sniffnet/blob/main/src/cli/mod.rs
# Reference accessed: 2026-05-21
# Verified: upstream src/cli/mod.rs Args struct (clap).
# Removed from prior file: fabricated -v/--version (not in upstream cli mod;
# clap auto-handles -V/--version by default).
# Added: -c/--config_path, -r/--restore_default, -l/--logs (Windows).

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-a --adapter)'{-a+,--adapter=}'[network adapter to inspect]:adapter:' \
  '(-c --config_path)'{-c,--config_path}'[print path to config file]' \
  '(-r --restore_default)'{-r,--restore_default}'[restore default settings]' \
  '(-l --logs)'{-l,--logs}'[show recent application logs (Windows release only)]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0
return ret
