#compdef systemd-pstore
# _systemd-pstore (systemd persistent-storage helper that drains entries from /sys/fs/pstore at boot, archives them in /var/lib/systemd/pstore/<unix-timestamp>/, then optionally clears the kernel ring buffer; reads /etc/systemd/pstore.conf for behaviour; takes no positional arguments)
# upstream: https://github.com/systemd/systemd (src/pstore)
# Argument shape from systemd src/pstore/pstore.c on tip.

_systemd-pstore() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]'
}

_systemd-pstore "$@"
