#compdef screenrecord
# Documentation: https://android.googlesource.com/platform/frameworks/av/+/refs/heads/main/cmds/screenrecord/screenrecord.cpp
# Source: AOSP frameworks/av — on-device screen recorder (run inside `adb shell screenrecord`).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[display usage]' \
    '--verbose[detailed output on stdout]' \
    '--size=[video dimensions WIDTHxHEIGHT]:WxH:' \
    '--bit-rate=[bitrate in bits/s or NM megabit suffix]:rate:' \
    '--bugreport[include timestamp overlay and diagnostics]' \
    '--time-limit=[max recording duration in seconds (default 180)]:seconds:' \
    '--display-id=[physical display to record]:id:' \
    '(- *)--version[display version]' \
    '--show-device-info[overlay device info]' \
    '--show-frame-time[overlay frame timing]' \
    '--rotate[rotate output 90 degrees]' \
    '--output-format=[output container/format]:fmt:(mp4 h264 webm 3gpp frames raw-frames)' \
    '--codec-name=[custom codec name]:codec:' \
    '--monotonic-time[use system monotonic clock for timestamps]' \
    '--persistent-surface[use persistent surface for encoding]' \
    '--bframes=[number of B-frames]:n:' \
    '--capture-secure[create secure virtual display]' \
    '*:output file:_files' \
    && ret=0

return ret
