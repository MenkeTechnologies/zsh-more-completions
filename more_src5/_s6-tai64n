#compdef s6-tai64n s6-tai64nlocal
# Documentation: https://skarnet.org/software/s6/s6-tai64n.html
# Reference accessed: 2026-05-30
# s6-tai64n / s6-tai64nlocal — filters that prepend TAI64N timestamps to each line read from stdin.
# NO FLAGS upstream. s6-tai64nlocal converts TAI64N back to local time.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  && ret=0

return ret
