#compdef release-please-cli
# _release-please-cli — Google release-please conventional-commit release automation CLI alias (Google, TypeScript); yargs
# upstream: https://github.com/googleapis/release-please

_release-please-cli() {
    local -a sub=(
        'release-pr:create/update release PR'
        'github-release:tag + publish github release'
        'bootstrap:bootstrap release-please config'
        'manifest-pr:create/update manifest release PR'
        'manifest-release:tag + publish manifest release'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--token=+[github token]:str:' \
        '--api-url=+[github api url]:url:_urls' \
        '--graphql-url=+[github graphql url]:url:_urls' \
        '--repo-url=+[repo url owner/repo]:str:' \
        '--config-file=+[config file]:file:_files' \
        '--manifest-file=+[manifest file]:file:_files' \
        '--target-branch=+[target branch]:str:' \
        '--default-branch=+[default branch]:str:' \
        '--release-type=+[release type]:t:(simple node ruby python php java krm helm rust go terraform-module dart elixir maven sfdx ocaml expo)' \
        '--release-as=+[release as version]:ver:' \
        '--bump-minor-pre-major[bump minor pre major]' \
        '--bump-patch-for-minor-pre-major[bump patch for minor pre major]' \
        '--prerelease[prerelease]' \
        '--draft[draft]' \
        '--draft-pull-request[draft pull request]' \
        '--changelog-path=+[changelog path]:file:_files' \
        '--changelog-type=+[changelog type]:t:(default github)' \
        '--changelog-host=+[changelog host]:host:_hosts' \
        '--changelog-sections=+[changelog sections json]:str:' \
        '--versioning-strategy=+[versioning strategy]:s:(default always-bump-patch always-bump-major always-bump-minor prerelease)' \
        '--package-name=+[package name]:str:' \
        '--monorepo-tags[monorepo tags]' \
        '--snapshot[snapshot]' \
        '--label=+[label]:str:' \
        '--release-label=+[release label]:str:' \
        '--include-component-in-tag[include component in tag]' \
        '--include-v-in-tag[include v in tag]' \
        '--last-package-version=+[last package version]:str:' \
        '--path=+[path]:dir:_files -/' \
        '--component=+[component]:str:' \
        '--proxy-key=+[proxy key]:str:' \
        '--release-search-depth=+[release search depth]:n:' \
        '--commit-search-depth=+[commit search depth]:n:' \
        '--separate-pull-requests[separate pull requests]' \
        '--debug[debug]' \
        '--dry-run[dry run]' \
        '--trace[trace]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'release-please subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_release-please-cli "$@"
