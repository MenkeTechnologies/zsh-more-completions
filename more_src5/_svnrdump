#compdef svnrdump
# Documentation: https://svnbook.red-bean.com/en/1.8/svn.ref.svnrdump.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local -a subcommands
subcommands=(
    'dump:Dump revisions from remote repository'
    'load:Load revisions into remote repository'
    'help:Show help'
)

_arguments -C \
    '1:subcommand:->subcmd' \
    '*:: :->args'

case $state in
    subcmd)
        _describe -t subcommands 'svnrdump subcommand' subcommands
        ;;
    args)
        _arguments \
            '-r[Revision range]:revision range' \
            '--revision[Revision range]:revision range' \
            '-q[Quiet mode]' \
            '--quiet[Quiet mode]' \
            '--incremental[Incremental dump]' \
            '--no-auth-cache[Do not cache authentication]' \
            '--non-interactive[Non-interactive mode]' \
            '--trust-server-cert[Trust server certificate]' \
            '--trust-server-cert-failures[Trust specific failures]:failures' \
            '--username[Username]:username' \
            '--password[Password]:password' \
            '--config-dir[Config directory]:dir:_directories' \
            '--config-option[Config option]:option' \
            '*:URL'
        ;;
esac
