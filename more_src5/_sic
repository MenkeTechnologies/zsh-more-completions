#compdef sic
# Documentation: https://github.com/foresterre/sic
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# foresterre/sic Rust image conversion CLI (renamed upstream to
# imagineer/ig but the sic binary alias is still shipped). NOTE:
# distinct from suckless.org `sic` IRC client (single-dash flags
# -h HOST -p PORT -n NICK -k PASS -f FULLNAME -v). This completion
# targets the Rust image tool.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-i --input)'{-i+,--input=}'[input image file]:file:_files' \
  '(-o --output)'{-o+,--output=}'[output image file]:file:_files' \
  '--output-format=[explicit output format]:format:(avif bmp gif jpeg png webp pnm farbfeld ico tiff)' \
  '--glob-input=[glob pattern for multiple input files]:pattern:' \
  '--glob-output=[output directory for batch processing]:dir:_files -/' \
  '--jpeg-encoding-quality=[JPEG quality 1-100]:quality:' \
  '--pnm-encoding-ascii[use ASCII encoding for PNM]' \
  '(-x --apply-operations)'{-x+,--apply-operations=}'[script-based operations]:script:' \
  '--preserve-aspect-ratio[maintain aspect ratio during resizing]' \
  '--sampling-filter=[resize filter]:filter:(catmullrom gaussian lanczos3 nearest triangle)' \
  '*::script path or operation:_files' && ret=0

return ret
