#compdef systemd-cgls
# _systemd-cgls — systemd systemd-cgls (control-group tree dumper showing every cgroup + the processes inside it; -a include kernel threads, -l do not truncate lines, -u/--unit print a single unit's cgroup, --no-pager, --no-legend, -p/--show-pid, -k include kernel threads; positional argument is an optional cgroup path)
# upstream: https://github.com/systemd/systemd (src/cgls)
# Flags from systemd src/cgls/cgls.c on tip.

_systemd-cgls() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-a[include kernel threads]' \
        '--all[include kernel threads]' \
        '-l[do not truncate lines]' \
        '--full[do not truncate lines]' \
        '-k[include kernel threads]' \
        '--kernel-threads[include kernel threads]' \
        '*-u+[unit]:unit:' \
        '*--unit+[unit]:unit:' \
        '-p[show PIDs]' \
        '--no-pager[no pager]' \
        '--no-legend[no legend]' \
        '*:cgroup path:'
}

_systemd-cgls "$@"
