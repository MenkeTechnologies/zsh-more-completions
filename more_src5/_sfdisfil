#compdef sfdisfil
# Documentation: http://www.ahay.org/RSF/sfdisfil.html
# Source: ahay/src system/main/disfil.c — display the data values of an RSF dataset as text.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'number=[(y/n) number the elements]: :(y n)' \
    'col=[number of columns]: :_default' \
    'format=[printf-style number format]: :_default' \
    'header=[header string before data]: :_default' \
    'trailer=[trailer string after data]: :_default' \
    '*:RSF file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
