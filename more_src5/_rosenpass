#compdef rosenpass
# _rosenpass — post-quantum WireGuard key exchange (rosenpass/rosenpass)
# upstream: https://github.com/rosenpass/rosenpass
# Subcommands from rosenpass/src/cli.rs (clap).

_rosenpass() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--log-level=[lowest log level to show]:level:(off error warn info debug trace)' \
        '(-v --verbose)'{-v,--verbose}'[verbose / debug logging]' \
        '(-q --quiet)'{-q,--quiet}'[suppress all but error logs]' \
        '--psk-broker-path=[WireGuard PSK broker socket]:file:_files' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'exchange-config:start key exchanges from config file'
                'exchange:start key exchanges from CLI args'
                'gen-config:generate a demo config file'
                'gen-keys:generate secret & public keys'
                'validate:validate a configuration file'
                'keygen:generate a single keypair'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                exchange-config) _arguments '1:config file:_files -g "*.toml"' ;;
                gen-config)
                    _arguments \
                        '(-f --force)'{-f,--force}'[overwrite existing config file]' \
                        '1:output config:_files -g "*.toml"'
                    ;;
                gen-keys)
                    _arguments \
                        '(-p --public-key)'{-p+,--public-key=}'[public key output]:file:_files' \
                        '(-s --secret-key)'{-s+,--secret-key=}'[secret key output]:file:_files' \
                        '(-f --force)'{-f,--force}'[overwrite key files]' \
                        '1:config file:_files -g "*.toml"'
                    ;;
                validate) _arguments '*:config file:_files -g "*.toml"' ;;
            esac
            ;;
    esac
}

_rosenpass "$@"
