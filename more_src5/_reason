#compdef refmt
# Documentation: https://reasonml.github.io/docs/en/refmt
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above. The binary is `refmt`; there is no
# CLI named `reason`. The script formerly aliased to `reason` is removed.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--parse=[input syntax]:syntax:(ml re binary binary_reason)' \
  '(-p --print)'{-p+,--print=}'[output format]:format:(ml re ast binary binary_reason none)' \
  '(-i --interface)'{-i+,--interface=}'[parse as interface file]:bool:(true false)' \
  '(-r --recoverable)'{-r,--recoverable}'[enable recoverable parser]' \
  '(-e --assume-explicit-arity)'{-e,--assume-explicit-arity}'[assume explicit arity for constructors]' \
  '--in-place[reformat file in place]' \
  '(-w --print-width)'{-w+,--print-width=}'[wrapping width in columns]:cols' \
  '(-h --heuristics-file)'{-h+,--heuristics-file=}'[heuristics file for tuple handling]:file:_files' \
  '*:file:_files -g "*.(re|ml|rei|mli)"' && ret=0

return ret
