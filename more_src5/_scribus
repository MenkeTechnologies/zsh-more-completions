#compdef scribus
# Documentation: https://manpages.ubuntu.com/manpages/jammy/en/man1/scribus.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-l --lang)'{-l+,--lang=}'[interface language (POSIX code)]:lang:' \
  '(-la --langs-available)'{-la,--langs-available}'[list available UI translations]' \
  '(-f --file)'{-f+,--file=}'[open specified file]:file:_files -g "*.sla"' \
  '(-fi --font-info)'{-fi,--font-info}'[display font file listing at startup]' \
  '(-pi --profile-info)'{-pi,--profile-info}'[show available color profiles]' \
  '(-pr --prefs)'{-pr+,--prefs=}'[custom preferences file path]:file:_files' \
  '(-py --python-script)'{-py+,--python-script=}'[execute Python script]:script:_files -g "*.py"' \
  '(-ns --no-splash)'{-ns,--no-splash}'[hide splash screen during startup]' \
  '(-nns --never-splash)'{-nns,--never-splash}'[permanently disable splash screen]' \
  '(-sb --swap-buttons)'{-sb,--swap-buttons}'[enable right-to-left dialog button ordering]' \
  '(-u --upgradecheck)'{-u,--upgradecheck}'[check for latest available versions]' \
  '*:file:_files -g "*.sla"' && ret=0

return ret
