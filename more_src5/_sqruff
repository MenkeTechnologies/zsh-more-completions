#compdef sqruff
# Documentation: https://github.com/quarylabs/sqruff
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Subcommand surface and global flags verified against the project README;
# lint/fix --format values mirror clap definitions.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'lint:lint SQL files (files, directories, or - for stdin)'
  'fix:apply auto-fixes to SQL files'
  'lsp:run the language server'
  'info:print toolchain and environment metadata'
  'rules:list or describe lint rules'
  'dialects:list supported SQL dialects'
  'templaters:list configured templaters'
)

_arguments -C -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config=[path to sqruff config file]:config:_files' \
  '--dialect=[override SQL dialect]:dialect:' \
  '--parsing-errors[print parser diagnostics]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'sqruff command' subcmds && ret=0 ;;
  (args)
    case $line[1] in
      (lint|fix)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-f --format)'{-f,--format=}'[result format]:format:(human github-annotation-native json)' \
          '--config=[path to sqruff config file]:config:_files' \
          '--dialect=[override SQL dialect]:dialect:' \
          '--parsing-errors[print parser diagnostics]' \
          '*:path:_files' && ret=0 ;;
      (lsp|info|rules|dialects|templaters)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config=[path to sqruff config file]:config:_files' \
          '--dialect=[override SQL dialect]:dialect:' \
          '--parsing-errors[print parser diagnostics]' && ret=0 ;;
    esac ;;
esac

return ret
