#compdef svgexport
# Documentation: https://github.com/shakiba/svgexport
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.
# Removed from prior file: fabricated -h/--help/-v/--version flags. svgexport
# is positional-only: `svgexport <input> <output> [options]` or
# `svgexport <datafile>`; there are no documented flags.

local curcontext="$curcontext" ret=1

_arguments -C '*:input_or_args:_files -g "*.{svg,json,js}"' && ret=0

return ret
