#compdef starship-cli starship
# Documentation: https://github.com/starship/starship/blob/master/src/main.rs
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'bug-report:create a pre-populated GitHub issue'
  'completions:generate shell completions to stdout'
  'config:edit starship configuration'
  'explain:explain currently shown modules'
  'init:print shell function used to execute starship'
  'module:print a specific prompt module'
  'preset:print a preset config'
  'print-config:print computed starship configuration'
  'prompt:print full starship prompt'
  'session:generate random session key'
  'statusline:print statusline for a specific provider'
  'timings:print timings of all active modules'
  'toggle:toggle a starship module'
  'config-schema:generate JSON schema for starship configuration'
)

# Properties common to prompt/module/explain/timings/statusline
local -a _starship_properties
_starship_properties=(
  '(-s --status)'{-s+,--status=}'[status code of last command]:code:'
  '*--pipestatus=[pipe statuses separated by spaces]:statuses:'
  '(-w --terminal-width)'{-w+,--terminal-width=}'[terminal width override]:width:'
  '(-p --path)'{-p+,--path=}'[working directory]:dir:_files -/'
  '-P+[logical path override]:path:'
  '--logical-path=[logical path override]:path:'
  '(-d --cmd-duration)'{-d+,--cmd-duration=}'[command duration in ms]:ms:'
  '(-k --keymap)'{-k+,--keymap=}'[shell keymap]:keymap:'
  '(-j --jobs)'{-j+,--jobs=}'[number of running jobs]:n:'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'starship command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (init)
        _arguments \
          '--print-full-init[print full init script]' \
          '1:shell:(bash zsh fish powershell pwsh ion elvish tcsh nu xonsh)' && ret=0 ;;
      (prompt)
        _arguments \
          '--right[print right prompt]' \
          '--profile=[use specified profile]:profile:' \
          '--continuation[print continuation prompt]' \
          $_starship_properties && ret=0 ;;
      (module)
        _arguments \
          '(-l --list)'{-l,--list}'[list available modules]' \
          $_starship_properties \
          '*:module:' && ret=0 ;;
      (config)
        _arguments \
          '1:name:' \
          '2:value:' && ret=0 ;;
      (toggle)
        _arguments \
          '1:module:' \
          '2:key (default disabled):' && ret=0 ;;
      (preset)
        _arguments \
          '(-l --list)'{-l,--list}'[list preset names]' \
          '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
          '*:preset:' && ret=0 ;;
      (print-config)
        _arguments \
          '(-d --default)'{-d,--default}'[print default instead of computed config]' \
          '*:name:' && ret=0 ;;
      (statusline)
        _arguments \
          '1:provider:(claude-code claude)' \
          '--profile=[profile]:profile:' \
          $_starship_properties && ret=0 ;;
      (explain|timings)
        _arguments $_starship_properties && ret=0 ;;
      (completions)
        _arguments '1:shell:(bash elvish fish nushell powershell pwsh zsh)' && ret=0 ;;
      (bug-report|session|time|config-schema) ;;
    esac ;;
esac

return ret
