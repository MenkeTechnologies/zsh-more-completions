#compdef sfheadersort
# Documentation: http://www.ahay.org/RSF/sfheadersort.html
# Source: ahay/src system/main/headersort.c — sort an RSF dataset by header values.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'head=[header file containing sort keys]: :_files -g "*.rsf(-.)"' \
    '*:RSF file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
