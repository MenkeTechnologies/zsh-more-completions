#compdef silq
# =============================================================================
# silq — silq-lang/silq's "Silq" QUANTUM
#   PROGRAMMING LANGUAGE — a HIGH-LEVEL,
#   STRONGLY-TYPED quantum language from ETH
#   Zurich's Secure, Reliable, and Intelligent
#   Systems Lab.  Ships a TYPE CHECKER + a
#   classical SIMULATOR built directly into the
#   `silq` binary, so quantum programs can be
#   developed + verified + simulated without
#   any external dependencies or quantum
#   hardware backend.  Implemented in the D
#   programming language, compiled via LDC.
#   130th language entry in the corpus.
#
# 130TH LANGUAGE ENTRY — Silq closes the 3+1
# micro-cycle started after Axis 50 (Full-Text
# Search Engine) closed at 1/1/1 three-language
# symmetry in R791 (TS-Node=105 `_compodoc` on
# lunr ^2.3.9 + R790 Go=105 `_srchx` on
# blevesearch/bleve v0.7.0 + R789 Rust=105
# `_toshi` on quickwit-oss/tantivy ^0.19) —
# the half-century axis landmark.
#
# Silq is the FIRST QUANTUM PROGRAMMING
# LANGUAGE in the corpus.  Distinguishing
# from the 129 prior languages:
#   - Q# (Microsoft, Q-Sharp): closely
#     related design goals — high-level
#     quantum language, classical+quantum
#     interop, simulator + hardware backends.
#     Differences:
#       * Q# is .NET-hosted (Mono/CoreCLR);
#         Silq is a standalone D binary
#       * Q# requires explicit `Adjoint` and
#         `Controlled` functor annotations.
#         Silq INFERS reversibility +
#         uncomputation automatically —
#         a key research contribution
#       * Q# leaves UNCOMPUTATION to the
#         programmer (manual `using`-block
#         management).  Silq's type system
#         CATCHES uncomputation errors at
#         compile time
#   - Quipper: Haskell-hosted DSL for
#     quantum.  Silq is a standalone language
#   - Cirq / Qiskit: Python LIBRARIES for
#     quantum circuit construction.  Silq is
#     a LANGUAGE with native quantum types
#     (`!ℕ`, `!𝔹`, `qubit`, superposition
#     `|0⟩ + |1⟩`)
#   - QASM / Quil: low-level instruction-
#     stream formats akin to assembly.  Silq
#     is a high-level surface
#   - Liquid (Microsoft Research's classical
#     LIQUi|>): predecessor to Q#.  Now
#     superseded
#
# KEY SILQ LANGUAGE FEATURES (per the ETH
# PLDI 2020 paper "Silq: A High-Level Quantum
# Language with Safe Uncomputation and
# Intuitive Semantics"):
#   - AUTOMATIC UNCOMPUTATION — Silq's type
#     system detects when an intermediate
#     quantum register can be safely
#     uncomputed (un-entangled from the
#     rest of the program state).  The
#     compiler inserts the uncomputation
#     gates automatically; the programmer
#     never writes them.  Eliminates the
#     entire class of "forgot to
#     uncompute" bugs that plague Q# /
#     Quipper code
#   - QFREE ANNOTATION — functions marked
#     `qfree` are guaranteed to introduce
#     no quantum entanglement (i.e. they
#     map basis states to basis states).
#     The compiler verifies the
#     restriction.  Critical for safe
#     reversibility analysis
#   - DEPENDENT TYPES FOR ARRAY SIZES —
#     `uint[n]` for an n-qubit register
#     where `n` is a value-level
#     expression.  Silq's type system
#     statically tracks register sizes
#     through gate sequences
#   - INTUITIVE QUANTUM SYNTAX — `H(q)`
#     applies Hadamard; `q := measure(r)`
#     measures a register into a classical
#     value; `if q { ... }` is quantum-
#     controlled (the body becomes a
#     controlled operation on `q`).  No
#     `Adjoint` / `Controlled` keyword
#     gymnastics
#   - CLASSICAL + QUANTUM TYPES — `!ℕ`
#     denotes a classical natural number;
#     `ℕ` denotes a quantum one (basis-
#     state-superposable).  Compiler
#     prevents accidental quantum-to-
#     classical leaks
#   - BUILT-IN SIMULATOR — the binary's
#     `--run` flag classically simulates
#     the main function over the
#     accessible Hilbert space.  No
#     external SDK needed.  `--style`
#     and `--coords` tune how the
#     resulting amplitude distribution is
#     printed (compact vs verbose;
#     cartesian a+bi vs polar r∠θ)
#   - TOP-K AMPLITUDE INSPECTION —
#     `--top[=k]` filters the simulator
#     output to the k highest-amplitude
#     basis states.  Critical for
#     debugging programs whose state
#     space exceeds a few qubits
#   - FIXED-POINT INFERENCE LIMIT —
#     `--inference-limit=<n>` caps the
#     number of type-inference iterations
#     for recursive quantum functions.
#     Default is sufficient for most
#     programs; raise it for deeply
#     recursive code
#   - REPRODUCIBLE RANDOM SEEDS —
#     `--seed=<n>` fixes the simulator
#     RNG for repeatable experiments.
#     Different seeds explore different
#     paths through the measurement-
#     induced collapse tree
#   - ERROR DIAGNOSTICS AS JSON —
#     `--error-json` emits errors in a
#     machine-parseable format for IDE
#     integration (Silq's VS Code
#     extension consumes this)
#   - PROGRAM SUMMARISATION —
#     `--summarize=[name,arg-arity,ret-
#     arity]` introspects function
#     signatures without running the
#     program.  Useful for static
#     analysis tooling on top of Silq
#
# QUANTUM STATE FORMAT (`--fmt=<MODE>`):
# Combines style and amplitude representation
# into a single hyphenated mode token, e.g.:
#   * `compact-cartesian`   — `0.707 + 0i`
#                              one-line per
#                              state
#   * `compact-polar`       — `0.707 ∠ 0`
#                              one-line per
#                              state
#   * `pretty-cartesian`    — multi-line
#                              formatted
#                              cartesian
#                              amplitudes
#   * `pretty-polar`        — multi-line
#                              formatted polar
#                              amplitudes
#                              (DEFAULT)
# `--style=<S>` and `--coords=<C>` override
# the corresponding half of `--fmt` if both
# are given.
#
# SOURCE FILE EXTENSION: `*.slq`
#
# CRITICAL BUILD DEPENDENCIES (from
# dependencies.sh / build-release.sh):
#   - LDC                      — LLVM-based D
#                                compiler.
#                                Downloaded
#                                automatically
#                                by
#                                dependencies-
#                                release.sh
#                                if not on
#                                PATH
#   - libgmp, libmpfr          — arbitrary-
#                                precision
#                                arithmetic
#                                for the
#                                simulator's
#                                amplitude
#                                fields
#   - DUB                      — D package
#                                manager.
#                                dub.json
#                                ships in the
#                                repo
#
# SUPPORTED PLATFORMS:
# Linux (x86-64), macOS (x86-64 + arm64),
# FreeBSD/amd64 (ports tree).  WebAssembly
# build available via build-wasm-ldc.sh
# (LDC + Emscripten).  Windows cross-build
# from Linux supported via build-xwindows-
# release.sh.
#
# UPSTREAM:
#   * Source             : https://github.com/silq-lang/silq
#   * Site               : https://silq.ethz.ch
#   * VS Code extension  : https://silq.ethz.ch/install
#   * PLDI 2020 paper    : https://doi.org/10.1145/3385412.3386007
#   * License            : BSL-1.0 (Boost Software License)
#   * Authors            : Benjamin Bichsel, Maximilian Baader,
#                          Timon Gehr, Martin Vechev (ETH Zurich)
#
# INSTALL:
#   # Build from source (Linux/macOS)
#   git clone https://github.com/silq-lang/silq
#   cd silq
#   ./dependencies-release.sh
#   ./build-release.sh
#
#   # FreeBSD ports
#   cd /usr/ports/lang/silq && make install
#   # Or binary package
#   pkg install silq
#
#   # VS Code extension (recommended for
#   # interactive development)
#   #   Install "silq" from the Marketplace
#
# USAGE EXAMPLES:
#
#   # Type-check a Silq file (no execution)
#   silq main.slq
#
#   # Type-check + classically simulate main()
#   silq --run main.slq
#
#   # Run main() with an explicit input
#   silq --run-on='5' main.slq
#
#   # Run main() with each element of a list
#   # as input
#   silq --run-on-each='[0,1,2,3,4]' main.slq
#
#   # Run an inline expression (no source file)
#   silq --run='H(0:𝔹)'
#
#   # Repeat the run 10 times (collect
#   # measurement distribution)
#   silq --run --repeat=10 main.slq
#
#   # Fixed seed for reproducibility
#   silq --run --seed=42 main.slq
#
#   # Trace each statement + state
#   silq --run --trace main.slq
#
#   # Verbose multi-line cartesian output
#   silq --run --style=pretty --coords=cartesian main.slq
#   silq --run --fmt=pretty-cartesian main.slq
#
#   # Compact polar output (one line per basis
#   # state, magnitude + angle)
#   silq --run --fmt=compact-polar main.slq
#
#   # Show only the top-5 amplitude basis
#   # states
#   silq --run --top=5 main.slq
#
#   # Raise fixed-point inference limit for
#   # deeply recursive quantum code
#   silq --inference-limit=10000 deep.slq
#
#   # Summarize function declarations + exit
#   silq --summarize='[name,arg-arity,ret-arity]' lib.slq
#
#   # JSON diagnostics (for IDE integration)
#   silq --error-json main.slq
#
#   # Multi-file compilation
#   silq lib.slq main.slq
#
#   # Help
#   silq --help
#
# OPTIONS (sourced directly from
# https://github.com/silq-lang/silq/blob/master/help.d help text):
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _silq_styles
_silq_styles=(
    'compact:One-line per basis state'
    'pretty:Multi-line verbose formatting (default)'
)

local -a _silq_coords
_silq_coords=(
    'cartesian:Amplitudes as a + bi'
    'polar:Amplitudes as r ∠ θ (default)'
)

local -a _silq_fmt_modes
_silq_fmt_modes=(
    'compact-cartesian:Compact cartesian amplitudes'
    'compact-polar:Compact polar amplitudes'
    'pretty-cartesian:Pretty cartesian amplitudes'
    'pretty-polar:Pretty polar amplitudes (default)'
)

_arguments -C \
    '(- *)--help[show help]' \
    '--run[run main() in the classical simulator]' \
    '--run-on=[run main() with argument given by expression]:expr: ' \
    '--run-on-each=[run main() on each element of expression]:expr: ' \
    '--run=[run an expression directly (no source file)]:expr: ' \
    '--repeat=[repeat the run n times]:n: ' \
    '--trace[print statements as they run, together with state]' \
    '--seed=[fixed random seed for reproducible experiments]:n: ' \
    '--fmt=[quantum state formatting MODE = STYLE-COORDS]:mode:->fmt' \
    '--style=[verbosity style (overrides --fmt style half)]:style:->style' \
    '--coords=[amplitude representation (overrides --fmt coords half)]:coords:->coords' \
    '--top=[sort by amplitudes, restricted to top-k]:k: ' \
    '--inference-limit=[max iterations for fixed-point inference]:n: ' \
    '--summarize=[summarize function declarations and exit (ex: [name,arg-arity,ret-arity])]:spec: ' \
    '--error-json[print diagnostics in JSON format]' \
    '*:Silq source file:_files -g "*.slq"' \
    && ret=0

case $state in
    style)
        _describe -t styles 'verbosity style' _silq_styles && ret=0 ;;
    coords)
        _describe -t coords 'amplitude representation' _silq_coords && ret=0 ;;
    fmt)
        _describe -t fmt 'quantum state format mode' _silq_fmt_modes && ret=0 ;;
esac

return ret
