#compdef s6-fdholder-getdump
# _s6-fdholder-getdump — s6 fdholder s6-fdholder-getdump (dump all stored fds + their metadata from a running s6-fdholderd, then exec child with the dump available — used for live migration)
# upstream: https://github.com/skarnet/s6
# Flags from src/fdholder/s6-fdholder-getdump.c on tip.

_s6-fdholder-getdump() {
    _arguments \
        '-t+[timeout (ms)]:ms:' \
        '1:socket:_files' \
        '*::program:_command_names -e'
}

_s6-fdholder-getdump "$@"
