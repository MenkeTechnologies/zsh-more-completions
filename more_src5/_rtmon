#compdef rtmon
# Documentation: man rtmon(8)
# Source: iproute2/iproute2 ip/rtmon.c (main) — capture routing/link/address events to file (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-f -family)'{-f+,-family+}'[address family]:family:(inet inet6 link help)' \
    '(-4 -6 -0)-4[IPv4 family]' \
    '(-4 -6 -0)-6[IPv6 family]' \
    '(-4 -6 -0)-0[unspecified family]' \
    '(-V -Version)'{-V,-Version}'[show version]' \
    'file[record to file FILE]:file:_files' \
    '*:object:(all link address route)' \
    && ret=0

return ret
