#compdef systemd-pcrlock
# _systemd-pcrlock — systemd systemd-pcrlock (TPM PCR policy builder/locker for TPM2-bound disk encryption; subcommands: log/cel-log show PCR measurement logs, lock-firmware-config / unlock-firmware-config, lock-secureboot-policy, lock-gpt, lock-pe, lock-uki, lock-machine-id, lock-fs-config, predict, make-policy, remove-policy, list-components, --json output, --pcr=NN+NN comma-list)
# upstream: https://github.com/systemd/systemd (src/pcrlock)
# Subcommands from systemd src/pcrlock/pcrlock.c on tip.

_systemd-pcrlock() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--no-pager[no pager]' \
        '--no-legend[no legend]' \
        '--json=*[json mode]:mode:(short pretty off)' \
        '--pcr=*[PCR list]:pcrs:' \
        '--nv-index=*[NV index]:index:' \
        '--recovery-pin=*[recovery pin]:mode:(query show hide)' \
        '--policy+[policy file]:file:_files' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'pcrlock command' '(log cel-log list-components predict make-policy remove-policy lock-firmware-config unlock-firmware-config lock-secureboot-policy unlock-secureboot-policy lock-secureboot-authority unlock-secureboot-authority lock-gpt unlock-gpt lock-pe unlock-pe lock-uki unlock-uki lock-machine-id unlock-machine-id lock-fs-config unlock-fs-config lock-kernel-cmdline unlock-kernel-cmdline lock-kernel-initrd unlock-kernel-initrd help)' ;;
        args) _arguments '*:argument:_files' ;;
    esac
}

_systemd-pcrlock "$@"
