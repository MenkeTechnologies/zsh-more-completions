#compdef smu
# Documentation: https://github.com/karlb/smu
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above (only -n is explicitly documented).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-n[strictly escape HTML tags]' \
  '*:markdown file:_files' && ret=0

return ret
