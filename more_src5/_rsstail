#compdef rsstail
# Documentation: https://manpages.debian.org/bookworm/rsstail/rsstail.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (C rsstail by Folkert van Heusden).

# rsstail (C version, flok99) uses single-dash short options only.

_arguments -s \
  '-h[show help]' \
  '-V[show version]' \
  '*-v[verbose (repeatable)]' \
  '-t[show timestamp]' \
  '-l[show link]' \
  '-d[show description]' \
  '-p[show pubdate]' \
  '-a[show author]' \
  '-c[show comments]' \
  '-N[do not show headings]' \
  '-Z+[add heading prefix]:str:' \
  '-b+[limit description/comments to N bytes]:n:' \
  '-z[continue past XML parser errors]' \
  '-n+[initially display N items]:n:' \
  '-H[strip HTML tags]' \
  '*-u+[URL of RSS feed]:url:_urls' \
  '-i+[check interval seconds (default 900)]:n:' \
  '-r[print in reverse order]' \
  '-x+[proxy server host[:port]]:proxy:' \
  '-y+[proxy authorization user:password]:auth:' \
  '-P[do not exit on error]' \
  '-o+[only show items newer than duration]:dur:'
