#compdef rust-lldb
# Documentation: Rust toolchain rust-lldb (lldb wrapper with Rust pretty-printers)
# Source: Rust rust-lldb — invoke lldb with Rust formatters preloaded.
# Reference accessed: 2026-06-10
# NOTE: rust-lldb forwards every flag to lldb; cover the most-used lldb flags.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-v,--version}'[show lldb version]' \
    '(- *)'{-h,--help}'[show help]' \
    '*'{-o,--one-line=}'[execute lldb command after startup]:cmd:' \
    '*'{-O,--one-line-before-file=}'[execute lldb command before loading file]:cmd:' \
    '*'{-s,--source=}'[read commands from file]:file:_files' \
    '*'{-S,--source-before-file=}'[read commands from file before loading]:file:_files' \
    '(-x --no-lldbinit)'{-x,--no-lldbinit}'[do not read ~/.lldbinit]' \
    '(-X --debug-lldb-init)'{-X,--debug-lldb-init}'[debug ~/.lldbinit]' \
    '(-Q --source-quietly)'{-Q,--source-quietly}'[execute source commands quietly]' \
    '(-l --script-language)'{-l,--script-language=}'[scripting language]:lang:(python lua none default)' \
    '(-K --source-on-crash)'{-K,--source-on-crash=}'[source FILE on crash]:file:_files' \
    '*'{-k,--source-on-quit=}'[execute command on quit]:cmd:' \
    '(-d --debug)'{-d,--debug}'[enable lldb debug logging]' \
    '(-w --wait-for)'{-w,--wait-for}'[wait for process to launch]' \
    '(-n --attach-name)'{-n,--attach-name=}'[attach to process by name]:name:' \
    '(-p --attach-pid)'{-p,--attach-pid=}'[attach to process by pid]:pid:_pids' \
    '(-c --core)'{-c,--core=}'[load a core file]:file:_files' \
    '(-f --file)'{-f,--file=}'[target executable]:file:_files' \
    '(-a --arch)'{-a,--arch=}'[target architecture]:arch:(arm64 arm64e x86_64 i386)' \
    '(-b --batch)'{-b,--batch}'[non-interactive batch mode]' \
    '(-r --repl)'{-r,--repl=-}'[run in REPL mode]::compiler-args:' \
    '(-R --repl-language)'{-R,--repl-language=}'[REPL language]:lang:' \
    '(-E --editor)'{-E,--editor}'[start in editor mode]' \
    '*:executable then args:_files' \
    && ret=0

return ret
