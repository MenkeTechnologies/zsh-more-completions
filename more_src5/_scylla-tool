#compdef scylla-tool
# Documentation: https://github.com/scylladb/scylladb/tree/master/tools
# Reference accessed: 2026-05-21
# Verified: upstream tools/ directory listing shows no "scylla-tool" binary;
# real binaries are scylla-nodetool, scylla-sstable, scylla-types,
# scylla-local-file-key-generator (each with its own subcommand set).
# Removed from prior file: all "scylla-tool subcommand" entries
# (sstable/commitlog/system_schema/compact/sstabledump/sstableinfo/
# sstableupgrade/sstableloader/sstablerepairedset/sstablelevelreset/
# sstableofflinerelevel/types) — those subcommands belong to scylla-sstable
# and scylla-types, not a unified "scylla-tool" binary.
# STUB: no upstream binary named "scylla-tool"; keep as file-only fallback.

local curcontext="$curcontext" state line ret=1
_arguments -s -S '*:file:_files' && ret=0
return ret
