#compdef rust-readobj
# Documentation: https://llvm.org/docs/CommandGuide/llvm-readobj.html
# Reference accessed: 2026-05-21
# Verified: cargo-binutils (rust-embedded/cargo-binutils) wrapper invoking
# llvm-readobj from the Rust toolchain sysroot; same flag surface as
# llvm-readobj upstream.

local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--all[display all main format-relevant info]' \
  '(-h --file-header)'{-h,--file-header}'[display file header]' \
  '(-S --sections)'{-S,--sections}'[display all sections]' \
  '(-s --symbols)'{-s,--symbols}'[display symbol table]' \
  '(-r --relocations)'{-r,--relocations}'[display relocations]' \
  '*'{-x+,--hex-dump=}'[hex dump section]:section:' \
  '*'{-p+,--string-dump=}'[string dump section]:section:' \
  '(-C --demangle)'{-C,--demangle}'[demangle symbol names]' \
  '(-u --unwind)'{-u,--unwind}'[display unwind information]' \
  '(-l --program-headers)'{-l,--program-headers}'[display program headers (ELF)]' \
  '(-d --dynamic-table)'{-d,--dynamic-table}'[display dynamic table (ELF)]' \
  '--dyn-symbols[display dynamic symbol table (ELF)]' \
  '(-n --notes)'{-n,--notes}'[display notes (ELF)]' \
  '(-V --version-info)'{-V,--version-info}'[display version sections (ELF)]' \
  '--elf-output-style=[ELF output style]:style:(LLVM GNU JSON)' \
  '*:object file:_files' && ret=0
return ret
