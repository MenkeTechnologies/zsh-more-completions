#compdef qmail qmailctl
# Documentation: https://github.com/sagredo-dev/qmail/blob/main/scripts/qmailctl
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# NOTE: qmail itself is not a single CLI; this completion targets qmailctl,
# the canonical control wrapper script that ships with qmail packages.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start mail service'
  'stop:stop mail service'
  'restart:stop and restart smtp and qmail-send'
  'reload:re-read locals and virtualdomains'
  'stat:display status of mail service'
  'pause:temporarily stop mail service'
  'cont:continue paused mail service'
  'flush:schedule queued messages for immediate delivery'
  'doqueue:schedule queued messages for immediate delivery'
  'queue:show queue stats'
  'cdb:rebuild the tcpserver cdb file for smtp'
  'help:show help'
)

_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'qmailctl command' commands && ret=0 ;;
esac

return ret
