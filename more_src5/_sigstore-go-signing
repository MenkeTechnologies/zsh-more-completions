#compdef sigstore-go-signing
# _sigstore-go-signing — sample sigstore-go binary that signs a payload (sigstore/sigstore-go)
# upstream: https://github.com/sigstore/sigstore-go
# Flags from examples/sigstore-go-signing/main.go (flag).

_sigstore-go-signing() {
    _arguments \
        '-id-token=[OIDC token to send to Fulcio]:token:' \
        '-in-toto[content to sign is an in-toto document]' \
        '-tsa[include signed timestamp from timestamp authority]' \
        '-rekor[include transparency log entry from Rekor]' \
        '(-s -signing-config)'{-s+,-signing-config=}'[path to signingconfig JSON file]:file:_files' \
        '(-t -trusted-root)'{-t+,-trusted-root=}'[path to trusted root JSON file]:file:_files' \
        '1:payload file:_files'
}

_sigstore-go-signing "$@"
