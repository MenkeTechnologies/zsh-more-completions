#compdef sbcl-cli sbcl2
# _sbcl-cli — SBCL Team sbcl-cli CLI command-line frontend wrapping the Steel Bank Common Lisp SBCL high performance ANSI Common Lisp compiler open-source written in Common Lisp originally derived from CMU CL by William Newman in 1999 forked from CMU CL Common-Lisp ANSI Common Lisp implementation native compiler MOP class precedence list slot value generic-function method package symbol macro setf compile load eval print-loop interactive REPL toplevel core image dynamic-space-size control-stack-size disable-debugger lose-on-corruption end-runtime-options end-toplevel-options sysinit userinit non-interactive eval no-debugger debug-on-error help (SBCL Team William Newman Christophe Rhodes, Common Lisp); custom argparse
# upstream: https://www.sbcl.org/

_sbcl-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--core=+[file]:file:_files -g "*.core"' \
        '--dynamic-space-size=+[N]:n:' \
        '--control-stack-size=+[N]:n:' \
        '--tls-limit=+[N]:n:' \
        '--lose-on-corruption[lose on corruption]' \
        '--disable-ldb[disable LDB]' \
        '--no-sysinit[no sysinit]' \
        '--no-userinit[no userinit]' \
        '--no-debugger[no debugger]' \
        '--disable-debugger[disable debugger]' \
        '--debug-on-error[debug on error]' \
        '--sysinit=+[file]:file:_files' \
        '--userinit=+[file]:file:_files' \
        '--script=+[file]:file:_files -g "*.lisp"' \
        '--non-interactive[non interactive]' \
        '--quit[quit]' \
        '--no-quit[no quit]' \
        '--eval=+[expression]:str:' \
        '*--eval=+[expression]:str:' \
        '--load=+[file]:file:_files -g "*.lisp"' \
        '*--load=+[file]:file:_files -g "*.lisp"' \
        '--end-toplevel-options[end toplevel options]' \
        '--end-runtime-options[end runtime options]' \
        '--print=+[expr]:str:' \
        '*--print=+[expr]:str:' \
        '--no-print[no print]' \
        '--merge-core-pages[merge core pages]' \
        '--no-merge-core-pages[no merge core pages]' \
        '--default-merge-core-pages[default merge core pages]' \
        '--noprint[no print]' \
        '--noinform[no inform]' \
        '*:lisp file:_files -g "*.lisp *.lsp *.cl *.fasl"'
}

_sbcl-cli "$@"
