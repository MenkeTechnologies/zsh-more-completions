#compdef staq staq-cli staq2qasm staq2quil staq-tools
# _staq — Stanford softwareQinc staq fast OpenQASM 2.0 compiler with optimization passes and code generation (softwareqinc team, C++); custom argparse
# upstream: https://github.com/softwareQinc/staq

_staq() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-c+[input compiler]:c:(openqasm qasm 2 3 staq)' \
        '--compiler=+[input compiler]:c:(openqasm qasm 2 3 staq)' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-O+[opt level]:l:(0 1 2 3)' \
        '-d+[device]:str:' \
        '--device=+[device]:str:' \
        '-S+[output format]:f:(qasm staq cirq quil projectq qsharp ionq tket pyquil oqasm openqasm2 openqasm3 resources)' \
        '--output-format=+[format]:f:(qasm staq cirq quil projectq qsharp ionq tket pyquil oqasm)' \
        '--inline-stdgates[inline standard gates]' \
        '--no-inline[do not inline]' \
        '--simplify[apply simplification]' \
        '--cnot-resynth[CNOT resynthesis]' \
        '--rotation-folding[rotation folding]' \
        '--rules-based[rule-based optimization]' \
        '--matrix-based[matrix-based optimization]' \
        '--max-fold-depth=+[N]:n:' \
        '--mapping=+[mapping algorithm]:m:(swap-network steiner basic shortest)' \
        '--layout=+[layout algorithm]:l:(linear bestfit eager)' \
        '--routing=+[routing algorithm]:r:(astar steiner)' \
        '--decompose[decompose to native gates]' \
        '--device-config=+[json file]:file:_files -g "*.json *.yaml *.yml"' \
        '--basis-gates=+[gates csv]:str:' \
        '--coupling-map=+[json]:str:' \
        '--counts[print operation counts]' \
        '--depth[print circuit depth]' \
        '--show-help-message[show full help]' \
        '--no-progress[no progress]' \
        '*:source file:_files -g "*.qasm *.qpp *.staq"'
}

_staq "$@"
