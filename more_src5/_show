#compdef show
# Documentation: man show(1)
# Source: nmh uip/show.c (master) — display nmh messages (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-checkmime -nocheckmime)-checkmime[check for MIME content]' \
    '(-checkmime -nocheckmime)-nocheckmime[do not check MIME]' \
    '(-header -noheader)-header[show one-line header]' \
    '(-header -noheader)-noheader[no one-line header]' \
    '-form+[format file]:file:_files' \
    '-moreproc+[pager program]:cmd:_command_names -e' \
    '-nomoreproc[no pager]' \
    '-length+[max lines]:N:_default' \
    '-width+[output columns]:cols:_default' \
    '-showproc+[show program]:cmd:_command_names -e' \
    '-showmimeproc+[show MIME program]:cmd:_command_names -e' \
    '-noshowproc[no show program]' \
    '-draft[show draft message]' \
    '-file+[show file directly]:file:_files' \
    '-fmtproc+[format program]:cmd:_command_names -e' \
    '-nofmtproc[no format program]' \
    '-version[show version]' \
    '-help[show help]' \
    '-concat[concatenate body lines]' \
    '-noconcat[do not concatenate]' \
    '1::+folder:_default' \
    '*::msgs:_default' \
    && ret=0

return ret
