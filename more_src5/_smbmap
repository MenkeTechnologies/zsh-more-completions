#compdef smbmap
# _smbmap — ShawnDEvans smbmap SMB share enumerator and exploiter for Windows networks (ShawnDEvans team, Python); argparse
# upstream: https://github.com/ShawnDEvans/smbmap

_smbmap() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-H+[target host]:host:_hosts' \
        '--host=+[target host]:host:_hosts' \
        '--host-file=+[host list file]:file:_files' \
        '-u+[username]:user:_users' \
        '--username=+[username]:user:_users' \
        '-p+[password]:str:' \
        '--password=+[password]:str:' \
        '-s+[share]:str:' \
        '--share=+[share]:str:' \
        '-d+[domain]:str:' \
        '--domain=+[domain]:str:' \
        '-P+[port]:port:_ports' \
        '--port=+[port]:port:_ports' \
        '-v[show version]' \
        '--ntlm-hash=+[ntlm hash]:str:' \
        '--lmhash=+[lm hash]:str:' \
        '--nthash=+[nt hash]:str:' \
        '-k[kerberos auth]' \
        '--kerberos[kerberos auth]' \
        '--no-pass[no password]' \
        '-r+[recursive list path]:str:' \
        '--recursive=+[recursive list path]:str:' \
        '-R[recursive list root]' \
        '--depth=+[recursion depth]:n:' \
        '-A+[search regex]:str:' \
        '--search=+[search regex]:str:' \
        '--exclude=+[exclude share]:str:' \
        '-x+[command to exec]:str:' \
        '--exec=+[command to exec]:str:' \
        '--mode=+[exec mode]:m:(SHARE SERVER)' \
        '--upload=+[local:remote]:str:' \
        '--download=+[remote path]:str:' \
        '--delete=+[remote path]:str:' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--csv=+[output csv]:file:_files' \
        '--no-banner[no banner]' \
        '--no-color[disable color]'
}

_smbmap "$@"
