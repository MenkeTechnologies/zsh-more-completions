#compdef smbios-wakeup-ctl
# Documentation: https://man.archlinux.org/man/extra/libsmbios/smbios-wakeup-ctl.1.en
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# smbios-wakeup-ctl: configure Dell scheduled wakeup via SMBIOS
local curcontext="$curcontext" ret=1
_arguments -C \
  '--version[show program version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--hour=[set wakeup hour (0-23)]:hour:' \
  '--minute=[set wakeup minute (0-59)]:minute:' \
  '--everyday[set wakeup for every day]' \
  '--weekday[set wakeup for weekdays only]' \
  '--disable[disable wakeups]' \
  '(-v --verbose)'{-v,--verbose}'[display more verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[minimize program output]' \
  '--trace[enable verbose function tracing]' \
  '--logconfig=[alternate config log]:file:_files' \
  '--password=[BIOS Setup password]:password:' \
  '(-r --rawpassword)'{-r,--rawpassword}'[do not auto-convert password to scancodes]' \
  '--memory-dat=[memory dump file]:file:_files' \
  '--cmos-dat=[CMOS dump file]:file:_files' && ret=0
return ret
