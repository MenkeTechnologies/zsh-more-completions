#compdef rmlint
# Documentation: https://manpages.debian.org/bookworm/rmlint/rmlint.1.en.html
# Reference accessed: 2026-05-30
# rmlint — Christopher Pahl & Daniel Thomas's duplicate-and-lint finder.
# Finds duplicate files, empty files/dirs, broken symlinks, broken sUid/sGid
# bits, non-stripped binaries, and bad encodings. Outputs a shell script
# that can be reviewed before running to actually delete the cruft.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show brief help]' \
  '(- *)'{-H,--show-man}'[show full manpage]' \
  '(- *)--version[show version + compiled features]' \
  '*'{-T,--types=}'[lint types to search for (CSV +/-name list)]:types:' \
  '*'{-o,--output=}'[output format/destination]:fmt:file:' \
  '*'{-O,--add-output=}'[add output without overwriting defaults]:fmt:file:' \
  '*'{-c,--config=}'[formatter key=value]:opt:' \
  '(-z --perms)'{-z,--perms=}'[filter by RWX permissions]:perms:' \
  '(-a --algorithm)'{-a,--algorithm=}'[hash algorithm]:algo:(blake2b blake2bp blake2s blake2sp sha3 sha3-256 sha3-384 sha3-512 sha256 sha512 sha1 md5 highway64 highway128 highway256 metro metro256 metrocrc metrocrc256 xxhash murmur murmur256 city city256 cumulative ext paranoid)' \
  '(-p --paranoid -P --less-paranoid)'{-p,--paranoid}'[byte-by-byte verify]' \
  '(-p --paranoid -P --less-paranoid)'{-P,--less-paranoid}'[decrease paranoia for speed]' \
  '(-v --loud -V --quiet)'{-v,--loud}'[stackable verbosity (stderr)]' \
  '(-v --loud -V --quiet)'{-V,--quiet}'[stackable quietness]' \
  '(-g --progress -G --no-progress)'{-g,--progress}'[show progress bar]' \
  '(-g --progress -G --no-progress)'{-G,--no-progress}'[no progress bar]' \
  '(-D --merge-directories)'{-D,--merge-directories}'[find duplicate directory trees]' \
  '(-j --honour-dir-layout)'{-j,--honour-dir-layout}'[require identical path layouts]' \
  '(-y --sort-by)'{-y,--sort-by=}'[sort dup groups]:by:(size name mtime nameorig)' \
  '(-w --with-color -W --no-with-color)'{-w,--with-color}'[color output]' \
  '(-w --with-color -W --no-with-color)'{-W,--no-with-color}'[no color output]' \
  '(-s --size)'{-s,--size=}'[size filter (e.g. 1K-100M)]:range:' \
  '(-d --max-depth)'{-d,--max-depth=}'[max recursion depth]:N:' \
  '(-l --hardlinked -L --no-hardlinked)'{-l,--hardlinked}'[treat hardlinks as dups (default)]' \
  '(-l --hardlinked -L --no-hardlinked)'{-L,--no-hardlinked}'[ignore hardlinks]' \
  '--keep-hardlinked[do not delete hardlinks to originals]' \
  '(-f --followlinks -F --no-followlinks -@ --see-symlinks)'{-f,--followlinks}'[follow symlinks]' \
  '(-f --followlinks -F --no-followlinks -@ --see-symlinks)'{-F,--no-followlinks}'[ignore symlinks]' \
  '(-f --followlinks -F --no-followlinks -@ --see-symlinks)'{-@,--see-symlinks}'[treat symlinks as small files (default)]' \
  '(-x --no-crossdev -X --crossdev)'{-x,--no-crossdev}'[stay on one filesystem]' \
  '(-x --no-crossdev -X --crossdev)'{-X,--crossdev}'[cross mount points (default)]' \
  '(-r --hidden -R --no-hidden)'{-r,--hidden}'[traverse hidden directories]' \
  '(-r --hidden -R --no-hidden)'{-R,--no-hidden}'[skip hidden directories (default)]' \
  '--partial-hidden[include hidden files only inside duplicates]' \
  '(-b --match-basename -B --unmatched-basename)'{-b,--match-basename}'[only match identical basenames]' \
  '(-b --match-basename -B --unmatched-basename)'{-B,--unmatched-basename}'[only match different basenames]' \
  '(-e --match-with-extension -E --no-match-with-extension)'{-e,--match-with-extension}'[only match same extension]' \
  '(-e --match-with-extension -E --no-match-with-extension)'{-E,--no-match-with-extension}'[ignore extension]' \
  '(-i --match-without-extension -I --no-match-without-extension)'{-i,--match-without-extension}'[match by name minus extension]' \
  '(-i --match-without-extension -I --no-match-without-extension)'{-I,--no-match-without-extension}'[do not ignore extension]' \
  '(-n --newer-than-stamp)'{-n,--newer-than-stamp=}'[only newer than timestamp file]:file:_files' \
  '(-N --newer-than)'{-N,--newer-than=}'[only newer than time/date]:time:' \
  '(-k --keep-all-tagged)'{-k,--keep-all-tagged}'[preserve all tagged-path files]' \
  '(-K --keep-all-untagged)'{-K,--keep-all-untagged}'[preserve all untagged-path files]' \
  '(-m --must-match-tagged)'{-m,--must-match-tagged}'[only dups present in tagged paths]' \
  '(-M --must-match-untagged)'{-M,--must-match-untagged}'[only dups in untagged paths]' \
  '(-S --rank-by)'{-S,--rank-by=}'[rank duplicates]:by:(m a c M A C l L p P x X h H o O d D r R)' \
  '--replay=[reprocess previous JSON output]:file:_files -g "*.json"' \
  '(-C --xattr)'{-C,--xattr}'[cache checksums in xattrs]' \
  '--xattr-read[read cached checksums from xattrs]' \
  '--xattr-write[write checksums to xattrs]' \
  '--xattr-clear[clear xattr checksums]' \
  '(-U --write-unfinished)'{-U,--write-unfinished}'[include unhashed files in output]' \
  '(-t --threads)'{-t,--threads=}'[N processing threads]:N:' \
  '(-u --limit-mem)'{-u,--limit-mem=}'[memory cap for hashing]:size:' \
  '(-q --clamp-low)'{-q,--clamp-low=}'[examine only N bytes from start]:size:' \
  '(-Q --clamp-top)'{-Q,--clamp-top=}'[examine only N bytes to end]:size:' \
  '(-Z --mtime-window)'{-Z,--mtime-window=}'[mtime tolerance for matching]:seconds:' \
  '--with-fiemap[optimize disk access on rotational drives]' \
  '--without-fiemap[disable extent-based optimization]' \
  '*:path:_files -/' \
  && ret=0

return ret
