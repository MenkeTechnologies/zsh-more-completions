#compdef roslaunch
# Documentation: http://wiki.ros.org/roslaunch
# Source: ros/ros_comm noetic-devel tools/roslaunch/src/roslaunch/__init__.py — ROS1 multi-node launcher.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '--files[print files loaded by launch file]' \
    '--args=[print command-line args for node]:node:_default' \
    '--nodes[print list of node names in launch file]' \
    '--find-node=[find launch file that defines node]:node:_default' \
    '(-c --child)'{-c+,--child=}'[run as child service NAME (req. with -u)]:name:_default' \
    '--local[do not launch remote nodes]' \
    '--screen[force all local nodes to screen output]' \
    '--required[force all nodes to be required]' \
    '--log[force all local nodes to log output]' \
    '(-u --server_uri)'{-u+,--server_uri=}'[URI of server (req. with -c)]:uri:_urls' \
    '--run_id=[run_id of session (req. with -c)]:id:_default' \
    '--wait[wait for master to start before launching]' \
    '(-p --port)'{-p+,--port=}'[master port (only if master is launched)]:port:_default' \
    '--core[launch core services only]' \
    '--pid=[write roslaunch pid to file]:file:_files' \
    '-v[verbose printing]' \
    '--no-summary[hide summary printing]' \
    '--dump-params[dump parameters of all roslaunch files to stdout]' \
    '--skip-log-check[skip check size of log folder]' \
    '--ros-args[display command-line args for launch file]' \
    '--disable-title[disable setting of terminal title]' \
    '(-w --numworkers)'{-w+,--numworkers=}'[override number of worker threads (core only)]:n:_default' \
    '(-t --timeout)'{-t+,--timeout=}'[socket timeout (s; core only)]:seconds:_default' \
    '--master-logger-level=[rosmaster.master logger level]:level:(debug info warn error fatal)' \
    '--sigint-timeout=[SIGINT timeout when killing nodes (s)]:seconds:_default' \
    '--sigterm-timeout=[SIGTERM timeout when killing nodes (s)]:seconds:_default' \
    '*:package or launch file:_files -g "*.launch(-.)"' \
    && ret=0

return ret
