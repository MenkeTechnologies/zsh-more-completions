#compdef squido
# ---------------------------------------------------------------------------
# squido — "a dead-simple static HTML website generator for super fast
#          static websites which are easier to develop, more secure and
#          dirt cheaper to host": JavaScript SSG that emits plain HTML
#          from Markdown source files + Handlebars templates + an
#          embedded lunr.js full-text search index, with built-in
#          WordPress / Ghost importers for migrating off heavy CMS
#          installations (JavaScript, 68★)
#
# upstream: https://github.com/mrvautin/squido
# author : Mark Moffat (mrvautin / markmoffat.com) — also the author
#          of expressCart (the e-commerce platform), adminMongo,
#          dbgate, restoql, gistsite, and the broader mrvautin
#          ecosystem of "small focused JS / Node infrastructure tools"
# license: MIT
#
# Source-direct completion: every subcommand + flag below is verbatim
# from cli.js on the mrvautin/squido tip — `commander` (TJ Holowaychuk's
# commander.js) `.command(...)` / `.description(...)` / `.option(...)`
# / `.action(...)` registrations parsed exactly as declared.  Sub-
# commands (`build`, `clean`, `new`, `import`) each get their own
# `program.command(...)` block with type-specific options preserved
# (e.g. `import -t wordpress` / `-t ghost` from the if/else type
# branches in the action handler).
#
# Direct deps from package.json (selected):
#   lunr                    ^2.3.9   ← canonical JS-side full-text
#                                       search engine library (this
#                                       axis) — by Oliver Nightingale
#                                       (oliver/lunr.js); pure-JS
#                                       inverted-index search engine
#                                       inspired by Solr (the Apache
#                                       Lucene-based server).  Builds
#                                       a serializable index from
#                                       documents with a configurable
#                                       schema (fields, boosts,
#                                       tokenizers, stemmers, stop-
#                                       word filters), serializes to
#                                       a static JSON blob that can
#                                       be shipped alongside the
#                                       static site, and queries via
#                                       the in-browser `lunr.Index`
#                                       constructor for client-side
#                                       search without a backend.
#                                       Predates the modern wave of
#                                       JS search libs (minisearch,
#                                       flexsearch, orama) by ~8
#                                       years; the longest-running
#                                       JS embedded-search lib still
#                                       in active use.  Used by
#                                       TypeDoc (the canonical TS
#                                       documentation generator),
#                                       compodoc (the canonical
#                                       Angular doc generator),
#                                       Bitwarden's CLI for its
#                                       vault item index, microsoft/
#                                       FluidFramework's docs site,
#                                       stdlib-js/stdlib's docs.  THE
#                                       de-facto-historical-standard
#                                       JS embedded search — though
#                                       the modern JS ecosystem has
#                                       SPLIT into four competing
#                                       options (lunr / minisearch /
#                                       flexsearch / orama) without
#                                       any single Lucene-equivalent
#                                       emerging, unlike Rust+Go's
#                                       cleaner tantivy+bleve pair.
#                                       squido uses lunr in the
#                                       `lib/build.js` indexPosts
#                                       function: every post gets
#                                       indexed at build time and the
#                                       resulting `search-index.json`
#                                       is shipped alongside the
#                                       generated HTML so the static
#                                       site's search UI loads the
#                                       index client-side and queries
#                                       in-browser without a server
#                                       round trip.
#   commander                         (TJ Holowaychuk's CLI parser —
#                                       .command / .description /
#                                       .option / .action chain)
#   chokidar                          (file-watcher for the optional
#                                       `--watch` / serve mode that
#                                       rebuilds on Markdown changes)
#   handlebars + handlebars-helpers   (template engine for layouts /
#                                       partials / post pages —
#                                       handlebars is the historical
#                                       canonical Mustache-superset
#                                       template library that pairs
#                                       naturally with lunr in the JS
#                                       ecosystem)
#   chalk + log-symbols + ora         (terminal output styling +
#                                       spinner during build)
#   marked + cheerio                  (Markdown→HTML + HTML
#                                       post-processing)
#   fs-extra + glob                   (file system primitives)
#
# squido's design is "the SSG you'd write yourself if you spent a
# weekend on it" — author content in Markdown, configure pages in a
# small JS config, run `squido build` to emit a /build directory of
# plain HTML files ready to drop on any static host (S3 / Netlify /
# Vercel / Cloudflare Pages / GitHub Pages / `python -m http.server`),
# `squido serve` to preview locally, `squido new` to scaffold a fresh
# site, and `squido import` to migrate posts from WordPress (XML
# export) or Ghost (JSON export).  Lunr-powered client-side search is
# baked into the default theme so visitors can search the entire site
# without a backend.
#
# ============================================================================
# === AXIS 189 CLOSES — embeddable full-text search engine libraries =======
# === TRIPLE-244 ROUND-NUMBER LANDMARK · 182nd AXIS CLOSED ================
# ============================================================================
# Axis position: TS-Node=244 CLOSES Axis 189 at slot 1/1/1 — quadruple-clean
# closure of the canonical embeddable full-text search engine library
# ecosystem spanning the three major systems languages.  The JS lane
# closure here is unusual: unlike Rust+Go which each have a clear
# single canonical lib, the JS ecosystem has SPLIT into four competing
# options (lunr / minisearch / flexsearch / @orama/orama) without any
# single Lucene-equivalent emerging.  lunr.js holds the de-facto-
# historical-standard slot — it's the oldest still-active option (by
# Oliver Nightingale, ~8 years before the modern wave) and is what
# the canonical TypeScript / Angular documentation generators
# (TypeDoc, compodoc) reach for:
#
#     Rust    : tantivy                  by Paul Masurel + quickwit-
#                                          oss; pure-Rust full-text
#                                          search engine inspired by
#                                          Lucene.  Single-crate
#                                          vertical with all backends
#                                          feature-gated.
#                 → tracey (Amos Wenger bearcove — CLI/Web/LSP/MCP/
#                            daemon toolkit for spec coverage;
#                            tantivy indexes spec rules + source-
#                            comment references; 207★ MIT/Apache)
#                 _tracey           [Rust=244 OPENED Axis 189, slot 1/0/0]
#
#     Go      : github.com/blevesearch/bleve/v2
#                                          by Marty Schoch (originally
#                                          CouchBase); pure-Go full-
#                                          text indexing/search lib
#                                          inspired by Lucene.  Umbrella
#                                          org (blevesearch/*) with
#                                          each backend (zapx / scorch
#                                          / gtreap / upsidedown
#                                          storage, geo, go-faiss
#                                          vector, snowballstem,
#                                          porterstemmer, segment
#                                          tokenizer) as a separately
#                                          go-mod-versioned repo.
#                 → nginx-ui (0xJacky + maintainers — Vue+Gin Nginx
#                              admin UI; Bleve-indexed search over
#                              every server block / upstream /
#                              location / SSL cert / directive across
#                              all managed configs; 11182★ AGPL-3.0)
#                 _nginx-ui         [Go=244 CONTINUED Axis 189, slot 2/0/0]
#
#     JS/Node : lunr                      by Oliver Nightingale
#                                          (oliver/lunr.js); pure-JS
#                                          inverted-index search
#                                          engine inspired by Solr.
#                                          Builds a serializable index
#                                          from documents with config-
#                                          urable fields/boosts/
#                                          tokenizers/stemmers/stop-
#                                          words; serializes to a
#                                          static JSON blob shipped
#                                          alongside the static site
#                                          for client-side search
#                                          without a backend.  The
#                                          longest-running JS embedded
#                                          search lib in active use.
#                 → squido (Mark Moffat mrvautin — dead-simple JS
#                            static HTML site generator; embeds a
#                            lunr.js index at build time inside
#                            search-index.json shipped alongside the
#                            generated HTML so the site's search UI
#                            loads it client-side and queries without
#                            a server round trip; commander-based CLI
#                            with build / clean / new / import {-t
#                            wordpress|ghost} subcommands;
#                            68★ MIT)
#                 _squido           [TS-Node=244 CLOSES Axis 189, 1/1/1]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#                 Architectural divergence on this axis: Rust+Go each
#                 converged on a single Lucene-inspired lib (tantivy /
#                 bleve), but JS SPLIT into four competing options
#                 with no single canonical emerging — lunr (historical
#                 standard, used by TypeDoc + compodoc + Bitwarden's
#                 CLI) / minisearch (modern, used by VitePress +
#                 Observable Framework + chappe) / flexsearch (used by
#                 Quartz + many Obsidian-static-site builders) /
#                 @orama/orama (newest, used by Tabby + Hedgedoc).
#                 The split is partly historical (lunr predates the
#                 wave) and partly preference (minisearch is the
#                 cleanest modern API; flexsearch is the fastest;
#                 orama is the most full-featured with vector search
#                 and typo tolerance).  No JS lib has built the
#                 Lucene-feature-parity vertical that tantivy and
#                 bleve aim for; client-side search use cases tend
#                 to need only a subset of Lucene's surface so the
#                 lighter libs have stayed competitive.
#
# Round-number 244 landmark fires simultaneously across all three lanes:
# Rust completion #244 (_tracey) + Go completion #244 (_nginx-ui) + TS-
# Node completion #244 (_squido) = triple-244.  Axis #182 closed in the
# lifetime of the corpus.
# ============================================================================

_squido() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'build:build your website (render Markdown source → static HTML in the build/ directory + bake the lunr search index into search-index.json)'
                'clean:clean your website build (delete build/ directory)'
                'new:scaffold a new squido website in the current directory'
                'import:import posts from external CMS sources (WordPress XML export or Ghost JSON export)'
                'serve:start local preview server (alias for `node serve.js`; not registered as a commander command — invoked via `npm run serve` in scaffolded sites)'
                'help:show CLI help (or help for a specific command)'
            )
            _describe -t commands 'squido command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                build)
                    _arguments \
                        '(-h --help)'{-h,--help}'[show help]' \
                        '(-c --clean)'{-c,--clean}'[clean the build/ directory before building (combines `squido clean` + `squido build` into one step)]' && ret=0
                    ;;
                import)
                    _arguments \
                        '(-h --help)'{-h,--help}'[show help]' \
                        '(-f --file)'{-f,--file}'=[path to the export file to import]:file:_files -g "*.(xml|json|XML|JSON)"' \
                        '(-t --type)'{-t,--type}'=[type of file to import]:type:(wordpress ghost)' && ret=0
                    ;;
                clean|new)
                    _arguments '(-h --help)'{-h,--help}'[show help]' && ret=0
                    ;;
                help)
                    local -a allsubs
                    allsubs=(build clean new import)
                    _describe -t commands 'subcommand for help' allsubs && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_squido "$@"
