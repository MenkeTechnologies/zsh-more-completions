#compdef reparo
# _reparo — TiDB Binlog point-in-time recovery tool
# upstream: https://github.com/pingcap/tidb-binlog
# Flags from reparo/config.go on tip.

_reparo() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-V[print version and exit]' \
        '--config=[reparo config file]:file:_files' \
        '--data-dir=[drainer data directory]:dir:_files -/' \
        '--start-datetime=[recover from this datetime]:datetime:' \
        '--stop-datetime=[recover up to this datetime]:datetime:' \
        '--start-tso=[recover from this PD TSO]:n:' \
        '--stop-tso=[recover up to this PD TSO]:n:' \
        '--txn-batch=[binlog events per transaction batch]:n:' \
        '-c=[parallel worker count]:n:' \
        '--log-file=[log file path]:file:_files' \
        '--dest-type=[destination type]:type:(print mysql)' \
        '-L=[log level]:level:(debug info warn error fatal)' \
        '--safe-mode=[enable safe mode (reentrant syncing)]:bool:(true false)'
}

_reparo "$@"
