#compdef stylish-cabal
# _stylish-cabal — format a .cabal file (pikajude/stylish-cabal)
# upstream: https://github.com/pikajude/stylish-cabal
# Flags from Main.hs (optparse-applicative).

_stylish-cabal() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-n --indent)'{-n+,--indent=}'[indent size in spaces]:n:' \
        '(-s --simplify-versions)'{-s,--simplify-versions}'[simplify version ranges where possible]' \
        '(-i --in-place)'{-i,--in-place}'[format file in place]' \
        '(-c --disable-color)'{-c,--disable-color}'[disable colorized output]' \
        '(-w --width)'{-w+,--width=}'[character width limit]:n:' \
        '1:cabal file:_files -g "*.cabal"'
}

_stylish-cabal "$@"
