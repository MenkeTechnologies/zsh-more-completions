#compdef sccainfo
# Documentation: https://github.com/libyal/libscca
# Source: libyal/libscca manuals/sccainfo.1 — display info about a Windows Prefetch / SuperFetch (.pf) file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[show allocation information]' \
    '-h[show help]' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '*:Prefetch .pf file:_files' \
    && ret=0

return ret
