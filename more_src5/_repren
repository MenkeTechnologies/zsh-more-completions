#compdef repren
# Documentation: https://github.com/jlevy/repren
# Reference accessed: 2026-05-20
# Verified: upstream README at the URL above.

local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)--version[show version]'
  '--from=[match pattern (single replacement)]:pattern'
  '--to=[replacement text (single replacement)]:pattern'
  '(-p --patterns)'{-p,--patterns}'=[file with multiple pattern pairs]:file:_files'
  '--full[do full renames (paths + contents) recursively]'
  '--renames[file/directory renames only, applied to full paths]'
  '--literal[treat patterns as literal strings (not regex)]'
  '--preserve-case[case-preserving renames across case variants]'
  '--word-breaks[require matches to be on word breaks]'
  '(-n --dry-run)'{-n,--dry-run}'[non-destructive preview]'
  '--at-once[read entire file into memory (not line by line)]'
  '--include=[include only paths matching pattern]:pattern'
  '--exclude=[exclude paths matching pattern]:pattern'
  '--backup-suffix=[custom backup-file suffix]:suffix'
  '--clean-backups[remove .orig backup files]'
  '--undo[restore files from .orig backups]'
  '--format=[output format]:format:(json)'
  '*:path:_files'
)

_arguments -s -S $arguments
