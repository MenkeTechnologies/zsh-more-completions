local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:infile.nii:_files -g "*.{nii,nii.gz,hdr,img,mha,nrrd}"' \
    '2:outfile.nii:_files' \
    '*:direction matrix entries (row-major; 4 for 2D or 9 for 3D):_default' \
    && ret=0

return ret
