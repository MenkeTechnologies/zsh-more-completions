#compdef sfattr
# Documentation: http://www.ahay.org/RSF/sfattr.html
# Source: ahay/src system/main/attr.c — statistical attributes of an RSF dataset.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'want=[attribute to display]: :(all rms mean norm var std max min nonzero samples short)' \
    'lval=[norm option (default 2 = L2)]: :_default' \
    '*:RSF file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
