#compdef sndfile-convert
# Documentation: sndfile-convert usage (libsndfile)
# Source: libsndfile sndfile-convert — convert audio formats with optional re-encoding.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a encs
encs=(
    -pcms8 -pcmu8 -pcm16 -pcm24 -pcm32
    -float32 -float64
    -ulaw -alaw
    -alac16 -alac20 -alac24 -alac32
    -ima-adpcm -ms-adpcm -gsm610
    -dwvw12 -dwvw16 -dwvw24
    -vorbis -opus
)

_arguments -s \
    '-override-sample-rate=[force input sample rate]:rate:' \
    '-endian=[force output endianness]:endian:(little big cpu)' \
    '-normalize[normalize output data]' \
    "(${encs[*]})-pcms8[signed 8-bit PCM]" \
    "(${encs[*]})-pcmu8[unsigned 8-bit PCM]" \
    "(${encs[*]})-pcm16[16-bit PCM]" \
    "(${encs[*]})-pcm24[24-bit PCM]" \
    "(${encs[*]})-pcm32[32-bit PCM]" \
    "(${encs[*]})-float32[32-bit float]" \
    "(${encs[*]})-float64[64-bit float]" \
    "(${encs[*]})-ulaw[ULAW]" \
    "(${encs[*]})-alaw[ALAW]" \
    "(${encs[*]})-alac16[16-bit ALAC (CAF only)]" \
    "(${encs[*]})-alac20[20-bit ALAC (CAF only)]" \
    "(${encs[*]})-alac24[24-bit ALAC (CAF only)]" \
    "(${encs[*]})-alac32[32-bit ALAC (CAF only)]" \
    "(${encs[*]})-ima-adpcm[IMA ADPCM (WAV only)]" \
    "(${encs[*]})-ms-adpcm[MS ADPCM (WAV only)]" \
    "(${encs[*]})-gsm610[GSM 6.10 (WAV only)]" \
    "(${encs[*]})-dwvw12[12-bit DWVW (AIFF only)]" \
    "(${encs[*]})-dwvw16[16-bit DWVW (AIFF only)]" \
    "(${encs[*]})-dwvw24[24-bit DWVW (AIFF only)]" \
    "(${encs[*]})-vorbis[Vorbis encoded audio]" \
    "(${encs[*]})-opus[Opus encoded audio]" \
    '1:input file:_files' \
    '2:output file:_files' \
    && ret=0

return ret
