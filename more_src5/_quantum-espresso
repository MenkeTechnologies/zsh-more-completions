#compdef quantum-espresso
# Documentation: https://www.quantum-espresso.org/Doc/user_guide/
# Reference accessed: 2026-05-20
# Verified: Quantum ESPRESSO is a suite of binaries (pw.x, ph.x, ...).
# `quantum-espresso` is the Debian meta-package name; no canonical CLI; STUB.

local curcontext="$curcontext" ret=1
_arguments -C \
  '*::quantum-espresso binary and args:_files' && ret=0
return ret
