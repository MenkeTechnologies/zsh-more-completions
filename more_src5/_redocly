#compdef redocly
# Documentation: https://redocly.com/docs/cli/commands
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for redocly - Redocly OpenAPI CLI (@redocly/cli)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a formats
formats=(codeframe stylish json checkstyle codeclimate github-actions markdown summary)

local -a lint_severities
lint_severities=(warn error off)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config=[config file]:file:_files' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'lint:lint API definitions'
      'bundle:bundle API definitions'
      'preview:preview docs locally'
      'build-docs:build static API reference docs'
      'translate:manage translations'
      'eject:eject components for customization'
      'stats:show API definition statistics'
      'score:compute API definition score'
      'join:join multiple API definitions'
      'split:split an API definition'
      'check-config:validate the Redocly configuration'
      'respect:run API tests against descriptions'
      'generate-arazzo:generate an Arazzo description'
      'push:push API definitions to Redocly'
      'push-status:check status of a previous push'
      'login:log in to Redocly'
      'logout:log out of Redocly'
      'completion:generate shell completion'
    )
    _describe -t commands 'redocly command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      lint)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config=[config file]:file:_files' \
          '--format=[output format]:format:('"$formats"')' \
          '*--extends=[ruleset to extend]:ruleset:(spec minimal recommended recommended-strict)' \
          '*--skip-rule=[rule to skip]:rule:' \
          '*--skip-preprocessor=[preprocessor to skip]:name:' \
          '--generate-ignore-file[generate ignore file]' \
          '--max-problems=[maximum number of problems (default 100)]:int:' \
          '--lint-config=[lint config severity]:severity:('"$lint_severities"')' \
          '*:api definitions:_files -g "*.{yaml,yml,json}"' && ret=0
        ;;
      bundle)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config=[config file]:file:_files' \
          '(-o --output)'{-o+,--output=}'[output file or folder]:file:_files' \
          '--ext=[output file extension]:extension:(json yaml yml)' \
          '(-d --dereferenced)'{-d,--dereferenced}'[fully dereferenced bundle]' \
          '(-f --force)'{-f,--force}'[force overwrite of output file]' \
          '--remove-unused-components[remove unused components]' \
          '(-k --keep-url-references)'{-k,--keep-url-references}'[preserve absolute URL references]' \
          '*--skip-decorator=[decorator to skip]:name:' \
          '*--skip-preprocessor=[preprocessor to skip]:name:' \
          '--metafile=[bundle metadata file]:file:_files' \
          '--component-renaming-conflicts-severity=[severity for naming conflicts]:severity:('"$lint_severities"')' \
          '--lint-config=[lint config severity]:severity:('"$lint_severities"')' \
          '*:api definitions:_files -g "*.{yaml,yml,json}"' && ret=0
        ;;
      preview)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-p --port)'{-p+,--port=}'[port to listen on (default 4000)]:port:' \
          '(-d --project-dir)'{-d+,--project-dir=}'[project directory]:dir:_directories' \
          '--plan=[product plan]:plan:(pro enterprise)' \
          '--product=[product]:product:(redoc revel reef realm redoc-revel redoc-reef revel-reef)' && ret=0
        ;;
      build-docs)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config=[config file]:file:_files' \
          '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
          '(-t --template)'{-t+,--template=}'[handlebars template]:file:_files' \
          '--theme.openapi=[theme options]:opt:' \
          '--disableGoogleFont[disable Google Font]' \
          '1:api definition:_files -g "*.{yaml,yml,json}"' && ret=0
        ;;
      stats|score)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config=[config file]:file:_files' \
          '--format=[output format]:format:('"$formats"')' \
          '1:api definition:_files -g "*.{yaml,yml,json}"' && ret=0
        ;;
      join)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config=[config file]:file:_files' \
          '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
          '--prefix-tags-with-info-prop=[info property to prefix tags]:property:' \
          '--prefix-tags-with-filename[prefix tags with source filename]' \
          '--prefix-components-with-info-prop=[info property to prefix components]:property:' \
          '--without-x-tag-groups[skip x-tagGroups generation]' \
          '--lint-config=[lint config severity]:severity:('"$lint_severities"')' \
          '*:api definitions:_files -g "*.{yaml,yml,json}"' && ret=0
        ;;
      split)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config=[config file]:file:_files' \
          '--outDir=[output directory]:directory:_directories' \
          '1:api definition:_files -g "*.{yaml,yml,json}"' && ret=0
        ;;
      push)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-o --organization)'{-o+,--organization=}'[organization slug]:slug:' \
          '(-p --project)'{-p+,--project=}'[project slug]:slug:' \
          '(-mp --mount-path)'{-mp+,--mount-path=}'[destination path in project]:path:' \
          '(-b --branch)'{-b+,--branch=}'[source branch]:branch:' \
          '(-a --author)'{-a+,--author=}'[author]:author:' \
          '(-m --message)'{-m+,--message=}'[commit message]:message:' \
          '--commit-sha=[commit SHA]:sha:' \
          '--commit-url=[commit URL]:url:' \
          '--repository=[repository ID]:id:' \
          '--namespace=[repository owner]:namespace:' \
          '--created-at=[commit creation date]:datetime:' \
          '--domain=[target domain]:domain:' \
          '--default-branch=[repository default branch]:branch:' \
          '--lint-config=[lint config severity]:severity:('"$lint_severities"')' \
          '--max-execution-time=[max wait time seconds]:seconds:' \
          '--wait-for-deployment[wait for build completion]' \
          '--verbose[verbose output]' \
          '*:file:_files' && ret=0
        ;;
      check-config)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config=[config file]:file:_files' \
          '--lint-config=[lint config severity]:severity:('"$lint_severities"')' && ret=0
        ;;
      login|logout|push-status|completion|translate|eject|respect|generate-arazzo)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
