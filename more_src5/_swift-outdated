#compdef swift-outdated
# Documentation: https://github.com/kiliankoe/swift-outdated
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-f --format)'{-f+,--format=}'[output format]:format:(markdown json xcode)' \
  '--ignore-prerelease[ignore pre-release versions]' \
  '(-m --only-major)'{-m,--only-major}'[output only packages with major version updates]' \
  '-v[verbose output]' \
  '(-u --include-up-to-date)'{-u,--include-up-to-date}'[include up to date packages]' \
  '--update=[update outdated packages]:scope:(patch minor major)' \
  '*--package=[only update specific packages (repeatable)]:package:' \
  '--dry-run[show what would be updated without making changes]' \
  '*::Package.resolved directory:_files -/' && ret=0
return ret
