#compdef systemd-cgroups-agent
# _systemd-cgroups-agent (small notify-on-empty agent registered by cgroup v1 release_agent so the kernel can let pid 1 know when the last process leaves a cgroup; not intended to be invoked directly - cgroup core hands it the freed cgroup path as its sole positional argument)
# upstream: https://github.com/systemd/systemd (src/cgroups-agent)
# Argument shape from systemd src/cgroups-agent/cgroups-agent.c on tip.

_systemd-cgroups-agent() {
    _arguments \
        '1:cgroup path:_files'
}

_systemd-cgroups-agent "$@"
