#compdef R-CMD-Stangle
# _R-CMD-Stangle — R Core Team R CMD Stangle extract R code from Sweave noweb documents (rcore team, C); getopt
# upstream: https://cran.r-project.org/

_R-CMD-Stangle() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--encoding=+[encoding]:str:' \
        '--engine=+[engine]:e:(R latex utf8 knitr)' \
        '--driver=+[driver]:d:(Rtangle Knitr)' \
        '--syntax=+[syntax]:s:(SweaveSyntaxLatex SweaveSyntaxNoweb)' \
        '--no-init-file[no init file]' \
        '--output=+[output file]:file:_files -g "*.R"' \
        '--annotate[annotate output]' \
        '--quiet[quiet]' \
        '--split=+[bool]:b:(yes no)' \
        '*:Sweave file:_files -g "*.Rnw *.snw *.Stex *.Snw *.Rtex"'
}

_R-CMD-Stangle "$@"
