#compdef sweepai
# Documentation: https://github.com/sweepai/sweep
# Reference accessed: 2026-05-22
# Verified: sweepai/cli.py Typer CLI (PyPI console script sweepai).

# Zsh completion for sweepai - Sweep AI coding assistant CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'sweepai command' \
      'init[initialize Sweep CLI config]' \
      'run[run Sweep on GitHub issue URL]' \
      'watch[watch repository events]' \
      'test[test Sweep configuration]' && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments '--override[override existing config]' && ret=0
        ;;
      run)
        _arguments '1:GitHub issue URL:' && ret=0
        ;;
    esac
    ;;
esac

return ret
