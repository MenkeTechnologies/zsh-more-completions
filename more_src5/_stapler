#compdef stapler
# _stapler — Philippe Lagadec stapler lightweight PDF manipulation CLI built on PyPDF2 for cat split delete burst zip select PDF pages without external GhostScript dependency (hellerbarde team, Python); argparse
# upstream: https://github.com/hellerbarde/stapler

_stapler() {
    local -a sub=(
        'cat:concatenate pages'
        'select:select pages'
        'split:split into individual pages'
        'burst:burst into single-page files'
        'delete:delete pages'
        'del:delete pages'
        'background:apply background'
        'zip:interleave pages from inputs'
        'info:show PDF info'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'stapler subcommand' sub ;;
        args)
            case $words[1] in
                cat|select|delete|del|zip) _arguments \
                    '*:PDF and page selector:_files -g "*.pdf"' ;;
                split|burst) _arguments \
                    '*:PDF file:_files -g "*.pdf"' ;;
                background) _arguments \
                    '*:foreground bg output:_files -g "*.pdf"' ;;
                info) _arguments '*:PDF file:_files -g "*.pdf"' ;;
            esac
            ;;
    esac
}

_stapler "$@"
