#compdef satellite-installer
# Documentation: https://github.com/theforeman/kafo/blob/master/lib/kafo/kafo_configure.rb
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# satellite-installer: Red Hat Satellite installer (kafo wrapper over puppet);
# CLI options inherited from upstream kafo.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--full-help[print complete help]' \
  '(-i --interactive)'{-i,--interactive}'[run in interactive mode]' \
  '(-n --noop)'{-n,--noop}'[run puppet in noop mode]' \
  '(-v --verbose --no-verbose)'{-v,--verbose,--no-verbose}'[display log on STDOUT instead of progressbar]' \
  '-l+[verbose log level (terminal)]:level:(ERROR WARN NOTICE INFO DEBUG)' \
  '--verbose-log-level=[verbose log level (terminal)]:level:(ERROR WARN NOTICE INFO DEBUG)' \
  '--log-level=[log level for log file]:level:(ERROR WARN NOTICE INFO DEBUG)' \
  '--list-scenarios[list available installation scenarios]' \
  '(-S --scenario)'{-S+,--scenario=}'[use installation scenario]:scenario:(satellite capsule)' \
  '--enable-scenario=[enable installation scenario]:scenario:' \
  '--disable-scenario=[disable installation scenario]:scenario:' \
  '--compare-scenarios[show changes between scenarios]' \
  '--force[force change of installation scenario]' \
  '--migrations-only[apply migrations and exit]' \
  '--checks-only[run only system checks and exit]' \
  '(-s --skip-checks-i-know-better)'{-s,--skip-checks-i-know-better}'[skip all system checks]' \
  '--skip-puppet-version-check[skip Puppet version compatibility check]' \
  '(-p --profile)'{-p,--profile}'[run puppet in profile mode]' \
  '--dont-save-answers[skip saving answers to config file]' \
  '--ignore-undocumented[ignore inconsistent parameter documentation]' \
  '--detailed-exitcodes[return puppet detailed exit codes]' \
  '(--colors --no-colors)--colors[use color output on STDOUT]' \
  '(--colors --no-colors)--no-colors[disable color output]' \
  '--color-of-background=[terminal background color]:color:(bright dark)' \
  '(--parser-cache --no-parser-cache)--parser-cache[force Puppet module parser cache]' \
  '(--parser-cache --no-parser-cache)--no-parser-cache[bypass Puppet module parser cache]' \
  '*::module options:_files' && ret=0
return ret
