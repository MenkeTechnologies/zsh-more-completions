#compdef qpdfview
# Documentation: https://www.mankier.com/1/qpdfview
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local ret=1

_arguments \
  '(- *)--help[display usage information]' \
  '--quiet[suppress warning messages for files that fail to open]' \
  '--search=[initiate a search for text in the current tab]:text:' \
  '--unique[open files as tabs in the original window]' \
  '--instance=[name of the instance to contact or create]:name:' \
  '--choose-instance[show dialog to select instance name at startup]' \
  '*:document file:_files -g "*.{pdf,ps,djvu,xps,oxps,fb2,epub,cbz,cbr,cbt,cba,cb7}"' && ret=0

return ret
