#compdef ship-js
# Documentation: https://github.com/algolia/shipjs
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Note: ship-js is the legacy binary name; current upstream binary is shipjs.
# Documented subcommands: setup, prepare, trigger. --dir is the only flag
# explicitly documented; --dry-run / --yes are widely used but not exhaustively
# listed upstream — kept conservatively.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'setup:interactive setup wizard (creates ship.config.js)'
  'prepare:bump version, update changelog, open release PR'
  'trigger:run release after PR merge (publish, tag, release notes)'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'ship-js command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (setup|prepare|trigger)
        _arguments \
          '(-d --dir)'{-d+,--dir=}'[base directory]:directory:_directories' \
          '--dry-run[dry run without making changes]' \
          '(-y --yes)'{-y,--yes}'[skip confirmation prompts]' && ret=0
        ;;
    esac
    ;;
esac

return ret
