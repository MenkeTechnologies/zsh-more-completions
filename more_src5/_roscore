#compdef roscore
# Documentation: http://wiki.ros.org/roscore
# Source: ros/ros_comm noetic-devel tools/roslaunch/scripts/roscore — ROS1 master + parameter server + rosout launcher.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-p --port)'{-p+,--port=}'[master port (if master is launched)]:port:_default' \
    '-v[verbose printing]' \
    '(-w --numworkers)'{-w+,--numworkers=}'[override number of worker threads]:n:_default' \
    '(-t --timeout)'{-t+,--timeout=}'[socket connection timeout (s)]:seconds:_default' \
    '--master-logger-level=[rosmaster.master logger level]:level:(debug info warn error fatal)' \
    '--sigint-timeout=[SIGINT timeout when killing core (s)]:seconds:_default' \
    '--sigterm-timeout=[SIGTERM timeout when killing core (s)]:seconds:_default' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
