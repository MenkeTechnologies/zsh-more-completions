#compdef staprun
# Documentation: man staprun(8)
# Source: sourceware.org systemtap staprun/common.c (HEAD) — SystemTap runtime module loader (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A[attach to running module]' \
    '-L[load only (no run)]' \
    '-u+[need uprobes; optional path]::path:_files' \
    '*-v[verbose (stackable)]' \
    '-i[read script from stdin]' \
    '-h[show help]' \
    '-b+[buffer size in MB (1-4095)]:size:_default' \
    '(-t -x)-t+[target PID]:pid:_pids' \
    '(-t -x)-x+[target PID (alias)]:pid:_pids' \
    '-d[delete module]' \
    '-c+[target command]:command:_command_names -e' \
    '-o+[output filename]:file:_files' \
    '-N+[target namespaces PID]:pid:_pids' \
    '-S+[output file size,count]:size,n:_default' \
    '-D[daemonize]' \
    '-w[suppress warnings]' \
    '-R[rename module]' \
    '-r+[remote id:url]:id\:url:_default' \
    '-V[show version]' \
    '-T+[reader timeout (ms)]:ms:_default' \
    '-C+[color mode]:mode:(auto always never)' \
    '-M+[monitor interval]:interval:_default' \
    '-F+[relay basedir fd]:fd:_default' \
    '1:module:_files -g "*.ko"' \
    '*::module args:_default' \
    && ret=0

return ret
