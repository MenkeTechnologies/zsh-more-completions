#compdef sigmac sigma2attack sigma_uuid sigma_similarity merge_sigma
# Documentation: source-direct extraction from upstream
# SigmaHQ/legacy-sigmatools
#   tools/sigma/sigmac.py:               argparser.add_argument(...) -> 18 flags
#   tools/sigma/sigma2attack.py:         parser.add_argument(...)    -> 6 flags
#   tools/sigma/sigma_uuid.py:           argparser.add_argument(...) -> 4 flags
#   tools/sigma/sigma_similarity.py:     argparser.add_argument(...) -> 5 flags
#   tools/sigma/merge_sigma.py:          argparser.add_argument(...) -> 1 positional
# The PATH-installed `tools/<name>` scripts are 5-line stubs that
# `from sigma.<name> import main; main()` so the actual flag
# surface lives in tools/sigma/<name>.py.
# Reference accessed: 2026-05-30 via gh api.
# SigmaHQ legacy-sigmatools R169 — 5-stem multi-binary harvest
# of the SigmaHQ legacy sigmatools detection-engineering CLI
# suite.  Sister tools to the heavily-covered SIEM/IR family
# (yara/yarac/yara-x R168, plaso log2timeline.py/psort.py/preg/
# pinfo + osquery/osqueryd/osqueryctl + wazuh-control/wazuh-
# modulesd + velociraptor + theHive/misp + volatility3/vol3/
# vol.py/rekall + sleuthkit tsk_loaddb/tsk_recover/icat/mmls/
# fls/fsstat/ils/blkls/blkstat/blkcat/blkcalc/img_stat/img_cat/
# mactime + vt + sigma-cli for the modern sigma successor)
# already in the corpus.

case $service in

  sigmac)
    # 40 backend choices decoded source-direct from
    # tools/sigma/backends/*.py directory listing (each backend
    # module is registered via getBackendDict()).
    local -a backends=(
      ala arcsight athena carbonblack chronicle cim csharp
      datadog devo discovery dnif ee-outliers elasticsearch
      fireeye-helix fortisiem graylog hawk hedera humio
      lacework limacharlie logiq logpoint mdatp netwitness
      netwitness-epl opensearch powershell qradar qualys
      splunk splunkdm sql sqlite stix
    )
    _arguments -s -S \
      '(--recurse -r)'{--recurse,-r}'[use directory as input]' \
      '(--filter -f)'{--filter=,-f+}'[filter rules (logsource/tags/level)]:filter:' \
      '(--target -t)'{--target=,-t+}'[output target format (sigma-backend)]:backend:($backends)' \
      '(--lists -l)'{--lists,-l}'[list available output target formats and configurations]' \
      '(--lists-files-after-date -L)'{--lists-files-after-date=,-L+}'[list yml files modified/created after date (YYYY/MM/DD)]:date:' \
      '*'{--config=,-c+}'[target environment field/index mapping config (repeatable)]:config:_files -g "*.yml"' \
      '(--output -o)'{--output=,-o+}'[output file or filename prefix]:file:_files' \
      '(--output-fields -of)'{--output-fields=,-of+}'[additional Sigma-rule fields to include in output]:fields:' \
      '(--output-format -oF)'{--output-format=,-oF+}'[wrap output in JSON or YAML]:fmt:(json yaml)' \
      '(--output-extention -e)'{--output-extention=,-e+}'[extension of output file (for filename-prefix mode)]:ext:' \
      '--print0[NUL-delimit results]' \
      '*'{--backend-option=,-O+}'[backend-specific option (repeatable)]:opt:' \
      '(--backend-config -C)'{--backend-config=,-C+}'[backend config file (YAML)]:file:_files -g "*.yml"' \
      '--backend-help[print backend options]' \
      '(--defer-abort -d)'{--defer-abort,-d}'[do not abort on parse/conversion errors]' \
      '(--ignore-backend-errors -I)'{--ignore-backend-errors,-I}'[only return error codes for parse errors]' \
      '(--verbose -v)'{--verbose,-v}'[verbose]' \
      '(--debug -D)'{--debug,-D}'[debug output]' \
      '*:Sigma rule yml file (or "-" for stdin):_files -g "*.(yml|yaml)"'
    ;;

  sigma2attack)
    _arguments -s -S \
      '(--rules-directory -d)'{--rules-directory=,-d+}'[directory to read rules from (default rules)]:dir:_files -/' \
      '(--out-file -o)'{--out-file=,-o+}'[file to write the JSON layer to (default heatmap.json)]:file:_files' \
      '--no-comment[do not store rule names in comments]' \
      '(--status-start -s)'{--status-start=,-s+}'[check rules with minimum status (default unsupported)]:status:(unsupported experimental test stable deprecated)' \
      '(--status-end -se)'{--status-end=,-se+}'[check rules with maximum status (default stable)]:status:(unsupported experimental test stable deprecated)' \
      '(--level-score -l)'{--level-score,-l}'[score depends on rule level]'
    ;;

  sigma_uuid)
    _arguments -s -S \
      '(--verify -V)'{--verify,-V}'[verify existence and uniqueness of UUID assignments]' \
      '(--verbose -v)'{--verbose,-v}'[verbose]' \
      '(--recursive -r)'{--recursive,-r}'[recurse into directories]' \
      '(--error -e)'{--error,-e}'[exit with error code 10 on verification failures]' \
      '*:Sigma rule files or directories:_files -g "*.(yml|yaml)"'
    ;;

  sigma_similarity)
    _arguments -s -S \
      '(--recursive -r)'{--recursive,-r}'[recurse into directories]' \
      '*'{--verbose,-v}'[verbose (repeat for debug output)]' \
      '(--top -t)'{--top=,-t+}'[output only the n most similar rule pairs]:n:' \
      '(--min-similarity -m)'{--min-similarity=,-m+}'[minimum similarity threshold (percent)]:percent:' \
      '(--primary -p)'{--primary=,-p+}'[file with paths to primary rules]:file:_files' \
      '*:Sigma input files:_files -g "*.(yml|yaml)"'
    ;;

  merge_sigma)
    _arguments -s -S \
      '1:Sigma input file:_files -g "*.(yml|yaml)"'
    ;;

esac
