#compdef rasttopnm
# Documentation: man rasttopnm (Netpbm)
# Source: convert a Sun rasterfile (.ras) to PNM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-index[output a colormap index instead of pixel values]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:rasterfile:_files -g "*.(ras|rast)"' \
    && ret=0

return ret
