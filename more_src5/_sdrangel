#compdef sdrangel sdrangelsrv sdrangelbench
# Documentation: https://github.com/f4exb/sdrangel/blob/master/sdrbase/mainparser.cpp
# Reference accessed: 2026-05-27
# Verified: upstream MainParser constructor in sdrbase/mainparser.cpp (Qt QCommandLineParser options)

# Zsh completion for SDRangel (Software Defined Radio application)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help and exit]' \
  '(-v --version)'{-v,--version}'[display version and exit]' \
  '(-a --api-address)'{-a+,--api-address=}'[web API server address]:address:' \
  '(-p --api-port)'{-p+,--api-port=}'[web API server port]:port:' \
  '(-w --fftwf-wisdom)'{-w+,--fftwf-wisdom=}'[FFTW wisdom file]:file:_files' \
  '--scratch[start from scratch (no current config)]' \
  '--soapy[activate Soapy SDR support]' \
  '--remote-tcp[start Remote TCP Sink]' \
  '--remote-tcp-address=[remote TCP Sink interface IP address (default 0.0.0.0)]:address:' \
  '--remote-tcp-port=[remote TCP Sink port (default 1234)]:port:' \
  '--remote-tcp-hwtype=[remote TCP Sink device hardware type (e.g. RTLSDR, SDRplayV3, AirspyHF)]:hwtype:' \
  '--remote-tcp-serial=[remote TCP Sink device serial]:serial:' \
  '--list-devices[list available physical devices]' \
  '--start[start all devices and features]' && ret=0

return ret
