#compdef cargo-shuttle
# _shuttle-cli — Shuttle.rs deployment platform CLI (shuttle-hq/shuttle)
# upstream: https://github.com/shuttle-hq/shuttle

_shuttle-cli() {
    local curcontext="$curcontext" state line ret=1

    local -a commands=(
        'init:create a new Shuttle project'
        'run:run the project locally'
        'deploy:deploy the project to Shuttle'
        'deployment:manage deployments'
        'status:view project status'
        'logs:view project logs'
        'stop:stop the running deployment'
        'restart:restart the deployment'
        'clean:clean build artifacts'
        'login:log in to Shuttle'
        'logout:log out of Shuttle'
        'generate:generate shell completions'
        'feedback:open feedback page'
        'project:manage Shuttle projects'
        'resource:manage project resources'
        'certificate:manage TLS certificates'
    )

    _arguments -C \
        '--api-url=[Shuttle API URL]:url:' \
        '--working-directory=[project directory]:dir:_directories' \
        '--name=[project name]:name:' \
        '--help[show help]' \
        '1: :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        cmd)
            _describe -t commands 'cargo-shuttle command' commands && ret=0 ;;
        args)
            case $line[1] in
                project)
                    local -a project_cmds=(
                        'start:start the project'
                        'stop:stop the project'
                        'restart:restart the project'
                        'status:show project status'
                        'list:list all projects'
                        'delete:delete a project'
                    )
                    _describe -t commands 'project subcommand' project_cmds && ret=0 ;;
                resource)
                    local -a resource_cmds=(
                        'list:list project resources'
                        'delete:delete a resource'
                    )
                    _describe -t commands 'resource subcommand' resource_cmds && ret=0 ;;
                deployment)
                    local -a deploy_cmds=(
                        'list:list deployments'
                        'status:show deployment status'
                    )
                    _describe -t commands 'deployment subcommand' deploy_cmds && ret=0 ;;
                logs)
                    _arguments '--follow[follow log output]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

_shuttle-cli "$@"
