#compdef subl sublime sublime_text sublime-text
# Documentation: https://www.sublimetext.com/docs/command_line.html
# Reference accessed: 2026-05-29
# Sublime Text command-line launcher.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--project=[load specified project file]:file:_files -g "*.sublime-project"' \
  '*--command=[execute the given Sublime command]:command:' \
  '(-n --new-window)'{-n,--new-window}'[launch a new window instance]' \
  '--launch-or-new-window[new window only if app is already running]' \
  '(-a --add)'{-a,--add}'[add folders to the currently active window]' \
  '(-w --wait)'{-w,--wait}'[block until edited files are closed]' \
  '(-b --background)'{-b,--background}'[launch without bringing app to foreground]' \
  '--safe-mode[start in sandboxed, clean environment]' \
  '*:file or dir (filename\:line\:column allowed):_files' && ret=0

return ret
