#compdef rargs
# Documentation: https://github.com/lotabout/rargs
# Reference accessed: 2026-05-20
# Verified: upstream src/main.rs structopt definitions.

local ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-p --pattern)'{-p+,--pattern=}'[regex pattern that captures input]:regex:' \
  '(-d --delimiter)'{-d+,--delimiter=}'[regex pattern used as delimiter]:regex:' \
  '(-s --separator)'{-s+,--separator=}'[separator for ranged fields]:str:' \
  '(-w --worker)'{-w+,--worker=}'[number of threads (deprecated alias for --threads)]:n:' \
  '(-j --threads)'{-j+,--threads=}'[number of threads to use]:n:' \
  '(-0 --read0)'{-0,--read0}'[read input delimited by ASCII NUL]' \
  '(-e --dry-run)'{-e,--dry-run}'[print commands without executing]' \
  '(-n --startnum)'{-n+,--startnum=}'[start value for line number]:n:' \
  '*:command template:_command_names -e' && ret=0
return ret
