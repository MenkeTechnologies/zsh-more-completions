#compdef run_erl
# Documentation: run_erl usage
# Source: Erlang/OTP run_erl — launch Erlang VM detached with FIFOs + log file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:pipe_name or pipe_dir:_files -/' \
    '2:log_dir:_files -/' \
    '3:Erlang command + parameters:' \
    && ret=0

return ret
