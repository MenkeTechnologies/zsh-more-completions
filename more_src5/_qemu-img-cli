#compdef qemu-img-cli
# _qemu-img-cli — QEMU disk image utility CLI alias (QEMU Project, C); custom argparse
# upstream: https://github.com/qemu/qemu

_qemu-img-cli() {
    local -a sub=(
        'amend:amend image options'
        'bench:run benchmark'
        'bitmap:bitmap commands'
        'check:check image consistency'
        'commit:commit overlay into backing'
        'compare:compare two images'
        'convert:convert image format/size'
        'create:create new image'
        'dd:write image with dd-like syntax'
        'info:show image info'
        'map:map blocks to file offsets'
        'measure:measure size required'
        'rebase:change backing file'
        'resize:resize image'
        'snapshot:list/apply/create/delete snapshot'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-T+[caching]:c:(none writeback writethrough directsync unsafe)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'qemu-img subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '-f+[format]:fmt:(raw qcow2 qcow vmdk vdi vhdx vpc parallels qed luks)' \
                    '-b+[backing file]:file:_files' \
                    '-F+[backing format]:fmt:(raw qcow2 vmdk vdi vhdx vpc)' \
                    '-o+[options key=value csv]:str:' \
                    '*:filename-size:_files' ;;
                convert) _arguments \
                    '-f+[source format]:fmt:(raw qcow2 qcow vmdk vdi vhdx vpc parallels qed luks)' \
                    '-O+[output format]:fmt:(raw qcow2 qcow vmdk vdi vhdx vpc parallels qed luks)' \
                    '-c[compress output]' \
                    '-p[show progress]' \
                    '-S+[size]:str:' \
                    '-o+[options]:str:' \
                    '-W[allow out-of-order writes]' \
                    '-m+[parallel coroutines]:n:' \
                    '*:file:_files' ;;
                info) _arguments \
                    '-f+[format]:fmt:(raw qcow2 vmdk vdi vhdx vpc)' \
                    '--output=+[output format]:fmt:(human json)' \
                    '--backing-chain[show backing chain]' \
                    '-U[force shared permissions]' \
                    '*:file:_files' ;;
                resize) _arguments \
                    '-f+[format]:fmt:(raw qcow2 vmdk vdi vhdx vpc)' \
                    '--shrink[allow shrink]' \
                    '-q[quiet]' \
                    '--preallocation=+[preallocation]:p:(off metadata falloc full)' \
                    '*:file-size:_files' ;;
                check) _arguments \
                    '-f+[format]:fmt:(raw qcow2 vmdk vdi vhdx vpc)' \
                    '-r+[repair]:r:(leaks all)' \
                    '-q[quiet]' \
                    '--output=+[output format]:fmt:(human json)' \
                    '*:file:_files' ;;
                snapshot) _arguments \
                    '-l[list snapshots]' \
                    '-a+[apply snapshot]:str:' \
                    '-c+[create snapshot]:str:' \
                    '-d+[delete snapshot]:str:' \
                    '-q[quiet]' \
                    '*:file:_files' ;;
                rebase) _arguments \
                    '-f+[format]:fmt:(qcow2)' \
                    '-b+[new backing file]:file:_files' \
                    '-F+[new backing format]:fmt:(raw qcow2)' \
                    '-u[unsafe]' \
                    '*:file:_files' ;;
                commit) _arguments \
                    '-f+[format]:fmt:(qcow2 qed)' \
                    '-b+[backing file]:file:_files' \
                    '-d[do not empty image after commit]' \
                    '-p[progress]' \
                    '*:file:_files' ;;
                compare) _arguments \
                    '-f+[format1]:fmt:(raw qcow2 vmdk vdi vhdx vpc)' \
                    '-F+[format2]:fmt:(raw qcow2 vmdk vdi vhdx vpc)' \
                    '-p[progress]' \
                    '-q[quiet]' \
                    '*:files:_files' ;;
            esac
            ;;
    esac
}

_qemu-img-cli "$@"
