#compdef sign-efi-sig-list
# Documentation: man sign-efi-sig-list(1)
# Source: mjg59/efitools sign-efi-sig-list.c (master) — sign EFI sig list for variable update (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--version[show version]' \
    '--help[show help]' \
    '-r[certificate is RSA2048 instead of X.509 (unimplemented)]' \
    '-m[use monotonic count instead of timestamp (unimplemented)]' \
    '-a[prepare variable for APPEND_WRITE]' \
    '-o[output unsigned bundle (for external signing)]' \
    '-t+[timestamp YYYY-MM-DD HH:MM:SS]:timestamp:_default' \
    '-i+[detached signature input (PEM)]:file:_files -g "*.{pem,sig}"' \
    '-g+[signature owner GUID]:guid:_default' \
    '-c+[signing certificate (PEM)]:file:_files -g "*.{pem,crt}"' \
    '-k+[signing key (PEM)]:file:_files -g "*.{pem,key}"' \
    '1:variable name:(PK KEK db dbx MokList)' \
    '2:EFI sig list input file:_files -g "*.esl"' \
    '3:output file:_files' \
    && ret=0

return ret
