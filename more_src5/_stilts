#compdef stilts
# Documentation: https://www.star.bris.ac.uk/mbt/stilts/sun256/sun256.html
# Reference accessed: 2026-05-27
# Verified: upstream STILTS User Guide SUN/256 task list and global flags

local curcontext="$curcontext" state line ret=1

local -a _stilts_tasks
_stilts_tasks=(
  'arrayjoin:join tables with array-valued columns'
  'calc:evaluate algebraic expressions'
  'cdsskymatch:upload sky crossmatch to CDS X-Match service'
  'cone:multi-cone search against cone-search service'
  'coneskymatch:multi-cone crossmatch against cone-search service'
  'datalinklint:validate DataLink documents'
  'doc:produce reference documentation'
  'funcs:browse expression-language functions'
  'mocshape:write MOC describing table sky coverage'
  'parqlint:check Parquet file conformance'
  'parqlook:examine Parquet file metadata'
  'pixfoot:HEALPix footprint of a table'
  'pixsample:sample HEALPix pixel data at table positions'
  'plot2corner:scatter plots in corner-plot grid (plot2)'
  'plot2cube:plot in 3D Cartesian cube (plot2)'
  'plot2plane:plot on a 2D plane (plot2)'
  'plot2sphere:plot on a 3D sphere (plot2)'
  'plot2sky:plot on a 2D sky surface (plot2)'
  'plot2time:plot time-series data (plot2)'
  'plot2d:old-style 2D plot (deprecated)'
  'plot3d:old-style 3D plot (deprecated)'
  'plothist:old-style histogram plot (deprecated)'
  'regquery:query VO registry'
  'server:run STILTS as an HTTP server'
  'sqlclient:run SQL queries against a JDBC database'
  'sqlskymatch:sky crossmatch against SQL database'
  'sqlupdate:run SQL UPDATE against database'
  'taplint:validate TAP service'
  'tapquery:run synchronous TAP query'
  'tapresume:resume an interrupted async TAP query'
  'tapskymatch:sky crossmatch against TAP service'
  'tcat:concatenate multiple similar tables'
  'tcatn:concatenate N tables with column adjustment'
  'tcopy:copy a table (often with format conversion)'
  'tcube:histogram-like binning of a table'
  'tgridmap:produce HEALPix table from grid'
  'tgroup:perform GROUP BY-style aggregation'
  'tjoin:join multiple tables side-by-side'
  'tloop:iterate algebraic expressions producing a table'
  'tmatch1:internal crossmatch within a single table'
  'tmatch2:crossmatch two tables'
  'tmatchn:crossmatch N tables'
  'tmulti:write a multi-extension/multi-table output file'
  'tmultin:write N tables as multi-extension output'
  'tpipe:apply a processing pipeline to a table'
  'tskymap:produce sky density map from a table'
  'tskymatch2:fast sky crossmatch of two tables'
  'votcopy:copy a VOTable changing encoding'
  'votlint:validate a VOTable document'
  'xsdvalidate:validate XML against an XSD schema'
)

_arguments -C \
  '(- *)-help[print usage information]' \
  '(- *)-version[print STILTS version]' \
  '*-verbose[increase logging verbosity (repeatable)]' \
  '*+verbose[decrease logging verbosity (repeatable)]' \
  '-allowunused[tolerate unused parameters]' \
  '-prompt[prompt for all unspecified parameters]' \
  '-bench[display execution time]' \
  '-debug[enable debugging output with full stack traces]' \
  '-batch[disable all parameter prompting]' \
  '-memory[prefer heap memory for caching]' \
  '-disk[prefer temporary disk files for caching]' \
  '-memgui[display memory usage window]' \
  '-checkversion[require exact version match]:version:' \
  '-stdout[redirect standard output]:file:_files' \
  '-stderr[redirect error output]:file:_files' \
  '1: :->task' \
  '*:: :->args' && ret=0

case $state in
  task)
    _describe -t commands 'stilts task' _stilts_tasks && ret=0
    ;;
  args)
    _arguments \
      '*:parameter:' && ret=0
    ;;
esac

return ret
