#compdef sh2power
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/sh2power.html
# Source: MRtrix3/mrtrix3 cmd/sh2power.cpp — compute total SH power image or per-degree spectrum (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-spectrum[output per-degree (l=0,2,4...) power as a 4D image]' \
    '1:SH (input):_files -g "*.{nii,nii.gz,mif}"' \
    '2:power (output):_files' \
    && ret=0

return ret
