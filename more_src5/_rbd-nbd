#compdef rbd-nbd
# Documentation: https://docs.ceph.com/en/latest/man/8/rbd-nbd/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# rbd-nbd: map RBD images to /dev/nbdN
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'map:map image to /dev/nbdN'
  'unmap:unmap /dev/nbdN'
  'list-mapped:list mapped images'
  'attach:attach image to a specified NBD device'
  'detach:detach an NBD device'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-c[ceph config file]:file:_files -g "*.conf"' \
  '--conf=[ceph config file]:file:_files -g "*.conf"' \
  '--cluster=[cluster name]:name:' \
  '-i[id]:id:' \
  '--id=[id]:id:' \
  '--name=[name]:name:' \
  '--read-only[read-only]' \
  '--exclusive[exclusive lock]' \
  '--nbds_max=[max NBDs]:n:' \
  '--max_part=[max partitions]:n:' \
  '--encryption-format=[encryption format]:fmt:(luks luks1 luks2)' \
  '--encryption-passphrase-file=[encryption passphrase file]:file:_files' \
  '--device=[nbd device]:dev:_files' \
  '--snap-id=[snapshot id]:id:' \
  '--notrim[disable trim/discard]' \
  '--io-timeout=[request timeout]:secs:' \
  '--reattach-timeout=[reattach timeout]:secs:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'rbd-nbd command' commands && ret=0 ;;
esac
return ret
