#compdef qrencode
# _qrencode-bin — qrencode QR-Code image encoder (C); produces PNG/EPS/SVG/UTF8/ANSI QR codes from text
# upstream: https://github.com/fukuchi/libqrencode

_qrencode-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-o --output)'{-o,--output}'+[output file]:file:_files' \
        '(-r --read-from)'{-r,--read-from}'+[read from file]:file:_files' \
        '(-s --size)'{-s,--size}'+[dot size px]:n:' \
        '(-l --level)'{-l,--level}'+[error-correction level]:level:(L M Q H)' \
        '(-v --symversion)'{-v,--symversion}'+[QR version 1-40]:n:' \
        '(-m --margin)'{-m,--margin}'+[margin dots]:n:' \
        '(-d --dpi)'{-d,--dpi}'+[DPI for printable formats]:n:' \
        '(-t --type)'{-t,--type}'+[output type]:type:(PNG PNG32 EPS SVG XPM ANSI ANSI256 ASCII ASCIIi UTF8 ANSIUTF8 ANSI256UTF8 UTF8i ANSIUTF8i)' \
        '(-S --structured)'{-S,--structured}'[structured-append symbols]' \
        '(-k --kanji)'{-k,--kanji}'[encode kanji]' \
        '(-c --casesensitive)'{-c,--casesensitive}'[case sensitive (8-bit)]' \
        '(-i --ignorecase)'{-i,--ignorecase}'[ignore case (alphanum)]' \
        '(-8 --8bit)'{-8,--8bit}'[8-bit mode]' \
        '(-M --micro)'{-M,--micro}'[Micro QR Code]' \
        '(--rle)--rle[RLE compression for SVG]' \
        '(--svg-path)--svg-path[SVG path instead of rect]' \
        '(--foreground)--foreground+[fg color RRGGBB[AA]]:hex:' \
        '(--background)--background+[bg color RRGGBB[AA]]:hex:' \
        '(--inline)--inline[inline SVG]' \
        '(--strict-version)--strict-version[strict version]' \
        '*:string:'
}

_qrencode-bin "$@"
