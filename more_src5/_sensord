#compdef sensord
# Documentation: man sensord(8)
# Source: lm-sensors/lm-sensors prog/sensord/args.c (master) — sensors logging daemon (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-i --interval)'{-i+,--interval=}'[scan interval (s)]:seconds:_default' \
    '(-l --log-interval)'{-l+,--log-interval=}'[log interval (s)]:seconds:_default' \
    '(-t --rrd-interval)'{-t+,--rrd-interval=}'[RRD interval (s)]:seconds:_default' \
    '(-1 --oneline)'{-1,--oneline}'[one-line log format]' \
    '(-T --rrd-no-average)'{-T,--rrd-no-average}'[do not RRD-average values]' \
    '(-f --syslog-facility)'{-f+,--syslog-facility=}'[syslog facility]:facility:(daemon local0 local1 local2 local3 local4 local5 local6 local7)' \
    '(-r --rrd-file)'{-r+,--rrd-file=}'[RRD database file]:file:_files -g "*.rrd"' \
    '(-c --config-file)'{-c+,--config-file=}'[sensors config file]:file:_files' \
    '(-p --pid-file)'{-p+,--pid-file=}'[PID file]:file:_files' \
    '(-g --rrd-cgi)'{-g+,--rrd-cgi=}'[RRD CGI script output]:file:_files' \
    '(-a --load-average)'{-a,--load-average}'[also log load average]' \
    '(-d --debug)'{-d,--debug}'[debug output]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '*:chip:_default' \
    && ret=0

return ret
