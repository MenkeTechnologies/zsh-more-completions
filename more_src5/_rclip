#compdef rclip

_arguments -s -S \
  '(- *)--help[show help information]' \
  '(- *)--version[show version]' \
  '--filepath-only[only output file paths]' \
  '--no-recursive[do not search recursively]' \
  '--top[number of results to show]:count' \
  '--port[server port]:port' \
  '1:query' \
  '2::path:_files -/'
