#compdef rospack rosstack
# Documentation: http://wiki.ros.org/rospack
# Source: ros/rospack noetic-devel src/rospack.cpp Rospack::usage() — ROS1 package management.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '(- *)help[display usage information]' \
    '--deps-only[restrict cflags/libs queries to direct deps only]' \
    '--target=[explain dependency chain to this target]:target:_default' \
    '--lang=[language for export]:lang:_default' \
    '--attrib=[attribute name for export/plugins]:attrib:_default' \
    '--top=[top package for plugins query]:pkg:_default' \
    '--length=[crawl profile length]:n:_default' \
    '--zombie-only[only report zombie paths in profile]' \
    '1:subcommand:((
        find\:"return absolute path to package"
        list\:"list all packages"
        list-names\:"list package names only"
        list-duplicates\:"identify duplicate packages"
        depends\:"show package dependencies"
        deps\:"alias for depends"
        depends-indent\:"display dependencies with indentation"
        depends-manifests\:"list dependency manifest paths"
        depends-on\:"show reverse dependencies"
        depends-why\:"explain dependency chain (use --target=)"
        cflags-only-I\:"include directory flags"
        cflags-only-other\:"other compiler flags"
        libs-only-L\:"library path flags"
        libs-only-l\:"library name flags"
        libs-only-other\:"other linker flags"
        export\:"export package metadata (use --lang= --attrib=)"
        plugins\:"list plugin information"
        rosdep\:"show system dependencies"
        vcs\:"display version control information"
        profile\:"analyze crawl performance"
        langs\:"list configured languages"
    ))' \
    '*::args:_default' \
    && ret=0

return ret
