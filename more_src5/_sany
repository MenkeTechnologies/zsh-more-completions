#compdef sany
# Documentation: https://raw.githubusercontent.com/pmer/tla-bin/master/bin/sany
# Reference accessed: 2026-05-27
# Verified: upstream tla2sany.drivers.SANY.SANYmain0() in tlaplus/tlaplus
#   tlatools/org.lamport.tlatools/src/tla2sany/drivers/SANY.java

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-help[print help and exit]' \
  '(-s -S)'{-s,-S}'[toggle semantic analysis (default on)]' \
  '(-l -L)'{-l,-L}'[toggle level checking (default on)]' \
  '(-g -G)'{-g,-G}'[toggle linting (default on)]' \
  '(-d -D)'{-d,-D}'[toggle debugging / semantic graph explorer]' \
  '(-stat -STAT)'{-stat,-STAT}'[accepted but ignored (legacy)]' \
  '-error-codes[return descriptive exit codes (2 parse, 4 semantic)]' \
  '-suppressMessages[silence specific message codes]:codes (comma-separated):' \
  '-messagesAsErrors[treat specific message codes as fatal]:codes (comma-separated):' \
  '*:spec:_files -g "*.tla"' && ret=0

return ret
