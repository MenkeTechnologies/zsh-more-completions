#compdef restful-as
# _restful-as — Confidential Containers RESTful Attestation Service (Trustee CoCo-AS HTTP/HTTPS server)
# upstream: https://github.com/confidential-containers/trustee
# Flags from attestation-service/src/bin/restful-as.rs Cli on tip (clap).

_restful-as() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '(-c --config-file)'{-c,--config-file}'=[path to CoCo-AS config file]:file:_files' \
        '(-s --socket)'{-s,--socket}'=[address to listen on (IP:port)]:addr:' \
        '(-t --https-pubkey-cert)'{-t,--https-pubkey-cert}'=[HTTPS public-key cert (PEM)]:file:_files' \
        '--https-prikey=[HTTPS private key (PEM)]:file:_files'
}

_restful-as "$@"
