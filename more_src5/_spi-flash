#compdef spi-flash flashrom-spi
# _spi-flash — Linaro spi-flash CLI for reading writing erasing identifying SPI NOR NAND flash chips via Linux SPIdev character device chip select size geometry write protect status query manufacturer (linaro team, C); getopt
# upstream: https://github.com/spi-flash/spi-flash

_spi-flash() {
    local -a sub=(
        'identify:identify chip'
        'read:read chip contents'
        'write:write file to chip'
        'erase:erase chip'
        'verify:verify chip contents'
        'status:show chip status'
        'wp:show write protect status'
        'wp-disable:disable write protect'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-d+[device]:file:_files -g "/dev/spidev*"' \
        '--device=+[device]:file:_files -g "/dev/spidev*"' \
        '-s+[speed Hz]:n:' \
        '--speed=+[speed Hz]:n:' \
        '-c+[chip]:str:' \
        '--chip=+[chip]:str:' \
        '-S+[start address]:n:' \
        '--start=+[start address]:n:' \
        '-l+[length bytes]:n:' \
        '--length=+[length bytes]:n:' \
        '-y[yes confirm]' \
        '--yes[yes confirm]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'spi-flash subcommand' sub ;;
        args)
            case $words[1] in
                read|verify) _arguments \
                    '*:output file:_files -g "*.bin *.hex *.rom"' ;;
                write) _arguments \
                    '--no-verify[skip verify]' \
                    '*:input file:_files -g "*.bin *.hex *.rom"' ;;
                erase) _arguments \
                    '--whole[erase whole chip]' \
                    '--sector=+[N]:n:' \
                    '--sectors=+[N N N ...]:str:' ;;
            esac
            ;;
    esac
}

_spi-flash "$@"
