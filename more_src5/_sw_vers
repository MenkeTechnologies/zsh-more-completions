#compdef sw_vers
# Documentation: https://www.unix.com/man-page/osx/1/sw_vers/
# Source: Apple macOS — print operating system name / version / build.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-productName[print ProductName property only]' \
    '(- *)-productVersion[print ProductVersion property only]' \
    '(- *)-buildVersion[print BuildVersion property only]' \
    && ret=0

return ret
