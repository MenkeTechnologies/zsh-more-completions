#compdef squashfuse squashfuse_ll squashfuse_ls squashfuse_extract
# Documentation: https://github.com/vasi/squashfuse (hl.c + ll_main.c + ls.c + extract.c + fuseprivate.c sqfs_usage())
# Reference accessed: 2026-05-29
# squashfuse — mount SquashFS archives via FUSE without root.
#   squashfuse        : high-level FUSE driver (hl.c)
#   squashfuse_ll     : low-level FUSE driver, supports idle-timeout auto-unmount + uid/gid mapping (ll_main.c)
#   squashfuse_ls     : list archive contents without mounting (ls.c) — single ARCHIVE positional
#   squashfuse_extract: extract single path or whole archive (extract.c) — ARCHIVE PATH or ARCHIVE -a

local curcontext="$curcontext" state line ret=1

case $service in
  squashfuse_ls)
    _arguments \
      '1:archive:_files -g "*.(sfs|squashfs|sqfs|img)"' && ret=0
    ;;
  squashfuse_extract)
    _arguments \
      '1:archive:_files -g "*.(sfs|squashfs|sqfs|img)"' \
      '2:path-to-extract (or -a for all):' && ret=0
    ;;
  squashfuse_ll)
    _arguments -s -S \
      '-h[show usage]' \
      '-V[show version]' \
      '-d[enable FUSE debug output]' \
      '-f[run in foreground]' \
      '-s[disable multi-threaded operation]' \
      '*-o[mount option (squashfuse_ll: offset=N, subdir=PATH, notify_pipe=PATH, timeout=N, uid=N, gid=N; plus FUSE opts: ro,rw,allow_other,allow_root,nonempty,default_permissions,uid=N,gid=N,umask=M,direct_io,kernel_cache,auto_cache)]:opt:->llopts' \
      '1:archive:_files -g "*.(sfs|squashfs|sqfs|img)"' \
      '2:mountpoint:_directories' && ret=0
    [[ $state == llopts ]] && _values -s , 'mount option' \
      'offset=[offset N bytes into ARCHIVE]:N:' \
      'subdir=[mount subdirectory PATH of ARCHIVE]:path:' \
      'notify_pipe=[named pipe receiving s/f when ready]:pipe:_files' \
      'timeout=[idle N seconds before automatic unmount]:N:' \
      'uid=[set file owner to uid N]:N:' \
      'gid=[set file group to gid N]:N:' \
      'ro[read-only]' \
      'rw[read-write (no-op for squashfuse)]' \
      'allow_other[allow access by all users]' \
      'allow_root[allow access by root]' \
      'default_permissions[use kernel permission check]' \
      'direct_io[use direct I/O]' \
      'kernel_cache[cache files in kernel]' \
      'auto_cache[invalidate cache on file modification]' \
      'umask=[set file permission umask]:mask:' \
      && ret=0
    ;;
  *)
    _arguments -s -S \
      '-h[show usage]' \
      '-V[show version]' \
      '-d[enable FUSE debug output]' \
      '-f[run in foreground]' \
      '-s[disable multi-threaded operation]' \
      '*-o[mount option (squashfuse: offset=N, subdir=PATH, notify_pipe=PATH; plus FUSE opts ro,allow_other,allow_root,default_permissions,direct_io,kernel_cache,auto_cache,uid=N,gid=N,umask=M)]:opt:->hlopts' \
      '1:archive:_files -g "*.(sfs|squashfs|sqfs|img)"' \
      '2:mountpoint:_directories' && ret=0
    [[ $state == hlopts ]] && _values -s , 'mount option' \
      'offset=[offset N bytes into ARCHIVE]:N:' \
      'subdir=[mount subdirectory PATH of ARCHIVE]:path:' \
      'notify_pipe=[named pipe receiving s/f when ready]:pipe:_files' \
      'ro[read-only]' \
      'allow_other[allow access by all users]' \
      'allow_root[allow access by root]' \
      'default_permissions[use kernel permission check]' \
      'direct_io[use direct I/O]' \
      'kernel_cache[cache files in kernel]' \
      'auto_cache[invalidate cache on file modification]' \
      'uid=[set file owner to uid N]:N:' \
      'gid=[set file group to gid N]:N:' \
      'umask=[set file permission umask]:mask:' \
      && ret=0
    ;;
esac

return ret
