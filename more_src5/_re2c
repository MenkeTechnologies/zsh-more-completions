#compdef re2c re2d re2go re2hs re2js re2ocaml re2py re2rust re2swift re2v re2zig
# Documentation: re2c --help
# Source: lexer generator for C / D / Go / Haskell / JS / OCaml / Python / Rust / Swift / V / Zig.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-?,-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '--api=[generated API style]:api:(simple record generic)' \
    {-b,--bit-vectors}'[optimize jumps with bit masks]' \
    '(--captvars --leftmost-captvars)--captures[leftmost-greedy capture into array]' \
    '(--captvars --leftmost-captvars --captures)--leftmost-captures[leftmost-greedy capture into array]' \
    '(--captures --leftmost-captures)--captvars[leftmost-greedy capture into variables]' \
    '(--captures --leftmost-captures --captvars)--leftmost-captvars[leftmost-greedy capture into variables]' \
    '--case-insensitive[treat quoted strings as case-insensitive]' \
    '--case-inverted[invert quoting case semantics]' \
    '--case-ranges[use character ranges in case statements]' \
    {-c,--conditions,--start-conditions}'[enable start conditions (lex-style)]' \
    {-d,--debug-output}'[generate debug output]' \
    {-D,--emit-dot}'[emit DFA as Graphviz dot]' \
    {-e,--ecb}'[emit ECB-encoded character classes]' \
    {-F,--flex-syntax}'[allow flex-like syntax]' \
    {-f,--storable-state}'[generate code with storable state]' \
    {-g,--computed-gotos}'[use computed gotos]' \
    {-I+,--include=}'[search dir for includes]:dir:_files -/' \
    '*-i+[search dir for includes]:dir:_files -/' \
    {-o+,--output=}'[output file]:file:_files' \
    {-r,--reusable}'[allow reuse of generated blocks]' \
    {-S,--skeleton}'[generate skeleton for testing]' \
    {-s,--nested-ifs}'[use nested if statements]' \
    {-t+,--type-header=}'[type header file]:file:_files' \
    {-T,--tags}'[enable submatch extraction with tags]' \
    '-P[allow Posix-style captures]' \
    {-W,--all-warnings}'[turn on all warnings]' \
    '--no-debug-info[do not generate #line directives]' \
    '--no-version[do not include version in output]' \
    '--no-generation-date[do not include generation date]' \
    '--no-unsafe[disable unsafe constructs]' \
    '--input-encoding=[input encoding]:encoding:(ascii ebcdic ucs2 utf8 utf16 utf32)' \
    '--encoding-policy=[encoding policy]:policy:(fail substitute ignore)' \
    '--empty-class=[empty class policy]:policy:(match-empty match-none error)' \
    '--target=[target language]:lang:(c d go haskell java ocaml python rust swift v zig)' \
    '--lang=[target language alias]:lang:(c d go haskell java ocaml python rust swift v zig)' \
    '-1[lookahead by 1 character (default in some modes)]' \
    '--dump-dfa-raw[dump raw DFA]' \
    '--dump-dfa-det[dump deterministic DFA]' \
    '--dump-dfa-tagopt[dump tag-optimized DFA]' \
    '--dump-dfa-min[dump minimized DFA]' \
    '--dump-nfa[dump NFA]' \
    '--dump-adfa[dump adjacent DFA]' \
    '*:input:_files -g "*.(re|re2c)"' \
    && ret=0

return ret
