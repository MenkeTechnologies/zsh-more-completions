#compdef smbios-battery-ctl
# Documentation: https://man.archlinux.org/man/extra/libsmbios/smbios-battery-ctl.1.en
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# smbios-battery-ctl: Dell battery charging configuration via SMBIOS
local curcontext="$curcontext" ret=1
_arguments -C \
  '--version[show program version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[display more verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[minimize program output]' \
  '--trace[enable verbose function tracing]' \
  '--logconfig=[alternate config log]:file:_files' \
  '--security-key=[BIOS pre-calculated security key]:key:' \
  '--password=[BIOS Setup password]:password:' \
  '(-r --rawpassword)'{-r,--rawpassword}'[do not auto-convert password to scancodes]' \
  '--memory-dat=[memory dump file]:file:_files' \
  '--cmos-dat=[CMOS dump file]:file:_files' \
  '(-c --battery-charge)'{-c,--battery-charge}'[get current battery charging state]' \
  '--get-charging-cfg[get current primary battery charge configuration]' \
  '--set-charging-mode=[set charging configuration mode]:mode:' \
  '--set-custom-charge-interval=[set percentage bounds for custom charging]:start end:' && ret=0
return ret
