#compdef shopctl
# _shopctl — manage Shopify store data from the terminal (ankitpokhrel/shopctl)
# upstream: https://github.com/ankitpokhrel/shopctl
# Subcommands + flags from internal/cmd/root/root.go (cobra).

_shopctl() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-c --context)'{-c+,--context=}'[override current-context]:context:' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_shopctl_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                auth)
                    _arguments '1:auth subcommand:(login)'
                    ;;
                config)
                    _arguments '1:config subcommand:(current-context delete-context get-contexts use-context)'
                    ;;
                product)
                    _arguments '1:product subcommand:(create list update delete clone get publish unpublish search)'
                    ;;
                customer)
                    _arguments '1:customer subcommand:(create list update delete)'
                    ;;
                order)
                    _arguments '1:order subcommand:(list)'
                    ;;
                webhook)
                    _arguments '1:webhook subcommand:(create list delete update)'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_shopctl_commands] )) ||
_shopctl_commands() {
    local -a commands
    commands=(
        'auth:authenticate with a Shopify store'
        'config:manage shopctl config contexts'
        'product:manage products (create, list, update, delete, clone)'
        'customer:manage customers (create, list, update, delete)'
        'order:list orders'
        'export:export Shopify data to a file'
        'ingest:import data from a file into Shopify'
        'webhook:manage Shopify webhooks'
        'version:print shopctl version'
    )
    _describe -t commands 'shopctl command' commands
}

_shopctl "$@"
