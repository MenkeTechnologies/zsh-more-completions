#compdef shuttle
# Documentation: https://docs.shuttle.dev/guides/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Zsh completion for Shuttle.rs CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--api-url=[Shuttle API URL]:url' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:Generate a Shuttle project from a template'
      'run:Run a project locally'
      'deploy:Deploy a project'
      'deployment:Manage deployments'
      'logs:View build and deployment logs'
      'project:Manage Shuttle projects'
      'resource:Manage resources'
      'certificate:Manage SSL certificates for custom domains'
      'account:Show account information'
      'login:Authenticate with Shuttle'
      'logout:Sign out of Shuttle'
      'generate:Create shell completions and man pages'
      'feedback:Submit GitHub issue with feedback'
      'upgrade:Update the CLI binary'
      'mcp:Configure Shuttle MCP server'
    )
    _describe -t commands 'shuttle command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      init)
        _arguments -s -S \
          '--name=[project name]:name' \
          '--template=[template to use]:template' \
          '--path=[path for project]:directory:_directories' \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
      run)
        _arguments -s -S \
          '--port=[local port]:port' \
          '--release[build in release mode]' \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
      deploy)
        _arguments -s -S \
          '--allow-dirty[deploy with uncommitted changes]' \
          '--no-follow[do not follow deployment logs]' \
          '--name=[project name]:name' \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
      project)
        local -a subcmds=(
          'start:Start a project'
          'stop:Stop a project'
          'restart:Restart a project'
          'status:Show project status'
          'list:List projects'
          'delete:Delete a project'
        )
        if (( CURRENT == 2 )); then
          _describe -t subcmds 'project subcommand' subcmds && ret=0
        fi
        ;;
      resource)
        local -a subcmds=(
          'list:List resources'
          'delete:Delete a resource'
        )
        if (( CURRENT == 2 )); then
          _describe -t subcmds 'resource subcommand' subcmds && ret=0
        fi
        ;;
      logs)
        _arguments -s -S \
          '--follow[follow log output]' \
          '--name=[project name]:name' \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
      login)
        _arguments -s -S \
          '--api-key=[API key]:key' \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
