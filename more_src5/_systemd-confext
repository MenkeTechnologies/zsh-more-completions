#compdef systemd-confext
# _systemd-confext — systemd systemd-confext (extension-image manager for /etc and /var; subcommands: status (default), list, refresh, attach, detach, reattach, merge, unmerge, has-image; --root override prefix, --image-policy filter image classes, --image-class type, --no-reload skip daemon-reload, --no-pager, -q quiet)
# upstream: https://github.com/systemd/systemd (src/sysext)
# Subcommands from systemd src/sysext/sysext.c (confext variant) on tip.

_systemd-confext() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '-q[quiet]' \
        '--no-pager[no pager]' \
        '--no-legend[no legend]' \
        '--root+[root prefix]:dir:_files -/' \
        '--image-policy+[policy]:policy:' \
        '--no-reload[skip daemon-reload]' \
        '--force[force]' \
        '--json=*[json mode]:mode:(short pretty off)' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'confext command' '(status list refresh attach detach reattach merge unmerge has-image help)' ;;
        args) _arguments '*:image:_files' ;;
    esac
}

_systemd-confext "$@"
