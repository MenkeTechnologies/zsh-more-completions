#compdef s-tui
# Documentation: https://github.com/amanusk/s-tui
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[display version]' \
  {-d,--debug}'[output debug log to _s-tui.log]' \
  '--debug-file=[custom debug file]:file:_files' \
  {-dr,--debug_run}'[run for 5 seconds and quit]' \
  {-c,--csv}'[save stats to CSV file]' \
  '--csv-file=[custom CSV file]:file:_files' \
  {-t,--terminal}'[display a single line of stats without TUI]' \
  {-j,--json}'[display a single line of stats in JSON format]' \
  {-nm,--no-mouse}'[disable mouse for TTY systems]' \
  '(-tt --t_thresh)'{-tt,--t_thresh}'[set high temperature threshold]:threshold:' && return 0
