#compdef rcvtty
# Documentation: man rcvtty(1)
# Source: nmh uip/rcvtty.c (master) — notify user of new mail on terminals (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-biff[honor biff(1) -n]' \
    '-form+[format file]:file:_files' \
    '-format+[format string]:string:_default' \
    '-width+[output width]:cols:_default' \
    '(-newline -nonewline)-newline[print final newline]' \
    '(-newline -nonewline)-nonewline[no final newline]' \
    '(-bell -nobell)-bell[ring bell]' \
    '(-bell -nobell)-nobell[no bell]' \
    '-version[show version]' \
    '-help[show help]' \
    '*::command:_command_names -e' \
    && ret=0

return ret
