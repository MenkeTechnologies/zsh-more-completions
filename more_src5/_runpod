#compdef runpod runpodctl
# _runpod — RunPod runpodctl CLI for managing GPU pods serverless endpoints and templates (runpod team, Go); cobra
# upstream: https://github.com/runpod/runpodctl

_runpod() {
    local -a sub=(
        'config:configure API key and settings'
        'pod:pod subcommands'
        'project:project subcommands'
        'template:template subcommands'
        'endpoint:endpoint subcommands'
        'create:create resource'
        'get:get resource'
        'remove:remove resource'
        'start:start pod'
        'stop:stop pod'
        'send:upload file to pod'
        'receive:download file from pod'
        'exec:exec command on pod'
        'ssh:ssh to pod'
        'logs:show pod logs'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--apiKey=+[API key]:str:' \
        '--apiUrl=+[API URL]:url:_urls' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml"' \
        '--debug[debug logging]' \
        '--output=+[format]:f:(table json yaml)' \
        '-o+[format]:f:(table json yaml)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'runpod subcommand' sub ;;
        args)
            case $words[1] in
                pod) _arguments '1:pod cmd:(create get list start stop terminate connect exec ssh logs)' ;;
                project) _arguments '1:project cmd:(new dev deploy build start logs delete)' ;;
                template) _arguments '1:template cmd:(create get list update delete)' ;;
                endpoint) _arguments '1:endpoint cmd:(create get list update delete invoke logs)' ;;
                create) _arguments \
                    '--name=+[name]:str:' \
                    '--imageName=+[docker image]:str:' \
                    '--gpuType=+[gpu type]:str:' \
                    '--gpuCount=+[N]:n:' \
                    '--containerDiskSize=+[GB]:n:' \
                    '--volumeSize=+[GB]:n:' \
                    '--volumePath=+[path]:dir:_files -/' \
                    '--ports=+[ports csv]:str:' \
                    '--secureCloud[secure cloud]' \
                    '--communityCloud[community cloud]' ;;
                send|receive) _arguments '*:file:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_runpod "$@"
