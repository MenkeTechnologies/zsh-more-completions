#compdef snapshot-conversion-webhook snapshot-webhook
# _snapshot-conversion-webhook — VolumeSnapshot CRD conversion webhook (kubernetes-csi/external-snapshotter)
# upstream: https://github.com/kubernetes-csi/external-snapshotter
# Flags from cmd/snapshot-conversion-webhook/main.go on tip.

_snapshot-conversion-webhook() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--tls-cert-file=[TLS server cert (required)]:file:_files' \
        '--tls-private-key-file=[TLS server key (required)]:file:_files' \
        '--port=[HTTPS bind port]:port:' \
        '-v[klog verbosity level]:n:'
}

_snapshot-conversion-webhook "$@"
