#compdef stayrtr
# _stayrtr — bgp/stayrtr StayRTR open-source RPKI-to-Router server formerly Cloudflare GoRTR (bgp team, Go); standard flag package
# upstream: https://github.com/bgp/stayrtr

_stayrtr() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '--version[show version]' \
        '-bind+[bind address]:str:' \
        '-bind.tls+[tls bind address]:str:' \
        '-tls.cert+[cert file]:file:_files' \
        '-tls.key+[key file]:file:_files' \
        '-checktime[require valid signed time]' \
        '-cache+[VRP cache file or url]:str:' \
        '-cache.refresh+[refresh duration]:str:' \
        '-cache.refresh.retry+[retry duration]:str:' \
        '-cache.refresh.expire+[expire duration]:str:' \
        '-checkjson[validate JSON]' \
        '-debug[debug logging]' \
        '-loglevel+[level]:l:(panic fatal error warn info debug trace)' \
        '-metrics.addr+[prometheus addr]:str:' \
        '-metrics.path+[prometheus path]:str:' \
        '-pid+[pid file]:file:_files' \
        '-protocol+[RTR version]:n:(0 1)' \
        '-refresh+[interval seconds]:n:' \
        '-retry+[retry seconds]:n:' \
        '-expire+[expire seconds]:n:' \
        '-rtr.session.id+[session id]:n:' \
        '-rtr.session.size+[chunk size]:n:' \
        '-sentry[enable sentry]' \
        '-sentry.dsn+[sentry dsn]:str:' \
        '-ssh+[ssh bind address]:str:' \
        '-ssh.bind.priv+[ssh host key]:file:_files' \
        '-ssh.method.password+[user:pass]:str:' \
        '-ssh.method.key+[auth key file]:file:_files' \
        '-useragent+[user agent]:str:' \
        '-verify[verify signed cache]' \
        '-verify.key+[verify pubkey]:file:_files' \
        '-export[export cache to file]:file:_files' \
        '-mfa.required[require client mfa]'
}

_stayrtr "$@"
