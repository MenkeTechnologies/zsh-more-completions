#compdef sgdisk-cli
# _sgdisk-cli — Rod Smith gdisk sgdisk command-line GPT partition tool CLI alias (gdisk team, C++); custom argparse
# upstream: https://sourceforge.net/projects/gptfdisk/

_sgdisk-cli() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a+[sector alignment]:n:' \
        '--set-alignment=+[sector alignment]:n:' \
        '-A+[attributes]:str:' \
        '--attributes=+[attributes]:str:' \
        '-b+[file]:file:_files' \
        '--backup=+[file]:file:_files' \
        '-B+[file]:file:_files' \
        '--rebuild-backup-from=+[file]:file:_files' \
        '-c+[partnum:name]:str:' \
        '--change-name=+[partnum:name]:str:' \
        '-C[recompute CHS]' \
        '--recompute-chs[recompute CHS]' \
        '-d+[partnum]:n:' \
        '--delete=+[partnum]:n:' \
        '-D[show default attributes]' \
        '--display-alignment[show default attributes]' \
        '-e[move backup GPT to end]' \
        '--move-second-header[move backup GPT to end]' \
        '-E[show second header]' \
        '--end-of-largest[show end of largest free region]' \
        '-f[show first available sector]' \
        '--first-in-largest[show first available sector]' \
        '-F[show free sectors]' \
        '--first-aligned-in-largest[show free sectors]' \
        '-g+[disk GUID]:str:' \
        '--mbrtogpt[convert mbr to gpt]' \
        '-G[randomize disk GUID]' \
        '--randomize-guids[randomize disk GUID]' \
        '-h+[hybrid mbr partition]:str:' \
        '--hybrid=+[hybrid mbr partition]:str:' \
        '-i+[show info for partition]:n:' \
        '--info=+[show info for partition]:n:' \
        '-l+[file]:file:_files' \
        '--load-backup=+[file]:file:_files' \
        '-L[list known partition types]' \
        '--list-types[list known partition types]' \
        '-m+[partnum]:str:' \
        '--gpttombr=+[partnum]:str:' \
        '-n+[partnum:start:end]:str:' \
        '--new=+[partnum:start:end]:str:' \
        '-N+[partnum]:n:' \
        '--largest-new=+[partnum]:n:' \
        '-o[clear partition table]' \
        '--clear[clear partition table]' \
        '-O[print device info]' \
        '--print-mbr[print device info]' \
        '-p[print partition table]' \
        '--print[print partition table]' \
        '-P[show all but writes nothing]' \
        '--pretend[show all but writes nothing]' \
        '-r+[swap partition numbers]:str:' \
        '--transpose=+[swap partition numbers]:str:' \
        '-R+[recovery file]:file:_files' \
        '--replicate=+[recovery file]:file:_files' \
        '-s[sort partitions]' \
        '--sort[sort partitions]' \
        '-t+[partnum:hex]:str:' \
        '--typecode=+[partnum:hex]:str:' \
        '-T[transform mbr to gpt]' \
        '--transform-bsd=+[partnum]:str:' \
        '-u+[partnum:guid]:str:' \
        '--partition-guid=+[partnum:guid]:str:' \
        '-U+[diskguid]:str:' \
        '--disk-guid=+[diskguid]:str:' \
        '-v[verify disk]' \
        '--verify[verify disk]' \
        '-z[zap (destroy) GPT data]' \
        '--zap[zap (destroy) GPT data]' \
        '-Z[zap GPT and MBR]' \
        '--zap-all[zap GPT and MBR]' \
        '*:device:_files -g "/dev/{sd,hd,nvme,mapper}*"'
}

_sgdisk-cli "$@"
