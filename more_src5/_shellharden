#compdef shellharden
# Documentation: https://github.com/anordal/shellharden
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for shellharden - shell script linter and syntax corrector

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--check[check without modifying (exit 2 if changes needed)]' \
  '--replace[replace files in-place]' \
  '--transform[output the transformed file to stdout]' \
  '--suggest[suggest changes (default)]' \
  '--syntax[syntax highlight only]' \
  '--syntax-suggest[syntax highlight with suggestions]' \
  '*:file:_files -g "*.(sh|bash|ksh|zsh)"'
