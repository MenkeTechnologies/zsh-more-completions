#compdef smbios-keyboard-ctl
# Documentation: https://man.archlinux.org/man/extra/libsmbios/smbios-keyboard-ctl.1.en
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# smbios-keyboard-ctl: Dell keyboard illumination control via SMBIOS
local curcontext="$curcontext" ret=1
_arguments -C \
  '--version[show program version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --info)'{-i,--info}'[display supported features for keyboard illumination]' \
  '(-g --get-status)'{-g,--get-status}'[display current status of keyboard illumination settings]' \
  '--set-mode=[set user selectable keyboard mode]:mode:' \
  '--set-trigger=[set trigger types for keyboard illumination]:trigger:' \
  '--set-timeout-battery=[set illumination timeout value on battery]:seconds:' \
  '--set-timeout-ac=[set illumination timeout value on AC]:seconds:' \
  '--set-level=[set keyboard illumination level]:level:' \
  '--als=[set/get ambient light sensor status and control level]:option:' \
  '(-v --verbose)'{-v,--verbose}'[display more verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[minimize program output]' \
  '--trace[enable verbose function tracing]' \
  '--logconfig=[alternate config log]:file:_files' \
  '--security-key=[BIOS pre-calculated security key]:key:' \
  '--password=[BIOS Setup password]:password:' \
  '(-r --rawpassword)'{-r,--rawpassword}'[do not auto-convert password to scancodes]' \
  '--memory-dat=[memory dump file]:file:_files' \
  '--cmos-dat=[CMOS dump file]:file:_files' && ret=0
return ret
