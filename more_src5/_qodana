#compdef qodana
# Documentation: https://github.com/JetBrains/qodana-cli
# Reference accessed: 2026-05-20
# Verified: upstream README and tracked help. Removed --ide and
# --fixes-strategy (not present upstream).

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--disable-update-checks[disable update checks]' \
  '--log-level=[log level]:level:(error info debug)' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'scan:run Qodana analysis'
      'show:show Qodana report'
      'init:configure a project for Qodana'
      'send:send a Qodana report to Cloud'
      'view:view SARIF files in CLI'
      'contributors:calculate active project contributors'
      'cloc:calculate lines of code'
      'pull:pull latest version of linter'
    )
    _describe -t commands 'qodana command' commands && ret=0
    ;;
  args)
    case $line[1] in
      scan)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-i --project-dir)'{-i+,--project-dir=}'[project directory]:directory:_directories' \
          '(-o --results-dir)'{-o+,--results-dir=}'[results directory]:directory:_directories' \
          '(-l --linter)'{-l+,--linter=}'[linter to use]:linter:' \
          '(-e --env)'{-e+,--env=}'[environment variable for the container]:var:' \
          '(-v --volume)'{-v+,--volume=}'[volume mount for the container]:mount:' \
          '--cache-dir=[cache directory]:directory:_directories' \
          '--fail-threshold=[fail threshold]:threshold:' \
          '--baseline=[baseline file]:file:_files -g "*.sarif.json"' \
          '--profile-name=[inspection profile name]:profile:' \
          '--profile-path=[inspection profile path]:file:_files -g "*.xml"' \
          '--property=[JVM property]:property:' \
          '--source-directory=[source directory]:directory:_directories' \
          '--disable-sanity[disable sanity inspections]' \
          '--save-report[save report]' \
          '--print-problems[print problems to stdout]' \
          '--clear-cache[clear cache before running]' \
          '--apply-fixes[apply all available quick-fixes, including cleanup]' \
          '--cleanup[run project cleanup]' \
          '--stub-profile=[stub profile path]:file:_files' && ret=0
        ;;
      show)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-d --report-dir)'{-d+,--report-dir=}'[report directory]:directory:_directories' \
          '(-p --port)'{-p+,--port=}'[port]:port:' && ret=0
        ;;
      init)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-i --project-dir)'{-i+,--project-dir=}'[project directory]:directory:_directories' \
          '(-f --force)'{-f,--force}'[force overwrite existing config]' && ret=0
        ;;
    esac
    ;;
esac

return ret
