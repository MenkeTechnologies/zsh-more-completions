#compdef redcsl reduce redpsl
# Documentation: man redcsl(1)
# Source: reduce-algebra/reduce-algebra csl/cslbase/redcsl.1 (master) — REDUCE under CSL Lisp (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-b[disable prompt/input recolouring]' \
    '*-d+[define Lisp symbol[=value]]:symbol\=value:_default' \
    '-g[debug mode (backtrace enabled)]' \
    '*-i+[image file (read-only)]:file:_files -g "*.img"' \
    '-i-[use default image]' \
    '-o+[image file (read-write)]:file:_files -g "*.img"' \
    '-j+[dependency dump file]:file:_files' \
    '-k+[heap size nnn[/ss] with K/M/G suffix]:size:_default' \
    '-l+[log file copy of stdout]:file:_files' \
    '-n[ignore startup function]' \
    '-q[quiet (no GC messages)]' \
    '-r+[seed RNG nnn[,mmm]]:seed:_default' \
    '-s[generate compiler asm listing]' \
    '-t+[report timestamp of module]:name:_default' \
    '*-u+[undefine Lisp symbol]:symbol:_default' \
    '-v[verbose (banner + GC messages)]' \
    '(-w -w+)-w[force console mode]' \
    '(-w -w+)-w+[force windowed mode]' \
    '-z[start without image (bootstrap)]' \
    '--help[show help]' \
    '--+[redirect stdout to file]:file:_files' \
    '--dump-source[dump REDUCE source]' \
    '*:file:_files' \
    && ret=0

return ret
