#compdef skopeo-sync
# _skopeo-sync — skopeo sync subcommand for syncing images (containers/skopeo)
# upstream: https://github.com/containers/skopeo
# Flags from skopeo-sync(1) man page.

_skopeo-sync() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-a --all)'{-a,--all}'[copy all images in list manifests]' \
        '--authfile=[primary registry credentials file]:file:_files' \
        '--src-authfile=[source registry credentials file]:file:_files' \
        '--dest-authfile=[dest registry credentials file]:file:_files' \
        '--dry-run[do not actually copy data]' \
        '(-s --src)'{-s+,--src=}'[source transport]:transport:(docker yaml dir docker-archive)' \
        '(-d --dest)'{-d+,--dest=}'[destination transport]:transport:(docker dir docker-archive)' \
        '(-f --format)'{-f+,--format=}'[destination manifest type]:type:(oci v2s1 v2s2)' \
        '--scoped[prefix images with the source image path]' \
        '--append-suffix=[append string to destination tags]:suffix:' \
        '--digestfile=[file to write digests of resulting images]:file:_files' \
        '--preserve-digests[preserve digests during copying]' \
        '--remove-signatures[do not copy signatures from source]' \
        '--sign-by=[sign with key ID]:key-id:' \
        '--sign-by-sigstore=[sigstore signing param file]:file:_files' \
        '--sign-by-sigstore-private-key=[sigstore private key file]:file:_files' \
        '--sign-by-sq-fingerprint=[sequoia signature fingerprint]:fingerprint:' \
        '--sign-passphrase-file=[passphrase file]:file:_files' \
        '--keep-going[do not abort on first error]' \
        '--retry-times=[retry on failures]:n:' \
        '--retry-delay=[delay between retries]:duration:' \
        '--src-cert-dir=[source TLS cert directory]:dir:_files -/' \
        '--src-creds=[source credentials USER[:PASSWORD]]:creds:' \
        '--src-no-creds[force unauthenticated source access]' \
        '--src-password=[source registry password]:password:' \
        '--src-registry-token=[source registry bearer token]:token:' \
        '--src-tls-verify=[verify source TLS]:bool:(true false)' \
        '--src-username=[source registry username]:user:' \
        '--dest-cert-dir=[dest TLS cert directory]:dir:_files -/' \
        '--dest-creds=[dest credentials USER[:PASSWORD]]:creds:' \
        '--dest-no-creds[force unauthenticated dest access]' \
        '--dest-password=[dest registry password]:password:' \
        '--dest-registry-token=[dest registry bearer token]:token:' \
        '--dest-tls-verify=[verify dest TLS]:bool:(true false)' \
        '--dest-username=[dest registry username]:user:' \
        '--override-arch=[override architecture]:arch:' \
        '--override-os=[override OS]:os:' \
        '--override-variant=[override variant]:variant:' \
        '1:source:' \
        '2:destination:'
}

_skopeo-sync "$@"
