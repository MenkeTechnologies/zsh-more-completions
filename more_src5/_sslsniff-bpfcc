#compdef sslsniff-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/sslsniff.py argparse)
# Reference accessed: 2026-05-29
# sslsniff-bpfcc — sniff OpenSSL/GnuTLS/NSS plain-text payloads via SSL_read/SSL_write uprobes (BCC/eBPF).
# Note: BCC's sslsniff ships as sslsniff-bpfcc on Debian/Ubuntu to avoid clash with Moxie Marlinspike's
#       SSL/TLS MITM sslsniff (covered by src/_sslsniff).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --pid)'{-p,--pid=}'[sniff this PID only]:pid:_pids' \
  '(-u --uid)'{-u,--uid=}'[sniff this UID only]:uid:' \
  '(-x --extra)'{-x,--extra}'[show extra fields (UID, TID)]' \
  '(-c --comm)'{-c,--comm=}'[sniff only commands matching string]:comm:' \
  '(-o --no-openssl)'{-o,--no-openssl}'[do not show OpenSSL calls]' \
  '(-g --no-gnutls)'{-g,--no-gnutls}'[do not show GnuTLS calls]' \
  '(-n --no-nss)'{-n,--no-nss}'[do not show NSS calls]' \
  '*'{-d,--debug}'[debug mode (repeat to increase verbosity)]' \
  '--ebpf[(internal) eBPF debug output]' \
  '--hexdump[show data as hexdump instead of decoding as UTF-8]' \
  '--max-buffer-size=[size of captured buffer (default 8192)]:bytes:' \
  '(-l --latency)'{-l,--latency}'[show function latency]' \
  '--handshake[show SSL handshake latency (requires --latency)]' \
  '*--extra-lib=[intercept calls from extra library (format lib_type\:lib_path)]:spec:' \
  && ret=0

return ret
