#compdef ra ratop ralabel rasort racount rasplit
# Documentation: https://manpages.debian.org/testing/argus-client/ — argus-client manpages
# Reference accessed: 2026-05-30
# Argus client family — read/process/aggregate argus(8) network flow records.
# QoSient © 2000-2024. ra(1) is the base; ratop/ralabel/rasort/racount/rasplit inherit ra's options plus tool-specific.

local curcontext="$curcontext" state line ret=1

# Base ra(1) options shared across all argus clients.
local -a _ra_common
_ra_common=(
  '(- *)-h[print explanation of all arguments]'
  '-A[print aggregate statistics for the input stream on termination]'
  '-b[dump compiled transaction-matching code to stdout and stop]'
  '-c+[delimiter character for output columns (default " ")]:char:'
  '-D+[debug level to stderr (1-8)]:level:(1 2 3 4 5 6 7 8)'
  '-d[toggle running as a daemon]'
  '-e+[match regular expression in flow user data fields]:regex:'
  '-E+[append filter-rejected records to file]:file:_files'
  '-F+[use this file as configuration source]:file:_files -g "*.conf"'
  '-H[abbreviate numeric metrics (human-readable large values)]'
  '-L+[header label printing frequency]:n:'
  '-n[modify number-to-name conversion (4-state toggle)]'
  '-N+[process first N records (or specified ranges)]:N:'
  '-p+[digits of precision for floating point values]:digits:'
  '-q[run in quiet mode (suppress record output)]'
  '*-r+[read argus data from file (repeatable)]:file:_files -g "*.(argus|arg)"'
  '-R+[recursively process all files in directory]:dir:_directories'
  '*-s+[fields to print (e.g. stime, saddr, daddr, sport, dport, proto, bytes)]:field:'
  '-S+[remote flow data source URI [user[:pass]@]host[:port]]:uri:'
  '-t+[time range for matching records]:timerange:'
  '-T+[read argus from remote server for N seconds]:secs:'
  '-u[print time values using Unix time format]'
  '-w+[append matching data to file (argus format)]:file:_files -g "*.(argus|arg)"'
  '-X[reset all options to default values]'
  '-z[modify status field to represent TCP state changes]'
  '-Z+[modify status field to represent actual TCP flag values]:which:(s d b)'
)

# Sort fields for rasort -m.
local -a _sort_fields
_sort_fields=(
  stime ltime dur avgdur mindur maxdur trans
  smac dmac soui doui
  saddr daddr proto sport dport
  tos ttl load rate loss ploss
  bytes pkts sbytes spkts dbytes dpkts
  vlan mpls srcid tcpb tcprtt
  smeansz dmeansz
  scc dcc sas das ias
)

# Aggregation objects for ratop -m / racluster.
local -a _agg_objects
_agg_objects=(
  none srcid smac dmac soui doui smpls dmpls svlan dvlan
  saddr daddr matrix proto sport dport stos dtos sttl dttl
  stcpb dtcpb inode sco dco sas das ias
)

case $service in
  ratop)
    _arguments -s -S \
      $_ra_common \
      '-m+[aggregation object]:obj:('"${_agg_objects[*]}"')' \
      '-M+[mode options]:mode:(correct nocorrect preserve nopreserve norep rmon nocurses)' \
      '*:filter expression:' && ret=0
    ;;
  ralabel)
    _arguments -s -S \
      $_ra_common \
      '-f+[label-strategy specification file]:file:_files' \
      '-M+[simple address-list mode address]:addr:' \
      '-m+[IANA address labeling target (default saddr,daddr)]:which:(saddr daddr saddr,daddr)' \
      '*:filter expression:' && ret=0
    ;;
  rasort)
    _arguments -s -S \
      $_ra_common \
      '*-m+[sort field (repeatable; stime is default)]:field:('"${_sort_fields[*]}"')' \
      '-M+[rasort mode (replace = overwrite input file in place)]:mode:(replace)' \
      '*:filter expression:' && ret=0
    ;;
  racount)
    _arguments -s -S \
      $_ra_common \
      '-M+[racount mode: protocol count breakdown or address summary]:mode:(proto addr)' \
      '*:filter expression:' && ret=0
    ;;
  rasplit)
    _arguments -s -S \
      $_ra_common \
      '-M+[split mode (size/count/time-based partitioning)]:mode:' \
      '*:filter expression:' && ret=0
    ;;
  *)
    _arguments -s -S \
      $_ra_common \
      '*:filter expression (BPF-style; see tcpdump):' && ret=0
    ;;
esac

return ret
