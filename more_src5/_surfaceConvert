#compdef surfaceConvert
# Documentation: https://cfd.direct/openfoam/user-guide/
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/surface/surfaceConvert — convert surface between file formats (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[OpenFOAM case directory]:dir:_files -/' \
    '-fileHandler+[file handler]:handler:(uncollated collated masterUncollated)' \
    '-noFunctionObjects[disable function objects]' \
    '-clean[perform surface checking/cleanup]' \
    '-group[reorder faces into per-region groups]' \
    '-scale+[scaling factor]:factor:_default' \
    '-writePrecision+[write precision]:label:_default' \
    '1:input surface:_files -g "*.{stl,obj,nas,vtk,off,gts,inp}"' \
    '2:output surface:_files' \
    && ret=0

return ret
