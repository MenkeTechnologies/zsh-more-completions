#compdef sfinterleave
# Documentation: http://www.ahay.org/RSF/sfinterleave.html
# Source: ahay/src system/main/interleave.c — interleave multiple RSF datasets along an axis.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'axis=[axis along which to interleave (default 3)]: :_default' \
    '*:RSF file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
