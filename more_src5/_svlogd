#compdef svlogd
# Documentation: http://smarden.org/runit/svlogd.8.html
# Reference accessed: 2026-05-29

_arguments -s \
  '-tt[prefix each line with tai64n timestamp]' \
  '-ttt[prefix each line with ISO 8601 timestamp]' \
  '-v[verbose]' \
  '-r[raw, do not add missing newlines]' \
  '-R[raw, do not strip trailing carriage returns]' \
  '*:log directory:_directories'
