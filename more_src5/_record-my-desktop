#compdef record-my-desktop
# _record-my-desktop — recordmydesktop desktop session recorder CLI alias (recordmydesktop team, C); custom argparse
# upstream: https://github.com/rocketnia/recordmydesktop

_record-my-desktop() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-x+[x offset]:n:' \
        '-y+[y offset]:n:' \
        '--width=+[width]:n:' \
        '--height=+[height]:n:' \
        '--display=+[display]:str:' \
        '--windowid=+[window id]:str:' \
        '--use-jack=+[ports]:str:' \
        '--freq=+[frequency hz]:n:' \
        '--channels=+[channels]:n:' \
        '--device=+[device]:str:' \
        '--full-shots[take a full shot every frame]' \
        '--fps=+[frames per second]:n:' \
        '--no-sound[no sound]' \
        '--no-cursor[no cursor]' \
        '--no-frame[no frame]' \
        '--no-encode[no encode]' \
        '--no-wm-check[no wm check]' \
        '--on-the-fly-encoding[encode on the fly]' \
        '--quick-subsampling[quick subsampling]' \
        '--scrshot-fps=+[fps]:n:' \
        '--shared-jack-data[shared jack data]' \
        '--use-shm[use shared memory]' \
        '--workdir=+[dir]:dir:_files -/' \
        '-o+[output file]:file:_files -g "*.ogv"' \
        '--output=+[output file]:file:_files -g "*.ogv"' \
        '--compress-cache[compress cache]' \
        '--v-quality=+[0-63]:n:' \
        '--s-quality=+[-1 to 10]:n:' \
        '--v-bitrate=+[bitrate]:n:' \
        '--s-bitrate=+[bitrate]:n:' \
        '--delay=+[seconds]:n:' \
        '--rescue=+[dir]:dir:_files -/' \
        '--overwrite[overwrite]' \
        '--no-shared[no shared memory]' \
        '--use-buffer=+[bytes]:n:' \
        '--mit-shm-attach-thresh=+[bytes]:n:' \
        '--dummy-cursor=+[mode]:str:' \
        '--pause-shortcut=+[shortcut]:str:' \
        '--stop-shortcut=+[shortcut]:str:' \
        '*:arg:'
}

_record-my-desktop "$@"
