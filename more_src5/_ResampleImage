#compdef ResampleImage
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/ResampleImage.cxx — resample image to a new size/spacing (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:imageDimension:(2 3 4)' \
    '2:inputImage:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3:outputImage:_files' \
    '4:MxNxO (output size or spacing):_default' \
    '5::size=1,spacing=0:(0,0 1,0 0,1 1,1)' \
    '6::interpolation type:(0 1 2 3 4)' \
    '7::pixeltype:(0 1 2 3 4 5 6)' \
    && ret=0

return ret
