#compdef rooteventselector
# Documentation: https://github.com/root-project/root/blob/master/main/python/rooteventselector.py
# Source: root-project/root main/python/rooteventselector.py — copy a range of events between ROOT trees.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(-c --compress)'{-c+,--compress=}'[compression factor for destination]:factor:_default' \
    '--recreate[recreate the destination file]' \
    '(-f --first)'{-f+,--first=}'[first event to copy (1-based)]:n:_default' \
    '(-l --last)'{-l+,--last=}'[last event to copy]:n:_default' \
    '(-s --selection)'{-s+,--selection=}'[selection expression]:expr:_default' \
    '*'{-i+,--branchinclude=}'[only write matching branches]:pattern:_default' \
    '*'{-e+,--branchexclude=}'[exclude matching branches]:pattern:_default' \
    '1:source file:tree:_default' \
    '2:destination file:_files -g "*.root(-.)"' \
    && ret=0

return ret
