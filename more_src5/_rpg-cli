#compdef rpg-cli
# Documentation: https://github.com/facundoolano/rpg-cli
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above lists the subcommands.

local -a commands
commands=(
  'cd:move the hero to a directory'
  'pwd:print the hero current location'
  'ls:search for hidden treasure in the current directory'
  'class:change the player character class'
  'stat:display item or character information'
  'reset:create a new hero with randomized stats'
  'use:consume an item (e.g. potion)'
  'buy:purchase items from the shop'
  'todo:show active quests'
)

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'rpg-cli command' commands && ret=0 ;;
  args)
    case $line[1] in
      cd|ls) _arguments '*:dir:_directories' && ret=0 ;;
      use|stat|buy) _arguments '*:item' && ret=0 ;;
    esac ;;
esac

return ret
