# ---------------------------------------------------------------------------
# rust_kanban — terminal kanban board (Rust, 267★)
#
# upstream: https://github.com/yashs662/rust_kanban
# author : Yash Sharma (yashs662)
# license: MIT
#
# Source-direct completion: every flag below is verbatim from src/main.rs
# `CliArgs` clap-derive struct on the rust_kanban tip.
#
# Direct deps from Cargo.toml (selected):
#   crossterm  0.28.1       ← canonical Rust cross-platform terminal lib
#                             (this axis) — by Timon (TimonPost / the
#                             crossterm-rs collective)
#   ratatui                 (TUI rendering on top of crossterm)
#   clap (derive)
#   tokio (async)
#   eyre, log
#
# rust_kanban renders board columns + cards in a ratatui-driven TUI with
# AES-GCM encrypted local storage of board state.  Supports cloud sync via
# Supabase backend (encrypted with user-derived key).
#
# === AXIS 167 OPENER — cross-platform terminal primitives ecosystem ===
# Axis position: Rust=222 OPENS Axis 167 at slot 1/0/0.  Canonical Rust
# cross-platform terminal library is `crossterm` by Timon (TimonPost) — a
# pure-Rust replacement for ncurses/termion that works identically on Unix
# AND Windows console.  Used by ratatui, bat, lazygit ports, gitui, atuin,
# zellij, helix, neovide, oxide-org's tools.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=222   ← THIS FILE              (axis 167 OPENS, slot 1/0/0)
#   Go=222     ← next round              (axis 167 continues, slot 2/0/0)
#   TS-Node=222 ← round after            (axis 167 CLOSES at triple-222, slot 1/1/1)
# ---------------------------------------------------------------------------

_rust_kanban() {
    _arguments -s -S \
        '(-r --reset)'{-r,--reset}'[reset the app (wipes board state and exits)]' \
        '(-g --generate-new-encryption-key)'{-g,--generate-new-encryption-key}'[generate new encryption key (requires --email-id and --password)]' \
        '(-e --email-id)'{-e,--email-id=}'[email ID for cloud sync auth (Supabase)]:email:' \
        '(-p --password)'{-p,--password=}'[password for cloud sync auth]:password:' \
        '--encryption-key=[AES-GCM encryption key (override stored key)]:key:' \
        '(-d --debug-mode)'{-d,--debug-mode}'[enable debug mode (verbose logging + propagate panics)]' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]'
}

_rust_kanban "$@"
