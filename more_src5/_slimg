autoload -U is-at-least

_slimg() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_slimg_commands" \
"*::: :->slimg" \
&& ret=0
    case $state in
    (slimg)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:slimg-command-$line[1]:"
        case $line[1] in
            (convert)
_arguments "${_arguments_options[@]}" : \
'-f+[Output format]:FORMAT:(jpeg png webp avif jxl qoi)' \
'--format=[Output format]:FORMAT:(jpeg png webp avif jxl qoi)' \
'-q+[Encoding quality (0-100)]:QUALITY:_default' \
'--quality=[Encoding quality (0-100)]:QUALITY:_default' \
'-o+[Output path (file or directory)]:OUTPUT:_files' \
'--output=[Output path (file or directory)]:OUTPUT:_files' \
'-j+[Number of parallel jobs (defaults to CPU count)]:JOBS:_default' \
'--jobs=[Number of parallel jobs (defaults to CPU count)]:JOBS:_default' \
'--recursive[Process subdirectories recursively]' \
'-h[Print help]' \
'--help[Print help]' \
':input -- Input file or directory:_files' \
&& ret=0
;;
(optimize)
_arguments "${_arguments_options[@]}" : \
'-q+[Encoding quality (0-100)]:QUALITY:_default' \
'--quality=[Encoding quality (0-100)]:QUALITY:_default' \
'-o+[Output path (file or directory)]:OUTPUT:_files' \
'--output=[Output path (file or directory)]:OUTPUT:_files' \
'-j+[Number of parallel jobs (defaults to CPU count)]:JOBS:_default' \
'--jobs=[Number of parallel jobs (defaults to CPU count)]:JOBS:_default' \
'--overwrite[Overwrite original file]' \
'--recursive[Process subdirectories recursively]' \
'-h[Print help]' \
'--help[Print help]' \
':input -- Input file or directory:_files' \
&& ret=0
;;
(resize)
_arguments "${_arguments_options[@]}" : \
'--width=[Target width in pixels]:WIDTH:_default' \
'--height=[Target height in pixels]:HEIGHT:_default' \
'--scale=[Scale factor (e.g. 0.5 for half size)]:SCALE:_default' \
'-f+[Output format (defaults to input format)]:FORMAT:(jpeg png webp avif jxl qoi)' \
'--format=[Output format (defaults to input format)]:FORMAT:(jpeg png webp avif jxl qoi)' \
'-q+[Encoding quality (0-100)]:QUALITY:_default' \
'--quality=[Encoding quality (0-100)]:QUALITY:_default' \
'-o+[Output path]:OUTPUT:_files' \
'--output=[Output path]:OUTPUT:_files' \
'-h[Print help]' \
'--help[Print help]' \
':input -- Input file:_files' \
&& ret=0
;;
(crop)
_arguments "${_arguments_options[@]}" : \
'(--aspect)--region=[Crop region\: x,y,width,height (e.g. 100,50,800,600)]:REGION:_default' \
'(--region)--aspect=[Aspect ratio\: width\:height (e.g. 16\:9, 1\:1)]:ASPECT:_default' \
'-f+[Output format (defaults to input format)]:FORMAT:(jpeg png webp avif jxl qoi)' \
'--format=[Output format (defaults to input format)]:FORMAT:(jpeg png webp avif jxl qoi)' \
'-q+[Encoding quality (0-100)]:QUALITY:_default' \
'--quality=[Encoding quality (0-100)]:QUALITY:_default' \
'-o+[Output path (file or directory)]:OUTPUT:_files' \
'--output=[Output path (file or directory)]:OUTPUT:_files' \
'-j+[Number of parallel jobs (defaults to CPU count)]:JOBS:_default' \
'--jobs=[Number of parallel jobs (defaults to CPU count)]:JOBS:_default' \
'--recursive[Process subdirectories recursively]' \
'--overwrite[Overwrite existing files]' \
'-h[Print help]' \
'--help[Print help]' \
':input -- Input file or directory:_files' \
&& ret=0
;;
(extend)
_arguments "${_arguments_options[@]}" : \
'(--size)--aspect=[Aspect ratio\: width\:height (e.g. 1\:1, 16\:9)]:ASPECT:_default' \
'(--aspect)--size=[Target size\: WIDTHxHEIGHT (e.g. 1920x1080)]:SIZE:_default' \
'(--transparent)--color=[Fill color as hex (e.g. '\''#FFFFFF'\'', '\''000000'\''). Default\: white]:COLOR:_default' \
'-f+[Output format (defaults to input format)]:FORMAT:(jpeg png webp avif jxl qoi)' \
'--format=[Output format (defaults to input format)]:FORMAT:(jpeg png webp avif jxl qoi)' \
'-q+[Encoding quality (0-100)]:QUALITY:_default' \
'--quality=[Encoding quality (0-100)]:QUALITY:_default' \
'-o+[Output path (file or directory)]:OUTPUT:_files' \
'--output=[Output path (file or directory)]:OUTPUT:_files' \
'-j+[Number of parallel jobs (defaults to CPU count)]:JOBS:_default' \
'--jobs=[Number of parallel jobs (defaults to CPU count)]:JOBS:_default' \
'(--color)--transparent[Use transparent background (for formats with alpha support)]' \
'--recursive[Process subdirectories recursively]' \
'--overwrite[Overwrite existing files]' \
'-h[Print help]' \
'--help[Print help]' \
':input -- Input file or directory:_files' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_slimg__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:slimg-help-command-$line[1]:"
        case $line[1] in
            (convert)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(optimize)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(resize)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(crop)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(extend)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_slimg_commands] )) ||
_slimg_commands() {
    local commands; commands=(
'convert:Convert image to a different format with compression' \
'optimize:Optimize image in the same format (reduce file size)' \
'resize:Resize image with optional format conversion' \
'crop:Crop image with optional format conversion' \
'extend:Extend image by adding padding with optional format conversion' \
'completions:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'slimg commands' commands "$@"
}
