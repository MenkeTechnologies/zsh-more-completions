#compdef smartctl
# _smartctl-bin — smartmontools SMART control & monitor (Bruce Allen, Christian Franke, et al, C++); device health + self-test queries for ATA/SCSI/NVMe
# upstream: https://github.com/smartmontools/smartmontools

_smartctl-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-i --info)'{-i,--info}'[show identity]' \
        '(-g --get)'{-g,--get}'+[get setting]:setting:(aam apm lookahead security wcache rcache wcreorder wcache-sct)' \
        '(-s --set)'{-s,--set}'+[set setting]:setting:' \
        '(-a --all)'{-a,--all}'[print SMART data + attrs]' \
        '(-x --xall)'{-x,--xall}'[extended all]' \
        '--scan[scan for devices]' \
        '--scan-open[scan with open]' \
        '(-d --device)'{-d,--device}'+[device type]:type:(ata scsi nvme sat usbjmicron usbsunplus usbcypress sat,N marvell raid raid,N areca,N areca,N/E)' \
        '(-T --tolerance)'{-T,--tolerance}'+[error tolerance]:level:(normal conservative permissive verypermissive)' \
        '(-b --badsum)'{-b,--badsum}'+[behavior on bad checksum]:behavior:(warn exit ignore)' \
        '(-r --report)'{-r,--report}'+[report]:level:(ioctl ataioctl scsiioctl nvmeioctl)' \
        '(-n --nocheck)'{-n,--nocheck}'+[skip if standby]:mode:(never sleep standby idle)' \
        '(-c --capabilities)'{-c,--capabilities}'[print SMART capabilities]' \
        '(-l --log)'{-l,--log}'+[show log]:log:(error selftest selective directory background xerror xselftest scterc scttempsts scttemphist scttempint sctstatus sataphy sasphy sasphy,reset gplog,N smartlog,N nvmelog,N,size)' \
        '(-H --health)'{-H,--health}'[show health status]' \
        '(-A --attributes)'{-A,--attributes}'[show SMART attributes]' \
        '(-f --format)'{-f,--format}'+[format]:fmt:(old brief hex,id hex,val)' \
        '(-v --vendorattribute)'{-v,--vendorattribute}'+[vendor attr]:str:' \
        '(-F --firmwarebug)'{-F,--firmwarebug}'+[firmware bug]:bug:' \
        '(-P --presets)'{-P,--presets}'+[presets]:val:(use ignore show showall)' \
        '(-B --drivedb)'{-B,--drivedb}'+[drive db]:file:_files' \
        '(-t --test)'{-t,--test}'+[run test]:test:(offline short long conveyance pending select selective vendor force afterselect afterselect,off,on selective,N afterselect,off afterselect,on)' \
        '(-C --captive)'{-C,--captive}'[captive (foreground) test]' \
        '(-X --abort)'{-X,--abort}'[abort test]' \
        '--smart+[smart on/off]:bool:(on off)' \
        '--offlineauto+[offline auto-collect]:bool:(on off)' \
        '--saveauto+[autosave attributes]:bool:(on off)' \
        '--json+[json output]:mode:(c o v y)' \
        '*:device:_files'
}

_smartctl-bin "$@"
