#compdef R-CMD-LINK
# _R-CMD-LINK — R Core Team R CMD LINK link C C++ Fortran object files with R libraries to create executable (rcore team, C); getopt
# upstream: https://cran.r-project.org/

_R-CMD-LINK() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-o+[output file]:file:_files' \
        '-l+[library]:str:' \
        '-L+[lib dir]:dir:_files -/' \
        '-I+[include dir]:dir:_files -/' \
        '-D+[macro]:str:' \
        '*:object file:_files -g "*.o *.a *.so *.dylib"'
}

_R-CMD-LINK "$@"
