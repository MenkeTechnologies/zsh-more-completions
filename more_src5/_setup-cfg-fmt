#compdef setup-cfg-fmt
# Documentation: https://github.com/asottile/setup-cfg-fmt
# Reference accessed: 2026-06-04

# Zsh completion for setup-cfg-fmt - Python setup.cfg formatter

_arguments \
    '--min-py3-version[minimum Python 3 version to target]:version (e.g. 3.8)' \
    '--max-py-version[maximum Python version to target]:version (e.g. 3.12)' \
    '--include-version-classifiers[include Python version classifiers]' \
    '(- *)--help[show help message and exit]' \
    '(- *)--version[show version and exit]' \
    '*:file:_files -g "setup.cfg"'
