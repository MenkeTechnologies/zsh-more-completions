#compdef svg-sprite
# ---------------------------------------------------------------------------
# svg-sprite — SVG sprites & stacks galore — a low-level Node.js module
#               that takes a bunch of SVG files, optimizes them, and bakes
#               them into SVG sprites of five different types (CSS / view /
#               defs / symbol / stack) along with optional stylesheet
#               resources (CSS, Sass, LESS, Stylus) (TypeScript/Node.js,
#               1,988★)
#
# upstream: https://github.com/svg-sprite/svg-sprite
# author : Joschi Kuphal (jkphl, joschi@kuphal.net)
# license: MIT
# npm    : `svg-sprite`
#
# Source-direct completion: every flag below is verbatim from bin/config.
# yaml on the svg-sprite/svg-sprite tip — yargs-generated dynamically
# from the YAML schema by bin/svg-sprite.js's `addOption(name, option)`
# recursive walker.  The schema defines a nested option tree (e.g.
# `shape.id.separator` → `--shape-id-separator`); this completion
# documents the top-level modes + their primary toggles + key common
# flags.  For per-mode option detail (e.g. `--css-render-css-template`,
# `--symbol-prefix`), pair with `svg-sprite --help`.
#
# Direct deps from package.json (selected):
#   @resvg/resvg-js   ^2.6.2  ← canonical TypeScript/Node.js SVG renderer
#                              (this axis) — by Yevhenii Reizner
#                              (RazrFalcon); WASM port of his Rust resvg
#                              + usvg crates packaged as native-binding
#                              Node modules + WASM fallback for browsers
#                              / edge runtimes.  Pixel-identical output
#                              to the Rust mmdr / vello / lyon pipeline
#                              since the WASM bytes are compiled from
#                              the same Rust source.  Used by svg-sprite
#                              for raster fallback rendering of generated
#                              sprites + example documents.
#   svgo              ^3.3.2   (the SVG OptimizerO project — pure-JS SVG
#                              optimizer; runs as a `shape.transform`
#                              transformer by default)
#   js-yaml + lodash.merge + glob + vinyl  (Joschi's preferred stack
#                              for templating + plumbing)
#   yargs                     (CLI argv parsing)
#
# svg-sprite reads SVG source files (file/glob/dir), optimizes each via
# svgo, then bakes them into one of five sprite output styles:
#   - CSS sprite — image-based sprite with stylesheet (.svg + .css/.scss/
#     .less/.styl)
#   - view sprite — fragment-identifier addressable (#shape-name)
#   - defs sprite — collection of <defs> for <use> references
#   - symbol sprite — collection of <symbol> elements (the modern default)
#   - stack sprite — clean :target-based stack
# Multiple modes can be activated simultaneously; each emits to its own
# subdirectory under `--dest`.
#
# ============================================================================
# === AXIS 179 CLOSES — pure-language SVG renderers/generators =============
# === TRIPLE-234 ROUND-NUMBER LANDMARK · 172nd AXIS CLOSED =================
# ============================================================================
# Axis position: TS-Node=234 CLOSES Axis 179 at slot 1/1/1 — quadruple-clean
# closure of the canonical pure-language SVG-processing ecosystem spanning
# the three major systems languages.  All three lanes anchor on a single
# library by a single recognized maintainer that processes SVG (render,
# generate, optimize, or sprite) without shelling out to a headless
# Chrome / librsvg / Cairo / Inkscape:
#
#     Rust    : resvg + usvg              by Yevhenii Reizner
#                                          (RazrFalcon/resvg); pure-Rust
#                                          SVG 1.1 parser + renderer
#                                          rasterizing via tiny-skia.
#                                          Companion crates ttf-parser
#                                          + fontdb cover font shaping;
#                                          all by the same author.
#                 → mmdr (1jehuang — fast Mermaid diagram renderer in
#                          pure Rust; renders Mermaid syntax to SVG or
#                          PNG via resvg+usvg pipeline with no browser
#                          dependency; claimed 100-1400× faster than
#                          mermaid-cli; 23 diagram types supported;
#                          1369★ MIT v0.2.2)
#                 _mmdr            [Rust=234 OPENED Axis 179, slot 1/0/0]
#
#     Go      : ajstarks/svgo + nikolaydubina/treemap
#                                  Anthony Starks (ajstarks) wrote svgo,
#                                  the canonical pure-Go SVG writer;
#                                  Nikolay Dubina (nikolaydubina) wrote
#                                  the treemap library that powers
#                                  go-cover-treemap and go-binsize-
#                                  treemap.  Where Rust's lane is
#                                  RENDERING-focused, Go's lane is
#                                  GENERATION-focused — emit SVG markup
#                                  directly from typed data without
#                                  dragging in librsvg/Cairo.
#                 → go-cover-treemap (Nikolay Dubina nikolaydubina —
#                                     generate heat treemaps from Go
#                                     cover profiles as SVG; pipe-
#                                     friendly `go-cover-treemap
#                                     -coverprofile cover.out > out.svg`;
#                                     each rectangle is file/directory
#                                     sized by statement count colored
#                                     by coverage percentage; sibling
#                                     go-binsize-treemap does same for
#                                     `go tool nm` output; 594★ MIT)
#                 _go-cover-treemap  [Go=234 CONTINUED Axis 179, 2/0/0]
#
#     JS/Node : @resvg/resvg-js + svgo    Yevhenii Reizner's WASM port of
#                                          his own Rust resvg crate
#                                          (pixel-identical output since
#                                          WASM is compiled from the same
#                                          Rust source) + the canonical
#                                          pure-JS SVG optimizer svgo
#                                          by the svg/svgo team (Andrey
#                                          Sitnik + Bogdan Chadkin + others
#                                          at the svgo collective).
#                 → svg-sprite (Joschi Kuphal jkphl — low-level Node.js
#                                module taking SVG files optimizing via
#                                svgo and baking into sprites of five
#                                types CSS/view/defs/symbol/stack with
#                                optional stylesheet resources CSS/Sass/
#                                LESS/Stylus; @resvg/resvg-js for raster
#                                fallback rendering of generated sprites
#                                + example documents; 1988★ MIT)
#                 _svg-sprite       [TS-Node=234 CLOSES Axis 179, 1/1/1]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#                 The JS lane has both halves of the SVG stack — render
#                 (resvg-js) + optimize (svgo) — which together make
#                 svg-sprite's full sprite-baking pipeline possible.
#                 The lane is unique among the three in that one of its
#                 canonical libs (@resvg/resvg-js) is literally compiled
#                 from the same Rust source as the Rust lane's resvg —
#                 the only axis in the corpus where the JS and Rust
#                 lanes share build-byte-identical implementations.
#
# Round-number 234 landmark fires simultaneously across all three lanes:
# Rust completion #234 (_mmdr) + Go completion #234 (_go-cover-treemap)
# + TS-Node completion #234 (_svg-sprite) = triple-234.  Axis #172
# closed in the lifetime of the corpus — every pure-language SVG
# rendering / generation / optimization library in the three big
# systems languages now has both a representative consumer completion
# AND a documented axis closure landmark; the lanes are tied together
# by a common design discipline (in-process SVG processing without
# shelling out to headless Chrome / librsvg / Cairo / Inkscape).
# ============================================================================

_svg-sprite() {
    _arguments -s -S \
        '(- *)'{-h,--help}'[display help information]' \
        '(- *)--version[print version]' \
        '(-D --dest)'{-D,--dest=}'[main output directory (base path; default .)]:directory:_files -/' \
        '(-C --config)'{-C,--config=}'[path to external JSON config file]:JSON config:_files -g "*.(json|JSON)"' \
        '(-l --log)'{-l,--log=}'[logging verbosity (default info)]:verbosity:(info verbose debug)' \
        '(-w --shape-dim-width)'{-w,--shape-dim-width=}'[maximum shape width in pixels (default 2000)]:pixels:' \
        '(-h --shape-dim-height)'--shape-dim-height='[maximum shape height in pixels (default 2000)]:pixels:' \
        '(-p --shape-spacing-padding)'{-p,--shape-spacing-padding=}'[padding around shape (up to 4× comma-separated; default 0,0,0,0)]:padding:' \
        '(-b --shape-spacing-box)'{-b,--shape-spacing-box=}'[box sizing strategy (default content)]:strategy:(content padding icon)' \
        '(-m --shape-meta)'{-m,--shape-meta=}'[path to YAML file with meta information]:meta YAML:_files -g "*.(yaml|yml|YAML|YML)"' \
        '(-a --shape-align)'{-a,--shape-align=}'[path to YAML file with alignment information]:align YAML:_files -g "*.(yaml|yml|YAML|YML)"' \
        '(--ims --shape-dest)'{--ims=,--shape-dest=}'[path to output directory for intermediate SVG files]:dir:_files -/' \
        '--shape-transform=[comma-separated list of predefined transformers (default svgo)]:transformers:(svgo)' \
        '--svg-xmldecl[include an XML declaration in SVG files (default true)]' \
        '--svg-doctype[include a doctype declaration in SVG files (default true)]' \
        '--svg-namespace-ids[apply ID namespacing to the sprite (default true)]' \
        '--svg-namespace-classnames[apply CSS class namespacing to the sprite (default true)]' \
        '--svg-dimattrs[add width and height attributes to the sprite (default true)]' \
        '--svg-precision=[floating-point precision for CSS positioning values (default -1)]:precision:' \
        '(-c --css)'{-c,--css}'[activate the «css» mode — image-based sprite + stylesheet]' \
        '(--cl --css-layout)'{--cl=,--css-layout=}'[CSS sprite layout]:layout:(vertical horizontal diagonal packed)' \
        '(--cs --css-sprite)'{--cs=,--css-sprite=}'[CSS sprite output filename]:filename:' \
        '(--ccss --css-render-css)'{--ccss,--css-render-css}'[render CSS stylesheet for the CSS sprite]' \
        '(--cscss --css-render-scss)'{--cscss,--css-render-scss}'[render Sass (SCSS) stylesheet]' \
        '(--cless --css-render-less)'{--cless,--css-render-less}'[render LESS stylesheet]' \
        '(--cstyl --css-render-styl)'{--cstyl,--css-render-styl}'[render Stylus stylesheet]' \
        '(--cx --css-example)'{--cx,--css-example}'[render an HTML example document for the CSS sprite]' \
        '(-v --view)'{-v,--view}'[activate the «view» mode — fragment-identifier addressable sprite]' \
        '(--vl --view-layout)'{--vl=,--view-layout=}'[view sprite layout]:layout:(vertical horizontal diagonal packed)' \
        '(--vs --view-sprite)'{--vs=,--view-sprite=}'[view sprite output filename]:filename:' \
        '(--vcss --view-render-css)'{--vcss,--view-render-css}'[render CSS stylesheet for the view sprite]' \
        '(--vscss --view-render-scss)'{--vscss,--view-render-scss}'[render Sass stylesheet]' \
        '(--vless --view-render-less)'{--vless,--view-render-less}'[render LESS stylesheet]' \
        '(--vstyl --view-render-styl)'{--vstyl,--view-render-styl}'[render Stylus stylesheet]' \
        '(--vx --view-example)'{--vx,--view-example}'[render an HTML example document]' \
        '(-d --defs)'{-d,--defs}'[activate the «defs» mode — <defs> collection for <use> refs]' \
        '(--ds --defs-sprite)'{--ds=,--defs-sprite=}'[defs sprite output filename]:filename:' \
        '(--di --defs-inline)'{--di,--defs-inline}'[inline defs sprite into HTML example]' \
        '(--dx --defs-example)'{--dx,--defs-example}'[render an HTML example document]' \
        '(-s --symbol)'{-s,--symbol}'[activate the «symbol» mode — <symbol> collection (modern default)]' \
        '(--ss --symbol-sprite)'{--ss=,--symbol-sprite=}'[symbol sprite output filename]:filename:' \
        '(--si --symbol-inline)'{--si,--symbol-inline}'[inline symbol sprite into HTML example]' \
        '(--sx --symbol-example)'{--sx,--symbol-example}'[render an HTML example document]' \
        '(-S --stack)'{-S,--stack}'[activate the «stack» mode — clean :target-based stack]' \
        '(--Ss --stack-sprite)'{--Ss=,--stack-sprite=}'[stack sprite output filename]:filename:' \
        '(--Sx --stack-example)'{--Sx,--stack-example}'[render an HTML example document]' \
        '--variables=[path to external JSON file with Mustache variable definitions]:JSON:_files -g "*.(json|JSON)"' \
        '*:SVG input files (file/glob/dir):_files -g "*.(svg|SVG)"'
}

_svg-sprite "$@"
