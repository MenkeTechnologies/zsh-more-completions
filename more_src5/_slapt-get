#compdef slapt-get
# slapt-get — APT-like package manager for Slackware

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--update[update package cache]' \
  '--upgrade[upgrade installed packages]' \
  '--dist-upgrade[upgrade to newer Slackware version]' \
  '--install[install packages]:*:package:' \
  '--install-set[install a package set]:set:' \
  '--remove[remove packages]:*:package:' \
  '--search[search for packages]:query:' \
  '--list[list available packages]' \
  '--installed[list installed packages]' \
  '--clean[clean package cache]' \
  '--autoclean[remove packages no longer in sources]' \
  '--show[show package details]:package:' \
  '--filelist[show file list for a package]:package:' \
  '--re[treat --search and --list as regex]' \
  '(-d --download-only)'{-d,--download-only}'[download only, do not install]' \
  '(-s --simulate)'{-s,--simulate}'[simulate, do not actually install]' \
  '--no-prompt[do not prompt for confirmation]' \
  '-y[assume yes to all prompts]' \
  '--prompt[always prompt]' \
  '--reinstall[reinstall packages]' \
  '--ignore-excludes[ignore excludes in config]' \
  '--no-md5[skip MD5 verification]' \
  '--ignore-dep[skip dependency resolution]' \
  '--no-dep[alias for --ignore-dep]' \
  '--print-uris[print URIs instead of downloading]' \
  '--show-stats[show download stats]' \
  '--config=[alternate config file]:file:_files' \
  '--retry=[retry failed downloads N times]:n:' \
  '--no-upgrade[do not upgrade, only install new]' \
  '--allow-unauthenticated[allow unauthenticated packages]' \
  && ret=0

return ret
