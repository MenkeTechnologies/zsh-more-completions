#compdef scala3
# Documentation: https://scala-cli.virtuslab.org/docs/reference/commands
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (Scala 3 launcher dispatches to scala-cli).

# scala3: Scala 3 launcher (scala-cli)
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'compile:compile Scala code'
  'run:compile and run Scala code'
  'test:compile and test Scala (or Java) code'
  'package:compile and package Scala code'
  'repl:fire up a Scala REPL'
  'console:fire up a Scala REPL (alias)'
  'fmt:format Scala code'
  'new:create a new project from a giter8 template'
  'doc:generate Scaladoc documentation'
  'version:print version'
  'setup-ide:generate BSP file for IDE'
  'shebang:run a shebang-style script'
  'publish:publish artifacts to Maven repositories'
  'fix:run Scalafix rules'
  'export:export project to sbt/Mill/JSON'
  'clean:clean the workspace'
  'config:configure global settings'
  'help:show help'
  'install:install completions'
  'uninstall:uninstall scala-cli'
  'update:update scala-cli'
)
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'scala3 command' commands && ret=0 ;;
  args) _files && ret=0 ;;
esac
return ret
