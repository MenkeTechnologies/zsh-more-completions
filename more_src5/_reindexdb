#compdef reindexdb
# Documentation: reindexdb --help (PostgreSQL)
# Source: reindex a PostgreSQL database / table / index.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-?,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    {-a,--all}'[reindex all databases]' \
    '--concurrently[reindex concurrently]' \
    {-d+,--dbname=}'[database name]:db:' \
    {-e,--echo}'[show commands sent to server]' \
    '*'{-i+,--index=}'[recreate specific index]:index:' \
    {-j+,--jobs=}'[concurrent connections]:n:' \
    {-q,--quiet}'[no messages]' \
    {-s,--system}'[system catalogs only]' \
    '*'{-S+,--schema=}'[reindex schemas]:schema:' \
    '*'{-t+,--table=}'[reindex tables]:table:' \
    '--tablespace=[tablespace where indexes are rebuilt]:tablespace:' \
    {-v,--verbose}'[verbose output]' \
    {-h+,--host=}'[server host/socket]:host:_hosts' \
    {-p+,--port=}'[server port]:port:_ports' \
    {-U+,--username=}'[user name]:user:_users' \
    {-w,--no-password}'[never prompt for password]' \
    {-W,--password}'[force password prompt]' \
    '--maintenance-db=[alternate maintenance database]:db:' \
    ':dbname:' \
    && ret=0

return ret
