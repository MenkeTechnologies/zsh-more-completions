#compdef setkeycodes
# _setkeycodes — Linux kbd setkeycodes (set the kernel scancode->keycode mapping for the Linux input layer; takes pairs of "scancode keycode" arguments in hex; scancodes ≥ e000 are AT-style escaped scancodes; companion to getkeycodes(8))
# upstream: https://github.com/legionus/kbd
# Argument shape from kbd src/setkeycodes.c on tip.

_setkeycodes() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '*:scancode keycode pair:'
}

_setkeycodes "$@"
