#compdef rootprint
# Documentation: https://github.com/root-project/root/blob/master/main/python/rootprint.py
# Source: root-project/root main/python/rootprint.py — print histograms/graphs from ROOT files to image files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(-d --directory)'{-d+,--directory=}'[output subdirectory]:dir:_directories' \
    '--divide=[canvas layout (cols,rows)]:layout:_default' \
    '(-D --draw)'{-D+,--draw=}'[draw options]:opts:_default' \
    '(-f --format)'{-f+,--format=}'[output format]:format:(pdf png ps eps svg jpg)' \
    '(-o --output)'{-o+,--output=}'[merge into single file (ps/pdf only)]:file:_files' \
    '(-s --size)'{-s+,--size=}'[canvas dimensions WxH]:size:_default' \
    '(-S --style)'{-S+,--style=}'[C file defining custom style]:file:_files -g "*.[Cc](-.)"' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-r --recursive)'{-r,--recursive}'[traverse directories recursively]' \
    '*:source ROOT file or object path:_files -g "*.root(-.)"' \
    && ret=0

return ret
