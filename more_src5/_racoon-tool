#compdef racoon-tool
# _racoon-tool — Debian racoon-tool Perl wrapper CLI for managing IPSec connections with racoon IKE daemon providing connection up/down restart reload show and SPD/SAD inspection (debian team, Perl); getopt
# upstream: https://packages.debian.org/sid/racoon-tool

_racoon-tool() {
    local -a sub=(
        'start:start IKE daemon'
        'stop:stop IKE daemon'
        'restart:restart IKE daemon'
        'reload:reload config'
        'reload-force:reload force'
        'reload-conf:reload only config'
        'check:check config'
        'status:show status'
        'show:show config'
        'add:add connection'
        'del:remove connection'
        'add-secret:add psk'
        'del-secret:remove psk'
        'vshow:verbose show'
        'sashow:show SAD'
        'spdshow:show SPD'
        'showspi:show spi'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[conf file]:file:_files -g "*.conf racoon-tool.conf"' \
        '--conf=+[conf file]:file:_files -g "*.conf racoon-tool.conf"' \
        '-d[debug]' \
        '--debug[debug]' \
        '-n[dry run]' \
        '--dry-run[dry run]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'racoon-tool subcommand' sub ;;
        args)
            case $words[1] in
                add|del|add-secret|del-secret|showspi) _arguments '*:peer connection:' ;;
            esac
            ;;
    esac
}

_racoon-tool "$@"
