#compdef serial-stress
# _serial-stress — serial-stress CLI for the serial-port stress generator producing high-throughput transmit-receive load patterns measuring CPU utilisation buffer overruns frame errors break-detection thresholds (linux team, C); getopt
# upstream: https://github.com/serial-stress/serial-stress

_serial-stress() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-p+[port]:file:_files -g "/dev/tty* /dev/cu*"' \
        '--port=+[port]:file:_files -g "/dev/tty* /dev/cu*"' \
        '-b+[baud]:n:(9600 19200 38400 57600 115200 230400 460800 921600 1500000 2000000)' \
        '--baud=+[baud]:n:(9600 19200 38400 57600 115200 230400 460800 921600 1500000 2000000)' \
        '-d+[duration sec]:n:' \
        '--duration=+[duration sec]:n:' \
        '-t+[threads]:n:' \
        '--threads=+[threads]:n:' \
        '-r+[rate bps]:n:' \
        '--rate=+[rate bps]:n:' \
        '-S+[buffer size]:n:' \
        '--buffer-size=+[buffer size]:n:' \
        '-l+[loopback peer]:file:_files -g "/dev/tty* /dev/cu*"' \
        '--loopback=+[loopback peer]:file:_files -g "/dev/tty* /dev/cu*"' \
        '-i+[interval ms]:n:' \
        '--interval=+[interval ms]:n:' \
        '-P+[pattern]:p:(seq random alternating all-ones all-zeros)' \
        '--pattern=+[pattern]:p:(seq random alternating all-ones all-zeros)' \
        '--rx-only[receive only]' \
        '--tx-only[transmit only]' \
        '--full-duplex[full duplex]' \
        '--no-color[no color]' \
        '--log-file=+[file]:file:_files' \
        '--csv[csv output]'
}

_serial-stress "$@"
