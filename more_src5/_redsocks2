#compdef redsocks2 redsocks
# _redsocks2 — semigodking redsocks2 transparent socket-redirector through SOCKS5/HTTPS/Shadowsocks/UDP fork of redsocks (semigodking team, C); custom argparse
# upstream: https://github.com/semigodking/redsocks

_redsocks2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-c+[config file]:file:_files -g "redsocks.conf *.conf"' \
        '--config=+[config file]:file:_files -g "redsocks.conf *.conf"' \
        '-t[test config and exit]' \
        '--test[test config and exit]' \
        '-p+[pid file]:file:_files' \
        '--pid=+[pid file]:file:_files' \
        '-d[run as daemon]' \
        '--daemon[run as daemon]' \
        '-l+[log file]:file:_files' \
        '--log=+[log file]:file:_files' \
        '-s+[log level]:l:(0 1 2 3 4 5 6 7)' \
        '--log-level=+[log level]:l:(0 1 2 3 4 5 6 7)' \
        '-D[no daemonize]' \
        '--no-daemon[no daemonize]'
}

_redsocks2 "$@"
