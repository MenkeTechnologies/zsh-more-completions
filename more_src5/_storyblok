#compdef storyblok
# _storyblok — Storyblok CMS CLI (storyblok/storyblok-cli)
# upstream: https://github.com/storyblok/storyblok-cli
# Subcommands & flags from src/cli.ts and src/constants.js (commander).

_storyblok() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-s --space)'{-s+,--space=}'[Storyblok space ID]:space:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'login:log in to the Storyblok API'
                'logout:log out of the Storyblok API'
                'user:show the currently logged-in user'
                'select:choose a working space'
                'spaces:list spaces'
                'quickstart:bootstrap a Storyblok project'
                'scaffold:scaffold a new component'
                'pull-components:download components schema as JSON'
                'push-components:upload components schema to a space'
                'delete-component:delete a single component'
                'delete-components:bulk-delete components from a source'
                'pull-languages:download space languages schema'
                'sync:sync content/types between spaces'
                'import:import content from a JSON/CSV file'
                'generate-migration:scaffold a migration script'
                'run-migration:execute a migration script'
                'rollback-migration:revert a migration'
                'delete-datasources:bulk-delete datasources'
                'generate-typescript-typedefs:generate TS typings from components'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                login)
                    _arguments \
                        '(-t --token)'{-t+,--token=}'[OAuth token (skip prompt)]:token:' \
                        '(-r --region)'{-r+,--region=}'[Storyblok region]:region:(eu us ap ca cn)'
                    ;;
                pull-components)
                    _arguments \
                        '--sf[separate components into individual files]' \
                        '(-p --path)'{-p+,--path=}'[output directory]:dir:_files -/' \
                        '(-f --file-name)'{-f+,--file-name=}'[filename override]:name:' \
                        '-ppn[prefix preset names with component name]' \
                        '--rd[resolve datasource fields]'
                    ;;
            esac
            ;;
    esac
}

_storyblok "$@"
