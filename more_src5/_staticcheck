#compdef staticcheck
# Documentation: https://staticcheck.dev/docs/running-staticcheck/cli/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '-checks[comma-separated list of checks to enable]:checks:' \
  '-explain[show documentation for a check]:check:' \
  {-f,--format}'[output format]:format:(text json stylish)' \
  '-fail[comma-separated list of checks that can cause non-zero exit]:checks:' \
  '-tags[build tags]:tags:' \
  '-tests[include tests]' \
  '-debug.*[debug flags]' \
  '-go[target Go version]:version:' \
  '-matrix[run analysis in matrix mode]' \
  '-merge[merge results from multiple packages]' \
  '-show-ignored[show ignored diagnostics]' \
  '-version[show version]' \
  '-help[show help]' \
  '*:package:_files -/'
