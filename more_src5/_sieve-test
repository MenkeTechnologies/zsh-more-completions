#compdef sieve-test
# Documentation: man sieve-test(1)
# Source: dovecot/pigeonhole src/sieve-tools/sieve-test.c (main) — execute Sieve script against a mail file (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a+[original recipient address]:address:_default' \
    '-c+[Dovecot config file]:file:_files' \
    '-C[only compile, do not execute]' \
    '-D[show parser/code debug info]' \
    '-d+[dump compiled binary to file]:file:_files' \
    '-e[execute even with parse errors]' \
    '-f+[envelope sender]:from:_default' \
    '-l+[mail location URL]:loc:_default' \
    '-m+[default mailbox]:mailbox:_default' \
    '*-P+[plugin to load]:plugin:_default' \
    '-r+[recipient address]:address:_default' \
    '-s+[additional script file]:file:_files -g "*.sieve"' \
    '-t+[trace output file]:file:_files' \
    '*-T+[trace option key=value]:opt:_default' \
    '-x+[enabled extensions]:exts:_default' \
    '1:script file:_files -g "*.sieve"' \
    '2:mail file:_files' \
    && ret=0

return ret
