#compdef reg_tools
# Documentation: https://github.com/KCL-BMEIS/niftyreg
# Source: KCL-BMEIS/niftyreg reg-apps/reg_tools.cpp — NIfTI image utility (C++; single-dash long opts).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(- *)-help[show help]' \
    '(- *)-v[print version]' \
    '(- *)-version[print version]' \
    '(-omp --omp)'{-omp+,--omp=}'[OpenMP threads]:n:_default' \
    '(-in --in)'{-in+,--in=}'[input image]:file:_files -g "*.{nii,nii.gz,hdr,img}"' \
    '(-out --out)'{-out+,--out=}'[output image]:file:_files' \
    '(-add --add)'{-add+,--add=}'[add image/value]:operand:_default' \
    '(-sub --sub)'{-sub+,--sub=}'[subtract image/value]:operand:_default' \
    '(-mul --mul)'{-mul+,--mul=}'[multiply image/value]:operand:_default' \
    '(-div --div)'{-div+,--div=}'[divide image/value]:operand:_default' \
    '(-iso --iso)'{-iso,--iso}'[create isotropic image]' \
    '(-rms --rms)'{-rms+,--rms=}'[print RMS difference with image]:file:_files' \
    '(-down --down)'{-down,--down}'[downsample image (by 2)]' \
    '(-float --float)'{-float,--float}'[store output as float]' \
    '(-smoS --smoS)'{-smoS+,--smoS=}'[spline-based smoothing]:n:_default' \
    '(-smoG --smoG)'{-smoG+,--smoG=}'[Gaussian smoothing]:n:_default' \
    '(-smoL --smoL)'{-smoL+,--smoL=}'[label-aware smoothing]:n:_default' \
    '-smoM+[mean smoothing radius]:n:_default' \
    '(-bin --bin)'{-bin,--bin}'[binarise output (>0)]' \
    '(-thr --thr)'{-thr+,--thr=}'[threshold value]:n:_default' \
    '(-nan --nan)'{-nan+,--nan=}'[replace value by NaN]:n:_default' \
    && ret=0

return ret
