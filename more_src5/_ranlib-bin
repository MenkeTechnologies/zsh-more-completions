#compdef ranlib
# _ranlib-bin — GNU binutils ranlib; generate an index for an ar archive (same as ar s)
# upstream: https://sourceware.org/binutils

_ranlib-bin() {
    _arguments \
        '(-D --deterministic)'{-D,--deterministic}'[deterministic mode]' \
        '(-U --no-deterministic)'{-U,--no-deterministic}'[disable deterministic mode]' \
        '(-t --touch)'{-t,--touch}'[update timestamp]' \
        '(-v --verbose -V --version)'{-v,--verbose,-V,--version}'[verbose / version]' \
        '(-h --help)'{-h,--help}'[show help]' \
        '--plugin+[load plugin]:plugin:' \
        '--target+[BFD target]:target:' \
        '*:archive:_files -g "*.a"'
}

_ranlib-bin "$@"
