#compdef strfry
# Documentation: https://github.com/hoytech/strfry
# Source: hoytech/strfry src/apps/ — nostr relay implementation (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _strfry_cmds
_strfry_cmds=(
    'relay:run the relay'
    'scan:scan database for events matching a filter'
    'export:export events from the database'
    'import:import events into the database'
    'delete:delete events from the database'
    'info:show database statistics'
    'compact:compact the database'
    'dict:build / inspect compression dictionary'
    'monitor:monitor events as they arrive'
    'negentropy:run negentropy reconciliation operations'
    'sync:sync events with another relay'
    'stream:stream events from another relay'
    'router:run the strfry-router (mesh router)'
    'download:download events from another relay'
    'upload:upload events to another relay'
)

_arguments -C \
    '--config=[config file path]:file:_files -g "*.conf"' \
    '(-h --help)'{-h,--help}'[show help]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'strfry command' _strfry_cmds && ret=0
        ;;
esac

return ret
