#compdef rakudo2 raku2 perl6_2
# _rakudo2 — Larry Wall Patrick Michaud Rakudo Raku rakudo2 CLI command-line frontend wrapping the Rakudo reference implementation of the Raku programming language formerly called Perl 6 written in NQP and Raku originally Patrick Michaud now Rakudo team backed by MoarVM JVM runtime supports concurrency Grammar Junctions Roles Multi-Dispatch Gradual Typing Lazy Lists MAIN multi sub-named-arguments Slurpy Rationals BigInts Cool Pair Bag Set Mix native types perl-style sigils sigils Larry Wall Damian Conway -e -E -I -c --doc --target --optimize --profile --tracing --rakudo-home --output --help --version --ll-exception (Larry Wall Patrick Michaud Rakudo Raku team, NQP/Raku); custom argparse
# upstream: https://rakudo.org/

_rakudo2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c[check syntax]' \
        '-e+[expression]:str:' \
        '*-e+[expression]:str:' \
        '-E+[no autoprint]:str:' \
        '*-E+[no autoprint]:str:' \
        '-I+[include path]:dir:_files -/' \
        '*-I+[include path]:dir:_files -/' \
        '-M+[module]:str:' \
        '*-M+[module]:str:' \
        '-n[non-print loop]' \
        '-p[print loop]' \
        '-a[autosplit]' \
        '-F+[regex]:str:' \
        '-l+[record separator]:str:' \
        '*-l+[record separator]:str:' \
        '-0+[octal value]:str:' \
        '-x+[script dir]:dir:_files -/' \
        '-T[taint mode]' \
        '-W+[warnings]:str:' \
        '-w[warnings]' \
        '-X+[experimental]:str:' \
        '--doc=+[backend]:str:' \
        '--doc[generate doc]' \
        '--target=+[t]:t:(parse ast optimize mast moar mbc js)' \
        '--rakudo-home=+[dir]:dir:_files -/' \
        '--optimize=+[level]:n:(off 0 1 2 3)' \
        '--profile[profile]' \
        '--profile-filename=+[file]:file:_files' \
        '--profile-kind=+[k]:k:(instrumented heap calls)' \
        '--profile-stage=+[s]:str:' \
        '--ll-exception[low-level exception]' \
        '--full-cleanup[full cleanup]' \
        '--debug-port=+[port]:n:' \
        '--debug-suspend[debug suspend]' \
        '--tracing=+[t]:str:' \
        '--compile-only[compile only]' \
        '--output=+[file]:file:_files' \
        '-o+[output]:file:_files' \
        '--show-cores[show cores]' \
        '--repl-mode=+[m]:m:(interactive non-interactive)' \
        '--rakudo-bin-path=+[dir]:dir:_files -/' \
        '--encoding=+[enc]:str:' \
        '--container[container]' \
        '--container-build=+[bld]:str:' \
        '*:raku file:_files -g "*.raku *.p6 *.pm6 *.pl *.pl6 *.pm *.t *.rakumod *.rakutest"'
}

_rakudo2 "$@"
