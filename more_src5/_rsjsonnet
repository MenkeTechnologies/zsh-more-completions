#compdef rsjsonnet
# _rsjsonnet — Rust port of the Jsonnet data templating language (eduardosm/rsjsonnet)
# upstream: https://github.com/eduardosm/rsjsonnet
# Flags from rsjsonnet/src/cli.rs (clap).

_rsjsonnet() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-e --exec)'{-e,--exec}'[treat filename as inline code]' \
        '*'{-J+,--jpath=}'[additional library search dir]:dir:_files -/' \
        '(-o --output-file)'{-o+,--output-file=}'[write to file rather than stdout]:file:_files' \
        '(-m --multi)'{-m+,--multi=}'[write multiple files to dir, list on stdout]:dir:_files -/' \
        '(-y --yaml-stream)'{-y,--yaml-stream}'[emit YAML stream of JSON documents]' \
        '(-S --string)'{-S,--string}'[expect string, manifest as plain text]' \
        '--no-trailing-newline[no trailing newline in output]' \
        '(-s --max-stack)'{-s+,--max-stack=}'[max allowed stack frames]:n:' \
        '(-t --max-trace)'{-t+,--max-trace=}'[max stack trace length]:n:' \
        '*'{-V+,--ext-str=}'[external variable as string (var[=val])]:var=val:' \
        '*--ext-str-file=[external variable as string from file]:var=file:' \
        '*--ext-code=[external variable as code (var[=code])]:var=code:' \
        '*--ext-code-file=[external variable as code from file]:var=file:' \
        '*'{-A+,--tla-str=}'[top-level argument as string (var[=val])]:var=val:' \
        '*--tla-str-file=[top-level arg as string from file]:var=file:' \
        '*--tla-code=[top-level arg as code (var[=code])]:var=code:' \
        '*--tla-code-file=[top-level arg as code from file]:var=file:' \
        '1:input file (or - for stdin):_files -g "*.(jsonnet|libsonnet)"'
}

_rsjsonnet "$@"
