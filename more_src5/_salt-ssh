#compdef salt-ssh
# _salt-ssh — SaltStack salt-ssh (agentless transport: opens SSH connections to each target in roster, ships a tarball, runs salt-call on the remote; --roster picks the roster backend, -r raw shell, -i ignore host keys, --key-deploy ships the master key)
# upstream: https://github.com/saltstack/salt (salt/cli/ssh.py)
# Flags from salt cli/ssh.py on tip.

_salt-ssh() {
    _arguments \
        '--version[show version]' \
        '-h[show help]' \
        '-c+[config dir]:dir:_files -/' \
        '-r[raw shell command]' \
        '--raw-shell[raw shell command]' \
        '-i[ignore host keys]' \
        '--ignore-host-keys[ignore host keys]' \
        '-w[wipe runtime dir]' \
        '--wipe[wipe runtime dir]' \
        '-W[always wipe]' \
        '--rand-thin-dir[randomize thin dir]' \
        '--key-deploy[deploy ssh key]' \
        '--roster+[roster backend]:backend:(flat scan cache cloud ansible clustershell)' \
        '--roster-file+[file]:file:_files' \
        '--priv+[private key file]:file:_files' \
        '--priv-passwd+[private key passwd]:passwd:' \
        '--user+[ssh user]:user:_users' \
        '--passwd+[ssh password]:passwd:' \
        '--askpass[ask password]' \
        '--sudo[use sudo]' \
        '--sudo-user+[sudo user]:user:_users' \
        '-t+[timeout]:seconds:' \
        '--max-procs+[max parallel]:n:' \
        '-E[treat target as PCRE]' \
        '-L[treat target as list]' \
        '-G[treat target as grain]' \
        '-N[treat target as nodegroup]' \
        '-C[treat target as compound]' \
        '--output+[output format]:format:(yaml json nested key pprint highstate progress newline_values_only txt)' \
        '--no-color[disable colors]' \
        '1:target:' \
        '2:function:' \
        '*::arg:'
}

_salt-ssh "$@"
