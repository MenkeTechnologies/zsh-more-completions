#compdef scorep
# _scorep — Score-P HPC measurement infrastructure (TU Dresden + Jülich); instrumentation wrapper for MPI/OpenMP/CUDA profiling + tracing
# upstream: https://www.vi-hps.org/projects/score-p

_scorep() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--verbose=+[verbosity]:n:' \
        '--config=+[config file]:file:_files' \
        '--user[user instrumentation]' \
        '--nouser[no user instrumentation]' \
        '--cuda[CUDA instrumentation]' \
        '--nocuda[no CUDA]' \
        '--opencl[OpenCL instrumentation]' \
        '--noopencl[no OpenCL]' \
        '--openacc[OpenACC instrumentation]' \
        '--noopenacc[no OpenACC]' \
        '--mpp=+[mpp variant]:variant:(none mpi shmem)' \
        '--thread=+[thread model]:model:(none omp pthread)' \
        '--compiler[compiler instrumentation]' \
        '--nocompiler[no compiler instrumentation]' \
        '--pdt[PDT instrumentation]' \
        '--nopdt[no PDT]' \
        '--cobi[binary rewrite]' \
        '--memory[memory tracking]' \
        '--io=+[IO wrapper]:variant:(none posix)' \
        '--instrument-filter=+[filter file]:file:_files' \
        '--keep-files[keep temporary files]' \
        '--dry-run[print commands without executing]' \
        '*::command:_command_names -e'
}

_scorep "$@"
