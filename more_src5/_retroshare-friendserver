#compdef retroshare-friendserver
# _retroshare-friendserver — RetroShare friend-server discovery daemon (RetroShare/RetroShare)
# upstream: https://github.com/RetroShare/RetroShare
# Flags from retroshare-friendserver/src/retroshare-friendserver.cc (argstream).

_retroshare-friendserver() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-c --base-dir)'{-c+,--base-dir=}'[base directory for keys and data]:dir:_files -/' \
        '(-t --tor-executable)'{-t+,--tor-executable=}'[absolute path for tor executable]:file:_command_names -e' \
        '(-v --verbose)'{-v,--verbose}'[display additional debug information]'
}

_retroshare-friendserver "$@"
