#compdef samu
# Documentation: https://man.archlinux.org/man/samu.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-C+[change to directory before building]:directory:_directories' \
  '-f+[specify build file]:build file:_files' \
  '-j+[number of parallel jobs]:jobs' \
  '-k+[keep going until N failures]:failures' \
  '-n[dry run, do not execute commands]' \
  '-t+[invoke a subtool]:tool:(clean commands compdb graph query targets)' \
  '-v[verbose output, show full commands]' \
  '-d+[debug mode]:mode:(explain keepdepfile keeprsp)' \
  '-w+[warning flag]:warning:(dupbuild=err dupbuild=warn)' \
  '-l+[load average limit]:load' \
  '*:target' && ret=0

return ret
