#compdef rbldns
# _rbldns — djbdns rbldns (DNS-blocklist server; serves a flat list of CIDR ranges from data.cdb (compiled by rbldns-data) under the $BASE domain so RBL clients can look up reverse-IP names)
# upstream: https://github.com/dterweij/ndjbdns
# Flags from server.c on tip (shared with tinydns/dnscache/axfrdns); requires $BASE env var pointing at the DNSBL base name.

_rbldns() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version and exit]' \
        '-c+[config file path]:file:_files' \
        '-d+[debug level]:n:' \
        '-D[daemonize]' \
        '-l+[log file path]:file:_files' \
        '-p+[pid file path]:file:_files' \
        '-P+[server port (default 53)]:port:'
}

_rbldns "$@"
