#compdef supertokens
# Documentation: https://supertokens.com
# Reference accessed: 2026-05-21
# Verified: upstream CLI subcommand list (start/stop/list/uninstall/update/load-license)
# could not be re-fetched from a stable URL during this audit pass.
# STUB: keep minimal subcommand routing without claiming flag-level accuracy.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'start:start the core'
  'stop:stop the core'
  'list:list running cores'
  'uninstall:uninstall'
  'update:update SuperTokens'
  'load-license:load license'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:_default' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'supertokens subcommand' subcommands && ret=0
    ;;
esac

return ret
