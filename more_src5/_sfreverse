#compdef sfreverse
# Documentation: http://www.ahay.org/RSF/sfreverse.html
# Source: ahay/src system/main/reverse.c — reverse one or more axes in the data hypercube.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'which=[axes-to-reverse bitmask (0=none, sum of powers of 2)]: :_default' \
    'memsize=[max RAM (MB)]: :_default' \
    'opt=[update reversed-axis params (y=update, i=ignore, n=negate)]: :(y i n)' \
    'verb=[(y/n) verbose]: :(y n)' \
    '*:RSF file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
