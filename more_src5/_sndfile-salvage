#compdef sndfile-salvage
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/sndfile-salvage.1.html
# Reference accessed: 2026-05-21
# Verified: Ubuntu jammy sndfile-salvage(1) manpage. No flags; usage
# is `sndfile-salvage <broken WAV> <fixed W64>`.

local -a arguments

arguments=(
    '1:broken WAV file:_files -g "*.wav"'
    '2:output W64 file:_files'
)

_arguments -s -S $arguments
