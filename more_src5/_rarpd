#compdef rarpd
# Documentation: man rarpd(8)
# Source: dgibson/iputils rarpd.c (master) — Reverse ARP daemon (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[listen on all interfaces]' \
    '-A[also listen for ARP packets]' \
    '*-d[debug (stackable)]' \
    '*-v[verbose (stackable)]' \
    '-o[allow off-link replies]' \
    '-e[only consult /etc/ethers]' \
    '-b+[tftp directory]:dir:_files -/' \
    '1::interface:_net_interfaces' \
    && ret=0

return ret
