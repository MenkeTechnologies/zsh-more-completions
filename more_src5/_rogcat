#compdef rogcat
# Documentation: https://github.com/flxo/rogcat
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for rogcat - adb logcat wrapper

local curcontext="$curcontext" state line ret=1
local -a subcommands
subcommands=(
  'bugreport:capture bugreport (Android < 7)'
  'clear:clear logd buffers'
  'completions:generate shell completions'
  'devices:list available devices'
  'log:add log messages to buffer'
  'help:print help'
)

_arguments -s -S -C \
  '(- *)--help[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--bright-colors[use intense colors]' \
  '(-d --dump)'{-d,--dump}'[dump log and exit]' \
  '--ffx[use ffx log instead of adb logcat]' \
  '--hide-timestamp[hide timestamp]' \
  '(-L --last)'{-L,--last}'[dump logs prior to last reboot]' \
  '--no-dimm[use white as dim color]' \
  '--overwrite[overwrite output file if present]' \
  '--restart[restart command on exit]' \
  '--show-date[show month and day]' \
  '(-b --buffer)'{-b+,--buffer=}'[select logd buffers]:buffer' \
  '--color=[terminal coloring]:when:(auto always never)' \
  '(-s --serial)'{-s+,--serial=}'[adb device serial]:serial' \
  '(-a --filename-format)'{-a+,--filename-format=}'[output file naming]:fmt' \
  '(-f --filter)*'{-f+,--filter=}'[regex filter]:regex' \
  '--format=[output format]:fmt:(csv html human json raw)' \
  '(-H --head)'{-H+,--head=}'[read n records and exit]:n' \
  '(-h --highlight)*'{-h+,--highlight=}'[highlight matching patterns]:pattern' \
  '(-i --input)*'{-i+,--input=}'[read from file or serial port]:input:_files' \
  '(-l --level)'{-l+,--level=}'[minimum log level]:level' \
  '(-m --message)*'{-m+,--message=}'[message filter]:regex' \
  '(-M --Message)*'{-M+,--Message=}'[case-insensitive message filter]:regex' \
  '(-o --output)'{-o+,--output=}'[write output to file]:file:_files' \
  '(-p --profile)'{-p+,--profile=}'[select profile]:profile' \
  '(-n --records-per-file)'{-n+,--records-per-file=}'[records per file]:n' \
  '(-t --tag)*'{-t+,--tag=}'[tag filter]:regex' \
  '(-T --Tag)*'{-T+,--Tag=}'[case-insensitive tag filter]:regex' \
  '--tail=[dump most recent N lines]:n' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'rogcat command' subcommands && ret=0 ;;
esac
return ret
