#compdef rwallformats rwcompare rwip2cc rwipaexport rwipaimport rwpdedupe rwpdu2silk rwpmatch rwptoflow rwtotal mapsid
# Documentation: upstream tools.netsa.cert.org/silk/ man pages
# Reference accessed: 2026-05-30 via WebFetch of rw{compare,total,
# ip2cc,ipa{ex,im}port,p{dedupe,du2silk,match,toflow}}.html and
# mapsid.html.
# CERT NetSA SiLK R91 — 11-stem multi-binary harvest completing the
# R90 SiLK deferred queue. Existing coverage: _rwfilter (8 stems),
# _rwcut (8 stems from R90), _rwaggbag, _rwappend, _rwflowpack,
# _rwipfix2silk, _rwsetbuild. Adds the remaining auxiliary tools.

local curcontext="$curcontext" state line ret=1

# Shared SiLK common options (subset used across these tools).
local -a _silk_io
_silk_io=(
  '--no-titles[suppress column headers]'
  '--no-columns[disable fixed-width columnar output]'
  '--column-separator=[column delimiter (default |)]:char:'
  '--no-final-delimiter[omit separator after final column]'
  '--delimited=[shorthand for --no-columns with custom delimiter]:char:'
  '--output-path=[write output to file/pipe]:file:_files'
  '--pager=[paging command]:cmd:'
  '--site-config-file=[read SiLK site config from file]:file:_files'
  '--compression-method=[output compression]:method:(none zlib lzo1x snappy best)'
  '--xargs=[read input filenames from file (or stdin)]:file:_files'
  '*--note-add=[add annotation text (repeatable)]:text:'
  '*--note-file-add=[add annotation from file (repeatable)]:file:_files'
  '--note-strip[do not copy notes from input]'
  '--invocation-strip[omit command-line history from output]'
  '--print-filenames[print input filenames to stderr]'
  '--copy-input=[duplicate input records to this path]:file:_files'
)

case $service in

  rwallformats)
    # Write a test SiLK file in every supported record format/version.
    _arguments -s -S \
      $_silk_io \
      '--basename=[output filename basename]:basename:' \
      '*:SiLK flow file:_files' \
      '(- *)--help[show help]' \
      '(- *)--version[show version]' && ret=0
    ;;

  rwcompare)
    # Compare two SiLK flow files for equality.
    _arguments -s -S \
      '--quiet[do not print messages if files differ or fail to open]' \
      '--site-config-file=[read SiLK site config from file]:file:_files' \
      '(- *)--help[show help]' \
      '(- *)--version[show version]' \
      '1:first file (or stdin/-):_files' \
      '2:second file (or stdin/-):_files' && ret=0
    ;;

  rwip2cc)
    # Map IP addresses to country codes. DEPRECATED since SiLK 3.0
    # — use rwpmaplookup(1) instead.
    _arguments -s -S \
      '(--address --input-file)--address=[look up country code for a single IP]:ip:' \
      '(--address --input-file)--input-file=[read IPs from file (- or stdin for stdin)]:file:_files' \
      '--map-file=[custom country-code prefix-map file]:file:_files' \
      '--print-ips=[control IPs in output]:value:(0 1)' \
      '--integer-ips[output IPs as integers]' \
      '--zero-pad-ips[output canonical IPs with zero-padding]' \
      '--no-columns[disable fixed-width columnar output]' \
      '--column-separator=[column delimiter]:char:' \
      '--no-final-delimiter[omit trailing separator]' \
      '--delimited=[delimited output mode]:char:' \
      '--output-path=[output path]:file:_files' \
      '--pager=[pager command]:cmd:' \
      '(- *)--help[show help]' \
      '(- *)--version[show version]' && ret=0
    ;;

  rwipaexport)
    # Export an IPA catalog to a SiLK IPset or prefix-map file.
    _arguments -s -S \
      '--catalog=[IPA catalog name to export from]:catalog:' \
      '--time=[active timestamp (YYYY/MM/DD[\:HH[\:MM[\:SS]]])]:time:' \
      '--prefix-map-name=[map-name to write in prefix-map header]:name:' \
      '*--note-add=[add annotation text (repeatable)]:text:' \
      '*--note-file-add=[add annotation from file (repeatable)]:file:_files' \
      '--compression-method=[output compression]:method:(none zlib lzo1x snappy best)' \
      '(- *)--help[show help]' \
      '(- *)--version[show version]' && ret=0
    ;;

  rwipaimport)
    # Import SiLK IP collections into an IPA catalog.
    _arguments -s -S \
      '--catalog=[IPA catalog name to import into (required)]:catalog:' \
      '--description=[catalog contents description]:text:' \
      '--start-time=[valid time range start (YYYY/MM/DD[\:HH[\:MM[\:SS]]])]:time:' \
      '--end-time=[valid time range end (YYYY/MM/DD[\:HH[\:MM[\:SS]]])]:time:' \
      '(- *)--help[show help]' \
      '(- *)--version[show version]' \
      '*:IP collection file:_files' && ret=0
    ;;

  rwpdedupe)
    # Drop duplicate packets from one or more tcpdump capture files.
    _arguments -s -S \
      '(--first-duplicate --random-duplicate)--first-duplicate[always choose the earliest-timestamp packet]' \
      '(--first-duplicate --random-duplicate)--random-duplicate=[choose a random duplicate (optional seed)]:seed:' \
      '--threshold=[time window for duplicate detection (ms, 0-1000000)]:ms:' \
      '(- *)--help[show help]' \
      '(- *)--version[show version]' \
      '*:tcpdump capture file:_files -g "*.(pcap|cap|dump)"' && ret=0
    ;;

  rwpdu2silk)
    # Convert NetFlow v5 PDU records to SiLK Flow format.
    _arguments -s -S \
      '--silk-output=[output SiLK file]:file:_files' \
      '--print-statistics[print record counts to stderr]' \
      '--log-destination=[log destination]:dest:' \
      '*--log-flags=[log flags (repeatable)]:flag:(all bad default missing record-timestamps)' \
      '*--note-add=[add annotation text (repeatable)]:text:' \
      '*--note-file-add=[add annotation from file (repeatable)]:file:_files' \
      '--compression-method=[output compression]:method:(none zlib lzo1x snappy best)' \
      '--xargs=[read input filenames from file]:file:_files' \
      '(- *)--help[show help]' \
      '(- *)--version[show version]' \
      '*:NetFlow v5 PDU file:_files' && ret=0
    ;;

  rwpmatch)
    # Match packets from a tcpdump file against a SiLK flow file.
    _arguments -s -S \
      '--flow-file=[SiLK flow file determining which packets to output (required)]:file:_files' \
      '--msec-compare[compare timestamps at millisecond precision]' \
      '--ports-compare[also compare src/dst ports for TCP/UDP]' \
      '(- *)--help[show help]' \
      '(- *)--version[show version]' \
      '1:tcpdump input file (or stdin):_files -g "*.(pcap|cap|dump)"' && ret=0
    ;;

  rwptoflow)
    # Generate SiLK flow records from tcpdump packet capture data.
    _arguments -s -S \
      '*--plugin=[load custom plugin .so file]:file:_files' \
      '--active-time=[ignore packets outside time range]:range:' \
      '--flow-output=[write flow records to file]:file:_files' \
      '--packet-pass-output=[save packets used for flow generation]:file:_files' \
      '--packet-reject-output=[save rejected packets]:file:_files' \
      '--reject-all-fragments[skip fragmented packets entirely]' \
      '--reject-incomplete[skip packets lacking protocol data]' \
      '--set-sensorid=[set sensor ID for all flows]:id:' \
      '--compression-method=[output compression]:method:(none zlib lzo1x snappy best)' \
      '--print-statistics[print processing summary]' \
      '(- *)--help[show help]' \
      '(- *)--version[show version]' \
      '*:tcpdump capture file:_files -g "*.(pcap|cap|dump)"' && ret=0
    ;;

  rwtotal)
    # Compute per-bin totals (records, bytes, packets) for one of
    # 17 keying schemes (IP prefix slices, ports, proto, etc.).
    _arguments -s -S \
      $_silk_io \
      '--sip-first-8[key by first 8 bits of source IP]' \
      '--sip-first-16[key by first 16 bits of source IP]' \
      '--sip-first-24[key by first 24 bits of source IP]' \
      '--sip-last-8[key by last 8 bits of source IP]' \
      '--sip-last-16[key by last 16 bits of source IP]' \
      '--dip-first-8[key by first 8 bits of destination IP]' \
      '--dip-first-16[key by first 16 bits of destination IP]' \
      '--dip-first-24[key by first 24 bits of destination IP]' \
      '--dip-last-8[key by last 8 bits of destination IP]' \
      '--dip-last-16[key by last 16 bits of destination IP]' \
      '--sport[key by source port]' \
      '--dport[key by destination port]' \
      '--proto[key by protocol]' \
      '--packets[key by packet count]' \
      '--bytes[key by byte count]' \
      '--duration[key by record duration]' \
      '--icmp-code[key by ICMP type+code]' \
      '--summation[add a total row]' \
      '--min-bytes=[exclude bins below threshold]:N:' \
      '--max-bytes=[exclude bins above threshold]:N:' \
      '--min-packets=[exclude bins below threshold]:N:' \
      '--max-packets=[exclude bins above threshold]:N:' \
      '--min-records=[exclude bins below threshold]:N:' \
      '--max-records=[exclude bins above threshold]:N:' \
      '--skip-zeroes[omit zero-traffic bins]' \
      '(- *)--help[show help]' \
      '(- *)--version[show version]' \
      '*:SiLK flow file:_files' && ret=0
    ;;

  mapsid)
    # Map sensor names to IDs and vice versa (from silk.conf).
    _arguments -s -S \
      '--print-classes[show data collection classes per sensor]' \
      '--print-descriptions[show sensor descriptions from silk.conf]' \
      '--site-config-file=[SiLK site config file]:file:_files' \
      '(- *)--help[show help]' \
      '(- *)--version[show version]' \
      '*:sensor name or ID:' && ret=0
    ;;

esac

return ret
