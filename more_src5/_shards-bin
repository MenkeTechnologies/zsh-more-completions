#compdef shards
# _shards-bin — Crystal Shards dependency manager (Manas Technology Solutions, Crystal); fetch/install Crystal libraries
# upstream: https://github.com/crystal-lang/shards

_shards-bin() {
    local -a sub=(
        'build:build executables'
        'check:check installed deps'
        'init:initialize shard.yml'
        'install:install dependencies'
        'list:list installed shards'
        'lock:lock dependency versions'
        'outdated:list outdated deps'
        'prune:remove unused shards'
        'show:show shard tree'
        'update:update dependencies'
        'version:show project version'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--no-color[no color]' \
        '--production[production mode]' \
        '--frozen[frozen lockfile]' \
        '--local[use local cache only]' \
        '--global[install globally]' \
        '--ignore-crystal-version[ignore crystal version]' \
        '--skip-postinstall[skip postinstall scripts]' \
        '--skip-executables[skip executables]' \
        '--without-development[without dev deps]' \
        '--with-development[with dev deps]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'shards subcommand' sub ;;
    esac
}

_shards-bin "$@"
