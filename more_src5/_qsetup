#compdef qsetup
# _qsetup — PBS qsetup (one-shot post-install helper that wires the PBS server, scheduler and mom services and sets up the default queue layout; --pbsserver host name, --pbsmother host name, --client-only client-only setup, --no-default-queue skip default queue creation, --pbsexec exec path override)
# upstream: https://github.com/openpbs/openpbs
# Flags from openpbs src/cmds/qsetup on tip.

_qsetup() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--pbsserver+[server host]:host:_hosts' \
        '--pbsmother+[mother host]:host:_hosts' \
        '--client-only[client only]' \
        '--no-default-queue[skip default queue]' \
        '--pbsexec+[exec path]:dir:_files -/'
}

_qsetup "$@"
