#compdef sar-cli
# _sar-cli — sysstat sar collect, report or save system activity CLI alias (sysstat team, C); custom argparse
# upstream: https://github.com/sysstat/sysstat

_sar-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--human[human readable]' \
        '--version[show version]' \
        '-V[show version]' \
        '-A[show all reports]' \
        '-B[paging stats]' \
        '-b[I/O stats]' \
        '-C[show comments]' \
        '-c[task creation stats]' \
        '-D[show DEVMAP]' \
        '-d[block device stats]' \
        '--dev=+[devices]:str:' \
        '-e+[end time]:str:' \
        '-F+[mount stats]:m:(MOUNT)' \
        '-f+[file]:file:_files' \
        '--fs[show filesystems]' \
        '--help[show help]' \
        '-H[hugepages]' \
        '-I+[interrupts]:str:' \
        '-i+[interval]:n:' \
        '--iface=+[interfaces]:str:' \
        '-j+[id mode]:m:(LABEL UUID PATH ID)' \
        '-k[kilobytes]' \
        '-m+[power management]:str:' \
        '-M[multi format]' \
        '-n+[network stats]:str:' \
        '-o+[output file]:file:_files' \
        '-P+[cpu]:str:' \
        '-p[print device names]' \
        '-q+[queue stats]:str:' \
        '-r+[memory stats]:str:' \
        '-S[swap stats]' \
        '-s+[start time]:str:' \
        '-t[time stamps]' \
        '-u+[cpu stats]:str:' \
        '-v[file stats]' \
        '-W[swapping stats]' \
        '-w[task switching stats]' \
        '-x+[pid]:pid:_pids' \
        '-y[tty stats]' \
        '-z[hide zero activity]' \
        '*:interval count:'
}

_sar-cli "$@"
