#compdef sndfile-info
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/sndfile-info.1.html
# Reference accessed: 2026-05-21
# Verified: Ubuntu jammy sndfile-info(1) manpage and upstream
# libsndfile/programs/sndfile-info.c. Flags are long-only.
# Removed from prior file: fabricated short -b/-c/-i flags (upstream
# uses --broadcast/--cart/--instrument). Added --channel-map.

local -a arguments

arguments=(
    '--broadcast[display broadcast (BWF) info]'
    '--cart[display cart chunk info]'
    '--channel-map[display channel map]'
    '--instrument[display instrument info]'
    '*:sound file:_files -g "*.{wav,flac,ogg,aiff,aif,au,snd,w64,caf,rf64}"'
)

_arguments -s -S $arguments
