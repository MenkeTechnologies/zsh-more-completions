#compdef snyk
# Documentation: https://docs.snyk.io/developer-tools/snyk-cli/cli-commands-and-options-summary
# Reference accessed: 2026-05-21
# Verified: upstream Snyk CLI commands & options summary.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'auth:authenticate with Snyk'
      'test:test for open-source vulnerabilities and license issues'
      'monitor:create a project snapshot for continuous monitoring'
      'container:test and monitor container images'
      'iac:test infrastructure as code'
      'code:test source code (SAST)'
      'sbom:generate or test software bill of materials'
      'aibom:generate AI model bill of materials (Python)'
      'log4shell:find Log4Shell vulnerabilities'
      'config:manage Snyk CLI config'
      'policy:display .snyk policy for a package'
      'ignore:ignore an issue via .snyk policy'
      'apps:manage Snyk Apps'
      'help:show help for a command'
    )
    _describe -t commands 'snyk command' commands && ret=0
    ;;
  args)
    case $words[1] in
      test)
        _arguments -s -S \
          '--all-projects[test all projects]' \
          '*--exclude=[directories to exclude]:dir' \
          '--dev[include dev dependencies]' \
          '--org=[organization]:org' \
          '--file=[manifest file]:file:_files' \
          '--project-name=[project name]:name' \
          '--severity-threshold=[severity threshold]:severity:(low medium high critical)' \
          '--json[output as JSON]' \
          '--sarif[output as SARIF]' \
          '--json-file-output=[JSON output file]:file:_files' \
          '--sarif-file-output=[SARIF output file]:file:_files' \
          '--policy-path=[custom policy path]:path:_files' \
          '*:path:_files' \
          && ret=0
        ;;
      monitor)
        _arguments -s -S \
          '--all-projects[monitor all projects]' \
          '*--exclude=[directories to exclude]:dir' \
          '--dev[include dev dependencies]' \
          '--org=[organization]:org' \
          '--file=[manifest file]:file:_files' \
          '--project-name=[project name]:name' \
          '*:path:_files' \
          && ret=0
        ;;
      container)
        _arguments -s -S -C \
          '1:subcommand:(test monitor sbom)' \
          '--severity-threshold=[severity threshold]:severity:(low medium high critical)' \
          '--file=[Dockerfile]:file:_files' \
          '--json[output as JSON]' \
          '--sarif[output as SARIF]' \
          '--org=[organization]:org' \
          '*:image' \
          && ret=0
        ;;
      iac)
        _arguments -s -S -C \
          '1:subcommand:(test describe update-exclude-policy)' \
          '--severity-threshold=[severity threshold]:severity:(low medium high critical)' \
          '--json[output as JSON]' \
          '--sarif[output as SARIF]' \
          '--org=[organization]:org' \
          '*:path:_files' \
          && ret=0
        ;;
      code)
        _arguments -s -S -C \
          '1:subcommand:(test)' \
          '--severity-threshold=[severity threshold]:severity:(low medium high critical)' \
          '--json[output as JSON]' \
          '--sarif[output as SARIF]' \
          '--org=[organization]:org' \
          '--include-ignores[include ignored issues]' \
          '--report[upload findings to Snyk]' \
          '--target-name=[custom target name]:name' \
          '*:path:_files' \
          && ret=0
        ;;
      sbom)
        _arguments -s -S -C \
          '1:subcommand:(test)' \
          '--org=[organization]:org' \
          '*:path:_files' \
          && ret=0
        ;;
      auth)
        _arguments -s -S \
          '--auth-type=[auth type]:type' \
          '--client-id=[OAuth client id]:id' \
          '--client-secret=[OAuth client secret]:secret' \
          '1:token' \
          && ret=0
        ;;
      config)
        _arguments -s -S -C \
          '1:subcommand:(set get unset clear environment)' \
          '--no-check[skip pre-checks for environment]' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
