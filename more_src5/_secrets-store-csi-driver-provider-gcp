        '(- *)'{-h,--help}'[show help]' \
        '--kubeconfig=[absolute path to kubeconfig file]:file:_files' \
        '--log-format-json=[emit logs in JSON]:bool:(true false)' \
        '--metrics_addr=[metrics HTTP listener host\:port]:host\:port:' \
        '--enable-pprof=[enable pprof profiling]:bool:(true false)' \
