#compdef surfshark surfshark-vpn
# _surfshark — Surfshark surfshark commercial VPN CLI for managing Surfshark VPN connections server selection multi-hop WireGuard OpenVPN protocol switching CleanWeb kill switch features (Surfshark team, Go); cobra
# upstream: https://surfshark.com/

_surfshark() {
    local -a sub=(
        'login:login to account'
        'logout:logout'
        'status:show connection status'
        'connect:connect to a server'
        'disconnect:disconnect from VPN'
        'list:list servers'
        'protocol:set protocol'
        'multihop:multi-hop connection'
        'static:static IP'
        'killswitch:kill switch operations'
        'cleanweb:CleanWeb operations'
        'autoconnect:autoconnect operations'
        'bypasser:bypasser operations'
        'settings:show or edit settings'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'surfshark subcommand' sub ;;
        args)
            case $words[1] in
                connect) _arguments \
                    '--country=+[code]:str:' \
                    '--city=+[name]:str:' \
                    '--region=+[name]:str:' \
                    '--protocol=+[p]:p:(wireguard openvpn-udp openvpn-tcp ikev2)' \
                    '*:server name:' ;;
                multihop) _arguments \
                    '1:action:(connect list)' \
                    '*:hop config:' ;;
                protocol) _arguments \
                    '1:protocol:(wireguard openvpn-udp openvpn-tcp ikev2)' ;;
                killswitch|cleanweb|autoconnect) _arguments \
                    '1:action:(enable disable status)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_surfshark "$@"
