#compdef qrls
# _qrls-pbs — PBS qrls (release a previously held PBS job so the scheduler can consider it for execution again; -h hold type to release (u user, o operator, s system, n none; default releases all set holds), -t array selector to limit which array indices, -W wait spec; positional argument is the jobID list)
# upstream: https://github.com/openpbs/openpbs
# Flags from openpbs src/cmds/qrls.c on tip.

_qrls-pbs() {
    _arguments \
        '-h+[hold type to release]:type:(u o s n us uo os uos)' \
        '-t+[array selector]:range:' \
        '-W+[wait spec]:wait:' \
        '*:jobID:'
}

_qrls-pbs "$@"
