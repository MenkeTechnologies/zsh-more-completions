#compdef sfcc-ci
# ============================================================================
# sfcc-ci - Salesforce Commerce Cloud CLI (Node, BSD-3-Clause)
#
# Author : Salesforce Commerce Cloud (SalesforceCommerceCloud org)
# Upstream: https://github.com/SalesforceCommerceCloud/sfcc-ci
#
# sfcc-ci is the official Salesforce B2C Commerce Cloud command-line
# client for CI/CD pipelines and developer workflows: it covers the
# full SFCC operational surface including OAuth2 authentication,
# sandbox provisioning + lifecycle, instance management (add / set /
# clear / list / upload / import / export), code-version deployment
# + activation + diff, job orchestration, user + role administration,
# Shopper Login & API Access Services (SLAS) tenant + client config,
# and Commerce API access. Subcommands follow a `namespace:action`
# convention with 60+ total subcommands across `auth`, `client`,
# `data`, `sandbox`, `instance`, `code`, `job`, `cartridge`, `org`,
# `role`, `user`, and `slas` namespaces.
#
# The JWT codec lane is built on `jsonwebtoken ^9.0.0` (declared
# verbatim at upstream package.json HEAD), the canonical Node JWT
# library originally from Auth0 (`auth0/node-jsonwebtoken`,
# 18000+ stars on github.com/auth0/node-jsonwebtoken, ~30M weekly
# npm downloads). Auth0 has since deprecated some of the auth-flow
# wrappers around the library but the core `jsonwebtoken` package
# remains the dominant Node JWT toolkit and is the dependency-of-
# record for every Express / Fastify / NestJS / Hono web framework's
# JWT auth middleware.
#
# sfcc-ci uses jsonwebtoken to sign + verify the JWTs that
# Salesforce's Account Manager OAuth2 server issues for client-
# credentials grants and authorization-code grants. The CLI
# decodes returned JWTs locally to inspect scope / expiry / claims
# before caching them under `~/.dw.json` for subsequent requests.
#
# ----------------------------------------------------------------------------
# AXIS 202 :: JSON WEB TOKEN (RFC 7519 + RFC 7515 + RFC 7518)  [CLOSES]
# Round 1306 :: TS-Node slot 3 of 4 :: CLOSES Axis 202 (195th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : Keats/jsonwebtoken              [R1304 _jwtui]
#   Go      : golang-jwt/jwt                  [R1305 _spacectl]
#   TS/Node : auth0/node-jsonwebtoken         [R1306 THIS FILE]
#
# auth0/node-jsonwebtoken is the oldest of the three (2013 - it
# pre-dates the final 2015 publication of RFC 7519, which makes it
# the rare case where the canonical library shaped the spec rather
# than implementing it from spec text). The package is one of the
# very few Node libraries with consistent ~30M weekly npm downloads
# and is the upstream dep that holds together OAuth2 / OIDC /
# session-token toolchains across the entire JavaScript ecosystem.
#
# sfcc-ci is the canonical "enterprise CLI authenticated by JWT"
# consumer pattern - many short-lived JWTs per pipeline run, each
# scoped to a specific instance + permission set, with refresh
# token rotation between long-running jobs. This is the production
# shape that pre-dated the OIDC PKCE-everywhere shift; sfcc-ci
# keeps both flows live for backwards compatibility.
# ============================================================================

_sfcc-ci() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(-D --debug)'{-D,--debug}'[enable verbose output]' \
        '--selfsigned[allow self-signed TLS certs]' \
        '(-I --ignorewarnings)'{-I,--ignorewarnings}'[ignore console warnings]' \
        '(- *)'{-V,--version}'[print version]' \
        '(- *)'{-h,--help}'[print help]' \
        '1: :_sfcc-ci_cmds' \
        '*::arg:->_default' \
    && ret=0

    return ret
}

_sfcc-ci_cmds() {
    local -a cmds
    cmds=(
        'auth\:login:Authenticate present user for interactive use'
        'auth\:logout:End the current session and clear authentication'
        'client\:auth:Authenticate as an API client (OAuth client-credentials)'
        'client\:auth\:renew:Renew the cached client auth token'
        'client\:auth\:token:Print the cached client auth token'
        'client\:list:List configured API clients'
        'client\:create:Create a new API client'
        'client\:update:Update an existing API client'
        'client\:rotate:Rotate the API client secret'
        'client\:delete:Delete an API client'
        'data\:upload:Upload a data archive to an instance'
        'sandbox\:realm\:list:List sandbox realms'
        'sandbox\:realm\:update:Update sandbox realm config'
        'sandbox\:list:List sandboxes in the realm'
        'sandbox\:ips:List sandbox-egress IP allowlist'
        'sandbox\:create:Provision a new sandbox'
        'sandbox\:get:Show details of a sandbox'
        'sandbox\:update:Update sandbox settings'
        'sandbox\:start:Start a stopped sandbox'
        'sandbox\:stop:Stop a sandbox'
        'sandbox\:restart:Restart a sandbox'
        'sandbox\:reset:Reset a sandbox to clean state'
        'sandbox\:delete:Delete a sandbox'
        'sandbox\:alias\:add:Add a hostname alias to a sandbox'
        'sandbox\:alias\:list:List aliases for a sandbox'
        'sandbox\:alias\:delete:Remove an alias from a sandbox'
        'instance\:add:Register an instance (alias optional)'
        'instance\:set:Make a registered instance active'
        'instance\:clear:Clear all registered instances'
        'instance\:list:List registered instances'
        'instance\:upload:Upload an archive to the active instance'
        'instance\:import:Import an archive on the active instance'
        'instance\:export:Export the active instance state to an archive'
        'code\:list:List code versions on the active instance'
        'code\:deploy:Deploy a code archive to the active instance'
        'code\:activate:Activate a deployed code version'
        'code\:delete:Delete a code version'
        'code\:manifest\:generate:Generate a manifest from local directories'
        'code\:compare:Compare local directories with the active code version'
        'code\:deploy\:diff:Deploy only the diff vs an existing code version'
        'job\:run:Run a named job with optional parameters'
        'job\:status:Show the status of a running job execution'
        'cartridge\:add:Add a cartridge to the active code version'
        'org\:list:List orgs for the current account'
        'role\:list:List roles in the current org'
        'role\:grant:Grant a role to a user'
        'role\:revoke:Revoke a role from a user'
        'user\:list:List users in the current org'
        'user\:create:Create a new user'
        'user\:update:Update a user'
        'user\:delete:Delete a user'
        'user\:reset:Reset a user (force password reset)'
        'slas\:tenant\:list:List Shopper Login (SLAS) tenants'
        'slas\:tenant\:add:Add a SLAS tenant'
        'slas\:tenant\:get:Show a SLAS tenant config'
        'slas\:tenant\:delete:Delete a SLAS tenant'
        'slas\:client\:add:Add a SLAS client to a tenant'
        'slas\:client\:get:Show a SLAS client config'
        'slas\:client\:list:List SLAS clients in a tenant'
        'slas\:client\:delete:Delete a SLAS client'
    )
    _describe -t commands 'sfcc-ci command' cmds
}

_sfcc-ci "$@"
