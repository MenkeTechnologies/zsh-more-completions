#compdef qmail-qmqpc
# _qmail-qmqpc — qmail's QMQP client (drop-in replacement for qmail-queue that forwards each message to one of the QMQP servers listed in control/qmqpservers; used in mini-qmail installations)
# upstream: https://github.com/notqmail/notqmail
# Source: qmail-qmqpc.8 on tip; no flags.

_qmail-qmqpc() {
    _arguments '(- *)-h[show help]'
}

_qmail-qmqpc "$@"
