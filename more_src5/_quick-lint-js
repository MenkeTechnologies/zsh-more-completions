#compdef quick-lint-js
# Documentation: https://quick-lint-js.com/cli/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for quick-lint-js - JavaScript/TS linter

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--output-format=[output format]:format:(gnu-like vim-qflist-json emacs-lisp)' \
  '--diagnostic-hyperlinks=[when to use hyperlinks]:when:(auto always never)' \
  '--vim-file-bufnr=[Vim buffer number]:number' \
  '--config-file=[use specific config file]:file:_files' \
  '--path-for-config-search=[path for config discovery]:path:_files -/' \
  '--stdin-path=[treat stdin as if from path]:path:_files' \
  '--stdin[read from standard input]' \
  '--language=[language]:lang:(javascript javascript-jsx typescript typescript-jsx typescript-definition)' \
  '--exit-fail-on=[exit non-zero for these error codes]:codes' \
  '(--lsp --lsp-server)'{--lsp,--lsp-server}'[run as LSP server]' \
  '--debug-apps[list running instances]' \
  '--snarky[snarky error messages]' \
  '*:file:_files' && return 0
