#compdef su-exec
# Documentation: https://github.com/ncopa/su-exec
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Usage: su-exec user-spec command [ arguments... ]

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:user[\:group]:_users' \
  '2:command:_command_names -e' \
  '*::args:_normal' && ret=0

return ret
