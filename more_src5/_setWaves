#compdef setWaves
# Documentation: https://cfd.direct/openfoam/user-guide/
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/preProcessing/setWaves — initialise volume-fraction and velocity from a wave model (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[OpenFOAM case directory]:dir:_files -/' \
    '-fileHandler+[file handler]:handler:(uncollated collated masterUncollated)' \
    '-parallel[run in parallel]' \
    '-noFunctionObjects[disable function objects]' \
    '-time+[restrict to selected times]:times:_default' \
    '-latestTime[use latest time]' \
    '-newTimes[only new times]' \
    '-alpha+[volume-fraction field name (default alpha)]:name:_default' \
    '-U+[velocity field name (default U)]:name:_default' \
    '-gas[the alpha field is the gas above the wave]' \
    '-dict+[setWavesDict file]:file:_files' \
    '-region+[region name]:region:_default' \
    && ret=0

return ret
