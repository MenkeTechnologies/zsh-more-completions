#compdef reg_f3d
# Documentation: https://github.com/KCL-BMEIS/niftyreg
# Source: KCL-BMEIS/niftyreg reg-apps/reg_f3d.cpp — fast free-form deformation (FFD) non-rigid registration (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(- *)-help[show help]' \
    '(- *)-v[print version]' \
    '(- *)-version[print version]' \
    '-voff[suppress verbose output]' \
    '(-ref --ref -target)'{-ref+,--ref=,-target+}'[reference image]:file:_files -g "*.{nii,nii.gz,hdr,img}"' \
    '(-flo --flo -source)'{-flo+,--flo=,-source+}'[floating image]:file:_files -g "*.{nii,nii.gz,hdr,img}"' \
    '(-vel --vel)'{-vel,--vel}'[use stationary velocity field]' \
    '(-platf --platf)'{-platf+,--platf=}'[platform: 0=CPU 1=CUDA 2=OpenCL]:platform:(0 1 2)' \
    '(-gpuid --gpuid)'{-gpuid+,--gpuid=}'[GPU device id]:n:_default' \
    '(-aff --aff)'{-aff+,--aff=}'[input initial affine transformation]:file:_files -g "*.txt"' \
    '(-incpp --incpp)'{-incpp+,--incpp=}'[input initial control-point grid]:file:_files' \
    '(-rmask --rmask -tmask)'{-rmask+,--rmask=,-tmask+}'[reference mask]:file:_files' \
    '(-res --res -result)'{-res+,--res=,-result+}'[output resampled image]:file:_files' \
    '(-cpp --cpp)'{-cpp+,--cpp=}'[output control-point grid]:file:_files' \
    '(-maxit --maxit)'{-maxit+,--maxit=}'[max iterations per level]:n:_default' \
    '(-sx --sx)'{-sx+,--sx=}'[final CPG spacing x (mm)]:n:_default' \
    '(-sy --sy)'{-sy+,--sy=}'[final CPG spacing y (mm)]:n:_default' \
    '(-sz --sz)'{-sz+,--sz=}'[final CPG spacing z (mm)]:n:_default' \
    '(-rbn -tbn)'{-rbn+,-tbn+}'[reference image bin count]:n:_default' \
    '(-fbn -sbn)'{-fbn+,-sbn+}'[floating image bin count]:n:_default' \
    '(-ln --ln)'{-ln+,--ln=}'[number of pyramid levels]:n:_default' \
    '(-lp --lp)'{-lp+,--lp=}'[levels to perform]:n:_default' \
    '(-be --be)'{-be+,--be=}'[bending energy weight]:n:_default' \
    '(-le --le)'{-le+,--le=}'[linear elasticity weight]:n:_default' \
    '(-jl --jl)'{-jl+,--jl=}'[Jacobian-based penalty term weight]:n:_default' \
    '(-noAppJL --noAppJL)'{-noAppJL,--noAppJL}'[do not approximate Jacobian log]' \
    '(-land --land)'{-land+,--land=}'[landmark file]:file:_files' \
    '(-smooR --smooR -smooT)'{-smooR+,--smooR=,-smooT+}'[reference smoothing sigma (mm)]:n:_default' \
    '(-smooF --smooF -smooS)'{-smooF+,--smooF=,-smooS+}'[floating smoothing sigma (mm)]:n:_default' \
    '(-rLwTh -tLwTh)'{-rLwTh+,-tLwTh+}'[reference image lower threshold]:n:_default' \
    '(-rUpTh -tUpTh)'{-rUpTh+,-tUpTh+}'[reference image upper threshold]:n:_default' \
    '(-fLwTh -sLwTh)'{-fLwTh+,-sLwTh+}'[floating image lower threshold]:n:_default' \
    '(-fUpTh -sUpTh)'{-fUpTh+,-sUpTh+}'[floating image upper threshold]:n:_default' \
    '-smoothGrad+[gradient smoothing sigma (mm)]:n:_default' \
    '(-ssd -ssdn -kld -lncc -lnccMean -nmiw)-ssd[use SSD similarity]' \
    '(-ssd -ssdn -kld -lncc -lnccMean -nmiw)-ssdn[use SSD-normalised similarity]' \
    '(-ssd -ssdn -kld -lncc -lnccMean -nmiw)-kld[use KLD similarity]' \
    '(-rr --rr)'{-rr,--rr}'[remove redundancy]' \
    '(-ssd -ssdn -kld -lncc -lnccMean -nmiw)-lncc[use LNCC similarity]' \
    '(-ssd -ssdn -kld -lncc -lnccMean -nmiw)-lnccMean[use LNCC-mean similarity]' \
    '(-dti --dti)'{-dti,--dti}'[DTI mode]' \
    '(-ssd -ssdn -kld -lncc -lnccMean -nmiw)-nmiw+[NMI weight]:n:_default' \
    '-lnccw+[LNCC weight]:n:_default' \
    '-ssdw+[SSD weight]:n:_default' \
    '-kldw+[KLD weight]:n:_default' \
    '(-wSim --wSim)'{-wSim+,--wSim=}'[similarity image weight]:file:_files' \
    '(-pad --pad)'{-pad+,--pad=}'[padding value]:n:_default' \
    '(-nopy --nopy)'{-nopy,--nopy}'[no pyramid]' \
    && ret=0

return ret
