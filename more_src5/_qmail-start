#compdef qmail-start
# _qmail-start — qmail's daemon orchestrator (launches qmail-send + qmail-lspawn + qmail-rspawn + qmail-clean under the proper uids/gids; the standard way to start qmail's delivery subsystem)
# upstream: https://github.com/notqmail/notqmail
# Source: qmail-start.9 on tip; positional args only.

_qmail-start() {
    _arguments \
        '1:defaultdelivery:' \
        '2:logger:_command_names -e' \
        '*::logger-args:'
}

_qmail-start "$@"
