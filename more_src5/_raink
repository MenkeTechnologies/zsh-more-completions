        '-r+[number of runs (default 10)]:n:' \
        '-t+[max tokens per batch (default 128000)]:n:' \
        '--ratio=[refinement ratio as decimal (default 0.5)]:ratio:' \
        '--ollama-model=[Ollama model name (if unset, OpenAI is used)]:model:(llama3 llama3.1 llama3.2 llama2 mistral mixtral phi3 qwen2 gemma2 codellama deepseek-coder)' \
