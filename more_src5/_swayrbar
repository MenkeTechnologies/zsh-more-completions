#compdef swayrbar
# Documentation: https://docs.rs/crate/swayrbar/latest/source/src/bar.rs
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for swayrbar - swaybar protocol implementation

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config=}'[config file]:config file:_files -g "*.toml"' && ret=0

return ret
