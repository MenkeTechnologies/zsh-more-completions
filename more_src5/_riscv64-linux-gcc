# _riscv64-linux-gcc — GNU GCC riscv64-linux-gcc CLI cross-compiler build targeting RV64GC RV64GCV little-endian Linux SiFive U54 U74 Allwinner D1 StarFive VisionFive HiFive generating ELF64 DWARF Zfinx Zfh Zba Zbb Zbc Zbs Zicond V Zvbb extensions march mabi mtune (GNU team, C); custom argparse
# upstream: https://gcc.gnu.org/

_riscv64-linux-gcc() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-E[stop after preprocessor]' \
        '-S[stop after compilation]' \
        '-c[compile or assemble only]' \
        '-o+[output file]:file:_files' \
        '-O+[optimization level]:l:(0 1 2 3 s g fast)' \
        '-g[debug info]' \
        '-Wall[enable common warnings]' \
        '-Wextra[enable extra warnings]' \
        '-Werror[treat warnings as errors]' \
        '-fPIC[position independent code]' \
        '-fPIE[position independent executable]' \
        '-pie[link as PIE]' \
        '-static[link statically]' \
        '-shared[link as shared object]' \
        '-march=+[arch]:a:(rv64gc rv64imac rv64imafdc rv64imafdcv rv32gc rv32imac rv32imafdc rv32e rv32em rv64g rv64imafc)' \
        '-mabi=+[abi]:a:(ilp32 ilp32f ilp32d ilp32e lp64 lp64f lp64d)' \
        '-mcpu=+[cpu]:c:(generic-rv64 sifive-7-series sifive-u54 sifive-u74 sifive-e76 sifive-s51 sifive-e21 sifive-e31 sifive-e34 thead-c906 xt-c908 xt-c910 xiangshan-nanhu)' \
        '-mtune=+[tune]:str:' \
        '-mstrict-align[strict alignment]' \
        '-mno-strict-align[allow unaligned access]' \
        '-mcmodel=+[code model]:m:(medlow medany)' \
        '-mexplicit-relocs[explicit relocations]' \
        '-msave-restore[use save-restore stubs]' \
        '-mbranch-cost=+[N]:n:' \
        '-mplt[use PLT for function calls]' \
        '-mno-plt[no PLT]' \
        '-D+[macro]:str:' \
        '-U+[macro]:str:' \
        '-I+[include dir]:dir:_files -/' \
        '-isystem+[system include dir]:dir:_files -/' \
        '-L+[library dir]:dir:_files -/' \
        '-l+[library]:str:' \
        '-Wl,+[linker option]:str:' \
        '-flto[link time optimization]' \
        '-std=+[std]:s:(c89 c99 c11 c17 c23 gnu89 gnu99 gnu11 gnu17 gnu23 c++98 c++11 c++14 c++17 c++20 c++23 gnu++11 gnu++14 gnu++17 gnu++20 gnu++23)' \
        '-MD[generate dependency .d file]' \
        '-MMD[generate dependency .d file no system]' \
        '-MP[add phony rules]' \
        '-MF+[file]:file:_files' \
        '-x+[lang]:l:(c c-header c++ c++-header assembler assembler-with-cpp none)' \
        '--sysroot=+[dir]:dir:_files -/' \
        '*:source file:_files -g "*.c *.cc *.cpp *.cxx *.h *.hpp *.hxx *.s *.S *.o *.a *.so"'
}

_riscv64-linux-gcc "$@"
