#compdef rctest
# Documentation: https://github.com/bluez/bluez/blob/master/tools/rctest.c
# Source: BlueZ tools/rctest.c — RFCOMM transport test harness.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-r -w -d -s -u -n -c -m -a)-r[listen and receive]' \
    '(-r -w -d -s -u -n -c -m -a)-w[listen and send]' \
    '(-r -w -d -s -u -n -c -m -a)-d[listen and dump incoming data]' \
    '(-r -w -d -s -u -n -c -m -a)-s[connect and send]' \
    '(-r -w -d -s -u -n -c -m -a)-u[connect and receive]' \
    '(-r -w -d -s -u -n -c -m -a)-n[connect and be silent]' \
    '(-r -w -d -s -u -n -c -m -a)-c[connect, disconnect, connect, ...]' \
    '(-r -w -d -s -u -n -c -m -a)-m[multiple connects]' \
    '(-r -w -d -s -u -n -c -m -a)-a[automated test (hciX device argument)]:hciX:' \
    '-b[data packet size in bytes]:bytes:' \
    '-i[local device]:device:' \
    '-P[RFCOMM channel]:channel:' \
    '-U[service UUID]:uuid:' \
    '-L[SO_LINGER seconds]:seconds:' \
    '-W[deferred setup seconds]:seconds:' \
    '-B[read data packets from file]:file:_files' \
    '-O[save received data to file]:file:_files' \
    '-N[number of frames to send]:n:' \
    '-C[frames before delay (default 1)]:n:' \
    '-D[delay after N frames (ms, default 0)]:ms:' \
    '-Y[socket priority]:prio:' \
    '-A[request authentication]' \
    '-E[request encryption]' \
    '-S[secure connection]' \
    '-M[become central]' \
    '-T[enable timestamps]' \
    '*:bd addr:' \
    && ret=0

return ret
