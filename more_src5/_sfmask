#compdef sfmask
# Documentation: http://www.ahay.org/RSF/sfmask.html
# Source: ahay/src system/main/mask.c — produce an integer mask from min/max thresholds on header values.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'min=[minimum header value (float or int)]: :_default' \
    'max=[maximum header value (float or int)]: :_default' \
    '*:RSF file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
