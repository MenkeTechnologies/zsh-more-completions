#compdef redis-check-aof redis-check-rdb
# Documentation: redis-check-aof / redis-check-rdb usage
# Source: Redis — AOF / RDB file validator.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--fix[truncate file at first error and rewrite]' \
    '--truncate-to-timestamp=[truncate at given timestamp]:timestamp:' \
    '*:AOF or manifest or RDB file:_files -g "*.{aof,rdb,manifest}"' \
    && ret=0

return ret
