#compdef superagent
# Documentation: https://github.com/superagent-ai/superagent/tree/main/cli
# Reference accessed: 2026-05-22
# Verified: cli/src/index.ts and commands/guard.ts redact.ts scan.ts.

# Zsh completion for superagent - AI security guard, redact, and repo scan CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'superagent command' \
      'guard[analyze prompts for security threats]' \
      'redact[remove sensitive data from text]' \
      'scan[scan repository for agent-targeted attacks]' && ret=0
    ;;
  args)
    case $line[1] in
      guard)
        _arguments \
          '--file[PDF file to analyze]:file:_files' \
          '--system-prompt[custom guard system prompt]:text:' \
          '--model[model to use]:model:' \
          '*:prompt or URL:' && ret=0
        ;;
      redact)
        _arguments \
          '--entities[comma-separated entity types to redact]:entities:' \
          '--rewrite[naturally rewrite instead of placeholders]' \
          '--model[model to use]:model:' \
          '*:text:' && ret=0
        ;;
      scan)
        _arguments \
          '--repo[repository URL to scan]:url:' \
          '--branch[branch tag or commit]:branch:' \
          '--model[model to use]:model:' && ret=0
        ;;
    esac
    ;;
esac

return ret
