#compdef radium
# _radium — Carter Bullard QoSient Argus radium multiplexer/distributor CLI receiving Argus flow records from collectors filtering routing and forwarding to remote Argus clients with optional encryption (qosient team, C); getopt
# upstream: https://github.com/openargus/clients

_radium() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-r+[read file]:file:_files -g "*.argus *.arg"' \
        '--read=+[read file]:file:_files -g "*.argus *.arg"' \
        '-w+[write file]:file:_files -g "*.argus *.arg"' \
        '--write=+[write file]:file:_files -g "*.argus *.arg"' \
        '-S+[remote host]:h:_hosts' \
        '--source=+[remote host]:h:_hosts' \
        '-P+[port]:n:' \
        '--port=+[port]:n:' \
        '-c+[config file]:file:_files -g "*.conf radium.conf"' \
        '--config=+[config file]:file:_files -g "*.conf radium.conf"' \
        '-i+[interface]:str:' \
        '--interface=+[interface]:str:' \
        '-d[daemonize]' \
        '--daemon[daemonize]' \
        '-D+[debug level]:n:' \
        '--debug=+[debug level]:n:' \
        '-A+[ssh auth]:str:' \
        '-p+[pid file]:file:_files' \
        '--pidfile=+[pid file]:file:_files' \
        '-u+[user]:u:_users' \
        '-g+[group]:g:_groups' \
        '-X[hex output]' \
        '-Z+[zone]:str:' \
        '-l+[log file]:file:_files' \
        '--logfile=+[log file]:file:_files' \
        '-T+[timeout sec]:n:' \
        '--timeout=+[timeout sec]:n:' \
        '-O+[output mode]:m:(buffered nodirect direct)' \
        '*:files:_files -g "*.argus *.arg *.bin *.dat"'
}

_radium "$@"
