#compdef sem
# Documentation: https://www.gnu.org/software/parallel/sem.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# GNU parallel sem - counting semaphore (alias of `parallel --semaphore`).
local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(--bg)--fg[do not put command in background]' \
  '(--fg)--bg[execute command in background (default)]' \
  '(--id --semaphorename --semaphore-name)'{--id=,--semaphorename=,--semaphore-name=}'[semaphore name]:name:' \
  '(--st --semaphoretimeout --semaphore-timeout)'{--st=,--semaphoretimeout=,--semaphore-timeout=}'[semaphore timeout (seconds)]:secs:' \
  '--wait[wait for all commands to complete]' \
  '(-j --jobs --max-procs -P)'{-j+,--jobs=,--max-procs=,-P+}'[parallel job count]:n:' \
  '--pipe[pass stdin to command]' \
  '*::command:_command_names -e' && ret=0

return ret
