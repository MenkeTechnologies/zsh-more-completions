#compdef shoryuken
# _shoryuken — Shoryuken AWS SQS Ruby worker (Sidekiq-style); processes SQS messages with concurrency + delayed/scheduled jobs
# upstream: https://github.com/ruby-shoryuken/shoryuken

_shoryuken() {
    local -a sub=(
        'start:start worker (default)'
        'sqs:SQS administration'
        'help:show help'
    )
    _arguments -C \
        '(-c --concurrency)'{-c,--concurrency}'+[concurrency]:n:' \
        '(-d --daemon)'{-d,--daemon}'[daemonize]' \
        '(-q --queue)'{-q,--queue}'+[queue (name,weight)]:queue:' \
        '(-r --require)'{-r,--require}'+[require path]:file:_files' \
        '(-C --config)'{-C,--config}'+[config file]:file:_files -g "*.yml"' \
        '(-L --logfile)'{-L,--logfile}'+[log file]:file:_files' \
        '(-P --pidfile)'{-P,--pidfile}'+[pid file]:file:_files' \
        '(-R --rails)'{-R,--rails}'[boot Rails]' \
        '(-v --verbose)'{-v,--verbose}'[verbose log]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-h --help)'{-h,--help}'[show help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'shoryuken subcommand' sub ;;
        args)
            case $words[1] in
                sqs) _arguments \
                    '1:sqs cmd:(create delete list ls send send_batch dump requeue mv purge)' \
                    '*:args:' ;;
            esac
            ;;
    esac
}

_shoryuken "$@"
