#compdef syncthing
# Documentation: https://docs.syncthing.net/users/syncthing.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed: --device-id, --paths, --reset-database, --reset-deltas,
# --skip-port-probing, --upgrade*, --version (now version subcmd),
# --browser-only, --no-default-folder, --logfile, --logflags,
# --generate (top-level), --auditfile (positional), --upgrade-to.
# Per upstream, these are subcommands (device-id, paths, generate,
# upgrade, version, browser, debug) or live only under `serve`.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-H --home)'{-H,--home=}'[set configuration and data directory]:dir:_directories' \
  '(-C --config)'{-C,--config=}'[set config directory (requires --data)]:dir:_directories' \
  '(-D --data)'{-D,--data=}'[set data directory (requires --config)]:dir:_directories' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'serve:run syncthing (default)'
      'cli:command line interface to REST API'
      'browser:open GUI in browser'
      'decrypt:decrypt files from untrusted devices'
      'device-id:print device ID'
      'generate:generate initial configuration'
      'paths:show configuration and data paths'
      'upgrade:check for or perform upgrade'
      'version:show version'
      'debug:diagnostic tools'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (serve)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--allow-newer-config[allow newer config version]' \
          '--audit[write events to audit log]' \
          '--auditfile=[audit file (- for stdout, -- for stderr)]:file:_files' \
          '--db-maintenance-interval=[DB maintenance interval]:interval:' \
          '--db-delete-retention-interval=[DB delete retention interval]:interval:' \
          '--gui-address=[override GUI address]:address:' \
          '--gui-apikey=[override GUI API key]:key:' \
          '--log-level=[log level]:level:(DEBUG INFO WARN ERROR)' \
          '--log-file=[log file (- for stdout, default for default)]:file:_files' \
          '--log-max-old-files=[number of old log files to keep]:number:' \
          '--log-max-size=[maximum size of log file]:size:' \
          '--log-format-timestamp=[log timestamp format]:fmt:' \
          '--log-format-level-string[log level as string]' \
          '--no-log-format-level-string[no string level]' \
          '--log-format-level-syslog[log level as syslog]' \
          '--no-log-format-level-syslog[no syslog level]' \
          '--no-browser[do not start browser]' \
          '--no-console[hide console window (Windows)]' \
          '--no-port-probing[skip initial port availability check]' \
          '--no-restart[do not restart when upgrading]' \
          '--no-upgrade[do not check for upgrades]' \
          '--paused[start with all devices paused]' \
          '--unpaused[start with all devices unpaused]' \
          '--version[show version]' \
          && ret=0
        ;;
      (decrypt)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--to=[destination directory for decrypted files]:dir:_directories' \
          '--verify-only[verify but do not write]' \
          '--password=[folder password]:password:' \
          '--folder-id=[folder ID]:id:' \
          '--token-path=[auth token file]:file:_files' \
          '--continue[skip errors and continue]' \
          '--verbose[verbose output]' \
          '*:path:_directories' \
          && ret=0
        ;;
      (generate)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--gui-user=[GUI username]:user:' \
          '--gui-password=[GUI password (- to read from stdin)]:password:' \
          '--no-port-probing[skip port availability check]' \
          && ret=0
        ;;
      (upgrade)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--check-only[check availability without upgrading]' \
          '--from=[upgrade from specific URL]:url:' \
          && ret=0
        ;;
      (cli)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(config show operations errors debug)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
