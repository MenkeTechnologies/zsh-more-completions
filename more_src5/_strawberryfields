#compdef strawberryfields sf strawberry-fields
# _strawberryfields — Xanadu Strawberry Fields photonic quantum computing software Continuous Variable circuits Gaussian Fock (xanaduai team, Python); argparse
# upstream: https://github.com/XanaduAI/strawberryfields

_strawberryfields() {
    local -a sub=(
        'simulate:simulate a photonic program'
        'run:run on Xanadu cloud or local'
        'compile:compile a Blackbird program'
        'backend:backend subcommands'
        'tdm:time-domain multiplexed subcommands'
        'gbs:Gaussian boson sampling subcommands'
        'auth:authentication subcommands'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--backend=+[backend]:b:(gaussian fock tf bosonic fock-mixed cv-mixed)' \
        '-b+[backend]:b:(gaussian fock tf bosonic)' \
        '--cutoff-dim=+[N]:n:' \
        '--shots=+[shots]:n:' \
        '-s+[shots]:n:' \
        '--pure[pure state]' \
        '--mixed[mixed state]' \
        '--hbar=+[F]:f:' \
        '--measurement=+[mode]:m:(MeasureFock MeasureHomodyne MeasureHeterodyne MeasureThreshold MeasureP MeasureX)' \
        '--target=+[target]:t:(simulon_gaussian X8 X12 borealis)' \
        '--device=+[device]:str:' \
        '--api-key=+[Xanadu Cloud API key]:str:' \
        '--auth-token=+[auth token]:str:' \
        '--platform-url=+[url]:url:_urls' \
        '--no-progress-bar[no progress bar]' \
        '--debug[debug]' \
        '--verbose[verbose]' \
        '-V[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'strawberryfields subcommand' sub ;;
        args)
            case $words[1] in
                simulate|run|compile) _arguments \
                    '*:program:_files -g "*.xbb *.py *.blackbird"' ;;
                gbs) _arguments '1:gbs cmd:(sample apps data)' ;;
                auth) _arguments '1:auth cmd:(login logout status configure)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_strawberryfields "$@"
