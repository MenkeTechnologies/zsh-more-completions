#compdef rsbuild-cli
# _rsbuild-cli — ByteDance Rsbuild Rspack-based build tool CLI alias (Web Infra ByteDance, TypeScript); cac
# upstream: https://github.com/web-infra-dev/rsbuild

_rsbuild-cli() {
    local -a sub=(
        'dev:start dev server'
        'build:production build'
        'preview:preview production build'
        'serve:serve production (alias)'
        'inspect:print config'
        'mf-dev:start module federation dev'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-c+[config file]:file:_files -g "rsbuild.config.*"' \
        '--config=+[config file]:file:_files -g "rsbuild.config.*"' \
        '--root=+[project root]:dir:_files -/' \
        '-r+[project root]:dir:_files -/' \
        '--env-mode=+[env mode]:m:(none loose strict)' \
        '--mode=+[build mode]:m:(development production none)' \
        '-m+[build mode]:m:(development production none)' \
        '--no-env[no env]' \
        '--env-dir=+[env dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'rsbuild subcommand' sub ;;
        args)
            case $words[1] in
                dev|preview|serve) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--host=+[host]:host:_hosts' \
                    '--open=+[open browser]:str:' \
                    '-o+[open browser]:str:' \
                    '--no-open[no open]' \
                    '--strict-port[strict port]' \
                    '--cors[enable CORS]' \
                    '--https[https]' ;;
                build) _arguments \
                    '--watch[watch]' \
                    '-w[watch]' \
                    '--env-mode=+[env mode]:m:(none loose strict)' \
                    '--source-map[source map]' \
                    '--no-source-map[no source map]' \
                    '--minify[minify]' \
                    '--no-minify[no minify]' ;;
                inspect) _arguments \
                    '--mode=+[mode]:m:(development production)' \
                    '--env=+[env]:e:(client server)' \
                    '--verbose[verbose]' \
                    '--output=+[output file]:file:_files' ;;
            esac
            ;;
    esac
}

_rsbuild-cli "$@"
