#compdef saucelabs-cli saucelabs
# _saucelabs-cli — Sauce Labs saucelabs-cli CLI command-line frontend to the Sauce Labs cloud test platform supporting Sauce Connect tunnel jobs builds asset upload account configuration test orchestration storage bucket browser virtual-device session-monitoring secrets management (Sauce Labs team, Go); cobra
# upstream: https://saucelabs.com/

_saucelabs-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:log out'
        'config:configuration'
        'jobs:job operations'
        'builds:build operations'
        'storage:storage bucket operations'
        'tunnel:tunnel management'
        'session:session operations'
        'account:account operations'
        'browsers:list browsers'
        'devices:list devices'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-u+[user]:str:' \
        '--user=+[user]:str:' \
        '-k+[access key]:str:' \
        '--access-key=+[key]:str:' \
        '--region=+[r]:r:(us-west-1 us-east-1 eu-central-1 apac-southeast-1 staging)' \
        '-r+[region]:r:(us-west-1 us-east-1 eu-central-1 apac-southeast-1 staging)' \
        '-c+[config file]:file:_files -g ".saucelabs.json *.yml *.yaml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.json"' \
        '-f+[format]:f:(json yaml table csv)' \
        '--format=+[format]:f:(json yaml table csv)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'saucelabs-cli subcommand' sub ;;
        args)
            case $words[1] in
                jobs|builds) _arguments '1:op:(list show stop delete)' '*:id:' ;;
                storage) _arguments '1:op:(upload list download delete)' '*:file:_files' ;;
                tunnel) _arguments '1:op:(start stop list status)' ;;
            esac
            ;;
    esac
}

_saucelabs-cli "$@"
