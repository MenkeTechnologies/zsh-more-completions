#compdef snpguest
# _snpguest — AMD SEV-SNP guest utility (virtee/snpguest)
# upstream: https://github.com/virtee/snpguest
# Subcommands from src/main.rs (clap derive).

_snpguest() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-q --quiet)'{-q,--quiet}'[suppress console output]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'report:request an attestation report'
                'certificates:request cached certificates from AMD PSP'
                'fetch:fetch certificates'
                'verify:verify certificates and attestation report'
                'display:display files in human-readable form'
                'key:generate derived key'
                'ok:probe system for SEV-SNP support'
                'generate:generate pre-attestation components'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                fetch|verify|display|generate)
                    _arguments '*::subcommand:'
                    ;;
            esac
            ;;
    esac
}

_snpguest "$@"
