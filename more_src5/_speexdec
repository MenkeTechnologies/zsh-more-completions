#compdef speexdec
# Documentation: speexdec --help (Speex)
# Source: Xiph Speex — speech-codec decoder.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(--enh --no-enh --pf --no-pf)--enh[enable perceptual enhancement (default)]' \
    '(--enh --no-enh --pf --no-pf)--no-enh[disable perceptual enhancement]' \
    '(--enh --no-enh --pf --no-pf)--pf[deprecated alias for --enh]' \
    '(--enh --no-enh --pf --no-pf)--no-pf[deprecated alias for --no-enh]' \
    '(--force-nb --force-wb --force-uwb)--force-nb[force decoding in narrowband]' \
    '(--force-nb --force-wb --force-uwb)--force-wb[force decoding in wideband]' \
    '(--force-nb --force-wb --force-uwb)--force-uwb[force decoding in ultra-wideband]' \
    '(--mono --stereo)--mono[force decoding in mono]' \
    '(--mono --stereo)--stereo[force decoding in stereo]' \
    '--rate=[force decoding sample rate (Hz)]:n:' \
    '--packet-loss=[simulate N percent random packet loss]:n:' \
    '-V[verbose (show bit-rate)]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '1:input Speex (.spx):_files -g "*.spx"' \
    '2:output file (omit = play to soundcard):_files' \
    && ret=0

return ret
