#compdef slarchive
# Documentation: https://github.com/EarthScope/slarchive
# Source: EarthScope/slarchive src/slarchive.c — SeedLink client that archives real-time seismic data.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-V[show version]' \
    '(- *)-h[show help]' \
    '-H[show extended help with format details]' \
    '*-v[verbose (stackable)]' \
    '*-p[print packet details (stackable)]' \
    '-f+[maximum files to keep open]:max:_default' \
    '-nd+[network re-connect delay (s, default 30)]:seconds:_default' \
    '-nt+[network timeout (s, default 600)]:seconds:_default' \
    '-k+[keepalive interval (seconds)]:seconds:_default' \
    '-x+[save/restore stream state file]:file[:int]:_default' \
    '-i+[idle stream timeout (s, default 300)]:seconds:_default' \
    '-d[dial-up mode]' \
    '-b[batch mode]' \
    '-Fi+[initial newer-record check]:overlap:_default' \
    '-Fc+[continuous newer-record check]:overlap:_default' \
    '-s+[stream selectors]:selectors:_default' \
    '-l+[stream list file]:file:_files' \
    '-S+[multi-station stream list]:streams:_default' \
    '-tw+[time window begin:[end]]:window:_default' \
    '-A+[custom file structure format]:format:_default' \
    '-SDS+[SDS archive directory]:dir:_directories' \
    '-BUD+[BUD archive directory]:dir:_directories' \
    '-CSS+[CSS-like archive directory]:dir:_directories' \
    '-CHAN+[Net.Sta.Loc.Chan archive dir]:dir:_directories' \
    '-QCHAN+[quality-tagged channel archive dir]:dir:_directories' \
    '-CDAY+[daily channel archive dir]:dir:_directories' \
    '1:server[:port]:_default' \
    && ret=0

return ret
