#compdef swcat
# ============================================================================
# swcat - lightweight file-based software catalog +
#          visualizer for service/API inventory (Go,
#          unlicensed)
#
# Author : dnswlt (Go developer)
# Upstream: https://github.com/dnswlt/swcat
#
# `swcat` is a file-based software catalog inspired
# by Backstage.io's Software Catalog. Entities
# (services, APIs, components, resources, users,
# groups) are described in YAML files under a root
# directory; swcat scans them, builds a relationship
# graph, generates SVG diagrams via Graphviz dot,
# and serves a web UI for browsing + querying. It
# also lints catalog entries + scans live
# Kubernetes/Prometheus/Bitbucket/JFrog backends for
# auto-discovery + status overlays.
#
# Use cases:
#   - Internal-platform engineering team's "service
#     directory" for an organization (similar to
#     Backstage but file-based instead of Postgres-
#     backed)
#   - Lightweight Kubernetes workload + ownership
#     overlay (which team owns which deployment)
#   - SVG-based service-dependency diagrams in MR
#     reviews + docs
#   - Query language for "what services depend on
#     component X?" + "who owns API Y?"
#
# Usage:
#   swcat [flags]
#
# Flags (Go stdlib `flag` + peterbourgon/ff/v3
# env-var wrapper; all single-dash style):
#   -addr <host:port>                  - HTTP listen
#                                         address
#                                         (default
#                                         localhost:8080)
#   -root-dir <dir>                    - root
#                                         directory of
#                                         local data
#                                         store
#                                         (default ".")
#   -git-url <url>                     - git repo URL
#                                         to use as
#                                         data store
#                                         (instead of
#                                         -root-dir)
#   -git-ref <ref>                     - git ref
#                                         (branch/tag)
#                                         to use
#                                         initially
#   -git-root-dir <dir>                - path within
#                                         the git
#                                         repository
#                                         that
#                                         contains the
#                                         catalog
#                                         structure
#                                         (default ".")
#   -git-user-name <name>              - name used for
#                                         git commits
#                                         in edit
#                                         sessions
#   -git-user-email <email>            - email used
#                                         for git
#                                         commits in
#                                         edit
#                                         sessions
#   -base-dir <dir>                    - base
#                                         directory
#                                         for resource
#                                         files (empty
#                                         = embedded;
#                                         recommended
#                                         for prod)
#   -read-only                         - start server
#                                         in read-only
#                                         mode (no
#                                         entity
#                                         editing)
#   -disable-plugins                   - disable all
#                                         plugins
#                                         (even if
#                                         plugin
#                                         config is
#                                         found)
#   -disable-scheduler                 - disable the
#                                         plugin
#                                         scheduler
#                                         (even if
#                                         plugin
#                                         config has
#                                         it enabled)
#   -dot-timeout <duration>            - max wait
#                                         before
#                                         cancelling
#                                         dot
#                                         executions
#                                         (default
#                                         10s)
#   -dot-streaming                     - use long-
#                                         running dot
#                                         process to
#                                         render SVG
#                                         graphs (only
#                                         when dot
#                                         startup is
#                                         slow, e.g.
#                                         on Windows)
#   -svg-cache-size <n>                - max number of
#                                         SVG graphs
#                                         to hold in
#                                         the in-
#                                         memory LRU
#                                         cache
#                                         (default
#                                         1024)
#   -comments-dir <dir>                - directory
#                                         where entity
#                                         comments are
#                                         stored
#                                         (empty =
#                                         disabled)
#   -kube-kubeconfig <file>            - path to
#                                         kubeconfig
#                                         for
#                                         Kubernetes
#                                         workload
#                                         scanning
#   -kube-context <name>               - Kubernetes
#                                         context to
#                                         use (only
#                                         with
#                                         -kube-
#                                         kubeconfig)
#   -kube-in-cluster                   - use in-
#                                         cluster
#                                         Kubernetes
#                                         config (for
#                                         running
#                                         inside a
#                                         pod)
#   -prometheus-url <url>              - base URL of
#                                         Prometheus
#                                         or Thanos
#                                         REST
#                                         endpoint
#                                         (for
#                                         linting)
#   -prometheus-timeout <duration>     - max wait for
#                                         Prometheus
#                                         queries
#                                         (default
#                                         30s)
#   -bitbucket-url <url>               - base URL of
#                                         Bitbucket
#                                         Data Center
#                                         instance
#   -jfrog-url <url>                   - base URL of
#                                         JFrog
#                                         Artifactory/
#                                         Docker repo
#   -documents-dir <dir>               - local path to
#                                         serve HTML
#                                         documents
#                                         from
#                                         (bypasses
#                                         the catalog
#                                         store; e.g.
#                                         for sidecar
#                                         sync)
#   -database-dsn <dsn>                - SQLite DSN
#                                         for entity
#                                         status
#                                         observations
#   -h, -help                          - print help
#
# Environment variables (peterbourgon/ff/v3
# auto-binds each flag to SWCAT_<UPPER_SNAKE>):
#   SWCAT_ADDR                       <-> -addr
#   SWCAT_ROOT_DIR                   <-> -root-dir
#   SWCAT_GIT_URL                    <-> -git-url
#   SWCAT_GIT_REF                    <-> -git-ref
#   SWCAT_KUBE_KUBECONFIG            <-> -kube-
#                                         kubeconfig
#   SWCAT_PROMETHEUS_URL             <-> -prometheus-
#                                         url
#   (... and so on for every flag)
#
# Additional environment variables (not flag-
# backed; read directly from os.Getenv):
#   SWCAT_GIT_USER                    - basic-auth
#                                         user for
#                                         git URL
#   SWCAT_GIT_PASSWORD                - basic-auth
#                                         password
#   SWCAT_PROMETHEUS_USER             - basic-auth
#                                         user for
#                                         Prometheus
#   SWCAT_PROMETHEUS_PASSWORD         - basic-auth
#                                         password
#   SWCAT_PROMETHEUS_TOKEN            - bearer token
#                                         for
#                                         Prometheus
#   SWCAT_JFROG_USER                  - basic-auth
#                                         user for
#                                         JFrog
#   SWCAT_JFROG_PASSWORD              - basic-auth
#                                         password
#   SWCAT_JFROG_MAVEN_SETTINGS_PATH   - Maven
#                                         settings.xml
#                                         path for
#                                         JFrog auth
#                                         lookup
#   SWCAT_JFROG_MAVEN_SERVER_ID       - server-id
#                                         within
#                                         Maven
#                                         settings to
#                                         extract
#                                         credentials
#                                         from
#
# The yaml.v3 lane is built on `gopkg.in/yaml.v3
# v3.0.1` (declared verbatim at upstream go.mod
# HEAD as a direct dep, imported as
# `"gopkg.in/yaml.v3"` across
# `internal/api/api.go`, `internal/api/api_marshal.go`,
# `internal/config/config.go`, `internal/kube/
# kube.go`, `internal/lint/lint.go`, `internal/
# plugins/plugins.go`, `internal/plugins/timestamp_
# plugin.go`, `internal/plugins/asyncapi_plugin.go`,
# `internal/svg/layout_config.go` for parsing
# catalog YAML files + plugin configs + lint
# definitions + SVG layout configuration), the
# canonical Go YAML library by Canonical Ltd
# (originally by Gustavo Niemeyer) - github.com/
# go-yaml/yaml.
#
# Gustavo Niemeyer authored the original go-yaml
# library at Canonical Ltd to support Canonical's
# (the Ubuntu company's) Go infrastructure tooling
# stack. The library was donated to the
# Canonical-maintained `go-yaml` GitHub
# organization in 2014 + has remained the canonical
# Go YAML library ever since.
#
# yaml.v3 (released 2020) is the YAML 1.2-compliant
# major version, replacing yaml.v2 (YAML 1.1
# semantics). v3 is the de-facto Go canonical:
#   - Used by ~every Kubernetes Go client (k8s.io/
#     apimachinery internally uses sigs.k8s.io/yaml
#     which wraps yaml.v3)
#   - Used by Helm (`gopkg.in/yaml.v3`)
#   - Used by Prometheus + Grafana for config
#   - Used by Buildah + Podman + container-tools
#   - Used by GoReleaser + golangci-lint +
#     goimports + every major Go developer tooling
#
# yaml.v3's distinguishing features over yaml.v2:
#   - Full YAML 1.2 spec compliance (booleans
#     `yes`/`no`/`on`/`off` no longer mis-parsed)
#   - Improved error messages with source line+col
#   - Better handling of complex anchor/alias
#     resolution
#   - Tag handling that correctly distinguishes
#     `!!str "true"` from `!!bool true`
#   - Custom Marshaler/Unmarshaler interfaces with
#     `MarshalYAML`/`UnmarshalYAML` methods
#   - Node-level access via `yaml.Node` for
#     comment-preserving round-trip parsing
#
# Notable: in 2023+ Canonical announced eventual
# transition of go-yaml to a new home; the
# import path `gopkg.in/yaml.v3` remains the
# canonical fetch path for Go modules. As of HEAD,
# `gopkg.in/yaml.v3` v3.0.1 + v3.0.4 (released as
# `go.yaml.in/yaml/v3`) are both in active use,
# with a long migration runway.
#
# swcat uses yaml.v3 as the spine of its catalog
# data model:
#   ```go
#   import "gopkg.in/yaml.v3"
#   var entity Entity
#   err := yaml.NewDecoder(file).Decode(&entity)
#   ```
# Each catalog entity (Component / API / Resource
# / System / Domain / User / Group) is a Go struct
# with `yaml:"..."` field tags; the YAML file
# parsing produces the in-memory entity graph that
# the SVG generator + web UI walk.
#
# ----------------------------------------------------------------------------
# AXIS 262 :: YAML parsing libraries (YAML 1.1/1.2
#              spec parsing + serialization)
# Round 1485 :: Go slot 2 of 4 :: continues Axis 262
#
# Cross-language canonical library family for this axis:
#   Rust    : dtolnay/serde-yaml          [R1484 _lorikeet]
#             (archived 2024 but still
#              dominant via 10,000+
#              reverse-deps)
#   Go      : go-yaml/yaml v3             [R1485 THIS FILE]
#             (Canonical Ltd / Gustavo
#              Niemeyer; the official
#              `gopkg.in/yaml.v3`)
#   TS/Node : nodeca/js-yaml              [R1486 closing]
#             (Vitaly Puzrin; YAML 1.2
#              + 1.1 compatibility modes)
#
# go-yaml/yaml v3 is structurally interesting in
# this axis because it's the *single canonical
# import path* - there is no fragmentation in the
# Go YAML ecosystem the way there is in Rust
# (serde_yaml archived + saphyr + serde_yml) or
# Node (js-yaml + yaml + yawn).
#
# The three lanes form a clean spectrum of YAML-
# ecosystem-canonicalization patterns:
#
#   - Rust (serde_yaml): foundational-but-archived;
#     ecosystem fragmented; community migrating
#     slowly to saphyr/serde_yml
#   - Go (yaml.v3): foundational + actively
#     maintained; single canonical import path;
#     migration to go.yaml.in/yaml/v3 in progress
#     but unified
#   - Node (js-yaml): foundational + actively
#     maintained; one of two co-canonical Node
#     YAML libraries (js-yaml + yaml-rust by
#     eemeli) with js-yaml being the older + more
#     widely used
#
# Each lane reflects the host ecosystem's library-
# governance norms:
#   - Rust: single-author libraries; when the
#     author archives, the library dies
#   - Go: company-backed (Canonical) libraries;
#     ownership transfer happens but the import
#     path persists
#   - Node: org-backed libraries (nodeca) +
#     multiple maintainers; continuity through
#     contributor churn
#
# Use-case spectrum across the three lanes:
#   - lorikeet (Rust, serde_yaml): parallel DevOps
#     test runner using serde_yaml for test-plan
#     loading
#   - swcat (Go, yaml.v3): file-based software
#     catalog using yaml.v3 for entity definitions
#     + plugin configs
#
# Cross-language interop at the YAML document
# level - the same YAML file parses into
# equivalent data structures across all three
# lanes (with minor differences in tag handling
# + boolean interpretation between YAML 1.1 + 1.2
# compatible parsers).
#
# Gustavo Niemeyer's broader Go ecosystem
# footprint (the Canonical/Ubuntu Go stack):
#   - gopkg.in/yaml.v2 + v3 (THIS AXIS)
#   - gopkg.in/check.v1 (testing assertion library
#     used by Canonical Go projects)
#   - gopkg.in/mgo.v2 (canonical Go MongoDB driver
#     for many years; eventually superseded by the
#     official MongoDB Go driver)
#   - The `gopkg.in/` Go versioning convention
#     itself (gopkg.in is a versioned-Go-import-
#     URL service Niemeyer ran from Canonical)
#
# Niemeyer's foundational role in early Go (~2012-
# 2015 era) mirrors Schlueter's role in early Node
# - foundational libraries + ecosystem
# infrastructure (the gopkg.in URL versioning
# service) that the language ecosystem became
# dependent on.
#
# Multi-axis canonical-Go author cohort (now
# spanning multiple distinct individuals):
#   - Andrew Gerrand + the Go team (stdlib)
#   - Russ Cox (Go modules + crypto)
#   - Gustavo Niemeyer (yaml.v3 + gopkg.in
#     infrastructure, THIS AXIS)
#   - Klaus Post (compress + reedsolomon + asmfmt)
#   - Eli Bendersky + Sergey Kamardin (specialized
#     infrastructure)
# ============================================================================

_swcat() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '-addr=[HTTP listen address]:host\:port:' \
        '-root-dir=[root directory of local data store]:dir:_files -/' \
        '-git-url=[git repo URL to use as data store]:url:' \
        '-git-ref=[git ref (branch/tag) to use initially]:ref:' \
        '-git-root-dir=[path within git repo containing catalog structure]:dir:' \
        '-git-user-name=[name for git commits in edit sessions]:name:' \
        '-git-user-email=[email for git commits in edit sessions]:email:' \
        '-base-dir=[base directory for resource files (empty = embedded)]:dir:_files -/' \
        '-read-only[start server in read-only mode]' \
        '-disable-plugins[disable all plugins]' \
        '-disable-scheduler[disable the plugin scheduler]' \
        '-dot-timeout=[max wait before cancelling dot executions]:duration:' \
        '-dot-streaming[use long-running dot process for SVG rendering]' \
        '-svg-cache-size=[max SVG graphs in LRU cache]:n:' \
        '-comments-dir=[directory where entity comments are stored]:dir:_files -/' \
        '-kube-kubeconfig=[path to kubeconfig for k8s workload scanning]:file:_files' \
        '-kube-context=[Kubernetes context to use]:context:' \
        '-kube-in-cluster[use in-cluster Kubernetes config]' \
        '-prometheus-url=[base URL of Prometheus/Thanos REST endpoint]:url:' \
        '-prometheus-timeout=[max wait for Prometheus queries]:duration:' \
        '-bitbucket-url=[base URL of Bitbucket Data Center instance]:url:' \
        '-jfrog-url=[base URL of JFrog Artifactory/Docker repo]:url:' \
        '-documents-dir=[local path to serve HTML documents from]:dir:_files -/' \
        '-database-dsn=[SQLite DSN for entity status observations]:dsn:' \
        '(- *)'{-h,-help}'[print help]'
}

_swcat "$@"
