#compdef sendinpaths
# Documentation: man sendinpaths(8)
# Source: InterNetNews/inn backends/sendinpaths.in — send inpaths reports by mail (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-c[also send copy to newsmaster]' \
    '-d[debug messages]' \
    '(- *)-h[show help]' \
    '-k+[keep N days of processed dumps]:days:_default' \
    '-n[no mail: gather stats only]' \
    '-r+[process N days of dump files]:days:_default' \
    '*:address:_email_addresses' \
    && ret=0

return ret
