#compdef rdcli
# ============================================================================
# _rdcli — zsh completion for lujiajing1126/redis-cli (`rdcli`), a
#           TypeScript Redis CLI wrapper around the node-redis library
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/lujiajing1126/redis-cli
#   Author     : Lu Jiajing  (lujiajing1126)
#   License    : MIT
#   Language   : TypeScript
#   Package    : redis-cli v2.1.2  (npm)
#   Binary     : rdcli  (package.json bin: ./bin/rdcli)
#   Last push  : 2023-11-01
#
# WHAT IT IS
#   rdcli is "a Redis-CLI tool written in TypeScript for the
#   terminal" — Lu Jiajing's interactive Redis REPL with command-
#   history, line editing, cluster-aware ASK / MOVED redirection
#   handling, and TLS support.  Internally it wraps node-redis
#   (`createClient` from `redis`);  when `--cluster` is set it
#   follows `-ASK` and `-MOVED` redirections to the indicated node
#   and caches the slot→endpoint mapping per key.  Commands can be
#   passed inline (`rdcli SET foo bar`) or entered interactively
#   at the prompt.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/index.ts yargs `.options`
#                       definitions)
#   rdcli [OPTIONS] [cmd [arg [arg ...]]]
#
#   Options:
#     -h, --host <HOST>       Server hostname
#                               [default: 127.0.0.1]
#     -p, --port <PORT>       Server port            [default: 6379]
#     -s, --socket <SOCKET>   Server Unix socket path (overrides
#                             --host and --port)
#     -a, --auth <PASS>       Server password
#     -u <URI>                Server URI in `redis[s]://[user:pass]@
#                             host[:port][/db]` form (parses host,
#                             port, password, and database from a
#                             single argument)
#     -n <DB>                 Database number        [default: 0]
#     -m, --mode <MODE>       Server type (currently only `redis`)
#                               [default: redis]
#     -c, --cluster           Enable cluster mode (follow -ASK and
#                             -MOVED redirections, cache slot→
#                             endpoint mapping)
#         --tls               Establish a TLS connection
#
#   Positional:
#     cmd [arg [arg ...]]     Run a single Redis command and exit.
#                             Without positionals, enters an
#                             interactive REPL with readline-based
#                             history + line editing.
#
#   Standard yargs auto-flags:
#         --version           Show version
#         --help              Show help
#
# AXIS / CORPUS POSITION
#   Direct dependency on `redis ^3.1.2` declared in package.json —
#   the canonical Node.js Redis client maintained by the
#   redis/node-redis organization (originally Matt Ranney, now
#   Matías Pessino and the node-redis team).  node-redis is the
#   reference JavaScript Redis client:  typed `RedisClient` +
#   `RedisClientType<typeof modules>` (v4+) with auto-generated
#   commands, idiomatic Promise / async-await API, pub/sub,
#   pipelines, transactions (MULTI/EXEC + watch/unwatch), cluster
#   topology, sentinel, TLS, and pluggable command modules
#   (RedisJSON, RediSearch, RedisGraph, RedisTimeSeries).  rdcli's
#   `src/redis.ts` imports `{ RedisClient, createClient, ClientOpts }
#   from 'redis'`, builds a `RedisClient` per node, and uses the
#   client's command surface to execute every dispatched command.
#   Verified via:
#     gh api repos/lujiajing1126/redis-cli/contents/package.json
#       → "redis": "^3.1.2"
#       → "bin": {"rdcli": "./bin/rdcli"}
#     gh api repos/lujiajing1126/redis-cli/contents/src/redis.ts
#       → import { RedisClient, createClient, ClientOpts }
#               from 'redis';
#   This entry is the TS-Node=134 leader bump that CLOSES Axis 79
#   (Redis Client Library) at 1/1/1 three-language symmetry —
#   pairing Rust=redis-rs 0.27 (R905 _jiascheduler), Go=go-redis/
#   redis v8.11.5 (R906 _redis-viewer), and TS-Node=node-redis
#   ^3.1.2 (this entry).  Triple-134 landmark on commit.
#
#   No completion for `rdcli` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_rdcli() {
    _arguments -s \
        '(-h --host)'{-h+,--host=}'[server hostname (default 127.0.0.1)]:host:_hosts' \
        '(-p --port)'{-p+,--port=}'[server port (default 6379)]:port:' \
        '(-s --socket)'{-s+,--socket=}'[server Unix socket path (overrides host/port)]:socket:_files' \
        '(-a --auth)'{-a+,--auth=}'[server password]:password:' \
        '-u+[server URI (redis\:// form)]:URI:' \
        '-n+[database number (default 0)]:db:' \
        '(-m --mode)'{-m+,--mode=}'[server type]:mode:(redis)' \
        '(-c --cluster)'{-c,--cluster}'[enable cluster mode]' \
        '--tls[establish a TLS connection]' \
        '(- *)--version[show version]' \
        '(- *)--help[show help]' \
        '*: :'
}

_rdcli "$@"
