#compdef qpid-queue-stats
# Documentation: https://github.com/cajus/qpid-tools/blob/master/src/py/qpid-queue-stats
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(-a --broker-address)'{-a,--broker-address=}'[broker address]:addr:' \
  '(-f --filter)'{-f,--filter=}'[comma-separated queue name regexes to show]:filter:' \
  '--sasl-mechanism=[SASL mechanism]:mech:(EXTERNAL ANONYMOUS PLAIN CRAM-MD5 DIGEST-MD5 GSSAPI)'
