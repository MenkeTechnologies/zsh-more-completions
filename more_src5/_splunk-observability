#compdef splunk-observability splunk-obs-cli signalfx-cli
# _splunk-observability — Splunk Observability splunk-observability CLI command-line frontend wrapping the Splunk Observability Cloud formerly SignalFx APM RUM Synthetics Infrastructure Monitoring Log Observer Connect Network Explorer Network Performance Monitoring platform CLI providing login logout whoami metric event chart dashboard detector mute team integration token alertmuting service synthetic-test rum-app log-search OTel-collector configuration realm (Splunk SignalFx team, Go); cobra
# upstream: https://www.splunk.com/en_us/products/observability.html

_splunk-observability() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'metric:metric operations'
        'event:event operations'
        'chart:chart operations'
        'dashboard:dashboard operations'
        'dashboard-group:dashboard group ops'
        'detector:detector operations'
        'mute:mute operations'
        'team:team operations'
        'integration:integration operations'
        'token:token operations'
        'alertmuting:alert muting operations'
        'service:service operations'
        'synthetic-test:synthetic test operations'
        'rum-app:RUM application operations'
        'log-search:log search operations'
        'tag:tag operations'
        'user:user operations'
        'org:organization operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--access-token=+[token]:str:' \
        '--api-url=+[url]:str:' \
        '--realm=+[r]:r:(us0 us1 us2 eu0 eu1 ap0 jp0)' \
        '--ingest-url=+[url]:str:' \
        '--stream-url=+[url]:str:' \
        '--app-url=+[url]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'splunk-obs subcommand' sub ;;
        args)
            case $words[1] in
                metric|event|chart|dashboard|dashboard-group|detector|mute|team|integration|token|alertmuting|service|synthetic-test|rum-app|log-search|tag|user|org) _arguments '1:op:(list get create update delete enable disable mute unmute send)' '*:id:' ;;
            esac
            ;;
    esac
}

_splunk-observability "$@"
