#compdef quera quera-cli bloqade bloqade-cli
# _quera — QuEra Computing Bloqade neutral atom analog quantum simulator and emulator runner (QuEraComputing team, Julia/Python); argparse
# upstream: https://github.com/QuEraComputing/bloqade-python

_quera() {
    local -a sub=(
        'submit:submit program to QuEra cloud'
        'simulate:simulate analog program locally'
        'emulate:emulate analog program'
        'tasks:task subcommands'
        'devices:list available devices'
        'auth:authentication subcommands'
        'metrics:show usage metrics'
        'visualize:visualize Hamiltonian'
        'aquila:Aquila backend subcommands'
        'gemini:Gemini backend subcommands'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--api-key=+[API key]:str:' \
        '--api-url=+[API URL]:url:_urls' \
        '--token=+[auth token]:str:' \
        '--region=+[AWS region]:r:(us-east-1 us-west-2)' \
        '--shots=+[shots]:n:' \
        '-s+[shots]:n:' \
        '--seed=+[seed]:n:' \
        '--backend=+[backend]:b:(braket aquila gemini emulator python-simulator stack julia-simulator cuquantum)' \
        '-b+[backend]:b:(braket aquila gemini emulator python-simulator)' \
        '--solver=+[solver]:s:(adaptive_rk5 julia_dp8 dp5 dp8 vern9 vern8 dopri5 dopri853)' \
        '--device-id=+[device id]:str:' \
        '--no-progress-bar[no progress bar]' \
        '--verbose[verbose]' \
        '-V[verbose]' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'quera subcommand' sub ;;
        args)
            case $words[1] in
                submit) _arguments \
                    '--shots=+[shots]:n:' \
                    '--device=+[device]:d:(Aquila Gemini)' \
                    '--name=+[task name]:str:' \
                    '*:program:_files -g "*.py *.json *.bloqade"' ;;
                simulate|emulate) _arguments \
                    '--shots=+[shots]:n:' \
                    '--solver=+[solver]:s:(adaptive_rk5 julia_dp8 dp5 dp8 vern9)' \
                    '*:program:_files -g "*.py *.json *.bloqade"' ;;
                tasks) _arguments '1:tasks cmd:(list show cancel result status)' ;;
                auth) _arguments '1:auth cmd:(login logout status configure)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_quera "$@"
