#compdef sponge
# _sponge — moreutils sponge (read stdin fully then write to filename atomically — lets you sort foo > foo without truncating; -a appends instead of overwriting)
# upstream: https://salsa.debian.org/built-using-team/moreutils (joeyh)
# Flags from moreutils sponge.c on tip.

_sponge() {
    _arguments \
        '-a[append instead of overwrite]' \
        '1:output file:_files'
}

_sponge "$@"
