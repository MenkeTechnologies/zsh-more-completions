#compdef rnote rnote-cli
# _rnote — Rnote vector note-taking app + CLI (flxzt/rnote)
# upstream: https://github.com/flxzt/rnote
# Subcommands from crates/rnote-cli/src/cli.rs (clap).

_rnote() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_rnote_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                test)
                    _arguments '*:rnote file:_files -g "*.rnote"'
                    ;;
                import)
                    _arguments \
                        '(-i --input-file)'{-i+,--input-file=}'[input file]:file:_files -g "*.xopp"' \
                        '--xopp-dpi=[import DPI for .xopp files]:dpi:' \
                        '1:rnote save file:_files -g "*.rnote"'
                    ;;
                export)
                    _arguments \
                        '--on-conflict=[behavior if output file exists]:mode:(ask skip overwrite suffix)' \
                        '(-b --no-background)'{-b,--no-background}'[export without background]' \
                        '(-p --no-pattern)'{-p,--no-pattern}'[export without background pattern]' \
                        '--optimize-printing[optimize colors for printing]' \
                        '--open[open the result after export]' \
                        '1:export subcommand:(doc doc-pages selection)' \
                        '*:rnote file:_files -g "*.rnote"'
                    ;;
                thumbnail)
                    _arguments \
                        '(-o --output-file)'{-o+,--output-file=}'[output thumbnail file]:file:_files -g "*.{png,jpg,svg,webp}"' \
                        '--timeout=[render timeout (seconds)]:seconds:' \
                        '1:rnote file:_files -g "*.rnote"'
                    ;;
                create)
                    _arguments \
                        '--background-pattern=[background pattern]:pattern:(none lines grid dots isometric isometric-grid)' \
                        '--page-format=[page format]:format:(a3 a4 a5 a6 us-letter us-legal)' \
                        '--page-orientation=[page orientation]:orientation:(portrait landscape)' \
                        '1:new rnote file:_files -g "*.rnote"'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_rnote_commands] )) ||
_rnote_commands() {
    local -a commands
    commands=(
        'test:check whether rnote files open / are valid'
        'import:import an external file (currently .xopp) into a .rnote'
        'export:export .rnote files (doc / doc-pages / selection)'
        'thumbnail:generate a thumbnail from a .rnote file'
        'create:create a new empty .rnote file'
    )
    _describe -t commands 'rnote command' commands
}

_rnote "$@"
