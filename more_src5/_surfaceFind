#compdef surfaceFind
# Documentation: https://cfd.direct/openfoam/user-guide/
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/surface/surfaceFind — find nearest face on a surface to a point (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[OpenFOAM case directory]:dir:_files -/' \
    '-fileHandler+[file handler]:handler:(uncollated collated masterUncollated)' \
    '-noFunctionObjects[disable function objects]' \
    '-x+[point x-coordinate]:X:_default' \
    '-y+[point y-coordinate]:Y:_default' \
    '-z+[point z-coordinate]:Z:_default' \
    '1:surface file:_files -g "*.{stl,obj,nas,vtk,off,gts,inp}"' \
    && ret=0

return ret
