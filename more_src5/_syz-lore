#compdef syz-lore
# _syz-lore — query LKML lore.kernel.org archives for syzkaller discussions (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-lore/query_lkml.go (flag).

_syz-lore() {
    _arguments \
        '-emails=[comma-separated own emails]:list:' \
        '-domains=[comma-separated own domains]:list:' \
        '-out_dir=[directory to save discussions as JSON]:dir:_files -/' \
        '-dashboard=[dashboard address]:url:_urls' \
        '-client=[API client name]:name:' \
        '-key=[API key]:key:' \
        '-v[print more debug info]' \
        '*:archive file:_files'
}

_syz-lore "$@"
