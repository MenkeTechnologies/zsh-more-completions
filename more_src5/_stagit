#compdef stagit
# _stagit — stagit suckless static git page generator (C); generates HTML files (log, files, refs) for a bare git repo
# upstream: https://codemadness.org/stagit.html

_stagit() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[commit cache file]:file:_files' \
        '-l+[max log entries]:n:' \
        '-r+[output dir]:dir:_files -/' \
        '*:bare repo:_files -/'
}

_stagit "$@"
