#compdef risor
# Documentation: https://github.com/risor-io/risor/blob/main/cmd/risor/main.go
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local -a _risor_commands
_risor_commands=(
  'version:print version information'
  'dis:disassemble Risor bytecode'
  'test:run tests'
  'doc:browse language documentation'
  'ast:display the AST for Risor code'
  'fmt:format Risor source code'
  'examples:browse code examples'
  'eval:evaluate an expression'
  'lint:check code for issues'
  'bench:benchmark code execution'
  'completion:generate shell completions'
)

local curcontext="$curcontext" state line

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --code)'{-c,--code}'+[code to evaluate]:code' \
  '--stdin[read code from stdin]' \
  '*--var=[set a variable (key=value)]:var' \
  '--var-json=[set variables from a JSON object]:json' \
  '--cpu-profile=[capture CPU profile]:file:_files' \
  '--no-color[disable colored output]' \
  '--no-default-globals[disable the standard library]' \
  '--timing[show execution time]' \
  '(-o --output)'{-o,--output}'+[output format]:format:(json text)' \
  '--no-repl[disable the REPL]' \
  '1:command:->cmds' \
  '*::arg:->args'

case "$state" in
  cmds)
    _describe -t commands 'risor commands' _risor_commands
    ;;
  args)
    case "$words[1]" in
      dis|ast|lint|bench)
        _arguments \
          '(-c --code)'{-c,--code}'+[code input]:code' \
          '--stdin[read code from stdin]' \
          '*:file:_files'
        ;;
      test)
        _arguments \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '(-r --run)'{-r,--run}'+[run only tests matching pattern]:pattern' \
          '*:pattern'
        ;;
      doc|d)
        _arguments \
          '(-f --format)'{-f,--format}'+[output format]:format:(json text markdown)' \
          '(-q --quick)'{-q,--quick}'[show quick reference]' \
          '(-a --all)'{-a,--all}'[show complete documentation]' \
          '*:topic'
        ;;
      fmt|f)
        _arguments \
          '(-c --code)'{-c,--code}'+[code to format]:code' \
          '--stdin[read code from stdin]' \
          '(-w --write)'{-w,--write}'[write result to source file]' \
          '*:file:_files'
        ;;
      examples|ex)
        _arguments \
          '(-r --run)'{-r,--run}'[run the example]' \
          '(-o --output)'{-o,--output}'+[output format]:format:(json text)' \
          '*:name'
        ;;
      eval|e)
        _arguments \
          '(-c --code)'{-c,--code}'+[expression to evaluate]:code' \
          '--stdin[read from stdin]' \
          '(-o --output)'{-o,--output}'+[output format]:format:(json text)' \
          '(-q --quiet)'{-q,--quiet}'[suppress output]' \
          '*:expression'
        ;;
      bench)
        _arguments \
          '(-c --code)'{-c,--code}'+[code to benchmark]:code' \
          '--stdin[read code from stdin]' \
          '(-n --iterations)'{-n,--iterations}'+[number of iterations]:n' \
          '(-w --warmup)'{-w,--warmup}'+[warmup iterations]:n' \
          '(-o --output)'{-o,--output}'+[output format]:format:(json text)' \
          '*:file:_files'
        ;;
      version)
        _arguments \
          '(-o --output)'{-o,--output}'+[output format]:format:(json text)'
        ;;
    esac
    ;;
esac
