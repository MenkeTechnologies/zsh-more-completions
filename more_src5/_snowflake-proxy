#compdef snowflake-proxy
# Documentation: https://gitlab.torproject.org/tpo/anti-censorship/pluggable-transports/snowflake
# Reference accessed: 2026-05-21
# Verified: flags taken directly from proxy/main.go in upstream snowflake repo.

# snowflake-proxy: volunteer proxy for Snowflake
local curcontext="$curcontext" ret=1
_arguments -C \
  '-poll-interval=[broker poll interval]:duration:' \
  '-capacity=[max concurrent clients]:n:' \
  '-stun=[comma-separated STUN server URLs]:urls:' \
  '-log=[log filename]:file:_files' \
  '-broker=[URL of the broker server]:url:' \
  '-unsafe-logging[keep sensitive info in the logs]' \
  '-log-local-time[use local time for logging]' \
  '-keep-local-addresses[keep local LAN address ICE candidates]' \
  '-relay=[default URL of the server (relay)]:url:' \
  '-nat-probe-server=[URL of NAT probe server]:url:' \
  '-outbound-address=[preferred outbound address for client connections]:addr:' \
  '-allowed-relay-hostname-pattern=[allowed relay hostname pattern]:pattern:' \
  '-allow-proxying-to-private-addresses[allow forwarding to private IP addresses]' \
  '-allow-non-tls-relay[allow forwarding to relay over unencrypted connection]' \
  '-nat-retest-interval=[NAT type measurement interval]:duration:' \
  '-summary-interval=[stats summary interval]:duration:' \
  '-disable-stats-logger[disable stats logging]' \
  '-metrics[enable metrics exposition]' \
  '-metrics-address=[listen address for metrics service]:addr:' \
  '-metrics-port=[port for the metrics service]:port:' \
  '-verbose[increase log verbosity]' \
  '-ephemeral-ports-range=[range of ports used for client connections (min:max)]:range:' \
  '-geoipdb=[IPv4 geoip database path]:file:_files' \
  '-geoip6db=[IPv6 geoip database path]:file:_files' \
  '-version[display version info to stderr and quit]' \
  '-covertdtls-config=[DTLS mimic/randomize config]:mode:(mimic randomize randomizemimic disable)' \
  '-covertdtls-fingerprint=[raw DTLS fingerprint to mimic]:fp:' \
  '*::snowflake-proxy args:_files' && ret=0
return ret
