#compdef rostopic
# Documentation: http://wiki.ros.org/rostopic
# Source: ros/ros_comm noetic-devel tools/rostopic/src/rostopic/__init__.py — ROS1 topic introspection CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '1:subcommand:((
        bw\:"display bandwidth used by topic"
        delay\:"display delay of topic from header timestamp"
        echo\:"print messages to screen"
        find\:"find topics by type"
        hz\:"display publishing rate of topic"
        info\:"print information about active topic"
        list\:"list active topics"
        pub\:"publish data to topic"
        type\:"print topic or field type"
    ))' \
    '*::args:_default' \
    && ret=0

return ret
