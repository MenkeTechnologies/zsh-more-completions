#compdef repl
# Documentation: man repl(1)
# Source: nmh uip/repl.c (master) — reply to a message (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-group -nogroup)-group[group reply]' \
    '(-group -nogroup)-nogroup[no group reply]' \
    '(-annotate -noannotate)-annotate[annotate original]' \
    '(-annotate -noannotate)-noannotate[do not annotate]' \
    '*-cc+[include in cc]:type:(all to cc me)' \
    '*-nocc+[exclude from cc]:type:(all to cc me)' \
    '-draftfolder+[draft folder]:folder:_default' \
    '-draftmessage+[draft message]:msg:_default' \
    '-nodraftfolder[no draft folder]' \
    '-editor+[editor]:cmd:_command_names -e' \
    '-noedit[skip editor]' \
    '-fcc+[fcc folder]:folder:_default' \
    '-filter+[filter file]:file:_files' \
    '-form+[format file]:file:_files' \
    '(-format -noformat)-format[apply format]' \
    '(-format -noformat)-noformat[no format]' \
    '(-inplace -noinplace)-inplace[in-place annotation]' \
    '(-inplace -noinplace)-noinplace[no in-place]' \
    '(-mime -nomime)-mime[encode as MIME]' \
    '(-mime -nomime)-nomime[no MIME encoding]' \
    '(-query -noquery)-query[query before adding addresses]' \
    '(-query -noquery)-noquery[no query]' \
    '-whatnowproc+[whatnow program]:cmd:_command_names -e' \
    '-nowhatnowproc[skip whatnow]' \
    '-width+[output width]:cols:_default' \
    '-version[show version]' \
    '-help[show help]' \
    '-file+[draft file]:file:_files' \
    '-build[build draft only]' \
    '(-atfile -noatfile)-atfile[allow @file shorthand]' \
    '(-atfile -noatfile)-noatfile[no @file shorthand]' \
    '-fmtproc+[format program]:cmd:_command_names -e' \
    '-nofmtproc[no format program]' \
    '1::+folder:_default' \
    '2::msg:_default' \
    && ret=0

return ret
