#compdef qbittorrent-nox
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/qbittorrent-nox.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above. Removed from prior file:
# --portable (not documented in upstream man page).

# Zsh completion for qbittorrent-nox - qBittorrent headless client

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--webui-port=[change the Web UI port]:port' \
  '--profile=[store configuration files in specified directory]:directory:_files -/' \
  '--configuration=[use specified configuration name]:name' \
  '--relative-fastresume[use relative path in fast resume data]' \
  '(-d --daemon)'{-d,--daemon}'[run in daemon mode (background)]' \
  '(-v --version)'{-v,--version}'[display program version]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '*:torrent file:_files -g "*.torrent"' && ret=0

return ret
