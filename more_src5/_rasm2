#compdef rasm2
# Documentation: https://man.archlinux.org/man/rasm2.1.en
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s \
  '-A[show analysis info]' \
  '-B[binary input/output]' \
  '-C[C output format]' \
  '-d[disassemble hex]' \
  '-D[disassemble showing hex+opcode]' \
  '-e[big endian]' \
  '-E[ESIL output]' \
  '-h[show help]' \
  '-hh[long help]' \
  '-j[JSON output]' \
  '-N[no plugins]' \
  '-p[run SPP preprocessor]' \
  '-q[quiet]' \
  '-r[r2 script output]' \
  '-v[show version]' \
  '-w[describe opcode]' \
  '-x[hex dwords output]' \
  '-a=[arch]:arch:(x86 arm mips ppc avr sh sparc m68k riscv 6502 8051 wasm bpf)' \
  '-b=[bits]:bits:(8 16 32 64)' \
  '-c=[CPU]:cpu:' \
  '-f=[input file]:file:_files' \
  '-F=[parse plugin]:parser:' \
  '-H=[show variable]:var:' \
  '-i=[skip bytes]:n:' \
  '-k=[OS]:os:(linux windows darwin android ios)' \
  '-l=[length]:n:' \
  '-L=[list plugins]:filter:' \
  '-LL=[list parse plugins]:name:' \
  '-o=[output file]:file:_files' \
  '-s=[start address]:addr:' \
  '-@=[start address]:addr:' \
  '-S=[syntax]:syntax:(intel att masm)' \
  '*:code or hex:'
