#compdef sigfind
# Documentation: https://www.sleuthkit.org/sleuthkit/man/sigfind.html
# Source: sleuthkit/sleuthkit man/sigfind.1 — find a binary signature in a file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-b[block size to search (multiple of 512, default 512)]:bsize:(512 1024 2048 4096)' \
    '-o[offset in a block where signature must exist (default 0)]:offset:' \
    '-t[template name defining signature value and offset]:template:(dospart ext2 ext3 ext4 fat fat12 fat16 fat32 hfs+ hfsj iso9660 ntfs reiserfs ufs1 ufs2 jffs2)' \
    '-l[signature is stored little-endian (reverse byte order)]' \
    '-V[display version]' \
    '*:image file or hex signature:_files' \
    && ret=0

return ret
