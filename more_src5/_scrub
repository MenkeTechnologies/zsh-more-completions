#compdef scrub
# _scrub — scrub disk overwriting tool (Jim Garlick, C); secure delete by overwriting with NNSA/DoE-approved patterns
# upstream: https://github.com/chaos/scrub

_scrub() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-D+[device or file]:device:_files' \
        '-S+[symlink target]:file:_files' \
        '-X[create new file (with -s)]' \
        '-s+[size of file to create]:n:' \
        '-r[remove file after scrubbing]' \
        '-p+[pattern]:pattern:(nnsa dod bsi old fillzero fillff random random2 gutmann schneier pfitzner7 pfitzner33 usarmy fastold custom)' \
        '-b+[block size]:n:' \
        '-c[do not check device boundary]' \
        '-f[force overwrite]' \
        '-L[create / preserve symlinks]' \
        '-R[regenerate]' \
        '-t[trim & discard]' \
        '*:file:_files'
}

_scrub "$@"
