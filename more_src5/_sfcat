#compdef sfcat
# Documentation: http://www.ahay.org/RSF/sfcat.html
# Source: ahay/src system/main/cat.c — concatenate RSF files along an axis.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'axis=[axis to concatenate along (default 3)]: :_default' \
    'space=[(y/n) insert space between merged datasets]: :(y n)' \
    'nspace=[traces to insert when space=y]: :_default' \
    'o=[axis origin value]: :_default' \
    'd=[axis sampling interval]: :_default' \
    'order=[concatenation order (vector of indices)]: :_default' \
    '*:RSF file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
