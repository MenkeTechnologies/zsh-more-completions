#compdef servo servoshell
# Documentation: https://github.com/servo/servo (ports/servoshell/prefs.rs bpaf parser)
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-B --bhm)'{-B,--bhm}'[enable Background Hang Monitor]' \
  '--certificate-path=[path to SSL certificates]:path:_directories' \
  '--config-dir=[configuration directory (xdg spec)]:dir:_directories' \
  '--content-process=[connect to the given pipe as a content process]:pipe:' \
  '(-Z --debug)'{-Z,--debug=}'[comma-separated debug options]:opts:' \
  '--device-pixel-ratio=[device pixels per px]:ratio:' \
  '--devtools=[start remote devtools server]:address\:port:' \
  '(-y --layout-threads)'{-y,--layout-threads=}'[number of threads for layout]:n:' \
  '--local-script-source=[directory root with unminified scripts]:dir:_directories' \
  '(-o --output)'{-o,--output=}'[path to output image]:file:_files' \
  '(-p --profile)'{-p,--profile=}'[time profiler flag and TSV filename or interval]:value:' \
  '--profiler-trace-path=[path to dump HTML timeline of profiler traces]:path:_files' \
  '*--pref=[preference to set]:pref:' \
  '*--prefs-file=[load additional prefs from file]:file:_files' \
  '(-S --sandbox)'{-S,--sandbox}'[run in a sandbox if multiprocess]' \
  '--screen-size=[override screen resolution]:WxH:' \
  '(-u --user-agent)'{-u,--user-agent=}'[custom user agent string]:ua:' \
  '*--user-stylesheet=[add UTF-8 CSS file as user stylesheet]:file:_files' \
  '--window-size=[initial window size]:WxH:' \
  '--clean-shutdown[do not shutdown until all threads finish]' \
  '--temporary-storage[use non-persistent temporary storage]' \
  '(-x --exit)'{-x,--exit}'[exit after detecting stable output image]' \
  '(-I --force-ipc)'{-I,--force-ipc}'[use ipc_channel in singleprocess mode]' \
  '(-f --hard-fail)'{-f,--hard-fail}'[exit on thread failure]' \
  '(-z --headless)'{-z,--headless}'[headless mode]' \
  '--host-file=[path to hosts file]:file:_files' \
  '--ignore-certificate-errors[ignore certificate errors]' \
  '(-M --multiprocess)'{-M,--multiprocess}'[run in multiprocess mode]' \
  '(-b --no-native-titlebar)'{-b,--no-native-titlebar}'[do not use native titlebar]' \
  '--enable-experimental-web-platform-features[enable experimental features]' \
  '--simulate-touch-events[convert mouse events to touch events]' \
  '--tracing-filter=[custom filter for traces]:filter:' \
  '--unminify-js[unminify JavaScript]' \
  '--unminify-css[unminify CSS]' \
  '*--userscripts=[use userscripts in specified full path]:path:_files' \
  '--webdriver=[start remote WebDriver server on port]:port:' \
  '*:url:_urls' && ret=0

return ret
