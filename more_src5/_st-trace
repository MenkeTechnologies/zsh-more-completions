#compdef st-trace
# Documentation: https://github.com/stlink-org/stlink/blob/develop/src/st-trace/trace.c
# Reference accessed: 2026-05-21
# Verified: upstream C source getopt_long table.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'+[verbose level (0-99)]:level:' \
  '(-c --clock)'{-c+,--clock=}'[core frequency (k/m/g suffix)]:freq:' \
  '(-t --trace)'{-t+,--trace=}'[trace frequency (k/m/g suffix)]:freq:' \
  '(-n --no-reset)'{-n,--no-reset}'[do not reset board on connection]' \
  '(-s --serial)'{-s+,--serial=}'[device serial number]:serial:' \
  '(-f --force)'{-f,--force}'[continue despite initialization errors]' && ret=0

return ret
