#compdef snappyHexMeshConfig
# Documentation: https://cfd.direct/openfoam/user-guide/
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/preProcessing/snappyHexMeshConfig — auto-generate snappyHexMeshDict + blockMeshDict from a surface (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[OpenFOAM case directory]:dir:_files -/' \
    '-fileHandler+[file handler]:handler:(uncollated collated masterUncollated)' \
    '-noFunctionObjects[disable function objects]' \
    '-surface+[geometry surface file]:file:_files -g "*.{stl,obj,nas,vtk,off,gts,inp}"' \
    '-nCells+[cells per direction (e.g. "(10 20 30)")]:cells:_default' \
    '-minDimCells+[cells in shortest direction]:n:_default' \
    '-bounds+[bounding box "((x0 y0 z0) (x1 y1 z1))"]:box:_default' \
    '-cylindricalBackground[generate z-aligned cylindrical background mesh]' \
    '-noBackground[do not write blockMeshDict]' \
    '-refineBackground+[refine background by factor]:n:_default' \
    && ret=0

return ret
