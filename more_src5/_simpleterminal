#compdef simpleterminal st
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/st.1.html
# Reference accessed: 2026-05-21
# Verified: upstream st(1) man page.
# All flags from st(1): -a, -c, -f, -g, -i, -n, -o, -T, -t, -l, -w, -v, -e.

_arguments -s -S \
  '-a[disable alternate screens in terminal]' \
  '-c+[set window class (default $TERM)]:class:' \
  '-f+[set font]:font:' \
  '-g+[X11 window geometry]:geometry:' \
  '-i[fix window position from -g]' \
  '-n+[set window instance name (default $TERM)]:name:' \
  '-o+[record terminal I/O to file (use - for stdout)]:file:_files' \
  '-T+[set window title]:title:' \
  '-t+[set window title]:title:' \
  '-l+[use serial device line]:line:' \
  '-w+[embed in given window id]:windowid:' \
  '-v[print version then exit]' \
  '-e[execute command (must be last)]:*:command:_command_names -e'
