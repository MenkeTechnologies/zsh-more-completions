#compdef syz-ci
# _syz-ci — syzkaller continuous integration manager (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from syz-ci/syz-ci.go (flag).

_syz-ci() {
    _arguments \
        '-config=[config file]:file:_files -g "*.cfg"' \
        '-autoupdate=[auto-update the binary]:val:(true false)' \
        '-managers=[start managers]:val:(true false)' \
        '-debug[debug mode]' \
        '-exit-on-upgrade[exit after syz-ci upgrade is applied]'
}

_syz-ci "$@"
