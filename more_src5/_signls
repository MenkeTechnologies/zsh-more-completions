#       `cc.PortamentoTime = 5`, `cc.DataEntryMSB = 6`,
#       `cc.ChannelVolume = 7`, `cc.Balance = 8`, `cc.Pan = 10`,
#       `cc.Expression = 11`, `cc.SustainPedal = 64`,
#       `cc.PortamentoOnOff = 65`, `cc.SostenutoPedal = 66`,
#       `cc.SoftPedal = 67`, `cc.LegatoFootswitch = 68`,
#       `cc.Hold2 = 69`, `cc.SoundController1 = 70`, ...,
#       `cc.AllNotesOff = 123`, `cc.OmniModeOff = 124`,
#       `cc.OmniModeOn = 125`, `cc.MonoOperation = 126`,
#       `cc.PolyOperation = 127`)
#
#   `gomidi/midi/v2` powers every serious Go MIDI integration
#   in production:
#
#     ‚Ä¢ **alda-lang/alda** ‚Äî the canonical music programming
#       language (5,901+ ‚òÖ; the Alda Clojure server + Go
