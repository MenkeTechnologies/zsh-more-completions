_signls() {
    _arguments -s \
        '-h[show usage]' \
        '-help[show usage]' \
        '-version[print current version]' \
        '-config=[config file to load or create (default config.json)]:path:_files -g "*.json"' \
        '-bank=[bank file to store grids (default default.json)]:path:_files -g "*.json"' \
        '-keyboard=[keyboard layout]:layout:(qwerty qwerty-mac azerty azerty-mac)' \
        '-debug[enable debug mode (writes debug.log)]'
}

_signls "$@"
