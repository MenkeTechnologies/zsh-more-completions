#compdef qshape
# Documentation: man qshape(1)
# Source: vdukhovni/postfix auxiliary/qshape/qshape.pl (master) — print Postfix queue domain/age distribution (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-s[show sender domain distribution (default: recipient)]' \
    '-p[aggregate stats for parent domains]' \
    '-m+[minimum subdomain count for -p (default 5)]:N:_default' \
    '-b+[number of age buckets]:N:_default' \
    '-t+[age limit in minutes for first bucket]:minutes:_default' \
    '-l[long output]' \
    '-w+[terminal width]:cols:_default' \
    '-N+[batch message count]:N:_default' \
    '-n+[batch top domains]:N:_default' \
    '-c+[Postfix config directory]:dir:_files -/' \
    '-h[show help]' \
    '*:queue name:(incoming active deferred hold corrupt maildrop)' \
    && ret=0

return ret
