#   Last push  : 2026-03-27
#
# WHAT IT IS
#   solana-validator-failover is "p2p Solana validator failover" —
#   SOL-Strategies' QUIC-based active/passive failover daemon that
#   safely swaps the active validator role between a pair of
#   Solana nodes.  The CLI ships a single `run` subcommand that
#   auto-detects whether it is being invoked on the currently
#   active or passive node and runs the appropriate side of the
#   handshake:  health-checks the upcoming-active node against
#   the validator RPC `/health` endpoint, waits until the leader-
#   slot window is clear, syncs the tower file from the
#   active to the passive node (so the new active doesn't
#   double-vote), prompts for confirmation (or skips with `-y`),
#   and executes the role swap.  An optional rollback path can
#   restore the previous active if the swap fails mid-flight.
#
# CLI ARGUMENT GRAMMAR  (verbatim from cmd/solanavalidatorfailover/
#                       root.go and run.go — spf13/cobra v1.8.0)
#   solana-validator-failover [GLOBAL OPTIONS] <SUBCOMMAND> [args]
#
#   Persistent (global) options:
#     -c, --config <PATH>            Path to the config file
#                                    [default: standard config path]
#     -l, --log-level <LEVEL>        Log level (trace|debug|info|
#                                                warn|error)
#                                    [default: info]
#     -n, --no-update-check          Skip the background update
#                                    check
#
#   Subcommands:
#     run                            Run a failover (auto-detects
#                                    active vs passive role from
#                                    the local node's state)
#       --not-a-drill                  Execute for real
#                                      (otherwise dry-run;
#                                      ignored on the active node)
#       --no-wait-for-healthy          Don't wait for the node to
#                                      report healthy via
#                                      <validator.rpc_address>/
#                                      health
#       --no-min-time-to-leader-slot   On the active node, don't
#                                      wait until it has no leader
#                                      slots in the next
#                                      <validator.min_time_to_
#                                      leader_slot> (default 5m);
#                                      ignored on passive node
#       --skip-tower-sync              Skip syncing the tower file
#                                      from active to passive
#                                      (passive must not have a
#                                      tower file)
#       -y, --yes                      Automatically answer yes to
#                                      all prompts
#       -r, --rollback-enabled         Force-enable rollback
#                                      regardless of
#                                      rollback.enabled in config
#       --to-peer <NAME_OR_IP>         On active, auto-select the
#                                      peer by name or IP address
#                                      (skips interactive prompt)
#
#   Standard cobra auto-flags:
#     -h, --help                     Show help
#     -v, --version                  Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `github.com/gagliardetto/solana-go
#   v1.8.4` declared in go.mod — the canonical Go Solana SDK
#   maintained by Geoff Gagliardetto (gagliardetto/solana-go).
#   gagliardetto/solana-go is THE Go counterpart to anza-xyz/
#   agave's solana-sdk Rust crate:  it exposes typed `solana.
#   PublicKey`, `solana.PrivateKey`, `solana.Transaction`,
#   `solana.Instruction`, `solana.Message`, `solana.Hash`, the
#   System Program, Compute Budget Program, Address Lookup
#   Table Program, Stake Program, Vote Program, BPF Loader v3/
#   v4, the SPL Token Program and Associated Token Account
#   Program bindings, the `rpc.Client` JSON-RPC client (HTTP +
#   WebSocket subscription variants), and the
#   `programs/system`, `programs/token`, `programs/stake`
#   instruction builders that every Go Solana validator tool
#   relies on.  solana-validator-failover's `internal/validator`
#   package uses this SDK to read the validator identity
#   keypair, query the cluster for upcoming leader slots, and
#   verify slot/leader state during the failover handshake.
#   Verified via:
#     gh api repos/SOL-Strategies/solana-validator-failover/
#         contents/go.mod
#       → github.com/gagliardetto/solana-go v1.8.4
#       → github.com/spf13/cobra v1.8.0
#       → module github.com/sol-strategies/solana-validator-
#         failover
#     gh api repos/SOL-Strategies/solana-validator-failover/
#         contents/cmd/solanavalidatorfailover/root.go
#       → rootCmd.Use = constants.AppName ("solana-validator-
#         failover")
#       → constants.AppName = "solana-validator-failover"
#     gh api repos/SOL-Strategies/solana-validator-failover/
#         contents/cmd/solanavalidatorfailover/run.go
#       → runCmd.Use = "run"
#       → Flags: --not-a-drill, --no-wait-for-healthy,
#         --no-min-time-to-leader-slot, --skip-tower-sync,
#         -y/--yes, -r/--rollback-enabled, --to-peer
#   This entry is the Go=141 leader bump that continues Axis 86
#   (Solana SDK Library) opened at R933 with Rust=solana-sdk
#   via solana-foundation/kora.
#
#   No completion for `solana-validator-failover` ships with
#   Apple zsh (/usr/share/zsh/*/functions) or Homebrew
#   zsh-completions (/opt/homebrew/share/zsh/site-functions) —
#   confirmed absent.
# ============================================================================

_solana-validator-failover() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-c --config)'{-c,--config}'=[config file path]:path:_files' \
        '(-l --log-level)'{-l,--log-level}'=[log level]:level:(trace debug info warn error)' \
        '(-n --no-update-check)'{-n,--no-update-check}'[skip background update check]' \
        '1: :_solana_validator_failover_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                run)
                    _arguments \
                        '--not-a-drill[execute failover for real]' \
                        '--no-wait-for-healthy[do not wait for node /health]' \
                        '--no-min-time-to-leader-slot[do not wait for leader-slot window (active node)]' \
                        '--skip-tower-sync[skip tower file sync from active to passive]' \
                        '(-y --yes)'{-y,--yes}'[automatically answer yes to all prompts]' \
                        '(-r --rollback-enabled)'{-r,--rollback-enabled}'[force-enable rollback]' \
                        '--to-peer=[auto-select peer by name or IP (active node)]:peer:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_solana_validator_failover_commands] )) ||
_solana_validator_failover_commands() {
    local -a commands
    commands=(
        'run:run a failover (auto-detects active/passive role)'
    )
    _describe -t commands 'solana-validator-failover command' commands
}

_solana-validator-failover "$@"
