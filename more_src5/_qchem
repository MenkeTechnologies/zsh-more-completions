#compdef qchem q-chem qchem-cli qcprog
# _qchem — Q-Chem Inc qchem ab initio quantum chemistry program with broad post-Hartree-Fock methods (qchem team, Fortran/C++); custom argparse
# upstream: https://www.q-chem.com

_qchem() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-nt+[number of OpenMP threads]:n:' \
        '--threads=+[number of OpenMP threads]:n:' \
        '-np+[number of MPI procs]:n:' \
        '--mpi=+[number of MPI procs]:n:' \
        '-mpi[use MPI]' \
        '-pbs[PBS scheduler]' \
        '-slurm[Slurm scheduler]' \
        '-fc+[fchk file]:file:_files -g "*.fchk *.chk"' \
        '--fchk=+[fchk file]:file:_files -g "*.fchk *.chk"' \
        '-save[save scratch files]' \
        '--save[save scratch files]' \
        '-save scratch[save scratch]' \
        '-r+[restart from job]:str:' \
        '--restart=+[restart from job]:str:' \
        '-i+[input file]:file:_files -g "*.in *.inp *.qc *.qchem"' \
        '--input=+[input file]:file:_files -g "*.in *.inp *.qc *.qchem"' \
        '-o+[output file]:file:_files -g "*.out *.log"' \
        '--output=+[output file]:file:_files -g "*.out *.log"' \
        '-s+[scratch dir]:dir:_files -/' \
        '--scratch=+[scratch dir]:dir:_files -/' \
        '-mem+[memory MB]:n:' \
        '--memory=+[memory MB]:n:' \
        '-w+[wall time hrs]:n:' \
        '--walltime=+[wall time hrs]:n:' \
        '-d+[debug level]:n:' \
        '--debug=+[debug level]:n:' \
        '-x[execute only no run]' \
        '*:input file:_files -g "*.in *.inp *.qc *.qchem"'
}

_qchem "$@"
