#compdef spi-config
# _spi-config — Christophe Blaess spi-tools spi-config CLI for configuring SPI bus parameters via the Linux SPIdev character device setting mode bits-per-word speed LSB-first query current settings (cpb team, C); getopt
# upstream: https://github.com/cpb-/spi-tools

_spi-config() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-d+[device]:file:_files -g "/dev/spidev*"' \
        '--device=+[device]:file:_files -g "/dev/spidev*"' \
        '-m+[mode]:n:(0 1 2 3)' \
        '--mode=+[mode]:n:(0 1 2 3)' \
        '-l+[LSB first]:b:(0 1)' \
        '--lsb=+[LSB first]:b:(0 1)' \
        '-b+[bits per word]:n:' \
        '--bits=+[bits per word]:n:' \
        '-s+[max speed Hz]:n:' \
        '--speed=+[max speed Hz]:n:' \
        '-q[query current config]' \
        '--query[query current config]' \
        '-r+[bytes to read]:n:' \
        '--read=+[bytes to read]:n:'
}

_spi-config "$@"
