#compdef render
# Documentation: https://render.com/docs/cli-reference
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for render - the official Render CLI (render-oss/cli)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-o --output)'{-o,--output}'=[output format]:format:(json yaml interactive text)' \
  '--confirm[skip confirmation prompts]' \
  '--non-interactive[disable interactive prompts]' \
  '--profile=[profile to use]:profile:' \
  '--workspace=[workspace ID]:workspace:' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'blueprints:blueprint commands'
      'deploys:deploy commands'
      'docs:open Render documentation'
      'environments:list environments'
      'jobs:job commands'
      'kv-cli:open redis-cli or valkey-cli session'
      'login:log in to Render'
      'logout:log out of Render'
      'logs:view logs for services and datastores'
      'pgcli:open pgcli session to a Postgres database'
      'projects:browse projects'
      'psql:open psql session to a Postgres database'
      'restart:restart a service'
      'services:service commands'
      'skills:install/manage Render agent skills'
      'ssh:SSH into a service instance'
      'whoami:show current user'
      'workflows:Render Workflows commands'
      'workspace:current workspace commands'
      'workspaces:list available workspaces'
      'help:show help'
      'completion:generate shell completion'
    )
    _describe -t commands 'render command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      blueprints)
        _arguments -s -S \
          '1:subcommand:(validate)' \
          '*: :' && ret=0
        ;;
      deploys)
        _arguments -s -S \
          '1:subcommand:(cancel create list)' \
          '*: :' && ret=0
        ;;
      jobs)
        _arguments -s -S \
          '1:subcommand:(cancel create list)' \
          '*: :' && ret=0
        ;;
      services)
        _arguments -s -S \
          '1:subcommand:(create instances update)' \
          '*: :' && ret=0
        ;;
      skills)
        _arguments -s -S \
          '1:subcommand:(install list remove update)' \
          '*: :' && ret=0
        ;;
      workflows)
        _arguments -s -S \
          '1:subcommand:(create dev init list)' \
          '*: :' && ret=0
        ;;
      workspace)
        _arguments -s -S \
          '1:subcommand:(current set)' \
          '*: :' && ret=0
        ;;
      logs)
        _arguments -s -S \
          '--resources=[resource IDs (comma-separated)]:list:' \
          '--limit=[limit]:n:' \
          '--start=[start time]:t:' \
          '--end=[end time]:t:' \
          '--type=[log type (comma-separated)]:list:' \
          '--level=[log level (comma-separated)]:list:' \
          '*: :' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
