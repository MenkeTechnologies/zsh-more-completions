#compdef radvd-config
# Documentation: https://github.com/radvd-project/radvd
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# STUB: no canonical radvd-config CLI documented upstream; the radvd
# project ships only radvd(8) and radvdump(8), and radvd.conf is
# hand-edited (no generator binary in upstream). Provide minimal stub.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*::radvd-config args:_files' && ret=0
return ret
