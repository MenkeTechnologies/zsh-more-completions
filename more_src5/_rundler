_rundler() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--network=[network preset (env NETWORK)]:network:' \
        '--chain_spec=[chain spec file path]:path:_files' \
        '--node_http=[ETH node HTTP URL]:url:' \
        '--unsafe[turn unsafe bundling mode on (env UNSAFE)]' \
        '--max_verification_gas=[max verification gas]:gas:' \
        '--max_call_gas=[max call gas]:gas:' \
        '--max_user_ops_per_bundle=[max user operations per bundle]:n:' \
        '--target_bundle_gas_limit=[target bundle gas limit]:gas:' \
        '--metrics.port=[metrics server port]:port:' \
        '--metrics.host=[metrics server host]:host:' \
        '--metrics.sample_interval_millis=[metrics sample interval (ms)]:ms:' \
        '*--metrics.tags=[repeatable metric tags (KEY=VAL)]:tag:' \
        '--metrics.buckets=[histogram bucket spec]:csv:' \
        '--logs.json[emit logs as JSON]' \
        '--logs.otlp_grpc_endpoint=[OTLP gRPC tracing endpoint]:url:' \
        '--logs.otlp_service_name=[OTel service.name resource attribute]:name:' \
        '*--logs.otlp_resource=[OTel resource attribute (KEY=VAL, repeatable)]:kv:' \
        '1: :_rundler_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            _arguments '*: :' && ret=0
            ;;
    esac

    return ret
}

(( $+functions[_rundler_commands] )) ||
_rundler_commands() {
    local -a commands
    commands=(
        'node:run the full bundler (Pool + Builder + Rpc) in a single process'
        'rpc:run only the Rpc server'
        'pool:run only the Pool server (UserOperation mempool + simulation)'
        'builder:run only the Builder server'
        'backend:combined Pool + Builder behind a gRPC gateway'
        'admin:operator commands against a running bundler'
    )
    _describe -t commands 'rundler command' commands
}

_rundler "$@"
