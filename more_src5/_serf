#compdef serf
# _serf — HashiCorp Serf cluster membership tool (hashicorp/serf)
# upstream: https://github.com/hashicorp/serf

_serf() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '1: :_serf_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                agent)
                    _arguments \
                        '-bind=[address to bind]:addr:' \
                        '-iface=[network interface]:iface:' \
                        '-advertise=[advertise address]:addr:' \
                        '-config-dir=[config directory]:dir:_files -/' \
                        '-config-file=[config file]:file:_files' \
                        '-discover=[cluster discovery]:name:' \
                        '-encrypt=[gossip encryption key]:key:' \
                        '-join=[address to join]:addr:' \
                        '-log-level=[log level]:level:(trace debug info warn err)' \
                        '-node=[node name]:name:' \
                        '-profile=[timing profile]:profile:(lan wan local)' \
                        '-protocol=[protocol version]:version:' \
                        '-role=[node role]:role:' \
                        '-rpc-addr=[RPC address]:addr:' \
                        '-snapshot=[snapshot path]:file:_files' \
                        '-rejoin[rejoin cluster on start]' \
                        '-tag=[tag key=value]:tag:' \
                        '-event-handler=[event handler]:handler:' \
                        '-replay[replay old events]' \
                        '--help[show help]' && ret=0 ;;
                event)
                    _arguments \
                        '-coalesce=[coalesce]:bool:(true false)' \
                        '-rpc-addr=[RPC address]:addr:' \
                        '-rpc-auth=[RPC auth token]:token:' \
                        '1:event name:' \
                        '2:payload:' \
                        '--help[show help]' && ret=0 ;;
                join)
                    _arguments \
                        '-replay[replay events]' \
                        '-rpc-addr=[RPC address]:addr:' \
                        '-rpc-auth=[RPC auth token]:token:' \
                        '*:address:' \
                        '--help[show help]' && ret=0 ;;
                members)
                    _arguments \
                        '-detailed[detailed output]' \
                        '-format=[output format]:format:(text json)' \
                        '-name=[filter by name]:name:' \
                        '-role=[filter by role]:role:' \
                        '-status=[filter by status]:status:(alive failed left)' \
                        '-tag=[filter by tag]:tag:' \
                        '-rpc-addr=[RPC address]:addr:' \
                        '-rpc-auth=[RPC auth token]:token:' \
                        '--help[show help]' && ret=0 ;;
                query)
                    _arguments \
                        '-format=[output format]:format:(text json)' \
                        '-node=[target node]:node:' \
                        '-tag=[target tag]:tag:' \
                        '-timeout=[query timeout]:timeout:' \
                        '-no-ack[do not require acks]' \
                        '-rpc-addr=[RPC address]:addr:' \
                        '-rpc-auth=[RPC auth token]:token:' \
                        '1:query name:' \
                        '2:payload:' \
                        '--help[show help]' && ret=0 ;;
                monitor)
                    _arguments \
                        '-log-level=[log level]:level:(trace debug info warn err)' \
                        '-rpc-addr=[RPC address]:addr:' \
                        '-rpc-auth=[RPC auth token]:token:' \
                        '--help[show help]' && ret=0 ;;
                *)
                    _arguments \
                        '-rpc-addr=[RPC address]:addr:' \
                        '-rpc-auth=[RPC auth token]:token:' \
                        '--help[show help]' '*:args:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_serf_commands] )) ||
_serf_commands() {
    local -a commands
    commands=(
        'agent:run a Serf agent'
        'event:send a custom event'
        'force-leave:force a member into left state'
        'info:show agent information'
        'join:join an existing cluster'
        'keygen:generate an encryption key'
        'keys:manage gossip encryption keys'
        'leave:gracefully leave the cluster'
        'members:list cluster members'
        'monitor:stream agent logs'
        'query:send a query'
        'reachability:test network reachability'
        'rtt:estimate network round trip time'
        'tags:modify node tags'
        'version:show version'
    )
    _describe -t commands 'serf command' commands
}

_serf "$@"
