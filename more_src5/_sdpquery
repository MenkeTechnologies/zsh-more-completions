#compdef sdpquery
# Documentation: man sdpquery(1)
# Source: netbsd/src usr.bin/sdpquery — Bluetooth SDP query utility (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a+[remote device (BD_ADDR or hostname)]:address:_default' \
    '-c+[control socket path (default /var/run/sdp)]:socket:_files' \
    '-d+[local device (BD_ADDR or name)]:device:_default' \
    '-l[query local SDP server via control socket]' \
    '-N[display numerical values additionally]' \
    '-R[show raw service attributes]' \
    '-X[display attribute values in hexadecimal]' \
    '1:command:(browse record search)' \
    '*::group, handle, or uuid:_default' \
    && ret=0

return ret
