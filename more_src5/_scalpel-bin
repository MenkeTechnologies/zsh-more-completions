#compdef scalpel
# _scalpel-bin — Scalpel file carver (Brian Carrier/Golden G. Richard III, redesign of Foremost); high-performance carving with header/footer rules
# upstream: https://github.com/sleuthkit/scalpel

_scalpel-bin() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-b[carve files preserving block/cluster geometry]' \
        '-c+[config file]:file:_files' \
        '-d[generate header/footer DB]' \
        '-e[do not perform embedded-file checks]' \
        '-i[skip indirect block detection (UFS/ext)]' \
        '-n[do not write rescued files]' \
        '-o+[output dir]:dir:_files -/' \
        '-O[no organization (flat output)]' \
        '-p[preview mode]' \
        '-q+[clusters of N KiB to skip]:n:' \
        '-r[continue past recovered files]' \
        '-s+[skip N bytes initially]:n:' \
        '-t+[carve threads]:n:' \
        '-u[do not validate carve list]' \
        '-v[verbose]' \
        '*:image:_files'
}

_scalpel-bin "$@"
