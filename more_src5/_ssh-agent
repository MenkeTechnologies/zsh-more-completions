#compdef ssh-agent
# _ssh-agent (OpenSSH ssh-agent — start an authentication agent and emit shell exports on stdout; -a binds named socket, -c csh syntax, -s bourne, -d debug, -D no-fork debug, -k kill running agent, -t default lifetime; positional args run the command under the agent)
# upstream: https://github.com/openssh/openssh-portable
# Flags from openssh-portable ssh-agent.c on tip.

_ssh-agent() {
    _arguments \
        '-a+[bind path]:file:_files' \
        '-c[csh-style output]' \
        '-D[no-fork debug]' \
        '-d[debug]' \
        '-E+[fingerprint hash]:hash:(md5 sha256)' \
        '-k[kill running agent]' \
        '-P+[allowed providers pattern]:pattern:' \
        '-O+[option]:option:(allow-remote-pkcs11)' \
        '-s[bourne-style output]' \
        '-t+[default identity lifetime]:seconds:' \
        '*::command:_command_names -e'
}

_ssh-agent "$@"
