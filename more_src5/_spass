#compdef SPASS spass
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/SPASS.1.html
# Reference accessed: 2026-05-21
# Verified: Ubuntu trusty SPASS(1) manpage. Trimmed flag set to those
# explicitly documented in the manpage; removed earlier ad-hoc options
# (-CNFOptSkolem, -CNFRenaming, -CNFStrSkolem, -CNFSubSumption, -DocFile,
# -Document, -FPDFGTrans, -FullRed, -IDef, -IEq, -IEqF, -IFactor, -IHyper,
# -IOFactor, -IPara, -ISFactor, -ISpT, -PProblem, -PGiven, -PKept, -RAED,
# -RBackContrCNF, -RBackTaut, -RCondRew, -RDescend, -Select, -Sorts, -Sub,
# -Sub2, -Verbose) that did not match the upstream documented list.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-help[show help]' \
  '-Stdin[read input from stdin]' \
  '-Auto+[automatic mode (default 1)]:n:(0 1)' \
  '-Interactive+[interactive mode for successive proof tasks]:n:(0 1)' \
  '-Flotter+[perform CNF translation only]:n:(0 1)' \
  '-TPTP+[expect TPTP syntax input]:n:(0 1)' \
  '-Splits+[max splitting applications (-1 = unlimited)]:n:' \
  '-Memory+[memory in bytes (-1 = unrestricted)]:bytes:' \
  '-TimeLimit+[time limit in seconds (-1 = unlimited)]:s:' \
  '-Loops+[max mainloop iterations]:n:' \
  '-DocProof+[document the proof]:n:(0 1)' \
  '-DocSST+[document static soft typing]:n:(0 1)' \
  '-DocSplit+[show split backtracking levels]:n:(0 1)' \
  '-FPModel+[output saturated clause set to file]:n:(0 1)' \
  '-FPDFGProof+[write proof to file (needs -DocProof)]:n:(0 1)' \
  '-PStatistic+[print final statistics]:n:(0 1)' \
  '-IORe+[ordered resolution]:n:(0 1)' \
  '-ISRe+[standard resolution]:n:(0 1)' \
  '-ISpL+[superposition left]:n:(0 1)' \
  '-ISpR+[superposition right]:n:(0 1)' \
  '-IEqR+[equality resolution]:n:(0 1)' \
  '-ISHy+[standard hyper-resolution]:n:(0 1)' \
  '-IOHy+[ordered hyper-resolution]:n:(0 1)' \
  '-RFRew+[forward rewriting]:n:(0 1)' \
  '-RBRew+[backward rewriting]:n:(0 1)' \
  '-RFSub+[forward subsumption deletion]:n:(0 1)' \
  '-RBSub+[backward subsumption deletion]:n:(0 1)' \
  '-RTaut+[tautology deletion]:n:(0 1)' \
  '-RSST+[static soft typing reduction]:n:(0 1)' \
  '*: :_files -g "*.dfg *.tptp *.p"' && ret=0

return ret
