#compdef semaphoreci sem
# _semaphoreci — Rendered Text Semaphore CI/CD sem CLI alias (semaphoreci team, Go); cobra
# upstream: https://github.com/semaphoreci/cli

_semaphoreci() {
    local -a sub=(
        'connect:configure connection to org'
        'context:list:list contexts'
        'context:use:use context'
        'context:current:show current context'
        'context:add:add context'
        'context:remove:remove context'
        'context:rename:rename context'
        'create:create resource from YAML'
        'apply:apply resource from YAML'
        'get:get resource'
        'edit:edit resource'
        'delete:delete resource'
        'list:list resources'
        'attach:attach to a job'
        'logs:show job logs'
        'jobs:list:list jobs'
        'jobs:get:get job'
        'jobs:create:create job'
        'jobs:stop:stop job'
        'jobs:debug:debug job'
        'pipelines:list:list pipelines'
        'pipelines:get:get pipeline'
        'pipelines:rebuild:rebuild pipeline'
        'pipelines:stop:stop pipeline'
        'projects:list:list projects'
        'projects:get:get project'
        'projects:create:create project'
        'projects:delete:delete project'
        'projects:rename:rename project'
        'projects:set-default-branch:set default branch'
        'projects:debug:debug project'
        'projects:add-collaborator:add collaborator'
        'projects:remove-collaborator:remove collaborator'
        'projects:fork-and-run-workflows:fork and run'
        'workflows:list:list workflows'
        'workflows:get:get workflow'
        'workflows:rebuild:rebuild workflow'
        'workflows:terminate:terminate workflow'
        'workflows:create:create workflow'
        'workflows:stop:stop workflow'
        'secrets:list:list secrets'
        'secrets:get:get secret'
        'secrets:create:create secret'
        'secrets:delete:delete secret'
        'self_hosted_agent_types:list:list agent types'
        'self_hosted_agent_types:create:create agent type'
        'self_hosted_agent_types:delete:delete agent type'
        'self_hosted_agent_types:reset_token:reset token'
        'self_hosted_agent_types:disable:disable agents'
        'self_hosted_agent_types:enable:enable agents'
        'self_hosted_agent_types:get:get agent type'
        'configure:configure default options'
        'init:initialize project in repo'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--token=+[api token]:str:' \
        '--host=+[host]:host:_hosts' \
        '--config=+[config file]:file:_files -g "*.yml"' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'sem subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                init) _arguments '--project-name=+[name]:str:' '--ignore-failures[ignore failures]' '--repo-url=+[url]:url:_urls' ;;
            esac
            ;;
    esac
}

_semaphoreci "$@"
