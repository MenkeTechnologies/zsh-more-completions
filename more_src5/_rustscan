#compdef rustscan
# Documentation: https://github.com/RustScan/RustScan
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (src/input.rs clap definitions).

_arguments -s -S \
  '(-a --addresses)'{-a,--addresses}'=[comma-delimited list / newline-delimited file of CIDRs, IPs, or hosts]:addresses:' \
  '(-p --ports)'{-p,--ports}'=[comma-separated list of ports to scan]:ports:' \
  '(-r --range)'{-r,--range}'=[range of ports to scan (start-end)]:range:' \
  '(-e --exclude-ports)'{-e,--exclude-ports}'=[comma-separated list of ports to exclude]:ports:' \
  '(-x --exclude-addresses)'{-x,--exclude-addresses}'=[comma-separated list of CIDRs/IPs/hosts to exclude]:addresses:' \
  '(-n --no-config)'{-n,--no-config}'[ignore the configuration file]' \
  '--no-banner[hide the banner]' \
  '(-c --config-path)'{-c,--config-path}'=[custom path to config file]:file:_files' \
  '(-b --batch-size)'{-b,--batch-size}'=[batch size for port scanning]:size:' \
  '(-t --timeout)'{-t,--timeout}'=[timeout in milliseconds before a port is assumed closed]:milliseconds:' \
  '--tries=[number of tries before a port is assumed closed]:n:' \
  '(-u --ulimit)'{-u,--ulimit}'=[automatically raise the ulimit to the given value]:n:' \
  '(-g --greppable)'{-g,--greppable}'[greppable output mode (no nmap)]' \
  '--accessible[accessible mode (screen-reader friendly)]' \
  '--resolver=[comma-delimited list / file of DNS resolvers]:resolvers:' \
  '--scan-order=[order of scanning]:order:(serial random)' \
  '--scripts=[level of scripting required for the run]:level:(none default custom)' \
  '--top[use the top 1000 ports]' \
  '--udp[UDP scanning mode]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:command:'
