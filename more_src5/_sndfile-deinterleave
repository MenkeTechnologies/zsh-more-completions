#compdef sndfile-deinterleave
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/sndfile-deinterleave.1.html
# Reference accessed: 2026-05-21
# Verified: Ubuntu jammy sndfile-deinterleave(1) manpage. No flags;
# takes a single multi-channel input file and writes name_XY.suf outputs.

local -a arguments

arguments=(
    '1:multi-channel sound file:_files -g "*.{wav,flac,ogg,aiff,aif,au,snd,w64,caf,rf64}"'
)

_arguments -s -S $arguments
