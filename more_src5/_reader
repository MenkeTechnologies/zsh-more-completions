#                                                     extraction
#                                                     algorithm; also
#                                                     handles CycleTLS
#                                                     browser fingerprint
#                                                     spoofing for sites
#                                                     that block bots)
#   github.com/emersion/go-message                  (RFC 5322 / MIME
#                                                     parser for the
#                                                     `--eml` mode that
#                                                     reads raw email
#                                                     files instead of
#                                                     web URLs)
#   github.com/dolmen-go/kittyimg                   (Kitty terminal
#                                                     graphics protocol)
#   github.com/eliukblau/pixterm/pkg/ansimage       (ANSI block-character
