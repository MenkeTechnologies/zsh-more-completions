#
# WHAT IT IS
#   rpg is "a modern Postgres terminal written in Rust — psql-
#   compatible, with built-in DBA diagnostics and an AI assistant"
#   — Nikolay Samokhvalov's drop-in replacement for `psql`.  Every
#   psql command-line flag and meta-command works unchanged
#   (handshake / connection / scripting / output formatting), so an
#   `alias psql=rpg` is a one-line swap.  On top of psql parity rpg
#   adds:  built-in DBA tools (Postgres.AI diagnostic reports), an
#   SSH-tunnel mode (`--ssh-tunnel`), text-to-SQL natural-language
#   prompting (`--text2sql`), live syntax-highlighted REPL,
#   per-query EXPLAIN annotation (`--plan`), and a multi-host
#   failover connection string with comma-separated ports.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/main.rs clap-derive Cli
#                       struct;  `disable_help_flag = true` to free
#                       `-h` for `--host` psql compatibility)
#   rpg [DBNAME] [USER] [HOST] [PORT] [OPTIONS]
#
#   Positional arguments (psql-compatible order — overridden by the
#   matching named flag when both are present):
#     DBNAME                       Database to connect to
#     USER                         Username
#     HOST                         Hostname
#     PORT                         Port (or comma-separated list)
#
#   Connection flags:
#     -h, --host <HOST>            Database host or socket directory
#     -p, --port <PORT>            Port (single or comma-separated
#                                  list matched to `-h` hosts)
#     -U, --username <USER>        Database username
#     -d, --dbname   <NAME>        Database name
#         --sslmode <MODE>         SSL mode: disable / allow /
#                                  prefer / require / verify-ca /
#                                  verify-full
#     -W, --password               Force password prompt
#     -w, --no-password            Never prompt for password
#         --ssh-tunnel <USER@HOST:PORT>
#                                  SSH bastion tunnel
#
#   Psql scripting flags:
#     -v, --variable <NAME=VAL>    Set psql variable (repeatable)
#     -c, --command <SQL>          Run command(s) and exit
#                                  (repeatable)
#     -f, --file <FILE>            Execute commands from file
#     -X, --no-psqlrc              Skip ~/.psqlrc and ~/.rpgrc
#
#   Output-mode flags:
#     -A, --no-align               Unaligned output
#     -t, --tuples-only            Print rows only
#     -x, --expanded               Expanded display (\x)
#     -P, --pset <VAR[=ARG]>       \pset option (repeatable)
#     -o, --output <FILE>          Send results to file or pipe
#     -F, --field-separator <SEP>  Unaligned field separator
#     -R, --record-separator <SEP> Unaligned record separator
#     -L, --log-queries <FILE>     Log all query output to file
#     -n, --no-readline            Disable line editing
#     -s, --single-step            Confirm each command
#     -z, --field-separator-zero   NUL field separator
#     -0, --record-separator-zero  NUL record separator
#     -a, --echo-all               Echo all input to stdout
#     -E, --echo-hidden            Echo rpg-generated queries
#     -e, --echo-queries           Echo queries from script
#     -b, --echo-errors            Echo only failed-command errors
#     -q, --quiet                  Suppress informational output
#     -S, --single-line            Newline terminates a command
#     -1, --single-transaction     BEGIN/COMMIT wrap-around
#     -i, --interactive            Force interactive mode
#         --csv                    CSV output
#         --json                   JSON output
#         --markdown               Markdown-table output
#     -D, --debug                  Debug logging
#
#   Rpg-specific flags:
#         --compat                 Print psql-compatibility report
#         --no-highlight           Disable REPL syntax highlighting
#         --text2sql               Enable natural-language → SQL
#                                  translation
#         --plan                   Show EXPLAIN before each query
#         --report [FORMAT]        Generate diagnostic report
#                                  (default text;  also json)
#         --log-file <FILE>        Write structured logs to file
#         --log-level <LEVEL>      error / warn / info / debug /
#                                  trace
#         --generate-wrappers [PG] Emit rpg_ops wrapper SQL for the
#                                  named PG version (default 16)
#                                  and exit
#         --update                 Check for + install update, exit
#         --update-check           Check for update (no install)
#
#   Standard clap auto-flags:
#         --help                   Show help
#         --version                Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `tokio-postgres = "0.7"` (with-chrono-0_4
#   feature) declared in Cargo.toml — the canonical async Rust
#   PostgreSQL driver maintained by Steven Fackler (sfackler/
#   rust-postgres) under the `rust-postgres` umbrella project.
#   tokio-postgres is the async sibling of the synchronous
#   `postgres` crate;  both share the same wire-protocol parser,
#   prepared-statement cache, COPY support, LISTEN/NOTIFY, GSSAPI/
#   SCRAM-SHA-256 auth, replication-protocol API, and binary
#   `tokio_postgres::types::ToSql` / `FromSql` codecs for every
#   PostgreSQL type.  rpg's `src/connection.rs` constructs
#   `tokio_postgres::Config::new()` from the parsed CLI flags +
#   `$PGPASSWORD` / `$PGHOST` / `$PGPORT` env vars, opens the
#   `Client` over the configured TCP/TLS/SSH-tunnel transport, and
#   re-uses it across every metacmd and REPL query.  Verified via:
#     gh api repos/NikolayS/rpg/contents/Cargo.toml
#       → tokio-postgres = "0.7"
#       → [[bin]] name = "rpg" path = "src/main.rs"
#     gh api repos/NikolayS/rpg/contents/src/main.rs
#       → #[derive(Parser, Debug)]
#         #[command(name = "rpg", ..., disable_help_flag = true)]
#         struct Cli { ... -h short for --host (psql compat) ... }
#   This entry is the Rust=136 leader bump that OPENS Axis 81
#   (PostgreSQL Driver Library), pairing with future Go=
#   jackc/pgx and TS-Node=node-postgres / pg poles to close the
#   axis at 1/1/1.
#
#   No completion for `rpg` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
#   The adjacent `_rpg-cli` in the corpus targets the unrelated
#   roguelike-game `rpg-cli`;  this `rpg` is the Postgres terminal.
# ============================================================================

_rpg() {
    _arguments -s \
        '(-h --host)'{-h+,--host=}'[database host or socket directory]:host:_hosts' \
        '(-p --port)'{-p+,--port=}'[port (single or comma-separated for multi-host)]:port:' \
        '(-U --username)'{-U+,--username=}'[database username]:user:_users' \
        '(-d --dbname)'{-d+,--dbname=}'[database name]:database:' \
        '--sslmode=[SSL mode]:mode:(disable allow prefer require verify-ca verify-full)' \
        '(-W --password)'{-W,--password}'[force password prompt]' \
        '(-w --no-password)'{-w,--no-password}'[never prompt for password]' \
        '--ssh-tunnel=[SSH bastion (user@host\:port)]:tunnel:' \
        '*'{-v+,--variable=}'[set psql variable (repeatable)]:NAME=VALUE:' \
        '*'{-c+,--command=}'[run command and exit (repeatable)]:SQL:' \
        '(-f --file)'{-f+,--file=}'[execute commands from file]:file:_files -g "*.sql"' \
        '(-X --no-psqlrc)'{-X,--no-psqlrc}'[skip ~/.psqlrc / ~/.rpgrc]' \
        '(-A --no-align)'{-A,--no-align}'[unaligned output]' \
        '(-t --tuples-only)'{-t,--tuples-only}'[print rows only]' \
        '(-x --expanded)'{-x,--expanded}'[expanded display]' \
        '*'{-P+,--pset=}'[\\pset option (repeatable)]:VAR[=ARG]:' \
        '(-o --output)'{-o+,--output=}'[send results to file or pipe]:file:_files' \
        '(-F --field-separator)'{-F+,--field-separator=}'[unaligned field separator]:sep:' \
        '(-R --record-separator)'{-R+,--record-separator=}'[unaligned record separator]:sep:' \
        '(-L --log-queries)'{-L+,--log-queries=}'[log all query output to file]:file:_files' \
        '(-n --no-readline)'{-n,--no-readline}'[disable line editing]' \
        '(-s --single-step)'{-s,--single-step}'[confirm each command]' \
        '(-z --field-separator-zero)'{-z,--field-separator-zero}'[NUL field separator]' \
        '(-0 --record-separator-zero)'{-0,--record-separator-zero}'[NUL record separator]' \
        '(-a --echo-all)'{-a,--echo-all}'[echo all input to stdout]' \
        '(-E --echo-hidden)'{-E,--echo-hidden}'[echo rpg-generated queries]' \
        '(-e --echo-queries)'{-e,--echo-queries}'[echo queries from script]' \
        '(-b --echo-errors)'{-b,--echo-errors}'[echo only failed-command errors]' \
        '(-q --quiet)'{-q,--quiet}'[suppress informational output]' \
        '(-S --single-line)'{-S,--single-line}'[newline terminates a command]' \
        '(-1 --single-transaction)'{-1,--single-transaction}'[BEGIN/COMMIT wrap-around]' \
        '(-i --interactive)'{-i,--interactive}'[force interactive mode]' \
        '--csv[CSV output]' \
        '--json[JSON output]' \
        '--markdown[Markdown-table output]' \
        '(-D --debug)'{-D,--debug}'[debug logging]' \
        '--compat[print psql-compatibility report]' \
        '--no-highlight[disable REPL syntax highlighting]' \
        '--text2sql[enable natural-language to SQL translation]' \
        '--plan[show EXPLAIN before each query]' \
        '--report=[generate diagnostic report]:format:(text json)' \
        '--log-file=[write structured logs to file]:file:_files' \
        '--log-level=[log verbosity level]:level:(error warn info debug trace)' \
        '--generate-wrappers=[emit rpg_ops wrapper SQL for PG version]:pg version:' \
        '(- *)--update[check for and install update]' \
        '(- *)--update-check[check for update without installing]' \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '*: :'
}

_rpg "$@"
