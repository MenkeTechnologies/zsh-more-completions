#compdef swarp SWarp
# Documentation: https://github.com/astromatic/swarp
# Documentation: https://github.com/astromatic/swarp/blob/master/src/main.c
# Documentation: https://github.com/astromatic/swarp/blob/master/src/preflist.h
# Reference accessed: 2026-05-27
# Verified: upstream src/main.c argument loop and src/preflist.h keystruct (astromatic/swarp)

# Zsh completion for SWarp (image resampling and coaddition)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show syntax/help]' \
  '-v[show version information]' \
  '-d[dump default configuration file to stdout]' \
  '-dd[dump extended default configuration file]' \
  '-c[specify configuration file]:config:_files -g "*.swarp"' \
  '*-'{BACK_DEFAULT,BACK_FILTERSIZE,BACK_FILTTHRESH,BACK_SIZE,BACK_TYPE,BLANK_BADPIXELS,CELESTIAL_TYPE,CENTER,CENTER_TYPE}'[override SWarp parameter]:value:' \
  '*-'{CLIP_AMPFRAC,CLIP_LOGNAME,CLIP_SIGMA,CLIP_WRITELOG,COMBINE,COMBINE_BUFSIZE,COMBINE_TYPE,COPY_KEYWORDS,DELETE_TMPFILES}'[override SWarp parameter]:value:' \
  '*-'{DGEO_IMAGE,DGEO_SUFFIX,DGEO_TYPE,FSCALASTRO_TYPE,FSCALE_DEFAULT,FSCALE_KEYWORD,GAIN_DEFAULT,GAIN_KEYWORD}'[override SWarp parameter]:value:' \
  '*-'{HEADER_NAME,HEADER_ONLY,HEADER_SUFFIX,HEADEROUT_NAME,IMAGE_SIZE,IMAGEOUT_NAME,INTERPOLATE,MEM_MAX,NNODES,NODE_INDEX,NOPENFILES_MAX,NTHREADS}'[override SWarp parameter]:value:' \
  '*-'{OVERSAMPLING,PIXEL_SCALE,PIXELSCALE_TYPE,PROJECTION_ERR,PROJECTION_TYPE,RESAMPLE,RESAMPLE_DIR,RESAMPLE_SUFFIX,RESAMPLING_TYPE,RESCALE_WEIGHTS}'[override SWarp parameter]:value:' \
  '*-'{SATLEV_DEFAULT,SATLEV_KEYWORD,SUBTRACT_BACK,TILE_COMPRESS,VERBOSE_TYPE,VMEM_DIR,VMEM_MAX}'[override SWarp parameter]:value:' \
  '*-'{WEIGHT_IMAGE,WEIGHT_SUFFIX,WEIGHT_THRESH,WEIGHT_TYPE,WEIGHTOUT_NAME,WRITE_FILEINFO,WRITE_XML,XML_NAME,XSL_URL}'[override SWarp parameter]:value:' \
  '*:image:_files -g "*.(fits|fit|fts|FITS|FIT|FTS)"' && ret=0

return ret
