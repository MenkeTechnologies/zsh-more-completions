#compdef RHVoice-test rhvoice-test
# Documentation: https://github.com/RHVoice/RHVoice
# Reference accessed: 2026-05-27
# Verified: upstream src/test/test.cpp option list (CLI11/TCLAP) in RHVoice/RHVoice

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-i --input)'{-i+,--input=}'[input file (- for stdin)]:file:_files' \
  '(-o --output)'{-o+,--output=}'[output file (empty for default audio sink)]:file:_files' \
  '(-s --ssml)'{-s,--ssml}'[process input as SSML]' \
  '(-p --profile)'{-p+,--profile=}'[voice profile spec]:profile:' \
  '(-r --rate)'{-r+,--rate=}'[speech rate (percent, default 100)]:percent:' \
  '(-R --sample-rate)'{-R+,--sample-rate=}'[output sample rate in Hz (default 24000)]:rate:(8000 11025 16000 22050 24000 32000 44100 48000)' \
  '(-t --pitch)'{-t+,--pitch=}'[speech pitch (percent, default 100)]:percent:' \
  '(-v --volume)'{-v+,--volume=}'[speech volume (percent, default 100)]:percent:' \
  '(-q --quality)'{-q+,--quality=}'[synthesizer quality]:quality:' \
  '(-w --view)'{-w+,--view=}'[stream view size]:n:' \
  '(-h --help)'{-h,--help}'[show help and exit]' && ret=0

return ret
