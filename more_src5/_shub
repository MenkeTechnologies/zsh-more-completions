#compdef shub
# Documentation: https://shub.readthedocs.io/
# Reference accessed: 2026-05-21
# Verified: upstream shub docs at the URL above describe shub as the
# Scrapinghub command-line client. Subcommand inventory and per-subcommand
# flag list are not exhaustively documented on the docs index; conservative
# completion of common global flags only.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'deploy:deploy project to Scrapy Cloud'
  'login:authenticate with Scrapinghub'
  'logout:log out from Scrapinghub'
  'schedule:schedule a spider'
  'fetch:fetch scraped items or logs'
  'items:list/retrieve items from a job'
  'log:retrieve log of a job'
  'requests:retrieve requests from a job'
  'image:manage custom Docker images'
  'version:show shub version'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command) _describe -t commands 'shub command' commands && ret=0 ;;
esac

return ret
