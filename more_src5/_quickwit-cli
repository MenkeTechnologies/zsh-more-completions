#compdef quickwit-cli
# _quickwit-cli — Quickwit cloud-native search engine CLI (Quickwit, Rust); clap-rs
# upstream: https://github.com/quickwit-oss/quickwit

_quickwit-cli() {
    local -a sub=(
        'run:start a quickwit node'
        'index:manage indexes'
        'source:manage sources'
        'split:manage splits'
        'tool:miscellaneous tools'
        'config:manage configuration'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g "*.yaml"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'quickwit subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments \
                    '--service=+[service to run]:service:(indexer searcher metastore control-plane janitor)' \
                    '--config=+[config file]:file:_files' ;;
                index) _arguments \
                    '1:cmd:(create describe list ingest search clear delete update gc merge)' \
                    '--index=+[index id]:id:' \
                    '--input-path=+[input path]:file:_files' \
                    '--query=+[query]:str:' ;;
                source) _arguments \
                    '1:cmd:(create enable disable delete describe list reset-checkpoint)' \
                    '--index=+[index id]:id:' \
                    '--source=+[source id]:id:' ;;
                split) _arguments \
                    '1:cmd:(list describe extract delete mark-for-deletion)' \
                    '--index=+[index id]:id:' \
                    '--target-dir=+[target dir]:dir:_files -/' ;;
                tool) _arguments \
                    '1:cmd:(local-ingest local-search merge gc extract-split)' \
                    '*:arg:' ;;
                config) _arguments \
                    '1:cmd:(generate validate)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish elvish powershell)' ;;
            esac
            ;;
    esac
}

_quickwit-cli "$@"
