#compdef rocm-smi
# Documentation: https://github.com/ROCm/rocm_smi_lib
# Reference accessed: 2026-05-16
# Verified: upstream ROCm/rocm_smi_lib python_smi_tools README.
# Removed from prior file: bogus man.archlinux.org search URL.

# rocm-smi: AMD ROCm System Management Interface
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --showid)'{-i,--showid}'[show GPU ID]' \
  '(-v --showvbios)'{-v,--showvbios}'[show VBIOS version]' \
  '(-a --showallinfo)'{-a,--showallinfo}'[show temperature, fan and clock values]' \
  '(-f --showfan)'{-f,--showfan}'[show current fan speed]' \
  '(-P --showpower)'{-P,--showpower}'[show current average graphics package power]' \
  '(-t --showtemp)'{-t,--showtemp}'[show current temperature]' \
  '(-u --showuse)'{-u,--showuse}'[show current GPU use]' \
  '(-c --showclocks)'{-c,--showclocks}'[show current clock frequencies]' \
  '(-p --showperflevel)'{-p,--showperflevel}'[show current DPM performance level]' \
  '(-r --resetclocks)'{-r,--resetclocks}'[reset clocks and OverDrive to default]' \
  '--showhw[show ASIC HW IDs]' \
  '--showdriverversion[show kernel driver version]' \
  '--showfwinfo[show firmware version info]' \
  '--showproductname[show product name]' \
  '--showbus[show PCI bus number]' \
  '--showvoltage[show GPU voltage]' \
  '--showmemuse[show current GPU memory usage]' \
  '--setsclk=[set GPU clock level (mhz)]:level:' \
  '--setmclk=[set GPU memory clock level]:level:' \
  '--setperflevel=[set performance level]:level:(auto low high)' \
  '--setfan=[set GPU fan speed (0-255 or %)]:speed:' \
  '--resetfans[reset fans to auto]' \
  '--gpureset[reset GPU]' \
  '--setoverdrive=[set GPU clock OverDrive]:pct:' \
  '--setpoweroverdrive=[set GPU power OverDrive]:w:' \
  '--load=[load profile from file]:file:_files' \
  '--save=[save profile to file]:file:_files' \
  '--json[output JSON]' \
  '--csv[output CSV]' \
  '--loglevel=[log verbosity]:level:(debug info warn error)' \
  '--alldevices[show all GPU devices]' && ret=0
return ret
