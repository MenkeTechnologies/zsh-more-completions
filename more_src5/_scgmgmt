#compdef scgmgmt
# _scgmgmt — Schroedinger Cluster Grid management helper (administrator console for the Squid Grid Mesh family; subcommands: node-add, node-remove, node-status, group-add, group-remove, mesh-sync, mesh-rebalance, cred-rotate, queue-purge, lock-clear, dump-config; -s server, -u user, -p password, -v verbose; runs over the REST API of the cluster controller)
# upstream: distro-shipped (squid-grid-mesh-mgmt)
# Subcommands from chaos/scgmgmt wrapper on tip.

_scgmgmt() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-h[show help]' \
        '-V[show version]' \
        '-s+[server]:host:_hosts' \
        '-u+[user]:user:_users' \
        '-p+[password]:password:' \
        '-v[verbose]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'scgmgmt command' '(node-add node-remove node-status group-add group-remove mesh-sync mesh-rebalance cred-rotate queue-purge lock-clear dump-config help)' ;;
        args) _arguments '*:arg:' ;;
    esac
}

_scgmgmt "$@"
