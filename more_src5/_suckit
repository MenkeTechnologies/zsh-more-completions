#compdef suckit
# Documentation: https://github.com/Skallwar/suckit
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --continue-on-error)'{-c,--continue-on-error}'[continue execution on errors]' \
  '--disable-certs-checks[skip SSL certificate verification]' \
  '--dry-run[execute without saving files]' \
  '(-v --verbose)'{-v,--verbose}'[verbose scraping information]' \
  '--visit-filter-is-download-filter[apply download filters to visit logic]' \
  '(-a --auth)'{-a+,--auth=}'[HTTP basic auth (username password host)]:auth:' \
  '--cookie=[HTTP cookies to send]:cookie:' \
  '--delay=[pause between downloads (seconds)]:seconds:' \
  '(-d --depth)'{-d+,--depth=}'[max recursion depth (-1 unlimited)]:depth:' \
  '(-e --exclude-download)'{-e+,--exclude-download=}'[regex to skip saving matching pages]:regex:' \
  '--exclude-visit=[regex to skip visiting matching pages]:regex:' \
  '--ext-depth=[recursion depth for external domains]:depth:' \
  '(-i --include-download)'{-i+,--include-download=}'[regex for pages to save]:regex:' \
  '--include-visit=[regex for pages to visit]:regex:' \
  '(-j --jobs)'{-j+,--jobs=}'[concurrent thread count]:n:' \
  '(-o --output)'{-o+,--output=}'[output directory path]:dir:_directories' \
  '--random-range=[additional random delay (0 to N seconds)]:n:' \
  '(-t --tries)'{-t+,--tries=}'[maximum retry attempts]:n:' \
  '(-u --user-agent)'{-u+,--user-agent=}'[custom user agent string]:agent:' \
  '*:url:' && return 0
