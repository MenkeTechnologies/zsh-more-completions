#compdef query-starkd
# Documentation: https://astrometry.net
# Source: dstndstn/astrometry.net man/query-starkd.1 — search index files for stars near a sky position (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-o+[output RA-DEC list FITS table]:file:_files' \
    '-r+[RA (deg)]:n:_default' \
    '-d+[Dec (deg)]:n:_default' \
    '-R+[search radius (deg)]:n:_default' \
    '*-t+[tag-along column]:col:_default' \
    '-T[tag along all columns]' \
    '-I[print indices too]' \
    '-v[verbose]' \
    '1:star-kdtree file:_files -g "*.{kd,kd.fits,fits}"' \
    && ret=0

return ret
