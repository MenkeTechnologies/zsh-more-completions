#compdef slaacctl
# _slaacctl — OpenBSD slaacctl (control + introspect the running slaacd(8) IPv6 stateless address autoconfiguration daemon; show interface state, send router solicitations, log level)
# upstream: https://github.com/openbsd/src (usr.sbin/slaacctl)
# Flags + commands from usr.sbin/slaacctl/slaacctl.8 on tip.

_slaacctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-s+[control socket (default /dev/slaacd.sock)]:file:_files' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'slaacctl command' \
                '(show:show interface state send:send router solicitation log:log level (brief|verbose))'
            ;;
        args)
            case $line[1] in
                show) _describe -t commands 'show target' '(interface)' ;;
                send) _describe -t commands 'send target' '(solicitation)' ;;
                log) _describe -t commands 'log level' '(brief verbose)' ;;
            esac
            ;;
    esac
}

_slaacctl "$@"
