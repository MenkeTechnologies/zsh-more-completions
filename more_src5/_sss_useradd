#compdef sss_useradd
# Documentation: https://manpages.debian.org/unstable/sssd-tools/sss_useradd.8.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)--usage[show usage]' \
  '(-u --uid)'{-u,--uid}'+[set UID]:uid:' \
  '(-c --gecos)'{-c,--gecos}'+[GECOS comment]:gecos:' \
  '(-h --home)'{-h,--home}'+[home directory]:dir:_files -/' \
  '(-s --shell)'{-s,--shell}'+[login shell]:shell:_files' \
  '(-G --groups)'{-G,--groups}'+[supplementary groups (comma-separated)]:groups:_groups' \
  '(-m --create-home -M --no-create-home)'{-m,--create-home}'[create home directory]' \
  '(-m --create-home -M --no-create-home)'{-M,--no-create-home}'[do not create home directory]' \
  '(-k --skel)'{-k,--skel}'+[skeleton directory]:dir:_files -/' \
  '(-Z --selinux-user)'{-Z,--selinux-user}'+[SELinux user for login]:user:' \
  '1:username:' && ret=0

return ret
