#compdef swimlane-cli swimlane sw-cli
# _swimlane-cli — Swimlane swimlane-cli CLI command-line frontend wrapping the Swimlane Turbine low-code security automation SOAR Security Orchestration Automation and Response platform CLI providing login logout whoami workflow application record case workspace asset plugin task connector trigger action user role group permission tenant content content-pack import export sync run record-statistic dashboard report (Swimlane team Cody Cornell, Go); cobra
# upstream: https://swimlane.com/

_swimlane-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'workflow:workflow operations'
        'application:application operations'
        'record:record operations'
        'case:case operations'
        'workspace:workspace operations'
        'asset:asset operations'
        'plugin:plugin operations'
        'task:task operations'
        'connector:connector operations'
        'trigger:trigger operations'
        'action:action operations'
        'user:user operations'
        'role:role operations'
        'group:group operations'
        'permission:permission operations'
        'tenant:tenant operations'
        'content-pack:content pack operations'
        'sync:sync operations'
        'import:import content'
        'export:export content'
        'run:run operations'
        'dashboard:dashboard operations'
        'report:report operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-token=+[token]:str:' \
        '--api-url=+[url]:str:' \
        '--swimlane-url=+[url]:str:' \
        '--tenant=+[name]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'swimlane subcommand' sub ;;
        args)
            case $words[1] in
                workflow|application|record|case|workspace|asset|plugin|task|connector|trigger|action|user|role|group|permission|tenant|content-pack|dashboard|report) _arguments '1:op:(list get create update delete enable disable run import export)' '*:id:' ;;
            esac
            ;;
    esac
}

_swimlane-cli "$@"
