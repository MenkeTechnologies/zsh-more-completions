#compdef reordercap
# _reordercap-bin — Wireshark reorder packets by timestamp; sort pcap by frame.time_relative
# upstream: https://gitlab.com/wireshark/wireshark

_reordercap-bin() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-n[do not write packet]' \
        '*:file:_files'
}

_reordercap-bin "$@"
