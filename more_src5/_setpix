#compdef setpix
# _setpix — set FITS image pixel values arithmetically (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from setpix.c (single-letter getopt-style).

_setpix() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-a+[add constant to image section]:val:' \
        '-d+[divide image section by constant]:val:' \
        '-i[print each change]' \
        '-m+[multiply image section by constant]:val:' \
        '-n[output to new file]' \
        '-s+[subtract constant from image section]:val:' \
        '-v[verbose output]' \
        '1:FITS file:_files -g "*.(fits|fit|fts|imh)"' \
        '*:x y value:'
}

_setpix "$@"
