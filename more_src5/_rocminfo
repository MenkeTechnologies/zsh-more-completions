#compdef rocminfo
# Documentation: https://github.com/ROCm/rocminfo
# Reference accessed: 2026-05-16
# Verified: upstream ROCm/rocminfo. Docs do not enumerate CLI flags;
# primary mode is no-argument dump.
# Removed from prior file: fabricated -V/--version (not documented) and
# bogus man.archlinux.org search URL.

# rocminfo: AMD ROCm system information (HSA agent dump)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' && ret=0
return ret
