#compdef qiime qiime2
# _qiime2 — QIIME 2 Project qiime CLI Quantitative Insights Into Microbial Ecology v2 microbiome bioinformatics platform supporting 16S 18S ITS amplicon shotgun metagenomic pipeline of plugins demux dada2 deblur feature-classifier alignment phylogeny diversity emperor metadata sample-classifier longitudinal taxa (QIIME 2 team, Python); click
# upstream: https://qiime2.org/

_qiime2() {
    local -a sub=(
        'info:show QIIME 2 deployment info'
        'tools:utilities for working with artifacts'
        'demux:demultiplex sequences'
        'dada2:denoise sequences with DADA2'
        'deblur:denoise sequences with Deblur'
        'cutadapt:trim primers with cutadapt'
        'quality-filter:filter sequences by quality'
        'vsearch:cluster sequences with vsearch'
        'feature-classifier:taxonomic classification'
        'feature-table:operations on feature tables'
        'phylogeny:build phylogenetic trees'
        'diversity:alpha/beta diversity analyses'
        'emperor:emperor 3D ordination plots'
        'taxa:taxonomic-level operations'
        'sample-classifier:sample classification ML'
        'longitudinal:longitudinal analyses'
        'metadata:operations on metadata'
        'composition:differential abundance'
        'gneiss:gneiss compositional analyses'
        'alignment:multiple sequence alignment'
        'fragment-insertion:fragment insertion to tree'
        'rescript:reference sequence curation'
        'aldex2:differential abundance ALDEx2'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--quiet[quiet]' \
        '--example-data=+[dir]:dir:_files -/' \
        '--show-importable-types[show importable types]' \
        '--show-importable-formats[show importable formats]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'qiime subcommand' sub ;;
        args)
            case $words[1] in
                tools) _arguments \
                    '1:tool:(import export view peek inspect-metadata extract validate cast-metadata)' \
                    '*:files:_files -g "*.qza *.qzv"' ;;
            esac
            ;;
    esac
}

_qiime2 "$@"
