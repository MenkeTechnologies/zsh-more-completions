#compdef streamcap stream-cap
# _streamcap — streamcap network-traffic stream-reassembly CLI for extracting TCP UDP HTTP TLS SMB streams from pcap files reconstructing application-layer payloads with optional decryption (streamcap team, C); getopt
# upstream: https://github.com/streamcap/streamcap

_streamcap() {
    local -a sub=(
        'tcp:reassemble TCP streams'
        'udp:reassemble UDP streams'
        'http:reassemble HTTP transactions'
        'tls:reassemble TLS sessions'
        'smb:reassemble SMB sessions'
        'dns:reassemble DNS transactions'
        'follow:follow specific stream'
        'list:list streams'
        'export:export streams to files'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-i+[input file]:file:_files -g "*.pcap *.pcapng *.cap"' \
        '--input=+[input file]:file:_files -g "*.pcap *.pcapng *.cap"' \
        '-o+[output dir]:dir:_files -/' \
        '--output=+[output dir]:dir:_files -/' \
        '-f+[BPF filter]:str:' \
        '--filter=+[BPF filter]:str:' \
        '-k+[TLS keys file]:file:_files -g "*.keylog"' \
        '--keys=+[TLS keys file]:file:_files -g "*.keylog"' \
        '-c+[count limit]:n:' \
        '--count=+[count limit]:n:' \
        '-s+[stream id]:n:' \
        '--stream-id=+[stream id]:n:' \
        '--src=+[src ip:port]:str:' \
        '--dst=+[dst ip:port]:str:' \
        '--format=+[fmt]:f:(raw text hex base64 json csv)' \
        '--separate-direction[separate direction]' \
        '--include-headers[include headers]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'streamcap subcommand' sub ;;
        args)
            case $words[1] in
                follow|export) _arguments \
                    '--protocol=+[p]:p:(tcp udp http tls smb dns)' \
                    '*:stream id or pattern:' ;;
            esac
            ;;
    esac
}

_streamcap "$@"
