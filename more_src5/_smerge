#compdef smerge
# Documentation: https://www.sublimemerge.com/docs/command_line
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(- *)'{-v,--version}'[show version and exit]' \
  '(-n --new-window)'{-n,--new-window}'[open a new window]' \
  '(-b --background)'{-b,--background}"[don't activate the application]" \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'search:search for commits in the current repository'
      'blame:blame the given file in the current repository'
      'log:show the file history in the current repository'
      'mergetool:open the merge tool for the given files'
    )
    _describe -t commands 'smerge command' commands && ret=0
    _files -/
    ;;
  args)
    case $line[1] in
      search)
        _arguments -s -S \
          '*:query:' && ret=0
        ;;
      blame)
        _arguments -s -S \
          '1:file:_files' \
          '2:line:' && ret=0
        ;;
      log)
        _arguments -s -S \
          '1:file:_files' && ret=0
        ;;
      mergetool)
        _arguments -s -S \
          '--no-wait[do not wait for tool to close]' \
          '-o+[output merged file]:merged file:_files' \
          '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
