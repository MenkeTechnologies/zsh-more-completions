#compdef root root.exe
# Documentation: https://github.com/root-project/root/blob/master/core/base/src/root-argparse.py
# Documentation: https://github.com/root-project/root/blob/master/core/base/src/TApplication.cxx
# Reference accessed: 2026-05-27
# Verified: upstream root-argparse.py + TApplication::GetOptions() argv loop

# root: CERN ROOT interactive interpreter / C++ scripting environment.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,-\?,--help}'[show summary of options and exit]' \
  '(- *)--version[show ROOT version and exit]' \
  '(- *)-config[print ./configure options and exit]' \
  '-b[run in batch mode without graphics]' \
  '-x[exit on exceptions]' \
  '-q[exit after processing command line macro files]' \
  '-l[do not show the ROOT banner]' \
  '-n[do not execute logon and logoff macros from .rootrc]' \
  '-t[enable thread-safety and implicit multi-threading (IMT)]' \
  '-a[show the ROOT splash screen (Windows only)]' \
  '-splash[signal that splash screen can be popped down]' \
  '*-e+[execute the C++ statement passed as argument]:statement:' \
  '--web=-[use web-based display (optional =off or =chrome/firefox/qt6)]::mode:(off on default chrome firefox qt6 server)' \
  '--notebook[execute ROOT notebook]' \
  '--ptrcheck[enable cling pointer-validity checks]' \
  '*:file or macro:_files -g "*.(root|C|cpp|cxx|cc|so|dll|dylib)"' && ret=0

return ret
