#compdef s6-linux-init-maker
# Documentation: https://skarnet.org/software/s6-linux-init/s6-linux-init-maker.html
# Reference accessed: 2026-05-30
# s6-linux-init-maker — generate a complete stage-1 init system for a Linux box using s6-rc.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-V+[boot verbosity level (default 1)]:level:(0 1 2 3 4)' \
  '-c+[basedir for stage-1 init data (default /etc/s6-linux-init/current)]:dir:_directories' \
  '-u+[user for catch-all logger (default root)]:user:_users' \
  '-G+[early-getty service spec for boot-failure logins]:tty:' \
  '-1[copy catch-all logger messages to /dev/console]' \
  '-L[add s6-linux-init-logouthookd service for utmp cleanup]' \
  '-p+[initial PATH (default /usr/bin\:/bin)]:path:' \
  '-m+[initial umask (octal, default 022)]:umask:' \
  '-t+[log timestamp style]:style:((0\:none 1\:TAI64N 2\:ISO8601 3\:both))' \
  '-d+[devtmpfs mount directory]:dir:_directories' \
  '-s+[save kernel env vars to this directory]:dir:_directories' \
  '*-e+[add env var to global environment (key=value; repeatable)]:env:' \
  '-q+[SIGKILL grace period (ms; default 3000)]:ms:' \
  '-D+[default runlevel (default "default")]:runlevel:' \
  '(-n -N)-n[remount /run instead of unmount+remount]' \
  '(-n -N)-N[skip all /run mounting]' \
  '-f+[skeleton scripts directory]:dir:_directories' \
  '-R+[global system resource limits]:limits:' \
  '-C[enable container-specific configurations]' \
  '-B[disable catch-all logger]' \
  '-S[sync disks on container halt (with -C)]' \
  '-W[wait for fd EOF before booting]' \
  '1:output directory:_directories' \
  && ret=0

return ret
