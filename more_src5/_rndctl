#compdef rndctl
# Documentation: man rndctl(8)
# Source: netbsd/src sbin/rndctl — kernel entropy pool control (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-C[disable data collection for device]' \
    '-c[enable data collection for device]' \
    '-E[ignore entropy estimates from drivers]' \
    '-e[accept entropy estimates from drivers]' \
    '(-t)-d+[operate on named device only]:devname:_default' \
    '(-d)-t+[operate on device type]:devtype:(disk net tape tty rng)' \
    '-i[ignore entropy estimate when loading seed]' \
    '-L+[load and update seed from file]:save-file:_files' \
    '-l[list sources]' \
    '-S+[generate and save entropy seed to file]:save-file:_files' \
    '-s[display entropy pool statistics]' \
    '-v[verbose output]' \
    && ret=0

return ret
