#compdef sketchybar
# Documentation: https://felixkratz.github.io/SketchyBar/setup
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above plus repo src/sketchybar.c
# (which parses -h/--help, -v/--version, -V/verbose, -m/--message,
# -c/--config). The remaining flags (--bar, --add, etc.) are the
# message-domain commands invoked through sketchybar (see
# https://felixkratz.github.io/SketchyBar/config/ for full list).

# Zsh completion for sketchybar - custom macOS status bar

_arguments -s -S \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbose)'{-V,--verbose}'[verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config}'[load configuration from file]:file:_files' \
  '--load-font[load a font from path]:file:_files' \
  '(-m --message)'{-m,--message}'[send a message to a running instance]:message:' \
  '--bar[configure the bar]:properties:' \
  '--add[add item to the bar]:type name:' \
  '--set[set properties of an item]:item properties:' \
  '--remove[remove item from the bar]:item:' \
  '--update[update all items]' \
  '--trigger[trigger a custom event]:event:' \
  '--subscribe[subscribe to events]:item events:' \
  '--push[push data to an item]:item data:' \
  '--animate[run animations]:interpolation duration:' \
  '--reload[reload configuration]' \
  '--query[query an item]:item:' \
  '--default[set default item properties]:properties:' \
  '--clone[clone an item]:source target:' \
  '--move[move items]:item before after:' \
  '--rename[rename an item]:old new:' \
  '--hotload[toggle hot reloading]:state:(on off)' \
  '--event[declare a custom event]:event:' \
  '--order[set item order]:items:'
