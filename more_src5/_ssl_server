#compdef ssl_server ssl_server2 ssl_fork_server ssl_pthread_server
# Documentation: https://github.com/Mbed-TLS/mbedtls/tree/development/programs/ssl
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
#
# ssl_server, ssl_fork_server, ssl_pthread_server are hardcoded demo programs with NO arguments.
# Only ssl_server2 accepts param=value style options.

local curcontext="$curcontext" state line ret=1
local -a params

# Subset of ssl_server2 param=value options verified against programs/ssl/ssl_server2.c DFL_* defines.
params=(
  'server_addr=:bind address'
  'server_port=:bind port'
  'debug_level=:debug level'
  'ca_file=:trusted CA file'
  'ca_path=:trusted CA directory'
  'crt_file=:server certificate'
  'key_file=:server key'
  'key_pwd=:server key password'
  'crt_file2=:second server certificate'
  'key_file2=:second server key'
  'key_pwd2=:second server key password'
  'psk=:pre-shared key'
  'psk_identity=:PSK identity'
  'force_ciphersuite=:force a single ciphersuite'
  'auth_mode=:authentication mode'
  'min_version=:minimum TLS version'
  'max_version=:maximum TLS version'
)

if [[ ${words[1]} != ssl_server2 ]]; then
  # ssl_server, ssl_fork_server, ssl_pthread_server take no arguments
  return 1
fi

_arguments -s -S \
  '*:param=value:->params' && ret=0

case $state in
  (params)
    if compset -P '(ca_file|crt_file|crt_file2|key_file|key_file2)='; then
      _files && ret=0
    elif compset -P 'ca_path='; then
      _files -/ && ret=0
    elif compset -P 'auth_mode='; then
      _values 'auth mode' none optional required && ret=0
    elif compset -P '(min_version|max_version)='; then
      _values 'TLS version' tls12 tls13 dtls12 && ret=0
    else
      _describe -t params 'param' params -S '' && ret=0
    fi
    ;;
esac

return ret
