#compdef sfclip
# Documentation: http://www.ahay.org/RSF/sfclip.html
# Source: ahay/src system/generic/Mclip.c — clip values above/below a threshold.
# Reference accessed: 2026-06-10
#
# Output: clip if input > clip, -clip if input < -clip, input if |input| < clip.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'clip=[clip value (threshold)]: :_default' \
    'value=[replacement value (default = clip)]: :_default' \
    '*:RSF file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
