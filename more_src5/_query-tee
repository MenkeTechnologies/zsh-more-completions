#compdef query-tee
# _query-tee — Grafana Mimir query response comparator proxy (grafana/mimir)
# upstream: https://github.com/grafana/mimir
# Flags from cmd/query-tee/main.go + tools/querytee/proxy.go RegisterFlags on tip.

_query-tee() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-server.metrics-port=[port exposing /metrics]:port:' \
        '-server.http-service-port=[HTTP request listen port]:port:' \
        '-server.grpc-service-port=[HTTP-over-gRPC listen port]:port:' \
        '-backend.endpoints=[comma-separated backend endpoint URLs]:list:' \
        '-backend.skip-tls-verify[skip TLS verification on backends]' \
        '-backend.preferred=[preferred backend hostname]:host:' \
        '-backend.read-timeout=[backend response read timeout]:dur:' \
        '-backend.config-file=[YAML/JSON per-backend config file]:file:_files' \
        '-proxy.compare-responses[compare responses across backends]' \
        '-proxy.log-slow-query-response-threshold=[slow query log threshold]:dur:' \
        '-proxy.compare-use-relative-error[use relative tolerance for floats]' \
        '-proxy.compare-skip-recent-samples=[lookback window to skip in comparison]:dur:' \
        '-proxy.compare-exact-error-matching[require exact error match]' \
        '-proxy.compare-skip-preferred-backend-failures[skip comparison on preferred 5xx]' \
        '-proxy.passthrough-non-registered-routes[passthrough unknown routes to preferred]' \
        '-proxy.add-missing-time-parameter-to-instant-queries[inject time param into instant queries]' \
        '-proxy.backends-lookback-delta=[backend lookback delta]:dur:' \
        '-log.level=[log level]:level:(debug info warn error)' \
        '-log.format=[log format]:fmt:(logfmt json)'
}

_query-tee "$@"
