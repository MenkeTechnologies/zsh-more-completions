#compdef stringtie
# Documentation: https://ccb.jhu.edu/software/stringtie/index.shtml?t=manual
# Reference accessed: 2026-05-21
# Verified: upstream StringTie manual at CCB Johns Hopkins. All flags
# below match the documented assembly + merge modes.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '-G+[reference annotation GTF/GFF]:file:_files -g "*.(gtf|gff|gff3)"' \
  '-o+[output GTF file]:file:_files' \
  '-l+[label prefix for output transcripts]:prefix:' \
  '-f+[minimum isoform fraction]:fraction:' \
  '-L[long reads processing mode]' \
  '--mix[process both short and long read alignments]' \
  '--ptf=[point-features (TSS, CPAS) file]:file:_files' \
  '-m+[minimum transcript length]:length:' \
  '-a+[minimum anchor length for junctions]:length:' \
  '-j+[minimum junction coverage]:coverage:' \
  '-t[disable trimming of predicted transcripts]' \
  '-c+[minimum reads per bp coverage]:coverage:' \
  '-s+[minimum single-exon coverage]:coverage:' \
  '-g+[max gap between reads in a bundle]:gap:' \
  '-M+[fraction of multi-mapped reads]:fraction:' \
  '-p+[number of threads]:threads:' \
  '-A+[gene abundances output]:file:_files' \
  '-B[enable output of Ballgown table files]' \
  '-b+[path for Ballgown tables]:dir:_files -/' \
  '-C+[output fully covered reference transcripts]:file:_files' \
  '-e[only estimate abundance for given annotation]' \
  '-u[disable multi-mapping correction]' \
  '-x+[ignore reference sequences]:comma-separated list:' \
  '--conservative[conservative assembly mode]' \
  '--ref=[reference genome for CRAM input]:file:_files' \
  '--cram-ref=[reference genome for CRAM input]:file:_files' \
  '--merge[transcript merge mode]' \
  '-i[keep merged transcripts with retained introns (merge mode)]' \
  '-F+[minimum input transcript FPKM (merge mode)]:fpkm:' \
  '-T+[minimum input transcript TPM (merge mode)]:tpm:' \
  '--rf[assume stranded library - first read reverse]' \
  '--fr[assume stranded library - first read forward]' \
  '-v[verbose mode]' \
  '*:BAM file:_files -g "*.(bam|cram)"' && ret=0

return ret
