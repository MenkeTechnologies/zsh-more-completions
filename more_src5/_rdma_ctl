#compdef rdma_ctl
# Documentation: rdma_ctl --help (Apple macOS RDMA control utility)
# Reference accessed: 2026-05-20
# Verified: rdma_ctl -h output: Usage: rdma_ctl <status|enable|disable>.

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:command:(status enable disable)' && ret=0

return ret
