#compdef shuffledns
# Documentation: https://github.com/projectdiscovery/shuffledns
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above. Flag inventory aligned to the
# real shuffledns flag set (single-dash long options per projectdiscovery
# convention; -v is verbose, not version; -version is the version flag).
# Removed/corrected: fake -h/--help, -v/--version, -t/--threads (-- prefixes
# not used upstream). Added missing flags: -ad, -tr, -j, -wo, -mcmd, -mode,
# -nc, -up, -duc, -version.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-d+[target domain(s)]:domain' \
  '-domain+[target domain(s)]:domain' \
  '-ad[auto-extract root domains]' \
  '-auto-domain[auto-extract root domains]' \
  '-l+[subdomain list file]:list:_files' \
  '-list+[subdomain list file]:list:_files' \
  '-w+[bruteforce wordlist file]:wordlist:_files' \
  '-wordlist+[bruteforce wordlist file]:wordlist:_files' \
  '-r+[resolver list file]:resolvers:_files' \
  '-resolver+[resolver list file]:resolvers:_files' \
  '-tr+[trusted resolver list]:resolvers:_files' \
  '-trusted-resolver+[trusted resolver list]:resolvers:_files' \
  '-ri[validate raw massdns output]' \
  '-raw-input[validate raw massdns output]' \
  '-t+[concurrent massdns resolves (default 10000)]:threads' \
  '-o+[output file]:file:_files' \
  '-output+[output file]:file:_files' \
  '-j[NDJSON output]' \
  '-json[NDJSON output]' \
  '-wo+[wildcard IPs output file]:file:_files' \
  '-wildcard-output+[wildcard IPs output file]:file:_files' \
  '-m+[massdns binary path]:binary:_files' \
  '-massdns+[massdns binary path]:binary:_files' \
  '-mcmd+[optional massdns commands]:cmd' \
  '-massdns-cmd+[optional massdns commands]:cmd' \
  '-directory+[temporary directory]:directory:_directories' \
  '-mode+[execution mode]:mode:(bruteforce resolve filter)' \
  '-retries+[DNS retries (default 5)]:retries' \
  '-sw[wildcard checking on all subdomains]' \
  '-strict-wildcard[wildcard checking on all subdomains]' \
  '-wt+[concurrent wildcard checks (default 250)]:threads' \
  '-silent[subdomains only output]' \
  '-v[verbose output]' \
  '-nc[disable colors]' \
  '-no-color[disable colors]' \
  '-version[show version]' \
  '-up[update tool]' \
  '-update[update tool]' \
  '-duc[skip update checks]' \
  '-disable-update-check[skip update checks]' && ret=0

return ret
