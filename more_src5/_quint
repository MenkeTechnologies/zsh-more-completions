#compdef quint
# Documentation: https://github.com/informalsystems/quint/blob/main/quint/src/cli.ts
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--out=[output file path]:file:_files' \
  '--main=[main module name]:name' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'repl:Start interactive Quint REPL'
      'parse:Parse a Quint specification'
      'typecheck:Type-check a specification'
      'compile:Compile to target language'
      'run:Simulate a specification'
      'test:Run Quint tests'
      'verify:Model-check via Apalache or TLC'
      'docs:Generate documentation'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    case $line[1] in
      repl)
        _arguments \
          '(-r --require)'{-r,--require}'=[preload file]:file:_files' \
          '(-q --quiet)'{-q,--quiet}'[disable banners]' \
          '--verbosity=[output verbosity 0-5]:level:(0 1 2 3 4 5)' \
          '--seed=[random seed]:seed' \
          '--backend=[evaluation backend]:backend:(typescript rust)' && ret=0
        ;;
      compile)
        _arguments \
          '--target=[compile target]:target:(tlaplus json)' \
          '--flatten[flatten modules into one]' \
          '--verbosity=[output verbosity 0-5]:level:(0 1 2 3 4 5)' \
          '--apalache-version=[Apalache version]:version' \
          '--server-endpoint=[server endpoint]:host:port' && ret=0
        ;;
      run)
        _arguments \
          '--out-itf=[trace output file]:file:_files' \
          '--max-samples=[maximum samples]:n' \
          '--n-traces=[number of traces]:n' \
          '--max-steps=[max steps per trace]:n' \
          '--n-threads=[thread count]:n' \
          '--invariant=[invariants]:invariants' \
          '--invariants=[invariants]:invariants' \
          '--witnesses=[witness expressions]:witnesses' \
          '--hide=[variables to hide]:vars' \
          '--seed=[random seed]:seed' \
          '--verbosity=[output verbosity 0-5]:level:(0 1 2 3 4 5)' \
          '--mbt[MBT metadata in traces]' \
          '--backend=[simulation backend]:backend:(typescript rust)' && ret=0
        ;;
      test)
        _arguments \
          '--out-itf=[trace output file]:file:_files' \
          '--max-samples=[max samples per test]:n' \
          '--seed=[random seed]:seed' \
          '--verbosity=[output verbosity 0-5]:level:(0 1 2 3 4 5)' \
          '--match=[test name filter]:pattern' \
          '--backend=[testing backend]:backend:(typescript rust)' && ret=0
        ;;
      verify)
        _arguments \
          '--invariants=[invariants]:invariants' \
          '--inductive-invariant=[inductive invariant]:invariant' \
          '--out-itf=[trace output file]:file:_files' \
          '--max-steps=[max steps per trace]:n' \
          '--random-transitions[use symbolic simulation]' \
          '--apalache-config=[Apalache config]:file:_files' \
          '--verbosity=[output verbosity 0-5]:level:(0 1 2 3 4 5)' \
          '--apalache-version=[Apalache version]:version' \
          '--server-endpoint=[server endpoint]:host:port' \
          '--backend=[verification backend]:backend:(apalache tlc)' \
          '--tlc-config=[TLC config file]:file:_files' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
