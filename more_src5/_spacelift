#compdef spacectl
# Documentation: https://github.com/spacelift-io/spacectl
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Spacelift CLI (spacectl) completion

_spacectl_subcommands() {
  local -a subcmds=(
    'stack:Manage a Spacelift stack'
    'module:Manage a Spacelift module'
    'blueprint:Manage Spacelift blueprints'
    'policy:Manage Spacelift policies'
    'provider:Manage a Terraform provider'
    'workerpool:Manage workerpools and their workers'
    'audit-trail:Manage Spacelift audit trail entries'
    'run-external-dependency:Manage Spacelift Run external dependencies'
    'profile:Manage Spacelift profiles'
    'whoami:Print out logged-in user info'
    'mcp:Manage MCP server'
    'version:Print out CLI version'
  )
  _describe -t commands 'spacectl subcommand' subcmds
}

_spacectl() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[print version number]' \
    '1:subcommand:_spacectl_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        stack)
          local -a stack_cmds=(
            'list:List accessible stacks'
            'show:Show detailed stack information'
            'open:Open stack in browser'
            'set-current-commit:Set current commit on stack'
            'sync-commit:Sync tracked stack commit'
            'lock:Lock a stack for exclusive use'
            'unlock:Unlock a stack'
            'enable:Enable new runs'
            'disable:Disable new runs'
            'delete:Delete a stack'
            'deploy:Start a deployment (tracked run)'
            'preview:Start a preview (proposed run)'
            'promote:Promote a proposed run to a tracked run'
            'confirm:Confirm an unconfirmed tracked run'
            'discard:Discard an unconfirmed tracked run'
            'cancel:Cancel a run that has not started'
            'stop:Stop a running run'
            'approve:Approve a run or task'
            'reject:Reject a run or task'
            'retry:Retry a failed run'
            'replan:Replan an unconfirmed tracked run'
            'changes:Show changes for a given run'
            'logs:Show logs for a particular run'
            'prioritize:Prioritize a run'
            'deprioritize:Deprioritize a run'
            'task:Perform a task in a stack'
            'local-preview:Start preview based on current project'
            'environment:Manage stack environment variables (setvar/list/mount/delete)'
            'state:Pull stack state'
            'outputs:Show current stack outputs'
            'resources:List resources for a stack'
            'dependencies:Manage stack dependencies (on/off)'
          )
          _arguments -C \
            '(- *)'{-h,--help}'[show help]' \
            '1:action:->stack_action' \
            '*::arg:->stack_args'
          case $state in
            stack_action) _describe -t cmds 'stack action' stack_cmds ;;
            stack_args)
              _arguments \
                '(- *)'{-h,--help}'[show help]' \
                '--id=[stack ID]:stack id:'
              ;;
          esac
          ;;
        blueprint|module|policy|provider|workerpool|audit-trail)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
        whoami)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
        profile)
          local -a profile_cmds=(
            'login:Log in and create a profile'
            'logout:Log out of a profile'
            'select:Select a profile'
            'current:Show currently selected profile'
            'list:List profiles'
            'export-token:Export an API token'
            'usage-csv:Export usage CSV'
          )
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '1:action:->profile_action'
          case $state in
            profile_action) _describe -t cmds 'profile action' profile_cmds ;;
          esac
          ;;
      esac
      ;;
  esac
}

_spacectl "$@"
