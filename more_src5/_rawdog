#compdef rawdog
# Documentation: https://github.com/AbanteAI/rawdog
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for rawdog - LLM code runner

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[help]' \
  '--leash[print and manually approve each script before executing]' \
  '--retries=[number of retries if a script throws an error]:n' \
  '*: :_default' && ret=0

return ret
