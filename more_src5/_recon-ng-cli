_recon-ng-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-w+[workspace]:str:' \
        '--workspace=+[name]:str:' \
        '-r+[resource file]:file:_files -g "*.rc"' \
        '--resource=+[file]:file:_files -g "*.rc"' \
        '-c+[command]:str:' \
        '--command=+[cmd]:str:' \
        '-C+[global options command]:str:' \
        '--global-options=+[cmd]:str:' \
        '-A+[accessible]:str:' \
        '--accessible[accessible mode]' \
        '--check-mode[check mode]' \
        '-x[no analytics]' \
        '--no-analytics[no analytics]' \
        '--no-marketplace[no marketplace]' \
        '--no-version-check[no version check]' \
        '--dev[dev mode]' \
        '*:args:'
}

_recon-ng-cli "$@"
