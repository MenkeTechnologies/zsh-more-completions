#compdef spliceai
# _spliceai — Illumina spliceai CLI deep neural network splicing variant predictor predicting acceptor donor gain loss effect of small variants on RNA splicing from genomic VCF files producing per-variant splice score per-allele delta-score window-aware nucleotide-level annotations (Illumina team, Python); argparse
# upstream: https://github.com/Illumina/SpliceAI

_spliceai() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-I+[input vcf]:file:_files -g "*.vcf *.vcf.gz"' \
        '--input=+[file]:file:_files -g "*.vcf *.vcf.gz"' \
        '-O+[output vcf]:file:_files -g "*.vcf *.vcf.gz"' \
        '--output=+[file]:file:_files -g "*.vcf *.vcf.gz"' \
        '-R+[reference fasta]:file:_files -g "*.fa *.fasta *.fna"' \
        '--reference=+[file]:file:_files -g "*.fa *.fasta *.fna"' \
        '-A+[annotation]:a:(grch37 grch38)' \
        '--annotation=+[a]:a:(grch37 grch38)' \
        '-D+[distance bp]:n:' \
        '--distance=+[bp]:n:' \
        '-M+[mask]:n:(0 1)' \
        '--mask=+[N]:n:(0 1)' \
        '*::'
}

_spliceai "$@"
