#compdef s6-tcpclient
# Documentation: https://skarnet.org/software/s6-networking/s6-tcpclient.html
# Reference accessed: 2026-05-30
# s6-tcpclient — TCP client runner. Connects to host:port and runs program with stdin/stdout connected.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-q -Q -v)-q[quiet mode]' \
  '(-q -Q -v)-Q[normal verbosity (default)]' \
  '(-q -Q -v)-v[verbose mode]' \
  '(-4 -6)-4[IPv4 only]' \
  '(-4 -6)-6[IPv6 only]' \
  '(-d -D)-d[disable TCP_NODELAY (default)]' \
  '(-d -D)-D[enable TCP_NODELAY]' \
  '(-h -H)-h[check /etc/hosts before DNS]' \
  '(-h -H)-H[skip DNS lookups entirely]' \
  '(-n -N)-n[qualify host during resolution]' \
  '(-n -N)-N[do not qualify host (default)]' \
  '(-r -R)-r[obtain TCPREMOTEINFO via IDENT]' \
  '(-r -R)-R[disable IDENT (default)]' \
  '-t+[global connection timeout (seconds)]:sec:' \
  '-T+[connection attempt timeouts x+y (default 2+58)]:x+y:' \
  '-i+[bind to specific local IP]:ip:' \
  '-p+[bind to specific local port]:port:' \
  '-l+[set TCPLOCALHOST value]:name:' \
  '1:host:_hosts' \
  '2:port:' \
  '*:program + args:_command_names -e' \
  && ret=0

return ret
