#compdef supervise
# Documentation: https://cr.yp.to/daemontools/supervise.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# No flags; takes one positional service-directory argument.

# supervise: daemontools service supervisor (positional only)
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:service dir (contains ./run):_files -/' && ret=0
return ret
