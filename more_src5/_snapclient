#compdef snapclient
# Documentation: https://raw.githubusercontent.com/badaix/snapcast/master/client/snapclient.1
# Reference accessed: 2026-05-21
# Verified: upstream snapclient.1 man page at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--list[list available PCM devices]' \
  '(-h --host)'{-h,--host}'=[server hostname/IP (deprecated; use URL)]:host:_hosts' \
  '(-p --port)'{-p,--port}'=[server port (default 1704; deprecated; use URL)]:port:' \
  '(-s --soundcard)'{-s,--soundcard}'=[PCM device by index or name]:device:' \
  '--latency=[PCM device latency]:milliseconds:' \
  '--sampleformat=[resample to rate:bits:channels]:format:' \
  '--hostID=[custom host identifier (default MAC)]:id:' \
  '--cert=[client certificate PEM]:file:_files' \
  '--cert-key=[client private key PEM]:file:_files' \
  '--key-password=[encrypted key password]:password:' \
  '--server-cert[verify server CA certificate]' \
  '--player=[audio backend]:player:(alsa pipewire file)' \
  '--mixer=[mixer type]:mode:(software hardware script none)' \
  '(-d --daemon)'{-d,--daemon}'=[daemonize with optional priority -20..19]:priority:' \
  '--user=[user/group for daemon execution]:user:_users' \
  '--logsink=[log destination]:sink:(null system stdout stderr file)' \
  '--logfilter=[log filter (default *:info)]:filter:' \
  '(-i --instance)'{-i,--instance}'=[instance ID for multiple clients]:instance:' \
  '*:url:' && ret=0

return ret
