#compdef svnadmin
# Documentation: svnadmin help (Subversion)
# Source: Subversion repository administration tool.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args state line
local -a subcommands

subcommands=(
    'build-repcache:populate caches in the FSFS data store'
    'create:create a new empty repository'
    'crashtest:open a repository, then exit (test loadability)'
    'delrevprop:delete a revision property'
    'deltify:deltify or undeltify changed paths in revs'
    'dump:dump contents of repository to stdout'
    'dump-revprops:dump revision properties of REPOS_PATH'
    'freeze:make a repository read-only'
    'help:describe subcommand usage'
    'hotcopy:make a hot copy of a repository'
    'info:print information about a repository'
    'list-dblogs:list Berkeley DB log files'
    'list-unused-dblogs:list unused Berkeley DB log files'
    'load:read repository contents from stdin'
    'load-revprops:load revision properties from stdin'
    'lock:lock a path in the repository'
    'lslocks:print descriptions of all locks'
    'lstxns:print outstanding transactions'
    'pack:efficiently compress repository contents'
    'recover:run recovery procedures'
    'rev-size:print the total size of changed file content'
    'rmlocks:unconditionally remove locks'
    'rmtxns:delete transactions'
    'setlog:set log message on revision'
    'setrevprop:set value of revision property'
    'setuuid:reset repository UUID'
    'unlock:unlock a path'
    'upgrade:upgrade repository to latest schema'
    'verify:verify data stored in repository'
)

_arguments -s -C \
    '(- *)--version[show version]' \
    '(- *)'{-h,-?,--help}'[show help]' \
    '(-q --quiet)'{-q,--quiet}'[suppress informational messages]' \
    '(-r --revision)'{-r+,--revision=}'[revision or range]:rev:' \
    '--bypass-hooks[bypass repository hooks]' \
    '--bypass-prop-validation[skip property validation]' \
    '--clean-logs[remove logs no longer needed]' \
    '--deltas[output deltas in dump]' \
    '--ignore-uuid[ignore any repository UUID]' \
    '--force-uuid[set repository UUID]' \
    '--incremental[dump revs incrementally]' \
    '--parent-dir=[parent directory under which to load]:dir:' \
    '--use-pre-commit-hook[run pre-commit hook on loaded revs]' \
    '--use-post-commit-hook[run post-commit hook on loaded revs]' \
    '--use-pre-revprop-change-hook[run pre-revprop-change hook]' \
    '--use-post-revprop-change-hook[run post-revprop-change hook]' \
    '--fs-type=[filesystem type for new repos]:type:(fsfs bdb fsx)' \
    '--config-dir=[config files dir]:dir:_files -/' \
    '--memory-cache-size=[memory cache size in MB]:mb:' \
    '--no-flush-to-disk[do not flush changes to disk]' \
    '--exclude=[exclude path patterns]:pattern:' \
    '--include=[include path patterns]:pattern:' \
    '1:subcommand:->cmds' \
    '2:repos-path:_files -/' \
    '*::args:->args' \
    && ret=0

case $state in
    cmds) _describe -t subcommands 'svnadmin subcommand' subcommands && ret=0 ;;
    args) _files && ret=0 ;;
esac

return ret
