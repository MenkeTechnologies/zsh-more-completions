#compdef rgrc
# Documentation: https://github.com/BurntSushi/ripgrep/blob/master/GUIDE.md
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# STUB: rgrc has no widely-published canonical CLI. Best-effort completion
# only — defer to commands and files. The flag list previously asserted
# could not be verified against a primary source and has been removed.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:_command_names -e' \
  '*::args:_files' && ret=0

return ret
