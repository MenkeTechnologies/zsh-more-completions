#compdef stonith_admin
# Documentation: https://manpages.debian.org/bookworm/pacemaker-cli-utils/stonith_admin.8.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# stonith_admin: manage Pacemaker fencing devices (stonithd)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)--help-all[show all help]' \
  '(- *)--help-output[show output help]' \
  '(- *)--help-definition[show definition help]' \
  '(- *)--help-queries[show queries help]' \
  '(- *)--help-fence[show fence help]' \
  '(- *)--help-additional[show additional help]' \
  '(- *)'{-\$,--version}'[show version]' \
  '(-V --verbose)'{-V,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '--output-as=[output format]:format:(text xml html)' \
  '--output-to=[output destination]:destination:_files' \
  '--html-cgi[HTML CGI mode]' \
  '--html-stylesheet=[HTML stylesheet URI]:uri:' \
  '--html-title=[HTML title]:title:' \
  '--text-fancy[fancy text output]' \
  '(-R --register)'{-R,--register=}'[register device]:device:' \
  '(-D --deregister)'{-D,--deregister=}'[deregister device]:device:' \
  '(-r --register-level)'{-r,--register-level=}'[register fencing level for target]:target:' \
  '(-d --deregister-level)'{-d,--deregister-level=}'[deregister fencing level for target]:target:' \
  '(-l --list)'{-l,--list=}'[list nodes fenced by device]:host:' \
  '(-L --list-registered)'{-L,--list-registered}'[list registered fencing devices]' \
  '(-I --list-installed)'{-I,--list-installed}'[list installed fencing agents]' \
  '(-s --list-targets)'{-s,--list-targets=}'[list targets of fencing device]:device:' \
  '(-M --metadata)'{-M,--metadata}'[show metadata for fencing agent]' \
  '(-Q --query)'{-Q,--query=}'[query device state]:device:' \
  '(-H --history)'{-H,--history=}'[show fence history for node]:node:' \
  '(-h --last)'{-h,--last=}'[show last fence operation for node]:node:' \
  '(-K --validate)'{-K,--validate}'[validate fencing device configuration]' \
  '(-F --fence)'{-F,--fence=}'[fence host]:host:' \
  '(-U --unfence)'{-U,--unfence=}'[unfence host]:host:' \
  '(-B --reboot)'{-B,--reboot=}'[reboot host via fencing]:host:' \
  '(-C --confirm)'{-C,--confirm=}'[confirm host fenced]:host:' \
  '(-c --cleanup)'{-c,--cleanup}'[cleanup fence history]' \
  '(-b --broadcast)'{-b,--broadcast}'[broadcast operation]' \
  '(-a --agent)'{-a,--agent=}'[fencing agent type]:agent:' \
  '*'{-o,--option=}'[set device parameter]:name=value:' \
  '*'{-e,--env-option=}'[set parameter from environment]:name=env:' \
  '(-T --tag)'{-T,--tag=}'[operation tag]:tag:' \
  '(-v --device)'{-v,--device=}'[device for the operation]:device:' \
  '(-i --index)'{-i,--index=}'[fencing level index]:level:' \
  '(-t --timeout)'{-t,--timeout=}'[operation timeout in seconds]:seconds:' \
  '(-y --delay)'{-y,--delay=}'[delay in seconds]:seconds:' \
  '(-n --as-node-id)'{-n,--as-node-id}'[interpret target as node id]' \
  '--tolerance=[history tolerance in seconds]:seconds:' && ret=0
return ret
