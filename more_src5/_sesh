#compdef sesh
# Documentation: https://github.com/joshmedeski/sesh
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.
# Added from upstream: kill, last, window, picker subcommands; -b/-H/-d/-T
# list flags; --switch/--root connect flags; -C/--config global.

local curcontext="$curcontext" state line ret=1

_sesh_commands() {
  local -a commands=(
    'connect:attach to a tmux session (create if missing)'
    'list:list sessions from tmux, configs, and zoxide'
    'clone:clone a git repo and start a session'
    'window:manage tmux windows within a session'
    'picker:launch interactive built-in session selector'
    'root:jump to the root of the git worktree/repo'
    'last:switch attached client back to the last session'
    'kill:terminate a tmux session'
  )
  _describe -t commands 'sesh command' commands
}

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-C --config)'{-C,--config}'[custom config file path]:file:_files' \
  '1:command:_sesh_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      connect)
        _arguments -s -S \
          '(-c --command)'{-c,--command}'[run command after connecting]:command:' \
          '--switch[attach to session]' \
          '--root[connect to root session]' \
          '*:session name:' && ret=0
        ;;
      list)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'[show configured sessions]' \
          '(-H --hide-attached)'{-H,--hide-attached}'[hide attached sessions]' \
          '(-i --icons)'{-i,--icons}'[show nerd font icons]' \
          '(-j --json)'{-j,--json}'[output as JSON]' \
          '(-t --tmux)'{-t,--tmux}'[show tmux sessions]' \
          '(-z --zoxide)'{-z,--zoxide}'[show zoxide results]' \
          '(-b --blacklisted)'{-b,--blacklisted}'[show blacklisted sessions]' \
          '(-d --depth)'{-d,--depth}'[limit depth]:depth:' \
          '(-T --hide-types)'{-T,--hide-types}'[include session types]' && ret=0
        ;;
      clone)
        _arguments -s -S '*:repository:' && ret=0
        ;;
      kill)
        _arguments -s -S '*:session name:' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac
return ret
