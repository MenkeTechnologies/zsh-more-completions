#compdef quark
# Documentation: https://www.kali.org/tools/quark-engine/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above and github.com/quark-engine/quark-engine.

_arguments -s \
  '--version[show version]' \
  '(-s --summary)'{-s,--summary}'=[summary report]:rule:' \
  '(-d --detail)'{-d,--detail}'=[detail report]:rule:' \
  '(-o --output)'{-o,--output}'=[JSON output]:file:_files' \
  '(-w --webreport)'{-w,--webreport}'=[HTML report]:file:_files' \
  '*'{-a,--apk}'=[APK file]:file:_files' \
  '(-r --rule)'{-r,--rule}'=[rules file or dir]:path:_files' \
  '(-g --graph)'{-g,--graph}'=[call graph]:fmt:(png json)' \
  '(-c --classification)'{-c,--classification}'[show classification]' \
  '(-t --threshold)'{-t,--threshold}'=[confidence]:n:(20 40 60 80 100)' \
  '(-i --list)'{-i,--list}'=[list]:mode:(all native custom)' \
  '(-p --permission)'{-p,--permission}'[list permissions]' \
  '(-l --label)'{-l,--label}'=[label report]:mode:(max detailed)' \
  '(-C --comparison)'{-C,--comparison}'[behavior comparison]' \
  '--generate-rule=[output dir]:dir:_files -/' \
  '--core-library=[core lib]:lib:(androguard rizin)' \
  '--multi-process=[procs]:n:' \
  '(- *)--help[show help]'
