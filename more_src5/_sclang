#compdef sclang
# Documentation: https://github.com/supercollider/supercollider/blob/develop/lang/LangSource/SC_CLIOptions.cpp
# Reference accessed: 2026-05-21
# Verified: upstream SC_CLIOptions.cpp boost::program_options table.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --runtime-directory)'{-d+,--runtime-directory=}'[set runtime directory]:dir:_files -/' \
  '(-D --daemon)'{-D,--daemon}'[enter daemon mode]' \
  '(-g --heap-growth)'{-g+,--heap-growth=}'[heap growth size (k/m/g suffix)]:size:' \
  '(-l --yaml-config)'{-l+,--yaml-config=}'[YAML config file]:file:_files' \
  '(-m --heap-size)'{-m+,--heap-size=}'[initial heap size (k/m/g suffix)]:size:' \
  '(-r --call-run)'{-r,--call-run}'[call Main.run on startup]' \
  '(-s --call-stop)'{-s,--call-stop}'[call Main.stop on shutdown]' \
  '(-u --port)'{-u+,--port=}'[UDP listening port]:port:' \
  '(-i --ide)'{-i+,--ide=}'[set IDE name]:ide:' \
  '(-a --exclude-default-paths)'{-a,--exclude-default-paths}'[exclude default class library and extension paths (standalone)]' \
  '*--include-path=[class library path to include]:dir:_files -/' \
  '*--exclude-path=[class library path to exclude]:dir:_files -/' \
  '--post-inline-warnings[warn about missing inline opportunities]' \
  '*:scd_file:_files -g "*.(sc|scd)"' && ret=0

return ret
