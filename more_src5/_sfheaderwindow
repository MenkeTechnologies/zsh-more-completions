#compdef sfheaderwindow
# Documentation: http://www.ahay.org/RSF/sfheaderwindow.html
# Source: ahay/src system/main/headerwindow.c — window an RSF dataset by an integer header mask.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'mask=[header file (integer mask array of size n2)]: :_files -g "*.rsf(-.)"' \
    'inv=[(y/n) inverse window (expand masked traces back)]: :(y n)' \
    '*:RSF file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
