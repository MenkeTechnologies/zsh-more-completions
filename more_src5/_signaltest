#compdef signaltest
# Documentation: https://wiki.linuxfoundation.org/realtime/documentation/howto/tools/rt-tests
# Source: rt-tests src/signaltest/signaltest.c — measure signal delivery latency between threads.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-\?,--help}'[show help]' \
    '(-b --breaktrace)'{-b+,--breaktrace=}'[send break trace when latency > USEC]:usec:_default' \
    '(-l --loops)'{-l+,--loops=}'[number of loops (0=endless)]:n:_default' \
    '(-p --priority)'{-p+,--priority=}'[highest-priority thread priority]:prio:_default' \
    '(-q --quiet)'{-q,--quiet}'[only print summary on exit]' \
    '(-t --threads)'{-t+,--threads=}'[number of threads (default 2)]:n:_default' \
    '(-v --verbose)'{-v,--verbose}'[output values on stdout]' \
    '(-m --mlockall)'{-m,--mlockall}'[lock current and future memory]' \
    && ret=0

return ret
