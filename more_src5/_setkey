#compdef setkey
# _setkey — KAME setkey (IPv4/IPv6 IPsec SA/SP manager that talks to the kernel PF_KEY socket; -c read commands from stdin, -f read from file, -F flush all SAs, -FP flush all SPs, -D dump SAD, -DP dump SPD, -P parse without execute, -h hexdump, -x exit on error, -v verbose, -p paranoid mode (require key file), -V show version)
# upstream: https://github.com/iputils/iputils (setkey) or sourceforge ipsec-tools
# Flags from KAME setkey src/setkey.c on tip.

_setkey() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c[read commands from stdin]' \
        '-f+[command file]:file:_files' \
        '-F[flush SAD]' \
        '-D[dump SAD]' \
        '-FP[flush SPD]' \
        '-DP[dump SPD]' \
        '-P[parse without execute]' \
        '-x[exit on first error]' \
        '-v[verbose]' \
        '-p[paranoid mode]'
}

_setkey "$@"
