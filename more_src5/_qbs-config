#compdef qbs-config
# _qbs-config — Qt Project qbs-config CLI command-line viewer and editor for qbs persistent build-configuration settings located under ~/.config/QtProject/qbs.conf listing exporting importing per-profile keys with name=value model nested section traversal (Qt Project team, C++); custom argparse
# upstream: https://doc.qt.io/qbs/qbs-config.html

_qbs-config() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-l[list all settings]' \
        '--list[list all settings]' \
        '-u[unset a setting]' \
        '--unset[unset a setting]' \
        '-g[user scope]' \
        '--global[user scope]' \
        '-s[system scope]' \
        '--system[system scope]' \
        '--export=+[file]:file:_files' \
        '--import=+[file]:file:_files' \
        '--upgrade[upgrade settings format]' \
        '--user-scope[user scope]' \
        '--system-scope[system scope]' \
        '--settings-dir=+[dir]:dir:_files -/' \
        '*::'
}

_qbs-config "$@"
