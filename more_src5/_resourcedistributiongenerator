#compdef resourcedistributiongenerator
# _resourcedistributiongenerator — OpenKruise ResourceDistribution YAML generator
# upstream: https://github.com/openkruise/kruise-tools
# Subcommand-driven cobra binary; see cmd/resourcedistributiongenerator/generator/generator.go on tip.

_resourcedistributiongenerator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-f --file)'{-f,--file=}'[input ResourceDistribution YAML]:file:_files -g "*.(yaml|yml)"' \
        '(-o --output)'{-o,--output=}'[output file (default: stdout)]:file:_files' \
        '*: :_files -g "*.(yaml|yml)"'
}

_resourcedistributiongenerator "$@"
