_arguments -s \
  '*--channel=[channel name]:channel:' \
  '--channelfile=[channel file]:file:_files' \
  '--checkonly[check only, do not install]' \
  '--install=[install from local tarball]:file:_files' \
  '--allowplugins[allow plugins]' \
  '--reallyallowplugins[really allow plugins]' \
  '--gpg[verify GPG signatures]' \
  '--nogpg[skip GPG verification]' \
  '*--gpgkey=[GPG key id]:keyid:' \
  '--gpgkeyfile=[GPG key file]:file:_files' \
  '--gpghomedir=[GPG home dir]:dir:_files -/' \
  '--import=[import GPG file]:file:_files' \
  '--refreshmirrors[refresh MIRRORED.BY]' \
  '--forcemirror=[force mirror URL]:url:' \
  '--httputil=[HTTP utility]:util:(curl wget fetch lwp)' \
  '--score-multiplier=[score multiplier]:num:' \
  '--score-limit=[score limit]:num:' \
  '--updatedir=[update directory]:dir:_files -/' \
  '*'{-D,--debug=}'[debug areas]:areas:' \
  '*'{-v,--verbose}'[verbose output]' \
  '-4[force IPv4]' \
  '-6[force IPv6]' \
  '(- *)'{-V,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]'
