#compdef sonarqube
# Documentation: https://docs.sonarsource.com/sonarqube-cli/using-sonarqube-cli/commands.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Note: SonarQube CLI is distinct from sonar-scanner (see _sonar-scanner).
# Repo: https://github.com/SonarSource/sonarqube-cli

local curcontext="$curcontext" state line ret=1
local -a top_commands

top_commands=(
  'auth:authentication management'
  'integrate:setup IDE/agent integrations'
  'analyze:run analyses (secrets, agentic)'
  'verify:alias for analyze agentic'
  'remediate:fix issues'
  'list:list issues or projects'
  'api:make Sonar Web API calls'
  'config:configuration commands'
  'self-update:update the CLI'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'sonarqube command' top_commands && ret=0 ;;
  (args)
    case $line[1] in
      (auth)
        local -a auth_subs=(
          'login:save a token'
          'logout:remove active token'
          'purge:remove all saved tokens'
          'status:verify active connection'
        )
        _describe -t commands 'auth subcommand' auth_subs && ret=0
        ;;
      (integrate)
        local -a int_subs=(
          'claude:setup Claude integration'
          'copilot:setup Copilot integration'
          'git:setup Git hooks'
        )
        _describe -t commands 'integrate target' int_subs && ret=0
        ;;
      (analyze)
        local -a analyze_subs=(
          'secrets:scan for hardcoded secrets'
          'agentic:run server-side agentic analysis'
        )
        _describe -t commands 'analyze subcommand' analyze_subs && ret=0
        ;;
      (list)
        local -a list_subs=(
          'issues:list issues'
          'projects:list projects'
        )
        _describe -t commands 'list subcommand' list_subs && ret=0
        ;;
      (config)
        local -a config_subs=(
          'telemetry:configure telemetry'
        )
        _describe -t commands 'config subcommand' config_subs && ret=0
        ;;
    esac
    ;;
esac

return ret
