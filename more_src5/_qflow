#compdef qflow qrouter
# _qflow — Tim Edwards Open Circuit Design qflow open ASIC synthesis place-and-route flow with companion qrouter (RTimothyEdwards team, Bash/Tcl); custom argparse
# upstream: https://github.com/RTimothyEdwards/qflow

_qflow() {
    local -a sub=(
        'all:full flow synthesis to GDS'
        'synthesize:run yosys synthesis'
        'place:run placement'
        'sta:static timing analysis'
        'route:run qrouter'
        'gdsii:generate GDSII'
        'cleanup:cleanup intermediate files'
        'install:install design'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '-V[show version]' \
        '--version[show version]' \
        '-T+[technology]:str:' \
        '--tech=+[technology]:str:' \
        '-P+[project dir]:dir:_files -/' \
        '--project=+[project dir]:dir:_files -/' \
        '-c+[config file]:file:_files -g "qflow_vars.sh"' \
        '--config=+[config file]:file:_files' \
        '-l+[log dir]:dir:_files -/' \
        '--logdir=+[log dir]:dir:_files -/' \
        '-d+[debug]' \
        '--debug[debug]' \
        '-f+[force]' \
        '--force[force]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'qflow subcommand' sub ;;
        args)
            case $words[1] in
                synthesize|place|sta|route|gdsii|all) _arguments \
                    '*:design:_files -g "*.v *.sv *.lef *.gds *.def *.sdc"' ;;
            esac
            ;;
    esac
}

_qflow "$@"
