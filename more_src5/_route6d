#compdef route6d
# _route6d — OpenBSD route6d (RIP-over-IPv6 routing daemon; filter flags -A/-L/-N/-O/-T scope advertised prefixes per interface; -h advertises host routes, -l includes link-local, -s sends triggered updates)
# upstream: https://github.com/openbsd/src (usr.sbin/route6d)
# Flags from usr.sbin/route6d/route6d.8 on tip.

_route6d() {
    _arguments \
        '-a[do not advertise default route]' \
        '-D[debug]' \
        '-d[foreground debug]' \
        '-h[advertise host routes]' \
        '-l[include link-locals]' \
        '-n[do not update kernel routes]' \
        '-q[no advertisement]' \
        '-S[show route summary]' \
        '-s[send triggered updates]' \
        '-u[advertise updated routes only]' \
        '*-A+[aggregate prefix/preflen,ifs]:prefix/len,ifs:' \
        '*-L+[restrict prefix/preflen,ifs to listed ifs]:prefix/len,ifs:' \
        '*-N+[do not advertise to listed ifs]:ifs:' \
        '*-O+[advertise prefix/preflen,ifs only]:prefix/len,ifs:' \
        '*-T+[do not listen on listed ifs]:ifs:' \
        '-t+[route tag]:tag:'
}

_route6d "$@"
