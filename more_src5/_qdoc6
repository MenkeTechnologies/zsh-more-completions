#compdef qdoc6 qdoc-qt6
# _qdoc6 — Qt Project qdoc6 CLI Qt 6 documentation generator reading per-module .qdocconf project files extracting doxygen-style /// comments from C++ QML JavaScript headers emitting HTML qch DocBook qmake-friendly cross-referenced reference manuals for the Qt6 documentation set (Qt Project team, C++); getopt
# upstream: https://doc.qt.io/qt-6/qdoc-index.html

_qdoc6() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--debug[debug]' \
        '--no-examples[skip examples]' \
        '--no-link-errors[no link errors]' \
        '--obsoletelinks[allow obsolete links]' \
        '--outputdir=+[dir]:dir:_files -/' \
        '--outputformat=+[fmt]:f:(HTML DocBook)' \
        '--prepare[prepare phase]' \
        '--generate[generate phase]' \
        '--single-exec[single executable phase]' \
        '--log-progress[log progress]' \
        '--no-link[no link]' \
        '--showinternal[show internal]' \
        '--single[single-pass]' \
        '--include-paths=+[paths]:str:' \
        '--installdir=+[dir]:dir:_files -/' \
        '--indexdir=+[dir]:dir:_files -/' \
        '--I+[include path]:dir:_files -/' \
        '--D+[define]:str:' \
        '--timestamps[include timestamps]' \
        '--frameworkdir=+[dir]:dir:_files -/' \
        '*:qdocconf file:_files -g "*.qdocconf"'
}

_qdoc6 "$@"
