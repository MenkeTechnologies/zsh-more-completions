#compdef splitMeshRegions
# Documentation: https://cfd.direct/openfoam/user-guide/
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/mesh/manipulation/splitMeshRegions — split mesh into disconnected regions (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[OpenFOAM case directory]:dir:_files -/' \
    '-fileHandler+[file handler]:handler:(uncollated collated masterUncollated)' \
    '-parallel[run in parallel]' \
    '-noFunctionObjects[disable function objects]' \
    '-overwrite[overwrite existing mesh]' \
    '-cellZones[split into cellZones]' \
    '-cellZonesOnly[only use cellZones]' \
    '-cellZonesFileOnly+[cellZone file]:file:_files' \
    '-blockedFaces+[blocked faces file]:file:_files' \
    '-faceSet+[blocking faceSet name]:set:_default' \
    '-makeCellZones[create cellZones from regions]' \
    '-largestOnly[output only the largest region]' \
    '-insidePoint+[point inside selected region]:point:_default' \
    '-detectOnly[detect only, do not split]' \
    '-sloppyCellZones[loose cellZone handling]' \
    '-useFaceZones[use faceZones as blocked]' \
    '-prefixRegion[prefix region names with master]' \
    '-defaultRegionName+[default region name]:name:_default' \
    '-noFields[do not split fields]' \
    '-region+[region name]:region:_default' \
    && ret=0

return ret
