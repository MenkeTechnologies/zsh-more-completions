#compdef rpcgen
# Documentation: man rpcgen (Sun RPC protocol compiler)
# Source: generate C code (XDR + stubs) from an RPC protocol definition.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[generate all files including sample code]' \
    '-b[generate SunOS 4.1-style RPC (default)]' \
    '-C[generate ANSI C code]' \
    '(-h -l -m -t -Sc -Ss)-c[compile into XDR routines]' \
    '*-D+[define a preprocessor symbol]:name[=value]:' \
    '(-c -l -m -t -Sc -Ss)-h[compile into C data-definitions (header)]' \
    '-K+[server idle timeout seconds (-1 = never)]:secs:' \
    '-L[send server errors to syslog instead of stderr]' \
    '(-c -h -m -t -Sc -Ss)-l[compile into client-side stubs]' \
    '(-c -h -l -t -Sc -Ss)-m[compile into server-side stubs (no main)]' \
    '-N[use newstyle rpcgen (multiple args)]' \
    '*-n+[server-side stubs for netid]:netid:' \
    '-o+[output file]:file:_files' \
    '(-c -h -l -m -t -Ss)-Sc[generate sample client code]' \
    '(-c -h -l -m -t -Sc)-Ss[generate skeleton server code]' \
    '*-s+[server-side stubs for nettype]:nettype:(netpath visible circuit_n circuit_v datagram_n datagram_v tcp udp)' \
    '-T[generate RPC dispatch-table code]' \
    '-M[generate MT-safe code]' \
    '(-c -h -l -m -Sc -Ss)-t[compile into RPC dispatch table]' \
    '1:rpc file:_files -g "*.x"' \
    && ret=0

return ret
