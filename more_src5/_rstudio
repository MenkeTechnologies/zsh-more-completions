#compdef rstudio Rstudio
# Documentation: https://posit.co/products/open-source/rstudio/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (GUI IDE; only positional file argument supported).
# STUB: rstudio is a GUI IDE; CLI is minimal (positional file arg only).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*:project:_files -g "*.{R,Rproj,Rmd,qmd}"' && ret=0

return ret
