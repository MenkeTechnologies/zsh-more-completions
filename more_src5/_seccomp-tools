#compdef seccomp-tools
# Documentation: seccomp-tools --help
# Source: david942j/seccomp-tools lib/seccomp-tools/cli/cli.rb (master) — seccomp BPF analyzer (Ruby).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a cmds=(
    'asm:assemble seccomp BPF rules'
    'disasm:disassemble seccomp BPF bytecode'
    'dump:dump seccomp BPF from running process or ELF'
    'emu:emulate seccomp BPF with a sample syscall'
)

_arguments -s -C \
    '--version[show version]' \
    '--help[show help]' \
    '1:command:->cmd' \
    '*::cmd args:->cmdargs' \
    && ret=0

case $state in
    cmd) _describe -t commands 'seccomp-tools command' cmds && ret=0 ;;
    cmdargs)
        case $line[1] in
            asm) _arguments '-o+[output file]:file:_files' '-f+[format]:format:(inspect raw c_array c_source assembly carray)' '*:source file:_files' ;;
            disasm) _arguments '-f+[format]:format:(inspect raw)' '*:bpf file:_files' ;;
            dump)
                _arguments '-c+[command line to launch]:command:_command_names -e' \
                           '-f+[format]:format:(inspect raw disasm)' \
                           '-l+[limit dumps]:n:_default' \
                           '-o+[output file]:file:_files' \
                           '*:executable:_files' ;;
            emu)
                _arguments '-a+[architecture]:arch:(amd64 i386 aarch64)' \
                           '-q+[syscall name]:syscall:_default' \
                           '-i+[input bpf file]:file:_files' \
                           '*:syscall+args:_default' ;;
        esac
        ;;
esac

return ret
