#compdef qdepends
# Documentation: https://github.com/gentoo/portage-utils
# Source: gentoo/portage-utils qdepends.c — display package dependencies (DEPEND/RDEPEND/PDEPEND/BDEPEND/IDEPEND).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-d --depend)'{-d,--depend}'[show DEPEND]' \
    '(-r --rdepend)'{-r,--rdepend}'[show RDEPEND]' \
    '(-p --pdepend)'{-p,--pdepend}'[show PDEPEND]' \
    '(-b --bdepend)'{-b,--bdepend}'[show BDEPEND]' \
    '(-i --idepend)'{-i,--idepend}'[show IDEPEND]' \
    '(-Q --query)'{-Q,--query}'[query reverse deps]' \
    '(-I --installed)'{-I,--installed}'[search installed packages via VDB]' \
    '(-t --tree)'{-t,--tree}'[search ebuilds in tree]' \
    '(-U --use)'{-U,--use}'[apply profile USE-flags to conditionals]' \
    '(-F --format)'{-F+,--format=}'[output format string]:fmt:_default' \
    '(-S --pretty)'{-S,--pretty}'[pretty format depend strings]' \
    '(-R --resolve)'{-R,--resolve}'[resolve deps to package versions]' \
    '*:package atom:_default' \
    && ret=0

return ret
