#compdef runiq
# Documentation: https://github.com/whitfin/runiq
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# runiq - efficient way to filter duplicate lines from input.

local -a arguments

arguments=(
  '(-f --filter)'{-f,--filter}'=[set deduplication filter]:filter:(quick simple sorted compact)'
  '(-i --inverted)'{-i,--inverted}'[print duplicate lines instead of unique]'
  '(-s --statistics)'{-s,--statistics}'[print statistics about input/output counts]'
  '(-h --help)'{-h,--help}'[show help message]'
  '(-V --version)'{-V,--version}'[show version information]'
  '*:input file:_files'
)

_arguments -s -S $arguments
