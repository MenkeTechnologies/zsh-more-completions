#compdef rigsql
# Documentation: https://github.com/yukonsky/rigsql
# Reference accessed: 2026-05-20
# Verified: clap-generated completion from rigsql-cli@0.7.0 (cargo binstall + completions zsh).
# Source: cargo binstall rigsql-cli@0.7.0
# Repository: https://github.com/yukonsky/rigsql

autoload -U is-at-least

_rigsql() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_rigsql_commands" \
"*::: :->rigsql" \
&& ret=0
    case $state in
    (rigsql)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:rigsql-command-$line[1]:"
        case $line[1] in
            (parse)
_arguments "${_arguments_options[@]}" : \
'--dialect=[SQL dialect \[default\: ansi\] (overrides config file)]:DIALECT:(ansi postgres tsql)' \
'--locale=[Output locale (e.g. "en", "ja") — overrides config and system locale]:LOCALE:_default' \
'--format=[Output format]:FORMAT:(tree json)' \
'-h[Print help]' \
'--help[Print help]' \
':file -- SQL file to parse (use - for stdin):_default' \
&& ret=0
;;
(lint)
_arguments "${_arguments_options[@]}" : \
'--dialect=[SQL dialect \[default\: ansi\] (overrides config file)]:DIALECT:(ansi postgres tsql)' \
'--locale=[Output locale (e.g. "en", "ja") — overrides config and system locale]:LOCALE:_default' \
'--format=[Output format]:FORMAT:(human json sarif github)' \
'--no-color[Disable colored output]' \
'-h[Print help]' \
'--help[Print help]' \
'*::files -- SQL files or directories to lint:_default' \
&& ret=0
;;
(fix)
_arguments "${_arguments_options[@]}" : \
'--dialect=[SQL dialect \[default\: ansi\] (overrides config file)]:DIALECT:(ansi postgres tsql)' \
'--locale=[Output locale (e.g. "en", "ja") — overrides config and system locale]:LOCALE:_default' \
'--dry-run[Don'\''t write changes, just show what would be fixed]' \
'-f[Skip confirmation prompt]' \
'--force[Skip confirmation prompt]' \
'-h[Print help]' \
'--help[Print help]' \
'*::files -- SQL files or directories to fix:_default' \
&& ret=0
;;
(rules)
_arguments "${_arguments_options[@]}" : \
'--locale=[Output locale (e.g. "en", "ja") — overrides config and system locale]:LOCALE:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_rigsql__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:rigsql-help-command-$line[1]:"
        case $line[1] in
            (parse)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(lint)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(fix)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(rules)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_rigsql_commands] )) ||
_rigsql_commands() {
    local commands; commands=(
'parse:Parse SQL files and display the Concrete Syntax Tree' \
'lint:Lint SQL files for style violations' \
'fix:Auto-fix SQL files' \
'rules:List available lint rules' \
'completions:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'rigsql commands' commands "$@"
}
(( $+functions[_rigsql__subcmd__completions_commands] )) ||
_rigsql__subcmd__completions_commands() {
    local commands; commands=()
    _describe -t commands 'rigsql completions commands' commands "$@"
}
