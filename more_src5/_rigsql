    local commands; commands=()
    _describe -t commands 'rigsql help parse commands' commands "$@"
}
(( $+functions[_rigsql__subcmd__help__subcmd__rules_commands] )) ||
_rigsql__subcmd__help__subcmd__rules_commands() {
    local commands; commands=()
    _describe -t commands 'rigsql help rules commands' commands "$@"
}
(( $+functions[_rigsql__subcmd__lint_commands] )) ||
_rigsql__subcmd__lint_commands() {
    local commands; commands=()
    _describe -t commands 'rigsql lint commands' commands "$@"
}
(( $+functions[_rigsql__subcmd__parse_commands] )) ||
_rigsql__subcmd__parse_commands() {
