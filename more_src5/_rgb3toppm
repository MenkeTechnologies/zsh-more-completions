#compdef rgb3toppm
# Documentation: man rgb3toppm (Netpbm)
# Source: combine three PGM images (R/G/B planes) into a single PPM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:red pgm:_files -g "*.(pgm|pnm|pam)"' \
    '2:green pgm:_files -g "*.(pgm|pnm|pam)"' \
    '3:blue pgm:_files -g "*.(pgm|pnm|pam)"' \
    && ret=0

return ret
