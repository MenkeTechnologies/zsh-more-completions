#compdef redis-server
# Documentation: redis-server --help
# Source: Redis — in-memory key-value store; primary daemon.
# Reference accessed: 2026-06-10
# NOTE: redis-server accepts any directive from redis.conf as --<name> <value>;
# this completion exposes the most common ones plus the discoverable flags.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-v,--version}'[show version]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--test-memory=[memory test (MB)]:megabytes:' \
    '(- *)--check-system[run system compatibility check]' \
    '--port=[listen port]:port:_ports' \
    '--bind=[listen interfaces]:ips:_hosts' \
    '--unixsocket=[unix domain socket path]:socket:_files' \
    '--unixsocketperm=[unix socket permissions]:mode:' \
    '--daemonize=[run as daemon]:bool:(yes no)' \
    '--supervised=[init system integration]:mode:(no upstart systemd auto)' \
    '--pidfile=[pid file]:file:_files' \
    '--logfile=[log file]:file:_files' \
    '--loglevel=[log level]:level:(debug verbose notice warning nothing)' \
    '--databases=[number of databases]:n:' \
    '--maxmemory=[memory limit]:bytes:' \
    '--maxmemory-policy=[eviction policy]:policy:(noeviction allkeys-lru allkeys-lfu allkeys-random volatile-lru volatile-lfu volatile-random volatile-ttl)' \
    '--appendonly=[enable AOF]:bool:(yes no)' \
    '--appendfilename=[AOF file]:filename:' \
    '--appendfsync=[AOF fsync policy]:policy:(always everysec no)' \
    '--save=[RDB save points (seconds changes)]:spec:' \
    '--rdbcompression=[compress RDB]:bool:(yes no)' \
    '--rdbchecksum=[checksum RDB]:bool:(yes no)' \
    '--dbfilename=[RDB filename]:file:' \
    '--dir=[working directory]:dir:_files -/' \
    '--requirepass=[client auth password]:password:' \
    '--replicaof=[primary host port]:host port:' \
    '--slaveof=[deprecated alias for --replicaof]:host port:' \
    '--cluster-enabled=[run as cluster node]:bool:(yes no)' \
    '--cluster-config-file=[cluster config file]:file:_files' \
    '--sentinel[start in Sentinel mode]' \
    '--tls-port=[TLS listen port]:port:_ports' \
    '--tls-cert-file=[TLS cert]:file:_files' \
    '--tls-key-file=[TLS key]:file:_files' \
    '--tls-ca-cert-file=[TLS CA cert]:file:_files' \
    '--tls-ca-cert-dir=[TLS CA dir]:dir:_files -/' \
    '--protected-mode=[protected mode]:bool:(yes no)' \
    '*:redis.conf:_files -g "*.conf"' \
    && ret=0

return ret
