#compdef radzcheck
# _radzcheck — FreeRADIUS radzcheck (validate the freeradius `users` file syntax + dictionary references; -d dictionary dir, -f users file, -h help, -v version, -x debug; useful as a pre-commit / CI hook before deploying changes to /etc/raddb/users)
# upstream: https://github.com/FreeRADIUS/freeradius-server
# Common flag shape from FreeRADIUS scripts/radzcheck on tip.

_radzcheck() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-d+[dictionary dir]:dir:_files -/' \
        '-f+[users file]:file:_files' \
        '-x[debug]'
}

_radzcheck "$@"
