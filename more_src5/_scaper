#compdef scaper scaper-cli
# _scaper — Justin Salamon scaper Python library and CLI for soundscape synthesis with controlled augmentation (NYU MARL team, Python); argparse
# upstream: https://github.com/justinsalamon/scaper

_scaper() {
    local -a sub=(
        'generate:generate a single soundscape'
        'generate_from_jams:generate from JAMS file'
        'batch:batch generate soundscapes'
        'add-event:add an event'
        'add-background:add a background'
        'analyze:analyze soundscape'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-V[show version]' \
        '--version[show version]' \
        '--duration=+[seconds]:f:' \
        '--fg-path=+[foreground dir]:dir:_files -/' \
        '--bg-path=+[background dir]:dir:_files -/' \
        '--ref-db=+[reference dB]:f:' \
        '--no-audio[no audio output]' \
        '--no-jams[no JAMS]' \
        '--no-txt[no txt annotations]' \
        '--audio-path=+[output audio]:file:_files -g "*.wav *.flac *.ogg"' \
        '--jams-path=+[output JAMS]:file:_files -g "*.jams"' \
        '--txt-path=+[output annotations]:file:_files -g "*.txt"' \
        '--allow-repeated-source[allow repeated source]' \
        '--allow-repeated-label[allow repeated label]' \
        '--reverb=+[F]:f:' \
        '--peak-normalize=+[bool]:b:(true false)' \
        '--quick-pitch-time=+[bool]:b:(true false)' \
        '--save-isolated[save isolated events]' \
        '--no-audio[no audio]' \
        '--random-seed=+[seed]:n:' \
        '--protected-labels=+[csv]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'scaper subcommand' sub ;;
        args)
            case $words[1] in
                generate|generate_from_jams|batch) _arguments \
                    '--n-soundscapes=+[N]:n:' \
                    '--fg-path=+[dir]:dir:_files -/' \
                    '--bg-path=+[dir]:dir:_files -/' \
                    '*:input:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_scaper "$@"
