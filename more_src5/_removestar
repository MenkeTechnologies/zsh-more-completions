#compdef removestar

local curcontext="$curcontext" state line ret=1

_arguments \
  '--diff[Print diffs instead of modifying files]' \
  '--quiet[Suppress output]' \
  '(- *)--version[Show version information]' \
  '(- *)--help[Show help message]' \
  '(-i --in-place)'{-i,--in-place}'[Edit files in place]' \
  '--max-line-length[Maximum line length for reformatted imports]:length:' \
  '*:module or file:_files -g "*.py"' \
  && ret=0

return ret
