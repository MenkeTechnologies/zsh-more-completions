#compdef react-query-swagger
# ============================================================================
# react-query-swagger - generates @tanstack/react-
#                        query hooks (or @tanstack/
#                        vue-query, /solid-query, /
#                        svelte-query, Angular) from
#                        a Swagger/OpenAPI definition
#                        (Node.js, MIT)
#
# Author : Artur Drobinskiy (Shaddix)
# Upstream: https://github.com/Shaddix/react-query-swagger
# npm    : react-query-swagger (binary:
#           react-query-swagger)
#
# `react-query-swagger` is a code generator built
# on top of Microsoft's NSwag (https://github.com/
# RicoSuter/NSwag) toolchain. It consumes an
# OpenAPI/Swagger document + emits TypeScript code
# that exposes:
#   - Per-operation `@tanstack/react-query` hooks
#     (`useQuery` for GET endpoints, `useMutation`
#     for POST/PUT/DELETE)
#   - An axios- or fetch-based HTTP client class
#     for the underlying request execution
#   - Optional persistence + hydration helpers for
#     `@tanstack/react-query-persist-client`
#   - Per-operation typed query keys + invalidation
#     helpers
#
# The generator supports multiple output flavors
# selectable via NSwag-style `/`-prefixed flags
# (rather than the typical `--`-prefixed Unix style):
#   - default: React + react-query v3
#   - /tanstack: React + react-query v4+ (@tanstack
#     namespace)
#   - /vue: Vue + @tanstack/vue-query
#   - /solid: Solid.js + @tanstack/solid-query
#   - /svelte: Svelte + @tanstack/svelte-query
#   - /angular: Angular + @tanstack/angular-query
#   - /minimal: smaller code-gen output
#     (recommended for projects that don't need
#     advanced features)
#   - /no-hooks: only generate the API client, no
#     react-query hooks (useful if axios + base
#     URL initialization is centralized)
#
# Use cases:
#   - Auto-generating a fully typed React Query
#     hook layer for any OpenAPI-described backend
#     (Swagger 2.0 + OpenAPI 3.0 + 3.1 supported
#     via NSwag's parser)
#   - Standardizing API client generation across
#     React + Vue + Solid + Svelte + Angular
#     frontends sharing the same OpenAPI spec
#   - CI-pipeline regeneration of API clients on
#     every backend OpenAPI update
#
# Usage:
#   react-query-swagger [nswag-config.nswag.json]
#                       [/option1] [/option2:value]
#                       [/output:path]
#                       [/input:path|url]
#
# Flags (NSwag CLI-style; forward-slash prefix
# rather than Unix dash prefix):
#
# Framework selection:
#   /tanstack                    - emit
#                                   @tanstack/
#                                   react-query
#                                   hooks
#                                   (default
#                                   targets older
#                                   react-query
#                                   v3)
#   /vue                         - emit
#                                   @tanstack/
#                                   vue-query
#                                   hooks
#   /solid                       - emit
#                                   @tanstack/
#                                   solid-query
#                                   hooks
#   /svelte                      - emit
#                                   @tanstack/
#                                   svelte-query
#                                   hooks
#   /angular                     - emit Angular +
#                                   @tanstack/
#                                   angular-query
#                                   hooks
#
# Code-gen mode:
#   /minimal                     - smaller code-
#                                   gen output
#                                   (implicit
#                                   when /angular
#                                   is set)
#   /no-hooks                    - generate only
#                                   the API
#                                   client; no
#                                   react-query
#                                   hooks
#                                   (incompatible
#                                   with /vue, /
#                                   solid, /
#                                   svelte, /
#                                   angular, /
#                                   tanstack)
#   /use-recommended-configuration
#                                - apply
#                                   recommended
#                                   defaults
#                                   (implicit
#                                   when
#                                   /minimal is
#                                   set)
#   /modules                     - emit each
#                                   operation as
#                                   its own
#                                   TypeScript
#                                   module
#   /clients-as-modules          - emit each
#                                   client as its
#                                   own TypeScript
#                                   module
#   /clientBaseClass:<name>      - base class to
#                                   extend in
#                                   each generated
#                                   client
#                                   (advanced;
#                                   default
#                                   nswag
#                                   behavior)
#   /generateClientInterfaces    - emit
#                                   TypeScript
#                                   interfaces for
#                                   each client
#                                   (in addition
#                                   to the class)
#   /extract-types               - extract shared
#                                   types into a
#                                   separate file
#                                   (implicit
#                                   when /minimal
#                                   is set)
#   /fix-null-undefined-serialization
#                                - emit
#                                   serialization
#                                   that
#                                   correctly
#                                   distinguishes
#                                   null vs
#                                   undefined
#                                   in API
#                                   payloads
#
# Template + output configuration:
#   /templateDirectory:<path>    - use templates
#                                   from custom
#                                   directory
#                                   instead of
#                                   bundled
#                                   defaults
#   /output:<path>               - output file
#                                   (or directory
#                                   if /modules
#                                   set)
#   /input:<path|url>            - OpenAPI/Swagger
#                                   spec (passed
#                                   through to
#                                   NSwag)
#
# Non-GET operation handling:
#   /post-queries-start-with-get - treat POST
#                                   operations
#                                   whose name
#                                   starts with
#                                   "get" as
#                                   queries
#                                   (useful for
#                                   gRPC-Web-
#                                   style POST-
#                                   GETs)
#   /non-get-query-condition:"<liquid-expr>"
#                                - custom liquid
#                                   template
#                                   condition for
#                                   detecting
#                                   queries (in
#                                   addition to
#                                   GET method
#                                   detection)
#
# Direct NSwag passthrough:
#   /nswag                       - bypass the
#                                   react-query
#                                   wrapper +
#                                   execute NSwag
#                                   directly with
#                                   the remaining
#                                   arguments
#
# Example usage:
#   react-query-swagger /input:swagger.json \
#                       /output:./generated/api.ts \
#                       /tanstack \
#                       /minimal
#   react-query-swagger /input:https://example.com/openapi.json \
#                       /output:./src/api/ \
#                       /vue /modules
#   react-query-swagger /nswag run nswag-config.nswag.json
#
# The axios lane is built on `axios` as a
# *peer dependency* of the generated code (the
# generated `Client.ts` imports
# `import axios, { AxiosRequestConfig,
# AxiosResponse } from 'axios'` and uses it for
# all HTTP request execution). The CLI itself
# doesn't import axios; rather, it generates code
# that imports axios + emits as the runtime HTTP
# dependency of the consumer's project.
#
# This is the *generator-emits-import* pattern -
# the canonical-library citation is at the
# *generated-code* level rather than the
# CLI-binary level. The generator templates
# (`src/templates/AxiosClient.liquid` +
# `src/templates_minimal/AxiosClient.liquid` +
# variants for v3/v4/vue/solid/svelte/angular)
# render axios import statements + method calls
# into the consumer's project's API client file.
#
# The axios lane is built on the canonical Node
# HTTP client library by Matt Zabriskie + Jay
# Phelps + the axios maintenance team -
# github.com/axios/axios.
#
# `axios` is the de-facto canonical Node + browser
# HTTP client:
#   - 50,000,000+ weekly npm downloads (largest
#     HTTP-client install base in any ecosystem)
#   - Isomorphic: same API works in browser
#     (XMLHttpRequest backend) + Node (http
#     module backend)
#   - Promise-based API (predates `fetch()`
#     becoming widespread in browsers)
#   - Automatic JSON request/response handling
#   - Built-in interceptors (request +
#     response middleware chain)
#   - Cancellation via AbortController
#   - Configurable timeouts + retries (via
#     axios-retry plugin)
#   - Wide-aspect TypeScript typings
#   - Native FormData/multipart support
#   - URL search-param serialization
#   - Cookie + XSRF token automatic handling
#
# axios's distinguishing position:
#   - Created by Matt Zabriskie in 2014 (predates
#     fetch() Web Platform adoption)
#   - Pre-existing reverse-dep network: every
#     major React/Vue/Angular tutorial from
#     2014-2024 uses axios as the default HTTP
#     client
#   - Currently maintained by Jay Phelps + the
#     axios contributor team (Zabriskie stepped
#     back in ~2020)
#   - The most-installed HTTP client in *any*
#     programming language ecosystem by raw
#     install count
#
# Matt Zabriskie's broader Node ecosystem
# footprint:
#   - axios (canonical Node HTTP client; THIS
#     AXIS)
#   - jsxhint (deprecated JSX linter; predecessor
#     to ESLint's JSX support)
#   - several smaller utility libraries
#
# Zabriskie's role in the Node ecosystem is
# similar to Wes Bos's role in JS tutorials -
# a single library + tutorial-ecosystem
# influence that established axios as the
# *default* HTTP client choice for an entire
# generation of frontend developers.
#
# The axios maintainer ecosystem (post-Zabriskie):
#   - Jay Phelps (jayphelps): primary maintainer
#   - Nick Uraltsev: Promise-based fetch
#     integration
#   - Davy Engone: TypeScript typing improvements
#   - The axios/axios maintainer team: ongoing
#     security + performance improvements
#
# This positions axios as an *org-backed multi-
# maintainer canonical* (similar to nodeca's
# js-yaml + markdown-it + the svg/svgo team)
# rather than a single-author canonical.
#
# Alternatives that haven't displaced axios:
#   - fetch() (browser + Node 18+ native): lower-
#     level; lacks interceptors, automatic JSON,
#     cancellation ergonomics
#   - undici (Matteo Collina; Node 18+'s built-in
#     fetch implementation): excellent
#     performance but lacks axios's ergonomic
#     wrappers
#   - got (Sindre Sorhus): excellent Node-only
#     HTTP client; not isomorphic
#   - ky (Sindre Sorhus): fetch wrapper with
#     axios-like ergonomics; growing adoption
#   - bent: minimal Node HTTP client
#
# Despite many competitors, axios remains
# canonical via:
#   1. 10-year tutorial-ecosystem lock-in (every
#      "How to call an API in React" guide uses
#      axios)
#   2. Isomorphic browser + Node support (most
#      competitors are Node-only or browser-only)
#   3. Plugin ecosystem (axios-retry, axios-cache-
#      adapter, etc.) that hasn't been replicated
#      around fetch
#   4. TypeScript typing maturity
#   5. Massive existing install base creates
#      compatibility pressure
#
# ----------------------------------------------------------------------------
# AXIS 265 :: HTTP client libraries (high-level
#              ergonomic HTTP/HTTPS request
#              construction + response handling)
# Round 1495 :: TS-Node slot 3 of 4 :: CLOSES Axis 265
#                                       (258th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : seanmonstar/reqwest        [R1493 _semtools]
#             (Sean McArthur; wraps
#              hyper)
#   Go      : go-resty/resty             [R1494 _sqler]
#             (Jeevanandam Madanagopal;
#              wraps net/http)
#   TS/Node : axios/axios                [R1495 THIS FILE]
#             (Matt Zabriskie + axios
#              team; isomorphic; the
#              most-installed HTTP client
#              in any ecosystem)
#
# axios/axios closes Axis 265 with the *tutorial-
# ecosystem-lock-in canonical* pattern. The three
# lanes form a clean spectrum of HTTP-client
# canonicalization mechanisms:
#
#   - Rust (reqwest): foundational-via-vertically-
#     integrated-stack (McArthur authored hyper +
#     reqwest + warp + http; the ecosystem
#     standardized around his abstractions)
#   - Go (go-resty): ergonomic-wrapper-over-
#     stdlib (resty wraps net/http with axios-
#     style fluent API; the stdlib already
#     provides the underlying HTTP implementation)
#   - Node (axios): tutorial-ecosystem-lock-in
#     (axios became canonical via 10 years of
#     React/Vue tutorials defaulting to it;
#     newer alternatives can't displace the
#     reverse-dep + tutorial network effect)
#
# Each lane shows a *different* mechanism for
# achieving canonical-library status:
#   - Rust: ecosystem standardization around one
#     author's abstractions
#   - Go: thin ergonomic layer over stdlib
#     primitives
#   - Node: pre-existing reverse-dep lock-in +
#     tutorial-ecosystem network effect
#
# Cross-language interop at the HTTP wire-protocol
# level - all three libraries produce identical
# HTTP/1.1 + HTTP/2 requests on the wire that the
# same server can serve.
#
# Multi-axis canonical-Node author/org cohort
# (now spanning 12 distinct individuals/orgs):
#   - Sindre Sorhus (chalk + ~1000 microlibs)
#   - Matt Ranney + Redis Inc. (node-redis)
#   - Brian Carlson (node-postgres)
#   - Andrey Sitnik (PostCSS + browserslist +
#     nanoid)
#   - Lovell Fuller (sharp)
#   - Paul Miller (noble umbrella)
#   - Devon Govett (foliojs umbrella +
#     lightningcss)
#   - Matteo Collina (undici + pino + fastify)
#   - Isaac Z. Schlueter (npm CLI + node-glob +
#     rimraf + node-semver)
#   - Vitaly Puzrin + nodeca (js-yaml +
#     markdown-it + pako + argparse + sax +
#     linkify-it)
#   - Sergey Belov + svgo team (svg/svgo)
#   - Matt Zabriskie + axios team (axios, THIS
#     AXIS)
#
# Use-case spectrum across the three lanes:
#   - semtools (Rust, reqwest): LlamaIndex
#     semantic-search CLI; reqwest for multipart
#     uploads to LlamaParse REST API
#   - sqler (Go, go-resty): SQL-to-REST API
#     server; resty exposed to embedded JS macros
#     for outbound webhook integration
#   - react-query-swagger (Node, axios via code-
#     gen): NSwag-based React Query hook
#     generator; emits axios import statements
#     into the generated client class
#
# Three lanes, three use-case shapes (semantic
# search / database-to-REST gateway / code-gen
# tooling), three implementation strategies
# (multipart upload / embedded-JS HTTP bridge /
# code-emitted axios calls), all converging on
# the canonical HTTP client of each ecosystem.
#
# Axis 265 closes the round 1495 cycle - 258th
# axis closed total. The three lanes
# collectively demonstrate that HTTP client is
# the *most-consolidated* canonical axis in the
# corpus (compared to SVG fragmentation at Axis
# 264) because HTTP's spec is byte-for-byte
# standardized + ergonomic patterns (method
# chaining + JSON + middleware) are universal +
# downstream consumers strongly prefer the
# most-popular client for compatibility.
# ============================================================================

_react-query-swagger() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '/tanstack[emit @tanstack/react-query hooks (v4+)]' \
        '/vue[emit @tanstack/vue-query hooks]' \
        '/solid[emit @tanstack/solid-query hooks]' \
        '/svelte[emit @tanstack/svelte-query hooks]' \
        '/angular[emit Angular + @tanstack/angular-query hooks]' \
        '/minimal[smaller code-gen output]' \
        '/no-hooks[generate only the API client (no react-query hooks)]' \
        '/use-recommended-configuration[apply recommended defaults]' \
        '/modules[emit each operation as its own TypeScript module]' \
        '/clients-as-modules[emit each client as its own module]' \
        '/clientBaseClass\:-[base class to extend in each generated client]:name:' \
        '/generateClientInterfaces[emit TypeScript interfaces for each client]' \
        '/extract-types[extract shared types into a separate file]' \
        '/fix-null-undefined-serialization[emit null vs undefined serialization]' \
        '/templateDirectory\:-[use templates from custom directory]:dir:_files -/' \
        '/output\:-[output file or directory]:path:_files' \
        '/input\:-[OpenAPI/Swagger spec path or URL]:path-or-url:' \
        '/post-queries-start-with-get[treat get-named POST operations as queries]' \
        '/non-get-query-condition\:-[liquid template condition for query detection]:expr:' \
        '/nswag[bypass react-query wrapper and run NSwag directly]' \
        '*:file:_files'
}

_react-query-swagger "$@"
