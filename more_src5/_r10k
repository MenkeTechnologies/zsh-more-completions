#compdef r10k
# Documentation: https://github.com/puppetlabs/r10k
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'deploy:deploy environments or modules'
  'puppetfile:Puppetfile operations'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config=}'[config file]:file:_files' \
  '(-t --trace)'{-t,--trace}'[show backtraces]' \
  '(-v --verbose)'{-v,--verbose=}'[verbose level]:level:(debug info warn error fatal)' \
  '--color[enable color]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'r10k subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (deploy)
        _values 'deploy action' 'environment' 'module' 'display' 'purge' && ret=0
        ;;
      (puppetfile)
        _values 'puppetfile action' 'install' 'check' 'purge' 'display' && ret=0
        ;;
    esac
    ;;
esac

return ret
