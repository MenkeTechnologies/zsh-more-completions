#compdef sentinel
# Documentation: https://developer.hashicorp.com/sentinel/docs/commands
# Reference accessed: 2026-05-21
# Verified: HashiCorp Sentinel policy-as-code CLI (NOT Redis Sentinel
# - that binary is `redis-sentinel`).

local curcontext="$curcontext" ret=1 state line
local -a commands=(
  'apply:execute a policy and output the result'
  'fmt:format Sentinel policy to canonical form'
  'test:test policies'
)
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'sentinel command' commands && ret=0 ;;
  args) _files && ret=0 ;;
esac
return ret
