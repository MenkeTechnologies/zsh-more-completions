#compdef sizeseq
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/sizeseq.html
# Reference accessed: 2026-05-21
# Verified: EMBOSS 6.6 sizeseq documentation page.

# EMBOSS sizeseq: read a set of sequences and write them out in
# size-sorted order (ascending or descending).
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequences=[input sequence(s) to sort]:sequence USA:_files' \
  '-descending[sort by descending length (default ascending)]' \
  '-outseq=[output sequence file]:file:_files' \
  '-osformat=[output sequence format]:format:(fasta embl genbank gff swiss gcg pir nbrf raw msf ace text staden)' \
  '*:sequence USA:_files' && ret=0

return ret
