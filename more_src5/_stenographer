#compdef stenographer stenotype stenographerd
# _stenographer — Google stenographer high-speed packet capture daemon and stenotype kernel-bypass capture core for indexed disk-backed pcap retention with per-flow on-demand query (google team, Go); flag
# upstream: https://github.com/google/stenographer

_stenographer() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v+[verbosity]:n:(0 1 2 3 4)' \
        '-config=+[config file]:file:_files -g "*.conf stenographer.conf"' \
        '--config=+[config file]:file:_files -g "*.conf stenographer.conf"' \
        '-test-only[test config and exit]' \
        '-tlskeyfile=+[file]:file:_files -g "*.key *.pem"' \
        '-tlscertfile=+[file]:file:_files -g "*.crt *.pem"' \
        '-tlscafile=+[file]:file:_files -g "*.crt *.pem"' \
        '-listen=+[host:port]:str:' \
        '-rpcsocketdir=+[dir]:dir:_files -/' \
        '-cpuprofile=+[file]:file:_files' \
        '-blockprofile=+[file]:file:_files' \
        '-memprofile=+[file]:file:_files' \
        '-trace=+[file]:file:_files' \
        '-rpcdir=+[dir]:dir:_files -/' \
        '-logtostderr[log to stderr]' \
        '-stderrthreshold=+[level]:l:(INFO WARNING ERROR FATAL)' \
        '-log_dir=+[dir]:dir:_files -/' \
        '-vmodule=+[mod=N csv]:str:' \
        '-no-mlock[disable mlock]' \
        '-clean=+[d]:str:' \
        '-batch[batch mode]'
}

_stenographer "$@"
