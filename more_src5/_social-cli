_social-cli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_social_cli_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                sync)
                    _arguments \
                        '*'{-p,--platform}'=[platforms to sync (repeatable, default all)]:platform:(bsky x)' \
                        '--unread-only[only fetch unread notifications]' \
                        '(-n --limit)'{-n,--limit}'=[max per platform (default 50)]:n:' \
                        '(-o --output)'{-o,--output}'=[legacy shared output file (default inbox.yaml)]:file:_files -g "*.yaml *.yml"' \
                        '--max-items=[max inbox items before truncating (default 200)]:n:' \
                        '--users-dir=[user memory dir for context enrichment]:dir:_files -/' \
                        '--auto-create-users[create missing user memory files during sync]' \
                        '--reset[clear cursors and re-fetch all]' \
                        '--clear[clear cursors AND local inbox]' \
                        '--media[download attached images/videos]' \
                        '--attachments-dir=[override attachments root (default ./attachments)]:dir:_files -/' && ret=0 ;;
                dispatch)
                    _arguments \
                        '(-p --platform)'{-p,--platform}'=[platform to dispatch from]:platform:(bsky x)' \
                        '--dry-run[validate only, do not post]' \
                        '::outbox file:_files -g "*.yaml *.yml"' && ret=0 ;;
                doctor)
                    _arguments '--migrate[move legacy root-level runtime files into state directory]' && ret=0 ;;
                check)
                    _arguments \
                        '(-t --threshold)'{-t,--threshold}'=[minimum items to trigger (default 1)]:n:' \
                        '(-p --platform)'{-p,--platform}'=[check a specific platform inbox]:platform:(bsky x)' && ret=0 ;;
                search)
                    _arguments \
                        '(-p --platform)'{-p,--platform}'=[platform (default bsky)]:platform:(bsky x)' \
                        '(-n --limit)'{-n,--limit}'=[max results (default 10)]:n:' \
                        '1:search query:' && ret=0 ;;
                feed)
                    _arguments \
                        '(-p --platform)'{-p,--platform}'=[platform (default bsky)]:platform:(bsky x)' \
                        '(-n --limit)'{-n,--limit}'=[max posts (default 50)]:n:' \
                        '(-o --output)'{-o,--output}'=[output file (default feed.yaml)]:file:_files -g "*.yaml *.yml"' \
                        '--feed=[feed generator AT-URI for custom feeds]:at-uri:' && ret=0 ;;
                post)
                    _arguments \
                        '(-p --platform)'{-p,--platform}'=[platform (default bsky)]:platform:(bsky x)' \
                        '--quote=[quote / repost a post by ID]:id:' \
                        '--reply-to=[post as a reply to this post ID]:id:' \
                        '*'{-m,--media}'=[media files to attach (repeatable)]:file:_files' \
                        '1:post text:' && ret=0 ;;
                reply)
                    _arguments \
                        '(-p --platform)'{-p,--platform}'=[platform (default bsky)]:platform:(bsky x)' \
                        '*'{-m,--media}'=[media files to attach]:file:_files' \
                        '1:reply text:' && ret=0 ;;
                thread)
                    _arguments \
                        '(-p --platform)'{-p,--platform}'=[platform (default bsky)]:platform:(bsky x)' \
                        '*'{-m,--media}'=[media files for first post]:file:_files' \
                        '*:thread post (one positional arg per post):' && ret=0 ;;
                annotate)
                    _arguments \
                        '(-p --platform)'{-p,--platform}'=[platform (default bsky)]:platform:(bsky)' \
                        '--motivation=[W3C motivation (default commenting)]:motivation:(commenting bookmarking highlighting tagging linking describing)' \
                        '--quote=[exact text to anchor to]:text:' \
                        '::annotation text:' && ret=0 ;;
                bookmark|highlight)
                    _arguments \
                        '(-p --platform)'{-p,--platform}'=[platform (default bsky)]:platform:(bsky)' \
                        '(-t --text)'{-t,--text}'=[optional note]:text:' && ret=0 ;;
                repost-media)
                    _arguments \
                        '(-t --text)'{-t,--text}'=[optional text to include]:text:' \
                        '1:AT-URI of the post to repost media from:' && ret=0 ;;
                rate-limits|whoami)
                    _arguments \
                        '*'{-p,--platform}'=[platforms (repeatable, default all)]:platform:(bsky x)' && ret=0 ;;
                delete|like)
                    _arguments \
                        '(-p --platform)'{-p,--platform}'=[platform (default bsky)]:platform:(bsky x)' \
                        '1:post ID or AT-URI:' && ret=0 ;;
                posts)
                    _arguments \
                        '(-p --platform)'{-p,--platform}'=[platform (default bsky)]:platform:(bsky x)' \
                        '1:user handle:' && ret=0 ;;
                profile|follow|block)
                    _arguments \
                        '(-p --platform)'{-p,--platform}'=[platform]:platform:(bsky x)' \
                        '1:user handle:' && ret=0 ;;
                get)
                    _arguments '1:AT-URI:' && ret=0 ;;
                update-profile|create|semble|list|add-card|connect|blog|publish)
                    _arguments \
                        '(-p --platform)'{-p,--platform}'=[platform]:platform:(bsky x)' \
                        '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_social_cli_commands] )) ||
_social_cli_commands() {
    local -a commands
    commands=(
        'sync:fetch notifications from platforms → stateDir/inbox-{platform}.yaml'
        'dispatch:dispatch posts from platform-specific outbox YAML files'
        'doctor:check social-cli runtime state and local hygiene'
        'check:check if inbox has actionable items (exit 0 = yes, 1 = no)'
        'search:search posts on a platform'
        'feed:fetch timeline or custom feed → feed.yaml'
        'post:post to a platform'
        'reply:reply to a post'
        'thread:post a thread (one post per positional arg)'
        'annotate:annotate a URL or post (Bluesky-only)'
        'bookmark:bookmark a post (Bluesky-only, via at.margin.note)'
        'highlight:highlight text in a post (Bluesky-only, via at.margin.note)'
        'repost-media:repost media from an existing Bluesky post'
        'rate-limits:show rate-limit status per platform'
        'delete:delete a post by ID / URI'
        'like:like a post by ID / URI'
        'whoami:show current account info'
        'posts:fetch recent posts by a user'
        'profile:get a user profile (read)'
        'update-profile:update profile'
        'semble:Semble PDS account operations'
        'list:list your social lists'
        'get:get a specific post by AT-URI'
        'create:create a record'
        'add-card:add a card to a Semble profile'
        'connect:connect to a Semble PDS instance'
        'blog:cross-publish a blog post'
        'publish:publish queued blog posts'
        'follow:follow an account'
        'block:block an account'
    )
    _describe -t commands 'social-cli command' commands
}

_social-cli "$@"
