#compdef ssh-tunnel ssh-tunnel-cli
# _ssh-tunnel — SSH port forwarding/tunnel helper CLI alias (community, Bash); custom argparse
# upstream: SSH community

_ssh-tunnel() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--local=+[local forward L:P:H:P]:str:' \
        '-L+[local forward L:P:H:P]:str:' \
        '--remote=+[remote forward L:P:H:P]:str:' \
        '-R+[remote forward L:P:H:P]:str:' \
        '--dynamic=+[dynamic SOCKS port]:port:' \
        '-D+[dynamic SOCKS port]:port:' \
        '--user=+[ssh user]:str:_users' \
        '-u+[ssh user]:str:_users' \
        '--port=+[ssh port]:port:' \
        '-p+[ssh port]:port:' \
        '--identity=+[identity file]:file:_files' \
        '-i+[identity file]:file:_files' \
        '--background[background mode]' \
        '-b[background mode]' \
        '--no-shell[no remote shell]' \
        '-N[no remote shell]' \
        '--keep-alive[keep alive]' \
        '-k[keep alive]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--config=+[ssh config file]:file:_files' \
        '-F+[ssh config file]:file:_files' \
        '--strict-host-key-checking=+[strict host key checking]:b:(yes no ask accept-new off)' \
        '--exit-on-forward-failure[exit on forward failure]' \
        '*:host:_hosts'
}

_ssh-tunnel "$@"
