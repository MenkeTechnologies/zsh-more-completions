#compdef scala-cli
# _scala-cli-bin — Scala CLI (Virtuslab + Scala team, Scala); modern Scala command runner replacing scala/scalac
# upstream: https://github.com/VirtusLab/scala-cli

_scala-cli-bin() {
    local -a sub=(
        'about:about scala-cli'
        'add-path:add binary to PATH'
        'bsp:Build Server Protocol'
        'clean:clean workspace'
        'compile:compile source'
        'completions:print shell completion'
        'config:configure scala-cli'
        'directories:print scala-cli directories'
        'doc:generate docs'
        'doctor:diagnose env'
        'export:export to sbt/mill/maven/etc'
        'fmt:format source'
        'help:show help'
        'install:install dependencies/completions/scala'
        'metabrowse:browse compiled metadata'
        'package:package executable'
        'publish:publish artifact'
        'repl:start REPL'
        'run:run code'
        'setup-ide:setup IDE config'
        'shebang:run as shebang script'
        'test:run tests'
        'uninstall:uninstall scala-cli'
        'uninstall-completions:uninstall completions'
        'update:update scala-cli'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--progress+[progress]:bool:(true false)' \
        '-S+[Scala version]:ver:' \
        '--scala+[Scala version]:ver:' \
        '--scala-version+[Scala version]:ver:' \
        '--jvm+[JVM version]:ver:' \
        '--platform+[platform]:platform:(jvm scala-js js scala-native native)' \
        '--js[Scala.js]' \
        '--native[Scala Native]' \
        '--cross[cross-build]' \
        '--server+[bloop server]:bool:(true false)' \
        '--power[enable power user mode]' \
        '--use-bsp+[use BSP]:bool:(true false)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'scala-cli subcommand' sub ;;
        args)
            case $words[1] in
                compile|run|test|repl|fmt|doc) _arguments \
                    '*:file:_files -g "*.(scala|sc)"' \
                    '--main-class+[main class]:str:' \
                    '-M+[main class]:str:' \
                    '--watch[watch]' \
                    '-w[watch]' \
                    '--restart[restart on run change]' \
                    '-r[restart on run change]' \
                    '--dep+[dep]:str:' ;;
                package) _arguments \
                    '-o+[output file]:file:_files' \
                    '--output+[output file]:file:_files' \
                    '--assembly[assembly jar]' \
                    '--native-image[native image]' \
                    '--docker[docker image]' \
                    '--graalvm-version+[graalvm version]:ver:' \
                    '*:file:_files' ;;
                export) _arguments \
                    '--sbt[sbt]' \
                    '--mill[mill]' \
                    '--maven[maven]' \
                    '--output+[output dir]:dir:_files -/' \
                    '*:file:_files' ;;
                completions) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_scala-cli-bin "$@"
