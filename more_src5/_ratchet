#compdef ratchet
# Documentation: https://github.com/sethvargo/ratchet
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'lint:lint and report unpinned versions'
      'pin:resolve and pin all versions'
      'unpin:revert pinned versions to their unpinned values'
      'update:update all pinned versions to the latest value'
      'upgrade:upgrade all pinned versions to the latest version'
    )
    _describe -t commands 'ratchet command' commands && ret=0
    ;;
  args)
    case $line[1] in
      lint|pin|unpin|update|upgrade)
        _arguments \
          '--parser=[parser type]:parser:(actions circleci cloudbuild drone gitlabci tekton)' \
          '*:file:_files -g "*.{yaml,yml}"' && ret=0
        ;;
    esac
    ;;
esac

return ret
