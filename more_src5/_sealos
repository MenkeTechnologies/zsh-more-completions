#compdef sealos
# _sealos — Labring sealos cloud OS Kubernetes-based distro (labring team, Go); cobra
# upstream: https://github.com/labring/sealos

_sealos() {
    local -a sub=(
        'apply:apply cluster from clusterfile'
        'run:run cluster install'
        'reset:reset cluster'
        'add:add nodes'
        'delete:delete nodes'
        'cert:generate certs'
        'cri:cri subcommands'
        'images:list images'
        'pull:pull image'
        'push:push image'
        'tag:tag image'
        'save:save image to tar'
        'load:load image from tar'
        'rmi:remove image'
        'inspect:inspect image'
        'merge:merge images'
        'build:build image'
        'create:create cluster image'
        'login:login to registry'
        'logout:logout registry'
        'manifest:manage manifest list'
        'gen:generate clusterfile'
        'mount:mount image'
        'umount:unmount image'
        'exec:exec on nodes'
        'scp:scp to nodes'
        'version:show version'
        'completion:generate completion'
        'docs:generate docs'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--debug[debug logs]' \
        '-v+[verbosity]:n:' \
        '--cluster=+[cluster name]:str:' \
        '-c+[cluster name]:str:' \
        '--config=+[config file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'sealos subcommand' sub ;;
        args)
            case $words[1] in
                run|apply) _arguments \
                    '--masters=+[master IPs]:hosts:_hosts' \
                    '-m+[master IPs]:hosts:_hosts' \
                    '--nodes=+[node IPs]:hosts:_hosts' \
                    '-n+[node IPs]:hosts:_hosts' \
                    '--user=+[ssh user]:user:_users' \
                    '-u+[ssh user]:user:_users' \
                    '--passwd=+[ssh password]:str:' \
                    '-p+[ssh password]:str:' \
                    '--pk=+[ssh private key]:file:_files' \
                    '--pk-passwd=+[pk password]:str:' \
                    '--port=+[ssh port]:port:_ports' \
                    '*:image:' ;;
                add|delete) _arguments \
                    '--masters=+[master IPs]:hosts:_hosts' \
                    '--nodes=+[node IPs]:hosts:_hosts' ;;
                build) _arguments \
                    '--file=+[Kubefile]:file:_files' \
                    '-f+[Kubefile]:file:_files' \
                    '--tag=+[tag]:str:' \
                    '-t+[tag]:str:' \
                    '--pull[force pull]' \
                    '*:context:_files -/' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_sealos "$@"
