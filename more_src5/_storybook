#compdef storybook sb
# _storybook — Storybook UI component explorer CLI (storybookjs/storybook)
# upstream: https://github.com/storybookjs/storybook

_storybook() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '1: :_storybook_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                dev)
                    _arguments \
                        '(-p --port)'{-p,--port}'=[port to listen on]:port:' \
                        '(-h --host)'{-h,--host}'=[host to bind to]:host:' \
                        '(-c --config-dir)'{-c,--config-dir}'=[storybook config directory]:dir:_files -/' \
                        '--https[use HTTPS]' \
                        '--ssl-ca=[SSL CA file]:file:_files' \
                        '--ssl-cert=[SSL certificate file]:file:_files' \
                        '--ssl-key=[SSL key file]:file:_files' \
                        '--ci[CI mode]' \
                        '--quiet[suppress output]' \
                        '--debug-webpack[enable webpack debug]' \
                        '--no-open[do not open browser]' \
                        '--docs[build in docs mode]' \
                        '--initial-path=[initial URL path]:path:' \
                        '--preview-url=[custom preview URL]:url:' \
                        '--help[show help]' && ret=0 ;;
                build)
                    _arguments \
                        '(-o --output-dir)'{-o,--output-dir}'=[output directory]:dir:_files -/' \
                        '(-c --config-dir)'{-c,--config-dir}'=[storybook config directory]:dir:_files -/' \
                        '--quiet[suppress output]' \
                        '--debug-webpack[enable webpack debug]' \
                        '--docs[build in docs mode]' \
                        '--test[build for testing]' \
                        '--help[show help]' && ret=0 ;;
                init)
                    _arguments \
                        '--type=[project type]:type:' \
                        '--builder=[builder to use]:builder:(webpack5 vite)' \
                        '--framework=[framework]:framework:' \
                        '(-y --yes)'{-y,--yes}'[accept all defaults]' \
                        '--skip-install[skip dependency install]' \
                        '--package-manager=[package manager]:pm:(npm yarn pnpm)' \
                        '--help[show help]' && ret=0 ;;
                upgrade)
                    _arguments \
                        '--dry-run[check without upgrading]' \
                        '--yes[accept all prompts]' \
                        '--skip-check[skip version check]' \
                        '--package-manager=[package manager]:pm:(npm yarn pnpm)' \
                        '--help[show help]' && ret=0 ;;
                doctor)
                    _arguments \
                        '--help[show help]' && ret=0 ;;
                add)
                    _arguments \
                        '--help[show help]' \
                        '1:addon name:' && ret=0 ;;
                *)
                    _arguments '--help[show help]' '*:args:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_storybook_commands] )) ||
_storybook_commands() {
    local -a commands
    commands=(
        'dev:start storybook in development mode'
        'build:build storybook for production'
        'init:initialize storybook in a project'
        'upgrade:upgrade storybook to latest version'
        'automigrate:run automatic migrations'
        'doctor:diagnose storybook issues'
        'sandbox:create a sandbox project'
        'add:add a storybook addon'
        'migrate:run a specific migration'
    )
    _describe -t commands 'storybook command' commands
}

_storybook "$@"
