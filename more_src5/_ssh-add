#compdef ssh-add
# _ssh-add — OpenSSH ssh-add (manage SSH keys in ssh-agent(1); default adds ~/.ssh/id_*; -D removes all, -d removes one, -l lists fingerprints, -L lists public keys, -s adds from PKCS#11, -K stores in macOS Keychain, -x lock agent, -X unlock, -t lifetime, -c confirm-each-use)
# upstream: https://github.com/openssh/openssh-portable
# Flags from openssh-portable ssh-add.c on tip.

_ssh-add() {
    _arguments \
        '-c[ask for confirmation each use]' \
        '-D[delete all identities]' \
        '-d[delete identity]' \
        '-e+[remove PKCS#11 provider]:provider:' \
        '-K[macOS: store in keychain]' \
        '-k[load plain private keys only]' \
        '-L[list public keys]' \
        '-l[list fingerprints]' \
        '-q[quiet]' \
        '-s+[add PKCS#11 provider]:provider:' \
        '-t+[lifetime seconds]:seconds:' \
        '-T+[test if identity is loaded]:identity:_files' \
        '-X[unlock agent]' \
        '-x[lock agent]' \
        '-h+[hostkey file]:file:_files' \
        '-H+[allowed signers file]:file:_files' \
        '-S+[security key middleware]:lib:' \
        '*:identity file:_files'
}

_ssh-add "$@"
