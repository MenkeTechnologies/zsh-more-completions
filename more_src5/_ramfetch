#compdef ramfetch
# _ramfetch — minimal /proc/meminfo display tool (mdPlusPlus/ramfetch)
# upstream: https://github.com/mdPlusPlus/ramfetch
# Flags from ramfetch script.

_ramfetch() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]'
}

_ramfetch "$@"
