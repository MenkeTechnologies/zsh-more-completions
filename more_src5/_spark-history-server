# _spark-history-server — Apache Spark history-server launcher (start-history-server.sh and stop-history-server.sh manage the per-cluster Spark history UI that replays event-log directories; --properties-file, -h/--host bind host, -p/--port bind port; configuration mostly via spark.history.* in spark-defaults.conf)
# upstream: https://github.com/apache/spark
# Flags from Apache Spark core/src/main/scala/org/apache/spark/deploy/history/HistoryServer.scala on tip.

_spark-history-server() {
    _arguments \
        '--help[show help]' \
        '--properties-file+[properties file]:file:_files' \
        '-h+[bind host]:host:_hosts' \
        '--host+[bind host]:host:_hosts' \
        '-p+[bind port]:port:' \
        '--port+[bind port]:port:' \
        '1::action:(start stop status)'
}

_spark-history-server "$@"
