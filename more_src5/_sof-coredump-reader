#compdef sof-coredump-reader
# _sof-coredump-reader — decode SOF DSP coredumps (thesofproject/sof)
# upstream: https://github.com/thesofproject/sof
# Flags from tools/coredumper/sof-coredump-reader.py (argparse).

_sof-coredump-reader() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-a --arch)'{-a+,--arch=}'[architecture of the dump file]:arch:(byt cht bsw bdw apl skl kbl glk cnl icl tgl ehl jsl rpl mtl lnl ptl wcl)'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '(-o --outfile)'{-o+,--outfile=}'[write decoded output to file]:file:_files'
        '(-c --colour)'{-c,--colour}'[colorful output]'
        '(-l --columncount)'{-l+,--columncount=}'[group output into N columns (with -v)]:n:'
        '(-i --infile)'{-i+,--infile=}'[input sys-dump binary]:file:_files'
    )
    _arguments -s $args
}

_sof-coredump-reader "$@"
