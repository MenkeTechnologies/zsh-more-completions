#compdef s6-fdholder-store
# _s6-fdholder-store — s6 fdholder s6-fdholder-store (send one fd to a running s6-fdholderd to be stored under id with a TTL; identified pair survives child death so the fd can be re-handed-out across restarts)
# upstream: https://github.com/skarnet/s6
# Flags from src/fdholder/s6-fdholder-store.c on tip.

_s6-fdholder-store() {
    _arguments \
        '-d+[fd to store (default 0)]:fd:' \
        '-t+[command timeout (ms)]:ms:' \
        '-T+[fd-storage TTL (ms)]:ms:' \
        '1:socket:_files' \
        '2:id:'
}

_s6-fdholder-store "$@"
