#compdef so-import-pcap
# _so-import-pcap — Security Onion so-import-pcap CLI for replaying captured pcap files through Suricata and Zeek populating Elasticsearch with synthetic timestamps for retrospective investigation (security-onion team, Bash); getopt
# upstream: https://github.com/Security-Onion-Solutions/securityonion

_so-import-pcap() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-d+[output dir]:dir:_files -/' \
        '--output-dir=+[output dir]:dir:_files -/' \
        '-r+[replay time]:str:' \
        '--replay-time=+[replay time]:str:' \
        '-t+[delta seconds]:n:' \
        '--time-delta=+[delta seconds]:n:' \
        '-i+[interface]:str:' \
        '--interface=+[interface]:str:' \
        '-n+[node]:str:' \
        '--node=+[node]:str:' \
        '--rulesets=+[csv]:str:' \
        '--no-suricata[no Suricata]' \
        '--no-zeek[no Zeek]' \
        '--no-stenographer[no Stenographer]' \
        '--no-elasticsearch[no Elasticsearch]' \
        '--no-logstash[no Logstash]' \
        '--no-archive[no archive]' \
        '--no-cleanup[no cleanup]' \
        '--no-confirm[no confirm]' \
        '--keep-temp[keep temp dir]' \
        '*:pcap file:_files -g "*.pcap *.pcapng *.cap"'
}

_so-import-pcap "$@"
