#compdef qmltime
# Documentation: https://github.com/qt/qtdeclarative/blob/dev/tools/qmltime/qmltime.cpp
# Reference accessed: 2026-05-20
# Verified: upstream source (tools/qmltime/qmltime.cpp) — Qt QML benchmark tool.

local curcontext="$curcontext" ret=1

_arguments \
  '(-help)-help[show usage]' \
  '-iterations[number of benchmark iterations (default 1024)]:count:' \
  '-parent[parent the component to an item already in the scene]' \
  '*:QML file:_files -g "*.qml"' && ret=0

return ret
