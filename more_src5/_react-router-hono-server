#compdef react-router-hono-server
# =============================================================================
# react-router-hono-server — the Vite plugin that creates a Hono server for
#                            your React Router app in less than 10 seconds.
#                            Bundles a tiny `reveal` CLI that drops a starter
#                            `server.ts` (or `server/index.ts`) into the
#                            consuming app so you don't have to copy boilerplate
#                            from the README.  Adapters for node, bun, and
#                            cloudflare workers ship out of the box; the
#                            generated server picks the right runtime from the
#                            user's `vite.config.ts` `runtime:` field.
#
# Author:  Raphaël Moreau (rphlmr)
# Source:  https://github.com/rphlmr/react-router-hono-server
# CLI:     src/cli.ts (uses @drizzle-team/brocli)
# Library: @drizzle-team/brocli
#          ("Modern type-safe way of building CLIs with TypeScript or
#           JavaScript by Drizzle Team")
# License: MIT
# Status:  Stable — 430+ stars; canonical recipe for React-Router-v7 + Hono
#          stacks; recommended in the React Router community as the Hono
#          adapter pattern.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — TS-NODE CROSSES TO 32
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents the
# 32ND TypeScript-Node CLI library variant.  TypeScript-Node climbs from
# 31 to 32 documented libraries (@drizzle-team/brocli via
# react-router-hono-server).  New leaderboard: Rust=32, Go=32, TS-Node=32
# (THREE-WAY TIE RESTORED AT R500 ROUND-NUMBER MILESTONE).  Taxonomy now
# spans 239 cross-language CLI library variants across 57 documented
# languages.
# -----------------------------------------------------------------------------
#
# WHAT IS @drizzle-team/brocli AND WHY IS IT A DISTINCT 32ND TS-NODE
# CLI LIBRARY VARIANT?
#
# @drizzle-team/brocli (https://github.com/drizzle-team/brocli, 464+ stars,
# emoji 🥦) is **Drizzle Team's "Modern type-safe way of building CLIs with
# TypeScript or JavaScript"**.  It is the parser that powers drizzle-kit
# (the Drizzle ORM migration / push CLI used by every Drizzle ORM user).
# Drizzle Team — Andrew Sherman (AndriiSherman), Alex Blokh, Dan Kochetov
# — extracted brocli from drizzle-kit's internals after years of iterating
# on a CLI surface that needed type-level guarantees on flag types,
# composable option sets across commands, dedicated `transform` hooks for
# runtime config decoupling, command-level `hooks` for cross-cutting
# concerns, themable help output, and a docs-generation API that
# eliminates documentation drift.
#
# brocli is DISTINCT from every documented TS-Node CLI library on FIVE
# specific axes:
#
#   1. ZERO-DEPENDENCY FUNCTION-CALL BUILDER (NO STRUCT, NO CLASS, NO
#      ANNOTATION) — brocli's command surface is built by calling
#      free-standing functions and composing them:
#         const push = command({
#           name: "push",
#           options: {
#             dialect: string().enum("postgresql", "mysql", "sqlite"),
#             databaseSchema: string().required(),
#             databaseUrl: string().required(),
#             strict: boolean().default(false),
#           },
#           handler: (opts) => { ... },
#         });
#         run([push]);
#      Compare commander R??? (chained `.command().option().action()`
#      string DSL), yargs (chained `.command(spec, ...).demand().argv`),
#      oclif (file-based command discovery + class-per-command), citty
#      (defineCommand({meta, args, run}) UnJS), cleye R472 (string-
#      command map + typed flags object), clerc R496 (chained Clerc.create
#      ()), commander-rs / clap-derive style.  brocli's option-builder
#      API uses TYPED FACTORY FUNCTIONS — `string()`, `number()`,
#      `boolean()`, `positional()` — that return chainable builders.
#      First documented TS-Node CLI library to use the "**factory-
#      function + method-chain options + plain-object commands**"
#      pattern as a deliberate API decision.
#
#   2. OPTION-LEVEL FLUENT BUILDER WITH POST-FIX MODIFIERS — brocli's
#      option types are constructed by a factory call and then refined
#      by chained method calls:
#         string()                    → required: false, type: string
#         string().required()         → required: true
#         string().default("x")       → default value "x"
#         string().enum("a","b","c")  → enum-constrained values
#         string().alias("-s")        → short-form alias
#         string().desc("...")        → help description
#         string().hidden()           → hide from --help
#         number().default(8000)
#         boolean().alias("-v")
#         positional().desc("file path")
#      The .method() chain reads left-to-right as "type, modifiers,
#      description" — closer to **clap-derive's attribute order in
#      Rust** than to commander's `.option()` string DSL.  Compare:
#        commander:  `.option("-d, --debug", "enable debug")`
#        yargs:      `.option("debug", {alias: "d", type: "boolean"})`
#        oclif:      `Flags.boolean({char: "d"})`
#        citty:      `{ type: "boolean", alias: "d" }`
#        cleye R472: `{ debug: Boolean }`
#        clerc R496: `.flag("debug", { type: Boolean, alias: "d" })`
#        brocli:     `boolean().alias("-d")` (factory-then-modifier chain)
#
#   3. EXPLICIT GLOBAL-PARAMS PASSTHROUGH + REUSABLE OPTION SETS — brocli
#      supports defining a SHARED `options` OBJECT that multiple commands
#      can spread into their own options:
#         const dbOptions = {
#           url: string().required(),
#           schema: string().required(),
#         };
#         const push = command({
#           name: "push",
#           options: { ...dbOptions, strict: boolean() },
#           handler: ...,
#         });
#         const pull = command({
#           name: "pull",
#           options: { ...dbOptions, output: string() },
#           handler: ...,
#         });
#      This is plain JavaScript object spread — not a library API.
#      Brocli's design DELIBERATELY exposes options as a plain
#      Record<string, OptionBuilder>, making cross-command option
#      reuse work via the language rather than via a framework method.
#      Compare oclif's BaseCommand class inheritance, commander's
#      `.option()` per-command repetition, yargs' middleware pattern,
#      and citty's UnJS `parent` field.  brocli is the FIRST TS-Node
#      CLI library to make reusable option sets work via plain object
#      spread on a documented public type contract.
#
#   4. `transform` HOOK FOR RUNTIME CONFIG DECOUPLING — brocli commands
#      may declare an OPTIONAL `transform: (opts) => transformedOpts`
#      hook between parsing and the handler:
#         const push = command({
#           name: "push",
#           options: { config: string() },
#           transform: async (opts) => {
#             const cfg = await readConfig(opts.config);
#             return { ...opts, ...cfg };
#           },
#           handler: (opts) => {
#             // opts has both CLI flags AND merged config-file values
#           },
#         });
#      The transform hook is REQUESTED in the brocli README as a "to
#      decouple runtime config consumption from command business logic"
#      feature.  Compare:
#        commander:  no transform hook (preAction is for side effects)
#        yargs:      middleware chain (transforms argv globally)
#        oclif:      this.parse() returns typed flags, no transform hook
#        citty:      `setup` hook is for side effects
#        cleye R472: no transform hook
#        clerc R496: lifecycle plugins but no transform-then-handle
#                    chain on a single command
#        brocli:     `transform: (opts) => transformedOpts` (UNIQUE
#                    per-command typed transform hook with type
#                    inference on the return type flowing into handler)
#      Type inference: brocli infers `handler`'s parameter type from
#      EITHER the `options` schema OR the `transform` return type,
#      whichever is present.
#
#   5. DOCS-GENERATION API + THEMES (NON-RUNTIME METADATA) — brocli
#      exposes a separate `metadata` field on commands and a global
#      `theme` config for `help` output formatting:
#         const push = command({
#           name: "push",
#           shortDesc: "Apply schema to database",
#           desc: "Reads your Drizzle schema and pushes it...",
#           metadata: {
#             category: "schema",
#             since: "0.20.0",
#             stable: true,
#           },
#           options: { ... },
#           handler: ...,
#         });
#      The `metadata` field is IGNORED at runtime and exists purely for
#      docs-generation tooling that walks the command tree.  Themes:
#      `run([cmd], { theme: themeFn })` where themeFn(helpStruct) =>
#      string lets you fully replace help output.  Compare:
#        oclif:    runs help via Help class (subclass to override)
#        commander: `.helpInformation()` method override
#        yargs:    `.help()` string only, no theme function
#        citty:    UnJS uses scule/case helpers but no theme hook
#        brocli:   themeFn receives a structured help object —
#                  cleanest docs-generation API among TS-Node libs.
#      First documented TS-Node CLI library to ship a docs-generation
#      pipeline as a first-class library concern (not just `--help`
#      rendering).
#
# THE @drizzle-team/brocli API SURFACE (verbatim from upstream README)
#
#   import {
#     command, string, number, boolean, positional,
#     run,
#   } from "@drizzle-team/brocli";
#
#   const push = command({
#     name: "push",
#     desc: "Apply schema to database",
#     shortDesc: "Push schema",
#     aliases: ["p"],
#     options: {
#       dialect: string().enum("postgresql", "mysql", "sqlite"),
#       databaseSchema: string().required(),
#       databaseUrl: string().required(),
#       strict: boolean().default(false),
#     },
#     transform: (opts) => opts,
#     handler: (opts) => { /* business logic */ },
#     help: "Custom help text or callback",
#     hidden: false,
#     metadata: { category: "schema" },
#   });
#
#   const reveal = command({
#     name: "reveal",
#     subcommands: [
#       command({ name: "file",   handler: () => { ... } }),
#       command({ name: "folder", handler: () => { ... } }),
#     ],
#   });
#
#   run([push, reveal], {
#     name: "CLI Name",
#     version: "1.0.0",          // or async () => fetchVersion()
#     theme: (help) => render(help),
#   });
#
# Option builder factories:
#   string(name?)        — string-valued (--opt=value | --opt value)
#   number(name?)        — number-valued (parsed via Number())
#   boolean(name?)       — flag (--opt | --no-opt | --opt=true|false)
#   positional(name?)    — positional argument (no `--`)
#
# Chainable modifiers on every option builder:
#   .required()          — error if missing
#   .default(value)      — fallback when not specified
#   .enum(a, b, c)       — restrict to enumerated values
#   .alias("-x")         — short-form alias
#   .desc("...")         — help description
#   .hidden()            — exclude from --help
#
# Run-config options:
#   name                 — CLI display name
#   version              — string OR async callback for --version/-v
#   theme                — help-output renderer function
#   omitKeysOfUndefinedOptions — skip undefined keys in opts object
#   globals              — global options applied to every command
#   hook                 — before/after handler hooks for every command
#
# CONTRAST WITH OTHER TS-NODE CLI LIBRARIES DOCUMENTED IN THE CORPUS
#
#   * commander                  — chained .command().option().action()
#   * yargs                      — chained .command(spec).demand().argv
#   * oclif                      — file-based + class-per-command
#   * citty (UnJS)               — defineCommand({meta, args, run})
#   * cac                        — minimal chained .command().option()
#   * meow                       — fully-static parsing from JSDoc comment
#   * minimist                   — pure parser, no command abstraction
#   * sade                       — chained, lightweight
#   * arg                        — pure parser (Vercel)
#   * yargs-parser               — parsing kernel under yargs
#   * mri                        — minimist replacement, lighter
#   * args-parser                — variations on minimist API
#   * cleye R472                 — string-command map + typed flags
#   * clipanion                  — class-based with attribute decorators
#   * gluegun                    — extension-plugin architecture
#   * arg-parser                 — typed plain object schema
#   * gunshi (define+cli)        — typed-define modern variant
#   * stricli R484 (evalite)     — Bloomberg-built complex CLI framework
#   * type-flag                  — low-level typed flag primitive
#   * tinyargs                   — egoist's parser + Option class
#   * breadc                     — modern minimal TS framework
#   * clerc R496                 — plugin-driven typed chained API
#   * brocli (THIS)              — factory-function + method-chain
#                                  options + plain-object commands +
#                                  transform hook + theme + metadata +
#                                  reusable option sets via spread
#
# REAL-WORLD @drizzle-team/brocli USERS:
#
#   * drizzle-team/drizzle-orm:drizzle-kit (UPSTREAM) — Drizzle ORM
#       migration / push / introspection CLI
#   * rphlmr/react-router-hono-server (THIS, 430*)
#   * homarr-labs/homarr (3961*) — self-hosted dashboard, packages/cli
#   * pollinations/pollinations (4582*) — Gen-AI platform spore-to-microbe
#   * jonaspm/bunwright — Bun-native browser automation
#   * agorischek/verify-repo — repo verification bundler
#   * jaypopat/fyp — final-year-project CLI
#   * fTrestour/bookmarks — bookmark indexer
#   * compeer-ai/compeer — packages/cli for AI peer tooling
#   * aliou/obsdx — Obsidian extraction daemon
#   * ihusemann/ivy-orm — Drizzle-inspired ORM with kit-style commands
#   * bhagyamudgal/worktree-cli — Git worktree manager
#   * AmanVarshney01/focus-tree — focus tree CLI
#   * Jordan-Mysten/sui-mcp — Sui MCP server
#   * myty/deno-drizzle-demo — Deno + Drizzle demo
#
# brocli was extracted from drizzle-kit and its design is heavily
# informed by what Drizzle Team needed for a database-tooling CLI:
# typed options that flow into handler params, transform hook for
# config merging, themeable help, and docs generation that can't
# drift from the implementation.
#
# -----------------------------------------------------------------------------
# REACT-ROUTER-HONO-SERVER'S CLI SURFACE (verbatim from src/cli.ts)
# -----------------------------------------------------------------------------
#
# USAGE:
#   react-router-hono-server [--help|-h] <COMMAND> [SUBCOMMAND]
#
# Commands:
#   reveal file        Create app/server.ts (the single-file Hono server
#                      entrypoint).  Reads `runtime:` from vite.config.ts
#                      and emits `import { createHonoServer } from
#                      "react-router-hono-server/<runtime>";`.
#
#   reveal folder      Create app/server/index.ts (the multi-file Hono
#                      server layout, with the same runtime detection).
#                      Auto-creates app/server/ directory if missing.
#
#   help               Built-in brocli help command
#
# Built-in brocli flags (always reserved, work everywhere):
#   --help, -h         Show help (works at every level: root, command,
#                      subcommand)
#
# Runtime detection:
#   The CLI parses `runtime: 'node'|'bun'|'cloudflare'` from your
#   vite.config.ts and writes an import for the matching adapter:
#     `import { createHonoServer } from "react-router-hono-server/node";`
#     `import { createHonoServer } from "react-router-hono-server/bun";`
#     `import { createHonoServer } from "react-router-hono-server/cloudflare";`
#   Defaults to "node" if vite.config.ts is missing or has no runtime.
#
# Typical usage:
#   $ npm i react-router-hono-server
#   $ npx react-router-hono-server reveal file
#     ✨ File created at /path/to/app/server.ts
#
#   $ npx react-router-hono-server reveal folder
#     ✨ Folder and file created at /path/to/app/server/index.ts
#
# =============================================================================

_react-router-hono-server() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a top_commands reveal_subs

    top_commands=(
        'reveal:scaffold the Hono server entrypoint into the consuming app'
        'help:show help'
    )

    reveal_subs=(
        'file:create app/server.ts (single-file Hono server)'
        'folder:create app/server/index.ts (multi-file layout)'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        (cmd)
            _describe -t commands 'react-router-hono-server command' top_commands && ret=0
            ;;
        (args)
            case $line[1] in
                (reveal)
                    _arguments \
                        '(- *)'{-h,--help}'[show help]' \
                        '1: :->reveal_sub' && ret=0
                    case $state in
                        (reveal_sub)
                            _describe -t reveal 'reveal subcommand' reveal_subs && ret=0
                            ;;
                    esac
                    ;;
            esac
            ;;
    esac

    return ret
}

_react-router-hono-server "$@"
