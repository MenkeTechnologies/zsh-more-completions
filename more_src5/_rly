#compdef rly
# _rly — Cosmos Network go-relayer rly Inter-Blockchain Communication IBC packet relayer (cosmos team, Go); cobra
# upstream: https://github.com/cosmos/relayer

_rly() {
    local -a sub=(
        'start:start the relayer'
        'config:configuration subcommands'
        'chains:chain subcommands'
        'paths:path subcommands'
        'keys:key subcommands'
        'transact:transaction subcommands'
        'tx:transaction subcommands'
        'query:query subcommands'
        'q:query alias'
        'feegrant:feegrant subcommands'
        'flush:flush packets'
        'version:show version'
        'completion:generate completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--home=+[home dir]:dir:_files -/' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml"' \
        '--debug[debug mode]' \
        '-d[debug mode]' \
        '--debug-addr=+[debug listen]:str:' \
        '--log-format=+[format]:f:(auto console json logfmt)' \
        '--memo=+[memo]:str:' \
        '--block-history=+[blocks]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'rly subcommand' sub ;;
        args)
            case $words[1] in
                config) _arguments '1:config cmd:(show init add-chains add-paths)' ;;
                chains) _arguments '1:chains cmd:(add add-dir delete edit list show address registry-list)' ;;
                paths) _arguments '1:paths cmd:(add fetch delete list new show update)' ;;
                keys) _arguments '1:keys cmd:(add delete export list restore show)' ;;
                tx|transact) _arguments '1:tx cmd:(transfer link link-then-start clients connection channel client clients-expiration register-counterparty-payee flush)' ;;
                query|q) _arguments '1:query cmd:(balance channel channels client clients connection connections header packet-commitment unrelayed-packets unrelayed-acknowledgements ibc-denoms tx txs node-state)' ;;
                start) _arguments \
                    '--processor=+[type]:p:(events legacy)' \
                    '-p+[type]:p:(events legacy)' \
                    '--time-threshold=+[duration]:str:' \
                    '*:path:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_rly "$@"
