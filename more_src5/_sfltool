#compdef sfltool
# Documentation: https://keith.github.io/xcode-man-pages/sfltool.1.html
# Reference accessed: 2026-05-21
# Verified: upstream Apple man page at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'archive:snapshot SharedFileList persistent store locations'
  'dumpbtm:dump current Background Task Management status'
  'resetbtm:reset login and background item data'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'sfltool subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (archive)
        _arguments \
          '-z[compress the archive into a zipped file]' && ret=0
        ;;
    esac
    ;;
esac

return ret
