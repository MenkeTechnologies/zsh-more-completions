#compdef skate
# Documentation: https://github.com/charmbracelet/skate
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# skate - Charm personal key-value store. README documents these
# subcommands and flags only; @db-name syntax appended to keys
# selects database. Removed fabricated --db, --key-delimiter,
# --output/-o, delete/sync/reset subcommands not present in upstream.

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'set:store a key-value pair'
  'get:retrieve a value for a key'
  'list:list all key-value pairs'
  'list-dbs:list all databases'
)

_arguments -s -S \
  '--help[show help]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      list)
        _arguments -s -S \
          '-k[list keys only]' \
          '-v[list values only]' \
          '-r[reverse sort]' \
          '-d[delimiter between key and value]:delimiter:' \
          '-b[show binary values]' && ret=0
        ;;
      get|set|list-dbs)
        _arguments -s -S '*:arg:' && ret=0
        ;;
    esac
    ;;
esac

return ret
