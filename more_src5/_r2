#compdef r2 radare2
# Documentation: https://manpages.debian.org/unstable/radare2/radare2.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for radare2 (r2)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-a+[force asm.arch]:arch:' \
  '-A[run aaa before prompt]' \
  '-b+[force asm.bits]:bits:(16 32 64)' \
  '-B+[base address for PIE binaries]:baddr:' \
  '-c+[execute radare command]:command:' \
  '-d[debug the executable]' \
  '-D+[set debug backend]:backend:' \
  '-e+[evaluate config var]:key=value:' \
  '-f[set blocksize to file size]' \
  '-h[show help]' \
  '-H[show files and environment help]' \
  '-i+[run script file after loading]:script:_files' \
  '-I+[run script file before loading]:script:_files' \
  '-j[run QJS script or enter qjs shell]' \
  '-k+[select kernel (asm.os)]:kernel:(linux windows darwin freebsd netbsd openbsd)' \
  '-l+[load plugin file]:plugin:_files' \
  '-L[list loaded IO plugins]' \
  '-m+[map file at given address]:addr:' \
  '-M[disable demangling]' \
  '-n[do not perform any analysis]' \
  '-N[do not load user settings or scripts]' \
  '-p+[use project]:project:' \
  '-P+[apply rapatch file and quit]:file:_files' \
  '-q[quiet mode (no prompt) and quit]' \
  '-Q[quiet mode and quit faster]' \
  '-r+[rarun2 profile]:file:_files' \
  '-R+[rarun2 directive]:directive' \
  '-s+[initial seek]:addr:' \
  '-S[sandbox mode]' \
  '-t[analyze in background thread]' \
  '-T[skip file hashes]' \
  '-u[unfiltered bin names]' \
  '(-)-v[show radare2 version]' \
  '-V[show radare2 library versions]' \
  '-w[open file in write mode]' \
  '-x[map without executable permissions]' \
  '-X[disable extract plugins]' \
  '-z[search for strings in data sections]' \
  '-0[print \x00 after init and every command]' \
  '-1[redirect stderr to stdout]' \
  '-2[close stderr before starting RCore]' \
  '*:file:_files' && ret=0

return ret
