#compdef quartus_pgm
# _quartus_pgm — Intel Altera Quartus quartus_pgm CLI for the device programmer downloading SOF POF JIC RBF programming files to Intel FPGA devices over USB-Blaster Ethernet-Blaster Arrow USB JTAG cables list-cables list-jtag (Intel team, C++); custom argparse
# upstream: https://www.intel.com/content/www/us/en/products/details/fpga/development-tools/quartus-prime.html

_quartus_pgm() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-l[list cables]' \
        '--list[list cables]' \
        '-c+[cable]:c:(USB-Blaster USB-BlasterII Ethernet-Blaster Arrow-USB-Blaster Ethernet)' \
        '--cable=+[cable]:c:(USB-Blaster USB-BlasterII Ethernet-Blaster Arrow-USB-Blaster Ethernet)' \
        '-m+[mode]:m:(jtag as ps fpp)' \
        '--mode=+[mode]:m:(jtag as ps fpp)' \
        '-o+[operation file device]:str:' \
        '--operation=+[operation file device]:str:' \
        '--silent[silent]' \
        '--accelerator=+[name]:str:' \
        '--list-devices[list devices]' \
        '--read_chain[read JTAG chain]' \
        '--auto-detect[auto detect]' \
        '--device=+[device index]:n:' \
        '-d+[device index]:n:' \
        '--ir-mask=+[mask]:str:' \
        '--mfp=+[file]:file:_files -g "*.mfp"' \
        '--jam-action=+[name]:str:' \
        '--ja_action_param=+[param]:str:' \
        '*:cable args:'
}

_quartus_pgm "$@"
