#compdef rhpict
# Documentation: https://floyd.lbl.gov/radiance/man_html/rhpict.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Radiance rhpict: holodeck-based image rendering.
local curcontext="$curcontext" ret=1
_arguments -C \
  '-s[smooth resampling with linear interpolation (default)]' \
  '-r[random resampling]:randomness fraction 0-1:' \
  '-x[maximum x resolution]:n:' \
  '-y[maximum y resolution]:n:' \
  '-pa[pixel aspect ratio (height over width)]:ratio:' \
  '-pe[exposure value for output pictures]:expval:' \
  '-vt[view type]:type:((v\:perspective l\:parallel c\:cylindrical h\:hemispherical\ fisheye a\:angular\ fisheye s\:planisphere))' \
  '-vp[view point]:x y z:' \
  '-vd[view direction]:x y z:' \
  '-vu[view up vector]:x y z:' \
  '-vh[view horizontal size]:val:' \
  '-vv[view vertical size]:val:' \
  '-vo[view fore clipping plane distance]:val:' \
  '-va[view aft clipping plane distance]:val:' \
  '-vs[view shift amount]:val:' \
  '-vl[view lift amount]:val:' \
  '-vf[read view parameters from file]:file:_files' \
  '-S[generate multiple frames from stdin with sequence numbering]:seqstart:' \
  '-o[output file(s) instead of stdout]:fspec:_files' \
  '-w[disable warning messages]' \
  '*:holodeck file:_files -g "*.hdk"' && ret=0
return ret
