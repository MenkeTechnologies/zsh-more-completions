#compdef s3-credentials

_s3-credentials() {
    local curcontext="$curcontext" state line ret=1

    _arguments -C \
        '(- *)--help[show help message and exit]' \
        '(- *)--version[show version and exit]' \
        '1:subcommand:->subcmd' \
        '*::args:->args' && ret=0

    case $state in
        subcmd)
            local -a subcmds=(
                'create:create S3 credentials for a bucket'
                'list-users:list IAM users'
                'list-buckets:list S3 buckets'
                'delete-user:delete an IAM user'
                'policy:output the JSON policy for a bucket'
                'auth:save default credentials'
            )
            _describe -t commands 's3-credentials subcommand' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                create)
                    _arguments \
                        '--username=[IAM username to create]:username:' \
                        '--bucket=[S3 bucket name]:bucket:' \
                        '--prefix=[restrict access to prefix]:prefix:' \
                        '--read-only[grant read-only access]' \
                        '--write-only[grant write-only access]' \
                        '--policy=[custom JSON policy]:policy file:_files' \
                        '--duration=[duration in seconds for temporary credentials]:seconds:' \
                        '--output=[output format]:format:(json ini)' \
                        '--auth=[path to auth credentials file]:auth file:_files' \
                        '*:bucket name:' && ret=0
                    ;;
                delete-user)
                    _arguments \
                        '--auth=[path to auth credentials file]:auth file:_files' \
                        '*:username:' && ret=0
                    ;;
                list-users|list-buckets)
                    _arguments \
                        '--auth=[path to auth credentials file]:auth file:_files' && ret=0
                    ;;
                policy)
                    _arguments \
                        '--read-only[generate read-only policy]' \
                        '--write-only[generate write-only policy]' \
                        '--prefix=[restrict to prefix]:prefix:' \
                        '*:bucket name:' && ret=0
                    ;;
                auth)
                    _arguments \
                        '--auth=[path to auth credentials file]:auth file:_files' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_s3-credentials "$@"
