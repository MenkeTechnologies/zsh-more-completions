#compdef shtest
# _shtest — shtest tiny shell test runner (community); minimal Bash test runner with diff assertion
# upstream: https://github.com/sstephenson/bats fork ecosystem

_shtest() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '*:script:_files -g "*.sh"'
}

_shtest "$@"
