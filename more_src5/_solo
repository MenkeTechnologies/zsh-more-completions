#compdef solo
# _solo — solo / solo2 keys CLI (manage SoloKeys FIDO2 / U2F security tokens; subcommands: key, ls, list, monitor, reset, ping, version, program, sign, verify, set-pin, change-pin; per-key flags include --serial and --hmac-secret)
# upstream: https://github.com/solokeys/solo
# Subcommands from solo solo/cli on tip.

_solo() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'solo command' '(key ls list monitor reset ping version program sign verify set-pin change-pin make-credential get-assertion)' ;;
        args) _arguments '--serial+[device serial]:serial:' '*:argument:_files' ;;
    esac
}

_solo "$@"
