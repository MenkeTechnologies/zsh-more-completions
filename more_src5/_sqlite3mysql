#compdef sqlite3mysql
# Documentation: https://github.com/techouse/sqlite3-to-mysql
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Click-shipped completion; the binary self-serves _SQLITE3MYSQL_COMPLETE.

_sqlite3mysql_completion() {
    local -a completions
    local -a completions_with_descriptions
    local -a response
    (( ! $+commands[sqlite3mysql] )) && return 1

    response=("${(@f)$(env COMP_WORDS="${words[*]}" COMP_CWORD=$((CURRENT-1)) _SQLITE3MYSQL_COMPLETE=zsh_complete sqlite3mysql)}")

    for type key descr in ${response}; do
        if [[ "$type" == "plain" ]]; then
            if [[ "$descr" == "_" ]]; then
                completions+=("$key")
            else
                completions_with_descriptions+=("$key":"$descr")
            fi
        elif [[ "$type" == "dir" ]]; then
            _path_files -/
        elif [[ "$type" == "file" ]]; then
            _path_files -f
        fi
    done

    if [ -n "$completions_with_descriptions" ]; then
        _describe -V unsorted completions_with_descriptions -U
    fi

    if [ -n "$completions" ]; then
        compadd -U -V unsorted -a completions
    fi
}

if [[ $zsh_eval_context[-1] == loadautofunc ]]; then
    # autoload from fpath, call function directly
    _sqlite3mysql_completion "$@"
else
    # eval/source/. command, register function for later
    compdef _sqlite3mysql_completion sqlite3mysql
fi

