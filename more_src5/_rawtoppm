#compdef rawtoppm
# Documentation: man rawtoppm (Netpbm)
# Source: convert raw RGB byte data to a PPM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-headerskip+[header bytes to skip]:N:' \
    '-rowskip+[bytes to skip after each row]:N:' \
    '(-rgb -rbg -grb -gbr -brg -bgr)-rgb[RGB byte order]' \
    '(-rgb -rbg -grb -gbr -brg -bgr)-rbg[RBG byte order]' \
    '(-rgb -rbg -grb -gbr -brg -bgr)-grb[GRB byte order]' \
    '(-rgb -rbg -grb -gbr -brg -bgr)-gbr[GBR byte order]' \
    '(-rgb -rbg -grb -gbr -brg -bgr)-brg[BRG byte order]' \
    '(-rgb -rbg -grb -gbr -brg -bgr)-bgr[BGR byte order]' \
    '(-interpixel -interrow)-interpixel[interleaved per pixel]' \
    '(-interpixel -interrow)-interrow[interleaved per row]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:width:' \
    '2:height:' \
    '3:image data file:_files' \
    && ret=0

return ret
