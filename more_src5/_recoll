#compdef recoll
# Documentation: https://www.recoll.org/manpages/recoll.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)-h[show help (combine with -t for command-line help)]' \
  '-c+[configuration directory (overrides RECOLL_CONFDIR)]:dir:_directories' \
  '-L+[interface language]:lang' \
  '-w[start GUI minimized]' \
  '-W[start with only system-tray icon visible]' \
  '-o[interpret query as "any word" simple search]' \
  '-l[interpret query as query-language search (default)]' \
  '-f[interpret query as file-name search]' \
  '-a[interpret query as "all words" simple search]' \
  '-q+[initial query string]:query' \
  '-t[command-line mode (recollq-like, no GUI)]' \
  '*:query terms:' && ret=0

return ret
