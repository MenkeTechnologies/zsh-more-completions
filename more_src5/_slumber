#compdef slumber
# Documentation: https://github.com/LucasPickering/slumber
# Reference accessed: 2026-05-21
# Verified: crates/cli/src/lib.rs and crates/cli/src/commands/*.rs in upstream.

# slumber - terminal-based HTTP/REST client (TUI + CLI)

local curcontext="$curcontext" state line ret=1

_slumber_commands() {
  local -a commands=(
    'request:execute a single request and print its response'
    'req:execute a single request and print its response'
    'rq:execute a single request and print its response'
    'generate:render a request and generate equivalent for third-party client'
    'gen:render a request and generate equivalent for third-party client'
    'import:generate a Slumber collection from an external format'
    'new:generate a new Slumber collection file'
    'collection:view and edit the active Slumber request collection file'
    'config:view and edit global Slumber configuration'
    'db:access and modify the Slumber database'
  )
  _describe -t commands 'slumber command' commands
}

# Global args (apply to all subcommands and the TUI)
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-f --file)'{-f+,--file=}'[collection file]:file:_files' \
  '--log-level=[logging verbosity]:level:(off error warn info debug trace)' \
  '--print-log-path[print path to log file for this session]' \
  '1: :_slumber_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      request|req|rq)
        _arguments \
          '(-p --profile)'{-p+,--profile=}'[profile id]:profile' \
          '--basic=[HTTP Basic auth (user:pass)]:credentials' \
          '--user=[HTTP Basic auth (user:pass)]:credentials' \
          '--bearer=[HTTP Bearer token]:token' \
          '--token=[HTTP Bearer token]:token' \
          '--body=[override request body]:body' \
          '--data=[override request body]:body' \
          '*'{-F+,--form=}'[override form field (field=value)]:override' \
          '*'{-H+,--header=}'[override header (header=value)]:override' \
          '*'{-o+,--override=}'[override profile field (field=value)]:override' \
          '*--query=[override query parameter (parameter=value)]:override' \
          '--url=[set URL for the request]:url' \
          '(-v --verbose)'{-v,--verbose}'[print request and response metadata]' \
          '--output=[write response to file instead of stdout]:file:_files' \
          '--dry-run[print generated request without sending]' \
          '--exit-status[set exit code from HTTP status]' \
          '--persist[persist completed request to history]' \
          '1:recipe id' && ret=0
        ;;
      generate|gen)
        _arguments \
          '(-p --profile)'{-p+,--profile=}'[profile id]:profile' \
          '--basic=[HTTP Basic auth (user:pass)]:credentials' \
          '--bearer=[HTTP Bearer token]:token' \
          '--body=[override request body]:body' \
          '*'{-F+,--form=}'[override form field]:override' \
          '*'{-H+,--header=}'[override header]:override' \
          '*'{-o+,--override=}'[override profile field]:override' \
          '*--query=[override query parameter]:override' \
          '--url=[set URL for the request]:url' \
          '--execute-triggers[execute triggered sub-requests]' \
          '1:format:(curl)' \
          '2:recipe id' && ret=0
        ;;
      import)
        _arguments \
          '1:format:(insomnia openapi rest vscode jetbrains v3)' \
          '2:input file or URL:_files' \
          '3:output file:_files' && ret=0
        ;;
      new)
        _arguments \
          '--overwrite[overwrite existing file]' \
          '1:output file:_files' && ret=0
        ;;
      collection)
        _arguments \
          '--edit[open file in default editor]' \
          '--path[print path of collection file and exit]' && ret=0
        ;;
      config)
        _arguments \
          '--edit[open file in default editor]' \
          '--path[print path of config file and exit]' && ret=0
        ;;
      db)
        _arguments \
          '(-x --exec)'{-x+,--exec=}'[program to execute (default sqlite3)]:program' \
          '--path[print path of database file and exit]' \
          '1:subcommand:(collection coll request rq)' \
          '*:args' && ret=0
        ;;
    esac
    ;;
esac

return ret
