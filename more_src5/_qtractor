#compdef qtractor
# _qtractor — multi-track audio + MIDI sequencer (rncbc/qtractor)
# upstream: https://github.com/rncbc/qtractor
# Flags from src/qtractorOptions.cpp (QCommandLineParser).

_qtractor() {
    _arguments \
        '(- *)'{-h,--help,-?}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-s --session-id)'{-s+,--session-id=}'[NSM session identification (uuid)]:uuid:' \
        '*:project file:_files -g "*.{qtr,qts,qtz}"'
}

_qtractor "$@"
