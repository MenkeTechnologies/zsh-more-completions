#compdef solid-start
# Documentation: https://docs.solidjs.com/solid-start/getting-started
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# SolidStart wraps Vinxi: `dev`, `build`, `start` map to `vinxi dev|build|start`.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'dev:start the development server (vinxi dev)'
  'build:build for production (vinxi build)'
  'start:start the production server (vinxi start)'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config=[path to app config file]:file:_files' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'solid-start command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      dev)
        _arguments \
          '--config=[path to app config file]:file:_files' \
          '--port=[port to listen on]:port:' \
          '--host=[host to listen on]:host:_hosts' && ret=0
        ;;
      build)
        _arguments \
          '--config=[path to app config file]:file:_files' \
          '--preset=[deployment preset]:preset:' && ret=0
        ;;
      start)
        _arguments \
          '--config=[path to app config file]:file:_files' \
          '--port=[port to listen on]:port:' \
          '--host=[host to listen on]:host:_hosts' && ret=0
        ;;
    esac
    ;;
esac

return ret
