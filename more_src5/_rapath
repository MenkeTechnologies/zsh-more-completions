#compdef rapath
# _rapath — Carter Bullard QoSient Argus rapath CLI extracting end-to-end network paths from Argus flow records reconstructing per-hop layer-3 sequences and AS-paths from BGP enrichment (qosient team, C); getopt
# upstream: https://github.com/openargus/clients

_rapath() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-r+[read file]:file:_files -g "*.argus *.arg"' \
        '--read=+[read file]:file:_files -g "*.argus *.arg"' \
        '-w+[write file]:file:_files -g "*.argus *.arg"' \
        '--write=+[write file]:file:_files -g "*.argus *.arg"' \
        '-m+[match keys]:str:' \
        '--match=+[match keys]:str:' \
        '-t+[time range]:str:' \
        '--time=+[time range]:str:' \
        '-T+[timeout sec]:n:' \
        '--timeout=+[timeout sec]:n:' \
        '-N+[N records]:n:' \
        '--limit=+[N records]:n:' \
        '-A+[asn lookup]:b:(true false)' \
        '--asn=+[asn lookup]:b:(true false)' \
        '-B+[BGP routes file]:file:_files -g "*.bgp *.bview"' \
        '-d+[domain lookup]' \
        '--dns[domain lookup]' \
        '-G+[geoip]:b:(true false)' \
        '--geoip=+[geoip]:b:(true false)' \
        '-S+[source IP]:str:' \
        '-D+[dest IP]:str:' \
        '-c+[csv]:str:' \
        '--csv[csv]' \
        '-X[hex]' \
        '*:files:_files -g "*.argus *.arg *.bin *.dat"'
}

_rapath "$@"
