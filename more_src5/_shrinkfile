#compdef shrinkfile
# Documentation: man shrinkfile(1)
# Source: InterNetNews/inn backends/shrinkfile.c — truncate file to target size at line boundary (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-m+[max size before shrinking (suffix k/m/g)]:size:_default' \
    '-s+[target size after shrink]:size:_default' \
    '-n[no-op: only test size and exit]' \
    '-v[verbose]' \
    '*:file:_files' \
    && ret=0

return ret
