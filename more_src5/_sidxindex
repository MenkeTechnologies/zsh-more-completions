#compdef sidxindex
# Documentation: https://github.com/FFmpeg/FFmpeg/blob/master/tools/sidxindex.c
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# FFmpeg sidxindex creates a DASH MPD describing a set of input files
# (containing sidx atoms). Source declares only -out as a recognized
# option; all other args are taken as input filenames.
# Removed: fabricated -tpl, -base-url, -profile, -single-segment,
# -single-file, -bandwidth flags (not present in sidxindex.c).

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-out+[output MPD file]:file:_files -g "*.mpd"' \
  '*:input file:_files -g "*.(mp4|m4s|mov)"' && ret=0

return ret
