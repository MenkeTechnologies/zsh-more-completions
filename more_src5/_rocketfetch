#compdef rocketfetch
# _rocketfetch — Rust neofetch with TOML config (devanlooches/rocketfetch)
# upstream: https://github.com/devanlooches/rocketfetch
# Flags from src/cli.rs (clap).

_rocketfetch() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-V,--version}'[show version]'
        '(-c --config)'{-c+,--config=}'[custom TOML config file]:file:_files -g "*.toml"'
        '(-m --mode)'{-m+,--mode=}'[printing mode]:mode:(classic side-block bottom-block)'
        '--no-line-wrap[disable line wrapping]'
    )
    _arguments -s $args
}

_rocketfetch "$@"
