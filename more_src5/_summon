#compdef summon
# Documentation: https://github.com/cyberark/summon
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-p --provider)'{-p,--provider=}'[provider binary]:path:_files' \
  '-f+[secrets.yml path]:file:_files -g "*.yml"' \
  '--up[search upward for secrets.yml]' \
  '*-D+[variable substitution]:var=value:' \
  '--yaml=[inline YAML]:yaml:' \
  '*'{-i,--ignore=}'[ignore path]:path:' \
  '(-I --ignore-all)'{-I,--ignore-all}'[ignore all missing]' \
  '(-V --all-provider-versions)'{-V,--all-provider-versions}'[show provider versions]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[debug logging]' \
  '(-e --environment)'{-e,--environment=}'[YAML section]:section:' \
  '(- *)-h[show help]' \
  '*:command:_command_names'
