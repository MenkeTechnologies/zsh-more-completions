#compdef shopware bin-shopware
# _shopware — Shopware AG bin/console CLI for Shopware 6 e-commerce framework managing plugins themes administration imports exports media migration sales channel admin user role and cache (shopware team, PHP); Symfony Console
# upstream: https://github.com/shopware/shopware

_shopware() {
    local -a sub=(
        'cache:cache operations'
        'plugin:plugin operations'
        'theme:theme operations'
        'sales-channel:sales channel operations'
        'system:system operations'
        'database:database operations'
        'dal:DAL operations'
        'snippet:snippet operations'
        'user:user operations'
        'customer:customer operations'
        'media:media operations'
        'import:import operations'
        'export:export operations'
        'feature:feature flag operations'
        'state-machine:state machine operations'
        'http-cache:HTTP cache operations'
        'list:list commands'
        'help:show help'
        'completion:generate shell completion'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n[no interaction]' \
        '--no-interaction[no interaction]' \
        '-e+[environment]:e:(dev prod test)' \
        '--env=+[environment]:e:(dev prod test)' \
        '--ansi[force ansi]' \
        '--no-ansi[disable ansi]' \
        '--no-debug[no debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'shopware subcommand' sub ;;
        args)
            case $words[1] in
                cache) _arguments \
                    '1:action:(clear warmup pool)' ;;
                plugin) _arguments \
                    '1:action:(list install uninstall activate deactivate update upgrade refresh)' \
                    '--reinstall[reinstall]' \
                    '--keep-user-data[keep user data]' \
                    '*:plugin name:' ;;
                theme) _arguments \
                    '1:action:(change compile refresh dump)' \
                    '*:theme name:' ;;
                sales-channel) _arguments \
                    '1:action:(create list update delete)' ;;
                user) _arguments \
                    '1:action:(create change-password list)' \
                    '*:username:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_shopware "$@"
