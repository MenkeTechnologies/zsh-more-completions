#compdef scaffdog
# _scaffdog — Markdown-driven scaffolding tool (scaffdog/scaffdog)
# upstream: https://github.com/scaffdog/scaffdog
# Subcommands from packages/scaffdog/src/commands/.

_scaffdog() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '(-p --project)'{-p+,--project=}'[directory of scaffdog project]:dir:_files -/' \
        '(-v --verbose)'{-v,--verbose}'[enable logging]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'create:create a new template document'
                'generate:generate scaffold from template'
                'init:initialize scaffdog config in directory'
                'list:list available templates'
                'help:show command help'
                'version:show version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                generate)
                    _arguments \
                        '(-o --output)'{-o+,--output=}'[output destination directory]:dir:_files -/' \
                        '*'{-a+,--answer=}'[answer key\:value (repeatable)]:answer:' \
                        '(-n --dry-run)'{-n,--dry-run}'[print result to stdout]' \
                        '(-f --force)'{-f,--force}'[overwrite without prompt]' \
                        '1:template name:'
                    ;;
            esac
            ;;
    esac
}

_scaffdog "$@"
