#compdef scalafix
# Documentation: https://scalacenter.github.io/scalafix/docs/users/installation.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '--verbose[display diagnostic information]' \
  '(-c --config)'{-c+,--config=}'[scalafix config file]:file:_files -g "*.conf"' \
  '*-r+[run rule]:rule:' \
  '*--rules=[run rule]:rule:' \
  '--auto-classpath[infer classpath from semanticdb dirs]' \
  '*--auto-classpath-roots=[scan dirs]:dirs:' \
  '--classpath=[classpath]:cp:' \
  '--sourceroot=[source root]:dir:_files -/' \
  '*--semanticdb-targetroots=[semanticdb target roots]:dirs:' \
  '*--scalac-options=[options to scalac]:opts:' \
  '--scala-version=[scala version]:ver:' \
  '--check[fail if scalafix would produce a diff]' \
  '--diff[only fix files that differ in git]' \
  '--diff-base=[git revision to compare]:rev:' \
  '--exclude=[exclude pattern (glob)]:pat:' \
  '*--files=[file or dir to fix]:file:_files' \
  '--charset=[file encoding]:charset:' \
  '--stdout[print fixed code to stdout]' \
  '--syntactic[run only syntactic rules]' \
  '--out-from=[regex to find input]:re:' \
  '--out-to=[regex to find output]:re:' \
  '*: :_files -g "*.scala"' && ret=0

return ret
