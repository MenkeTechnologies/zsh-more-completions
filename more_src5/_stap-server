#compdef stap-server
# Documentation: man stap-server(8)
# Source: SystemTap stap-server (man + script) — manage SystemTap compile servers (sh).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:action:(start stop restart condrestart try-restart force-reload status)' \
    '*-c+[additional config file]:file:_files' \
    '-a+[target architecture]:arch:_default' \
    '*-r+[kernel release (repeatable)]:release:_default' \
    '*-I+[additional tapset path]:dir:_files -/' \
    '-R+[systemtap runtime path]:dir:_files -/' \
    '-B+[make options]:options:_default' \
    '-i[handle every release in /lib/modules]' \
    '-n+[server nickname]:name:_default' \
    '-p+[server process id]:pid:_pids' \
    '-u+[run-as user name]:user:_users' \
    && ret=0

return ret
