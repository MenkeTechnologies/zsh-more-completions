#compdef rsconnect
# _rsconnect — Posit/RStudio rsconnect R package CLI for deploying Shiny apps R Markdown documents Plumber APIs and Quarto projects to Posit Connect and shinyapps.io (rstudio team, R); R argparse
# upstream: https://github.com/rstudio/rsconnect

_rsconnect() {
    local -a sub=(
        'deploy:deploy content'
        'deployApp:deploy a Shiny app'
        'deployDoc:deploy R Markdown document'
        'deployAPI:deploy a Plumber API'
        'deploySite:deploy static site'
        'deployTFModel:deploy TF model'
        'deployQuarto:deploy Quarto project'
        'accounts:account operations'
        'addAccount:add account'
        'removeAccount:remove account'
        'accountInfo:account info'
        'servers:server operations'
        'addServer:add server'
        'removeServer:remove server'
        'serverInfo:server info'
        'showLogs:show logs'
        'showProperties:show properties'
        'showUsage:show usage'
        'terminateApp:terminate app'
        'restartApp:restart app'
        'forgetDeployment:forget deployment'
        'applications:list applications'
        'tasks:list tasks'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'rsconnect subcommand' sub ;;
        args)
            case $words[1] in
                deploy|deployApp|deployDoc|deployAPI|deploySite|deployQuarto) _arguments \
                    '--account=+[name]:str:' \
                    '--server=+[server]:str:' \
                    '--appName=+[name]:str:' \
                    '--appTitle=+[title]:str:' \
                    '--appId=+[id]:str:' \
                    '--contentCategory=+[c]:c:(site plot api)' \
                    '--forceUpdate[force update]' \
                    '--launch.browser=+[b]:b:(true false)' \
                    '--logLevel=+[l]:l:(quiet normal verbose)' \
                    '--lint=+[b]:b:(true false)' \
                    '--metadata=+[csv]:str:' \
                    '*:dir or appR:_files' ;;
                addAccount|addServer) _arguments \
                    '--name=+[name]:str:' \
                    '--server=+[url]:str:' \
                    '--token=+[token]:str:' \
                    '--secret=+[secret]:str:' \
                    '--certificate=+[file]:file:_files' \
                    '--apiKey=+[key]:str:' ;;
            esac
            ;;
    esac
}

_rsconnect "$@"
