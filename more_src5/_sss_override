#compdef sss_override
# Documentation: https://manpages.debian.org/unstable/sssd-tools/sss_override.8.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'user-add:add a user override'
  'user-del:delete a user override'
  'user-find:list users with overrides'
  'user-show:show user override'
  'user-import:import user overrides from file'
  'user-export:export user overrides to file'
  'group-add:add a group override'
  'group-del:delete a group override'
  'group-find:list groups with overrides'
  'group-show:show group override'
  'group-import:import group overrides from file'
  'group-export:export group overrides to file'
)

_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)--usage[show usage]' \
  '--debug=[debug level]:level:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'sss_override command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (user-add)
        _arguments \
          '(-n --name)'{-n,--name}'+[override username]:name:' \
          '(-u --uid)'{-u,--uid}'+[override UID]:uid:' \
          '(-g --gid)'{-g,--gid}'+[override GID]:gid:' \
          '(-h --home)'{-h,--home}'+[override home directory]:dir:_files -/' \
          '(-s --shell)'{-s,--shell}'+[override login shell]:shell:_files' \
          '(-c --gecos)'{-c,--gecos}'+[override GECOS field]:gecos:' \
          '(-x --certificate)'{-x,--certificate}'+[base64-encoded certificate]:cert:' \
          '1:user:_users' && ret=0 ;;
      (user-del|user-show)
        _arguments \
          '1:user:_users' && ret=0 ;;
      (user-find)
        _arguments \
          '(-d --domain)'{-d,--domain}'+[domain]:domain:' && ret=0 ;;
      (user-import|user-export)
        _arguments \
          '1:file:_files' && ret=0 ;;
      (group-add)
        _arguments \
          '(-n --name)'{-n,--name}'+[override group name]:name:' \
          '(-g --gid)'{-g,--gid}'+[override GID]:gid:' \
          '1:group:_groups' && ret=0 ;;
      (group-del|group-show)
        _arguments \
          '1:group:_groups' && ret=0 ;;
      (group-find)
        _arguments \
          '(-d --domain)'{-d,--domain}'+[domain]:domain:' && ret=0 ;;
      (group-import|group-export)
        _arguments \
          '1:file:_files' && ret=0 ;;
    esac ;;
esac

return ret
