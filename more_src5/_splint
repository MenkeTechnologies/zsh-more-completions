#compdef splint
# Documentation: https://man.archlinux.org/man/splint.1.en
# Reference accessed: 2026-05-21
# Verified: upstream splint(1) man page + splint.org manual.

# Zsh completion for Splint (C static analyzer)

_splint() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '-I+[add C include directory]:include dir:_files -/' \
    '-S+[add .lcl spec search directory]:spec dir:_files -/' \
    '-D+[define preprocessor symbol]:name=value:' \
    '-U+[undefine preprocessor symbol]:name:' \
    '-f+[load options file]:options file:_files' \
    '-nof[do not load default options files]' \
    '-system-dirs+[system file directories]:directories:_files -/' \
    '-tmpdir+[set temporary directory]:directory:_files -/' \
    '-weak[minimal checking for unannotated code]' \
    '-standard[standard comprehensive checking]' \
    '-checks[moderately strict checking]' \
    '-strict[extremely rigorous checking]' \
    '+strict[maximum strict checking]' \
    '-dump+[save checking state to file]:file:_files' \
    '-load+[load previously saved state]:file:_files' \
    '-nolib[skip standard library loading]' \
    '-standard-lib[use standard library variant]' \
    '-posix-lib[use POSIX library variant]' \
    '-unix-lib[use Unix library variant]' \
    '-use-stderr[send errors to standard error]' \
    '-show-summary[display error summary]' \
    '-show-scan[show processed filenames]' \
    '-stats[display processing statistics]' \
    '-quiet[suppress informational messages]' \
    '-limit+[cap consecutive similar errors]:n:' \
    '-show-column[display error column number]' \
    '-show-func[show containing function name]' \
    '-linelen+[max message line length]:n:' \
    '-help[display help]' \
    '*:source files:_files -g "*.{c,h}"' \
    && ret=0

  return ret
}

_splint "$@"
