#compdef surveyor
# _surveyor — surveyor CLI minimal infrastructure asset surveyor tool taking IP CIDR hostname domain list as input and probing each for HTTP HTTPS SSH SMTP DNS POP3 IMAP open-port banner-grabbing TLS-certificate-fingerprint TLS-version cipher-suite-enumeration producing JSON YAML CSV inventory report for attack-surface assessment (surveyor authors team, Go); pflag
# upstream: https://github.com/surveyor/surveyor

_surveyor() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-i+[input file]:file:_files' \
        '--input=+[file]:file:_files' \
        '-t+[targets]:str:' \
        '--targets=+[list]:str:' \
        '-p+[ports]:str:' \
        '--ports=+[list]:str:' \
        '-T+[threads]:n:' \
        '--threads=+[N]:n:' \
        '--timeout=+[sec]:n:' \
        '--retries=+[N]:n:' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '-f+[format]:f:(json yaml csv text table xml)' \
        '--format=+[format]:f:(json yaml csv text table xml)' \
        '--banner[grab banner]' \
        '--tls[probe TLS]' \
        '--tls-version=+[v]:v:(tls10 tls11 tls12 tls13)' \
        '--no-redirect[disable redirect following]' \
        '--user-agent=+[ua]:str:' \
        '--no-color[disable color output]' \
        '--silent[silent]' \
        '*::'
}

_surveyor "$@"
