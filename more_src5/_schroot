#compdef schroot
# Documentation: https://manpages.debian.org/schroot
# Source: schroot bin/schroot/*.cc — Debian chroot session manager (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    {-h,--help}'[show help]' \
    {-V,--version}'[show version]' \
    {-q,--quiet}'[quiet output]' \
    {-v,--verbose}'[verbose output]' \
    '--debug=-[debug level]:level:(none notice info warning critical)' \
    '(-l --list)'{-l,--list}'[list chroots]' \
    '(-i --info)'{-i,--info}'[show chroot info]' \
    '--config[show chroot config]' \
    '--location[print chroot location]' \
    '*'{-c+,--chroot=}'[chroot to select]:chroot:_default' \
    '(-a --all)'{-a,--all}'[select all chroots and sessions]' \
    '--all-chroots[select all chroots]' \
    '--all-sessions[select all active sessions]' \
    '--all-source-chroots[select all source chroots]' \
    '--exclude-aliases[do not include aliases]' \
    {-d+,--directory=}'[chroot directory]:dir:_files -/' \
    {-s+,--shell=}'[login shell]:shell:_command_names' \
    {-u+,--user=}'[user (default current)]:user:_users' \
    {-p,--preserve-environment}'[preserve environment]' \
    '*'{-o+,--option=}'[set option NAME=VALUE]:opt:_default' \
    '--automatic-session[auto session (default)]' \
    '(-b --begin-session)'{-b,--begin-session}'[begin session]' \
    '--recover-session[recover existing session]' \
    '(-r --run-session)'{-r,--run-session}'[run existing session]' \
    '(-e --end-session)'{-e,--end-session}'[end existing session]' \
    {-n+,--session-name=}'[session name]:name:_default' \
    {-f,--force}'[force operation]' \
    '*::command:_command_names -e' \
    && ret=0

return ret
