#compdef sif-info
# Documentation: https://github.com/sylabs/sif
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: sif-info is a legacy/deprecated front-end superseded by
# `sif info`. No standalone upstream CLI reference; restricted to the
# universally-supported -h/--help and positional SIF file argument.
# sif-info: print SIF header information (deprecated, use sif info)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '*:SIF file:_files -g "*.sif"' && ret=0
return ret
