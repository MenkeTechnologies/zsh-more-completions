#compdef rpki-client
# Documentation: https://man.openbsd.org/OpenBSD-current/rpki-client.8
# Reference accessed: 2026-05-21
# Verified: OpenBSD rpki-client(8) upstream manpage — RPKI validator
# for BGP origin validation. Single-dash flags only.
# Per upstream:
#  -B = BIRD output (v2.16+)
#  -o = OpenBGPD output (the default if -B/-c/-j are unspecified)
#  -p = parallel validation threads (real, default 2)
#  -s = total runtime timeout in seconds (real, default 3600)
#  -e = alternative rsync program path
#  -t = TAL file (repeatable). NO -T (-T does not exist).
# Removed from prior file: bogus claims that -p and -s were
# fabricated; they are real. Corrected -B/-o descriptions.

local ret=1
_arguments -s \
  '(- *)-V[print version]' \
  '-0[include hazardous AS0 TALs]' \
  '-A[exclude ASPA from output]' \
  '-B[BIRD-compatible output (v2.16+)]' \
  '-b+[source address for HTTP/rsync]:addr:' \
  '-c[CSV output]' \
  '-d+[cache directory]:dir:_files -/' \
  '-e+[alternative rsync program]:cmd:_command_names -e' \
  '-f+[decode/validate signed RPKI objects]:file:_files' \
  '*-H+[host shortlist (RRDP-only)]:host:_hosts' \
  '-j[JSON output]' \
  '-m[OpenMetrics output]' \
  '-n[offline mode (validate cache, no sync)]' \
  '-o[OpenBGPD output (default)]' \
  '-P+[override system time for evaluation (POSIX seconds)]:seconds:' \
  '-p+[validation thread count]:threads:' \
  '-R[disable RRDP (rsync only)]' \
  '-S+[skiplist file (blacklisted FQDNs)]:file:_files' \
  '-s+[total runtime timeout in seconds]:seconds:' \
  '*-t+[TAL file (Trust Anchor Locator)]:file:_files' \
  '*-v[verbose (cumulative)]' \
  '-x[enable experimental file format processing]' \
  '*:output dir:_files -/' && ret=0
return ret
