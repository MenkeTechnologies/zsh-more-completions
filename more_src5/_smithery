#compdef smithery
# Documentation: https://github.com/smithery-ai/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# smithery: Smithery MCP server registry CLI
local curcontext="$curcontext" state line ret=1
local -a top
top=(
  'mcp:manage MCP server connections'
  'tool:list/find/call MCP tools'
  'auth:authentication'
  'namespace:manage namespaces'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'smithery command' top && ret=0 ;;
  (args)
    case $line[1] in
      (mcp)
        local -a mcpcmds=(
          'search:search the Smithery registry'
          'add:add an MCP server connection'
          'list:list your connections'
          'remove:remove connections'
          'publish:publish an MCP server URL or bundle'
        )
        _describe -t mcpcmds 'mcp subcommand' mcpcmds && ret=0
        ;;
      (tool)
        local -a toolcmds=(
          'list:list tools from connected MCP servers'
          'find:search tools by name or intent'
          'get:show full details for one tool'
          'call:call a tool'
        )
        _describe -t toolcmds 'tool subcommand' toolcmds && ret=0
        ;;
      (auth)
        local -a authcmds=(
          'login:login with Smithery (OAuth)'
          'logout:log out'
          'whoami:check current user'
          'token:mint a service token'
        )
        _describe -t authcmds 'auth subcommand' authcmds && ret=0
        ;;
      (namespace)
        local -a nscmds=(
          'list:list your namespaces'
          'use:set current namespace'
        )
        _describe -t nscmds 'namespace subcommand' nscmds && ret=0
        ;;
    esac
    ;;
esac
return ret
