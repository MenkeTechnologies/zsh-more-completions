#compdef sndfile-resample
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/sndfile-resample.1.html
# Reference accessed: 2026-05-16
# Verified: Ubuntu jammy sndfile-resample(1) manpage.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# sndfile-resample: libsndfile sample-rate converter
local curcontext="$curcontext" ret=1
_arguments -C \
  '-c[converter type]:type:((0\:Best\ Sinc 1\:Medium\ Sinc 2\:Fastest\ Sinc 3\:Zero\ Order\ Hold 4\:Linear))' \
  '(-to -by)-to[convert to sample rate]:rate:' \
  '(-to -by)-by[change sample rate by ratio]:ratio:' \
  '--no-normalize[disable clipping check and normalization]' \
  '-i[input file]:file:_files' \
  '-o[output file]:file:_files' && ret=0
return ret
