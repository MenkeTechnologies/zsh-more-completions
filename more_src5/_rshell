#compdef rshell
# rshell — remote MicroPython shell for file management

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'boards:list connected boards'
  'cat:display file contents'
  'cd:change directory'
  'connect:connect to a board'
  'cp:copy files'
  'edit:edit a file'
  'filesize:show file sizes'
  'filetype:show file types'
  'ls:list files'
  'mkdir:create directory'
  'repl:enter REPL on board'
  'rm:remove files'
  'rsync:synchronize files'
  'shell:run a shell command'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  {-p,--port}'=[serial port]:port:_files -g "/dev/tty*(-.)"' \
  {-b,--baud}'=[baud rate]:baud rate:(9600 19200 38400 57600 115200)' \
  {-e,--editor}'=[editor to use]:editor:' \
  {-f,--file}'=[script file to run]:file:_files' \
  '--buffer-size=[buffer size for transfers]:bytes:' \
  '--wait=[time to wait for board]:seconds:' \
  '--timing[print timing info]' \
  '--nocolor[disable colored output]' \
  '-n[do not run /etc/profile]' \
  '-a[do not run .profile]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'rshell subcommand' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
