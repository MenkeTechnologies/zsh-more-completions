#compdef rescript
# Documentation: https://rescript-lang.org/docs/manual/latest/build-overview
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for ReScript (strongly typed language that compiles to JS).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:compile the project'
  'clean:remove build artifacts'
  'format:format ReScript source files'
  'convert:convert ReasonML code to ReScript syntax'
  'dump:output internal data for debugging'
  'help:display help'
)

_arguments -s -S \
  '(- *)'{-h,-help}'[show help]' \
  '(- *)'{-v,-version}'[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'rescript command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (build)
        _arguments -s -S \
          '-w[watch mode (rebuild on file changes)]' \
          '-with-deps[build with dependencies]' \
          '-verbose[verbose output]' \
          '-warn-error=[promote warnings to errors (e.g. +110)]:spec' && ret=0
        ;;
      (format)
        _arguments -s -S \
          '-all[format all .res and .resi files in the current directory]' \
          '-stdin[read from stdin]:extension:(.res .resi)' \
          '-check[check formatting but do not write]' \
          '*:files:_files -g "*.res(i|)"' && ret=0
        ;;
      (convert)
        _arguments -s -S \
          '-all[convert all .re and .rei files in the current directory]' \
          '*:files:_files -g "*.re(i|)"' && ret=0
        ;;
    esac
    ;;
esac

return ret
