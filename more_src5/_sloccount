#compdef sloccount
# Documentation: https://dwheeler.com/sloccount/sloccount.html
# Reference accessed: 2026-05-21
# Verified: upstream user guide at the URL above.

# Zsh completion for sloccount (Source Lines of Code counter)

_arguments -s \
  '--duplicates[count duplicate files as normal files]' \
  '--crossdups[count cross-project duplicate files]' \
  '--autogen[count automatically generated files]' \
  '--multiproject[treat each directory as independent project]' \
  '--filecount[show file counts instead of SLOC]' \
  '--details[show details for each source file]' \
  '--wide[show wide tab-separated format]' \
  '--follow[follow symbolic links]' \
  '*--addlang[add language not normally shown]:language' \
  '--append[append to existing data]' \
  '--datadir[data directory for cached results]:directory:_files -/' \
  '--cached[use cached data only]' \
  '--effort[override effort estimation factor and exponent]:f e' \
  '--schedule[override schedule estimation factor and exponent]:f e' \
  '--personcost[average annual salary]:dollars' \
  '--overhead[annual overhead multiplier]:ratio' \
  '*:directories:_files -/'
