#compdef sfdd
# Documentation: http://www.ahay.org/RSF/sfdd.html
# Source: ahay/src system/main/dd.c — convert data type / format of an RSF dataset.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'form=[on-disk format]: :(ascii native xdr)' \
    'type=[output data type]: :(int float complex short long)' \
    'format=[printf-style element format for ASCII output]: :_default' \
    'ibm=[(y/n) input is IBM float format]: :(y n)' \
    'trunc=[(y/n) truncate (vs round) on float→int]: :(y n)' \
    'line=[numbers per line for ASCII output]: :_default' \
    'strip=[trailing chars to strip per ASCII line]: :_default' \
    'n1=[1st-dim size for raw input]: :_default' \
    '*:RSF file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
