#compdef stcompdirs
# _stcompdirs — compare contents of two Syncthing directories (syncthing/syncthing)
# upstream: https://github.com/syncthing/syncthing
# Flags from cmd/dev/stcompdirs/main.go (stdlib flag).

_stcompdirs() {
    _arguments \
        '(- *)-h[show help]' \
        '*:directory:_files -/'
}

_stcompdirs "$@"
