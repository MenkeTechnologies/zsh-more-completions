#compdef suricatactl
# Documentation: https://docs.suricata.io/en/latest/manpages/suricatactl.html
# Documentation: https://docs.suricata.io/en/latest/manpages/suricatactl-filestore.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URLs above.
# Removed from prior file: fabricated subcommands (reload-rules, shutdown,
# register-tenant, unregister-tenant, iface-list, iface-stat, capture-mode)
# which the upstream manpage does not document. Only 'filestore prune' is
# documented; further subcommands are intentionally omitted.

local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands=(
  'filestore:manage Suricata filestore'
)
local -a filestore_cmds=(
  'prune:prune files older than a given age'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'suricatactl command' commands && ret=0 ;;
  args)
    case $line[1] in
      filestore)
        if (( CURRENT == 2 )); then
          _describe -t commands 'filestore command' filestore_cmds && ret=0
        else
          _arguments -s -S \
            '(-h --help)'{-h,--help}'[show help]' \
            '(-n --dry-run)'{-n,--dry-run}'[show what would be done without doing it]' \
            '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
            '(-q --quiet)'{-q,--quiet}'[only log errors and warnings]' \
            '(-d --directory)'{-d+,--directory=}'[filestore directory (required)]:dir:_files -/' \
            '--age=[age threshold for file deletion (required)]:age:' && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
