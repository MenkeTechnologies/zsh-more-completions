#compdef rocksdb_sst_dump sst_dump
# Documentation: https://github.com/facebook/rocksdb/blob/main/tools/sst_dump_tool.cc
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# rocksdb_sst_dump: dump SSTable file contents/stats
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--file=[sst file or directory]:path:_files' \
  '--env_uri=[underlying Env URI]:uri:' \
  '--fs_uri=[underlying FileSystem URI]:uri:' \
  '--command=[command]:cmd:(check scan raw verify recompress identify)' \
  '--output_hex[output keys/values in hex]' \
  '--input_key_hex[input keys are hex-encoded]' \
  '--decode_blob_index[show blob indices readable]' \
  '--show_sequence_number_type[show seqno with raw]' \
  '--show_properties[show table properties]' \
  '--show_summary[show aggregated summary]' \
  '--list_meta_blocks[list all meta blocks]' \
  '--from=[start key]:key:' \
  '--to=[end key]:key:' \
  '--prefix=[key prefix]:key:' \
  '--read_num=[max entries to read]:n:' \
  '--verify_checksum[verify checksums]' \
  '--compression_types=[compression algos list]:types:' \
  '--compression_level=[single compression level]:n:' \
  '--compression_level_from=[start compression level]:n:' \
  '--compression_level_to=[end compression level]:n:' \
  '--block_size=[block size for recompress]:bytes:' \
  '--compression_manager=[custom compression manager]:name:' \
  '--enable_index_compression=[compress index blocks]:bool:(true false)' \
  '--compression_max_dict_bytes=[dict size limit]:n:' \
  '--compression_zstd_max_train_bytes=[zstd training limit]:n:' \
  '--compression_max_dict_buffer_bytes=[dict buffer bytes]:n:' \
  '--compression_use_zstd_finalize_dict[use zstd finalizeDictionary]' \
  '--compression_parallel_threads=[parallel compression threads]:n:' \
  '--parse_internal_key=[decode internal key]:hex:' \
  '--readahead_size=[readahead buffer bytes]:n:' \
  '*:sst file:_files' && ret=0
return ret
