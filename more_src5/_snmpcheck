#compdef snmpcheck snmp-check
# _snmpcheck — snmp-check (Perl SNMP enumeration tool that walks well-known OIDs to discover system info, processes, users, network interfaces, routing table, NTP, share status; -c community, -p port, -t timeout, -r retries, -v 1|2c version, -d disable colors, -w write report file, -h help, -V version; positional argument is the target host)
# upstream: https://github.com/nccgroup/snmpcheck
# Flags from nccgroup/snmpcheck snmpcheck.pl on tip.

_snmpcheck() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[community]:community:' \
        '-p+[port]:port:' \
        '-t+[timeout seconds]:seconds:' \
        '-r+[retries]:n:' \
        '-v+[version]:version:(1 2c)' \
        '-d[disable colors]' \
        '-w+[report file]:file:_files' \
        '1:host:_hosts'
}

_snmpcheck "$@"
