#compdef rss2email r2e
# Documentation: https://github.com/rss2email/rss2email
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'new:create new feed database'
  'email:set default email'
  'add:add a feed'
  'run:fetch and send feeds'
  'list:list feeds'
  'pause:pause feeds'
  'unpause:unpause feeds'
  'delete:delete feeds'
  'reset:reset feed dynamic data'
  'opmlimport:import OPML'
  'opmlexport:export OPML'
)

_arguments -C \
  '(-v --version)'{-v,--version}'[show version]' \
  '--full-version[show all versions]' \
  '*'{-c,--config}'=[config file]:file:_files' \
  '(-d --data)'{-d,--data}'=[data file]:file:_files' \
  '*'{-V,--verbose}'[verbose]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'rss2email subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (add)
        _arguments \
          '--only-new[mark existing as sent]' \
          '1:name:' '2:url:' '3:email:' && ret=0 ;;
      (run)
        _arguments \
          '(-n --no-send)'{-n,--no-send}'[no send]' \
          '--clean[clean old entries]' \
          '*:index:' && ret=0 ;;
      (delete) _arguments '*:index:' && ret=0 ;;
      (pause|unpause|reset) _arguments '*:index:' && ret=0 ;;
      (opmlimport|opmlexport) _arguments '*:path:_files' && ret=0 ;;
      (email) _arguments '1:email:' && ret=0 ;;
      (new) _arguments '1:email:' && ret=0 ;;
    esac
    ;;
esac

return ret
