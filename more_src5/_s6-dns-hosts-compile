#compdef s6-dns-hosts-compile s6-dnsip s6-dnsip4-filter s6-dnsip6-filter s6-dnsmx s6-dnsname-filter s6-dnsns s6-dnsq s6-dnsqr s6-dnsqualify s6-dnssoa s6-dnssrv s6-dnstxt s6-randomip
# Documentation: source-direct extraction from upstream
# skarnet/s6-dns src/clients/*.c + src/utilities/*.c USAGE strings
# + subgetopt_r option-string specs + case-arm decoding for the
# mutex flag groups (s6-dnsip: -H/-h /etc/hosts-lookup mutex
# decoded from flaghosts=0|1; s6-dnsq/s6-dnsqr: -1/-2 stdout/stderr
# mutex decoded from where=&genwrite_{stdout,stderr}; s6-randomip /
# s6-dnsname-filter: -4/-6 IPv4-only / IPv6-only mutex).
# Reference accessed: 2026-05-30 via gh api.
# Skarnet s6-dns R127a — 14-stem multi-binary harvest of the s6-dns
# client + utility binaries. 3 binaries from this repo were
# previously covered (s6-dnsip4, s6-dnsip6, s6-dnsname) so they are
# deliberately omitted from this #compdef line. Sister tools to the
# wider s6 ecosystem (R117-R126). All s6-dns clients honor the
# standard ${RES_OPTIONS} env var and /etc/resolv.conf nameserver
# list out-of-the-box.

# Shared 5-flag surface for the s6-dns generic-filter clients
# (s6-dnsip4-filter, s6-dnsip6-filter, s6-dnsname-filter). These
# all go through `s6dns_generic_filter_main` upstream, so the
# accepted flags are identical.
local -a _s6dns_filter_flags
_s6dns_filter_flags=(
  '-l+[max parallel input lines buffered (default 1024)]:lines:'
  '-c+[max concurrent in-flight DNS queries (default 256)]:concurrency:'
  '-t+[per-query timeout in ms]:ms:'
  '-f+[format string for successful results (printf-like %s placeholders)]:format:'
  '-e+[format string for failed lookups (or empty to suppress)]:errorformat:'
)

case $service in

  s6-dns-hosts-compile)
    # Compile a /etc/hosts file into a packed cdb-style database
    # for fast lookup by the s6-dns client family.
    _arguments -s -S \
      '-i+[input hosts file (default /etc/hosts)]:input:_files' \
      '-o+[output compiled-hosts file]:output:_files'
    ;;

  s6-dnsip)
    # Look up both IPv4 (A) and IPv6 (AAAA) addresses for a name.
    _arguments -s -S \
      '-q[qualify the name using /etc/resolv.conf search list before query]' \
      '(-h)-H[do NOT consult /etc/hosts (or compiled-hosts cdb); query DNS only]' \
      '(-H)-h[consult /etc/hosts before falling back to DNS (default)]' \
      '-r[do NOT randomize result order]' \
      '-t+[query timeout in ms]:ms:' \
      '1:domain name:_hosts'
    ;;

  s6-dnsip4-filter)
    _arguments -s -S "${_s6dns_filter_flags[@]}"
    ;;

  s6-dnsip6-filter)
    _arguments -s -S "${_s6dns_filter_flags[@]}"
    ;;

  s6-dnsname-filter)
    _arguments -s -S \
      '(-6)-4[reverse-lookup IPv4 (A) addresses only]' \
      '(-4)-6[reverse-lookup IPv6 (AAAA) addresses only]' \
      "${_s6dns_filter_flags[@]}"
    ;;

  s6-dnsmx)
    # Look up MX records for a name (mail-exchanger priority list).
    _arguments -s -S \
      '-q[qualify with resolv.conf search list]' \
      '-r[do NOT randomize result order]' \
      '-t+[query timeout in ms]:ms:' \
      '1:domain name:_hosts'
    ;;

  s6-dnsns)
    # Look up NS records for a name (authoritative-nameserver list).
    _arguments -s -S \
      '-q[qualify with resolv.conf search list]' \
      '-r[do NOT randomize result order]' \
      '-t+[query timeout in ms]:ms:' \
      '1:domain name:_hosts'
    ;;

  s6-dnsq)
    # Low-level direct DNS query: send a single qtype query against
    # a list of nameservers (caller-supplied, not /etc/resolv.conf).
    # Useful for debugging and for non-resolver DNS introspection.
    _arguments -s -S \
      '(-2)-1[write packet dump to stdout]' \
      '(-1)-2[write packet dump to stderr]' \
      '-t+[query timeout in ms]:ms:' \
      '-D+[debug level]:level:' \
      '1:DNS qtype:(A AAAA MX NS CNAME PTR SOA SRV TXT ANY)' \
      '2:query name:_hosts' \
      '*:nameserver IP:_hosts'
    ;;

  s6-dnsqr)
    # Like s6-dnsq but uses the system resolver (/etc/resolv.conf)
    # rather than caller-supplied nameservers.
    _arguments -s -S \
      '(-2)-1[write packet dump to stdout]' \
      '(-1)-2[write packet dump to stderr]' \
      '-t+[query timeout in ms]:ms:' \
      '-D+[debug level]:level:' \
      '1:DNS qtype:(A AAAA MX NS CNAME PTR SOA SRV TXT ANY)' \
      '2:query name:_hosts'
    ;;

  s6-dnsqualify)
    # Apply the /etc/resolv.conf search-list qualification rules to
    # a name (no DNS query is sent; just textual rewriting).
    _arguments -s -S \
      '1:partial name:_hosts'
    ;;

  s6-dnssoa)
    # Look up SOA records for a name (start-of-authority data).
    _arguments -s -S \
      '-q[qualify with resolv.conf search list]' \
      '-r[do NOT randomize result order]' \
      '-t+[query timeout in ms]:ms:' \
      '1:domain name:_hosts'
    ;;

  s6-dnssrv)
    # Look up SRV records (service location for service+protocol+name).
    _arguments -s -S \
      '-q[qualify with resolv.conf search list]' \
      '-r[do NOT randomize result order]' \
      '-t+[query timeout in ms]:ms:' \
      '1:service:(http https ftp ssh smtp imap imaps pop3 pop3s ldap ldaps xmpp xmpp-server xmpp-client sip sips kerberos ntp dns)' \
      '2:protocol:(tcp udp tls)' \
      '3:domain name:_hosts'
    ;;

  s6-dnstxt)
    # Look up TXT records for a name.
    _arguments -s -S \
      '-q[qualify with resolv.conf search list]' \
      '-r[do NOT randomize result order]' \
      '-t+[query timeout in ms]:ms:' \
      '1:domain name:_hosts'
    ;;

  s6-randomip)
    # Print N random valid IPv4 and/or IPv6 addresses (no DNS query).
    _arguments -s -S \
      '(-6)-4[emit IPv4 addresses only]' \
      '(-4)-6[emit IPv6 addresses only]' \
      '-n+[number of addresses to print (default 1)]:n:'
    ;;

esac
