#compdef rocksdb_repair
# Documentation: https://github.com/facebook/rocksdb/wiki/RocksDB-Repairer
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# rocksdb_repair: try to repair a corrupted RocksDB
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--db=[database directory]:dir:_files -/' \
  '--verbose[verbose]' \
  '*:directory:_files -/' && ret=0
return ret
