#compdef redis-sentinel
# Documentation: redis-sentinel reuses redis-server with --sentinel
# Source: Redis Sentinel — high-availability monitor; same binary as redis-server.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-v,--version}'[show version]' \
    '(- *)'{-h,--help}'[show help]' \
    '--port=[listen port]:port:_ports' \
    '--bind=[listen interfaces]:ips:_hosts' \
    '--pidfile=[pid file]:file:_files' \
    '--logfile=[log file]:file:_files' \
    '--loglevel=[log level]:level:(debug verbose notice warning nothing)' \
    '--daemonize=[run as daemon]:bool:(yes no)' \
    '--supervised=[init system integration]:mode:(no upstart systemd auto)' \
    '--requirepass=[client auth password]:password:' \
    '--sentinel[explicit sentinel mode flag]' \
    '*:sentinel.conf:_files -g "*.conf"' \
    && ret=0

return ret
