#compdef sysdig
# Documentation: https://github.com/draios/sysdig/blob/dev/userspace/sysdig/sysdig.cpp
# Reference accessed: 2026-05-21
# Verified: upstream sysdig source and Arch sysdig(8) manpage.
# Removed: --help-chisel (not in upstream), --kube-api-server (use -k/--k8s-api),
# --kube-config (use -K/--k8s-api-cert), --cri, --logfile, --filter (long
# only), -pc/-pk (no such flags; use -p with format), -A as flag form
# (it's --print-ascii). Also removed --buffer-size (no such opt).

local -a arguments

arguments=(
  '(- *)'{-h,--help}'[print help page]'
  '(- *)--version[print version number]'
  {-A,--print-ascii}'[print only text portion of data buffers]'
  {-b,--print-base64}'[print data buffers in base64]'
  '-B+[enable BPF probe]:bpf_probe:'
  {-c,--chisel}'+[run chisel with arguments]:chisel:'
  '-C+[break capture into files by megabytes]:size:'
  {-cl,--list-chisels}'[list available chisels]'
  {-d,--displayflt}'[make filter a display filter]'
  {-D,--debug}'[capture sysdig own events]'
  {-E,--exclude-users}'[skip user/group table creation]'
  '-e+[break capture into files by event count]:n:'
  {-F,--fatfile}'[enable fatfile mode]'
  '--filter-proclist[apply filter to process table]'
  '-G+[break capture into files by seconds]:seconds:'
  {-H,--plugin}'+[register plugin]:plugin:'
  {-i,--chisel-info}'+[get chisel description]:chisel:'
  {-I,--input}'+[capture using specified plugin]:input:'
  {-Il,--list-inputs}'[list loaded plugins]'
  '--plugin-config-file=[load plugin config from YAML]:file:_files'
  {-j,--json}'[emit output as JSON]'
  {-k,--k8s-api}'+[Kubernetes API URL]:url:'
  {-K,--k8s-api-cert}'+[Kubernetes API authentication]:cert:_files'
  {-L,--list-events}'[list supported events]'
  {-l,--list}'[list filterable fields]'
  '--list-markdown[list fields in markdown format]'
  {-m,--mesos-api}'+[Mesos API URL]:url:'
  '-M+[stop collecting after N seconds]:seconds:'
  {-n,--numevents}'+[stop after N events]:n:'
  '--page-faults[capture page faults]'
  {-P,--progress}'[print progress on stderr]'
  {-p,--print}'+[specify output format]:format:'
  {-q,--quiet}'[suppress event screen output]'
  {-r,--read}'+[read events from file]:file:_files'
  {-R,--resolve-ports}'[resolve port numbers to names]'
  {-S,--summary}'[print event summary at end]'
  {-s,--snaplen}'+[capture first N bytes of buffers]:bytes:'
  {-t,--timetype}'+[time display format]:type:(h a r d D)'
  {-T,--force-tracers-capture}'[ensure full tracer capture]'
  '--unbuffered[disable output buffering]'
  {-v,--verbose}'[verbose output mode]'
  {-w,--write}'+[write captured events to file]:file:_files'
  '-W+[limit rotated files to N count]:n:'
  {-x,--print-hex}'[print buffers in hexadecimal]'
  {-X,--print-hex-ascii}'[print buffers in hex and ASCII]'
  {-z,--compress}'[enable tracefile compression]'
  '*:filter expression:'
)

_arguments -s -S $arguments
