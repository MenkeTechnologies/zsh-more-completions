#compdef R-CMD-rtags
# _R-CMD-rtags — R Core Team R CMD rtags generate Emacs-style ctags-style tags files for R source code (rcore team, C); getopt
# upstream: https://cran.r-project.org/

_R-CMD-rtags() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-o+[output file]:file:_files -g "TAGS *.tags"' \
        '--output=+[output file]:file:_files -g "TAGS *.tags"' \
        '-R[recursive]' \
        '--recursive[recursive]' \
        '--no-recursive[no recursive]' \
        '-e[Emacs tags format]' \
        '--ex[Emacs tags format]' \
        '--Emacs[Emacs tags format]' \
        '-v[vi tags format]' \
        '--vi[vi tags format]' \
        '--append[append to file]' \
        '*:R source file or dir:_files -g "*.R *.r *.Rd"'
}

_R-CMD-rtags "$@"
