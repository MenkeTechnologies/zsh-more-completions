#compdef sigi
# sigi - Organizer for stack-based workflows

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a commands=(
  'complete:move the current item to "_completed" stack'
  'count:print the total number of items'
  'delete:move the current item to "_deleted" stack'
  'delete-all:move all items to "_deleted" stack'
  'head:print the first item'
  'is-empty:exit with code 0 if stack is empty, 1 otherwise'
  'list:print all items'
  'move:move current item to another stack'
  'move-all:move all items to another stack'
  'next:cycle to the next item'
  'peek:print the current item (alias: head)'
  'pick:move an item to the top by index'
  'push:push a new item'
  'rot:rotate the stack (move top to bottom)'
  'swap:swap the top two items'
  'tail:print all items except the first'
)

_arguments -C -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[suppress non-essential output]' \
  '(-s --stack)'{-s+,--stack=}'[operate on specified stack]:stack name:' \
  '(-t --topic)'{-t+,--topic=}'[alias for --stack]:topic name:' \
  '(-f --format)'{-f+,--format=}'[output format]:format:(text json tsv)' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'sigi command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      push)
        _arguments '*:item text:' && ret=0
        ;;
      move|move-all)
        _arguments '1:destination stack:' && ret=0
        ;;
      pick)
        _arguments '1:item index:' && ret=0
        ;;
    esac
    ;;
esac

return ret
