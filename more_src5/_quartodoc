#compdef quartodoc quartodoc-cli
# _quartodoc — Machow / Posit quartodoc API doc generator for Python+Quarto CLI alias (Machow / Posit, Python); custom argparse
# upstream: https://github.com/machow/quartodoc

_quartodoc() {
    local -a sub=(
        'build:build API docs from configuration'
        'interlinks:generate interlinks'
        'create-ref:create reference page'
        'fetch:fetch inventory'
        'check:check configuration'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[quarto _quarto.yml]:file:_files -g "_quarto.yml *.yml *.yaml"' \
        '-c+[quarto _quarto.yml]:file:_files -g "_quarto.yml *.yml *.yaml"' \
        '--filter=+[filter pattern]:str:' \
        '-F+[filter pattern]:str:' \
        '--watch[watch and rebuild]' \
        '-w[watch and rebuild]' \
        '--dry-run[dry run]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'quartodoc subcommand' sub ;;
        args)
            case $words[1] in
                build) _arguments \
                    '--filter=+[filter pattern]:str:' \
                    '-F+[filter pattern]:str:' \
                    '--watch[watch]' \
                    '-w[watch]' \
                    '--dry-run[dry run]' ;;
                interlinks) _arguments \
                    '--quiet[quiet]' \
                    '-q[quiet]' ;;
                create-ref) _arguments \
                    '1:obj:' ;;
                fetch) _arguments \
                    '1:url:_urls' ;;
            esac
            ;;
    esac
}

_quartodoc "$@"
