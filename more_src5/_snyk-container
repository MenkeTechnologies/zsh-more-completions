#compdef snyk-container
# _snyk-container — Snyk container image scanner subcommand alias (Snyk, TypeScript); commander
# upstream: https://github.com/snyk/cli

_snyk-container() {
    local -a sub=(
        'test:test container image'
        'monitor:monitor container image'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--json[json output]' \
        '--json-file-output=+[json file output]:file:_files' \
        '--sarif[sarif output]' \
        '--sarif-file-output=+[sarif file output]:file:_files' \
        '--severity-threshold=+[severity threshold]:t:(low medium high critical)' \
        '--fail-on=+[fail on]:t:(all upgradable patchable)' \
        '--app-vulns[app vulns]' \
        '--exclude-app-vulns[exclude app vulns]' \
        '--exclude-base-image-vulns[exclude base image vulns]' \
        '--nested-jars-depth=+[nested jars depth]:n:' \
        '--platform=+[platform]:str:' \
        '--username=+[registry username]:str:_users' \
        '--password=+[registry password]:str:' \
        '--file=+[dockerfile]:file:_files' \
        '--exclude-node-modules[exclude node modules]' \
        '--policy-path=+[policy path]:file:_files' \
        '--print-deps[print deps]' \
        '--print-graph[print graph]' \
        '--remote-repo-url=+[remote repo url]:url:_urls' \
        '--ignore-policy[ignore policy]' \
        '--show-vulnerable-paths=+[show vulnerable paths]:t:(none some all)' \
        '--trust-policies[trust policies]' \
        '--policy=+[policy file]:file:_files' \
        '--tags=+[tags]:list:' \
        '--remote-repo-url=+[remote repo url]:url:_urls' \
        '--target-name=+[target name]:str:' \
        '--target-reference=+[target reference]:str:' \
        '--project-business-criticality=+[business criticality]:t:(critical high medium low)' \
        '--project-lifecycle=+[lifecycle]:t:(production development sandbox)' \
        '--project-environment=+[environment]:t:(frontend backend mobile saas onprem hosted distributed external internal)' \
        '--all-projects[all projects]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'snyk container subcommand' sub ;;
        args)
            case $words[1] in
                test|monitor) _arguments \
                    '*:image:' ;;
            esac
            ;;
    esac
}

_snyk-container "$@"
