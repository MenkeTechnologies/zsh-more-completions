#compdef sway
# Documentation: https://man.archlinux.org/man/sway.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for sway - i3-compatible Wayland compositor

_arguments \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'[specify config file]:config file:_files' \
  '(-C --validate)'{-C,--validate}'[validate config and exit]' \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '(-V --verbose)'{-V,--verbose}'[enable verbose logging]' \
  '--get-socketpath[get the IPC socket path and print it]' \
  '--unsupported-gpu[launch despite unsupported GPU]'
