#compdef sops-cli
# _sops-cli — getsops sops Secrets OPerationS encryption CLI alias (getsops / Mozilla, Go); custom argparse
# upstream: https://github.com/getsops/sops

_sops-cli() {
    local -a sub=(
        'edit:edit a sops file'
        'encrypt:encrypt a file in place'
        'decrypt:decrypt a file in place'
        'exec-env:exec a command with decrypted env vars'
        'exec-file:exec a command with decrypted file'
        'filestatus:check file encryption status'
        'groups:manage shamir groups'
        'keyservice:run keyservice'
        'publish:publish encrypted file'
        'rotate:rotate data key'
        'unset:remove key from sops file'
        'updatekeys:update keys for encrypted file'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g ".sops.yaml *.yaml"' \
        '--decryption-order=+[decryption order]:list:' \
        '--enable-local-keyservice[enable local keyservice]' \
        '--keyservice=+[keyservice tcp address]:str:' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'sops subcommand' sub ;;
        args)
            case $words[1] in
                encrypt|decrypt|edit) _arguments \
                    '--in-place[in place edit]' \
                    '-i[in place edit]' \
                    '--show-master-keys[show master keys]' \
                    '-s[show master keys]' \
                    '--input-type=+[input type]:t:(json yaml dotenv ini binary)' \
                    '--output-type=+[output type]:t:(json yaml dotenv ini binary)' \
                    '--output=+[output file]:file:_files' \
                    '--extract=+[extract subtree]:str:' \
                    '--encrypted-suffix=+[encrypted suffix]:str:' \
                    '--unencrypted-suffix=+[unencrypted suffix]:str:' \
                    '--encrypted-regex=+[encrypted regex]:str:' \
                    '--unencrypted-regex=+[unencrypted regex]:str:' \
                    '--kms=+[KMS arn csv]:str:' \
                    '--aws-profile=+[AWS profile]:str:' \
                    '--pgp=+[PGP fingerprint csv]:str:' \
                    '--gcp-kms=+[GCP KMS csv]:str:' \
                    '--azure-kv=+[Azure KV csv]:str:' \
                    '--hc-vault-transit=+[Vault transit csv]:str:' \
                    '--age=+[age public key csv]:str:' \
                    '--shamir-secret-sharing-threshold=+[shamir threshold]:n:' \
                    '*:file:_files' ;;
                rotate) _arguments \
                    '--in-place[in place]' \
                    '-i[in place]' \
                    '--input-type=+[input type]:t:(json yaml dotenv ini binary)' \
                    '--output-type=+[output type]:t:(json yaml dotenv ini binary)' \
                    '--add-kms=+[add KMS]:str:' \
                    '--rm-kms=+[remove KMS]:str:' \
                    '--add-pgp=+[add PGP]:str:' \
                    '--rm-pgp=+[remove PGP]:str:' \
                    '--add-gcp-kms=+[add GCP KMS]:str:' \
                    '--rm-gcp-kms=+[remove GCP KMS]:str:' \
                    '--add-azure-kv=+[add Azure KV]:str:' \
                    '--rm-azure-kv=+[remove Azure KV]:str:' \
                    '--add-hc-vault-transit=+[add Vault transit]:str:' \
                    '--rm-hc-vault-transit=+[remove Vault transit]:str:' \
                    '--add-age=+[add age]:str:' \
                    '--rm-age=+[remove age]:str:' \
                    '*:file:_files' ;;
                exec-env|exec-file) _arguments \
                    '--background[run in background]' \
                    '-b[run in background]' \
                    '--filename=+[output filename]:str:' \
                    '--no-fifo[no fifo]' \
                    '--user=+[user]:str:_users' \
                    '*:secret-and-command:' ;;
                groups) _arguments \
                    '1:cmd:(add delete)' \
                    '*:arg:' ;;
                updatekeys) _arguments \
                    '--yes[yes]' \
                    '-y[yes]' \
                    '--shamir-secret-sharing-threshold=+[shamir threshold]:n:' \
                    '*:file:_files' ;;
                publish) _arguments \
                    '--yes[yes]' \
                    '-y[yes]' \
                    '--omit-extensions[omit extensions]' \
                    '--recursive[recursive]' \
                    '-r[recursive]' \
                    '--verbose[verbose]' \
                    '*:file:_files' ;;
                filestatus|unset) _arguments '*:file:_files' ;;
                keyservice) _arguments \
                    '--network=+[network]:n:(tcp unix)' \
                    '--address=+[address]:str:' \
                    '--prompt[prompt]' ;;
            esac
            ;;
    esac
}

_sops-cli "$@"
