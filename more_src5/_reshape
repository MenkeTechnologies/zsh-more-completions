#compdef reshape
# Documentation: https://github.com/fabianlindfors/reshape
# Reference accessed: 2026-05-20
# Verified: upstream README at the URL above.

# Zsh completion for reshape (PostgreSQL zero-downtime schema migrations).

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _reshape_global_flags
_reshape_global_flags=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)'{-V,--version}'[show version]'
  '--url=[Database connection URL]:url'
  '--host=[Postgres host (default localhost)]:host:_hosts'
  '--port=[Postgres port (default 5432)]:port'
  '--database=[Database name (default postgres)]:database'
  '--username=[Postgres username (default postgres)]:user'
  '--password=[Postgres password (default postgres)]:password'
)

_arguments -s -S -C \
  "${_reshape_global_flags[@]}" \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'migration:Manage migrations'
      'status:Check migration status against the database'
      'schema-query:Generate the SQL query needed for application database connections'
      'docs:Display built-in documentation for Reshape'
    )
    _describe -t commands 'reshape commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      migration)
        _arguments -s -S -C \
          "${_reshape_global_flags[@]}" \
          '1:subcommand:->migration_cmd' \
          '*::arg:->migration_args' && ret=0
        case "$state" in
          migration_cmd)
            local -a migration_commands
            migration_commands=(
              'start:Start a new migration, applying all migrations under migrations/'
              'complete:Complete migrations previously started'
              'abort:Abort migrations that have not yet been completed'
            )
            _describe -t commands 'migration commands' migration_commands && ret=0
            ;;
          migration_args)
            case "${line[1]}" in
              start)
                _arguments -s -S \
                  "${_reshape_global_flags[@]}" \
                  '*:migration file:_files -g "*.toml"' && ret=0
                ;;
              complete|abort)
                _arguments -s -S "${_reshape_global_flags[@]}" && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      status|schema-query|docs)
        _arguments -s -S "${_reshape_global_flags[@]}" && ret=0
        ;;
    esac
    ;;
esac

return ret
