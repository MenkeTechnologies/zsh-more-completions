#compdef soelim
# Documentation: soelim usage / man soelim(1)
# Source: groff / FreeBSD soelim — interpret .so requests in manpages.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-C[recognise .so even when not followed by a space]' \
    '-r[GNU groff compatibility (no-op)]' \
    '-t[GNU groff compatibility (no-op)]' \
    '-v[GNU groff compatibility (no-op)]' \
    '*-I+[search directory for .so files]:dir:_files -/' \
    '*:roff file:_files' \
    && ret=0

return ret
