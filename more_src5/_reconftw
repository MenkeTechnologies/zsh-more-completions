#compdef reconftw

local curcontext="$curcontext" state line ret=1

_arguments \
  '-d[Target domain]:domain:' \
  '-l[List of targets file]:file:_files' \
  '-m[Module to run]:module:(osint subdomains web all)' \
  '-x[Exclude modules]:modules:' \
  '-r[Resolve subdomains]' \
  '-s[Take screenshots]' \
  '-a[Run all modules]' \
  '-w[Web only mode]' \
  '-o[Output directory]:directory:_directories' \
  '(- *)-h[Show help message]' \
  '--deep[Deep scan mode]' \
  '--axiom[Use axiom for distributed scanning]' \
  '--collaborative[Collaborative mode]' \
  '--diff[Show differences from previous scan]' \
  && ret=0

return ret
