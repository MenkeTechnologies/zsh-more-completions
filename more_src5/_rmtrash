#compdef rmtrash
# Documentation: https://github.com/PhrozenByte/rmtrash
# Reference accessed: 2026-05-16
# Verified: PhrozenByte/rmtrash GNU rm-compatible flag set
# (Linux GIO-trash CLI).
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -I, --interactive, --one-file-system, --preserve-root,
# --forbid-root flags missing.

# rmtrash: GNU rm-compatible CLI that sends files to trash
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-f --force)'{-f,--force}'[ignore nonexistent files, never prompt]' \
  '-i[prompt before every removal]' \
  '-I[prompt once before removing >3 files or recursing]' \
  '--interactive=[interactive level]:level:(never once always)' \
  '--one-file-system[stay on one filesystem when recursing]' \
  '--no-preserve-root[do not treat / specially]' \
  '--preserve-root[do not remove / (default)]' \
  '(-d --dir)'{-d,--dir}'[remove empty directories]' \
  '(-r -R --recursive)'{-r,-R,--recursive}'[remove directories recursively]' \
  '(-v --verbose)'{-v,--verbose}'[explain what is being done]' \
  '--forbid-root=[root-action policy]:policy:(ask-forbid ask-pass pass always never)' \
  '--help[show help]' \
  '--version[show version]' \
  '*:file:_files' && ret=0
return ret
