#compdef rarun2

_rarun2_keys() {
  local -a keys=(
    'program:path to program to run'
    'arg0:argv\[0\] override'
    'arg1:first argument'
    'arg2:second argument'
    'arg3:third argument'
    'arg4:fourth argument'
    'stdin:redirect stdin from file'
    'stdout:redirect stdout to file'
    'stderr:redirect stderr to file'
    'input:set stdin from hex string'
    'connect:connect stdin/stdout to host\:port'
    'listen:listen on port for stdin/stdout'
    'pty:use pseudoterminal'
    'fork:fork before executing'
    'timeout:timeout in seconds'
    'setenv:set environment variable'
    'unsetenv:unset environment variable'
    'chdir:change working directory'
    'chroot:change root directory'
    'libpath:set library path'
    'preload:preload shared library'
    'setuid:set user ID'
    'setgid:set group ID'
    'sleep:sleep before executing (seconds)'
    'maxstack:set maximum stack size'
    'maxproc:set maximum number of processes'
    'maxfd:set maximum number of file descriptors'
    'nice:set scheduling priority'
    'bits:set architecture bits'
    'pid:attach to process ID'
    'pidfile:write PID to file'
  )
  _describe -t keys 'rarun2 key' keys -S '='
}

_arguments -s -S \
  '(- *)-h[display help]' \
  '(- *)-v[display version]' \
  '-t[list all environment variables and config keys]' \
  '1:profile file:_files' \
  '*: :_rarun2_keys'
