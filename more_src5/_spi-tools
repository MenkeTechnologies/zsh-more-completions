#compdef spi-tools spi-config spi-pipe
# _spi-tools — Christophe Blaess spi-tools CLI suite spi-config spi-pipe for the Linux SPIdev character device configuring SPI bus modes speed bits-per-word reading writing arbitrary data through pipe full-duplex (cpb team, C); getopt
# upstream: https://github.com/cpb-/spi-tools

_spi-tools() {
    local -a sub=(
        'config:show or set SPI bus parameters'
        'pipe:transfer data through SPI bus'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-d+[device]:file:_files -g "/dev/spidev*"' \
        '--device=+[device]:file:_files -g "/dev/spidev*"' \
        '-m+[mode]:n:(0 1 2 3)' \
        '--mode=+[mode]:n:(0 1 2 3)' \
        '-l+[LSB-first]' \
        '--lsb=+[b]:b:(true false)' \
        '-b+[bits per word]:n:' \
        '--bits=+[bits per word]:n:' \
        '-s+[max speed Hz]:n:' \
        '--speed=+[max speed Hz]:n:' \
        '-q[query]' \
        '--query[query]' \
        '-r+[bytes to read]:n:' \
        '--read=+[bytes to read]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'spi-tools subcommand' sub ;;
        args)
            case $words[1] in
                config|pipe) _arguments '*:device:_files -g "/dev/spidev*"' ;;
            esac
            ;;
    esac
}

_spi-tools "$@"
