#compdef qstop
# _qstop-pbs — PBS qstop (server-side queue control: stop a running PBS queue so its enqueued jobs stop being selected for execution while leaving currently running jobs untouched; positional argument is a list of queue names; admin-only)
# upstream: https://github.com/openpbs/openpbs
# Argument shape from openpbs src/cmds/qstop.c on tip.

_qstop-pbs() {
    _arguments \
        '*:queue:'
}

_qstop-pbs "$@"
