#compdef rerun
# Documentation: https://github.com/alexch/rerun
# Reference accessed: 2026-05-20
# Verified: upstream README and rerun(1) manpage at the URL above.

# Zsh completion for rerun (alexch/rerun: launches commands and restarts them
# on filesystem changes).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-d --dir)'{-d+,--dir=}'[directory to watch (comma-separated; may repeat)]:dir:_files -/' \
  '--pattern=[glob to match inside directory]:pattern' \
  '--ignore=[file glob to ignore (may repeat)]:pattern' \
  '(-s --signal)'{-s+,--signal=}'[signal(s) to terminate the previous process]:signal:(HUP INT QUIT TERM KILL USR1 USR2)' \
  '(-w --wait)'{-w+,--wait=}'[seconds to wait before next signal]:seconds' \
  '(-r --restart)'{-r,--restart}'[expect process to restart itself (default signal HUP)]' \
  '(-x --exit)'{-x,--exit}'[expect the program to exit]' \
  '(-c --clear)'{-c,--clear}'[clear the screen before each run]' \
  '(-b --background)'{-b,--background}'[disable on-the-fly commands, allow backgrounding]' \
  '--notify=[notifier]:notifier:(growl osx notify-send)' \
  '--no-notify[disable notifications]' \
  '--name=[set the app name for display]:name' \
  '--force-polling[use polling instead of native filesystem scan]' \
  '--quiet[silence most messages]' \
  '--verbose[verbose output]' \
  '*:command:_command_names' && ret=0

return ret
