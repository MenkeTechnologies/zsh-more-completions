#compdef slurm
# Documentation: slurm --help on slurm 0.4.4
# Source: mattthias/slurm — yet another network load monitor.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[print help]' \
    '-H[long help]' \
    '-z[zero counters at startup]' \
    '-d+[delay between refreshes (1 < delay < 300)]:seconds:' \
    '(-c -s -l)-c[old classic/combined view]' \
    '(-c -s -l)-s[split-window mode with stats]' \
    '(-c -s -l)-l[large split-window mode]' \
    '-L[enable TX/RX leds]' \
    '-i+[select network interface]:iface:_net_interfaces' \
    '-t+[select a theme]:theme:' \
    && ret=0

return ret
