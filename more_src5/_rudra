#compdef rudra cargo-rudra
# _rudra — Rudra: Rust memory-safety & UB detector (sslab-gatech/Rudra)
# upstream: https://github.com/sslab-gatech/Rudra
# `cargo rudra` forwards cargo-check flags then `--` then Rudra/rustc flags.

_rudra() {
    local -a args
    args=(
        '-Zsensitivity-high[enable high-sensitivity analyses (more false positives)]'
        '-Zsensitivity-medium[enable medium-sensitivity analyses (default)]'
        '-Zsensitivity-low[enable only low-sensitivity analyses]'
        '-Zenable-unsafe-destructor[enable the UnsafeDestructor checker]'
        '-Zenable-send-sync-checker[enable the SendSyncVariance checker]'
        '-Zenable-panic-safety[enable the PanicSafety checker]'
        '-Zenable-call-graph[emit the call graph]'
        '-Zreport-dir=[directory for JSON reports]:dir:_files -/'
        '--crate-name=[crate name to analyze]:name:'
        '--target=[target triple]:triple:'
        '--target-dir=[target directory]:dir:_files -/'
        '--manifest-path=[path to Cargo.toml]:file:_files'
        '--all-features[activate all available features]'
        '--no-default-features[do not activate the `default` feature]'
        '--features=[space- or comma-separated list of features to activate]:features:'
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-V,--version}'[show version]'
        '*:source file:_files -g "*.rs"'
    )
    _arguments -s -S $args
}

_rudra "$@"
