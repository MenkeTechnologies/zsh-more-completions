#compdef rubyfmt
# rubyfmt — Ruby code formatter (Shopify)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-i --in-place)'{-i,--in-place}'[format files in place]' \
  '(-c --check)'{-c,--check}'[check if files are formatted (exit 1 if not)]' \
  '--header-comment-override=[override header comment policy]:policy:' \
  '*:ruby file:_files -g "*.rb"' \
  && ret=0

return ret
