#compdef sd
# Documentation: https://raw.githubusercontent.com/chmln/sd/master/sd-cli/src/cli.rs
# Reference accessed: 2026-05-21
# Verified: upstream clap Options struct in sd-cli/src/cli.rs.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-p --preview)'{-p,--preview}'[display changes without modifying files]' \
  '(-F --fixed-strings -s --string-mode)'{-F,--fixed-strings,-s,--string-mode}'[treat pattern as literal string]' \
  '(-n --max-replacements)'{-n+,--max-replacements=}'[limit number of replacements per file]:limit:' \
  '(-f --flags)'{-f+,--flags=}'[regex flags (c e i m s w)]:flags:' \
  '(-A --across)'{-A,--across}'[allow patterns to match across line boundaries]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:find pattern:' \
  '2:replace pattern:' \
  '*:file:_files' && ret=0

return ret
