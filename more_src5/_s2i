#compdef s2i
# Documentation: https://github.com/openshift/source-to-image/blob/master/docs/cli.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'build:build a new image'
  'rebuild:rebuild an image previously created via s2i'
  'create:bootstrap a new s2i-enabled image repository'
  'generate:generate a Dockerfile from a builder image'
  'usage:print information about builder image usage'
  'version:display version of s2i'
  'completion:generate shell completion scripts'
  'help:help about any command'
)

_arguments -C \
  '--loglevel=[set log output level]:level:(0 1 2 3 4 5)' \
  '(-U --url)'{-U,--url=}'[Docker daemon socket URL]:url' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 's2i subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (build)
        _arguments -s \
          '(-r --ref)'{-r,--ref=}'[branch/tag to use (git source)]:ref:' \
          '--context-dir=[sub-directory inside the repository with app sources]:dir:_directories' \
          '--incremental[try to perform an incremental build]' \
          '--incremental-pull-policy=[pull policy for previous image]:policy:' \
          '--pull-policy=[image pull policy]:policy:' \
          '(-e --env)'{-e,--env=}'[environment variable KEY=VALUE]:env:' \
          '(-E --environment-file)'{-E,--environment-file=}'[path to file with environment]:file:_files' \
          '(-u --allowed-uids)'{-u,--allowed-uids=}'[allowed UIDs]:uids:' \
          '(-n --application-name)'{-n,--application-name=}'[application name]:name:' \
          '(-c --copy)'{-c,--copy}'[use COPY rather than git clone]' \
          '(-d --destination)'{-d,--destination=}'[location for scripts and artifacts]:path:_files' \
          '(-i --inject)'{-i,--inject=}'[inject SRC into builder image at DST]:spec:' \
          '(-q --quiet)'{-q,--quiet}'[operate quietly]' \
          '(-a --runtime-artifact)'{-a,--runtime-artifact=}'[runtime artifact to copy]:spec:' \
          '(-s --scripts-url)'{-s,--scripts-url=}'[s2i scripts URL]:url:' \
          '(-v --volume)'{-v,--volume=}'[bind-mount HOST-DIR:CONTAINER-DIR]:spec:' \
          '--as-dockerfile=[write Dockerfile instead of running build]:path:_files' \
          '--assemble-user=[user to use for assemble script]:user:_users' \
          '--assemble-runtime-user=[user for runtime assemble]:user:_users' \
          '--callback-url=[URL to invoke when build is finished]:url:' \
          '--cap-drop=[capabilities to drop from build container]:capability:' \
          '--description=[description for the build]:desc:' \
          '--dockercfg-path=[Docker config file location]:path:_files' \
          '--exclude=[regex matching files to exclude from source upload]:regex:' \
          '--ignore-submodules[ignore submodules when cloning git source]' \
          '--network=[set Docker network mode]:network:' \
          '--rm[remove the previous image]' \
          '--run[execute the resulting image]' \
          '--runtime-image=[runtime image for chained builds]:image:' \
          '--runtime-pull-policy=[pull policy for runtime image]:policy:' \
          '--save-temp-dir[save the temporary directory used for build]' \
          '--use-config[use existing s2i config in current dir]' \
          '*:arg:' && ret=0 ;;
      (completion) _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
    esac
    ;;
esac

return ret
