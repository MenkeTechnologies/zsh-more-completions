#compdef rustfmt
# Documentation: rustfmt --help
# Source: Rust rustfmt — format Rust code.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--check[exit 1 + print diff if formatting needed]' \
    '--emit=[what data to emit and how]:target:(files stdout)' \
    '--backup[backup any modified files]' \
    '--config-path=[rustfmt.toml directory or path]:path:_files' \
    '--edition=[Rust edition to use]:edition:(2015 2018 2021 2024)' \
    '--style-edition=[Style Guide edition (unstable)]:edition:(2015 2018 2021 2024)' \
    '--color=[colored output]:when:(always never auto)' \
    '--print-config=[dump config to PATH]:kind path:(default minimal current)' \
    '(-l --files-with-diff)'{-l,--files-with-diff}'[print names of mismatched files]' \
    '*--config=[set options key1=val1,key2=val2 (overrides rustfmt.toml)]:settings:' \
    '(-v --verbose -q --quiet)'{-v,--verbose}'[verbose output]' \
    '(-v --verbose -q --quiet)'{-q,--quiet}'[less output]' \
    '(- *)'{-V,--version}'[show version]' \
    '(- *)'{-h,--help=-}'[show help; optional topic]::topic:(config)' \
    '*:Rust source file:_files -g "*.rs"' \
    && ret=0

return ret
