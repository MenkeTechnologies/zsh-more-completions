#compdef sbuild-createchroot
# Documentation: https://manpages.debian.org/sbuild-createchroot
# Source: Debian/sbuild bin/sbuild-createchroot — create an sbuild chroot via debootstrap (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    {-h,--help}'[show help]' \
    {-V,--version}'[show version]' \
    {-v,--verbose}'[verbose output]' \
    '--arch=-[architecture]:arch:_default' \
    '--components=-[apt components]:components:_default' \
    '*--exclude=-[exclude package]:pkg:_default' \
    '*--include=-[include package]:pkg:_default' \
    '*--extra-suites=-[extra suite]:suite:_default' \
    '*--extra-repository=-[extra apt repository]:repo:_default' \
    '--foreign[foreign debootstrap mode]' \
    '--keep-debootstrap-dir[keep debootstrap tmp dir]' \
    '--keep-sbuild-chroot-dir[keep chroot on failure]' \
    '--keyring=-[apt keyring]:file:_files' \
    '(--no-merged-usr)--merged-usr[create merged-/usr chroot]' \
    '(--merged-usr)--no-merged-usr[do not merge /usr]' \
    '--auto-merged-usr[auto-detect merged-/usr]' \
    '--no-check-gpg[skip gpg check]' \
    '(--no-resolve-deps)--resolve-deps[install build-deps]' \
    '(--resolve-deps)--no-resolve-deps[skip build-deps]' \
    '--alias=-[chroot alias]:alias:_default' \
    '--chroot-mode=-[chroot mode]:mode:(schroot sudo autopkgtest unshare)' \
    '--chroot-prefix=-[chroot prefix]:prefix:_default' \
    '--chroot-suffix=-[chroot suffix]:suffix:_default' \
    '*--command-prefix=-[command prefix]:prefix:_default' \
    '--debootstrap=-[debootstrap binary]:cmd:_command_names' \
    '--build-essential[include build-essential]' \
    '--no-deb-src[do not add deb-src line]' \
    '--make-sbuild-tarball=-[create tarball at path]:path:_files' \
    '--fakeroot[install fakeroot]' \
    '--overlay[overlay mode]' \
    '--setup-only[setup chroot only; no debootstrap]' \
    '1:distribution:_default' \
    '2:target directory:_files -/' \
    '3::mirror URL:_urls' \
    '4::script:_files' \
    && ret=0

return ret
