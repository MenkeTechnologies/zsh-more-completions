#compdef rofi-bluetooth
# _rofi-bluetooth — rofi-bluetooth CLI shell script frontend invoking bluetoothctl through rofi dmenu-style menu listing scanning available Bluetooth devices toggling connect disconnect pair trust untrust scan-on scan-off operations from the rofi launcher for quick desktop integration (nickclyde team, shell); getopt
# upstream: https://github.com/nickclyde/rofi-bluetooth

_rofi-bluetooth() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--no-confirmation[skip confirmation prompts]' \
        '--device=+[mac address]:str:' \
        '--scan-timeout=+[sec]:n:' \
        '--rofi-args=+[args]:str:' \
        '*::'
}

_rofi-bluetooth "$@"
