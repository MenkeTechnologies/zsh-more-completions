#compdef spacecmd
# Documentation: https://github.com/uyuni-project/uyuni/blob/master/spacecmd/src/bin/spacecmd
# Reference accessed: 2026-05-21
# Verified: upstream spacecmd script at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-u --username)'{-u+,--username=}'[Spacewalk/Uyuni/Satellite username]:user:' \
  '(-p --password)'{-p+,--password=}'[password (config file recommended)]:password:' \
  '(-s --server)'{-s+,--server=}'[server hostname (default: local)]:server:_hosts' \
  '(-c --config)'{-c+,--config=}'[config file (default: ~/.spacecmd/config)]:file:_files' \
  '(-y --yes)'{-y,--yes}'[answer yes to all prompts]' \
  '(-q --quiet)'{-q,--quiet}'[only display errors]' \
  '*'{-d,--debug}'[debug logging (repeatable)]' \
  '--nossl[use HTTP instead of HTTPS]' \
  '--nohistory[do not store command history]' \
  '*::spacecmd command:' && ret=0

return ret
