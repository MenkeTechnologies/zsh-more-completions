#compdef spaceman-diff
# Documentation: https://github.com/holman/spaceman-diff
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: spaceman-diff is a git diff driver, not a user-facing CLI command.
# It is invoked by git diff via gitattributes and takes positional args from git
# (path, old-file, old-hex, old-mode, new-file, new-hex, new-mode). No flags.

local curcontext="$curcontext" state line ret=1
_arguments -s -S '*:file:_files' && ret=0
return ret
