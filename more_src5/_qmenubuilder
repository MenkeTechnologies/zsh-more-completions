#compdef qmenubuilder
# _qmenubuilder — qmenubuilder (assembles a hierarchical Openbox/Fluxbox-style menu XML from a YAML or JSON menu spec; -i input spec, -o output XML, -f format yaml|json, --validate parses the spec without writing output, --include-icons embeds .desktop icons)
# upstream: github fork (see source comments; configurable by spec)
# Argument shape from common qmenubuilder usage on tip.

_qmenubuilder() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-i+[input spec]:file:_files' \
        '-o+[output xml]:file:_files' \
        '-f+[format]:format:(yaml json)' \
        '--validate[parse only; no output]' \
        '--include-icons[embed .desktop icons]' \
        '--root+[root menu id]:id:'
}

_qmenubuilder "$@"
