#compdef restler-quick-start.py restler-quick-start
# _restler-quick-start — quick-start runner for RESTler API fuzzer (microsoft/restler-fuzzer)
# upstream: https://github.com/microsoft/restler-fuzzer
# Flags from restler-quick-start.py (argparse).

_restler-quick-start.py() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--api_spec_path=[Swagger spec to compile and test]:file:_files' \
        '--ip=[IP of service to test]:ip:_hosts' \
        '--port=[port of service to test]:port:' \
        '--restler_drop_dir=[path to RESTler drop]:dir:_files -/' \
        '--use_ssl[use SSL validation for socket]' \
        '--host=[hostname of service to test]:host:_hosts' \
        '--task=[task to run]:task:(test fuzz-lean fuzz replay)' \
        '--replay_bug_buckets_dir=[bug buckets directory for replay]:dir:_files -/'
}

_restler-quick-start.py "$@"
