#compdef rpiboot
# Documentation: https://github.com/raspberrypi/usbboot (main.c getopt parsing)
# Reference accessed: 2026-05-29
# Raspberry Pi USB Boot tool — boot a Raspberry Pi device-mode SoC into
# mass storage or provide boot files over USB.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show usage information]' \
  '(- *)'{-V,--version}'[show version]' \
  '-d+[boot files directory]:dir:_directories' \
  '-p+[filter by USB device pathname (e.g. 1-1.3.2)]:path:' \
  '-l[loop continuously, waiting for devices]' \
  '*-v[verbose output (use -vv for extra verbose)]' \
  '-o[load overlay files from device-specific subdirectories]' \
  '-m+[microsecond delay between device checks (default 500)]:usec:' \
  '-s[enable signed boot using bootsig.bin]' \
  '-j+[write device metadata to JSON file]:file:_files -g "*.json"' \
  '-i+[target device by serial number]:serial:' \
  '*-0[target device by USB port 0]' \
  '*-1[target device by USB port 1]' \
  '*-2[target device by USB port 2]' \
  '*-3[target device by USB port 3]' \
  '*:: :_files' && ret=0

return ret
