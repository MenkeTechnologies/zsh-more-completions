#compdef sndfile-generate-chirp
# _sndfile-generate-chirp — generate a swept-sine "chirp" sound file (libsndfile/sndfile-tools)
# upstream: https://github.com/libsndfile/sndfile-tools
# Flags from src/generate-chirp.c.

_sndfile-generate-chirp() {
    local -a args
    args=(
        '(- *)-h[show help]'
        '-from+[sweep start frequency (Hz, default 200)]:hz:'
        '-to+[sweep end frequency (Hz, default fs/2)]:hz:'
        '-amp+[amplitude (default 1.0)]:amp:'
        '-log[logarithmic sweep (default)]'
        '-quad[quadratic sweep]'
        '-linear[linear sweep]'
        '1:sample rate (Hz):'
        '2:length (seconds):'
        '3:output sound file:_files -g "*.{wav,aif,aiff,aifc,au,caf,w64}"'
    )
    _arguments -s $args
}

_sndfile-generate-chirp "$@"
