#compdef realize
# _realize — Go build system with live-reload
# upstream: https://github.com/oxequa/realize

_realize() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'start:start a project'
                'add:add a project to the config'
                'init:create a new realize config'
                'remove:remove a project from the config'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                start)
                    _arguments \
                        '(-p --path)'{-p,--path=}'[project base path]:directory:_directories' \
                        '(-n --name)'{-n,--name=}'[project name]:name:' \
                        '--run[enable go run]' \
                        '--build[enable go build]' \
                        '--install[enable go install]' \
                        '--test[enable go test]' \
                        '--fmt[enable go fmt]' \
                        '--vet[enable go vet]' \
                        '--generate[enable go generate]' \
                        '--no-config[ignore config file]' \
                        '--open[open in browser]' \
                        '--server[start the web server]'
                    ;;
                add)
                    _arguments \
                        '(-p --path)'{-p,--path=}'[project base path]:directory:_directories' \
                        '(-n --name)'{-n,--name=}'[project name]:name:'
                    ;;
                remove)
                    _arguments \
                        '(-n --name)'{-n,--name=}'[project name]:name:'
                    ;;
            esac
            ;;
    esac
}

_realize "$@"
