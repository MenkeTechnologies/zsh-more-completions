#compdef rootmv
# Documentation: https://github.com/root-project/root/blob/master/main/python/rootmv.py
# Reference accessed: 2026-05-27
# Verified: upstream argparse add_argument calls in main/python/rootmv.py
#           (Python implementation; upstream does not expose -r/--recursive or --replace
#           for rootmv unlike the C++ rootcp/rootrm tools)

# rootmv: move objects between ROOT files.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --compress)'{-c+,--compress=}'[set compression algorithm/level (compress = 100*algorithm + level)]:value:' \
  '(-i --interactive)'{-i,--interactive}'[prompt before every removal]' \
  '--recreate[recreate the destination file]' \
  '*:file:_files -g "*.root"' && ret=0

return ret
