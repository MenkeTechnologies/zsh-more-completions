#compdef rootbrowse
# Documentation: https://github.com/root-project/root/blob/master/main/src/rootbrowse.cxx
# Reference accessed: 2026-05-27
# Verified: upstream ParseArgs() RCmdLineOpts AddFlag calls in main/src/rootbrowse.cxx

# rootbrowse: open a ROOT file in a TBrowser.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(-w --web)'{-w+,--web=}'[configure web display]:webdisplay:(chrome firefox qt6 default server off)' \
  '(-wf --webOff)'{-wf,--webOff}'[invoke the classic TBrowser (not the web version)]' \
  '*:root file:_files -g "*.root"' && ret=0

return ret
