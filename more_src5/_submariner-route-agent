#compdef submariner-route-agent
# _submariner-route-agent — Submariner per-node route agent (programs the host routing table + iptables/nftables to send cross-cluster traffic via the active gateway pod)
# upstream: https://github.com/submariner-io/submariner
# Flags from pkg/routeagent_driver/main.go on tip; deeper config via env vars (SUBMARINER_NAMESPACE, SUBMARINER_CLUSTERID, SUBMARINER_CLUSTERCIDR, SUBMARINER_SERVICECIDR, SUBMARINER_DEBUG, NODE_NAME, HOST_NAME, OS).

_submariner-route-agent() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '--kubeconfig=[path to kubeconfig (out-of-cluster only)]:file:_files' \
        '--master=[Kubernetes API URL]:url:_urls' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_submariner-route-agent "$@"
