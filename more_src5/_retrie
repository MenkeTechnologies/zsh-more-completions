#compdef retrie

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '*--adhoc[adhoc rewrite rule]:rewrite rule:' \
  '*--type[type-aware rewrite]:type rewrite:' \
  '*--unfold[unfold a definition]:definition name:' \
  '*--fold[fold a definition]:definition name:' \
  '*--rule-forward[apply rewrite rule forward]:rule name:' \
  '*--rule-backward[apply rewrite rule backward]:rule name:' \
  '*--target[target files or directories]:target:_files' \
  '--verbose[verbose output]' \
  '*--fixity[fixity declaration]:fixity:' \
  '--debug[enable debug output]' \
  '--round-trips[number of round trips]:round trips:' \
  '*--elaborations[elaboration strategy]:elaboration:' \
  '*--extra[extra GHC flags]:GHC flag:' && ret=0

return ret
