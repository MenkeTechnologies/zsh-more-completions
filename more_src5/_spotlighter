#compdef spotlighter
# Documentation: https://github.com/mvshmakov/homebrew-spotlighter
# Reference accessed: 2026-05-21
# Verified: spotlighter source script (case statements for options/commands).
# Replaced: prior file contained the raw shell script source rather than a completion.

# Zsh completion for spotlighter - macOS Spotlight exclusion manager

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add:add development directories to Spotlight exclusions (default)'
  'show:show current Spotlight exclusions'
  'find:print candidate development directories'
  'check:show Spotlight indexing status for the directory'
  'completions:generate shell completion script'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-d --dir)'{-d+,--dir=}'[directory to search]:directory:_directories' \
  '(-f --force)'{-f,--force}'[rebuild exclusions from scratch]' \
  '(-v --verbose)'{-v,--verbose}'[print additional information]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'spotlighter command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      completions)
        _arguments '1:shell:(bash zsh)' && ret=0
        ;;
    esac
    ;;
esac

return ret
