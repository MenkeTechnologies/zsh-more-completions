#compdef storrent
# ============================================================================
# storrent - STorrent BitTorrent client optimized for streaming media (Go, MIT)
#
# Author : Juliusz Chroboczek (jech)
# Upstream: https://github.com/jech/storrent
#
# STorrent is a BitTorrent v1 client built for one specific workload:
# streaming media on the fly. It downloads pieces in playback order
# rather than rarest-first, exposes the torrent contents as a FUSE
# filesystem (`-mountpoint`) so video players can seek into in-flight
# downloads, runs an HTTP control + status web UI, integrates a DHT
# node for trackerless swarms, supports peer-encryption (MSE/PE),
# webseed (BEP 19), and NAT portmap (PMP / UPnP / auto).
#
# The bencode lane is built on `github.com/zeebo/bencode v1.0.0`
# (declared verbatim at upstream go.mod HEAD), the canonical Go
# bencode codec by Jeff Wendling (github.com/zeebo/bencode, ~95
# stars). zeebo/bencode implements BEP 3 in pure Go with a
# reflective `encoding/json`-style API: `bencode.NewDecoder(r)`,
# `bencode.NewEncoder(w)`, plus struct-tag-driven marshaling
# (`json:"name" bencode:"announce,omitempty"`). It is the
# de-facto Go bencode library and the dependency-of-record for
# every Go BitTorrent client (anacrolix/torrent, cenkalti/rain,
# this STorrent, etc.) that doesn't roll its own codec.
#
# ----------------------------------------------------------------------------
# AXIS 205 :: BENCODE / BITTORRENT METAINFO (BEP 3)
# Round 1314 :: Go slot 2 of 4 :: continues Axis 205
#
# Cross-language canonical library family for this axis:
#   Rust    : P3KI/bendy                    [R1313 _vcz]
#   Go      : zeebo/bencode                 [R1314 THIS FILE]
#   TS/Node : webtorrent/bencode            [R1315 closing]
#
# storrent pairs cleanly with vcz/vczd (Rust opener) - both are
# BitTorrent clients but with structurally different design
# philosophies: vcz aims for general-purpose v1 client with TUI;
# storrent aims for streaming-first delivery with FUSE export and
# in-order piece fetching. The shared dependency on the canonical
# bencode codec of each language demonstrates that BitTorrent's
# metainfo wire format is one of the most stable protocol surfaces
# still in production - 23+ years since Bram Cohen published BEP 3
# in 2002, and every client still round-trips bencode the same way.
# ============================================================================

_storrent() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '-port[TCP and UDP port for BitTorrent and DHT (default 23222)]:port:' \
        '-http[web server bind address (default [::1]:8088)]:address:' \
        '-mem[target memory usage in bytes]:bytes:' \
        '-cpuprofile[CPU profile filename]:file:_files' \
        '-memprofile[memory profile filename]:file:_files' \
        '-mutexprofile[mutex profile filename]:file:_files' \
        '-proxy[proxy URL for BitTorrent + tracker traffic]:url:' \
        '-mountpoint[FUSE mountpoint]:directory:_files -/' \
        '-dht[DHT mode]:mode:(normal passive off)' \
        '-use-trackers[use trackers (if available)]' \
        '-use-webseeds[use webseeds (if available)]' \
        '-prefetch-rate[prefetch rate in bytes per second]:rate:' \
        '-prefer-encryption[prefer peer encryption (default true)]' \
        '-force-encryption[force peer encryption (drop unencrypted)]' \
        '-portmap[NAT port mapping protocol]:protocol:(natpmp upnp auto off)' \
        '-mptcp[use MP-TCP for peer-to-peer connections]' \
        '-debug[log all BitTorrent messages]' \
        '(- *)'{-h,--help}'[print help]'
}

_storrent "$@"
