#compdef ragator
# _ragator — Carter Bullard QoSient Argus ragator flow aggregator CLI for combining Argus flow records by tuple sum bytes packets and duration computing aggregate metrics per flow class subnet country (qosient team, C); getopt
# upstream: https://github.com/openargus/clients

_ragator() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-r+[read file]:file:_files -g "*.argus *.arg"' \
        '--read=+[read file]:file:_files -g "*.argus *.arg"' \
        '-w+[write file]:file:_files -g "*.argus *.arg"' \
        '--write=+[write file]:file:_files -g "*.argus *.arg"' \
        '-m+[match keys]:str:' \
        '--match=+[match keys]:str:' \
        '-M+[match mode]:m:(addr proto port dir tcpflags vlan dscp)' \
        '-N+[N records]:n:' \
        '-S+[remote host]:h:_hosts' \
        '-P+[port]:n:' \
        '-f+[config file]:file:_files -g "*.conf"' \
        '--config=+[config file]:file:_files -g "*.conf"' \
        '-F+[output fields]:str:' \
        '-t+[time range]:str:' \
        '--time=+[time range]:str:' \
        '-T+[timeout sec]:n:' \
        '--timeout=+[timeout sec]:n:' \
        '-z+[remove fields]:str:' \
        '--zone=+[zone]:str:' \
        '-c+[csv output]:str:' \
        '--csv[csv output]' \
        '-X[hex output]' \
        '-d[debug]' \
        '*:files:_files -g "*.argus *.arg *.bin *.dat"'
}

_ragator "$@"
