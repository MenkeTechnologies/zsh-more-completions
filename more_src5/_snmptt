#compdef snmptt snmpttd
# Documentation: https://snmptt.org/docs/snmptt.shtml
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '--daemon[run as daemon]' \
  '--debug=[debug level]:n:' \
  '--debugfile=[debug log file]:file:_files' \
  '--ini=[ini file]:file:_files -g "*.ini"' \
  '--dump[dump defined traps]' \
  '--time[measure load time]' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]'
