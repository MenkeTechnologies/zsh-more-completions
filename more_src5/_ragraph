#compdef ragraph
# _ragraph — Carter Bullard QoSient Argus ragraph CLI generating RRD-graphics charts from Argus flow records aggregating per-key time-series metrics bytes/packets/connections for ranged visualisation (qosient team, C); getopt
# upstream: https://github.com/openargus/clients

_ragraph() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-r+[read file]:file:_files -g "*.argus *.arg"' \
        '--read=+[read file]:file:_files -g "*.argus *.arg"' \
        '-w+[write image]:file:_files -g "*.png *.svg *.pdf *.html"' \
        '--write=+[write image]:file:_files -g "*.png *.svg *.pdf *.html"' \
        '-m+[match keys]:str:' \
        '--match=+[match keys]:str:' \
        '-t+[time range]:str:' \
        '--time=+[time range]:str:' \
        '-d+[step seconds]:n:' \
        '--step=+[step seconds]:n:' \
        '-y+[y-axis metric]:m:(bytes packets connections rate src dst pps bps)' \
        '--metric=+[y-axis metric]:m:(bytes packets connections rate src dst pps bps)' \
        '-G+[graph type]:t:(line area stack column scatter heatmap)' \
        '--graph=+[graph type]:t:(line area stack column scatter heatmap)' \
        '-W+[width px]:n:' \
        '--width=+[width px]:n:' \
        '-H+[height px]:n:' \
        '--height=+[height px]:n:' \
        '-l+[legend]:str:' \
        '-T+[title]:str:' \
        '--title=+[title]:str:' \
        '-Y+[y-axis label]:str:' \
        '-X+[x-axis label]:str:' \
        '-z+[zone]:str:' \
        '-c+[colours csv]:str:' \
        '--colors=+[csv]:str:' \
        '-f+[font]:str:' \
        '*:files:_files -g "*.argus *.arg *.bin *.dat"'
}

_ragraph "$@"
