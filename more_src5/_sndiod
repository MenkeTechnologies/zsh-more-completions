#compdef sndiod
# _sndiod — sndio audio / MIDI server daemon (OpenBSD sndio)
# upstream: https://sndio.org/ (man.openbsd.org/sndiod.8)
# Flags from sndiod(8).

_sndiod() {
    local -a args
    args=(
        '-a+[whether to autostart streams]:flag:(on off)'
        '-b+[block size (frames)]:nframes:'
        '-C+[capture channel range (min\:max)]:range:'
        '-c+[playback channel range (min\:max)]:range:'
        '-d[debug mode (foreground + log to stderr)]'
        '-e+[sample encoding]:enc:(s8 u8 s16le s16be u16le u16be s24le s24be u24le u24be s32le s32be u32le u32be)'
        '-F+[capture audio device]:device:'
        '-f+[playback audio device]:device:'
        '-j+[joystick / xrun policy]:flag:(ignore sync error)'
        '-L+[listen address (sndio TCP)]:addr:'
        '-m+[transport mode]:mode:(play rec play\,rec mon midi)'
        '-Q+[MIDI port to monitor]:port:'
        '-q+[MIDI port to use]:port:'
        '-r+[sample rate (Hz)]:rate:(44100 48000 88200 96000 176400 192000)'
        '-s+[sub-device name]:name:'
        '-t+[priority on xrun]:mode:(ignore sync error)'
        '-U+[server unit number]:unit:'
        '-v+[default audio volume]:vol:'
        '-w+[wait for the audio device]:flag:(on off)'
        '-z+[round (frames per device transfer)]:nframes:'
    )
    _arguments -s $args
}

_sndiod "$@"
