#compdef seff
# _seff — SchedMD Slurm seff (CPU + memory efficiency calculator for finished Slurm jobs; positional argument is the JobID (or JobID.StepID); -d show detailed per-step stats, -M cluster, -v verbose; reads from the Slurm accounting db so it only works when sacctmgr is configured)
# upstream: https://github.com/SchedMD/slurm
# Flags from SchedMD/slurm contribs/seff/seff on tip.

_seff() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-d[show per-step detail]' \
        '-v[verbose]' \
        '-M+[clusters]:clusters:' \
        '1:JobID:'
}

_seff "$@"
