#compdef ResetDirection
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/ResetDirection.cxx — set image direction cosines to identity (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:infile.nii:_files -g "*.{nii,nii.gz,mha,nrrd,hdr,img}"' \
    '2:outfile.nii:_files' \
    && ret=0

return ret
