#compdef sdcpp
# Documentation: https://sourceforge.net/p/sdcc/code/HEAD/tree/trunk/sdcc/support/cpp/
# Reference accessed: 2026-05-21
# Verified: sdcc support/cpp/ is a port of GCC's cpp; sdcpp accepts the GCC
# preprocessor flag set (https://gcc.gnu.org/onlinedocs/gcc/Preprocessor-Options.html).

# sdcpp: SDCC preprocessor (GCC cpp port)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '-D+[define macro]:macro[=value]' \
  '-U+[undefine macro]:macro:' \
  '-I+[add include directory]:dir:_files -/' \
  '-iquote+[quote include dir]:dir:_files -/' \
  '-isystem+[system include dir]:dir:_files -/' \
  '-include+[include file before processing]:file:_files' \
  '-imacros+[include macros file]:file:_files' \
  '-M[generate Make dependency rules]' \
  '-MD[deps and continue compilation]' \
  '-MM[deps without system headers]' \
  '-MMD[deps without system headers, continue]' \
  '-MP[add phony targets for each dependency]' \
  '-MF+[write dependencies to file]:file:_files' \
  '-MT+[change target of dependency rule]:target:' \
  '-MQ+[quoted target of dependency rule]:target:' \
  '-W+[warning option]:type:' \
  '-w[disable all warnings]' \
  '-pedantic[strict ISO C compliance]' \
  '-trigraphs[allow trigraphs]' \
  '-traditional[K&R preprocessing mode]' \
  '-undef[no predefined macros]' \
  '-nostdinc[no standard include paths]' \
  '-C[keep comments]' \
  '-CC[keep all comments including macro expansions]' \
  '-P[no line markers]' \
  '*:source file:_files -g "*.(c|h|i|S|s)"' && ret=0
return ret
