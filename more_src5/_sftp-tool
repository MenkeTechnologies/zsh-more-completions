#compdef sftp-tool
# _sftp-tool — OpenSSH sftp interactive secure file transfer client CLI alias (OpenBSD / OpenSSH team, C); custom argparse
# upstream: https://www.openssh.com

_sftp-tool() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-4[force IPv4]' \
        '-6[force IPv6]' \
        '-a[attempt to resume partial transfers]' \
        '-A[forward ssh-agent]' \
        '-B+[buffer size]:n:' \
        '-b+[batch file]:file:_files' \
        '-C[enable compression]' \
        '-c+[cipher spec]:str:' \
        '-D+[sftp server path]:file:_files' \
        '-e[no escape]' \
        '-f[fsync after writes]' \
        '-F+[ssh config file]:file:_files' \
        '-i+[identity file]:file:_files' \
        '-J+[jump host]:str:' \
        '-l+[max bandwidth in Kbit/s]:n:' \
        '-N[no shell]' \
        '-o+[ssh option]:str:' \
        '-P+[port]:port:' \
        '-p[preserve modification times]' \
        '-q[quiet]' \
        '-r[recursive]' \
        '-R+[max outstanding requests]:n:' \
        '-S+[ssh program]:file:_files' \
        '-s+[subsystem]:str:' \
        '-T[disable tty]' \
        '-v[verbose]' \
        '-X+[sftp option key=value]:str:' \
        '*:host-or-path:_hosts'
}

_sftp-tool "$@"
