#compdef standardrb-cli
# _standardrb-cli — Justin Searls Standard Ruby style guide and linter CLI alias (standardrb team, Ruby); custom argparse over rubocop
# upstream: https://github.com/standardrb/standard

_standardrb-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--fix[fix violations]' \
        '--format=+[formatter]:f:(progress simple clang fuendoc emacs files html json junit markdown offenses quiet tap worst)' \
        '-f+[formatter]:f:(progress simple clang fuendoc emacs files html json junit markdown offenses quiet tap worst)' \
        '--out=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--no-color[no color]' \
        '--color[force color]' \
        '--no-fix[no fix]' \
        '--parallel[parallel]' \
        '--no-parallel[no parallel]' \
        '--server[start server]' \
        '--no-server[no server]' \
        '--config=+[config file]:file:_files -g ".standard.{yml,yaml}"' \
        '--fail-fast[fail fast]' \
        '--no-fail-fast[no fail fast]' \
        '--only=+[only cops csv]:str:' \
        '--except=+[except cops csv]:str:' \
        '--stdin=+[filename]:file:_files' \
        '--list-cops[list cops]' \
        '--lsp[run LSP]' \
        '--fix-unsafely[fix unsafely]' \
        '--watch[watch for changes]' \
        '--debug[debug]' \
        '--no-debug[no debug]' \
        '--cache=+[cache]:c:(true false)' \
        '--no-cache[no cache]' \
        '--cache-root=+[cache dir]:dir:_files -/' \
        '--todo[print todo config]' \
        '*:files:_files -g "*.{rb,ru,gemspec,rake}"'
}

_standardrb-cli "$@"
