#compdef stripe-mock
# _stripe-mock — Stripe API mock server (stripe/stripe-mock)
# upstream: https://github.com/stripe/stripe-mock

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--http-port=[HTTP port to listen on]:port:' \
  '--https-port=[HTTPS port to listen on]:port:' \
  '--http-unix=[HTTP Unix socket path]:path:_files' \
  '--https-unix=[HTTPS Unix socket path]:path:_files' \
  '--port=[deprecated alias for --http-port]:port:' \
  '--fixtures-path=[path to fixtures file]:file:_files' \
  '--spec-path=[path to OpenAPI spec]:file:_files' \
  '--strict-version-check[require API version header]' \
  '--verbose[verbose request logging]'
