#compdef renv
# _renv — RStudio renv R project library manager CLI alias (RStudio / Posit, R); custom argparse via R wrapper
# upstream: https://github.com/rstudio/renv

_renv() {
    local -a sub=(
        'activate:activate a renv project'
        'deactivate:deactivate a renv project'
        'init:initialize a new project'
        'install:install packages'
        'remove:remove packages'
        'update:update packages'
        'snapshot:save state to renv.lock'
        'restore:restore packages from renv.lock'
        'status:show project status'
        'isolate:isolate a project library'
        'history:show project history'
        'revert:revert to previous state'
        'rebuild:rebuild packages'
        'diagnostics:produce diagnostic report'
        'consent:provide consent for renv'
        'dependencies:list project dependencies'
        'clean:remove stale objects'
        'purge:remove a package from cache'
        'embed:embed renv into a script'
        'load:load renv profile'
        'lockfile:work with lockfile'
        'modify:edit lockfile'
        'hash:show package hashes'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--project=+[project dir]:dir:_files -/' \
        '-p+[project dir]:dir:_files -/' \
        '--lockfile=+[lockfile]:file:_files -g "renv.lock"' \
        '-l+[lockfile]:file:_files -g "renv.lock"' \
        '--library=+[library path]:dir:_files -/' \
        '--profile=+[profile name]:str:' \
        '--no-prompt[no prompt]' \
        '--prompt[prompt]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'renv subcommand' sub ;;
        args)
            case $words[1] in
                install|remove|update|rebuild) _arguments \
                    '--type=+[package type]:t:(binary source)' \
                    '--rebuild[rebuild]' \
                    '--force[force]' \
                    '*:package:' ;;
                snapshot|restore) _arguments \
                    '--type=+[snapshot type]:t:(implicit explicit packrat all custom)' \
                    '--force[force]' \
                    '--clean[clean]' \
                    '--exclude=+[exclude packages]:list:' ;;
                init) _arguments \
                    '--bare[bare init]' \
                    '--force[force]' \
                    '--restart[restart R]' \
                    '--bioconductor=+[bioconductor version]:str:' ;;
                dependencies) _arguments \
                    '--path=+[path]:dir:_files -/' \
                    '--root=+[root]:dir:_files -/' \
                    '--errors=+[errors action]:a:(reported ignored fatal)' ;;
                lockfile) _arguments \
                    '1:cmd:(create show modify)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_renv "$@"
