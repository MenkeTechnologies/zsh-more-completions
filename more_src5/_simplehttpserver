#compdef simplehttpserver
# Documentation: https://github.com/projectdiscovery/simplehttpserver
# Reference accessed: 2026-05-21
# Verified: projectdiscovery/simplehttpserver upstream README.
# Removed from prior file: bogus man.archlinux.org search URL.

_arguments -s \
  '-listen=[listen address]:host\:port:' \
  '-path=[fileserver folder]:dir:_files -/' \
  '-verbose[dump request/response]' \
  '-tcp=[TCP server address]:host\:port:' \
  '-tls[TLS for TCP]' \
  '-rules=[YAML rules file]:file:_files' \
  '-upload[enable upload]' \
  '-max-file-size=[max upload MB]:n:' \
  '-sandbox[sandbox mode]' \
  '-https[HTTPS]' \
  '-http1[HTTP/1 only]' \
  '-cert=[TLS cert]:file:_files' \
  '-key=[TLS key]:file:_files' \
  '-domain=[self-signed domain]:domain:' \
  '-cors[enable CORS]' \
  '-basic-auth=[user:pass]:creds:' \
  '-realm=[basic auth realm]:realm:' \
  '-version[show version]' \
  '-silent[silent]' \
  '-py[emulate Python style]' \
  '*-header=[response header]:header:'
