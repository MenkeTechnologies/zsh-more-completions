#compdef simctl-cli xcrun-simctl
# _simctl-cli — Apple xcrun simctl iOS Simulator command-line CLI alias (Apple, Objective-C); custom argparse
# upstream: https://developer.apple.com/xcode/

_simctl-cli() {
    local -a sub=(
        'list:list available devices/runtimes/device types/pairs'
        'create:create a new device'
        'delete:delete a device'
        'rename:rename a device'
        'pair:create a watch+phone pair'
        'pair_activate:activate a pair'
        'unpair:delete a pair'
        'boot:boot a device'
        'shutdown:shutdown a device'
        'erase:erase a device'
        'clone:clone a device'
        'install:install app to device'
        'uninstall:uninstall app from device'
        'launch:launch app on device'
        'terminate:terminate app on device'
        'openurl:open a URL on device'
        'addmedia:add media to device'
        'icloud_sync:trigger iCloud sync'
        'spawn:spawn process on device'
        'getenv:print env vars'
        'logverbose:set verbose logging'
        'io:input/output'
        'push:simulate push'
        'privacy:grant/revoke privacy permissions'
        'monitor:monitor device events'
        'pbcopy:copy pasteboard'
        'pbpaste:paste pasteboard'
        'help:show help'
        'help_format:show output format help'
        'status_bar:control simulator status bar'
        'ui:UI commands'
        'fbsutil:fbsutil commands'
        'keychain:keychain commands'
        'logs:device system logs'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--set=+[device set path]:dir:_files -/' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--profiles=+[profiles to use]:list:' \
        '--no-progress[no progress]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'simctl subcommand' sub ;;
        args)
            case $words[1] in
                list) _arguments \
                    '1:cmd:(devices runtimes devicetypes pairs)' \
                    '--json[json output]' \
                    '-j[json output]' \
                    '*:arg:' ;;
                create) _arguments \
                    '1:name:' \
                    '2:device-type:' \
                    '3:runtime:' ;;
                boot|shutdown|erase|delete|rename|clone|terminate|spawn|getenv) _arguments '*:device:' ;;
                install|uninstall|launch) _arguments \
                    '1:device:' \
                    '*:app-path-or-bundle:_files' ;;
                openurl) _arguments \
                    '1:device:' \
                    '2:url:_urls' ;;
                addmedia) _arguments \
                    '1:device:' \
                    '*:media:_files' ;;
                push) _arguments \
                    '1:device:' \
                    '2:bundle-id-or-payload:_files' ;;
                io) _arguments \
                    '1:device:' \
                    '*:cmd:(screenshot recordVideo enumerate poll)' ;;
                privacy) _arguments \
                    '1:device:' \
                    '2:action:(grant revoke reset)' \
                    '3:service:(all calendar contacts location media-library microphone motion photos reminders siri speech)' \
                    '*:bundle-id:' ;;
                status_bar) _arguments \
                    '1:device:' \
                    '2:cmd:(override clear list)' \
                    '*:arg:' ;;
                ui) _arguments \
                    '1:device:' \
                    '2:cmd:(appearance content_size_category increase_contrast reduce_motion reduce_transparency)' \
                    '*:value:' ;;
                keychain) _arguments \
                    '1:device:' \
                    '2:cmd:(add-cert add-root-cert list reset)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_simctl-cli "$@"
