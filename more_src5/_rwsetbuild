#compdef rwsetbuild rwsetcat rwsetmember rwsetintersect rwsetunion rwsettool rwbagbuild rwbagcat rwbagtool
# Documentation: https://tools.netsa.cert.org/silk/rw{set*,bag*}.html
# Reference accessed: 2026-05-30
# SiLK Round 2 — companion to the round-135 `_rwfilter` multi-stem. Covers
# 9 more CERT NetSA SiLK tools for IPset + Bag construction/manipulation:
#   rwsetbuild       build IPset from textual IP list
#   rwsetcat         print IPset contents
#   rwsetmember      test IPs against an IPset
#   rwsetintersect   set intersection (rwsettool wrapper)
#   rwsetunion       set union (rwsettool wrapper)
#   rwsettool        general set-arithmetic engine
#   rwbagbuild       build Bag (key→counter) from text or IPset
#   rwbagcat         print Bag contents
#   rwbagtool        Bag arithmetic + filtering

local curcontext="$curcontext" state line ret=1

# Shared metadata flags appearing in every tool.
local -a _meta
_meta=(
  '--note-add=[annotation for header]:text:'
  '--note-file-add=[annotation file contents]:file:_files'
  '--invocation-strip[omit command line from header]'
  '--compression-method=[output compression]:method:(none zlib lzo1x snappy best)'
  '(- *)--help[show help]'
  '(- *)--version[show version]'
)

# Shared display flags appearing in the cat tools.
local -a _disp
_disp=(
  '--output-path=[output path]:path:_files'
  '--pager=[pager program]:program:_command_names -e'
  '--print-filenames[show input filenames]'
  '--no-columns[disable fixed-width columns]'
  '--column-separator=[column delimiter]:char:'
  '--no-final-delimiter[omit trailing separator]'
  '--delimited=-[pipe-delimited (custom char)]:char:'
  '--ip-format=[IP address representation]:fmt:(canonical decimal hex zero-padded any-cidr force-ipv6)'
)

case $service in

  rwsetbuild)
    _arguments -s -S \
      $_meta \
      '--ip-ranges=-[allow IP range pairs (default hyphen separator)]:delim:' \
      '--record-version=[IPset record format]:version:(0 2 3 4 5)' \
      '1:text input file:_files' \
      '2:output IPset:_files -g "*.set"' \
      && ret=0
    ;;

  rwsetcat)
    _arguments -s -S \
      $_meta \
      $_disp \
      '--count-ips[count IPs]' \
      '--print-ips[force IP printing alongside other options]' \
      '--print-statistics[summary: min/max/netblock counts]' \
      '(--cidr-blocks --ip-ranges --network-structure)--cidr-blocks[group IPs as CIDR notation]' \
      '(--cidr-blocks --ip-ranges --network-structure)--ip-ranges[output as start/end ranges]' \
      '(--cidr-blocks --ip-ranges --network-structure)--network-structure[netblock occupancy]' \
      '--integer-ips[deprecated: IPs as decimals]' \
      '--zero-pad-ips[deprecated: zero-padded]' \
      '*:IPset file:_files -g "*.set"' \
      && ret=0
    ;;

  rwsetmember)
    _arguments -s -S \
      $_meta \
      $_disp \
      '--count-records[print number of matches per file]' \
      '1:CIDR or IP pattern:' \
      '*:IPset file:_files -g "*.set"' \
      && ret=0
    ;;

  rwsetintersect|rwsetunion)
    # Thin wrappers around rwsettool with --intersect / --union pre-set.
    _arguments -s -S \
      $_meta \
      '--output-path=[output file]:file:_files -g "*.set"' \
      '--record-version=[IPset record version]:version:(0 2 3 4 5)' \
      '*:input IPset:_files -g "*.set"' \
      && ret=0
    ;;

  rwsettool)
    _arguments -s -S \
      $_meta \
      '(--union --intersect --difference --symmetric-difference --sample --mask --fill-blocks)--union[combine all input sets]' \
      '(--union --intersect --difference --symmetric-difference --sample --mask --fill-blocks)--intersect[keep common addresses only]' \
      '(--union --intersect --difference --symmetric-difference --sample --mask --fill-blocks)--difference[first set minus subsequent]' \
      '(--union --intersect --difference --symmetric-difference --sample --mask --fill-blocks)--symmetric-difference[XOR — addresses in one but not all]' \
      '(--union --intersect --difference --symmetric-difference --sample --mask --fill-blocks)--sample[random subset selection]' \
      '(--union --intersect --difference --symmetric-difference --sample --mask --fill-blocks)--mask=[replace block members with lowest IP]:block-size:' \
      '(--union --intersect --difference --symmetric-difference --sample --mask --fill-blocks)--fill-blocks=[fill entire blocks]:block-size:' \
      '--size=[sample size (exact N addresses)]:N:' \
      '--ratio=[sample ratio (0.0..1.0)]:ratio:' \
      '--seed=[RNG seed]:seed:' \
      '--output-path=[output file]:file:_files -g "*.set"' \
      '--modify-inplace[safely overwrite input file]' \
      '--backup-path=[backup before overwrite]:file:_files' \
      '--record-version=[IPset record version]:version:(0 2 3 4 5)' \
      '--note-strip[omit input annotations]' \
      '*:input IPset:_files -g "*.set"' \
      && ret=0
    ;;

  rwbagbuild)
    _arguments -s -S \
      $_meta \
      '(--set-input --bag-input)--set-input=[build Bag from IPset]:file:_files -g "*.set"' \
      '(--set-input --bag-input)--bag-input=[build Bag from delimited text]:file:_files' \
      '--delimiter=[key/counter separator (default |)]:char:' \
      '--proto-port-delimiter=[proto/port separator]:char:' \
      '--default-count=[override all counters with this value]:N:' \
      '--key-type=[key field type]:type:(sIPv4 dIPv4 sIPv6 dIPv6 sip-country dip-country sport dport protocol stcpflags dtcpflags input output)' \
      '--counter-type=[counter field type]:type:(packets bytes records sum-packets sum-bytes any-flag)' \
      '--pmap-file=[prefix-map file (MAPNAME:PATH)]:spec:' \
      '--output-path=[output Bag file]:file:_files -g "*.bag"' \
      && ret=0
    ;;

  rwbagcat)
    _arguments -s -S \
      $_meta \
      $_disp \
      '--network-structure[group IPs by netblock]' \
      '--bin-ips[invert: count keys per counter value]' \
      '--sort-counters=-[sort by counter]:direction:(increasing decreasing)' \
      '--minkey=[min key value]:value:' \
      '--maxkey=[max key value]:value:' \
      '--mincounter=[min counter value]:value:' \
      '--maxcounter=[max counter value]:value:' \
      '--mask-set=[only keys in IPset]:file:_files -g "*.set"' \
      '--zero-counts[include zero-counter records]' \
      '--key-format=[key display format]:fmt:(decimal canonical hex zero-padded timestamp duration epoch)' \
      '--pmap-file=[prefix-map file (MAPNAME:PATH)]:spec:' \
      '--print-statistics[show statistical breakdown]' \
      '--site-config-file=[SiLK site config]:file:_files' \
      '*:Bag file:_files -g "*.bag"' \
      && ret=0
    ;;

  rwbagtool)
    _arguments -s -S \
      $_meta \
      '(--add --subtract --minimize --maximize --divide --scalar-multiply --compare)--add[sum counters across Bags]' \
      '(--add --subtract --minimize --maximize --divide --scalar-multiply --compare)--subtract[first minus subsequent]' \
      '(--add --subtract --minimize --maximize --divide --scalar-multiply --compare)--minimize[min counter per key]' \
      '(--add --subtract --minimize --maximize --divide --scalar-multiply --compare)--maximize[max counter per key]' \
      '(--add --subtract --minimize --maximize --divide --scalar-multiply --compare)--divide[first Bag divided by second]' \
      '(--add --subtract --minimize --maximize --divide --scalar-multiply --compare)--scalar-multiply=[multiply counters by N]:N:' \
      '(--add --subtract --minimize --maximize --divide --scalar-multiply --compare)--compare=[counter comparison]:op:(lt le eq ge gt)' \
      '--intersect=[keep keys matching IPset]:file:_files -g "*.set"' \
      '--complement-intersect=[keep keys NOT in IPset]:file:_files -g "*.set"' \
      '--mincounter=[min counter]:value:' \
      '--maxcounter=[max counter]:value:' \
      '--minkey=[min key]:value:' \
      '--maxkey=[max key]:value:' \
      '--invert[swap keys and counters]' \
      '--coverset[output IPset instead of Bag]' \
      '--ipset-record-version=[IPset record version]:version:(0 2 3 4 5)' \
      '--output-path=[output file]:file:_files' \
      '--modify-inplace[safely overwrite input file]' \
      '--backup-path=[backup before overwrite]:file:_files' \
      '--note-strip[omit input annotations]' \
      '*:Bag file:_files -g "*.bag"' \
      && ret=0
    ;;

esac

return ret
