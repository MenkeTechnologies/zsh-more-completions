#compdef rego
# _rego — Styra rego REPL/runner wrapper (Styra, Go); wraps `opa run` / `opa eval`
# upstream: https://github.com/open-policy-agent/opa

_rego() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--data=+[data file/dir]:file:_files' \
        '-d+[data file/dir]:file:_files' \
        '--input=+[input file]:file:_files' \
        '-i+[input file]:file:_files' \
        '--query=+[query]:str:' \
        '-q+[query]:str:' \
        '--package=+[package]:pkg:' \
        '-p+[package]:pkg:' \
        '--format=+[output format]:fmt:(pretty json values bindings)' \
        '-f+[output format]:fmt:(pretty json values bindings)' \
        '--explain=+[explain]:lvl:(off full notes fails)' \
        '--metrics[metrics]' \
        '--profile[profile]' \
        '--coverage[coverage]' \
        '--watch[watch files]' \
        '*:file:_files -g "*.rego"'
}

_rego "$@"
