#compdef sbuild-update sbuild-upgrade sbuild-distupgrade
# Documentation: https://manpages.debian.org/sbuild-update
# Source: Debian/sbuild bin/sbuild-update — update sbuild chroots (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    {-h,--help}'[show help]' \
    {-V,--version}'[show version]' \
    {-v,--verbose}'[verbose output]' \
    {-q,--quiet}'[quiet output]' \
    '--arch=-[architecture]:arch:_default' \
    '--chroot-mode=-[chroot mode]:mode:(schroot sudo autopkgtest unshare)' \
    {-u,--update}'[apt-get update]' \
    {-g,--upgrade}'[apt-get upgrade]' \
    {-d,--dist-upgrade}'[apt-get dist-upgrade]' \
    {-c,--clean}'[apt-get clean]' \
    {-a,--autoclean}'[apt-get autoclean]' \
    {-r,--autoremove}'[apt-get autoremove]' \
    '*:chroot name:_default' \
    && ret=0

return ret
