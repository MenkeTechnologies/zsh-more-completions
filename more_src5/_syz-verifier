#compdef syz-verifier
# _syz-verifier — A/B verifier comparing two syzkaller manager configs (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from syz-verifier/main.go (flag).

_syz-verifier() {
    _arguments \
        '*-configs=[comma-separated kernel manager configs (>=2 required)]:files:_files -g "*.cfg"' \
        '-debug[dump all VM output to console]'
}

_syz-verifier "$@"
