#compdef sleek
# Documentation: https://github.com/nrempel/sleek
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
  '(-c --check)'{-c,--check}'[verify formatting without modifying files]'
  '(-i --indent-spaces)'{-i+,--indent-spaces=}'[indentation spaces (default 4)]:spaces:'
  '(-U --uppercase)'{-U+,--uppercase=}'[uppercase keywords (default true)]:bool:(true false)'
  '(-l --lines-between-queries)'{-l+,--lines-between-queries=}'[line breaks between queries (default 2)]:lines:'
  '(-n --trailing-newline)'{-n+,--trailing-newline=}'[add trailing newline (default true)]:bool:(true false)'
  '(-h --help)'{-h,--help}'[show help]'
  '(-V --version)'{-V,--version}'[show version]'
  '*:SQL file:_files -g "*.sql"'
)

_arguments -s -S $arguments
