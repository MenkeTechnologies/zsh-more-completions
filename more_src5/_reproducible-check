#compdef reproducible-check
# Documentation: https://manpages.debian.org/reproducible-check
# Source: debian/devscripts scripts/reproducible-check — list unreproducible installed Debian packages (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '--version[show version]' \
    '(-d --debug)'{-d,--debug}'[show debugging messages]' \
    '(-r --raw)'{-r,--raw}'[print unreproducible binary packages only (for dd-list -i)]' \
    && ret=0

return ret
