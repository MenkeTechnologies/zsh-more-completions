#compdef redoc redoc-cli
# _redoc — Redocly redoc-cli OpenAPI specification renderer producing standalone HTML PDF documentation from OpenAPI 2.0/3.0/3.1 with three-column layout request samples and language tabs (Redocly team, TypeScript); commander.js
# upstream: https://github.com/Redocly/redoc

_redoc() {
    local -a sub=(
        'build:build static HTML from OpenAPI'
        'serve:serve documentation locally'
        'bundle:bundle OpenAPI references'
        'stats:show OpenAPI stats'
        'help:show help'
        'version:show version'
        'completion:generate shell completion'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'redoc subcommand' sub ;;
        args)
            case $words[1] in
                build) _arguments \
                    '-o+[output file]:file:_files -g "*.html *.htm"' \
                    '--output=+[output file]:file:_files -g "*.html *.htm"' \
                    '-t+[template file]:file:_files -g "*.hbs *.handlebars"' \
                    '--template=+[template file]:file:_files -g "*.hbs *.handlebars"' \
                    '--title=+[title]:str:' \
                    '--cdn[use CDN bundle]' \
                    '--disableGoogleFont[no Google Font]' \
                    '--options=+[options json]:str:' \
                    '-r+[redoc options]:str:' \
                    '*:openapi:_files -g "*.yaml *.yml *.json"' ;;
                serve) _arguments \
                    '-p+[port]:n:' \
                    '--port=+[port]:n:' \
                    '-h+[host]:str:' \
                    '--host=+[host]:str:' \
                    '--watch[watch for changes]' \
                    '--ssl[serve over HTTPS]' \
                    '--use-config=+[file]:file:_files -g "*.yaml *.yml"' \
                    '*:openapi:_files -g "*.yaml *.yml *.json"' ;;
                bundle) _arguments \
                    '-o+[output]:file:_files -g "*.yaml *.yml *.json"' \
                    '--output=+[output]:file:_files -g "*.yaml *.yml *.json"' \
                    '--ext=+[ext]:e:(yaml yml json)' \
                    '--dereferenced[dereference all refs]' \
                    '*:openapi:_files -g "*.yaml *.yml *.json"' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_redoc "$@"
