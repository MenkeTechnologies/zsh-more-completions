#compdef run0
# Documentation: https://www.man7.org/linux/man-pages/man1/run0.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--no-ask-password[do not query the user for authentication]' \
  '--unit=[use this unit name]:unit name' \
  '--property=[set unit property]:property' \
  '--description=[set description for unit]:description' \
  '--slice=[run in specified slice]:slice' \
  '--slice-inherit[inherit slice of caller]' \
  '(-u --user)'{-u+,--user=}'[run as specified user]:user:_users' \
  '(-g --group)'{-g+,--group=}'[run as specified group]:group:_groups' \
  '--nice=[set nice value]:nice value' \
  '(-D --chdir)'{-D+,--chdir=}'[change to directory before running]:dir:_files -/' \
  '-i[shortcut for --via-shell --chdir=~]' \
  '--via-shell[run via login shell]' \
  '--setenv=[set environment variable]:variable=value' \
  '--background=[set ANSI background color]:color' \
  '--shell-prompt-prefix=[set shell prompt prefix]:prefix' \
  '--lightweight=[lightweight mode]:bool:(yes no)' \
  '--area=[area to run in]:area' \
  '--empower[grant additional privileges]' \
  '--same-root-dir[keep the same root directory]' \
  '--machine=[run on local container]:machine' \
  '--pty[allocate a pseudo-TTY]' \
  '--pty-late[allocate a pseudo-TTY late]' \
  '--pipe[use pipe for stdin/stdout]' \
  '*:command:_command_names -e' && ret=0

return ret
