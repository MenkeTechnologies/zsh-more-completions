#compdef specify
# Documentation: https://github.com/github/spec-kit
# Reference accessed: 2026-05-21
# Verified: upstream GitHub Spec Kit README (github/spec-kit). Subcommands
# init / check / extension / preset / integration / version confirmed.

# Zsh completion for specify CLI (GitHub Spec Kit)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:initialize a new Spec Kit project'
  'check:verify required tools are installed'
  'extension:manage extensions'
  'preset:manage presets'
  'integration:manage integrations'
  'version:show version'
  'help:show help'
)

_arguments -s -S \
  '1:command:->command' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'specify command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (init)
        _arguments -s -S \
          '--integration=[AI coding agent]:agent:(claude cursor copilot gemini codex)' \
          '--integration-options=[agent-specific options]:opts:' \
          '--here[initialize in current directory]' \
          '--force[overwrite non-empty directories]' \
          '--ignore-agent-tools[skip agent tool detection]' \
          '1:directory:_directories' && ret=0
        ;;
      (extension|preset)
        local -a sub=(
          'search:find available items'
          'add:install an item'
        )
        _describe -t commands "$words[1] subcommand" sub && ret=0
        ;;
      (integration)
        local -a sub=('list:list available integrations')
        _describe -t commands 'integration subcommand' sub && ret=0
        ;;
      (check|version|help)
        _arguments -s -S && ret=0
        ;;
    esac
    ;;
esac

return ret
