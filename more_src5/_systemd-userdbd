#compdef systemd-userdbd
# _systemd-userdbd (systemd user-database broker daemon multiplexing user records from JSON files, NSS modules, systemd-homed, machined containers and dynamic users so userdbctl(1) and other tooling sees a unified view; daemon binary accepts only standard systemd unit args)
# upstream: https://github.com/systemd/systemd (src/userdb)
# Argument shape from systemd src/userdb/userdbd.c on tip.

_systemd-userdbd() {
    _arguments \
        '--help[show help]' \
        '--version[show version]'
}

_systemd-userdbd "$@"
