#compdef ssservice sswinservice
# Documentation: https://github.com/shadowsocks/shadowsocks-rust/blob/master/bin/ssservice.rs
# Reference accessed: 2026-05-21
# Verified: upstream Rust source defines local/server/manager/genkey subcommands.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'local:run as Shadowsocks local service'
  'server:run as Shadowsocks server service'
  'manager:run as Shadowsocks manager service'
  'genkey:generate shadowsocks encryption key for method'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'ssservice command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (local|server|manager)
        _arguments \
          '(-c --config)'{-c+,--config=}'[shadowsocks configuration file]:file:_files -g "*.json"' \
          '(-b --outbound-bind-addr)'{-b+,--outbound-bind-addr=}'[outbound socket bind address]:addr:' \
          '--outbound-bind-interface=[outbound bind interface]:iface:_net_interfaces' \
          '*--outbound-proxy=[proxy hop for TCP relay]:url:' \
          '(-s --server-addr)'{-s+,--server-addr=}'[remote server address]:addr:' \
          '(-k --password)'{-k+,--password=}'[server password]:password:' \
          '(-m --encrypt-method)'{-m+,--encrypt-method=}'[encryption method]:method:(none plain aes-128-gcm aes-256-gcm chacha20-ietf-poly1305 2022-blake3-aes-128-gcm 2022-blake3-aes-256-gcm 2022-blake3-chacha20-poly1305)' \
          '--timeout=[TCP relay timeout in seconds]:seconds:' \
          '(-u --udp-only -U --tcp-and-udp)'{-u,--udp-only}'[UDP-only relay mode]' \
          '(-u --udp-only -U --tcp-and-udp)'{-U,--tcp-and-udp}'[TCP and UDP relay mode]' \
          '--plugin=[SIP003 plugin command]:plugin:' \
          '--plugin-opts=[plugin options]:opts:' \
          '--plugin-mode=[plugin mode]:mode:(tcp_only udp_only tcp_and_udp)' \
          '--tcp-no-delay[enable TCP_NODELAY]' \
          '--tcp-fast-open[enable TCP Fast Open]' \
          '--tcp-multipath[enable Multipath TCP]' \
          '--manager-addr=[manager address for ssmgr]:addr:' \
          '*'{-v,--verbose}'[increase log verbosity]' \
          '--log-without-time[omit timestamps in logs]' \
          '--log-config=[log4rs configuration file]:file:_files' \
          '(-d --daemonize)'{-d,--daemonize}'[run as daemon]' \
          '--daemonize-pid=[PID file path]:file:_files' \
          '(-n --nofile)'{-n+,--nofile=}'[set RLIMIT_NOFILE]:n:' \
          '--outbound-fwmark=[SO_MARK (Linux/Android)]:mark:' \
          '--single-threaded[run single-threaded]' \
          '--worker-threads=[number of worker threads]:n:' \
          '(-a --user)'{-a+,--user=}'[run as specified user]:user:_users' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0 ;;
      (genkey)
        _arguments \
          '(-m --method)'{-m+,--method=}'[encryption method]:method:(aes-128-gcm aes-256-gcm chacha20-ietf-poly1305 2022-blake3-aes-128-gcm 2022-blake3-aes-256-gcm 2022-blake3-chacha20-poly1305)' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0 ;;
    esac ;;
esac

return ret
