#compdef resticprofile
# Documentation: https://creativeprojects.github.io/resticprofile/usage/index.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for resticprofile - Restic backup profile manager

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-c --config)'{-c,--config}'[config file]:file:_files' \
  '(-f --format)'{-f,--format}'[config format]:format:(toml yaml json hcl)' \
  '(-n --name)'{-n,--name}'[profile name]:name:' \
  '(-l --log)'{-l,--log}'[log file or syslog]:target:_files' \
  '(-w --wait)'{-w,--wait}'[wait for user input on exit]' \
  '--dry-run[do not execute commands]' \
  '--no-ansi[disable console coloring]' \
  '--no-lock[disable resticprofile locks]' \
  '--no-prio[do not set process priority]' \
  '--trace[display trace/debug information]' \
  '--stderr[redirect output to stderr]' \
  '--theme=[color theme]:theme:(light dark none)' \
  '--lock-wait=[duration to retry lock acquisition]:duration:' \
  '--command-output=[command output handling]:mode:' \
  '--ignore-on-battery[skip execution on battery power]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'backup:run a backup'
      'check:check repository consistency'
      'copy:copy snapshots between repositories'
      'diff:show differences between snapshots'
      'dump:dump a file from a snapshot'
      'find:find a file in snapshots'
      'forget:remove snapshots'
      'generate:generate resources'
      'init:initialize a repository'
      'ls:list files in a snapshot'
      'mount:mount a repository'
      'prune:remove unneeded data'
      'restore:restore a snapshot'
      'schedule:schedule a profile via cron/systemd'
      'unschedule:remove a scheduled profile'
      'show:show profile configuration'
      'snapshots:list snapshots'
      'stats:show repository statistics'
      'status:show schedule job status'
      'profiles:list available profiles'
      'self-update:update resticprofile'
      'version:show version'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
esac

return ret
