#compdef ratbagctl
# Documentation: https://github.com/libratbag/libratbag
# Reference accessed: 2026-05-27
# Verified: upstream tools/ratbagctl.body.py.in parser_def schema (libratbag/libratbag)

# Zsh completion for ratbagctl (libratbag mouse configuration CLI)

local curcontext="$curcontext" state line ret=1

local -a _ratbagctl_subcommands
_ratbagctl_subcommands=(
  'info:show device information'
  'name:return the device name'
  'profile:access profile information (active, name, enable, disable, N ...)'
  'resolution:access resolution information (active, default, N ...)'
  'dpi:get/set/list DPI values for a resolution'
  'rate:get/set the report rate in Hz'
  'button:access button information (count, action, mapping, macro, ...)'
  'led:access LED information (count, mode, color, brightness, ...)'
)

# Global flags are recognised before the device/list positional, and -v/--verbose
# may also appear after subcommands. Only `list` is allowed in place of a device.
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show ratbagctl version]' \
  '(-v --verbose)*'{-v,--verbose}'[increase verbosity (repeatable)]' \
  '--nocommit[do not apply changes to the device]' \
  '1: :->dev' \
  '2: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  dev)
    local -a _devs
    _devs=( 'list:list available devices' )
    _describe -t devices 'device or list' _devs && ret=0
    _message -e 'device' 'hidraw device path' && ret=0
    ;;
  cmd)
    if [[ $line[1] == list ]]; then
      return ret
    fi
    _describe -t commands 'ratbagctl subcommand' _ratbagctl_subcommands && ret=0
    ;;
  args)
    local -a _subs
    case $line[2] in
      profile)
        _subs=(
          'active:access active profile (get|set N)'
          'name:get/set profile name'
          'enable:enable a profile'
          'disable:disable a profile'
          'get:show profile info for index N'
        )
        _describe -t commands 'profile action' _subs && ret=0
        ;;
      resolution)
        _subs=(
          'active:access active resolution (get|set N)'
          'default:access default resolution (get|set N)'
          'get:show resolution info for index N'
        )
        _describe -t commands 'resolution action' _subs && ret=0
        ;;
      dpi)
        _subs=(
          'get:show current DPI value'
          'set:set DPI value'
          'list:list supported DPI values'
        )
        _describe -t commands 'dpi action' _subs && ret=0
        ;;
      rate)
        _subs=(
          'get:show current report rate'
          'set:set report rate in Hz'
        )
        _describe -t commands 'rate action' _subs && ret=0
        ;;
      button)
        _subs=(
          'count:show number of buttons'
          'action:get/set button action'
          'mapping:get/set button mapping'
          'macro:set a macro for a button'
          'special:show available special actions'
        )
        _describe -t commands 'button action' _subs && ret=0
        ;;
      led)
        _subs=(
          'count:show number of LEDs'
          'mode:get/set LED mode'
          'color:get/set LED color (RRGGBB)'
          'brightness:get/set LED brightness'
          'effect-duration:get/set effect duration'
          'get:show LED settings'
        )
        _describe -t commands 'led action' _subs && ret=0
        ;;
      info|name)
        ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
