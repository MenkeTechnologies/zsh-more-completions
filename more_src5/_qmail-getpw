#compdef qmail-getpw
# _qmail-getpw — qmail's local-account resolver (look up the owner of a qmail local address; prints "user\0uid\0gid\0homedir\0dash\0ext\0" so qmail-lspawn(8) can spawn qmail-local under the right uid/gid)
# upstream: https://github.com/notqmail/notqmail
# Source: qmail-getpw.9 on tip; positional only.

_qmail-getpw() {
    _arguments '1:local:_users'
}

_qmail-getpw "$@"
