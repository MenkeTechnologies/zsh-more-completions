#compdef rufio
# _rufio — Tinkerbell Rufio BMC controller (reconciles Machine, Job, Task CRs into IPMI/Redfish operations against bare-metal BMCs)
# upstream: https://github.com/tinkerbell/rufio
# Flags from main.go on tip.

_rufio() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metrics-bind-address=[metric endpoint bind address]:addr:' \
        '--health-probe-bind-address=[probe endpoint bind address]:addr:' \
        '--leader-elect[enable leader election]' \
        '--kubernetes=[Kubernetes API URL]:url:_urls' \
        '--kubeconfig=[absolute path to kubeconfig (out-of-cluster only)]:file:_files' \
        '--kube-namespace=[namespace the controller reconciles in]:ns:' \
        '--bmc-connect-timeout=[timeout for BMC connections]:duration:' \
        '--max-concurrent-reconciles=[max concurrent reconciles per controller]:n:' \
        '-v[klog verbosity level]:n:'
}

_rufio "$@"
