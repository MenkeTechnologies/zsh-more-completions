#compdef schemalex
# _schemalex — MySQL schema diff tool
# upstream: https://github.com/schemalex/schemalex

_arguments -s -S \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '--transaction[wrap output in a transaction]' \
    '1:before schema (file or DSN):_files' \
    '2:after schema (file or DSN):_files' \
    && return 0
