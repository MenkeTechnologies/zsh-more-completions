#compdef rblsmtpd
# _rblsmtpd — DJB ucspi-tcp rblsmtpd (DNS-blocklist / allowlist front-end that runs under tcpserver before qmail-smtpd; consults the user-supplied DNSBL bases)
# upstream: https://github.com/schmonz/ucspi-tcp
# Flags from rblsmtpd.c on tip (getopt).

_rblsmtpd() {
    _arguments \
        '-b[bounce rejected mail (5xx) instead of soft-reject (4xx)]' \
        '-R[do not look up TXT for RBL]' \
        '-t+[connect timeout (sec)]:sec:' \
        '*-r+[DNS blocklist base domain (check RBL hit)]:base:' \
        '*-a+[DNS allowlist base domain (skip RBL when listed)]:base:' \
        '1:smtpd:_command_names -e' \
        '*::args:'
}

_rblsmtpd "$@"
