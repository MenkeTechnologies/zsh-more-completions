#compdef systemd-binfmt
# Documentation: source-direct extraction from upstream
# systemd/systemd src/binfmt/binfmt.c —
#   help() block at lines 110-135
#   parse_argv() at lines 137-177 (OptionParser FOREACH_OPTION_
#     OR_RETURN dispatch + OPTION_COMMON_CAT_CONFIG +
#     OPTION_COMMON_TLDR + OPTION_COMMON_NO_PAGER + OPTION_LONG
#     entries)
#   conflict validation at lines 171-173 (--unregister mutex
#     with --cat-config/--tldr and with positional args)
# Reference accessed: 2026-05-30 via gh api.
#
# systemd-binfmt registers binary formats (qemu-user binaries,
# wine-binfmt entries, etc.) with the kernel's binfmt_misc
# subsystem by reading /etc/binfmt.d/*.conf, /run/binfmt.d/*.conf,
# /usr/lib/binfmt.d/*.conf and applying their `:NAME:type:..:`
# directives to /proc/sys/fs/binfmt_misc.  Runs as
# systemd-binfmt.service at boot.  Can be invoked manually with
# a CONFIG-FILE positional to register just that file.
#
# Critical extraction note: binfmt introduces 2 NEW
# OPTION_COMMON_* macros (continuing R218/R219/R220's modern-
# systemd-CLI documentation effort):
#   OPTION_COMMON_CAT_CONFIG — auto-add --cat-config: print
#                              all loaded binfmt config files
#                              (with merged search-path output)
#   OPTION_COMMON_TLDR       — auto-add --tldr: print only the
#                              most-specific config file
#                              winning at each search-path
#                              level (deduplicated)
# Both are mutex with --unregister and with positional args.
# Used consistently across systemd-tmpfiles, systemd-sysusers,
# systemd-binfmt, systemd-modules-load — all the config-file-
# applying systemd services that read from `/etc/*.d/` dirs.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '--version[show package version and exit]' \
  '(--cat-config --tldr)--cat-config[print all loaded binfmt configuration files]' \
  '(--cat-config --tldr)--tldr[print only the most-specific config file at each search-path level]' \
  '--no-pager[do not pipe output into a pager]' \
  '(--unregister *)--unregister[unregister all existing binfmt_misc entries (mutex with --cat-config/--tldr and positional config files)]' \
  '*:binfmt configuration file:_files -g "*.conf"'
