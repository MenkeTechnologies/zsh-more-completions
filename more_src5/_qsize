#compdef qsize
# Documentation: https://github.com/gentoo/portage-utils
# Source: gentoo/portage-utils qsize.c — show installed-package disk usage.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-f --filesystem)'{-f,--filesystem}'[show size used on disk]' \
    '(-s --sum)'{-s,--sum}'[include summary]' \
    '(-S --sum-only)'{-S,--sum-only}'[show only the summary]' \
    '(-m --megabytes -k --kilobytes -b --bytes)'{-m,--megabytes}'[sizes in MB]' \
    '(-m --megabytes -k --kilobytes -b --bytes)'{-k,--kilobytes}'[sizes in KB]' \
    '(-m --megabytes -k --kilobytes -b --bytes)'{-b,--bytes}'[sizes in bytes]' \
    '*'{-i+,--ignore=}'[ignore regexp]:regex:_default' \
    '(-F --format)'{-F+,--format=}'[output format string]:fmt:_default' \
    '*:package atom:_default' \
    && ret=0

return ret
