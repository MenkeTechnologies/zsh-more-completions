#compdef ras2tiff
# Documentation: http://www.libtiff.org/tools.html
# Source: libtiff tools/ras2tiff.c — convert Sun raster file to TIFF (C, getopt).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[print help]' \
    '-r+[rows per strip]:rows:_default' \
    '-c+[output compression]:comp:(lzw zip jpeg packbits none)' \
    '1:input.ras:_files -g "*.{ras,RAS}"' \
    '2:output.tif:_files' \
    && ret=0

return ret
