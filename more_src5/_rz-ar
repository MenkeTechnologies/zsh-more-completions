#compdef rz-ar
# _rz-ar — rizin ar/.deb archive inspector (rizinorg/rizin)
# upstream: https://github.com/rizinorg/rizin
# Flags from librz/main/rz-ar.c (rz_ar_show_help).

_rz-ar() {
    _arguments \
        '-h[show help]' \
        '-l[list matching members]' \
        '-o+[output directory (default .)]:dir:_files -/' \
        '-q[quiet mode]' \
        '-v[show version]' \
        '1:archive:_files' \
        '*:member:_files'
}

_rz-ar "$@"
