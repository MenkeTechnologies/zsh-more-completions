#compdef qmail-qmqpd
# _qmail-qmqpd — qmail's Quick Mail Queueing Protocol daemon (accepts QMQP submissions from preauthorized clients on UCSPI-TCP and feeds them into qmail-queue; mirrors qmail-qmqpc)
# upstream: https://github.com/notqmail/notqmail
# Source: qmail-qmqpd.8 on tip; no flags — env vars come from tcp-environ(5).

_qmail-qmqpd() {
    _arguments '(- *)-h[show help]'
}

_qmail-qmqpd "$@"
