#compdef songrec
# _songrec — open-source Shazam client for Linux (marin-m/SongRec)
# upstream: https://github.com/marin-m/SongRec
# Subcommands from src/main.rs (clap builder).

_songrec() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '*'{-v,--verbose}'[verbose (repeatable: -v info, -vv debug, -vvv trace)]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'listen:listen the microphone and print recognized songs to stdout'
                'recognize:recognize a single song from a file'
                'audio-file-to-recognized-song:recognize song from an audio file'
                'microphone-to-recognized-song:recognize song from the microphone'
                'audio-file-to-fingerprint:print fingerprint of an audio file'
                'fingerprint-to-recognized-song:recognize song from a fingerprint'
                'gui:start the GUI'
                'gui-norecording:start the GUI without recording'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                listen|microphone-to-recognized-song|gui|gui-norecording)
                    _arguments \
                        '*:audio device:'
                    ;;
                recognize|audio-file-to-recognized-song|audio-file-to-fingerprint)
                    _arguments ':audio file:_files'
                    ;;
                fingerprint-to-recognized-song)
                    _arguments ':fingerprint string or file:_files'
                    ;;
            esac
            ;;
    esac
}

_songrec "$@"
