autoload -U is-at-least

_ragenix() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-e+[edits the age-encrypted FILE using \$EDITOR]:FILE:_files' \
'--edit=[edits the age-encrypted FILE using \$EDITOR]:FILE:_files' \
'-i+[private key to use when decrypting]:PRIVATE_KEY:_files' \
'--identity=[private key to use when decrypting]:PRIVATE_KEY:_files' \
'--editor=[editor to use when editing FILE]:EDITOR:_cmdstring' \
'--rules=[path to Nix file specifying recipient public keys]:RULES:_files' \
'-r[re-encrypts all secrets with specified recipients]' \
'--rekey[re-encrypts all secrets with specified recipients]' \
'-v[verbose output]' \
'--verbose[verbose output]' \
'-s[Prints the JSON schema Agenix rules have to conform to]' \
'--schema[Prints the JSON schema Agenix rules have to conform to]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
}

(( $+functions[_ragenix_commands] )) ||
_ragenix_commands() {
    local commands; commands=()
    _describe -t commands 'ragenix commands' commands "$@"
}

if [ "$funcstack[1]" = "_ragenix" ]; then
    _ragenix "$@"
else
    compdef _ragenix ragenix
fi
