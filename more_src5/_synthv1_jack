#compdef synthv1_jack
# _synthv1_jack — synthv1 polyphonic subtractive synth, JACK client (rncbc/synthv1)
# upstream: https://github.com/rncbc/synthv1
# Flags from src/synthv1_jack.cpp (QCommandLineParser).

_synthv1_jack() {
    _arguments \
        '(- *)'{-h,--help,-?}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-g --no-gui)'{-g,--no-gui}'[disable the GUI]' \
        '(-n --client-name)'{-n+,--client-name=}'[JACK client name]:name:' \
        '*:preset file:_files -g "*.{synthv1,xml}"'
}

_synthv1_jack "$@"
