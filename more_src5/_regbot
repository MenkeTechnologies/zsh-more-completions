#compdef regbot
# Documentation: https://github.com/regclient/regclient
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config}'[config file]:config file:_files' \
  '(-v --verbosity)'{-v,--verbosity}'[log verbosity level]:level:(debug info warn error)' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a subcommands=(
      'once:run bot once'
      'server:run as persistent server'
      'check:check configuration'
      'version:show version'
      'help:show help'
    )
    _describe -t commands 'regbot subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      once|server|check)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-c --config)'{-c,--config}'[config file]:config file:_files' \
          '(-v --verbosity)'{-v,--verbosity}'[log verbosity level]:level:(debug info warn error)' && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
