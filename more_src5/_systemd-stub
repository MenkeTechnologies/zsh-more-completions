#compdef systemd-stub
# _systemd-stub (systemd PE/COFF EFI stub bundling a kernel + initrd + cmdline + os-release into a single signed boot image consumed by sd-boot; usually not invoked directly — built into a unified-kernel-image via kernel-install / ukify(1))
# upstream: https://github.com/systemd/systemd (src/boot/efi/stub.c)
# Behaviour from systemd src/boot/efi/stub.c on tip.

_systemd-stub() {
    _arguments \
        '--help[show help]' \
        '--version[show version]'
}

_systemd-stub "$@"
