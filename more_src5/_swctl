#compdef swctl
# Documentation: https://github.com/apache/skywalking-cli/blob/master/cmd/swctl/main.go
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# swctl - Apache SkyWalking CLI (cobra/urfave-cli)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--config=[config file path]:file:_files' \
  '--base-url=[OAP backend GraphQL service URL]:url:' \
  '--grpc-addr=[backend gRPC service address]:host\:port:' \
  '--username=[basic auth username]:user:' \
  '--password=[basic auth password]:pass:' \
  '--authorization=[custom authorization header]:auth:' \
  '--insecure[skip TLS certificate verification]' \
  '--timezone=[timezone for time-based queries]:tz:' \
  '--debug[enable debug mode]' \
  '--display=[output format]:format:(json yaml table graph)' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'browser:browser-related operations'
      'endpoint:endpoint-related operations'
      'instance:instance-related operations'
      'service:service-related operations'
      'metrics:metrics-related operations'
      'trace:trace-related operations'
      'tracev2:zipkin/jaeger trace operations'
      'healthcheck:health check operations'
      'dashboard:dashboard operations'
      'install:install OAP, UI, etc'
      'event:event-related operations'
      'logs:logs-related operations'
      'completion:generate shell completion scripts'
      'dependency:dependency analysis operations'
      'alarm:alarm-related operations'
      'layer:layer-related operations'
      'process:process-related operations'
      'profiling:profiling operations'
      'records:records-related operations'
      'menu:menu operations'
      'hierarchy:hierarchy operations'
    )
    _describe -t commands 'swctl command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (completion)
        _values 'shell' bash zsh fish powershell && ret=0
        ;;
    esac
    ;;
esac

return ret
