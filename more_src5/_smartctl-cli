#compdef smartctl-cli
# _smartctl-cli — Bruce Allen smartmontools smartctl SMART disk monitoring CLI alias (smartmontools team, C++); custom argparse
# upstream: https://www.smartmontools.org/

_smartctl-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-i[show info]' \
        '--info[show info]' \
        '-a[show all SMART info]' \
        '--all[show all SMART info]' \
        '-x[show all SMART and non-SMART info]' \
        '--xall[show all SMART and non-SMART info]' \
        '-c[show generic SMART capabilities]' \
        '--capabilities[show generic SMART capabilities]' \
        '-A[show SMART attributes]' \
        '--attributes[show SMART attributes]' \
        '-l+[log type]:l:(error xerror selftest selective directory background sasphy sataphy scttemp scttempsts scttemphist scterc devstat ssd nvmelog farm xerror selftest scterc gplog smartlog gplistorder]' \
        '--log=+[log type]:l:(error xerror selftest selective directory background sasphy sataphy scttemp scttempsts scttemphist scterc devstat ssd nvmelog)' \
        '-q+[quiet level]:q:(errorsonly silent noserial)' \
        '--quietmode=+[quiet level]:q:(errorsonly silent noserial)' \
        '-d+[device type]:t:(ata scsi sat usbcypress usbjmicron usbprolific usbsunplus nvme cciss areca aacraid auto megaraid 3ware hpt)' \
        '--device=+[device type]:t:(ata scsi sat usbcypress usbjmicron usbprolific usbsunplus nvme cciss areca aacraid auto megaraid 3ware hpt)' \
        '-T+[tolerance]:t:(normal conservative permissive verypermissive)' \
        '--tolerance=+[tolerance]:t:(normal conservative permissive verypermissive)' \
        '-b+[bad mode]:b:(warn exit ignore)' \
        '--badsum=+[bad mode]:b:(warn exit ignore)' \
        '-r+[register]:r:(ioctl ataioctl scsiioctl)' \
        '--report=+[register]:r:(ioctl ataioctl scsiioctl)' \
        '-n+[no-check]:n:(never sleep standby idle)' \
        '--nocheck=+[no-check]:n:(never sleep standby idle)' \
        '-s+[enable/disable feature]:str:' \
        '--smart=+[enable/disable feature]:str:' \
        '-o+[offline data collection]:o:(on off)' \
        '--offlineauto=+[offline data collection]:o:(on off)' \
        '-S+[attribute autosave]:s:(on off)' \
        '--saveauto=+[attribute autosave]:s:(on off)' \
        '-t+[self-test]:t:(offline short long conveyance vendor select afterselect pending scttempint force scttempint conveyance long short offline)' \
        '--test=+[self-test]:t:(offline short long conveyance vendor select afterselect pending scttempint force scttempint conveyance long short offline)' \
        '-X[abort current self-test]' \
        '--abort[abort current self-test]' \
        '-C[captive mode for self-test]' \
        '--captive[captive mode for self-test]' \
        '-v+[ID:option,format]:str:' \
        '--vendorattribute=+[ID:option,format]:str:' \
        '-F+[firmware-bug option]:str:' \
        '--firmwarebug=+[firmware-bug option]:str:' \
        '-P+[presets]:p:(show showall use ignore)' \
        '--presets=+[presets]:p:(show showall use ignore)' \
        '-B+[drive db file]:file:_files' \
        '--drivedb=+[drive db file]:file:_files' \
        '-H[health check]' \
        '--health[health check]' \
        '-j[json output]' \
        '--json[json output]' \
        '--scan[scan for devices]' \
        '--scan-open[scan and open]' \
        '*:device:_files -g "/dev/{sd,hd,nvme}*"'
}

_smartctl-cli "$@"
