#compdef stan

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'check:check Haskell source files'
  'report:generate report'
  'inspect:inspect analysis results'
)

_arguments -s -S \
  '--include[include inspections]:inspections:' \
  '--exclude[exclude inspections]:inspections:' \
  '--config[configuration file]:config file:_files' \
  '--json[output in JSON format]' \
  '--html[output in HTML format]' \
  '--no-default[disable default inspections]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'stan subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (check)
        _arguments -s -S \
          '-i[input file]:input file:_files' \
          '--cabal-file-path[path to cabal file]:cabal file:_files -g "*.cabal"' \
          '--hiedir[directory containing .hie files]:hie directory:_files -/' \
          '*:file:_files' && ret=0
        ;;
      (*)
        _arguments -s -S '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
