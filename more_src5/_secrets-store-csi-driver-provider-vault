#compdef secrets-store-csi-driver-provider-vault vault-csi-provider
# _secrets-store-csi-driver-provider-vault — HashiCorp Vault provider for the SecretsStore CSI driver (gRPC provider that fetches secrets from Vault into pods)
# upstream: https://github.com/hashicorp/secrets-store-csi-driver-provider-vault
# Flags from main.go on tip; VAULT_ADDR / VAULT_NAMESPACE / VAULT_CACERT / VAULT_CAPATH / VAULT_TLS_SERVER_NAME / VAULT_CLIENT_CERT / VAULT_CLIENT_KEY / VAULT_SKIP_VERIFY env vars bind to the corresponding flags.

_secrets-store-csi-driver-provider-vault() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-version[print version information]' \
        '-output=[version output format]:fmt:(yaml json json-pretty)' \
        '-endpoint=[Unix socket the provider listens on]:socket:_files' \
        '-debug[DEPRECATED: alias for -log-level=debug]' \
        '-log-level=[log level]:level:(off error warn info debug trace)' \
        '-health-addr=[health server HTTP address]:addr:' \
        '-hmac-secret-name=[Kubernetes Secret name used to store the HMAC key]:name:' \
        '-cache-size=[max number of cached Vault tokens]:n:' \
        '-vault-addr=[default Vault address (VAULT_ADDR env var)]:url:_urls' \
        '-vault-mount=[default Vault auth mount path]:mount:' \
        '-vault-namespace=[default Vault namespace (VAULT_NAMESPACE env var)]:ns:' \
        '-vault-tls-ca-cert=[PEM CA certificate for Vault TLS (VAULT_CACERT env var)]:file:_files' \
        '-vault-tls-ca-directory=[directory of PEM CA certs (VAULT_CAPATH env var)]:dir:_files -/' \
        '-vault-tls-server-name=[SNI server name (VAULT_TLS_SERVER_NAME env var)]:host:' \
        '-vault-tls-client-cert=[mTLS client cert (VAULT_CLIENT_CERT env var)]:file:_files' \
        '-vault-tls-client-key=[mTLS client key (VAULT_CLIENT_KEY env var)]:file:_files' \
        '-vault-tls-skip-verify[disable Vault TLS verification (VAULT_SKIP_VERIFY env var)]'
}

_secrets-store-csi-driver-provider-vault "$@"
