#compdef scanspool
# Documentation: man scanspool(8)
# Source: InterNetNews/inn frontends/scanspool.in — validate news article spool (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a+[active file]:file:_files' \
    '-c[check filenames only, do not scan articles]' \
    '-n[do not throttle innd]' \
    '-r[remove problem articles]' \
    '-s+[spool directory]:dir:_files -/' \
    '-v[verbose]' \
    '*:newsgroup:_default' \
    && ret=0

return ret
