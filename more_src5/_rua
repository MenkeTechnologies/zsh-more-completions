#compdef rua
# Documentation: https://github.com/vn971/rua (src/cli_args.rs clap derive)
# Reference accessed: 2026-05-29
# rua — secure jailed AUR helper (Arch Linux). Builds AUR packages in bubblewrap/systemd-nspawn isolation.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'builddir:build package in specified directory, in jail'
  'info:show package information'
  'install:download a package by name and build it in jail'
  'search:search for packages by name or description (multi-keyword AND)'
  'shellcheck:run shellcheck on a PKGBUILD'
  'tarcheck:check a *.pkg.tar.{xz,gz,zst} archive'
  'upgrade:upgrade AUR packages (respects IgnorePkg)'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--color=[control color output]:mode:(auto never always)' \
  '1: :->subcmd' \
  '*:: :->args' && ret=0

case $state in
  subcmd)
    _describe -t commands 'rua subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      builddir)
        _arguments \
          '(-o --offline)'{-o,--offline}'[forbid internet access while building]' \
          '(-f --force)'{-f,--force}'[use --force option with makepkg]' \
          '1:target directory (defaults to current dir):_directories' && ret=0
        ;;
      info)
        _arguments '*:target:' && ret=0
        ;;
      install)
        _arguments \
          '--asdeps[install package as dependency]' \
          '--offline[forbid internet access while building]' \
          '*:AUR package:' && ret=0
        ;;
      search)
        _arguments '*:keyword:' && ret=0
        ;;
      shellcheck)
        _arguments '1:PKGBUILD or directory (defaults to ./PKGBUILD):_files' && ret=0
        ;;
      tarcheck)
        _arguments '1:archive:_files -g "*.pkg.tar*(|.xz|.gz|.zst)"' && ret=0
        ;;
      upgrade)
        _arguments \
          '(-d --devel)'{-d,--devel}'[also rebuild development packages (git, hg, svn, bzr, cvs, darcs)]' \
          '--printonly[print the list of outdated packages to stdout]' \
          '*--ignore=[do not upgrade specified package(s) (repeatable; or comma-separated)]:pkg:' && ret=0
        ;;
    esac
    ;;
esac

return ret
