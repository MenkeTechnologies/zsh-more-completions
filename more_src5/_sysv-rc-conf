#compdef sysv-rc-conf
# Documentation: man sysv-rc-conf(8)
# Source: Debian sysv-rc-conf (Perl, Getopt::Long) — SysV-style runlevel configurator.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--cache=[cache directory]:dir:_files -/' \
    '--help[show help]' \
    '--level=[runlevels (1-9,0,6,S)]:levels:_default' \
    '--list=[list services]::name:_default' \
    '--order=[script order]:order:_default' \
    '--priority[show priorities]' \
    '--Purge[purge cache]' \
    '--root=[alternate / root]:dir:_files -/' \
    '--show=[runlevels to show]:levels:_default' \
    '--verbose=[verbose log file]:file:_files' \
    '--Version[show version]' \
    '1::service name:_services' \
    '2::state:(on off)' \
    && ret=0

return ret
