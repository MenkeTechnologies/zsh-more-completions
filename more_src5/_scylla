#compdef scylla
# Documentation: https://github.com/scylladb/scylladb/blob/master/db/config.cc and https://github.com/scylladb/seastar/blob/master/src/core/reactor.cc
# Reference accessed: 2026-05-21
# Verified: scylladb db/config.cc named_value entries (cluster_name,
# listen_address, rpc_address, broadcast_address, work_directory→--workdir,
# commitlog_directory, hints_directory, saved_caches_directory, data_file_directories,
# api_address, api_port, alternator_address, alternator_port, alternator_https_port,
# prometheus_address, prometheus_port, prometheus_prefix, authenticator,
# authorizer, num_tokens, abort_on_lsa_bad_alloc, io_properties_file,
# max_io_requests, developer_mode, log_to_stdout, log_to_syslog,
# default_log_level, seed_provider_class_name+parameters), and seastar
# reactor.cc options (smp, memory, reserve-memory, cpuset, task-quota-ms,
# blocked-reactor-notify-ms, overprovisioned, abort-on-seastar-bad-alloc).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--workdir=[working directory]:dir:_files -/' \
  '--listen-address=[address to listen on for inter-node]:addr:' \
  '--rpc-address=[address for RPC/CQL]:addr:' \
  '--broadcast-address=[address advertised to other nodes]:addr:' \
  '--broadcast-rpc-address=[RPC address advertised to clients]:addr:' \
  '--smp=[restrict to N CPUs]:n:' \
  '--memory=[restrict memory]:size:' \
  '--reserve-memory=[memory to reserve for OS]:size:' \
  '--cpuset=[CPU set]:set:' \
  '--cluster-name=[cluster name]:name:' \
  '--seed-provider-parameters=[seed provider params]:params:' \
  '--data-file-directories=[data file directories]:dirs:' \
  '--commitlog-directory=[commitlog dir]:dir:_files -/' \
  '--hints-directory=[hints dir]:dir:_files -/' \
  '--saved-caches-directory=[saved caches dir]:dir:_files -/' \
  '--developer-mode=[developer mode]:flag:(0 1)' \
  '--overprovisioned[overprovisioned mode]' \
  '--default-log-level=[log level]:level:(trace debug info warn error)' \
  '--log-to-stdout=[log to stdout]:flag:(0 1)' \
  '--log-to-syslog=[log to syslog]:flag:(0 1)' \
  '--abort-on-seastar-bad-alloc[abort on bad_alloc]' \
  '--abort-on-lsa-bad-alloc=[abort on LSA bad_alloc]:flag:(0 1)' \
  '--api-address=[REST API address]:addr:' \
  '--api-port=[REST API port]:port:' \
  '--prometheus-address=[Prometheus address]:addr:' \
  '--prometheus-port=[Prometheus port]:port:' \
  '--prometheus-prefix=[Prometheus metric prefix]:prefix:' \
  '--alternator-address=[Alternator (DynamoDB) address]:addr:' \
  '--alternator-port=[Alternator port]:port:' \
  '--alternator-https-port=[Alternator HTTPS port]:port:' \
  '--authenticator=[authenticator class]:class:(AllowAllAuthenticator PasswordAuthenticator)' \
  '--authorizer=[authorizer class]:class:(AllowAllAuthorizer CassandraAuthorizer)' \
  '--num-tokens=[virtual nodes per host]:n:' \
  '--io-properties-file=[IO properties YAML]:file:_files -g "*.yaml"' \
  '--max-io-requests=[max concurrent IO requests]:n:' \
  '--task-quota-ms=[task quota ms]:ms:' \
  '--blocked-reactor-notify-ms=[blocked reactor threshold]:ms:' \
  '*--config-file=[config file]:file:_files -g "*.yaml"' && ret=0

return ret
