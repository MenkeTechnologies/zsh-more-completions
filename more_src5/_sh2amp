#compdef sh2amp
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/sh2amp.html
# Source: MRtrix3/mrtrix3 cmd/sh2amp.cpp — evaluate SH amplitudes along specified directions (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-nonnegative[output non-negative amplitudes (negative clipped to zero)]' \
    '-grad+[MRtrix gradient table]:file:_files' \
    '-fslgrad+[FSL bvecs bvals pair]:files:_files' \
    '-strides+[output data strides]:strides:_default' \
    '-datatype+[output datatype]:dtype:(float16 cfloat16 float32 cfloat32 float64 cfloat64 int8 uint8 int16 uint16 int32 uint32 int64 uint64 bit)' \
    '1:input (SH image):_files -g "*.{nii,nii.gz,mif}"' \
    '2:directions (file or image):_files' \
    '3:output (amplitudes image):_files' \
    && ret=0

return ret
