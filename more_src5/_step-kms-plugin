#compdef step-kms-plugin
# _step-kms-plugin — manage keys / certs on KMSs / HSMs (smallstep/step-kms-plugin)
# upstream: https://github.com/smallstep/step-kms-plugin
# Subcommands + persistent flag from cmd/*.go (cobra).

_step-kms-plugin() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--kms=[KMS configuration URI (pkcs11: tpmkms: awskms: cloudkms: azurekms: yubikey: mackms: sshagentkms:)]:uri:' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_step-kms-plugin_commands' \
        '*::arg:->args' && ret=0

    return ret
}

(( $+functions[_step-kms-plugin_commands] )) ||
_step-kms-plugin_commands() {
    local -a commands
    commands=(
        'attest:create an attestation certificate'
        'certificate:print / import / copy / delete a certificate in a KMS'
        'create:generate a key pair in the KMS'
        'decrypt:decrypt with an RSA key stored in the KMS'
        'key:print or delete a public key in a KMS'
        'sign:sign a digest using a KMS-stored key'
        'version:print the step-kms-plugin version'
    )
    _describe -t commands 'step-kms-plugin command' commands
}

_step-kms-plugin "$@"
