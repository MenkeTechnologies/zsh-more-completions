#compdef savvy
# Documentation: https://github.com/getsavvyinc/savvy-cli
# Source: https://github.com/getsavvyinc/savvy-cli/tree/main/cmd
# Reference accessed: 2026-06-01

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _sv_cmds
_sv_cmds=(
    'ask:ask Savvy a question and get a generated command'
    'explain:explain shell commands and functions'
    'login:login to savvy'
    'record:record terminal commands into a runbook'
    'run:run a runbook by ID'
    'sync:sync local copy of Savvy artifacts'
    'upgrade:upgrade savvy to the latest version'
    'version:show CLI version'
    'whoami:show current user info'
    'send:send to the SAVVY_SOCKET_PATH unix socket'
    'write:write a file to the file system'
    'init:output shell setup'
    'help:show help'
)

_arguments -C \
    '(-d --debug)'{-d,--debug}'[enable debug mode]' \
    '(- *)'{-h,--help}'[show help]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'savvy command' _sv_cmds && ret=0
        ;;
    args)
        case $line[1] in
            ask)
                _arguments -s -S \
                    '(-f --file)'{-f+,--file=}'[file to read for context]:file:_files' \
                    '--history[provide historical context to the AI model]' \
                    '*:question:_default' && ret=0
                ;;
            login)
                _arguments -s -S \
                    '(-f --force)'{-f,--force}'[force new login flow]' && ret=0
                ;;
            record)
                _arguments -s -S \
                    '--ignore-errors[ignore commands that return an error]' \
                    '1:subcommand:(history file)' \
                    '*::positional:_default' && ret=0
                ;;
            run)
                _arguments -s -S \
                    '(-l --local)'{-l,--local}'[use locally saved runbooks]' \
                    '1:runbookID:_default' && ret=0
                ;;
            send)
                _arguments -s -S \
                    '--step-id=[step ID]:id:_default' \
                    '--exit-code=[exit code]:n:_default' \
                    '--prompt=[shell prompt while command runs]:prompt:_default' && ret=0
                ;;
            write)
                _arguments -s -S \
                    '--step-id=[step id linked to the file]:id:_default' \
                    '*:file:_files' && ret=0
                ;;
            init)
                _arguments -s -S \
                    '1:shell:(zsh bash dash fish)' && ret=0
                ;;
        esac
        ;;
esac

return ret
