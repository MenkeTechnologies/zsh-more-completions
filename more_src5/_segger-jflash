#compdef segger-jflash JFlash JFlashLite JFlashSPI
# _segger-jflash — SEGGER Microcontroller JFlash and JFlashLite CLI for the SEGGER J-Link flash-programming utility opening loading project file selecting target device interface SWD JTAG connection speed unsecured programming verify (segger team, C++); custom argparse
# upstream: https://www.segger.com/downloads/jlink/

_segger-jflash() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-openprj+[project file]:file:_files -g "*.jflash"' \
        '-open+[file address]:str:' \
        '-device=+[target device]:str:' \
        '-device+[target device]:str:' \
        '-if=+[interface]:i:(SWD JTAG)' \
        '-IF=+[interface]:i:(SWD JTAG)' \
        '-speed=+[Hz]:n:' \
        '-Speed=+[Hz]:n:' \
        '-port=+[port]:n:' \
        '-serial=+[serial]:n:' \
        '-ip=+[host]:h:_hosts' \
        '-erasechip[erase entire chip]' \
        '-erasesectors+[start end]:str:' \
        '-secure[secure target]' \
        '-startapp[start application after programming]' \
        '-jflashfile=+[file]:file:_files -g "*.hex *.bin *.srec *.s19 *.mot"' \
        '-readfile=+[file]:file:_files' \
        '-verify[verify]' \
        '-program[program]' \
        '-autoanswer[auto answer all prompts]' \
        '-norunafterprog[no run after program]' \
        '-jlinkscript=+[file]:file:_files -g "*.JLinkScript"' \
        '-tunnel=+[host]:h:_hosts' \
        '-pin=+[pin]:str:' \
        '*:files:_files -g "*.hex *.bin *.srec *.s19 *.mot *.jflash *.elf *.axf"'
}

_segger-jflash "$@"
