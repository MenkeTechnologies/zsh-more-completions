#compdef replicate-cli replicate cog
# _replicate-cli — Replicate replicate-cli cog CLI command-line frontend wrapping the Replicate cloud platform for running open-source machine learning models inference via Cog containerized Hugging-Face-style image-to-text text-to-image llm whisper-stable-diffusion-stylegan REST API managing predictions models versions training collections runs (Replicate team, Go); cobra
# upstream: https://replicate.com/

_replicate-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'init:initialize a Cog model'
        'predict:run a prediction'
        'build:build a model image'
        'push:push to Replicate'
        'pull:pull a model'
        'run:run a model'
        'serve:serve locally'
        'list:list models'
        'show:show model'
        'create:create a model'
        'delete:delete a model'
        'training:training operations'
        'version:list versions'
        'collection:collection operations'
        'webhook:webhook operations'
        'cog:Cog operations'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-token=+[token]:str:' \
        '--api-url=+[url]:str:' \
        '--user-agent=+[ua]:str:' \
        '--model=+[owner/name]:str:' \
        '--version=+[id]:str:' \
        '--input=+[k=v]:str:' \
        '-i+[input]:str:' \
        '--output=+[file]:file:_files' \
        '-o+[output]:file:_files' \
        '--webhook=+[url]:str:' \
        '--use-cog-config=+[bool]:s:(true false)' \
        '--remote[use remote build]' \
        '--separate-weights[separate weights]' \
        '--gpus=+[N]:n:' \
        '-c+[config file]:file:_files -g "cog.yaml *.yaml *.yml"' \
        '--config=+[file]:file:_files -g "cog.yaml *.yaml *.yml"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'replicate-cli subcommand' sub ;;
        args)
            case $words[1] in
                predict|run|build|push|pull|serve|show|create|delete|version) _arguments '*:model:' ;;
                training) _arguments '1:op:(list show start stop cancel)' '*:id:' ;;
                collection) _arguments '*:slug:' ;;
            esac
            ;;
    esac
}

_replicate-cli "$@"
