#compdef sh2peaks
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/sh2peaks.html
# Source: MRtrix3/mrtrix3 cmd/sh2peaks.cpp — extract FOD peaks from SH-coefficient image (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-num+[number of peaks to extract (default 3)]:peaks:_default' \
    '*-direction+[seed direction (phi theta)]:phi:_default:theta:_default' \
    '-peaks+[image of pre-existing peaks to refine]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-threshold+[amplitude threshold for peaks]:value:_default' \
    '-seeds+[directions text file for seeding]:file:_files' \
    '-mask+[mask image to restrict computation]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-fast[fast non-iterative mode]' \
    '1:SH (input SH image):_files -g "*.{nii,nii.gz,mif}"' \
    '2:output peaks image:_files' \
    && ret=0

return ret
