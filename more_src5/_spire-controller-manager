#compdef spire-controller-manager
# _spire-controller-manager — SPIRE Controller Manager (spiffe/spire-controller-manager)
# upstream: https://github.com/spiffe/spire-controller-manager
# Flags from cmd/main.go + controller-runtime zap.Options on tip.

_spire-controller-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[SPIRE controller-manager YAML config file]:file:_files -g "*.(yml|yaml)(-.)"' \
        '--spire-api-socket=[(deprecated) SPIRE server API socket path]:path:_files' \
        '--expand-env=[expand environment variables in config file]:bool:(true false)' \
        '--zap-devel=[development logging]:bool:(true false)' \
        '--zap-encoder=[log encoder]:fmt:(json console)' \
        '--zap-log-level=[log level]:level:(debug info error)' \
        '--zap-stacktrace-level=[stacktrace threshold]:level:(info error panic)' \
        '--zap-time-encoding=[zap time encoding]:fmt:(epoch millis nano iso8601 rfc3339 rfc3339nano)' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_spire-controller-manager "$@"
