#compdef swift-object-info
# Documentation: https://opendev.org/openstack/swift/raw/branch/master/swift/cli/info.py
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --no-check-etag)'{-n,--no-check-etag}"[don't verify file contents against stored etag]" \
  '(-d --swift-dir)'{-d,--swift-dir=}'[location of swift configuration files]:swift dir:_files -/' \
  '--drop-prefixes[drop per-section common prefixes when outputting metadata]' \
  '(-P --policy-name)'{-P,--policy-name=}'[storage policy name]:name:' \
  '*:object file:_files' && ret=0
return ret
