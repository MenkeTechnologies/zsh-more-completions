#compdef setlock
# Documentation: https://cr.yp.to/daemontools/setlock.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-N)-n[no delay: give up if lock is held]' \
  '(-n)-N[delay until lock is obtainable (default)]' \
  '(-X)-x[exit zero if file cannot be opened/locked]' \
  '(-x)-X[error message and exit nonzero on failure (default)]' \
  '1:lock file:_files' \
  '*::cmd:_command_names' && ret=0

return ret
