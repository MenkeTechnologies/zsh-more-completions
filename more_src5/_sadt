#compdef sadt
# Documentation: https://manpages.debian.org/sadt
# Source: debian/devscripts scripts/sadt — simple DEP-8 autopkgtest runner (Python, argparse).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    {-h,--help}'[show help]' \
    {-v,--verbose}'[verbose output]' \
    '(-b --built-source-tree)'{-b,--built-source-tree}'[treat source tree as already built]' \
    '(--no-run-autodep8)--run-autodep8[run autodep8 (default)]' \
    '(--run-autodep8)--no-run-autodep8[do not run autodep8]' \
    '--ignore-restrictions=-[comma-separated restrictions to ignore]:restrictions:_default' \
    '*:test name:_default' \
    && ret=0

return ret
