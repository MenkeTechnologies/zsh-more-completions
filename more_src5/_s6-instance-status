#compdef s6-instance-status
# _s6-instance-status — s6 instance s6-instance-status (print the supervise state of a single instance: up/wantedup/normallyup/ready/paused/pid/exit/signal/sinceduration; default human format, -o picks fields)
# upstream: https://github.com/skarnet/s6
# Flags from src/instance/s6-instance-status.c on tip.

_s6-instance-status() {
    _arguments \
        '-u[show "up" boolean]' \
        '-w[show "wantedup" boolean]' \
        '-N[show "normallyup" boolean]' \
        '-r[show "ready" boolean]' \
        '-p[show pid]' \
        '-e[show exit code or signal]' \
        '-s[show updown-since timestamp]' \
        '-t[show updown-for elapsed time]' \
        '-n[machine-readable output]' \
        '-o+[comma-separated field list]:fields:_values -s , field up wantedup normallyup ready paused pid exitcode signal signum updownsince readysince updownfor readyfor' \
        '1:service:_files -/' \
        '2:instance-name:'
}

_s6-instance-status "$@"
