#compdef smcat state-machine-cat
# ============================================================================
# smcat / state-machine-cat - state-chart DSL to SVG/DOT/PNG/SCXML/JSON
#                              (Node, MIT)
#
# Author : Sander Verweij (sverweij)
# Upstream: https://github.com/sverweij/state-machine-cat
# npm    : state-machine-cat (binaries: smcat + state-machine-cat)
#
# state-machine-cat ("smcat") compiles a small UML-statechart
# DSL into renderable diagram formats. The grammar (.smcat
# files) describes states, transitions, entry/exit actions,
# notes, history/pseudo-states, and orthogonal regions in a
# ~PlantUML-readable syntax. The compiler emits any of: Graphviz
# DOT (for layout by dot/circo/fdp/neato/osage/twopi), pure
# SVG, PNG/EPS/PDF via the dot toolchain, SCXML (W3C State
# Chart XML), scjson (Sun Microsystems SCJSON), or AST / JSON
# for downstream tooling. Powers state-chart visualizations
# in mermaid-adjacent workflows.
#
# Output format pipeline:
#   smcat (.smcat) ->  peggy-generated parser  ->  AST (JSON)
#   AST  ->  Graphviz DOT or SVG via @hpcc-js/wasm-graphviz
#         OR direct SCXML/scjson emit
#         OR pretty-print back to .smcat (round-trip)
#
# Same package, two binaries: `smcat` is the short form,
# `state-machine-cat` is the full form. Identical behavior.
#
# Flags (Node node:util parseArgs - vanilla, no commander):
#   -T, --output-type <fmt>  - ast/dot/eps/json/oldeps/oldps/oldps2/oldsvg/
#                              pdf/png/ps/ps2/scjson/scxml/smcat/svg (svg default)
#   -I, --input-type <fmt>   - smcat/json/scxml (smcat default)
#   -E, --engine <name>      - dot/circo/fdp/neato/osage/twopi (dot default)
#   -d, --direction <dir>    - top-down/bottom-top/left-right/right-left
#   -o, --output-to <file>   - output destination; - for stdout
#       --desugar            - transform pseudo states into transitions
#                              (experimental)
#   -V, --version            - print version
#   -l, --license            - print license + exit
#   -h, --help               - print help
#
# The peggy lane is built on `peggy ^5.1.0` (declared verbatim
# at upstream package.json HEAD), the canonical Node PEG parser
# generator by Future Imperfect + the peggyjs org (peggyjs/peggy
# on github, 700+ stars). peggy is the actively-maintained fork
# of pegjs (David Majda's 2010 original) after the original was
# archived in 2020. smcat's grammar files (src/parse/smcat-
# parser.peggy + src/cli/attributes-parser.peggy) are compiled
# at build time via `npx peggy` to ES-module parsers that ship
# pre-generated in the published npm package - the standard
# peggy distribution pattern for end-user CLIs (grammar lives
# in the repo, generated parser ships in the tarball).
#
# ----------------------------------------------------------------------------
# AXIS 221 :: PEG (Parsing Expression Grammar) parser generators  [CLOSES]
# Round 1363 :: TS-Node slot 3 of 4 :: CLOSES Axis 221 (214th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : pest-parser/pest             [R1361 _tuliprox]
#   Go      : pointlander/peg              [R1362 _gnparser]
#   TS/Node : peggyjs/peggy                [R1363 THIS FILE]
#
# The three lanes converge on the same Ford (2004) PEG paper
# but diverge sharply in *how the generated parser ships*:
#
#   pest (Rust)   : derive macros - parser is generated by the
#                   Rust macro expansion every cargo build; no
#                   pre-generated file in the source tree
#   peg (Go)      : separate codegen step (`go generate`) emits
#                   a .go file checked into the repo; build-time
#                   no dependency on the peg binary
#   peggy (JS)    : separate codegen step (`npx peggy`) emits
#                   a .mjs/.cjs file shipped in the npm tarball;
#                   end users never need to install peggy
#
# Three different "where does the generated code live" answers
# for the same parser-generation philosophy: in the macro
# system (Rust), checked-in source file (Go), build-output
# tarball (Node). The cross-language structural commentary:
# pest's approach exploits Rust's powerful proc-macro system
# (macros run during compilation, see the syntax tree, emit
# new code) which Go and Node both lack. Go's `go generate`
# approximates this with a separate codegen step but the
# generated file is committed to the repo for reproducibility;
# Node's npm-tarball approach makes the generator a pure
# build-time tool that end users never need.
#
# Use-case mapping: tuliprox (Rust) ships the IPTV filter DSL
# parser as compile-time pest expansion; gnparser (Go) ships
# the scientific-name PEG-generated parser as committed .go
# files; smcat (Node) ships the .smcat statechart-DSL parser
# as a precompiled .mjs in the npm package. Same PEG formalism,
# three different distribution mechanics shaped by their host
# language's compilation model.
# ============================================================================

_smcat() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-T --output-type)'{-T,--output-type}'[output format]:format:(ast dot eps json oldeps oldps oldps2 oldsvg pdf png ps ps2 scjson scxml smcat svg)' \
        '(-I --input-type)'{-I,--input-type}'[input format]:format:(smcat json scxml)' \
        '(-E --engine)'{-E,--engine}'[Graphviz layout engine]:engine:(dot circo fdp neato osage twopi)' \
        '(-d --direction)'{-d,--direction}'[layout direction]:dir:(top-down bottom-top left-right right-left)' \
        '(-o --output-to)'{-o,--output-to}'[output destination (- for stdout)]:file:_files' \
        '--desugar[transform pseudo states into transitions (!experimental!)]' \
        '(- *)'{-V,--version}'[print version]' \
        '(- *)'{-l,--license}'[display license and exit]' \
        '(- *)'{-h,--help}'[display help for command]' \
        '*:input file:_files -g "*.(smcat|json|scxml)"'
}

_smcat "$@"
