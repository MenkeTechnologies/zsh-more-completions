#compdef sealed-secrets-controller
# _sealed-secrets-controller — Bitnami Sealed Secrets controller (bitnami-labs/sealed-secrets)
# upstream: https://github.com/bitnami-labs/sealed-secrets
# Flags from cmd/controller/main.go bindControllerFlags() on tip.

_sealed-secrets-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version information and exit]' \
        '--key-prefix=[sealing-key Secret name prefix]:prefix:' \
        '--key-size=[encryption key size (bits)]:n:' \
        '--key-ttl=[generated cert validity duration]:dur:' \
        '--my-cn=[issuer/subject CN of generated cert]:cn:' \
        '--key-renew-period=[automatic key-rotation period (0 disables)]:dur:' \
        '--key-order-priority=[key ordering basis]:order:(notBefore createdAt)' \
        '--accept-deprecated-v1-data=[accept legacy v1 data field]:bool:(true false)' \
        '--key-cutoff-time=[create new key if newest is older than this (RFC1123)]:t:' \
        '--all-namespaces=[scan all namespaces]:bool:(true false)' \
        '--additional-namespaces=[comma-sep extra namespaces to scan]:list:' \
        '--label-selector=[SealedSecret label selector]:sel:' \
        '--rate-limit=[/v1/verify sustained QPS]:n:' \
        '--rate-limit-burst=[/v1/verify burst]:n:' \
        '--privatekey-annotations=[extra annotations on renewed sealing keys]:list:' \
        '--privatekey-labels=[extra labels on renewed sealing keys]:list:' \
        '--old-gc-behavior=[manual managed-secret deletion (legacy)]:bool:(true false)' \
        '--update-status=[update SealedSecret status sub-resource]:bool:(true false)' \
        '--watch-for-secrets=[watch externally-managed sealing-key Secrets]:bool:(true false)' \
        '--skip-recreate=[skip listening for managed-secret changes]:bool:(true false)' \
        '--log-info-stdout=[log info to stdout (errors/warn to stderr)]:bool:(true false)' \
        '--log-level=[log level]:level:(INFO ERROR)' \
        '--log-format=[log format]:fmt:(text json)' \
        '--max-unseal-retries=[max unseal retries]:n:' \
        '--kubeclient-qps=[Kubernetes client QPS]:f:' \
        '--kubeclient-burst=[Kubernetes client burst]:n:' \
        '--listen-addr=[HTTP server bind host\:port]:host\:port:' \
        '--listen-metrics-addr=[metrics bind host\:port]:host\:port:'
}

_sealed-secrets-controller "$@"
