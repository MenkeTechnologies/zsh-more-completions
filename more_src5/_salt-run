#compdef salt-run
# _salt-run — SaltStack salt-run (execute runner modules locally on the master: jobs.lookup, manage.up, fileserver.update, saltutil.runner, state.event, mine.update; output mirrors salt's --output choices)
# upstream: https://github.com/saltstack/salt (salt/cli/run.py)
# Flags from salt cli/run.py on tip.

_salt-run() {
    _arguments \
        '--version[show version]' \
        '-h[show help]' \
        '-c+[config dir]:dir:_files -/' \
        '-t+[timeout]:seconds:' \
        '--async[fire and forget]' \
        '--skip-grains[skip grains]' \
        '-l+[log level]:level:(all garbage trace debug profile info warning error critical quiet)' \
        '--log-file+[log file]:file:_files' \
        '--output+[output format]:format:(yaml json nested key pprint highstate progress txt)' \
        '--out-indent+[indent level]:n:' \
        '--no-color[disable colors]' \
        '1:runner function:' \
        '*::arg:'
}

_salt-run "$@"
