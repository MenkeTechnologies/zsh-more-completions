#compdef resty
# Documentation: https://github.com/openresty/resty-cli
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-e+[execute inline Lua code]:Lua code' \
  '*-I+[add Lua library search directory]:directory:_directories' \
  '*-l+[require a Lua library]:library:' \
  '-c+[max concurrent connections]:connections:' \
  '--errlog-level=[error log level]:level:(stderr emerg alert crit error warn notice info debug)' \
  '--http-conf=[extra http block snippet]:config:' \
  '--http-include=[file to include in http block]:file:_files' \
  '--main-conf=[extra main block snippet]:config:' \
  '--main-include=[file to include in main block]:file:_files' \
  '--ns=[DNS nameserver IP]:nameserver:' \
  '--resolve-ipv6[enable IPv6 resolver lookups]' \
  '--shdict=[define a shared dict]:NAME SIZE:' \
  '--nginx=[nginx executable path]:path:_files' \
  '-j+[LuaJIT compiler mode]:mode:(on off dump v)' \
  '--no-stream[disable stream configuration block]' \
  '--gdb[run nginx under GDB]' \
  '--gdb-opts=[GDB options]:options:' \
  '--rr[record execution with rr]' \
  '--stap[enable SystemTap tracing]' \
  '--stap-opts=[SystemTap options]:options:' \
  '--user-runner=[custom runner command]:runner:' \
  '--valgrind[run under Valgrind]' \
  '--valgrind-opts=[Valgrind options]:options:' \
  '*:Lua file:_files -g "*.lua"' && ret=0

return ret
