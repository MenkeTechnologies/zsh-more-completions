#compdef sq
# Documentation: https://sq.io/docs/cmd/sq
# Reference accessed: 2026-05-21
# Verified: sq.io official command reference.

# Zsh completion for sq (neilotoole/sq, swiss-army knife for data)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add:add a data source'
  'src:get or set the active data source'
  'group:get or set the active group'
  'ls:list sources and groups'
  'mv:move/rename sources and groups'
  'rm:remove data source or group'
  'inspect:inspect data source schema and stats'
  'ping:ping data sources'
  'sql:execute DB-native SQL'
  'tbl:table actions (copy, truncate, drop)'
  'db:database actions'
  'diff:compare sources or tables (BETA)'
  'driver:manage drivers'
  'config:manage config'
  'cache:manage cache'
  'version:show version info'
  'help:show help'
  'completion:generate shell completions'
)

_arguments -s -S \
  '(-M --monochrome)'{-M,--monochrome}'[disable color output]' \
  '(-v --verbose)'{-v,--verbose}'[print verbose output]' \
  '(-f --format)'{-f+,--format=}'[output format]:format:' \
  '(-t --text)'{-t,--text}'[output text table]' \
  '(-j --json)'{-j,--json}'[output JSON]' \
  '(-A --jsona)'{-A,--jsona}'[output LF-delimited JSON arrays]' \
  '(-J --jsonl)'{-J,--jsonl}'[output LF-delimited JSON objects]' \
  '(-C --csv)'{-C,--csv}'[output CSV]' \
  '--tsv[output TSV]' \
  '--html[output HTML table]' \
  '--markdown[output Markdown]' \
  '(-r --raw)'{-r,--raw}'[output raw bytes]' \
  '(-x --xlsx)'{-x,--xlsx}'[output XLSX]' \
  '--xml[output XML]' \
  '(-y --yaml)'{-y,--yaml}'[output YAML]' \
  '(-h --header)'{-h,--header}'[print header row]' \
  '(-H --no-header)'{-H,--no-header}'[omit header row]' \
  '(-o --output)'{-o+,--output=}'[write output to file]:file:_files' \
  '--src=[override active source]:source:' \
  '--src.schema=[override active schema/catalog]:schema:' \
  '--render-sql[render SLQ to SQL without executing]' \
  '--help[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'sq command' commands && ret=0
    ;;
esac

return ret
