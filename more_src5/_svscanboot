#compdef svscanboot
# _svscanboot — daemontools svscanboot (boot wrapper that clears the environment, sets a sane $PATH, and runs `svscan /service | readproctitle service errors: ...` so failures are visible via ps(1))
# upstream: https://github.com/schmonz/daemontools-encore
# Source: svscanboot.8 on tip; no flags.

_svscanboot() {
    _arguments '(- *)-h[show help]'
}

_svscanboot "$@"
