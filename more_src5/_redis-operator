#compdef redis-operator
# _redis-operator — Spotahome Redis Operator (RedisFailover)
# upstream: https://github.com/spotahome/redis-operator
# Flags from cmd/utils/flags.go on tip.

_redis-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--kubeconfig=[kubeconfig file (dev mode only)]:file:_files' \
        '--supported-namespaces-regex=[regex limiting watched namespaces]:regex:' \
        '--development=[run outside a Kubernetes cluster]:bool:(true false)' \
        '--listen-address=[metrics listen host\:port]:host\:port:' \
        '--metrics-path=[metrics HTTP path]:path:' \
        '--k8s-cli-qps-limit=[K8s client-side QPS]:n:' \
        '--k8s-cli-burstable-limit=[K8s client-side burst]:n:' \
        '--concurrency=[concurrent event workers]:n:' \
        '--log-level=[log level]:level:(debug info warn error)'
}

_redis-operator "$@"
