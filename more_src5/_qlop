#compdef qlop
# Documentation: https://github.com/gentoo/portage-utils
# Source: gentoo/portage-utils qlop.c — emerge.log analyzer (merge timings / history / predictions).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-s --summary)'{-s,--summary}'[summary of average merges (implies -a)]' \
    '(-t --time)'{-t,--time}'[time taken per action]' \
    '(-a --average)'{-a,--average}'[average time taken per action]' \
    '(-p --predict)'{-p,--predict}'[predicted time to completion]' \
    '(-H --human)'{-H,--human}'[human-readable elapsed (with -t or -a)]' \
    '(-M --machine)'{-M,--machine}'[start/elapsed as seconds, no formatting]' \
    '(-m --merge)'{-m,--merge}'[show merge history]' \
    '(-u --unmerge)'{-u,--unmerge}'[show unmerge history]' \
    '(-U --autoclean)'{-U,--autoclean}'[show autoclean unmerge history]' \
    '(-S --sync)'{-S,--sync}'[show sync history]' \
    '(-E --emerge)'{-E,--emerge}'[show last merge like emerge -v]' \
    '(-e --endtime)'{-e,--endtime}'[report end time (vs start)]' \
    '(-r --running)'{-r,--running}'[show currently emerging pkgs]' \
    '*'{-d+,--date=}'[selection time bounds (1st=start, 2nd=end)]:date:_default' \
    '(-l --lastmerge)'{-l,--lastmerge}'[limit to last emerge action]' \
    '(-f --logfile)'{-f+,--logfile=}'[alternate emerge.log]:file:_files' \
    '(-A --atoms)'{-A+,--atoms=}'[read atoms from file]:file:_files' \
    '(-F --format)'{-F+,--format=}'[output format string]:fmt:_default' \
    '*:package atom:_default' \
    && ret=0

return ret
