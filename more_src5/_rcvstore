#compdef rcvstore
# Documentation: man rcvstore(1)
# Source: nmh uip/rcvstore.c (master) — incorporate new mail into an MH folder (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-create -nocreate)-create[create folder if needed (default)]' \
    '(-create -nocreate)-nocreate[do not create folder]' \
    '(-unseen -nounseen)-unseen[add msg to unseen sequence]' \
    '(-unseen -nounseen)-nounseen[do not add to unseen]' \
    '(-public -nopublic)-public[use a public sequence]' \
    '(-public -nopublic)-nopublic[use a private sequence]' \
    '(-zero -nozero)-zero[clear sequence before adding]' \
    '(-zero -nozero)-nozero[do not clear sequence]' \
    '*-sequence+[sequence name]:name:_default' \
    '-version[show version]' \
    '-help[show help]' \
    '1::+folder:_default' \
    && ret=0

return ret
