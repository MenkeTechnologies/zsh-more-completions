#compdef sfcmplx
# Documentation: http://www.ahay.org/RSF/sfcmplx.html
# Source: ahay/src system/main/cmplx.c — make a complex RSF dataset from real + imag parts.
# Reference accessed: 2026-06-10
#
# Usage: sfcmplx real.rsf imag.rsf > cmplx.rsf (no other parameters).

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:real part file:_files -g "*.rsf(-.)"' \
    '2:imaginary part file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
