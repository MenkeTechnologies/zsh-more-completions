#compdef revup
# _revup — stacked pull request workflow tool
# upstream: https://github.com/Skydio/revup

_revup() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '--verbose[verbose output]' \
        '--git-path=[path to git binary]:file:_files' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'upload:upload pull requests for review'
                'amend:amend the current commit'
                'restack:restack dependent branches'
                'cherry-pick:cherry-pick a commit from a PR'
                'toolkit:miscellaneous developer tools'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                upload)
                    _arguments \
                        '--dry-run[show what would be done]' \
                        '--skip-confirm[skip confirmation prompts]' \
                        '--auto-topic[automatically set topic from commit]' \
                        '--rebase[rebase PRs onto latest base]' \
                        '--base-branch=[base branch]:branch:' \
                        '--relative-chain[use relative PR chains]' \
                        '--create-as-draft[create new PRs as drafts]' \
                        '--auto-add-users=[auto-add reviewers]:mode:(r2c a2r)' \
                        '--uploader=[GitHub username]:user:' \
                        '--keep-body[keep existing PR body]' \
                        '(- *)'{-h,--help}'[show help]'
                    ;;
                amend)
                    _arguments \
                        '--all[stage all changes]' \
                        '--no-edit[keep existing commit message]' \
                        '--insert[insert a new commit]' \
                        '--drop[drop the current commit]' \
                        '--patch[interactively select changes]' \
                        '(- *)'{-h,--help}'[show help]'
                    ;;
                restack)
                    _arguments \
                        '--base-branch=[base branch]:branch:' \
                        '(- *)'{-h,--help}'[show help]'
                    ;;
            esac
            ;;
    esac
}

_revup "$@"
