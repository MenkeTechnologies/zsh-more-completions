#compdef racoon
# _racoon — KAME / ipsec-tools racoon (IKEv1 IPsec key exchange daemon paired with setkey(8); -f config file (racoon.conf), -F foreground, -D debug log to stderr, -L log file, -P pidfile, -d debug level, -v verbose, -v print kernel features + exit, -B preserve existing SA on restart, -p pidfile path, -l log file path)
# upstream: https://sourceforge.net/projects/ipsec-tools
# Flags from KAME / ipsec-tools src/racoon/main.c on tip.

_racoon() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-f+[config file]:file:_files -g "*.conf"' \
        '-F[foreground]' \
        '-D[debug to stderr]' \
        '-L+[log file]:file:_files' \
        '-P+[pidfile]:file:_files' \
        '-d+[debug level]:level:' \
        '-v[verbose]' \
        '-B[preserve SAs on restart]' \
        '-p+[pidfile path]:file:_files' \
        '-l+[log file path]:file:_files'
}

_racoon "$@"
