#compdef qrun
# _qrun-pbs — PBS qrun (administrative immediate-execution starter for a PBS job: bypasses the scheduler and runs the job at the next available slot or on a specified node; -H execNode (host[/N]), -a async response, -W extension list; positional jobIDs)
# upstream: https://github.com/openpbs/openpbs
# Flags from openpbs src/cmds/qrun.c on tip.

_qrun-pbs() {
    _arguments \
        '-H+[exec node]:host[/N]:_hosts' \
        '-a[async response]' \
        '-W+[extension list]:list:' \
        '*:jobID:'
}

_qrun-pbs "$@"
