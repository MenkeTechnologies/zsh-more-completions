#compdef rpi-eeprom-update rpi-eeprom-config rpi-eeprom-digest rpi-eeprom-recovery
# _rpi-eeprom-update — Raspberry Pi Foundation rpi-eeprom-update CLI for managing Raspberry Pi 4 bootloader EEPROM firmware updates checking current version applying latest or specific release channels stable beta critical (raspberrypi team, Bash); getopt
# upstream: https://github.com/raspberrypi/rpi-eeprom

_rpi-eeprom-update() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-a[apply]' \
        '--apply[apply]' \
        '-d[show ddiff]' \
        '--diff[show diff]' \
        '-f+[file]:file:_files -g "*.bin pieeprom-*.bin"' \
        '--file=+[file]:file:_files -g "*.bin pieeprom-*.bin"' \
        '-i[ignore-current]' \
        '--ignore[ignore current]' \
        '-j+[json-output]:file:_files' \
        '--json=+[json output]:file:_files' \
        '-l+[release channel]:c:(default critical stable beta latest)' \
        '--channel=+[release channel]:c:(default critical stable beta latest)' \
        '-r+[recovery file]:file:_files -g "recovery.bin"' \
        '-s[stop applying]' \
        '--stop[stop applying]' \
        '-t[skip timestamp]' \
        '--no-timestamp[skip timestamp]' \
        '-u[update]' \
        '--update[update]' \
        '-y[yes confirm]' \
        '--yes[yes confirm]'
}

_rpi-eeprom-update "$@"
