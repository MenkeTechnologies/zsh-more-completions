#compdef rdctl
# Documentation: https://docs.rancherdesktop.io/references/rdctl-command-reference/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for rdctl - Rancher Desktop CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'api:run API endpoints directly'
  'completion:generate autocompletion script for the specified shell'
  'create-profile:generate deployment profile in macOS plist or Windows registry format'
  'extension:manage extensions'
  'help:help about any command'
  'info:return information about Rancher Desktop'
  'list-settings:list current settings'
  'reset:reset Rancher Desktop'
  'set:update selected fields in the Rancher Desktop UI and restart the backend'
  'shell:run an interactive shell or a command in a Rancher Desktop-managed VM'
  'shutdown:shut down running Rancher Desktop application'
  'snapshot:manage Rancher Desktop snapshots'
  'start:start Rancher Desktop or update its settings'
  'version:show CLI version'
)

_arguments -s -S \
  '--verbose[be verbose]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--config-path=[config file path]:file:_files' \
  '--host=[host address (default 127.0.0.1)]:host:' \
  '--password=[override password setting]:password:' \
  '--port=[override port setting]:port:' \
  '--user=[override user setting]:user:' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'rdctl command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      set)
        _arguments \
          '--container-engine.name=[container engine]:engine:(containerd moby)' \
          '--kubernetes.enabled=[enable Kubernetes]:bool:(true false)' \
          '--kubernetes.version=[Kubernetes version]:version:' \
          '--application.path-management-strategy=[PATH strategy]:strategy:(manual rcfiles notset)' \
          '*:setting=value:'
        ;;
      snapshot)
        local -a snap_cmds=(
          'create:create a snapshot'
          'delete:delete a snapshot'
          'list:list snapshots'
          'restore:restore a snapshot'
        )
        _describe -t commands 'snapshot command' snap_cmds && ret=0
        ;;
      shell)
        _arguments '*:command:_command_names -e'
        ;;
    esac
    ;;
esac

return ret
