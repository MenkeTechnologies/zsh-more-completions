#compdef snforge sncast starknet-foundry
# _starknet-foundry — Software Mansion Starknet Foundry snforge testing framework and sncast on-chain interaction CLI for Cairo smart contracts (foundry-rs starknet team, Rust); clap
# upstream: https://github.com/foundry-rs/starknet-foundry

_starknet-foundry() {
    local -a sub=(
        'init:initialize project'
        'new:create new project'
        'test:run tests'
        'check-requirements:check requirements'
        'clean-cache:clean cache'
        'declare:declare contract'
        'deploy:deploy contract'
        'invoke:invoke function'
        'call:call function view'
        'multicall:multicall'
        'account:account operations'
        'tx-status:check tx status'
        'show-config:show config'
        'script:run script'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--accounts-file=+[file]:file:_files -g "*.json"' \
        '--profile=+[profile]:str:' \
        '-p+[profile]:str:' \
        '--url=+[url]:str:' \
        '-u+[url]:str:' \
        '--network=+[net]:n:(mainnet sepolia goerli devnet)' \
        '--keystore=+[file]:file:_files' \
        '-k+[keystore]:file:_files' \
        '--account=+[name]:str:' \
        '-a+[name]:str:' \
        '--max-fee=+[wei]:n:' \
        '--max-gas=+[N]:n:' \
        '--max-gas-unit-price=+[wei]:n:' \
        '--nonce=+[N]:n:' \
        '--wait[wait for tx]' \
        '--wait-timeout=+[s]:n:' \
        '--wait-retry-interval=+[s]:n:' \
        '--hex-format[hex format]' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'starknet-foundry subcommand' sub ;;
        args)
            case $words[1] in
                test) _arguments \
                    '--filter=+[csv]:str:' \
                    '--exact[exact filter]' \
                    '--ignored[run ignored]' \
                    '--include-ignored[include ignored]' \
                    '--detailed-resources[show detailed resources]' \
                    '--rerun-failed[rerun failed]' \
                    '--fuzzer-runs=+[N]:n:' \
                    '--fuzzer-seed=+[N]:n:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell elvish)' ;;
            esac
            ;;
    esac
}

_starknet-foundry "$@"
