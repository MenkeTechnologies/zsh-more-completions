#compdef sntp
# _sntp — ntp-project sntp (Simple Network Time Protocol client; one-shot NTP query/set tool for synchronizing clocks against a list of servers)
# upstream: https://github.com/ntp-project/ntp
# Flags from sntp/sntp-opts.def on tip (AutoOpts).

_sntp() {
    _arguments \
        '(- *)'{-?,--help}'[show help]' \
        '(- *)--version[show version and exit]' \
        '(-4 --ipv4 -6 --ipv6)'{-4,--ipv4}'[force IPv4 DNS resolution]' \
        '(-4 --ipv4 -6 --ipv6)'{-6,--ipv6}'[force IPv6 DNS resolution]' \
        '(-a --authentication)'{-a+,--authentication=}'[enable auth with this key number]:keynum:' \
        '(-b --broadcast)'{-b+,--broadcast=}'[broadcast time sync address]:addr:' \
        '(-c --concurrent)'{-c+,--concurrent=}'[concurrently query all IPs for host-name]:host:' \
        '(-d --debug-level)'{-d+,--debug-level=}'[increment debug level]:n:' \
        '(-g --gap)'{-g+,--gap=}'[gap between requests (ms)]:ms:' \
        '(-K --kod)'{-K+,--kod=}'[KoD history file]:file:_files' \
        '(-k --keyfile)'{-k+,--keyfile=}'[NTP key file for -a]:file:_files' \
        '(-l --logfile)'{-l+,--logfile=}'[log file]:file:_files' \
        '(-M --steplimit)'{-M+,--steplimit=}'[adjustments less than this (ms) are slewed]:ms:' \
        '(-o --ntpversion)'{-o+,--ntpversion=}'[NTP protocol version to send]:n:' \
        '(-r --usereservedport)'{-r,--usereservedport}'[use NTP reserved port (123)]' \
        '(-S --step)'{-S,--step}'[allow stepping the clock via settimeofday(2)]' \
        '(-s --slew)'{-s,--slew}'[allow slewing the clock via adjtime(2)]' \
        '(-t --timeout)'{-t+,--timeout=}'[response wait timeout (sec)]:sec:' \
        '--wait[wait synchronously instead of forking off]' \
        '*:host:_hosts'
}

_sntp "$@"
