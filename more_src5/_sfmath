#compdef sfmath
# Documentation: http://www.ahay.org/RSF/sfmath.html
# Source: ahay/src system/main/math.c — evaluate math expressions on RSF data.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'output=[output mathematical description]: :_default' \
    'type=[output data type]: :(float complex)' \
    'nostdin=[(y/n) ignore stdin]: :(y n)' \
    'label=[data label]: :_default' \
    'label1=[label on 1st axis]: :_default' \
    'label2=[label on 2nd axis]: :_default' \
    'label3=[label on 3rd axis]: :_default' \
    'unit=[data unit]: :_default' \
    'unit1=[unit on 1st axis]: :_default' \
    'unit2=[unit on 2nd axis]: :_default' \
    'unit3=[unit on 3rd axis]: :_default' \
    'n1=[size of 1st axis]: :_default' \
    'n2=[size of 2nd axis]: :_default' \
    'n3=[size of 3rd axis]: :_default' \
    'd1=[sampling, 1st axis]: :_default' \
    'd2=[sampling, 2nd axis]: :_default' \
    'o1=[origin, 1st axis]: :_default' \
    'o2=[origin, 2nd axis]: :_default' \
    '*:RSF file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
