#compdef rofi-cli
# _rofi-cli — Rofi window switcher/run dialog/dmenu replacement CLI alias (DaveDavenport / Sardem FF7, C); custom argparse
# upstream: https://github.com/davatorium/rofi

_rofi-cli() {
    _arguments \
        '--help[show help]' \
        '-help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-modes[print available modes]' \
        '-modi[print available modes (legacy)]' \
        '-list-themes[list themes]' \
        '-dump-theme[dump current theme]' \
        '-dump-config[dump config]' \
        '-show=+[show mode]:m:(run drun window ssh combi keys filebrowser script emoji calc)' \
        '-modi=+[modi enabled]:list:' \
        '-modes=+[modes enabled]:list:' \
        '-theme=+[theme file]:file:_files -g "*.rasi"' \
        '-theme-str=+[theme string]:str:' \
        '-config=+[config file]:file:_files -g "*.rasi *.conf"' \
        '-no-config[no config file]' \
        '-quiet[quiet]' \
        '-i[case insensitive]' \
        '-no-case-sensitive[no case sensitive]' \
        '-matching=+[matching method]:m:(normal regex glob fuzzy prefix)' \
        '-matching-negate-char=+[negate char]:str:' \
        '-tokenize[tokenize input]' \
        '-no-tokenize[no tokenize]' \
        '-monitor=+[monitor]:n:' \
        '-m+[monitor]:n:' \
        '-location=+[location]:n:' \
        '-yoffset=+[y offset]:n:' \
        '-xoffset=+[x offset]:n:' \
        '-no-cycle[no cycle]' \
        '-cycle[cycle]' \
        '-only-match[only match]' \
        '-allow-images[allow images]' \
        '-show-icons[show icons]' \
        '-no-show-icons[no show icons]' \
        '-icon-theme=+[icon theme]:str:' \
        '-icon-cache-dir=+[icon cache dir]:dir:_files -/' \
        '-eh=+[entries height]:n:' \
        '-window-thumbnail[window thumbnail]' \
        '-window-format=+[window format]:str:' \
        '-window-command=+[window command]:str:' \
        '-window-match-fields=+[window match fields]:list:' \
        '-window-mode-default-format=+[window mode default format]:str:' \
        '-window-mode-no-history[window mode no history]' \
        '-no-window-thumbnail[no window thumbnail]' \
        '-display-window=+[display window label]:str:' \
        '-display-windowcd=+[display windowcd label]:str:' \
        '-display-run=+[display run label]:str:' \
        '-display-drun=+[display drun label]:str:' \
        '-display-ssh=+[display ssh label]:str:' \
        '-display-combi=+[display combi label]:str:' \
        '-display-keys=+[display keys label]:str:' \
        '-display-emoji=+[display emoji label]:str:' \
        '-display-calc=+[display calc label]:str:' \
        '-display-filebrowser=+[display filebrowser label]:str:' \
        '-replace[replace running rofi]' \
        '-no-replace[no replace]' \
        '-normal-window[normal window]' \
        '-fullscreen[fullscreen]' \
        '-no-fullscreen[no fullscreen]' \
        '-padding=+[padding]:n:' \
        '-bw=+[border width]:n:' \
        '-width=+[width]:n:' \
        '-lines=+[lines]:n:' \
        '-columns=+[columns]:n:' \
        '-font=+[font]:str:' \
        '-no-fixed-num-lines[no fixed num lines]' \
        '-fixed-num-lines[fixed num lines]' \
        '-no-lazy-grab[no lazy grab]' \
        '-lazy-grab[lazy grab]' \
        '-p+[prompt]:str:' \
        '-prompt=+[prompt]:str:' \
        '-mesg=+[mesg]:str:' \
        '-format=+[format]:fmt:(s i d q f F)' \
        '-filter=+[filter]:str:' \
        '-input=+[input file]:file:_files' \
        '-dmenu[dmenu mode]' \
        '-no-custom[no custom input]' \
        '-only-match-prefix[only match prefix]' \
        '-multi-select[multi select]' \
        '-no-multi-select[no multi select]' \
        '-markup-rows[markup rows]' \
        '-no-markup-rows[no markup rows]' \
        '-show-match[show match]' \
        '-async-pre-read=+[async pre-read]:n:' \
        '-sync[sync]' \
        '-keep-right[keep right]' \
        '-no-keep-right[no keep right]' \
        '-selected-row=+[selected row]:n:' \
        '-tab-stops=+[tab stops]:str:' \
        '-define-modi=+[define modi]:str:' \
        '-define-modes=+[define modes]:str:' \
        '-l+[lines]:n:' \
        '-pretty[pretty]' \
        '-content-length-bytes-max[content length bytes max]' \
        '*:arg:'
}

_rofi-cli "$@"
