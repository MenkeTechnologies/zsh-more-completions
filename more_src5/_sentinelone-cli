#compdef sentinelone-cli s1ctl sentinelone
# _sentinelone-cli — SentinelOne sentinelone-cli CLI command-line frontend wrapping the SentinelOne Singularity autonomous endpoint protection XDR cloud-workload-protection IoT-discovery identity-threat-detection cybersecurity platform CLI providing login logout whoami agent group site account threat alert hash hash-blacklist hash-whitelist scope vulnerability application-management deep-visibility-query DV-query device-control firewall-control file-fetch storyline RemoteOps (SentinelOne team Tomer Weingarten, Go); cobra
# upstream: https://www.sentinelone.com/

_sentinelone-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'agent:agent operations'
        'group:group operations'
        'site:site operations'
        'account:account operations'
        'threat:threat operations'
        'alert:alert operations'
        'hash:hash operations'
        'blacklist:blacklist operations'
        'whitelist:whitelist operations'
        'exclusion:exclusion operations'
        'scope:scope operations'
        'vulnerability:vulnerability operations'
        'application:application management operations'
        'deep-visibility:deep visibility query operations'
        'device-control:device control operations'
        'firewall-control:firewall control operations'
        'file-fetch:file fetch operations'
        'storyline:storyline operations'
        'remote-ops:RemoteOps operations'
        'user:user operations'
        'role:role operations'
        'token:token operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-token=+[token]:str:' \
        '--api-url=+[url]:str:' \
        '--mgmt-url=+[url]:str:' \
        '--account-id=+[id]:str:' \
        '--site-id=+[id]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table csv)' \
        '--output=+[format]:f:(json yaml table csv)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 's1 subcommand' sub ;;
        args)
            case $words[1] in
                agent|group|site|account|threat|alert|hash|blacklist|whitelist|exclusion|scope|vulnerability|application|deep-visibility|device-control|firewall-control|file-fetch|storyline|user|role|token) _arguments '1:op:(list get create update delete enable disable disconnect connect quarantine unquarantine mark-as-benign mark-as-threat)' '*:id:' ;;
                remote-ops) _arguments '1:op:(run script abort list-scripts)' '*:arg:' ;;
            esac
            ;;
    esac
}

_sentinelone-cli "$@"
