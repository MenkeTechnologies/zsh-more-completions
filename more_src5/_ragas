#compdef ragas
# Documentation: https://github.com/explodinggradients/ragas
# Reference accessed: 2026-05-22
# Verified: src/ragas/cli.py Typer commands.

# Zsh completion for ragas - RAG evaluation framework CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'ragas command' \
      'evals[run Ragas evaluations]' \
      'quickstart[Ragas quickstart]' \
      'hello_world[hello world example]' && ret=0
    ;;
esac

return ret
