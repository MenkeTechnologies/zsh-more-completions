#compdef swift-account-info
# Documentation: https://manpages.debian.org/testing/swift-account/swift-account-info.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# swift-account-info: inspect an OpenStack Swift account DB

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(-d --swift-dir)'{-d,--swift-dir=}'[location of swift configuration]:dir:_files -/' \
  '*:account db file:_files' && ret=0
return ret
