#compdef swanky
# ============================================================================
# swanky - ink! / Substrate smart-contract dev environment (Node, MIT)
#
# Author : Ink! Dev Hub / Astar Network
# Upstream: https://github.com/inkdevhub/swanky-cli
# npm    : @astar-network/swanky-cli
#
# swanky is the all-in-one developer toolkit for building, testing,
# and deploying smart contracts on Polkadot ecosystem chains using
# the ink! framework. Subcommand surface:
#
#   init               - scaffold a new contract project
#   contract compile   - cargo-contract-driven build with metadata
#   contract deploy    - deploy compiled bundle to a chain
#   contract query     - call a read-only ink! method
#   contract tx        - submit an extrinsic to a contract method
#   contract test      - run E2E + integration tests
#   contract new       - generate a contract from template
#   contract verify    - verify on-chain bytecode matches local
#   contract explain   - human-readable contract metadata
#   account create / balance / faucet / default / list
#   env check / install (sets up rust + cargo-contract toolchain)
#   generate tests / types (codegen from contract ABI)
#   node start / install / purge / version
#   node chopsticks    - fork mainnet for local testing
#   zombienet init / start
#   clear              - clean cache
#
# The TOML lane is built on `@iarna/toml 2.2.5` (declared verbatim
# at upstream package.json HEAD), the canonical Node TOML library
# by Rebecca Turner (iarna, github.com/iarna/iarna-toml, 340+
# stars). The library is a pure-JavaScript TOML 1.0.0 parser +
# stringifier with full spec coverage: `TOML.parse(str)` for
# decoding, `TOML.stringify(obj)` for encoding, async streaming
# variants (`TOML.parse.async` / `TOML.parse.stream`), and the
# `TOML.Section` + `TOML.parsers` low-level builder APIs. It is
# the dependency-of-record for the Node + TypeScript ecosystem
# when TOML parsing is needed - npm packages, Eleventy site
# config, CycloneDX SBOM tools, Rust-toolchain wrappers like
# swanky here.
#
# swanky stores its project configuration in `swanky.config.json`
# (with @iarna/toml used to also parse companion Rust workspace
# `Cargo.toml` files at the contract crate's level - that's the
# load-bearing TOML use case for the CLI).
#
# ----------------------------------------------------------------------------
# AXIS 211 :: TOML 1.0.0 PARSING + EMISSION  [CLOSES]
# Round 1333 :: TS-Node slot 3 of 4 :: CLOSES Axis 211 (204th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : toml-rs/toml             [R1331 _tokf]
#   Go      : BurntSushi/toml          [R1332 _faq]
#   TS/Node : iarna/iarna-toml         [R1333 THIS FILE]
#
# All three canonical libraries pass the same upstream
# `toml-test` interoperability corpus, which BurntSushi himself
# maintains - one of the rare cross-language axes where the
# canonical Go author also owns the language-agnostic conformance
# test suite that the canonical libraries in other languages
# must pass to claim conformance.
# ============================================================================

_swanky() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :_swanky_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                init)     _arguments '(- *)'{-h,--help}'[help]' '1:project name:' ;;
                contract) _swanky_contract ;;
                account)  _swanky_account ;;
                env)      _arguments '(- *)'{-h,--help}'[help]' '1:subcommand:(check install)' ;;
                generate) _arguments '(- *)'{-h,--help}'[help]' '1:subcommand:(tests types)' ;;
                node)     _swanky_node ;;
                zombienet) _arguments '(- *)'{-h,--help}'[help]' '1:subcommand:(init start)' ;;
                clear)    _arguments '(- *)'{-h,--help}'[help]' ;;
                help)     _swanky_cmds ;;
            esac
            ;;
    esac

    return ret
}

_swanky_cmds() {
    local -a cmds
    cmds=(
        'init:Scaffold a new Swanky / ink! project'
        'contract:Manage ink! smart contracts (compile/deploy/query/tx/test/new/verify/explain)'
        'account:Manage development accounts (balance/create/default/faucet/list)'
        'env:Manage Rust + cargo-contract toolchain (check/install)'
        'generate:Codegen helpers (tests, TypeScript types from ABI)'
        'node:Manage the local Substrate node (start/install/purge/version/chopsticks)'
        'zombienet:Multi-node test net (init/start)'
        'clear:Clear caches'
    )
    _describe -t commands 'swanky command' cmds
}

_swanky_contract() {
    _arguments \
        '(- *)'{-h,--help}'[help]' \
        '1:subcommand:(compile deploy query tx test new verify explain)' \
        '*::arg:->_default'
}

_swanky_account() {
    _arguments \
        '(- *)'{-h,--help}'[help]' \
        '1:subcommand:(create balance default faucet list)' \
        '*::arg:->_default'
}

_swanky_node() {
    _arguments \
        '(- *)'{-h,--help}'[help]' \
        '1:subcommand:(start install purge version chopsticks)' \
        '*::arg:->_default'
}

_swanky "$@"
