#compdef qvidcap
# _qvidcap — Linux v4l-utils qvidcap CLI for the Qt-based Video4Linux2 capture display utility showing live preview from /dev/video* devices with format selection field-rate frame-buffer overlay raw display window scaling (linuxtv team, C++/Qt); Qt argparse
# upstream: https://git.linuxtv.org/v4l-utils.git

_qvidcap() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-d+[device]:file:_files -g "/dev/video*"' \
        '--device=+[device]:file:_files -g "/dev/video*"' \
        '-D+[subdev device]:file:_files -g "/dev/v4l-subdev*"' \
        '--subdev=+[subdev device]:file:_files -g "/dev/v4l-subdev*"' \
        '-M+[media-device]:file:_files -g "/dev/media*"' \
        '--media=+[media-device]:file:_files -g "/dev/media*"' \
        '-f+[file input]:file:_files -g "*.raw *.yuv *.rgb *.bgr"' \
        '--file=+[file input]:file:_files -g "*.raw *.yuv *.rgb *.bgr"' \
        '-w+[width]:n:' \
        '--width=+[width]:n:' \
        '-H+[height]:n:' \
        '--height=+[height]:n:' \
        '-x+[pixelformat 4cc]:str:' \
        '--pixelformat=+[pixelformat 4cc]:str:' \
        '-c+[chroma-format]:c:(yuv422 yuv420 yuv444 grey)' \
        '--colorspace=+[c]:c:(default smpte170m rec709 srgb adobergb bt2020 dcip3 jpeg)' \
        '--xfer-func=+[t]:t:(default 709 sRGB Adobe DCI smpte2084 hlg)' \
        '--ycbcr-enc=+[e]:e:(default 601 709 xv601 xv709 sycc 2020 smpte240m)' \
        '--quantization=+[q]:q:(default full limited)' \
        '-F+[field-mode]:m:(none top bottom interlaced seq_tb seq_bt alternate)' \
        '-r+[fps]:f:' \
        '--rate=+[fps]:f:' \
        '-O[only output frames]' \
        '--overlay[overlay]' \
        '--no-color-bar[no color bar]' \
        '--single-buffer[single buffer]' \
        '--win-pos=+[x,y]:str:' \
        '--win-size=+[w,h]:str:' \
        '--fullscreen[fullscreen]' \
        '-z[zoom 2x]' \
        '--zoom=+[F]:f:'
}

_qvidcap "$@"
