#compdef sftransp
# Documentation: http://www.ahay.org/RSF/sftransp.html
# Source: ahay/src system/main/transp.c — transpose two axes of an RSF dataset.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'plane=[two-digit code naming the axes to swap (default 12)]: :_default' \
    'memsize=[max RAM (MB)]: :_default' \
    '*:RSF file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
