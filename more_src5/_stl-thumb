        '-x[display in a window instead of saving]' \
        '*-v[increase verbosity (repeatable)]' \
        '(-m --material)'{-m,--material}'=[Phong material colors (ambient diffuse specular)]:material:' \
        '(-b --background)'{-b,--background}'=[background RGBA hex (default ffffff00)]:rgba:' \
        '(-a --antialiasing)'{-a,--antialiasing}'=[anti-aliasing method]:method:(none fxaa)' \
        '--recalc-normals[force recalculation of face normals]' \
        '1:model file (STL/OBJ/3MF, or - for stdin):_files -g "*.(stl|obj|3mf|STL|OBJ|3MF)"' \
        '2:output image file (or - for stdout):_files -g "*.(png|jpg|jpeg|gif|ico|bmp)"'
