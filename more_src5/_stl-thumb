    _arguments -s -S \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-f --format)'{-f,--format}'=[image format]:fmt:(PNG JPEG GIF ICO BMP)' \
