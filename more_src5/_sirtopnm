#compdef sirtopnm
# Documentation: man sirtopnm (Netpbm)
# Source: convert a Solitaire (SIR) image file to PNM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:sir file:_files' \
    && ret=0

return ret
