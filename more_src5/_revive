#compdef revive
# Documentation: https://github.com/mgechev/revive
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for revive - fast Go linter.

_arguments -s -S \
  '-config[config file]:file:_files' \
  '*-exclude[exclude pattern]:pattern:' \
  '-formatter[output formatter]:formatter:(default friendly json ndjson stylish checkstyle sarif unix)' \
  '-max_open_files[max concurrent open files]:number:' \
  '-set_exit_status[exit 1 if any issue found]' \
  '-version[show version]' \
  '*:package:_files -/' && return 0
