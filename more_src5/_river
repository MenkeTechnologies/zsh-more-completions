#compdef river riverwm
# Documentation: https://man.archlinux.org/man/river.1.en
# Reference accessed: 2026-05-16
# Verified: Arch river(1) manpage. Single-dash long flags (Zig argparse style).

# river: dynamic wlroots tiling Wayland compositor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-version[print version and exit]' \
  '-c[override init executable via /bin/sh -c]:shell command:' \
  '-log-level[log level]:level:(error warning info debug)' \
  '-no-xwayland[disable Xwayland at runtime]' && ret=0
return ret
