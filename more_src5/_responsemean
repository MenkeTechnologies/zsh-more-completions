#compdef responsemean
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/responsemean.html
# Source: MRtrix3/mrtrix3 bin/responsemean — average response functions across subjects (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-legacy[use legacy average_response behaviour]' \
    '*:inputs (response txt files) and output:_files -g "*.txt"' \
    && ret=0

return ret
