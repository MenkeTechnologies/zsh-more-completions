#compdef register-gen
# _register-gen — Kubernetes API zz_generated.register.go generator (kubernetes/code-generator)
# upstream: https://github.com/kubernetes/code-generator
# Flags from cmd/register-gen/args/args.go on tip.

_register-gen() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--output-file=[generated register file basename]:file:_files' \
        '--go-header-file=[Go header file prepended to generated files]:file:_files' \
        '-v[klog verbosity level]:n:' \
        '*:input-package:'
}

_register-gen "$@"
