#compdef strip-tags

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-m --minify)'{-m,--minify}'[minify output]' \
  '(-s --selectors)'{-s,--selectors}'[CSS selectors to extract]:selectors:' \
  '(-k --keep-tags)'{-k,--keep-tags}'[tags to keep]:tags:' \
  '(-r --remove-tags)'{-r,--remove-tags}'[tags to remove]:tags:' \
  '--version[show version]' \
  '--help[show help message]' \
  '*:file:_files' && ret=0

return ret
