#compdef slogin
# _slogin — OpenSSH slogin (legacy alias of ssh(1) - opens an interactive SSH session; flag surface is identical to ssh, kept for compat with old rlogin scripts)
# upstream: https://github.com/openssh/openssh-portable
# Aliased to ssh per openssh-portable Makefile.in on tip.

_slogin() {
    _arguments \
        '-4[IPv4 only]' \
        '-6[IPv6 only]' \
        '-A[forward authentication agent]' \
        '-a[disable agent forwarding]' \
        '-C[compress]' \
        '-f[background after auth]' \
        '-G[print config and exit]' \
        '-g[allow remote ports to bind any]' \
        '-K[use GSSAPI auth]' \
        '-k[disable GSSAPI forwarding]' \
        '-M[master mode for connection sharing]' \
        '-N[no command exec]' \
        '-n[redirect stdin from /dev/null]' \
        '-q[quiet]' \
        '-s[invoke subsystem]' \
        '-T[disable pseudo-tty]' \
        '-t[force pseudo-tty]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-x[disable X11 forwarding]' \
        '-X[enable X11 forwarding]' \
        '-Y[trusted X11 forwarding]' \
        '-y[log via syslog]' \
        '-b+[bind address]:bind:' \
        '-B+[bind interface]:if:_net_interfaces' \
        '-c+[cipher]:cipher:' \
        '-D+[dynamic SOCKS forward]:[bind:]port:' \
        '-E+[log file]:file:_files' \
        '-e+[escape char]:char:' \
        '-F+[config file]:file:_files' \
        '-I+[pkcs11 provider]:provider:' \
        '-i+[identity file]:file:_files' \
        '-J+[jump host]:user@host:_hosts' \
        '-L+[local forward]:[bind:]port:host:hostport:' \
        '-l+[user]:user:_users' \
        '-m+[MAC]:mac:' \
        '-O+[control command]:cmd:(check exit forward cancel stop)' \
        '*-o+[ssh option]:option:' \
        '-p+[port]:port:' \
        '-Q+[query]:query:(cipher cipher-auth compression hostkeyalg hostbasedkeyalg key key-cert key-cert-name kex mac protocol-version sig)' \
        '-R+[remote forward]:[bind:]port:host:hostport:' \
        '-S+[control path]:file:_files' \
        '-W+[host:port]:host:port:' \
        '-w+[tunnel]:tunnel:' \
        '1:host:_hosts' \
        '*::command:_command_names -e'
}

_slogin "$@"
