#compdef sweep-cli
# Documentation: https://github.com/sweepai/sweep
# Reference accessed: 2026-05-23
# Verified: sweepai PyPI CLI (console script sweepai); see _sweepai.

# Zsh completion for sweep-cli - Sweep AI coding assistant (alternate binary name)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'sweep-cli command' \
      'init[initialize Sweep CLI config]' \
      'run[run Sweep on GitHub issue URL]' \
      'watch[watch repository events]' \
      'test[test Sweep configuration]' && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments '--override[override existing config]' && ret=0
        ;;
      run)
        _arguments '1:GitHub issue URL:' && ret=0
        ;;
    esac
    ;;
esac

return ret
