#compdef rox rox-filer
# Documentation: https://manpages.debian.org/bookworm/rox-filer/rox.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream Debian rox(1) manpage. Removed bogus flags from
# prior file: -N/--no-session, -o/--override (not in manpage),
# --close (-D takes a DIR arg). Added real: -b/--border, -c/--client-id,
# -m/--mime-type, -S/--rox-session, -u/--user, -U/--url.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-b --border)'{-b,--border=}'[open panel]:panel' \
  '(-B --bottom)'{-B,--bottom=}'[open panel at bottom]:panel' \
  '(-c --client-id)'{-c,--client-id=}'[session manager client ID]:id' \
  '(-d --dir)'{-d,--dir}'[treat args as dirs]' \
  '(-D --close)'{-D,--close=}'[close window for dir]:dir:_files -/' \
  '(-l --left)'{-l,--left=}'[open panel at left]:panel' \
  '(-m --mime-type)'{-m,--mime-type=}'[print MIME type of file]:file:_files' \
  '(-n --new)'{-n,--new}'[force new instance]' \
  '(-p --pinboard)'{-p,--pinboard=}'[use named pinboard]:name' \
  '(-r --right)'{-r,--right=}'[open panel at right]:panel' \
  '(-R --RPC)'{-R,--RPC}'[read and invoke SOAP RPC from stdin]' \
  '(-s --show)'{-s,--show=}'[show file in parent]:file:_files' \
  '(-S --rox-session)'{-S,--rox-session}'[run as session manager]' \
  '(-t --top)'{-t,--top=}'[open panel at top]:panel' \
  '(-u --user)'{-u,--user}'[display user in each window]' \
  '(-U --url)'{-U,--url=}'[run URI as file or directory]:uri' \
  '(-x --examine)'{-x,--examine=}'[re-examine changed file]:file:_files' \
  '*:path:_files' && ret=0

return ret
