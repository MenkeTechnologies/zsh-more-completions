#compdef refmt
# Documentation: https://reasonml.github.io/docs/en/refmt
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Added --heuristics-file (verified in upstream help). Kept
# --use-stdin and --is-interface-pp (documented in upstream issues).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--parse=[input syntax]:syntax:(re ml binary binary_reason)' \
  '--print=[output syntax]:syntax:(re ml ast binary binary_reason none)' \
  '--interface=[parse AST as an interface]:bool:(true false)' \
  '--use-stdin=[read source from stdin]:bool:(true false)' \
  '--is-interface-pp=[treat stdin as interface for preprocessor]:bool:(true false)' \
  '--recoverable[enable recoverable parser]' \
  '--assume-explicit-arity[treat tuple constructor arg as multiple arguments]' \
  '--in-place[reformat file in-place]' \
  '--print-width=[wrapping width for printing the AST]:cols:' \
  '--heuristics-file=[heuristics file specifying tuple constructors]:file:_files' \
  '*:file:_files' && ret=0

return ret
