#compdef s6-log
# Documentation: https://skarnet.org/software/s6/s6-log.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-d+[readiness notification fd]:fd' \
  '-q[decrease verbosity]' \
  '-v[increase verbosity]' \
  '-b[blocking mode]' \
  '-p[protect against SIGTERM]' \
  '-l+[max line length in bytes]:linelimit' \
  '-t+[wait ms for partial line on termination]:lastlinetimeout' \
  '*:logging script:' && ret=0

return ret
