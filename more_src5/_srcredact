#compdef srcredact
# Documentation: srcredact -h (TeX Live 2026)
# Source: extract redacted versions of a source file (by audience guards), or merge them back.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[print help]' \
    '(- *)-v[print version]' \
    '(-e -u -l)-l[list audiences set in the file]' \
    '(-e -u -l)-e+[extract contents for AUDIENCE]:audience:' \
    '(-e -u -l)-u+[unextract: merge redacted file back into full file]:audience:' \
    '-c+[list of comment patterns]:patterns:(TeX c cpp fortran shell)' \
    '-d[debug mode on]' \
    '-w+[implicitly wrap full document in ALL guards]:value:(on off 1 0 true false)' \
    '*:source file:_files' \
    && ret=0

return ret
