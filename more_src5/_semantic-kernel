#compdef sk semantic-kernel
# _semantic-kernel — Microsoft sk Semantic Kernel CLI for managing skills planners and prompts in the Semantic Kernel SDK (microsoft team, .NET); System.CommandLine
# upstream: https://github.com/microsoft/semantic-kernel

_semantic-kernel() {
    local -a sub=(
        'init:initialize a new skill or project'
        'create:create skill or function'
        'list:list skills functions or planners'
        'run:run a skill function'
        'invoke:invoke a function'
        'plan:create a plan from goal'
        'execute:execute a plan'
        'config:configuration subcommands'
        'auth:authentication subcommands'
        'sk-server:start kernel server'
        'connect:connect to a deployed kernel'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--service=+[service]:s:(OpenAI AzureOpenAI HuggingFace Ollama Anthropic Mistral GoogleAI)' \
        '--model=+[model id]:str:' \
        '--api-key=+[API key]:str:' \
        '--endpoint=+[endpoint]:url:_urls' \
        '--deployment-name=+[deployment name]:str:' \
        '--max-tokens=+[N]:n:' \
        '--temperature=+[F]:f:' \
        '--config=+[config file]:file:_files -g "*.json *.yaml *.yml"' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'semantic-kernel subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '--type=+[type]:t:(skill function planner prompt connector memory)' \
                    '--name=+[name]:str:' \
                    '--description=+[description]:str:' \
                    '--template=+[template]:str:' ;;
                list) _arguments \
                    '--type=+[type]:t:(skills functions planners prompts connectors plugins)' ;;
                run|invoke) _arguments \
                    '--skill=+[skill]:str:' \
                    '--function=+[function]:str:' \
                    '--input=+[input]:str:' ;;
                plan) _arguments \
                    '--goal=+[goal]:str:' \
                    '--planner=+[planner]:p:(sequential action handlebars stepwise)' \
                    '--max-iterations=+[N]:n:' ;;
                config) _arguments '1:config cmd:(get set unset list)' ;;
                auth) _arguments '1:auth cmd:(login logout status)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_semantic-kernel "$@"
