#compdef storybook-cli
# _storybook-cli — Storybook UI component dev environment CLI alias (Storybook team, TypeScript); commander
# upstream: https://github.com/storybookjs/storybook

_storybook-cli() {
    local -a sub=(
        'dev:start dev server'
        'build:build static storybook'
        'init:add storybook to project'
        'add:add an addon'
        'remove:remove an addon'
        'upgrade:upgrade storybook'
        'migrate:run codemods'
        'sandbox:create sandbox project'
        'link:link storybook'
        'doctor:diagnose installation'
        'info:show env info'
        'install:install dependencies'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--disable-telemetry[disable telemetry]' \
        '--debug-webpack[debug webpack]' \
        '--webpack-stats-json[webpack stats json]' \
        '--no-manager-cache[no manager cache]' \
        '--quiet[quiet]' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'storybook subcommand' sub ;;
        args)
            case $words[1] in
                dev) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--host=+[host]:host:_hosts' \
                    '-h+[host]:host:_hosts' \
                    '--config-dir=+[config dir]:dir:_files -/' \
                    '-c+[config dir]:dir:_files -/' \
                    '--https[https]' \
                    '--ssl-ca=+[ssl ca]:file:_files' \
                    '--ssl-cert=+[ssl cert]:file:_files' \
                    '--ssl-key=+[ssl key]:file:_files' \
                    '--smoke-test[smoke test]' \
                    '--ci[CI mode]' \
                    '--no-open[no open browser]' \
                    '--loglevel=+[log level]:level:(silent error warn info verbose silly)' \
                    '--quiet[quiet]' \
                    '--no-version-updates[no version updates]' \
                    '--no-release-notes[no release notes]' \
                    '--debug[debug]' \
                    '--initial-path=+[initial path]:str:' \
                    '--exact-port[exact port]' ;;
                build) _arguments \
                    '--output-dir=+[output dir]:dir:_files -/' \
                    '-o+[output dir]:dir:_files -/' \
                    '--config-dir=+[config dir]:dir:_files -/' \
                    '-c+[config dir]:dir:_files -/' \
                    '--quiet[quiet]' \
                    '--loglevel=+[log level]:level:(silent error warn info verbose silly)' \
                    '--preview-url=+[preview url]:url:_urls' \
                    '--force-build-preview[force build preview]' \
                    '--docs[docs]' \
                    '--test[test mode]' \
                    '--stats-json[stats json]' \
                    '--debug-webpack[debug webpack]' ;;
                init) _arguments \
                    '--type=+[project type]:str:' \
                    '-t+[project type]:str:' \
                    '--features=+[features]:list:' \
                    '-f+[features]:list:' \
                    '--package-manager=+[package manager]:pm:(npm pnpm yarn yarn2 yarn3 bun)' \
                    '--skip-install[skip install]' \
                    '-s[skip install]' \
                    '--use-pnp[use pnp]' \
                    '--yes[yes]' \
                    '-y[yes]' \
                    '--dev[dev mode]' ;;
                add|remove) _arguments \
                    '--config-dir=+[config dir]:dir:_files -/' \
                    '-c+[config dir]:dir:_files -/' \
                    '--package-manager=+[package manager]:pm:(npm pnpm yarn yarn2 yarn3 bun)' \
                    '--skip-postinstall[skip postinstall]' \
                    '--skip-install[skip install]' \
                    '*:addon:' ;;
                upgrade) _arguments \
                    '--skip-check[skip check]' \
                    '--package-manager=+[package manager]:pm:(npm pnpm yarn yarn2 yarn3 bun)' \
                    '--dry-run[dry run]' \
                    '-Y[automatically apply migrations]' \
                    '--yes[yes]' ;;
                migrate) _arguments \
                    '1:codemod:' \
                    '--glob=+[glob]:str:' \
                    '-g+[glob]:str:' \
                    '--dry-run[dry run]' \
                    '-D[dry run]' \
                    '--list[list codemods]' \
                    '-l[list codemods]' \
                    '--rename=+[rename]:str:' \
                    '-r+[rename]:str:' \
                    '--parser=+[parser]:p:(babel babylon flow ts tsx)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_storybook-cli "$@"
