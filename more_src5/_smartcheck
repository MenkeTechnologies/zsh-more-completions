#compdef smartcheck
# _smartcheck — Deep Security smartcheck / Trend Micro Cloud One Image Scanner CLI (registry-aware container image scanner producing JSON / CycloneDX SBOM reports; --endpoint scanner URL, --user user, --password password, --insecure skip TLS, --threshold critical|high|medium|low, --debug, --version, --help; positional argument is the image reference (registry/repo:tag))
# upstream: https://github.com/deep-security/smartcheck-scan-action
# Common flag shape from deep-security/smartcheck-cli on tip.

_smartcheck() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--endpoint+[URL]:url:' \
        '--user+[user]:user:_users' \
        '--password+[password]:password:' \
        '--insecure[skip TLS verify]' \
        '--threshold+[severity]:threshold:(critical high medium low negligible)' \
        '--debug[debug]' \
        '--format+[output format]:format:(json sarif cyclonedx)' \
        '--out+[output file]:file:_files' \
        '1:image reference:'
}

_smartcheck "$@"
