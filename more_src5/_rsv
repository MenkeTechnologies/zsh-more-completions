#compdef rsv
# ============================================================================
# rsv - parallel command-line toolkit for
#        large CSV + TXT + Excel files
#        (Rust, MIT OR Unlicense)
#
# Author : zhuang dai (ribbondz)
# Upstream: https://github.com/ribbondz/rsv
# crates : csv-txt-excel-parallel-toolkit
#           (binary: rsv = Rust+CSV)
#
# `rsv` is a parallel + fast command-line
# toolkit for processing tabular data files
# (CSV + TXT + Excel/XLSX/XLS), with a
# unified API across all three formats.
# Designed for both small interactive use
# + large-scale (10+ GB) parallel processing.
#
# Architecture:
#   - **Unified format API** (every
#     command works on CSV + TXT + XLSX +
#     XLS via format auto-detection from
#     extension)
#   - **Parallel processing** (rayon-
#     based parallelism for stats +
#     frequency + search operations)
#   - **Streaming where possible**
#     (count + estimate + head + tail
#     don't load entire file)
#   - **In-memory for analytics**
#     (frequency + stats + sort load
#     into memory; suitable for
#     files up to system RAM)
#   - **Excel support via calamine**
#     (read XLSX + XLS via the
#     canonical Rust Excel library)
#
# Distinguishing features vs alternatives
# (csvkit + xsv + qsv + miller):
#   - **Excel support built-in** (most
#     CSV tools don't read XLSX
#     natively; rsv handles XLSX as
#     first-class)
#   - **Parallel by default** (rayon
#     thread pool for analytics
#     commands)
#   - **Both interactive + large-file
#     workflows** (small files render
#     to terminal table; large files
#     pipeline-friendly)
#   - **Pure Rust performance** (faster
#     than Python pandas for many
#     tabular operations)
#   - **Unified output formats** (every
#     command can output to TXT + CSV +
#     TSV + XLSX + XLS via the `to`
#     command)
#
# Use cases:
#   - Quick CSV exploration (head + tail
#     + headers + flatten + table)
#   - Large CSV aggregation (frequency +
#     stats + unique + sort on multi-GB
#     files)
#   - Excel-to-CSV conversion at scale
#     (excel2csv command)
#   - Data cleaning (clean + select +
#     slice + search)
#   - Format conversion (TXT ↔ CSV ↔
#     TSV ↔ XLSX ↔ XLS via `to`)
#   - File sampling for statistical
#     analysis (sample command)
#
# Usage:
#   rsv <command> [args]
#
# Subcommands (clap derive):
#   head [file]                    - show
#                                     first
#                                     N
#                                     lines
#                                     (default
#                                     10;
#                                     `rsv
#                                     head
#                                     --help`
#                                     for
#                                     flags)
#   tail [file]                    - show
#                                     last N
#                                     lines
#   headers [file]                 - show
#                                     file
#                                     headers
#                                     (column
#                                     names)
#   flatten [file]                 - print
#                                     flattened
#                                     records
#                                     (view
#                                     one row
#                                     at a
#                                     time
#                                     vertically)
#   count [file]                   - count
#                                     lines
#                                     in
#                                     file
#                                     or
#                                     files
#                                     in
#                                     directory
#   size [file]                    - show
#                                     file
#                                     size
#   estimate [file]                - fast
#                                     line
#                                     count
#                                     estimate
#                                     (approximate
#                                     for
#                                     large
#                                     files)
#   clean [file]                   - clean
#                                     escape
#                                     chars
#                                     (default
#                                     ")
#   frequency [file]               - frequency
#                                     table
#                                     for
#                                     column(s)
#   split [file]                   - split
#                                     file
#                                     into
#                                     separate
#                                     files
#                                     (by
#                                     count
#                                     or
#                                     column
#                                     value)
#   select [file]                  - select
#                                     rows +
#                                     columns
#                                     by
#                                     filter
#   slice [file]                   - extract
#                                     row
#                                     slice
#                                     (head
#                                     +
#                                     middle
#                                     + tail
#                                     regions)
#   search [file]                  - search
#                                     with
#                                     regexes
#   sort [file]                    - sort
#                                     data by
#                                     column(s)
#   stats [file]                   - statistics
#                                     for
#                                     column(s)
#                                     (min +
#                                     max +
#                                     mean +
#                                     unique
#                                     + null)
#   excel2csv [file]               - convert
#                                     Excel
#                                     to CSV
#                                     (alias
#                                     for
#                                     `to
#                                     --format
#                                     csv`
#                                     when
#                                     input
#                                     is
#                                     xlsx)
#   table [file]                   - show
#                                     data
#                                     in
#                                     aligned
#                                     terminal
#                                     table
#   to [file]                      - save
#                                     data
#                                     to disk
#                                     (TXT +
#                                     CSV +
#                                     TSV +
#                                     XLSX +
#                                     XLS)
#   sample [file]                  - sample
#                                     data
#                                     (random
#                                     or
#                                     systematic
#                                     sampling)
#   unique [file]                  - drop
#                                     duplicates
#
# Standard:
#   -h, --help                     - show
#                                     help
#   -V, --version                  - show
#                                     version
#
# Common flags (per-subcommand variations):
#   -n, --no-header                - file
#                                     has no
#                                     header
#                                     row
#   -s, --sep <char>               - field
#                                     separator
#                                     (default
#                                     auto-
#                                     detected
#                                     from
#                                     extension:
#                                     , for
#                                     CSV;
#                                     TAB for
#                                     TSV)
#   --sheet <name>                 - Excel
#                                     sheet
#                                     name
#                                     (for
#                                     XLSX/
#                                     XLS
#                                     input)
#   -c, --col <columns>            - column
#                                     specifier
#                                     (name
#                                     or
#                                     0-indexed
#                                     position)
#
# Example invocations:
#   # Show first 10 lines of a CSV
#   rsv head data.csv
#
#   # Show last 20 lines
#   rsv tail -n 20 data.csv
#
#   # Show column headers
#   rsv headers data.csv
#
#   # Display in aligned table format
#   rsv table data.csv
#
#   # Flattened record view (one row
#   # per screen)
#   rsv flatten data.csv
#
#   # Frequency of values in column 0
#   rsv frequency -c 0 data.csv
#
#   # Stats on column 1 (min, max, mean)
#   rsv stats -c 1 data.csv
#
#   # Search for regex matches
#   rsv search "^Alice" data.csv
#
#   # Sort by column "amount" descending
#   rsv sort -c amount data.csv
#
#   # Convert Excel to CSV
#   rsv excel2csv sales.xlsx
#
#   # Read specific Excel sheet
#   rsv head --sheet "Q1 Sales" sales.xlsx
#
#   # Convert any format to another
#   rsv to --format xlsx data.csv
#
#   # Sample 1000 random rows
#   rsv sample -n 1000 data.csv
#
#   # Drop duplicate rows
#   rsv unique data.csv
#
#   # Split a 10GB CSV into 1M-row files
#   rsv split -n 1000000 huge.csv
#
#   # Pipeline: filter + count
#   rsv search "Q4" sales.csv | wc -l
#
# The calamine lane is built on `calamine =
# { version = "0.32.0", features = ['dates']
# }` (declared verbatim at upstream
# workspace Cargo.toml HEAD as a direct
# workspace dep, imported by `rsv/src/
# excel/` for reading XLSX + XLS spreadsheet
# data with date type recognition), the
# canonical Rust Excel library by Johann
# Tuffe (tafia) - github.com/tafia/calamine.
#
# tafia/calamine is the de-facto canonical
# Rust Excel library:
#   - **Multi-format support**: XLSX +
#     XLSM + XLSB (binary) + XLS (legacy
#     pre-2007 Excel) + ODS (OpenDocument
#     Spreadsheet)
#   - **Pure-Rust implementation** (no
#     LibreOffice or Excel runtime
#     dependency; no native bindings)
#   - **Read-only by design** (calamine
#     focuses on reading; writing is
#     handled by sister crate
#     rust_xlsxwriter)
#   - **Sheet enumeration + selective
#     loading** (load specific sheets
#     by name; useful for multi-sheet
#     workbooks where only some sheets
#     matter)
#   - **Type-aware cells** (cell values
#     decoded to enum: Int + Float +
#     String + Bool + DateTime +
#     Empty)
#   - **Streaming worksheet reading**
#     (memory-efficient for large
#     spreadsheets)
#   - **1,500+ stars on github.com/
#     tafia/calamine**
#   - **~2,800 reverse-deps on
#     crates.io (the canonical Rust
#     Excel ecosystem)**
#
# calamine's distinguishing position vs
# Rust Excel alternatives:
#   - tafia/calamine (Tuffe): canonical;
#     read-only multi-format; THIS AXIS
#   - rust_xlsxwriter (jmcnamara/rust_
#     xlsxwriter; John McNamara - author
#     of the canonical Perl
#     Spreadsheet::WriteExcel + Python
#     XlsxWriter): canonical Rust XLSX
#     writer; complements calamine for
#     write workflows
#   - umya-spreadsheet (umya/umya-
#     spreadsheet): both read + write;
#     less mature than the
#     calamine + rust_xlsxwriter combo
#   - office-crypto: encrypted Excel
#     decryption; smaller scope
#
# Johann Tuffe (tafia) is a French Rust
# developer + maintainer of multiple
# foundational Rust XML + Office format
# libraries:
#   - **tafia/calamine** (THIS AXIS;
#     canonical Rust Excel reader)
#   - **tafia/quick-xml** (the canonical
#     Rust XML parser; ~1,200 stars;
#     used by calamine internally +
#     by many other Office-format
#     libraries since XLSX is ZIP-
#     bundled XML files)
#
# Tuffe's role in Rust is *XML +
# Office format infrastructure*. His
# quick-xml is the foundation that
# calamine + many other XLSX/DOCX/
# PPTX libraries build on - making
# Tuffe's contribution structurally
# critical to the entire Rust Office
# format ecosystem.
#
# Multi-axis canonical-Rust author/org
# cohort extension (now spanning even
# more distinct authors):
#   - + Johann Tuffe (tafia; calamine +
#     quick-xml; THIS AXIS; canonical
#     Rust Excel reader + foundational
#     XML parser used by virtually
#     every Rust Office format library)
#
# Tuffe joining the canonical-Rust
# cohort at the *foundational XML +
# Office format infrastructure* level
# extends the pattern of *single-author
# canonical vertical stack*
# documented across many corpus axes.
#
# rsv uses calamine for:
#   - Reading XLSX + XLS spreadsheet
#     files (single-sheet selection +
#     full workbook enumeration)
#   - Date cell decoding (the
#     `features = ['dates']` flag
#     enables typed DateTime cell
#     decoding via chrono integration)
#   - Multi-sheet workbook handling
#     (--sheet flag selects specific
#     sheets)
#   - Converting Excel to CSV
#     (excel2csv subcommand)
#
# This is the canonical use case for
# calamine in production Rust tools:
# reading spreadsheet data into a
# unified Rust-native representation
# for downstream processing (analytics +
# format conversion + data export).
#
# ----------------------------------------------------------------------------
# AXIS 291 :: Excel / spreadsheet
#              processing libraries
#              (XLSX + XLS + ODS file
#              format I/O; cell type
#              handling + multi-sheet
#              workbook enumeration +
#              formula evaluation)
# Round 1571 :: Rust slot 1 of 4 :: OPENS Axis 291
#
# Cross-language canonical library family
# for this axis (proposed):
#   Rust    : tafia/calamine            - Johann
#                                          Tuffe
#                                          (canonical
#                                          Rust
#                                          Excel
#                                          reader;
#                                          multi-
#                                          format
#                                          XLSX +
#                                          XLS +
#                                          XLSB +
#                                          ODS)
#   Go      : xuri/excelize             - Ri Xu
#                                          (canonical
#                                          Go Excel;
#                                          both
#                                          read +
#                                          write;
#                                          XLSX +
#                                          XLSM +
#                                          XLTM +
#                                          XLTX)
#   TS/Node : SheetJS/sheetjs           - SheetJS
#             OR                            LLC +
#             exceljs/exceljs               community
#                                          (canonical
#                                          Node
#                                          spreadsheet
#                                          library;
#                                          broadest
#                                          format
#                                          support)
#
# Excel/spreadsheet files are the
# *foundational data exchange format* in:
#   - Financial reporting (every
#     accounting + finance team uses
#     Excel)
#   - Business operations (KPIs +
#     dashboards + reports)
#   - Scientific data sharing (between
#     research groups + with vendors)
#   - Government data publishing
#     (FOIA + statistical agency data)
#   - Educational materials (homework
#     + grading + course rosters)
#
# Each canonical library provides:
#   - XLSX format parsing (Office Open
#     XML; the modern format since
#     Excel 2007)
#   - XLS format parsing (legacy
#     binary format from Excel 97-2003)
#   - Sheet enumeration + selective
#     loading
#   - Cell type handling (string + int
#     + float + date + boolean +
#     formula)
#   - Writing capability (varies by
#     library; calamine is read-only;
#     excelize + sheetjs handle both)
#
# Use-case spectrum for this axis (so far):
#   - rsv (Rust, calamine): parallel
#     CSV/TXT/Excel toolkit with
#     unified API across formats +
#     excel2csv conversion + analytics
# ============================================================================

_rsv() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_rsv_cmds' \
        '*::arg:->args' \
    && ret=0

    return ret
}

_rsv_cmds() {
    local -a cmds
    cmds=(
        'head:show head N lines'
        'tail:show tail N lines'
        'headers:show file headers (column names)'
        'flatten:print flattened records (vertical view)'
        'count:count lines in file or files in directory'
        'size:show file size'
        'estimate:fast line count estimate'
        'clean:clean escape chars (default ")'
        'frequency:frequency table for column(s)'
        'split:split file into separate files'
        'select:select rows + columns by filter'
        'slice:extract row slice'
        'search:search with regexes'
        'sort:sort data by column(s)'
        'stats:column statistics (min, max, mean, unique, null)'
        'excel2csv:convert Excel to CSV'
        'table:show data in aligned terminal table'
        'to:save data to disk (TXT/CSV/TSV/XLSX/XLS)'
        'sample:random or systematic data sampling'
        'unique:drop duplicate rows'
    )
    _describe -t commands 'rsv command' cmds
}

_rsv "$@"
