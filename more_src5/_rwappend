#compdef rwappend rwcombine rwdedupe rwmatch rwnetmask rwrandomizeip rwgeoip2ccmap rwpackchecker
# Documentation: https://tools.netsa.cert.org/silk/rw{append,combine,dedupe,match,netmask,randomizeip,geoip2ccmap,packchecker}.html
# Reference accessed: 2026-05-30
# SiLK Round 6 — single-purpose utilities. Companion to rounds 135-139.
# Standalone tools (no inter-tool sharing beyond the metadata cluster),
# but still grouped multi-stem since they fit cleanly under one file.
# Deferred this round: rwconvert and rwallroute (upstream 404).

local curcontext="$curcontext" state line ret=1

# Shared metadata cluster appearing across most tools.
local -a _meta
_meta=(
  '--note-add=[annotation for header]:text:'
  '--note-file-add=[annotation file]:file:_files'
  '--compression-method=[output compression]:method:(none zlib lzo1x snappy best)'
  '--site-config-file=[SiLK site config]:file:_files'
  '(- *)--help[show help]'
  '(- *)--version[show version + build info]'
)

# rwdedupe's --ignore-fields field set (20 fields).
local _dedupe_fields='_values -s , "field" sIP dIP sPort dPort protocol packets bytes flags sTime duration sensor in out nhIP class type initialFlags sessionFlags attributes application'

# rwcombine's --ignore-fields field set (12 fields, subset of dedupe).
local _combine_fields='_values -s , "field" sIP dIP sPort dPort protocol sensor in out nhIP class type application'

case $service in

  rwappend)
    _arguments -s -S \
      $_meta \
      '--create=-[create TARGET_FILE if missing (optional template)]:template:_files' \
      '--print-statistics[print per-source record counts to stderr]' \
      '1:target SiLK file:_files' \
      '*:source SiLK file:_files' \
      && ret=0
    ;;

  rwcombine)
    _arguments -s -S \
      $_meta \
      '--actions=[combination strategy]:action:(all timeout)' \
      '--ignore-fields=[fields excluded from grouping]:fields:'"$_combine_fields" \
      '--max-idle-time=[max idle gap (seconds)]:N:' \
      '--print-statistics=-[stats destination (default stderr)]:file:_files' \
      '--temp-directory=[temp file dir]:dir:_files -/' \
      '--buffer-size=[max buffer size (K/M/G)]:size:' \
      '--print-filenames[show input filenames]' \
      '--output-path=[output path]:path:_files' \
      '*--xargs=-[read filenames from file/stdin]:file:_files' \
      '(- *)--help-fields[show field descriptions]' \
      '*:input SiLK file:_files' \
      && ret=0
    ;;

  rwdedupe)
    _arguments -s -S \
      $_meta \
      '--ignore-fields=[fields excluded from comparison]:fields:'"$_dedupe_fields" \
      '--packets-delta=[allow packet-count delta]:N:' \
      '--bytes-delta=[allow byte-count delta]:N:' \
      '--stime-delta=[allow start-time delta (ms)]:float:' \
      '--duration-delta=[allow duration delta (ms)]:float:' \
      '--temp-directory=[temp file dir]:dir:_files -/' \
      '--buffer-size=[max buffer size]:size:' \
      '--print-filenames[show input filenames]' \
      '--output-path=[output path]:path:_files' \
      '*--xargs=-[read filenames from file/stdin]:file:_files' \
      '(- *)--help-fields[show field descriptions]' \
      '*:input SiLK file:_files' \
      && ret=0
    ;;

  rwmatch)
    _arguments -s -S \
      $_meta \
      '*--relate=[field pair for matching (required)]:fieldpair:' \
      '--time-delta=[seconds response may start after query]:N:' \
      '(--absolute-delta --relative-delta --infinite-delta)--absolute-delta[within DELTA of initial flow end (default)]' \
      '(--absolute-delta --relative-delta --infinite-delta)--relative-delta[within DELTA of running max end time]' \
      '(--absolute-delta --relative-delta --infinite-delta)--infinite-delta[ignore time constraints]' \
      '--symmetric-delta[allow response file to contain initial flow]' \
      '--unmatched=[emit unmatched: q|r|b]:which:(q r b)' \
      '--ipv6-policy=[IPv4/IPv6 handling]:policy:(ignore asv4 mix force only)' \
      '(- *)--help-relate[show --relate field reference]' \
      '1:query SiLK file:_files' \
      '2:response SiLK file:_files' \
      '3:output SiLK file:_files' \
      && ret=0
    ;;

  rwnetmask)
    _arguments -s -S \
      $_meta \
      '--4sip-prefix-length=[keep N MSBs of IPv4 sIP]:N:' \
      '--4dip-prefix-length=[keep N MSBs of IPv4 dIP]:N:' \
      '--4nhip-prefix-length=[keep N MSBs of IPv4 nhIP]:N:' \
      '--6sip-prefix-length=[keep N MSBs of IPv6 sIP]:N:' \
      '--6dip-prefix-length=[keep N MSBs of IPv6 dIP]:N:' \
      '--6nhip-prefix-length=[keep N MSBs of IPv6 nhIP]:N:' \
      '--sip-prefix-length=[alias for --4sip-prefix-length]:N:' \
      '--dip-prefix-length=[alias for --4dip-prefix-length]:N:' \
      '--nhip-prefix-length=[alias for --4nhip-prefix-length]:N:' \
      '--output-path=[output path]:path:_files' \
      '--print-filenames[show input filenames]' \
      '--ipv6-policy=[IPv4/IPv6 handling]:policy:(ignore asv4 mix force only)' \
      '*--xargs=-[read filenames from file/stdin]:file:_files' \
      '*:input SiLK file:_files' \
      && ret=0
    ;;

  rwrandomizeip)
    _arguments -s -S \
      $_meta \
      '--seed=[PRNG seed]:N:' \
      '--only-change-set=[randomize only IPs in IPset]:file:_files -g "*.set"' \
      '--dont-change-set=[keep IPs in IPset unchanged]:file:_files -g "*.set"' \
      '--consistent[map each input IP to one output IP]' \
      '--save-table=[save randomization table]:file:_files' \
      '--load-table=[load randomization table]:file:_files' \
      '1:input SiLK file:_files' \
      '2:output SiLK file:_files' \
      && ret=0
    ;;

  rwgeoip2ccmap)
    _arguments -s -S \
      '--note-add=[annotation for header]:text:' \
      '--note-file-add=[annotation file]:file:_files' \
      '--invocation-strip[omit command line from header]' \
      '(- *)--help[show help]' \
      '(- *)--version[show version]' \
      '--mode=[input + IPv4/IPv6 mode]:mode:(auto ipv4 ipv6 csv binary geoip2 legacy)' \
      '--input-path=[GeoIP source (file or dir)]:path:_files' \
      '--output-path=[binary CC prefix-map output]:file:_files' \
      '--dry-run[validate without writing]' \
      '--fields=[GeoName field priority]:fields:_values -s , "field" location registered represented flags continent' \
      '--csv-input[deprecated: IPv4 CSV legacy input]' \
      '--v6-csv-input[deprecated: IPv6 CSV legacy input]' \
      '--encoded-input[deprecated: binary legacy input]' \
      '--input-file=[deprecated alias for --input-path]:path:_files' \
      '--output-file=[deprecated alias for --output-path]:file:_files' \
      && ret=0
    ;;

  rwpackchecker)
    _arguments -s -S \
      '(- *)--help[show help]' \
      '(- *)--version[show version + build info]' \
      '*--value=[set TEST=VALUE threshold]:spec:' \
      '*--allowable-count=[TEST=ALLOWED violation tolerance]:spec:' \
      '--print-all[show results for all tests]' \
      '*--xargs=-[read filenames from file/stdin]:file:_files' \
      '*:input SiLK file:_files' \
      && ret=0
    ;;

esac

return ret
