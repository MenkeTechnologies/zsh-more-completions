#compdef revseq
# Documentation: https://galaxy-iuc.github.io/emboss-5.0-docs/revseq.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# EMBOSS revseq: reverse and/or complement nucleotide sequence(s).
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[force qualifier prompts]' '-debug[debug]' '-verbose[verbose]' \
  '-warning[warnings]' '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[DNA sequence(s)]:sequence USA:_files' \
  '-outseq=[output sequence file]:file:_files' \
  '-reverse[reverse the output sequence (default)]' \
  '-noreverse[do not reverse the sequence (keep 5->3 order)]' \
  '-complement[complement the output sequence (default)]' \
  '-nocomplement[do not complement (just reverse)]' \
  '-osformat=[output sequence format]:format:(fasta embl genbank gff swiss gcg ig pir nbrf raw msf ace text staden experiment)' \
  '-osname=[output base name]:name:' \
  '-osextension=[output file extension]:ext:' \
  '*:DNA sequence:_files' && ret=0

return ret
