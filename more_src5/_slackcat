#compdef slackcat
# Documentation: https://github.com/bcicen/slackcat
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# Zsh completion for slackcat

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-t --tee)'{-t,--tee}'[print stdin to screen before posting]' \
  '(-s --stream)'{-s,--stream}'[stream messages continuously]' \
  '--noop[skip posting to Slack (testing)]' \
  '--configure[configure slackcat via OAuth]' \
  '(-i --iconemoji)'{-i,--iconemoji}'[emoji icon for message]:emoji:' \
  '(-c --channel)'{-c,--channel}'[Slack channel, group, or user]:channel:' \
  '(-n --filename)'{-n,--filename}'[filename for upload]:name:' \
  '--filetype[filetype for syntax highlighting]:type:' \
  '--comment[initial comment for snippet]:comment:' \
  '--username[stream as given bot username]:user:' \
  '--thread[stream to thread after initial comment]:thread:' \
  '*:file:_files' && ret=0

return ret
