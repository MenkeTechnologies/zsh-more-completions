#compdef roo
# Documentation: https://github.com/RooCodeInc/Roo-Code/tree/main/apps/cli
# Reference accessed: 2026-05-22
# Verified: apps/cli/src/index.ts Commander program definitions.

# Zsh completion for roo - Roo Code CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--prompt-file[read prompt from file]:file:_files' \
  '--create-with-session-id[create task with UUID]:id:' \
  '--session-id[resume task by session ID]:id:' \
  '(-c --continue)'{-c,--continue}'[resume most recent task in workspace]' \
  '(-w --workspace)'{-w,--workspace}'[workspace directory]:directory:_directories' \
  '(-p --print)'{-p,--print}'[non-interactive print mode]' \
  '--stdin-prompt-stream[read NDJSON commands from stdin]' \
  '--signal-only-exit[exit only on SIGINT/SIGTERM]' \
  '(-e --extension)'{-e,--extension}'[extension bundle path]:directory:_directories' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(-a --require-approval)'{-a,--require-approval}'[require manual approval]' \
  '(-k --api-key)'{-k,--api-key}'[LLM API key]:key:' \
  '--provider[API provider]:provider:' \
  '(-m --model)'{-m,--model}'[model to use]:model:' \
  '--mode[starting mode]:mode:(code architect ask debug)' \
  '--terminal-shell[shell executable for inline commands]:file:_files' \
  '(-r --reasoning-effort)'{-r,--reasoning-effort}'[reasoning effort]:effort:(unspecified disabled none minimal low medium high xhigh)' \
  '--consecutive-mistake-limit[consecutive error limit before guidance]:limit:' \
  '--exit-on-error[exit on API errors instead of retrying]' \
  '--ephemeral[run without persisting state]' \
  '--oneshot[exit upon task completion]' \
  '--output-format[output format with --print]:format:(text json stream-json)' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'roo command' \
      'list[list commands modes models or sessions]' \
      'upgrade[upgrade Roo Code CLI]' && ret=0
    ;;
  args)
    case $line[1] in
      list)
        _values 'list target' commands modes models sessions && ret=0
        case $line[2] in
          commands|modes|models|sessions)
            _arguments \
              '(-w --workspace)'{-w,--workspace}'[workspace]:directory:_directories' \
              '(-e --extension)'{-e,--extension}'[extension bundle]:directory:_directories' \
              '(-k --api-key)'{-k,--api-key}'[API key]:key:' \
              '--format[output format]:format:(json text)' \
              '(-d --debug)'{-d,--debug}'[debug output]' && ret=0
            ;;
        esac
        ;;
      *)
        _arguments '*:prompt:' && ret=0
        ;;
    esac
    ;;
esac

return ret
