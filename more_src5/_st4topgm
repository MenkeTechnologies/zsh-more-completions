#compdef st4topgm
# Documentation: man st4topgm (Netpbm)
# Source: convert an SBIG ST-4 CCD camera image to PGM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:st4 file:_files' \
    && ret=0

return ret
