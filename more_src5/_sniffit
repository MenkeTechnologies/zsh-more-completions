#compdef sniffit
# Documentation: https://manpages.debian.org/bookworm/sniffit/sniffit.8.en.html
# Reference accessed: 2026-05-21
# Verified: Debian bookworm sniffit(8) manpage.
# Removed from prior file: broken '-a' label syntax. Added: -I (iface name
# selection alt), -R (recordfile read), -l (sniflen), -n/-N. Replaced bogus
# man.archlinux.org URL.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-v[show version]' \
  '-i[interactive ncurses mode]' \
  '-I[interactive ncurses mode (alternate)]' \
  '-d[dump packet contents]' \
  '-a[ASCII dump to stdout]' \
  '-x[extended TCP/UDP/IP info]' \
  '-b[both directions of conversation]' \
  '-n[no name resolution]' \
  '-N[no host lookups; show numbers]' \
  '-t+[target IP]:ip:' \
  '-s+[source IP]:ip:' \
  '-p+[port]:port:' \
  '-P+[protocol]:proto:(TCP UDP ICMP)' \
  '-A+[ASCII replacement char for non-printable]:char:' \
  '-F+[capture device]:iface:' \
  '-L+[log parameters]:logparam:' \
  '-M+[plugin module]:plugin:' \
  '-l+[capture length per packet]:n:' \
  '-r+[read recordfile]:file:_files' \
  '-R+[record to file]:file:_files' \
  '-c+[config file]:file:_files' \
  '-D+[dump to tty]:tty:_files -g "/dev/tty*"' && ret=0

return ret
