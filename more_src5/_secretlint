#compdef secretlint
# Documentation: https://github.com/secretlint/secretlint
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--init[setup configuration file]' \
  '--secretlintrc=[path to .secretlintrc config file]:config file:_files' \
  '--secretlintrcJSON=[JSON string of .secretlintrc config]:json:' \
  '--secretlintignore=[path to .secretlintignore file]:ignore file:_files' \
  '--format=[output format]:format:(checkstyle compact github jslint-xml junit pretty-error stylish tap unix json mask-result table)' \
  '--output=[output file]:output file:_files' \
  '--stdinFileName=[filename for STDIN content]:name:' \
  '--no-color[disable ANSI-color output]' \
  '--no-terminalLink[disable terminal link functionality]' \
  '--no-maskSecrets[disable secret masking]' \
  '--no-glob[treat inputs as literal paths]' \
  '--no-gitignore[disable .gitignore cascade]' \
  '--profile[enable performance profiling]' \
  '--locale=[locale tag for messages]:locale:' \
  '*:file or directory:_files' && ret=0

return ret
