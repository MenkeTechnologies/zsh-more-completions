#compdef svnpath
# Documentation: https://manpages.debian.org/svnpath
# Source: debian/devscripts scripts/svnpath.pl — print svn URL with tag/branch awareness (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '1::path type:(tags branches trunk)' \
    && ret=0

return ret
