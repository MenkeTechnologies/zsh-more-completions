#compdef siyuan-cli
# _siyuan-cli — SiYuan local-first personal knowledge management CLI alias (siyuan-note team, Go); custom argparse
# upstream: https://github.com/siyuan-note/siyuan

_siyuan-cli() {
    local -a sub=(
        'start:start kernel/server'
        'stop:stop server'
        'restart:restart server'
        'status:show server status'
        'notebook:list:list notebooks'
        'notebook:create:create notebook'
        'notebook:open:open notebook'
        'notebook:close:close notebook'
        'notebook:rename:rename notebook'
        'notebook:remove:remove notebook'
        'doc:list:list documents'
        'doc:create:create document'
        'doc:rename:rename document'
        'doc:remove:remove document'
        'doc:move:move document'
        'doc:export:export document'
        'doc:import:import document'
        'block:get:get block'
        'block:append:append block'
        'block:insert:insert block'
        'block:update:update block'
        'block:delete:delete block'
        'block:move:move block'
        'block:children:get children'
        'block:parents:get parents'
        'attr:get:get attribute'
        'attr:set:set attribute'
        'asset:upload:upload asset'
        'asset:list:list assets'
        'asset:remove:remove asset'
        'sql:run sql query'
        'search:full-text search'
        'tag:list:list tags'
        'tag:rename:rename tag'
        'tag:remove:remove tag'
        'bookmark:list:list bookmarks'
        'bookmark:rename:rename bookmark'
        'bookmark:remove:remove bookmark'
        'sync:start:start sync'
        'sync:stop:stop sync'
        'sync:status:show sync status'
        'sync:upload:upload to cloud'
        'sync:download:download from cloud'
        'snapshot:create:create snapshot'
        'snapshot:list:list snapshots'
        'snapshot:restore:restore snapshot'
        'export:export workspace'
        'import:import workspace'
        'plugin:list:list plugins'
        'plugin:install:install plugin'
        'plugin:enable:enable plugin'
        'plugin:disable:disable plugin'
        'plugin:remove:remove plugin'
        'theme:set:set theme'
        'theme:list:list themes'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--workspace=+[workspace path]:dir:_files -/' \
        '-w+[workspace path]:dir:_files -/' \
        '--port=+[port]:port:' \
        '-p+[port]:port:' \
        '--token=+[api token]:str:' \
        '--url=+[server url]:url:_urls' \
        '--lang=+[language]:l:(en_US zh_CN ja_JP fr_FR es_ES de_DE)' \
        '--config=+[config file]:file:_files' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'siyuan subcommand' sub ;;
        args)
            case $words[1] in
                block:append|block:insert|block:update) _arguments \
                    '--data=+[markdown content]:str:' \
                    '-d+[markdown content]:str:' \
                    '--file=+[content file]:file:_files' \
                    '--data-type=+[data type]:t:(markdown dom)' \
                    '--parent-id=+[parent id]:str:' \
                    '--previous-id=+[previous id]:str:' ;;
                doc:export) _arguments \
                    '1:doc id:' \
                    '--format=+[format]:f:(markdown html pdf docx odt epub html-pretty)' \
                    '--out=+[output file]:file:_files' ;;
                sql) _arguments '1:sql query:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_siyuan-cli "$@"
