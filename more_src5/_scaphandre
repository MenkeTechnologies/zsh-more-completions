#compdef scaphandre
# Documentation: https://github.com/hubblo-org/scaphandre
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: Upstream README/docs only confirm subcommand names (json,
# prometheus, qemu, riemann, stdout, warp10) but do not publish a
# per-flag reference. Pre-existing detailed flag list was removed to
# avoid fabrication; subcommand dispatch retained.

local curcontext="$curcontext" state line ret=1
local -a _scaphandre_commands
_scaphandre_commands=(
  'json:output to JSON'
  'prometheus:expose metrics via Prometheus endpoint'
  'qemu:expose metrics for virtual machines'
  'riemann:push metrics to Riemann'
  'stdout:display metrics on stdout'
  'warp10:push metrics to Warp10'
)

_arguments -C \
  '1:command:->cmds' \
  '*::arg:_files' && ret=0

case "$state" in
  cmds)
    _describe -t commands 'scaphandre subcommand' _scaphandre_commands && ret=0
    ;;
esac
return ret
