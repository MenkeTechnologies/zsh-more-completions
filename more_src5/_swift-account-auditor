#compdef swift-account-auditor
# Documentation: https://manpages.debian.org/testing/swift-account/swift-account-auditor.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# OpenStack Swift account auditor daemon

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[log to console]' \
  '(-o --once)'{-o,--once}'[only run one pass of daemon]' \
  '*:swift config file:_files -g "*.conf"' && ret=0
return ret
