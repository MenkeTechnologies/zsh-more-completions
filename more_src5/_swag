#compdef swag
# Documentation: https://github.com/swaggo/swag
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for swag (Go Swagger documentation generator)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[print help]' \
  '(- *)'{-v,--version}'[print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:Create docs.go and swagger spec from source'
      'fmt:Format swag comments'
    )
    _describe -t commands 'swag command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      init)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[print help]' \
          '(-q --quiet)'{-q,--quiet}'[make init less verbose]' \
          '(-g --generalInfo)'{-g+,--generalInfo=}'[Go file path where the main function is]:file:_files' \
          '(-d --dir)'{-d+,--dir=}'[directories to parse]:dirs' \
          '--exclude=[exclude directories from parsing]:dirs' \
          '(-p --propertyStrategy)'{-p+,--propertyStrategy=}'[property naming strategy]:strategy:(snakecase camelcase pascalcase)' \
          '(-o --output)'{-o+,--output=}'[output directory]:dir:_directories' \
          '(--ot --outputTypes)'{--ot+,--outputTypes=}'[output types]:types' \
          '--parseVendor[parse files in vendor directory]' \
          '(--pd --parseDependency)'{--pd,--parseDependency}'[parse go files inside dependency folder]' \
          '(--pdl --parseDependencyLevel)'{--pdl+,--parseDependencyLevel=}'[parse dependency level]:level' \
          '(--md --markdownFiles)'{--md+,--markdownFiles=}'[directory for markdown description files]:dir:_directories' \
          '(--cef --codeExampleFiles)'{--cef+,--codeExampleFiles=}'[directory for code example files]:dir:_directories' \
          '--parseInternal[parse go files in internal packages]' \
          '--generatedTime[generate timestamp at the top of docs.go]' \
          '--parseDepth=[dependency parse depth]:depth' \
          '--requiredByDefault[set required for all fields by default]' \
          '--instanceName=[set instance name for swagger doc]:name' \
          '--overridesFile=[file to override types]:file:_files' \
          '--parseGoList[parse dependency via go list]' \
          '(-t --tags)'{-t+,--tags=}'[comma-separated list of tags to filter]:tags' \
          '(--td --templateDelims)'{--td+,--templateDelims=}'[custom template delimiters]:delims' \
          '(--cf --collectionFormat)'{--cf+,--collectionFormat=}'[collection format]:format:(csv pipes tsv ssv multi)' \
          '--state=[initial state]:state' \
          '--parseFuncBody[parse API info within function bodies]' && ret=0
        ;;
      fmt)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[print help]' \
          '(-d --dir)'{-d+,--dir=}'[directories to format]:dirs' \
          '--exclude=[exclude directories]:dirs' \
          '(-g --generalInfo)'{-g+,--generalInfo=}'[Go file path to format]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
