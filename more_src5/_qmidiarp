#compdef qmidiarp
# _qmidiarp — MIDI arpeggiator / sequencer / LFO (emuse/qmidiarp)
# upstream: https://github.com/emuse/qmidiarp
# Flags from src/main.cpp (getopt_long).

_qmidiarp() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-a --alsa)'{-a,--alsa}'[use the ALSA MIDI backend]' \
        '(-j --jack)'{-j,--jack}'[use the JACK MIDI backend]' \
        '(-p --portCount)'{-p+,--portCount=}'[number of MIDI ports]:n:' \
        '*:.qmax project file:_files -g "*.qmax"'
}

_qmidiarp "$@"
