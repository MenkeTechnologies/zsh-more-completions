#compdef renice-cli
# _renice-cli — util-linux renice alter priority of running processes CLI alias (util-linux team, C); custom argparse
# upstream: https://github.com/util-linux/util-linux

_renice-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-n+[priority]:n:' \
        '--priority=+[priority]:n:' \
        '--relative[treat as relative]' \
        '-g+[process group]:str:' \
        '--pgrp=+[process group]:str:' \
        '-u+[user]:_users' \
        '--user=+[user]:_users' \
        '-p+[pid]:pid:_pids' \
        '--pid=+[pid]:pid:_pids' \
        '*:pid:_pids'
}

_renice-cli "$@"
