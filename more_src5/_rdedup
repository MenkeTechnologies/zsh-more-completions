#compdef rdedup

# Zsh completion for rdedup - deduplicating backup tool

_rdedup() {
  local curcontext="$curcontext" state line ret=1

  local -a subcommands=(
    'init:initialize new repo'
    'store:store data under a name'
    'load:load/retrieve stored data'
    'remove:remove stored data'
    'list:list stored names'
    'du:show disk usage'
    'gc:garbage collect unreferenced data'
    'verify:verify repo integrity'
  )

  _arguments -s -S -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '(-d --dir)'{-d,--dir}'[repo directory]:path:_directories' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '1:subcommand:->subcmd' \
    '*::args:->args' && ret=0

  case $state in
    subcmd)
      _describe -t subcommands 'rdedup command' subcommands && ret=0
      ;;
    args)
      case $words[1] in
        init)
          _arguments -s -S \
            '--chunking[chunking scheme]:scheme:(bup gear fastcdc)' \
            '--chunk-bits[chunk bits]:bits' \
            '--compression[compression type]:type:(none deflate xz brotli zstd)' \
            '--encryption[encryption type]:type:(none curve25519)' \
            '--nesting[nesting depth]:depth' && ret=0
          ;;
        store)
          _arguments '1:name:' && ret=0
          ;;
        load)
          _arguments '1:name:' && ret=0
          ;;
        remove)
          _arguments '1:name:' && ret=0
          ;;
        gc)
          _arguments '--grace[grace period]:duration' && ret=0
          ;;
        list|du|verify)
          ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_rdedup "$@"
