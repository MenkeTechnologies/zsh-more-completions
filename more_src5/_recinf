#compdef recinf
# Documentation: https://www.gnu.org/software/recutils/
# Reference accessed: 2026-06-10

# Zsh completion for recinf (GNU Recutils)

_arguments -s -S \
  '-t+[select record type]:record type:' \
  '-d[print record descriptors]' \
  '-S[show structure of recfile]' \
  '-n[print numeric statistics]' \
  '*:file:_files'
