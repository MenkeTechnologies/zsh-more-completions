#compdef surelog Surelog
# Documentation: https://github.com/chipsalliance/Surelog/blob/master/README.md
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-fileunit[compile each file as a separate compilation unit]' \
  '-parse[parse files]' \
  '-parseonly[parse only, no elaboration]' \
  '-nocomp[no compilation]' \
  '-noelab[no elaboration]' \
  '-elab[elaborate the design]' \
  '-top[specify top module name]:module name:' \
  '-timescale[set default timescale]:timescale:' \
  '*-I[add include directory]:include dir:_files -/' \
  '*-D[define preprocessor macro]:macro:' \
  '*-P[override parameter value]:parameter:' \
  '-odir[output directory]:output dir:_files -/' \
  '-o[output file]:output file:_files' \
  '-log[log file]:log file:_files' \
  '-nostdout[suppress stdout output]' \
  '-verbose[enable verbose output]' \
  '-profile[enable profiling]' \
  '-d[set debug level]:debug level:' \
  '-mt[number of threads for multi-threading]:threads:' \
  '-mp[number of processes for multi-processing]:processes:' \
  '-lowmem[enable low memory mode]' \
  '-sv[enable SystemVerilog mode]' \
  '(- *)--help[show help message]' \
  '*:source file:_files -g "*.(sv|svh|v|vh)"' && ret=0

return ret
