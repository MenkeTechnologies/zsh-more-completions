#compdef registry
# Documentation: https://github.com/distribution/distribution
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--log-level[log level]:level:(debug info warn error)' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a subcommands=(
      'serve:run the registry server'
      'garbage-collect:run garbage collection'
      'help:show help'
    )
    _describe -t commands 'registry subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      serve)
        _arguments \
          '(- *)--help[show help]' \
          '--log-level[log level]:level:(debug info warn error)' \
          '1:config file:_files' && ret=0
        ;;
      garbage-collect)
        _arguments \
          '(- *)--help[show help]' \
          '--log-level[log level]:level:(debug info warn error)' \
          '--dry-run[do a dry run]' \
          '--delete-untagged[delete manifests not currently referenced by tag]' \
          '1:config file:_files' && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
