#compdef swagger-cli
# Documentation: https://github.com/APIDevTools/swagger-cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for swagger-cli - Swagger/OpenAPI CLI tool

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-V,--version}'[display version]' \
  '(-d --debug)'{-d+,--debug=}'[enable debug output]:filter' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands
    commands=(
      'validate:Validate a Swagger/OpenAPI definition'
      'bundle:Bundle a multi-file Swagger/OpenAPI definition'
      'help:Display help for a command'
    )
    _describe -t commands 'swagger-cli commands' commands && ret=0
    ;;
  args)
    case ${line[1]} in
      validate)
        _arguments -s -S \
          '--no-schema[skip JSON Schema validation]' \
          '--no-spec[skip spec validation]' \
          '(-h --help)'{-h,--help}'[display help]' \
          '1:spec file:_files -g "*.(yaml|yml|json)"' && ret=0
        ;;
      bundle)
        _arguments -s -S \
          '(-o --outfile)'{-o+,--outfile=}'[output file]:output file:_files' \
          '(-t --type)'{-t+,--type=}'[output file type]:type:(json yaml)' \
          '(-r --dereference)'{-r,--dereference}'[fully dereference all references]' \
          '(-f --format)'{-f+,--format=}'[number of spaces to format output]:spaces' \
          '(-w --wrap)'{-w+,--wrap=}'[line wrap column for YAML]:column' \
          '(-h --help)'{-h,--help}'[display help]' \
          '1:spec file:_files -g "*.(yaml|yml|json)"' && ret=0
        ;;
      *)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
