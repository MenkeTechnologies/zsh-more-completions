#compdef stagit-index
# _stagit-index — stagit index page generator; produces an index.html listing multiple bare git repos
# upstream: https://codemadness.org/stagit.html

_stagit-index() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '*:bare repos:_files -/'
}

_stagit-index "$@"
