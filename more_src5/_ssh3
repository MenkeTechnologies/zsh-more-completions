#compdef ssh3
# Documentation: https://github.com/francoismichel/ssh3
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

# ssh3 client flags use single-dash long options (Go flag package).
_arguments -s -S \
  '-privkey[private key file]:file:_files' \
  '-pubkey-for-agent[agent key matching public key path]:file:_files' \
  '-use-password[use password authentication]' \
  '-forward-agent[forward SSH agent]' \
  '-forward-tcp[TCP port forwarding (localport/remoteip@remoteport)]:spec:' \
  '-forward-udp[UDP port forwarding (localport/remoteip@remoteport)]:spec:' \
  '-proxy-jump[use specified remote host as proxy]:host:_hosts' \
  '-insecure[skip server certificate verification]' \
  '-keylog[write QUIC TLS keys to file]:file:_files' \
  '-use-oidc[force OpenID Connect with issuer URL]:issuer:' \
  '-oidc-config[OIDC JSON config file]:file:_files' \
  '-do-pkce[perform PKCE challenge-response with OIDC]' \
  '-v[verbose mode]' \
  '*: :_files' && ret=0

return ret
