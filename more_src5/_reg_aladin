#compdef reg_aladin
# Documentation: https://github.com/KCL-BMEIS/niftyreg
# Source: KCL-BMEIS/niftyreg reg-apps/reg_aladin.cpp — block-matching global registration (C++; single-dash long opts).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(- *)-help[show help]' \
    '(- *)-v[print version]' \
    '(- *)-V[print version]' \
    '(- *)-version[print version]' \
    '--xml[print XML interface description]' \
    '(-ref --ref -target)'{-ref+,--ref=,-target+}'[reference (fixed/target) image]:file:_files -g "*.{nii,nii.gz,hdr,img}"' \
    '(-flo --flo -source)'{-flo+,--flo=,-source+}'[floating (source/moving) image]:file:_files -g "*.{nii,nii.gz,hdr,img}"' \
    '(-noSym --noSym)'{-noSym,--noSym}'[disable symmetric registration]' \
    '(-aff --aff)'{-aff+,--aff=}'[output affine transformation matrix]:file:_files -g "*.txt"' \
    '(-inaff --inaff)'{-inaff+,--inaff=}'[input initial affine transformation]:file:_files -g "*.txt"' \
    '(-rmask --rmask -tmask)'{-rmask+,--rmask=,-tmask+}'[reference image mask]:file:_files' \
    '(-fmask --fmask -smask)'{-fmask+,--fmask=,-smask+}'[floating image mask]:file:_files' \
    '(-res --res -result)'{-res+,--res=,-result+}'[output resampled floating image]:file:_files' \
    '(-maxit --maxit)'{-maxit+,--maxit=}'[max iterations per level]:n:_default' \
    '(-ln --ln)'{-ln+,--ln=}'[number of pyramid levels]:n:_default' \
    '(-lp --lp)'{-lp+,--lp=}'[levels to perform]:n:_default' \
    '(-smooR --smooR -smooT)'{-smooR+,--smooR=,-smooT+}'[reference smoothing sigma (mm)]:n:_default' \
    '(-smooF --smooF -smooS)'{-smooF+,--smooF=,-smooS+}'[floating smoothing sigma (mm)]:n:_default' \
    '(-rigOnly --rigOnly)'{-rigOnly,--rigOnly}'[rigid-only registration]' \
    '(-affDirect --affDirect)'{-affDirect,--affDirect}'[skip rigid, go straight to affine]' \
    '(-nac --nac)'{-nac,--nac}'[no aff centering]' \
    '(-comm --comm -cog --cog)'{-comm,--comm,-cog,--cog}'[initialise via centres of mass]' \
    '(-comi --comi)'{-comi,--comi}'[initialise via centres of intensity]' \
    '(-pv --pv)'{-pv+,--pv=}'[blocks % to consider as inliers]:n:_default' \
    '(-pi --pi)'{-pi+,--pi=}'[block size % to discard]:n:_default' \
    '(-speeed --speeed)'{-speeeeed,--speeed}'[fast (less accurate) registration]' \
    '(-interp --interp)'{-interp+,--interp=}'[interpolation order]:n:(0 1 3)' \
    '(-refLowThr --refLowThr)'{-refLowThr+,--refLowThr=}'[reference image lower threshold]:n:_default' \
    '(-refUpThr --refUpThr)'{-refUpThr+,--refUpThr=}'[reference image upper threshold]:n:_default' \
    '(-floLowThr --floLowThr)'{-floLowThr+,--floLowThr=}'[floating image lower threshold]:n:_default' \
    '(-floUpThr --floUpThr)'{-floUpThr+,--floUpThr=}'[floating image upper threshold]:n:_default' \
    '(-pad --pad)'{-pad+,--pad=}'[padding value]:n:_default' \
    '(-iso --iso)'{-iso,--iso}'[create isotropic images]' \
    '(-voff --voff)'{-voff,--voff}'[suppress verbose output]' \
    '(-platf --platf)'{-platf+,--platf=}'[platform: 0=CPU 1=CUDA 2=OpenCL]:platform:(0 1 2)' \
    '(-gpuid --gpuid)'{-gpuid+,--gpuid=}'[GPU device id]:n:_default' \
    '(-omp --omp)'{-omp+,--omp=}'[OpenMP threads]:n:_default' \
    && ret=0

return ret
