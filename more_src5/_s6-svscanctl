#compdef s6-svscanctl
# Documentation: https://skarnet.org/software/s6/s6-svscanctl.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-z[destroy zombies (trigger reaper)]' \
  '-a[alarm: rescan scandir for services]' \
  '-b[abort: exec into finishing procedure]' \
  '-h[reload configuration: scan and destroy inactive services]' \
  '-i[terminate (same as -t)]' \
  '-t[terminate gracefully (SIGTERM to services, SIGHUP to loggers)]' \
  '-q[quit: SIGTERM to all supervise processes]' \
  '-n[nuke: remove supervisors not matching scandir]' \
  '-N[really nuke: SIGTERM to all supervise including loggers]' \
  '1:scandir:_files -/' && ret=0

return ret
