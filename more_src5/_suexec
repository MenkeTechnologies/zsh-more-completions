#compdef suexec
# Documentation: https://httpd.apache.org/docs/current/suexec.html
# Source: apache/httpd support/suexec.c (trunk) — setuid wrapper for Apache CGI (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-V[show compile-time settings (root only)]' \
    '1:target user:_users' \
    '2:target group:_groups' \
    '3:command:_command_names -e' \
    '*::arg:_default' \
    && ret=0

return ret
