#compdef scm
# Documentation: https://people.csail.mit.edu/jaffer/scm/SCM-Options.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-b[no banner]' \
  '-c+[evaluate expression]:expr:' \
  '-d+[debug file]:file:_files' \
  '-e+[evaluate expression]:expr:' \
  '-f+[load file]:file:_files -g "*.scm"' \
  '-l+[load file]:file:_files -g "*.scm"' \
  '-L+[load specified language]:lang:' \
  '-no-init-file[suppress init file]' \
  '-no-symbol-case-fold[case-sensitive symbols]' \
  '-no-init-file[skip user init file]' \
  '-p+[print level]:level:' \
  '-r+[require feature]:feature:' \
  '-s+[script file]:file:_files -g "*.scm"' \
  '-u+[unset feature]:feature:' \
  '*:file:_files -g "*.scm"' && ret=0

return ret
