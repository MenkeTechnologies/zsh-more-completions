#compdef qlist
# Documentation: https://github.com/gentoo/portage-utils
# Source: gentoo/portage-utils qlist.c — list contents/installed Gentoo packages.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-I --installed)'{-I,--installed}'[show installed package names only]' \
    '(-B --binpkgs)'{-B,--binpkgs}'[use binpkgs instead of installed]' \
    '(-t --tree)'{-t,--tree}'[use available packages from the tree]' \
    '*'{-S,--slots}'[display slots (twice for subslots)]' \
    '(-R --repo)'{-R,--repo}'[display package with repository]' \
    '(-U --umap)'{-U,--umap}'[display package with flags used]' \
    '(-c --columns)'{-c,--columns}'[column view]' \
    '(-m --masks)'{-m,--masks}'[exclude profile-masked matches]' \
    '--showdebug[show /usr/lib/debug and /usr/src/debug files]' \
    '(-e --exact)'{-e,--exact}'[exact match (CAT/PN or PN, no PV)]' \
    '(-d --dir)'{-d,--dir}'[only directories]' \
    '(-o --obj)'{-o,--obj}'[only objects]' \
    '(-s --sym)'{-s,--sym}'[only symlinks]' \
    '(-F --format)'{-F+,--format=}'[output format string]:fmt:_default' \
    '*:package atom:_default' \
    && ret=0

return ret
