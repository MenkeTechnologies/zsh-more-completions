#compdef random-ip
# _random-ip — djbdns random-ip (generate NUM pseudo-random IPv4 addresses; useful for load-testing DNS resolvers; optional fixed leading bytes pin the prefix)
# upstream: https://github.com/dterweij/ndjbdns
# Flags from random-ip.c on tip; positional args: NUM [BYTE1] [BYTE2] [BYTE3].

_random-ip() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version and exit]' \
        '1:NUM:' \
        '2:BYTE1:' \
        '3:BYTE2:' \
        '4:BYTE3:'
}

_random-ip "$@"
