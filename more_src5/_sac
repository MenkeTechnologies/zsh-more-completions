#compdef sac
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/seis/sac.html
# Source: GenericMappingTools/gmt supplements/seis — plot SAC (Seismic Analysis Code) seismograms.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-J+[projection]:proj:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-B+[basemap frame/axes]:basemap:_default' \
    '-C+[time-window cut for plotting]:opts:_default' \
    '-D+[seismogram offset dx/dy]:offset:_default' \
    '-E+[profile type]:type:(a b d n u)' \
    '-F+[preprocessing (integral/square/remove mean)]:opts:_default' \
    '-G+[fill positive/negative trace portions]:fill:_default' \
    '-M+[vertical trace scale]:scale:_default' \
    '-Q[plot traces vertically (default horizontal)]' \
    '-S+[time scale (sec per unit)]:scale:_default' \
    '-T+[time alignment / shift]:opts:_default' \
    '-U+[GMT timestamp logo]:opts:_default' \
    '-W+[trace-line pen]:pen:_default' \
    '-X+[X offset of plot origin]:offset:_default' \
    '-Y+[Y offset of plot origin]:offset:_default' \
    '-K[multi-page: more pages follow]' \
    '-O[multi-page: this is overlay]' \
    '-P[portrait orientation]' \
    '*-V[verbose (stackable)]' \
    '-h+[header records]:n:_default' \
    '-p+[perspective view]:perspective:_default' \
    '-t+[transparency percent]:pct:_default' \
    '*:SAC file:_files -g "*.(sac|SAC)(-.)"' \
    && ret=0

return ret
