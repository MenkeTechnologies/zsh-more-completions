#compdef statik
# Documentation: https://github.com/rakyll/statik
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for statik (rakyll/statik, Go flag package — single-dash long flags)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-src+[asset source directory]:directory:_directories' \
  '-dest+[destination directory for generated package]:directory:_directories' \
  '-ns+[statik namespace name]' \
  '-f[force overwriting existing package]' \
  '-include+[file glob filter]' \
  '-m[ignore mtimes for deterministic output]' \
  '-Z[disable compression]' \
  '-p+[generated Go package name]' \
  '-tags+[build tags for generated package]' \
  '-c+[godoc comment for generated package]' \
  '-help[show help]' && ret=0

return ret
