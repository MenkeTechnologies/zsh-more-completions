#compdef selfserv
# Documentation: https://github.com/nss-dev/nss (cmd/selfserv/selfserv.c usage())
# Reference accessed: 2026-05-21
# Verified: upstream NSS source for selfserv test SSL server.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-A+[CA nickname for OCSP stapling]:ca:' \
  '-B[historical (no longer used)]' \
  '-C+[SSL cache entry count]:entries:' \
  '-D[disable Nagle (TCP_NODELAY)]' \
  '-E[enable post-handshake auth (TLS 1.3)]' \
  '-G[enable extended master secret]' \
  '-H+[DHE configuration]:mode:(0 1 2)' \
  '-I+[enabled groups for key exchange]:groups:' \
  '-J+[signature schemes]:schemes:' \
  '-L+[log statistics interval]:seconds:' \
  '-M+[multi-process mode]:procs:' \
  '-N[disable server session cache]' \
  '-P+[certificate database prefix]:prefix:' \
  '-Q[enable ALPN]' \
  '-R[disable rollback detection]' \
  '-S+[DSA certificate nickname]:cert:' \
  '-T+[OCSP stapling mode]:mode:' \
  '-U+[ECDHE key reuse]:mode:(0 1)' \
  '-V+[SSL/TLS version range]:min:max:' \
  '-W+[weak DHE support]:mode:(0 1)' \
  '-X+[ECH configuration]:params:' \
  '-Y[print allowed cipher values]' \
  '-Z[enable 0-RTT (TLS 1.3)]' \
  '-a+[SNI name]:name:' \
  '-b[bind to port and exit]' \
  '-c+[restrict ciphers]:ciphers:' \
  '-d+[certificate database directory]:dir:_files -/' \
  '-e+[EC certificate nickname]:cert:' \
  '-f+[password file]:file:_files' \
  '-g+[bulk test block count]:blocks:' \
  '-i+[PID file]:file:_files' \
  '-j[measure TCP throughput]' \
  '-k+[expected negotiated name]:name:' \
  '-l[use local threads]' \
  '-m[test model-socket feature]' \
  '-n+[RSA certificate nickname]:cert:' \
  '-o[accept invalid client certificates]' \
  '-p+[port]:port:' \
  '-q[enable zlib certificate compression]' \
  '-r[request client cert (repeatable)]' \
  '-s[disable SSL socket locking]' \
  '-t+[thread count]:n:' \
  '-u[enable session ticket extension]' \
  '-v[verbose]' \
  '-w+[password (plaintext)]:pw:' \
  '-x+[keying material exporters]:exporters:' \
  '-y[debug cache]' \
  '-z+[external PSK specification]:psk:' && ret=0

return ret
