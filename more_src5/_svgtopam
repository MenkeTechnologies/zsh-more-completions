#compdef svgtopam
# Documentation: man svgtopam (Netpbm)
# Source: convert an SVG file to PAM (raster).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-trace[trace SVG processing for debugging]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:svg file:_files -g "*.svg"' \
    && ret=0

return ret
