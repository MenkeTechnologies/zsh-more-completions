#compdef spirv-link
# Documentation: https://github.com/KhronosGroup/SPIRV-Tools (tools/link/linker.cpp)
# Reference accessed: 2026-05-21
# Verified: upstream spirv-tools linker.cpp option parsing.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-o+[output file (default out.spv)]:file:_files' \
  '--create-library[preserve all exported symbols when linking]' \
  '--allow-partial-linkage[accept unresolved imported symbols]' \
  '--allow-pointer-mismatch[tolerate pointer type mismatches]' \
  '--verify-ids[verify output module IDs are unique]' \
  '--use-highest-version[upgrade output to highest input SPIR-V version]' \
  '--fnvar-capabilities[include capabilities for function variants]' \
  '--fnvar-targets=[CSV file with OpSpecConditionalTarget parameters]:file:_files' \
  '--fnvar-architectures=[CSV file with OpSpecConditionalArchitecture parameters]:file:_files' \
  '--target-env=[interpretation env (default spv1.6)]:env:' \
  '*:file:_files -g "*.spv"' && ret=0

return ret
