#compdef sliplogin
# Documentation: man sliplogin(8)
# Source: netbsd/src usr.sbin/sliplogin — attach SLIP to a terminal line (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1::login name (from /etc/sliphome/slip.hosts):_users' \
    && ret=0

return ret
