#compdef stunnel4 stunnel3
# _stunnel4 — Debian stunnel wrapper (compat aliases for stunnel(8); arguments forwarded directly; common usage: stunnel4 /etc/stunnel/foo.conf to start a daemon defined by the config, or -fd <n> to read config from inherited fd)
# upstream: https://www.stunnel.org/ (mirrolib/stunnel)
# Arguments forwarded to stunnel(8); see stunnel src/options.c on tip.

_stunnel4() {
    _arguments \
        '-version[show version]' \
        '-help[show help]' \
        '-fd+[read config from file descriptor]:fd:' \
        '-reload+[reload running stunnel]:pidfile:_files' \
        '-sockets[print socket options]' \
        '-options[print SSL options]' \
        '1:config file:_files -g "*.conf"'
}

_stunnel4 "$@"
