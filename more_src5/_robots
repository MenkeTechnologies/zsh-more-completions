#compdef robots
# Documentation: man robots(6)
# Source: openbsd/src games/robots/main.c — fight off robots (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-s[show top scores]' \
    '-r[real-time mode]' \
    '-a[advanced — start at level 4]' \
    '-j[jump — repeat moves until significant event]' \
    '-t[allow teleports]' \
    '1::score file:_files' \
    && ret=0

return ret
