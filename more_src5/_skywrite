_skywrite() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--data-path=[base directory for configuration + persistent data (env SKYWRITE_DATA_PATH)]:path:_files -/' \
        '--database-url=[SQLite connection string (env DATABASE_URL)]:url:' \
        '1: :_skywrite_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                start)
                    _arguments \
                        '--app-service=[AT-Proto service URL (env SKYWRITE_APP_SERVICE, default https://bsky.social)]:url:' \
                        '--app-identifier=[username or email of the bot account (env SKYWRITE_APP_IDENTIFIER)]:identifier:' \
                        '--app-password=[app password (env SKYWRITE_APP_PASSWORD)]:password:' \
                        '--rerun-interval-seconds=[interval in seconds between checks (env SKYWRITE_RERUN_INTERVAL_SECONDS, default 300)]:seconds:' \
                        '--rss-feed-backdate-hours=[hours back to check for missed posts on startup (default 3)]:hours:' \
                        '--rss-feed-urls=[comma-separated RSS feed URLs (env SKYWRITE_RSS_FEED_URLS)]:urls:' \
                        '--disable-post-comments=[disable comments on bot posts (default true)]:bool:(true false)' \
                        '--post-languages=[comma-separated ISO-639-1 language codes (default en)]:langs:' && ret=0 ;;
                database)
                    _arguments \
                        '1: :_skywrite_db_commands' \
                        '*::arg:->db_args'
                    case $state in
                        db_args)
                            case $words[1] in
                                insert-post|remove-post)
                                    _arguments '*:URLs (comma-separated):' && ret=0 ;;
                                export-posts)
                                    _arguments '*: :' && ret=0 ;;
                            esac ;;
                    esac
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_skywrite_commands] )) ||
_skywrite_commands() {
    local -a commands
    commands=(
        'start:start the bot and begin checking for new RSS posts on an interval'
        'database:manage the bot state database (insert/remove/export posted URLs)'
    )
    _describe -t commands 'skywrite command' commands
}

(( $+functions[_skywrite_db_commands] )) ||
_skywrite_db_commands() {
    local -a commands
    commands=(
        'insert-post:insert URLs into the posted_urls table (mark as already posted)'
        'remove-post:remove URLs from the posted_urls table (allow reposting)'
        'export-posts:export all posted URLs as a comma-separated list'
    )
    _describe -t commands 'database subcommand' commands
}

_skywrite "$@"
