#   `agent.api.app.bsky.feed.get_likes(...)` /
#   `agent.api.app.bsky.feed.like.create(...)` /
#   `agent.api.app.bsky.feed.repost.create(...)` /
#   `agent.api.app.bsky.actor.get_profile(...)` /
#   `agent.api.app.bsky.actor.search_actors(...)` /
#   `agent.api.app.bsky.actor.put_preferences(...)` /
#   `agent.api.app.bsky.graph.follow.create(...)` /
#   `agent.api.app.bsky.graph.block.create(...)` /
#   `agent.api.app.bsky.graph.mute_actor(...)` /
#   `agent.api.app.bsky.notification.list_notifications(...)` /
#   `agent.api.com.atproto.repo.upload_blob(...)` /
#   `agent.api.com.atproto.repo.create_record(...)` /
#   `agent.api.com.atproto.repo.put_record(...)` /
#   `agent.api.com.atproto.repo.delete_record(...)` /
#   `agent.api.com.atproto.repo.list_records(...)` /
#   `agent.api.com.atproto.server.create_session(...)` /
#   `agent.api.com.atproto.server.refresh_session(...)` /
#   `agent.api.com.atproto.identity.resolve_handle(...)` /
#   `agent.api.com.atproto.identity.update_handle(...)` /
#   `agent.api.com.atproto.moderation.create_report(...)` /
#   `agent.api.com.atproto.sync.get_blob(...)` /
#   `agent.api.com.atproto.sync.subscribe_repos(...)` request
#   + response surface, the typed `Object<T>` /  `Record<T>` /
#   `Cid` /  `Did` /  `AtUri` /  `Datetime` /  `Nsid` /
#   `RecordKey` / `BlobRef` primitive types, the typed
#   `RichText` helper (with `RichText::detect_facets` for
