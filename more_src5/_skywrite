# WHAT IT IS
#   skywrite is an RSS-to-Bluesky cross-poster:  point it at one
#   or more RSS feed URLs, give it Bluesky credentials, and it
#   polls the feeds at the configured interval, deduplicates
#   against a SQLite-backed `posted_urls` table, and submits
#   each new entry as a Bluesky post via `bsky-sdk`'s typed
#   AT-Proto agent (with embed cards for the linked URL,
#   ISO-639-1 language tags, and optional "comments disabled"
#   reply gating).  Designed for the steady-state RSS-feeds-on-
#   Bluesky use case — works equally well for self-hosted
#   blogs, news aggregators, GitHub release feeds, podcast
#   RSS, etc.
#
#   Configuration is dual-mode: every flag has a `SKYWRITE_*`
#   env-var equivalent (read via clap's `env` attribute), and
#   the binary also honors a `.env` file in the working
#   directory via `dotenvy`.  State lives in a SQLite database
#   under the platform's standard local-config dir (overridable
#   via `--data-path` / `--database-url`).
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/commands/mod.rs +
#                       src/commands/start.rs +
#                       src/commands/database/{mod,insert_posts,
#                       remove_posts,export_posts}.rs clap-
#                       derive struct/enum declarations;
#                       extracted via `gh api repos/Blooym/
#                       skywrite/contents/src/commands/...`)
#
#   skywrite [GLOBAL OPTIONS] <SUBCOMMAND> [args...]
#
#   Global options  (apply to every subcommand):
#     --data-path <PATH>             Base directory to store
#                                    configuration files and
#                                    other persistent data
#                                    [env: SKYWRITE_DATA_PATH;
#                                     default: <local-config-
#                                     dir>/skywrite]
#     --database-url <URL>           SQLite connection string
#                                    (supports query parameters
#                                    like `?mode=rwc`)
#                                    [env: DATABASE_URL;
#                                     default: sqlite://<local-
#                                     config-dir>/skywrite/
#                                     db.sqlite3?mode=rwc]
#
#   Subcommands:
#     start [OPTIONS]                Start the bot and begin
#                                    checking for new RSS posts
#                                    on an interval
#       --app-service <URL>            Base URL of the AT-Proto
#                                      service to communicate
#                                      with  [env: SKYWRITE_
#                                      APP_SERVICE;
#                                      default: https://
#                                      bsky.social]
#       --app-identifier <ID>          Username or email of the
#                                      bot's account  (required)
#                                      [env: SKYWRITE_APP_
#                                      IDENTIFIER]
#       --app-password <PASS>          App password for
#                                      authentication
#                                      (required)
#                                      [env: SKYWRITE_APP_
#                                      PASSWORD]
#       --rerun-interval-seconds <N>   Interval in seconds
#                                      between checks for new
#                                      posts
#                                      [env: SKYWRITE_RERUN_
#                                      INTERVAL_SECONDS;
#                                      default: 300]
#       --rss-feed-backdate-hours <N>  Number of hours back to
#                                      check for missed posts
#                                      on startup
#                                      [env: SKYWRITE_RSS_
#                                      FEED_BACKDATE_HOURS;
#                                      default: 3]
#       --rss-feed-urls <CSV>          Comma-separated list of
#                                      RSS feed URLs to follow
#                                      (required)
#                                      [env: SKYWRITE_RSS_
#                                      FEED_URLS]
#       --disable-post-comments <BOOL>
#                                      Disable comments on the
#                                      Bluesky posts the bot
#                                      creates
#                                      [env: SKYWRITE_DISABLE_
#                                      POST_COMMENTS;
#                                      default: true]
#       --post-languages <CSV>         Comma-separated ISO-639-1
#                                      language codes to classify
#                                      posts under
#                                      [env: SKYWRITE_POST_
#                                      LANGUAGES;
#                                      default: en]
#
#     database <SUBCMD>              State-database CLI (skip
#                                    the polling loop)
#       insert-post <URL[,URL...]>     Insert one or more URLs
#                                      into the posted_urls
#                                      table so the bot will
#                                      skip them (does NOT post
#                                      to Bluesky)
#       remove-post <URL[,URL...]>     Remove one or more URLs
#                                      from the posted_urls
#                                      table so the bot will
#                                      consider them again
#                                      (does NOT delete from
#                                      Bluesky itself)
#       export-posts                   Export the posted_urls
#                                      table as a CSV to stdout
#
#   Standard clap auto-flags:
#     -h, --help                     Show help (root + each
#                                    subcommand)
#     -V, --version                  Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `bsky-sdk = "0.1.22"` declared in
#   Cargo.toml — `bsky-sdk` is THE canonical Rust ATProto /
#   Bluesky SDK, maintained by the atrium-rs project (atrium-
#   rs/atrium, 800+ stars; the predominant typed Rust client
#   for the AT Protocol and Bluesky's app.bsky.* lexicon,
#   used by every major Rust ATProto application —
#   skywrite, skywritings, microcosm-rs, pattern, isfegu/
#   musket, klausi/mastodon-bluesky-sync, mx-psi/bsky-deleter,
#   coreyja/pfp.blue, jerus-org/pcu, dave-andersen/pibot,
#   geesawra/atpage, and dozens of other downstream
#   consumers).  bsky-sdk exposes the typed `BskyAgent` (a
#   thin wrapper around `atrium-api::agent::AtpAgent`) with
#   `BskyAgent::builder().client(client).build().await` /
#   `agent.configure_endpoint(url)` /
#   `agent.login(identifier, password)` /
#   `agent.api.app.bsky.feed.post.create(...)` /
#   `agent.api.app.bsky.feed.post.delete(...)` /
