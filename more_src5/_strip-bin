#compdef strip
# _strip-bin — GNU binutils strip; remove symbols and sections from object files
# upstream: https://sourceware.org/binutils

_strip-bin() {
    _arguments \
        '(-I --input-target)'{-I,--input-target}'+[input target]:target:' \
        '(-O --output-target)'{-O,--output-target}'+[output target]:target:' \
        '(-F --target)'{-F,--target}'+[both targets]:target:' \
        '(-p --preserve-dates)'{-p,--preserve-dates}'[preserve dates]' \
        '(-D --enable-deterministic-archives)'{-D,--enable-deterministic-archives}'[deterministic archive]' \
        '(-R --remove-section)'{-R,--remove-section}'+[remove section]:section:' \
        '(-s --strip-all)'{-s,--strip-all}'[strip all symbols]' \
        '(-S --strip-debug -d -g)'{-S,--strip-debug,-d,-g}'[strip debug]' \
        '--strip-dwo[strip DWO sections]' \
        '--strip-unneeded[strip unneeded sym]' \
        '--strip-unneeded-symbol+[strip unneeded sym]:sym:' \
        '(-K --keep-symbol)'{-K,--keep-symbol}'+[keep sym]:sym:' \
        '(-N --strip-symbol)'{-N,--strip-symbol}'+[strip sym]:sym:' \
        '--keep-file-symbols[keep file symbols]' \
        '--keep-section-symbols[keep section symbols]' \
        '--only-keep-debug[keep only debug]' \
        '(-w --wildcard)'{-w,--wildcard}'[wildcard]' \
        '(-x --discard-all)'{-x,--discard-all}'[discard all local]' \
        '(-X --discard-locals)'{-X,--discard-locals}'[discard compiler local]' \
        '(-o)-o+[output file]:file:_files' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-h --help)'{-h,--help}'[show help]' \
        '*:file:_files'
}

_strip-bin "$@"
