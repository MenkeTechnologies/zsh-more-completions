#compdef skycoor
# _skycoor — convert sky-coordinate systems (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from skycoor.c (single-letter getopt-style).

_skycoor() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-a[position angle between two RA Dec pairs]' \
        '-b[output in B1950/FK4]' \
        '-d[output always in degrees]' \
        '-e[output in ecliptic]' \
        '-f+[file listing positions]:file:_files' \
        '-g[output in galactic]' \
        '-h[input RA in fractional hours]' \
        '-i+[input units]:units:(r d h s)' \
        '-j[output in J2000/FK5]' \
        '-k[RA and Dec angular separation]' \
        '-n+[decimal places in output]:n:' \
        '-o+[offset (seconds) to add]:secs:' \
        '-p+[proper motions (mas/year)]:pm:' \
        '-q+[output coordinate system]:sys:(J2000 B1950 FK5 FK4 GAL ECL)' \
        '-r[angular separation between two RA Dec pairs]' \
        '*:RA Dec:'
}

_skycoor "$@"
