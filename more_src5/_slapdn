#compdef slapdn
# _slapdn — OpenLDAP slapdn (validate distinguished names against slapd's DN normalization rules and the schemas declared in slapd.conf; -F config dir, -f slapd.conf, -P pretty form, -N normalised form, -d debug, -v verbose, -V version; positional argument is the DN to test)
# upstream: https://git.openldap.org/openldap/openldap (servers/slapd/slapdn)
# Flags from OpenLDAP servers/slapd/slapdn.c on tip.

_slapdn() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-F+[config dir]:dir:_files -/' \
        '-f+[slapd.conf]:file:_files' \
        '-P[pretty form]' \
        '-N[normalised form]' \
        '-d+[debug level]:level:' \
        '-v[verbose]' \
        '*:DN:'
}

_slapdn "$@"
