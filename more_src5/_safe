#compdef safe safe-cli
# _safe — Safe Global safe Smart Account CLI for Gnosis Safe multisig deployment owner management transaction batching and Safe-Transaction-Service interaction (safe-global team, Python); argparse
# upstream: https://github.com/safe-global/safe-cli

_safe() {
    local -a sub=(
        'show:show safe info'
        'deploy-safe:deploy new safe'
        'sign:sign transaction'
        'execute:execute transaction'
        'batch:batch transactions'
        'send:send safe transaction'
        'load-cli-owners:load CLI owners'
        'unload-cli-owners:unload CLI owners'
        'load-cli-owners-from-words:load from mnemonic'
        'enable-module:enable module'
        'disable-module:disable module'
        'change-threshold:change threshold'
        'change-master-copy:change master copy'
        'change-fallback-handler:change fallback handler'
        'change-guard:change guard'
        'add-owner:add owner'
        'remove-owner:remove owner'
        'swap-owner:swap owner'
        'update:update master copy'
        'history:show history'
        'tx-builder:transaction builder mode'
        'refresh:refresh safe info'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-r+[node url]:str:' \
        '--node-url=+[node url]:str:' \
        '--history[show history]' \
        '--get-safes-from-owner[get safes from owner]' \
        '--interactive[interactive mode]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'safe subcommand' sub ;;
        args)
            case $words[1] in
                deploy-safe) _arguments \
                    '--owners=+[csv addrs]:str:' \
                    '--threshold=+[N]:n:' \
                    '--fallback-handler=+[addr]:str:' \
                    '--singleton-address=+[addr]:str:' \
                    '--factory-address=+[addr]:str:' \
                    '--salt-nonce=+[N]:n:' \
                    '--private-key=+[hex]:str:' ;;
                sign|execute|send) _arguments \
                    '--private-key=+[hex]:str:' \
                    '*:safe addr:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_safe "$@"
