#compdef shorewall
# Documentation: https://shorewall.org/manpages/shorewall.html
# Reference accessed: 2026-05-21
# Verified: upstream shorewall(8) manpage at the URL above.
# Added missing commands per manpage: open, close, blacklist, call, run, savesets,
# export, reenable, noiptrace, remote-start, remote-reload, remote-restart,
# remote-getcaps, remote-getrc. Show subcommand list aligned with manpage.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add:add a host or subnet to a dynamic zone'
  'allow:re-enable a host previously dropped'
  'blacklist:manage blacklist entries'
  'call:invoke an internal function'
  'check:verify firewall configuration'
  'clear:clear all firewall rules'
  'close:close a previously opened connection'
  'compile:compile firewall script'
  'delete:remove a host or subnet from a dynamic zone'
  'disable:disable a provider'
  'drop:add a host to the dynamic drop list'
  'dump:display firewall state'
  'enable:enable a provider'
  'export:export compiled script to remote system'
  'forget:remove dynamic blacklist entries'
  'help:show help'
  'hits:display log hit counts'
  'ipdecrypt:decrypt packet log messages'
  'iptrace:trace a packet'
  'load:load rules onto remote firewall'
  'logdrop:drop and log traffic from host'
  'logreject:reject and log traffic from host'
  'logwatch:monitor firewall logs'
  'noiptrace:stop tracing a packet'
  'open:temporarily permit traffic'
  'reenable:re-enable a previously disabled provider'
  'refresh:refresh rules'
  'reject:add a host to the dynamic reject list'
  'reload:reload firewall configuration'
  'remote-getcaps:get capabilities from a remote firewall'
  'remote-getrc:get rc file from a remote firewall'
  'remote-reload:reload firewall on a remote system'
  'remote-restart:restart firewall on a remote system'
  'remote-start:start firewall on a remote system'
  'reset:reset traffic counters'
  'restart:restart the firewall'
  'restore:restore from saved state'
  'run:run an internal function or script'
  'safe-restart:restart with rollback on failure'
  'safe-start:start with rollback on failure'
  'save:save current state'
  'savesets:save dynamic ipsets'
  'show:show firewall state'
  'start:start the firewall'
  'status:display firewall status'
  'stop:stop the firewall'
  'try:try new configuration with rollback'
  'update:update configuration files'
  'version:show version'
)

_arguments -s -S \
  '1:command:->command' \
  '-4[IPv4 mode]' \
  '-6[IPv6 mode]' \
  '-l[lite mode]' \
  '-c+[specify configuration directory]:directory:_files -/' \
  '-D[enable debugging output]' \
  '-q[suppress informational messages]' \
  '-t[timestamp progress messages]' \
  '-T[trace script execution]' \
  '-v+[verbosity level 0-2]:level:(0 1 2)' \
  '-V[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'shorewall command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (show)
        local -a show_cmds=(
          'actions:show available actions'
          'action:show a specific action'
          'blacklists:show blacklist entries'
          'capabilities:show kernel capabilities'
          'classifiers:show classifier rules'
          'config:show configuration'
          'connections:show active connections'
          'event:show a specific event'
          'events:show events'
          'filters:show packet filters'
          'ip:show IP configuration'
          'ipa:show IPA accounting'
          'ipsec:show IPsec configuration'
          'log:show firewall log'
          'macro:show a specific macro'
          'macros:show available macros'
          'mangle:show mangle table'
          'marks:show marks'
          'nat:show NAT table'
          'opens:show open connections'
          'policies:show configured policies'
          'raw:show raw table'
          'rc:show rc file'
          'routing:show routing table'
          'rules:show rules'
          'saves:show saved states'
          'tc:show traffic control'
          'zones:show defined zones'
        )
        _describe -t commands 'show subcommand' show_cmds && ret=0
        ;;
      (add|delete)
        _arguments '1:zone' '2:host/subnet' && ret=0
        ;;
      (drop|reject|logdrop|logreject|allow|forget)
        _arguments '1:IP address' && ret=0
        ;;
      (try)
        _arguments '1:configuration directory:_files -/' '2:timeout' && ret=0
        ;;
      (enable|disable|reenable)
        _arguments '1:provider' && ret=0
        ;;
    esac
    ;;
esac

return ret
