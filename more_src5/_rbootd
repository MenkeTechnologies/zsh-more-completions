#compdef rbootd
# Documentation: man rbootd(8)
# Source: netbsd/src usr.sbin/rbootd — HP remote boot server (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[respond to boot requests from any machine]' \
    '-d[debug mode, display packets]' \
    '-i+[service boot requests on interface]:interface:_net_interfaces' \
    '1::config file (default /etc/rbootd.conf):_files' \
    && ret=0

return ret
