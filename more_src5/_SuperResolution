#compdef SuperResolution
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/SuperResolution.cxx — B-spline-based image super-resolution (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:imageDimension:(2 3 4)' \
    '2:outputImage:_files' \
    '3:domainImage:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '4:gradientSigma:_default' \
    '5:meshSize (e.g. 1x1x1):_default' \
    '6:numberOfLevels:_default' \
    '*:input images (low-res):_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    && ret=0

return ret
