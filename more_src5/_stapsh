#compdef stapsh
# Documentation: man stapsh(8)
# Source: SystemTap staprun/stapsh.c — stap remote shell helper (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-v[verbose (stackable)]' \
    '-l+[listen on TCP port]:port:_default' \
    && ret=0

return ret
