#compdef spt
# Documentation: https://github.com/Rigellute/spotify-tui
# Reference accessed: 2026-05-21
# Verified: src/cli/clap.rs (SubCommand::with_name)

# Zsh completion for spotify-tui (spt) - Spotify TUI client

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'playback:interact with current playback'
  'pb:interact with current playback (alias)'
  'play:start playback'
  'p:start playback (alias)'
  'list:list Spotify items'
  'l:list Spotify items (alias)'
  'search:search for items'
  's:search for items (alias)'
)

_arguments -s -S \
  '(-t --tick-rate)'{-t+,--tick-rate=}'[set tick rate in ms]:ms:' \
  '(-c --config)'{-c+,--config=}'[config directory]:directory:_files -/' \
  '--completions=[generate shell completions]:shell:(bash zsh fish powershell elvish)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'spt command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      playback|pb)
        _arguments \
          '(-d --device)'{-d+,--device=}'[device to use]:device:' \
          '(-f --format)'{-f+,--format=}'[output format]:format:' \
          '(-t --toggle)'{-t,--toggle}'[pause/resume playback]' \
          '(-s --status)'{-s,--status}'[print current playback status]' \
          '--share-track[print URL to current track]' \
          '--share-album[print URL to current album]' \
          '--transfer=[transfer playback to DEVICE]:device:' \
          '--like[like the current song]' \
          '--dislike[dislike the current song]' \
          '--shuffle[toggle shuffle mode]' \
          '--repeat[cycle repeat mode]' \
          '(-n --next)'{-n,--next}'[next track]' \
          '(-p --previous)'{-p,--previous}'[previous track]' \
          '--seek=[seek by milliseconds]:ms:' \
          '--volume=[set volume 0-100]:volume:'
        ;;
      play|p)
        _arguments \
          '(-d --device)'{-d+,--device=}'[device to use]:device:' \
          '(-f --format)'{-f+,--format=}'[output format]:format:' \
          '(-u --uri)'{-u+,--uri=}'[play a Spotify URI]:uri:' \
          '(-n --name)'{-n+,--name=}'[name to search and play]:name:' \
          '(-q --queue)'{-q,--queue}'[add to queue instead of playing]' \
          '(-r --random)'{-r,--random}'[play random track from context]' \
          '(-a --album)'{-a,--album}'[play an album]' \
          '--artist[play an artist]' \
          '(-t --track)'{-t,--track}'[play a track]' \
          '--show[play a show]' \
          '--playlist[play a playlist]'
        ;;
      list|l)
        _arguments \
          '(-d --device)'{-d+,--device=}'[device to use]:device:' \
          '(-f --format)'{-f+,--format=}'[output format]:format:' \
          '--devices[list devices]' \
          '--playlists[list playlists]' \
          '--liked[list liked songs]' \
          '--limit=[limit results]:limit:'
        ;;
      search|s)
        _arguments \
          '(-d --device)'{-d+,--device=}'[device to use]:device:' \
          '(-f --format)'{-f+,--format=}'[output format]:format:' \
          '--albums[search albums]' \
          '--artists[search artists]' \
          '--playlists[search playlists]' \
          '--tracks[search tracks]' \
          '--shows[search shows]' \
          '--limit=[limit results]:limit:' \
          '*:search query:'
        ;;
    esac
    ;;
esac

return ret
