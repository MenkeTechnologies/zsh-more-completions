#compdef SimulateDisplacementField
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/SimulateDisplacementField.cxx — synthesize random BSpline/Exponential displacement field (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:imageDimension:(2 3 4)' \
    '2:displacementFieldType:(BSpline Exponential)' \
    '3:domainImage:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '4:outputField:_files' \
    '5::numberOfRandomPoints (default 1000):_default' \
    '6::standardDeviationDisplacementField (default 10):_default' \
    '7::enforceStationaryBoundary (default 1):(0 1)' \
    '*:type-specific options (BSpline: numFittingLevels numControlPoints; Exponential: smoothingStdDev):_default' \
    && ret=0

return ret
