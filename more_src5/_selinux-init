#compdef selinux-init fixfiles selinux-autorelabel
# _selinux-init — SELinux init helpers (fixfiles + selinux-autorelabel + selinux-init scripts handle relabel-on-next-boot and reset SELinux contexts at startup; subcommands: check, restore, verify, relabel, onboot; -F force full relabel, -l logfile, -R store path filter, -v verbose, -h help)
# upstream: https://github.com/SELinuxProject/selinux
# Flags from SELinuxProject/selinux policycoreutils/fixfiles on tip.

_selinux-init() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-F[full relabel]' \
        '-f[fast (skip md5)]' \
        '-l+[log file]:file:_files' \
        '-R+[store path filter]:path:_files' \
        '-v[verbose]' \
        '-N[no kernel reset]' \
        '1::command:(check restore verify relabel onboot)' \
        '*::path:_files'
}

_selinux-init "$@"
