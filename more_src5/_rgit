#compdef rgit
# _rgit — fast cgit alternative, browse git repos via HTTP (w4/rgit)
# upstream: https://github.com/w4/rgit
# Flags from src/main.rs (clap derive Args).

_rgit() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-d --db-store)'{-d+,--db-store=}'[directory to store RocksDB database]:dir:_files -/' \
        '--repository-list=[file of whitelisted repositories]:file:_files' \
        '--refresh-interval=[metadata refresh interval (eg. never or 60s)]:interval:' \
        '--request-timeout=[request timeout (eg. 10s)]:duration:' \
        '1:bind address (host:port):' \
        '2:scan path (dir of bare git repos):_files -/'
}

_rgit "$@"
