#compdef spice
# Documentation: https://spiceai.org/docs
# Reference accessed: 2026-05-27
# Verified: upstream clap definitions at github.com/spiceai/spiceai (bin/spice/src/main.rs and bin/spice/src/commands/*.rs)

# Zsh completion for spice (Spice.ai client CLI)

local curcontext="$curcontext" state line ret=1

local -a _spice_subcommands
_spice_subcommands=(
  'version:print Spice CLI and runtime version'
  'install:download and install the Spice runtime (alias: i)'
  'i:alias for install'
  'upgrade:upgrade the Spice runtime to a newer version'
  'run:run the Spice runtime'
  'status:print runtime status'
  'init:scaffold a new Spice app (spicepod.yaml)'
  'add:add a Spicepod dependency'
  'connect:connect this Spicepod to a Spice runtime'
  'validate:validate the local spicepod.yaml'
  'dataset:add or configure datasets in spicepod.yaml'
  'catalog:add or configure catalog entries in spicepod.yaml'
  'model:add or configure model entries in spicepod.yaml'
  'view:add or configure view entries in spicepod.yaml'
  'embedding:add or configure embedding entries in spicepod.yaml'
  'reranker:add or configure reranker entries in spicepod.yaml'
  'tool:add or configure tool entries in spicepod.yaml'
  'worker:add or configure worker entries in spicepod.yaml'
  'function:add or configure function entries in spicepod.yaml'
  'secret:add or configure secret entries in spicepod.yaml'
  'runtime:configure the runtime: section of spicepod.yaml'
  'management:configure the management: section of spicepod.yaml'
  'snapshots:configure the snapshots: section of spicepod.yaml'
  'extension:configure extensions in spicepod.yaml'
  'metadata:configure metadata in spicepod.yaml'
  'pods:list pods loaded by the runtime'
  'datasets:list datasets in the runtime'
  'catalogs:list catalogs in the runtime'
  'models:list models in the runtime'
  'workers:list workers in the runtime'
  'trace:print traces from the runtime'
  'sql:open the SQL REPL against the runtime'
  'query:submit a query and inspect query state'
  'nsql:natural-language to SQL prompt'
  'search:vector or hybrid search across datasets'
  'chat:chat with a model served by the runtime'
  'refresh:trigger a refresh of an accelerated dataset'
  'acceleration:manage dataset acceleration'
  'login:authenticate with a data source or Spice.ai Cloud'
  'cloud:manage Spice.ai Cloud resources'
  'cluster:manage Spice runtime cluster nodes'
  'completions:generate shell completion scripts'
  'feedback:open the Spice.ai community Slack to share feedback'
  'help:print help for a subcommand'
)

local -a _spice_global_opts
_spice_global_opts=(
  '*'{-v,--verbose}'[increase log verbosity (-v debug, -vv trace)]'
  '--machine[machine-readable mode (JSON output and structured errors)]'
  '--programmatic[alias for --machine]'
  '--api-key=[API key for runtime or Spice.ai Cloud]:key:'
  '--cloud[target Spice.ai Cloud instead of local runtime]'
  '--cloud-region=[Spice.ai Cloud runtime endpoint region]:region:'
  '--http-endpoint=[HTTP endpoint of the Spice runtime]:url:'
  '--tls-root-certificate-file=[PEM root certificate to verify the runtime]:file:_files'
  '(-h --help)'{-h,--help}'[print help]'
  '(-V --version)'{-V,--version}'[print version]'
)

_arguments -C \
  $_spice_global_opts \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'spice subcommand' _spice_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments \
          '1:name:' && ret=0
        ;;
      install|i)
        _arguments \
          '(-f --force)'{-f,--force}'[force installation even if already installed]' \
          '*:args (version and/or flavor):(cuda)' && ret=0
        ;;
      upgrade)
        _arguments \
          '(-f --force)'{-f,--force}'[force upgrade even if already at the target version]' \
          '1:target_version:' && ret=0
        ;;
      run)
        _arguments \
          '--endpoint=[runtime endpoint with scheme (http://, https://, grpc://, grpc+tls://)]:endpoint:' \
          '--http-endpoint=[runtime HTTP endpoint for binding]:bind:' \
          '--flight-endpoint=[runtime Flight endpoint]:bind:' \
          '--metrics-endpoint=[runtime Prometheus metrics endpoint]:bind:' \
          '*::spiced args:' && ret=0
        ;;
      login)
        local -a login_subs
        login_subs=(
          'dremio:login to a Dremio instance'
          's3:login to S3 storage'
          'postgres:login to a Postgres instance'
          'snowflake:login to a Snowflake warehouse'
          'databricks:login to a Databricks instance'
          'delta-lake:configure credentials for a Delta Lake table'
          'spark:login to a Spark Connect remote'
          'sharepoint:login to a Microsoft 365 SharePoint account'
          'abfs:login to an Azure Blob Storage (ABFS) account'
        )
        _arguments \
          '(-k --key)'{-k+,--key=}'[API key for direct authentication (skips OAuth)]:key:' \
          '(-o --output)'{-o+,--output=}'[where to store the resulting credentials]:dest:(env json keychain)' \
          '1: :->login_sub' \
          '*:: :->login_args' && ret=0
        case $state in
          login_sub)
            _describe -t commands 'spice login subcommand' login_subs && ret=0
            ;;
        esac
        ;;
      chat)
        _arguments \
          '(-m --model)'{-m+,--model=}'[model name]:model:' \
          '--temperature=[sampling temperature]:float:' \
          '--endpoint=[runtime endpoint]:url:' \
          '*--headers=[custom HTTP header]:KEY\:VALUE:' \
          '(-o --output)'{-o+,--output=}'[output format]:fmt:(table json)' \
          '*::message:' && ret=0
        ;;
      query)
        local -a query_subs
        query_subs=(
          'list:list queries'
          'status:show status of a query'
          'results:fetch results of a query'
          'cancel:cancel a query'
        )
        _arguments \
          '--no-wait[submit without waiting for completion]' \
          '--timeout=[max wait time (e.g. 30s)]:duration:' \
          '(-o --output)'{-o+,--output=}'[output format]:fmt:(table json)' \
          '1: :->query_first' \
          '*:: :->query_rest' && ret=0
        case $state in
          query_first)
            _describe -t commands 'spice query subcommand' query_subs && ret=0
            _message 'sql query'
            ret=0
            ;;
          query_rest)
            case $line[1] in
              list)
                _arguments \
                  '--status=[filter by status]:status:(pending running succeeded failed cancelled)' \
                  '--limit=[max queries to return]:n:' \
                  '(-o --output)'{-o+,--output=}'[output format]:fmt:(table json)' && ret=0
                ;;
              status|results|cancel)
                _arguments \
                  '(-o --output)'{-o+,--output=}'[output format]:fmt:(table json)' \
                  '1:query_id:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      sql)
        _arguments \
          '--endpoint=[runtime endpoint]:url:' \
          '--flight-endpoint=[Flight endpoint]:url:' \
          '--cache-control=[cache control]:value:(cache no-cache)' \
          '--tls-root-certificate-file=[PEM root certificate]:file:_files' \
          '--client-tls-certificate-file=[client TLS certificate file]:file:_files' \
          '--client-tls-key-file=[client TLS key file]:file:_files' \
          '*--headers=[custom HTTP header]:KEY\:VALUE:' \
          '(-x --expanded)'{-x,--expanded}'[expanded vertical output]' \
          '(-o --output)'{-o+,--output=}'[output format]:fmt:(table json)' \
          '1:query:' && ret=0
        ;;
      search)
        _arguments \
          '(-l --limit)'{-l+,--limit=}'[max results]:n:' \
          '--cache-control=[cache control]:value:(cache no-cache)' \
          '--model=[model name]:model:' \
          '--endpoint=[runtime endpoint]:url:' \
          '*--headers=[custom HTTP header]:KEY\:VALUE:' \
          '(-o --output)'{-o+,--output=}'[output format]:fmt:(table json)' && ret=0
        ;;
      datasets|catalogs|models|pods|workers)
        _arguments \
          '(-o --output)'{-o+,--output=}'[output format]:fmt:(table json)' && ret=0
        ;;
      dataset)
        local -a dataset_subs
        dataset_subs=(
          'add:add a dataset to spicepod.yaml'
          'configure:create or update a dataset (or run interactively)'
        )
        _arguments \
          '--from=[provider/URI (e.g. s3://..., databricks:catalog.schema.table)]:source:' \
          '--description=[human-readable description]:text:' \
          '*--param=[params: entry (KEY=VALUE)]:KEY=VALUE:' \
          '*--set=[set any schema field by dotted path]:PATH=VALUE:' \
          '*--depends-on=[append to dependsOn:]:name:' \
          '--enable[set enabled: true]' \
          '--disable[set enabled: false]' \
          '--file=[read dataset body from file]:file:_files' \
          '--stdin[read dataset body from stdin]' \
          '--manifest=[edit a non-default Spicepod file]:file:_files' \
          '1: :->dataset_sub' \
          '*:: :->dataset_rest' && ret=0
        case $state in
          dataset_sub)
            _describe -t commands 'spice dataset subcommand' dataset_subs && ret=0
            ;;
        esac
        ;;
      add)
        _arguments \
          '1:pod_path:' && ret=0
        ;;
      refresh)
        _arguments \
          '--refresh-sql=[SQL filter to apply during refresh]:sql:' \
          '--refresh-mode=[refresh mode]:mode:' \
          '--refresh-jitter-max=[max jitter]:duration:' \
          '(-o --output)'{-o+,--output=}'[output format]:fmt:(table json)' \
          '1:dataset:' && ret=0
        ;;
      completions)
        _arguments \
          '--stdout[print completions to stdout instead of writing to a file]' \
          '1:shell:(bash zsh fish elvish powershell)' && ret=0
        ;;
      help)
        _describe -t commands 'spice subcommand' _spice_subcommands && ret=0
        ;;
      *)
        _arguments '*:argument:' && ret=0
        ;;
    esac
    ;;
esac

return ret
