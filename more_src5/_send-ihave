#compdef send-ihave
# Documentation: man send-ihave(8)
# Source: InterNetNews/inn backends/send-ihave.in — batch IHAVE control messages (sh).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d[debug — do not redirect output to log]' \
    '*:site[:host]:_default' \
    && ret=0

return ret
