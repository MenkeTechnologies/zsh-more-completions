#compdef spades spades.py
# Documentation: https://ablab.github.io/spades/running.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# SPAdes: de novo genome / transcriptome assembler
# Library numbered options use --pe<#>-1, --pe<#>-2, --pe<#>-12, etc. where
# <#> is 1-9 (library index). For brevity, only the library-1 forms are listed.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-v[show version]' \
  '-o[output directory]:dir:_files -/' \
  '--test[run on toy dataset]' \
  '-1[forward reads file]:file:_files -g "*.(fq|fastq|gz|bz2)"' \
  '-2[reverse reads file]:file:_files -g "*.(fq|fastq|gz|bz2)"' \
  '--12[interlaced paired-end reads]:file:_files' \
  '-s[unpaired reads]:file:_files' \
  '--pe1-1[forward reads for paired library 1]:file:_files' \
  '--pe1-2[reverse reads for paired library 1]:file:_files' \
  '--pe1-12[interlaced reads for paired library 1]:file:_files' \
  '--pe1-s[unpaired reads for paired library 1]:file:_files' \
  '--pe1-or[paired library 1 orientation]:orient:(fr rf ff)' \
  '--mp1-1[mate-pair forward reads library 1]:file:_files' \
  '--mp1-2[mate-pair reverse reads library 1]:file:_files' \
  '--mp1-12[mate-pair interlaced reads library 1]:file:_files' \
  '--mp1-or[mate-pair orientation library 1]:orient:(fr rf ff)' \
  '--hqmp1-1[high-quality mate-pair forward library 1]:file:_files' \
  '--hqmp1-2[high-quality mate-pair reverse library 1]:file:_files' \
  '--s1[unpaired reads library 1]:file:_files' \
  '--nanopore[Oxford Nanopore long reads]:file:_files' \
  '--pacbio[PacBio CLR reads]:file:_files' \
  '--sanger[Sanger reads]:file:_files' \
  '--trusted-contigs[trusted assembled contigs]:file:_files' \
  '--untrusted-contigs[untrusted contigs]:file:_files' \
  '--only-error-correction[run only error correction]' \
  '--only-assembler[run only assembly]' \
  '--careful[careful mode (slower, fewer mismatches)]' \
  '--checkpoints[save checkpoint after each k]:mode:' \
  '--continue[continue from last checkpoint]' \
  '--restart-from=[restart from stage]:stage:(ec as k mc last)' \
  '--disable-gzip-output[do not gzip outputs]' \
  '-k[k-mer sizes (comma list)]:k:' \
  '--cov-cutoff=[coverage cutoff]:val:' \
  '--phred-offset=[FASTQ Phred offset]:offset:(33 64)' \
  '-t[number of threads]:n:' \
  '--threads[number of threads]:n:' \
  '-m[memory limit (GB)]:GB:' \
  '--memory[memory limit (GB)]:GB:' \
  '--meta[metagenomic SPAdes]' \
  '--metaplasmid[metaplasmid SPAdes]' \
  '--metaviral[metaviral SPAdes]' \
  '--plasmid[plasmid SPAdes]' \
  '--rna[RNA-Seq mode]' \
  '--iontorrent[IonTorrent read mode]' \
  '--bio[biosynthetic gene cluster mode]' \
  '--corona[coronaSPAdes mode]' \
  '--rnaviral[RNA virus mode]' \
  '--isolate[isolate genome mode]' \
  '--sc[single-cell mode]' \
  '--sewage[sewage / wastewater mode]' \
  '--dataset[YAML dataset description]:file:_files' \
  '*:input reads:_files' && ret=0
return ret
