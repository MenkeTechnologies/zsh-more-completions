#compdef segment-cli segment-cli2 twilio-segment-cli
# _segment-cli — Twilio Segment segment-cli CLI command-line frontend wrapping the Twilio Segment Customer Data Platform CDP REST API managing workspaces sources destinations functions warehouses connections protocols tracking-plans events identifies pages screens groups aliases audiences computed-traits Reverse-ETL Engage Profile API (Twilio Segment team, Go); cobra
# upstream: https://segment.com/

_segment-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'workspace:workspace management'
        'source:source management'
        'destination:destination management'
        'function:function management'
        'warehouse:warehouse management'
        'connection:connection management'
        'tracking-plan:tracking plan management'
        'protocols:protocols operations'
        'audience:audience management'
        'computed-trait:computed-trait management'
        'reverse-etl:Reverse ETL operations'
        'event:event tracking'
        'identify:identify a user'
        'page:page tracking'
        'screen:screen tracking'
        'group:group tracking'
        'alias:alias mapping'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--token=+[token]:str:' \
        '--workspace=+[name]:str:' \
        '--region=+[r]:r:(us eu)' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'segment-cli subcommand' sub ;;
        args)
            case $words[1] in
                workspace|source|destination|function|warehouse|connection|tracking-plan|protocols|audience|computed-trait|reverse-etl) _arguments '1:op:(list get create update delete enable disable)' '*:id:' ;;
                event|identify|page|screen|group|alias) _arguments '*:payload:_files -g "*.json *.yaml"' ;;
            esac
            ;;
    esac
}

_segment-cli "$@"
