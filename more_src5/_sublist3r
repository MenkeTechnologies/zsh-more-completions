_arguments -s -S \
  '(-d --domain)'{-d+,--domain=}'[domain name to enumerate subdomains for (required)]:domain:_hosts' \
  '(-b --bruteforce)'{-b,--bruteforce}'[enable the subbrute bruteforce module]' \
  '(-p --ports)'{-p+,--ports=}'[scan found subdomains against these TCP ports]:port-list:' \
  '(-v --verbose)'{-v,--verbose}'[enable verbosity and display results in realtime]' \
  '(-t --threads)'{-t+,--threads=}'[number of threads for subbrute bruteforce (default 30)]:n:' \
  '(-e --engines)'{-e+,--engines=}'[comma-separated list of search engines]:engines:_values -s , engine baidu yahoo google bing ask netcraft dnsdumpster virustotal threatcrowd ssl passivedns' \
  '(-o --output)'{-o+,--output=}'[save results to text file]:file:_files' \
  '(-n --no-color)'{-n,--no-color}'[output without ANSI color]'
