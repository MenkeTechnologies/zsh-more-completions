#compdef shacl
# Documentation: https://jena.apache.org/documentation/shacl/
# Source: apache/jena SHACL command-line tool (validate + parse subcommands).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '1:subcommand:((
        validate\:"validate data against SHACL shapes"
        v\:"alias for validate"
        parse\:"parse shapes and emit text representation"
        p\:"alias for parse"
    ))' \
    '*::subcommand-args:->subarg' \
    && ret=0

case $state in
    subarg)
        case $words[1] in
            (validate|v)
                _arguments -s \
                    '(-s --shapes)'{-s+,--shapes=}'[shapes file (default = data file)]:file:_files -g "*.(ttl|nt|nq|trig|rdf)(-.)"' \
                    '(-d --data)'{-d+,--data=}'[data file]:file:_files -g "*.(ttl|nt|nq|trig|rdf)(-.)"' \
                    && ret=0
                ;;
            (parse|p)
                _arguments -s \
                    '--out=[output format (csv: text/t, compact/c, rdf/r, all)]:format:(text t compact c rdf r all)' \
                    '*:shapes file:_files -g "*.(ttl|nt|nq|trig|rdf)(-.)"' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
