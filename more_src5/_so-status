#compdef so-status
# _so-status — Security Onion so-status CLI showing health and uptime of Security Onion services Suricata Zeek Elasticsearch Kibana Logstash Filebeat Strelka Hunt MISP Cortex (security-onion team, Bash); getopt
# upstream: https://github.com/Security-Onion-Solutions/securityonion

_so-status() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-w[watch mode]' \
        '--watch[watch mode]' \
        '-i+[interval seconds]:n:' \
        '--interval=+[interval seconds]:n:' \
        '-n+[node]:str:' \
        '--node=+[node]:str:' \
        '-r+[role]:r:(manager forward heavy search storage standalone)' \
        '--role=+[role]:r:(manager forward heavy search storage standalone)' \
        '-s+[service]:s:(suricata zeek elasticsearch kibana logstash filebeat strelka hunt misp cortex playbook fleet osquery curator soctopus thehive elastalert dockerregistry)' \
        '--service=+[service]:s:(suricata zeek elasticsearch kibana logstash filebeat strelka hunt misp cortex)' \
        '--json[json output]' \
        '--no-color[no color]'
}

_so-status "$@"
