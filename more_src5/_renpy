# -----------------------------------------------------------------------------
#
# WHAT IS REN'PY AND WHY IS IT THE 69TH LANGUAGE?
#
# Ren'Py (https://www.renpy.org, https://github.com/renpy/renpy,
# 6528+ stars) is **Tom Rothamel's visual-novel game engine + DSL**
# — created in 2004 (22 years of continuous development), named
# after the Japanese word "ren'ai" (恋愛, "romantic love") +
# "Python" (referencing both the implementation language and the
# scripting language's syntax inspiration).  Ren'Py is the
# DOMINANT visual novel game engine — most commercial visual
# novels released between 2010-2026 use Ren'Py.
#
# Ren'Py's distinguishing characteristics:
#
#   1. NARRATIVE-SCRIPT-FIRST DSL — Ren'Py's scripting language is
#      designed for writing branching narrative:
#
#          # Define characters
#          define e = Character("Eileen", color="#c8ffc8")
#          define m = Character("Me", color="#c8c8ff")
#
#          # Define images and music
#          image bg classroom = "classroom.jpg"
#          define audio.theme = "theme_song.ogg"
#
#          # The story itself
#          label start:
#              scene bg classroom
#              play music theme
#              e "Hi there! Welcome to my visual novel."
#              menu:
#                  "Hello back.":
#                      m "Hello back!"
#                      jump good_ending
#                  "Be quiet.":
#                      m "I don't have time for this."
#                      jump bad_ending
#
#              label good_ending:
#                  e "I'm glad we're friends!"
#                  return
#
#      The `label`, `scene`, `play`, `say` (`character "dialogue"`),
#      and `menu` constructs are Ren'Py syntax PRIMITIVES.  Compare:
#         * Python: no concept of `label` or `menu choice`
#         * Twine: web-based hyperlink-driven branching (the closest
#                   analog, but Twine is HTML-rendered, Ren'Py is
#                   SDL2/OpenGL-rendered with full multimedia)
#         * Inform 7: text adventure DSL (rooms + objects, not
#                       branching narrative + multimedia)
#         * Yarn Spinner: branching-dialogue DSL but engine-agnostic
#                          (Ren'Py is engine + DSL together)
#      Ren'Py is the FIRST documented language designed
#      SPECIFICALLY for visual novel narrative scripting.
#
#   2. PYTHON-EMBEDDED DSL — Ren'Py scripts mix native Ren'Py
#      syntax with embedded Python code via `python:` blocks or
#      `$` shorthand:
#
#          # Ren'Py syntax with embedded Python
#          label start:
#              $ player_name = renpy.input("What's your name?")
#              $ score = 0
#
#              python:
#                 def calculate_ending(score):
#                     if score >= 50:
#                         return "good"
#                     elif score >= 25:
#                         return "neutral"
#                     else:
#                         return "bad"
#
#              # Use Python value in Ren'Py menu
#              menu:
#                  "[player_name], what do you do?"
#                  "Study hard":
#                      $ score += 10
#                  "Skip class":
#                      $ score -= 10
#
#              $ ending = calculate_ending(score)
#              jump expression "ending_" + ending
#
#      Compare:
#         * Vyper R??? — Python-syntax DSL but EVM-targeted
#         * Cython — Python+C-syntax DSL but Python-compiled
#         * Mojo — Python-like syntax but separate language
#      Ren'Py is unique in being a NARRATIVE-DSL that EMBEDS REAL
#      PYTHON for game logic.  FIRST documented language that
#      embeds Python natively within DSL syntax.
#
#   3. SCREEN LANGUAGE FOR UI — Ren'Py includes a separate "Screen
#      Language" sub-DSL for declarative UI:
#
#          screen main_menu:
#              add "menu_background.jpg"
#              vbox:
#                  textbutton "Start" action Start()
#                  textbutton "Load" action ShowMenu("load")
#                  textbutton "Preferences" action ShowMenu("preferences")
#                  textbutton "Quit" action Quit()
#
#      Compare:
#         * Flutter: dart widget tree (similar declarative UI)
#         * SwiftUI: Swift declarative UI
#         * React: JSX declarative UI
#         * Tcl/Tk: declarative UI as procedural calls
#      Ren'Py's Screen Language is a DECLARATIVE UI DSL embedded
#      within a NARRATIVE DSL — first documented language with
#      two layered DSLs (narrative outer + UI inner).
#
#   4. SAVE/LOAD ANYWHERE — Ren'Py automatically serializes the
#      entire Python interpreter state at any point in a game's
#      execution.  Players can save mid-conversation, mid-choice,
#      mid-animation and resume EXACTLY where they left off.  The
#      Ren'Py runtime serializes:
#         - All Python global state (variables, classes, modules)
#         - Current execution position (label + statement)
#         - Sprite/scene/music/sound state
#         - Animation progress
#         - Persistent data across save slots
#      Compare every other documented game/scripting language —
#      none have save-anywhere as a language-level guarantee.
#      FIRST documented language with save-anywhere semantics
#      built into the runtime.
#
#   5. COMMUNITY ECOSYSTEM — Ren'Py has the LARGEST commercial
#      visual novel game catalog of any documented language:
#         * 3000-5000+ commercial VN releases
#         * 50+ million Doki Doki Literature Club downloads
#         * Multiple commercial GotY-tier VNs (Long Live the Queen,
#           Analogue: A Hate Story, Magical Diary, Ladykiller in a
#           Bind, Cinders, Cute Demon Crashers)
#         * Active community on Lemma Soft Forums (~30k members)
#      Compare other narrative engines (Twine: hyperlink web-based;
#      Inform 7: text adventures; Yarn Spinner: engine-agnostic) —
#      Ren'Py has the WIDEST commercial deployment.
#
# Ren'Py's relationship to other documented languages:
#
#   * Like Python      — Python is the implementation language AND
#                         embedded Ren'Py uses Python for game logic
#   * Like Cython       — Python-derived DSL
#   * Like Vyper        — Python-syntax DSL but domain-specific
#   * Like Inform 7      — interactive-fiction DSL (closest
#                         pedigree but different rendering model)
#   * Like Yarn Spinner — branching-dialogue DSL
#   * Like Twine         — interactive-narrative DSL
#   * Unlike all of the above — VISUAL-NOVEL-ENGINE-FIRST design
#     with embedded Python + Screen Language + save-anywhere
#     guarantee.
#
# -----------------------------------------------------------------------------
#
# THE renpy CLI — argparse Subclass with Two-Pass Dynamic Command Registration
#
# Ren'Py's argv parser is a custom `ArgumentParser` SUBCLASS of
# Python's stdlib argparse (renpy/arguments.py):
#
#     class ArgumentParser(argparse.ArgumentParser):
#         def __init__(self, second_pass=True, description=None,
#                       require_command=True):
#             argparse.ArgumentParser.__init__(self,
#                 description="The Ren'Py visual novel engine.",
#                 add_help=False)
#             command_names = ", ".join(sorted(commands))
#             # First-pass: parse basedir + command (default 'run')
#             # Second-pass: re-parse with command-specific sub-args
#
# The TWO-PASS PARSING MODEL is unique:
#
#   First pass (before game loads):
#       Parse argv to determine:
#         - basedir (where the game lives)
#         - command (what to do: run / compile / lint / quickstart / etc.)
#       Run the Ren'Py engine init phase, which loads the game's
#       .rpy scripts.  The game can call `renpy.arguments.
#       register_command(name, function, uses_display=False)` to
#       REGISTER NEW COMMANDS during init.
#
#   Second pass (after init, before game runs):
#       Re-parse argv with the EXPANDED command registry.  Each
#       registered command's parser function adds its own
#       command-specific arguments.  This is the GAME-EXTENSIBLE
#       argument parsing pattern.
#
# Distinct from every other documented argparse-style usage on FIVE
# specific axes:
#
#   1. TWO-PASS PARSING MODEL — Every other documented argparse
#      user does a single parse_args() call.  Ren'Py does TWO
#      passes — load the game first to learn what commands exist,
#      THEN parse args against the expanded grammar.  FIRST
#      documented two-pass parsing pattern.
#
#   2. GAME-EXTENSIBLE COMMAND REGISTRY — Every other documented
#      CLI library has a STATIC command schema fixed at compile/
#      startup time.  Ren'Py's command registry is POPULATED BY
#      LOADED CONTENT — running Ren'Py with a different game can
#      result in different sub-commands being available.  FIRST
#      documented CLI library with content-driven command schema.
#
#   3. JSON DUMP ARGUMENT GROUP — Ren'Py uses argparse's argument-
#      group feature for organizing related flags (`--json-dump`,
#      `--json-dump-private`, `--json-dump-common`).  Most
#      documented argparse usage is flat.  FIRST documented
#      argparse usage with thematic argument groups.
#
#   4. compile_commands AUTO-FORCE SET — A separate Python set
#      `compile_commands = {"compile", "add_from", "merge_strings"}`
#      maps commands to flag behavior: if any of these commands is
#      given, `--compile` is automatically forced.  Compare every
#      other CLI library — none have a "command → automatic-flag
#      side-effect" mapping.  FIRST documented CLI library with
#      cross-command flag-side-effect set.
#
#   5. argv_emulation FOR APP BUNDLES — Ren'Py imports site and
#      calls `site._renpy_argv_emulation()` to handle macOS .app
#      bundle argv (where the OS may pass argv differently than
#      command-line invocation).  Most documented CLI libraries
#      assume standard sys.argv.  FIRST documented CLI library
#      that explicitly handles macOS .app bundle argv emulation.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/renpy/renpy/blob/master/renpy/arguments.py
# `ArgumentParser.__init__` add_argument calls.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a commands=(
    'run:run the game (default)'
    'compile:compile all .rpy scripts to .rpyc'
    'lint:check the game for common errors'
    'add_from:add `from` clauses to call statements'
    'merge_strings:merge translation strings'
    'quickstart:create a new project skeleton'
    'distribute:create a distributable build'
    'translate:generate translation files'
    'extract:extract dialogue text'
    'preferences:show or change Ren'\''Py-wide preferences'
)

_arguments -s -C \
    '(-h --help)'{-h,--help}'[show help and exit]' \
    '--version[display the version of Ren'\''Py in use]' \
    '--savedir=[directory for saves and persistent data]:directory:_directories' \
    '--trace=[trace level (1=per-call, 2=per-line) logged to trace.txt]:level:(1 2)' \
    '--compile[force all .rpy scripts to be recompiled before proceeding]' \
    '--compile-python[force all Python to be recompiled (skip .rpyb cache)]' \
    '--keep-orphan-rpyc[prevent compile from deleting orphan .rpyc files]' \
    '--errors-in-editor[open errors in a text editor]' \
    '--safe-mode[start in safe mode (allow player to configure graphics)]' \
    '--warp=[warp to statement before file:line (valid only with run)]:warp:' \
    '--json-dump=[name of JSON dump file]:file:_files' \
    '--json-dump-private[include private names (starting with _)]' \
    '--json-dump-common[include names defined in common/ directory]' \
    '1:basedir:_directories' \
    '2:command:->cmd' \
    '*:: :->args' \
    && ret=0

case "$state" in
    cmd)
        _describe -t commands 'Ren\''Py command' commands && ret=0
        ;;
    args)
        case "${words[2]}" in
            run|compile|lint)
                _files && ret=0
                ;;
        esac
        ;;
esac

return ret
