#compdef scan-build-py
# Documentation: https://clang-analyzer.llvm.org/
# Source: llvm/llvm-project clang/tools/scan-build-py/lib/libscanbuild/arguments.py — Python rewrite of scan-build (argparse).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--append[append to existing report DB]' \
    '--intercept-first[run compilation database extraction step first]' \
    '--status-bugs[exit with non-zero status if bugs found]' \
    '*--exclude=-[exclude path from analysis]:path:_files -/' \
    '(-o --output)'{-o+,--output=}'[output directory]:dir:_files -/' \
    '--keep-empty[keep empty report dirs]' \
    '--html-title=-[HTML report title]:title:_default' \
    '(--plist -plist)'{--plist,-plist}'[generate plist reports]' \
    '(--plist-html -plist-html)'{--plist-html,-plist-html}'[generate plist + HTML]' \
    '(--plist-multi-file -plist-multi-file)'{--plist-multi-file,-plist-multi-file}'[generate multi-file plist]' \
    '(--sarif -sarif)'{--sarif,-sarif}'[generate SARIF output]' \
    '(--sarif-html -sarif-html)'{--sarif-html,-sarif-html}'[generate SARIF + HTML]' \
    '--use-analyzer=-[path to clang analyzer]:bin:_files' \
    '--use-cc=-[path to C compiler]:bin:_files' \
    '--use-extdef-map-cmd=-[command to build external def map]:cmd:_default' \
    '(--no-failure-reports -no-failure-reports)'{--no-failure-reports,-no-failure-reports}'[do not save reports for failed analyses]' \
    '--analyze-headers[analyze functions in #included headers]' \
    '(--stats -stats)'{--stats,-stats}'[enable analyzer stats]' \
    '--internal-stats[generate internal analyzer stats]' \
    '(--maxloop -maxloop)'{--maxloop+,-maxloop+}'[max loop count]:n:_default' \
    '(--store -store)'{--store+,-store+}'[store model]:model:(region basic)' \
    '*--constraints=-[constraint manager]:cm:(range basic)' \
    '*--load-plugin=-[load analyzer plugin]:plugin:_files' \
    '*--enable-checker=-[enable checker]:checker:_default' \
    '*--disable-checker=-[disable checker]:checker:_default' \
    '--help-checkers[list available checkers]' \
    '--help-checkers-verbose[list with descriptions]' \
    '--ctu[run cross-translation-unit analysis]' \
    '--ctu-dir=-[CTU directory]:dir:_files -/' \
    '--ctu-collect-only[only collect external defs]' \
    '--ctu-analyze-only[only analyze with CTU info]' \
    '--analyzer-config=-[set analyzer config]:cfg:_default' \
    '--force-analyze-debug-code[force analysis of code under #ifdef NDEBUG]' \
    '--override-compiler[run analyzer as compiler]' \
    '--cdb=-[compile database file]:file:_files -g "compile_commands.json"' \
    '*-v[verbose output (stackable)]' \
    '--verbose[verbose output]' \
    '*:command:_command_names -e' \
    && ret=0

return ret
