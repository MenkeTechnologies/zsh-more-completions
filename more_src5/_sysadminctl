#compdef sysadminctl
# Documentation: sysadminctl -h (macOS)
# Source: macOS system administration controller (users, SecureToken, autologin, guest, time, screen lock).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '-deleteUser+[delete a user account]:user:_users' \
    '-secure[forensic secure delete]' \
    '-keepHome[keep home dir on delete]' \
    '-newPassword+[new password]:password:' \
    '-oldPassword+[old password]:password:' \
    '-passwordHint+[password hint]:hint:' \
    '-resetPasswordFor+[reset password for local user]:user:_users' \
    '-addUser+[add a user account]:user:' \
    '-fullName+[full name]:name:' \
    '-UID+[user ID]:uid:' \
    '-GID+[group ID]:gid:' \
    '-shell+[shell path]:shell:_files' \
    '-password+[user password]:password:' \
    '-hint+[user password hint]:hint:' \
    '-home+[user home path]:dir:_files -/' \
    '-admin[mark account as administrator]' \
    '-roleAccount[create a role account]' \
    '-picture+[user picture path]:image:_files' \
    '-adminUser+[administrator user name]:admin:_users' \
    '-adminPassword+[administrator password]:password:' \
    '-secureTokenStatus+[show SecureToken status]:user:_users' \
    '-secureTokenOn+[enable SecureToken for user]:user:_users' \
    '-secureTokenOff+[disable SecureToken for user]:user:_users' \
    '-autologin[autologin commands]:action:(set off status)' \
    '-userName+[autologin user name]:user:_users' \
    '-guestAccount[guest-account commands]:action:(on off status)' \
    '-afpGuestAccess[afp guest commands]:action:(on off status)' \
    '-smbGuestAccess[smb guest commands]:action:(on off status)' \
    '-automaticTime[automatic time commands]:action:(on off status)' \
    '-use12HourClockForLoginWindow[login-window 12h clock]:action:(on off status)' \
    '-filesystem[filesystem status]:action:(status)' \
    '-screenLock+[set screen lock]:action:(status immediate off)' \
    && ret=0

return ret
