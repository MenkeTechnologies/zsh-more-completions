#compdef sigstore-go-verification
# _sigstore-go-verification — sample sigstore-go verifier (sigstore/sigstore-go)
# upstream: https://github.com/sigstore/sigstore-go
# Flags from examples/sigstore-go-verification/main.go (flag).

_sigstore-go-verification() {
    _arguments \
        '-artifact=[path to artifact to verify]:file:_files' \
        '-artifact-digest=[hex-encoded artifact digest]:digest:' \
        '-artifact-digest-algorithm=[digest algorithm]:algo:(sha256 sha384 sha512)' \
        '-expectedIssuer=[expected OIDC issuer]:url:_urls' \
        '-expectedIssuerRegex=[expected OIDC issuer regex]:regex:' \
        '-expectedSAN=[expected SAN identity]:san:' \
        '-expectedSANRegex=[expected SAN regex]:regex:' \
        '-requireTimestamp=[require timestamp]:val:(true false)' \
        '-requireCTlog=[require Certificate Transparency log]:val:(true false)' \
        '-requireTlog=[require Rekor transparency log entry]:val:(true false)' \
        '-minBundleVersion=[minimum bundle version (e.g. 0.1)]:ver:' \
        '-publicKey=[path to trusted public key]:file:_files' \
        '-trustedrootJSONpath=[path to trusted root JSON]:file:_files' \
        '-tufRootURL=[URL of TUF root]:url:_urls' \
        '-tufTrustedRoot=[path to bootstrap TUF root.json]:file:_files' \
        '1:bundle file:_files'
}

_sigstore-go-verification "$@"
