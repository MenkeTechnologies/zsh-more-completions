#compdef rake
# Documentation: https://ruby.github.io/rake/
# Source: ruby/rake lib/rake/application.rb — Ruby task automation (Ruby).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    {-A,--all}'[show all tasks (with -T/-D)]' \
    '--backtrace=-[enable full backtrace]:out:(stderr stdout)' \
    {-B,--build-all}'[build all prereqs even if up-to-date]' \
    '--comments[show commented tasks only]' \
    {-D-,--describe=-}'[describe tasks then exit]::pattern:_default' \
    {-C+,--directory=}'[change to directory first]:dir:_files -/' \
    {-n,--dry-run}'[dry run; do not execute actions]' \
    {-e+,--execute=}'[execute Ruby code and exit]:code:_default' \
    {-p+,--execute-print=}'[execute code, print result, exit]:code:_default' \
    {-E+,--execute-continue=}'[execute code then continue]:code:_default' \
    {-j-,--jobs=-}'[max parallel tasks]::n:_default' \
    '--job-stats=-[display job statistics]::level:(history)' \
    {-I+,--libdir=}'[add to $LOAD_PATH]:dir:_files -/' \
    {-m,--multitask}'[treat all tasks as multitask]' \
    '--no-deprecation-warnings[disable deprecation warnings]' \
    {-N,--no-search}'[do not search parent directories for Rakefile]' \
    {-G,--no-system}'[disable system tasks]' \
    {-P,--prereqs}'[display tasks and dependencies]' \
    {-q,--quiet}'[quiet mode]' \
    {-f+,--rakefile=}'[Rakefile to use]:file:_files' \
    '--rakelibdir=-[Rakelib directory]:dir:_files -/' \
    {-r+,--require=}'[require library]:library:_default' \
    {-R+,--rules=}'[trace rule resolution]:rule:_default' \
    {-s,--silent}'[silent like -q but no in-directory announce]' \
    {-g,--system}'[use system-wide rakefiles]' \
    {-T-,--tasks=-}'[display tasks then exit]::pattern:_default' \
    {-v,--verbose}'[verbose log of task execution]' \
    {-V,--version}'[show version]' \
    {-W-,--where=-}'[where tasks are defined]::pattern:_default' \
    '(-h -H --help)'{-h,-H,--help}'[show help]' \
    '*:task name or VAR=VALUE:_default' \
    && ret=0

return ret
