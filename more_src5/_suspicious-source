#compdef suspicious-source
# Documentation: https://manpages.debian.org/suspicious-source
# Source: debian/devscripts scripts/suspicious-source — find non-source files in source dir (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --verbose)'{-v,--verbose}'[print more information]' \
    '(-d --directory)'{-d+,--directory=}'[check files in directory]:dir:_files -/' \
    '*'{-m+,--mimetype=}'[whitelist MIMETYPE]:mime:_default' \
    '*'{-e+,--extension=}'[whitelist EXTENSION]:ext:_default' \
    && ret=0

return ret
