#compdef scribus-cli
# _scribus-cli — Scribus open-source desktop publishing CLI alias (scribus team, C++); custom argparse
# upstream: https://github.com/scribusproject/scribus

_scribus-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--lang=+[language]:str:' \
        '-l+[language]:str:' \
        '--font-info[font info]' \
        '-f[font info]' \
        '--no-splash[no splash]' \
        '-ns[no splash]' \
        '--no-gui[no GUI]' \
        '-g[no GUI]' \
        '--swap-dialog-button-order[swap dialog button order]' \
        '-sb[swap dialog button order]' \
        '--prefs=+[prefs file]:file:_files' \
        '-p+[prefs file]:file:_files' \
        '--profile-info[profile info]' \
        '-pi[profile info]' \
        '--upgrade-check[check for upgrades]' \
        '-uc[check for upgrades]' \
        '--no-prefs[no prefs]' \
        '-np[no prefs]' \
        '--swap-dialog-button-yes-cancel[swap yes/cancel]' \
        '--display=+[X display]:str:' \
        '-d+[X display]:str:' \
        '--neverSplash[no splash always]' \
        '-ns[no splash always]' \
        '--python-script=+[script file]:file:_files -g "*.py"' \
        '-py+[script file]:file:_files -g "*.py"' \
        '--port=+[port]:port:' \
        '--http[http mode]' \
        '*:files:_files -g "*.{sla,sla.gz,scd}"'
}

_scribus-cli "$@"
