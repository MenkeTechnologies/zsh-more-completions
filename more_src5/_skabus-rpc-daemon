#compdef skabus-rpc-daemon
# _skabus-rpc-daemon — skabus skabus-rpc-daemon (super-server for skabus-rpcd: opens the Unix socket at `path`, listens, drops privileges, then forks skabus-rpcd for each client)
# upstream: https://github.com/skarnet/skabus
# Flags from src/rpc/skabus-rpc-daemon.c on tip.

_skabus-rpc-daemon() {
    _arguments \
        '-v+[verbosity]:n:' \
        '(-d -D)-d[bind in dgram mode]' \
        '(-d -D)-D[bind in stream mode (default)]' \
        '-1[print bound socket info on fd 1]' \
        '-c+[max simultaneous clients]:n:' \
        '-b+[listen() backlog]:n:' \
        '-G+[supplementary GIDs (csv)]:gids:' \
        '-g+[setgid to GID]:gid:_groups' \
        '-u+[setuid to UID]:uid:_users' \
        '-U[get UID/GID/groups from $UID/$GID/$GIDLIST]' \
        '-t+[per-request timeout (ms)]:ms:' \
        '-T+[lame-duck timeout (ms)]:ms:' \
        '(-i -x)-i+[accessrules directory]:dir:_files -/' \
        '(-i -x)-x+[accessrules cdb file]:file:_files' \
        '(-S -s)-S[skip cleanup on lame-duck]' \
        '(-S -s)-s[clean up on lame-duck (default)]' \
        '(-J -j)-J[no peer journal]' \
        '(-J -j)-j[register peer journal (default)]' \
        '1:socket-path:_files'
}

_skabus-rpc-daemon "$@"
