#
# WHY image IS THE 77TH RUST CLI LIBRARY
#
# image (image-rs/image) is the canonical Rust image
# processing library.  Distinct from format-specific
# libraries (png-rs, jpeg-decoder, gif-rs, libavif-rs) which
# image aggregates under a unified DynamicImage / ImageBuffer
# API, and from imagemagick-rs (FFI wrapper for the C
# ImageMagick library).  image is PURE RUST — no Cgo /
# libimagemagick / libvips dependency.
#
# Five distinguishing characteristics:
#
#   1. CROSS-FORMAT UNIFIED API — single ImageReader /
#      ImageEncoder abstraction over 14+ raster formats
#      (JPEG, PNG, GIF, WebP, AVIF, BMP, TIFF, TGA, PNM, DDS,
#      ICO, HDR, EXR, Farbfeld, QOI, OpenEXR).  Distinct
#      from per-format crates that require separate codecs +
#      APIs for each format.
#
#   2. DynamicImage + ImageBuffer DUAL API — DynamicImage
#      (runtime-polymorphic enum) for handling unknown-at-
#      compile-time color types; ImageBuffer<P: Pixel,
#      Vec<P::Subpixel>> for typed compile-time pixel access.
#      Distinct from libvips (single buffer type) and
#      ImageMagick (image_t).
#
#   3. imageops MODULE — built-in operations: resize (4 filter
#      types), rotate90/180/270, flip_horizontal/vertical,
#      brighten, adjust_contrast, blur, unsharpen, crop,
#      overlay, replace, vertical_gradient,
#      horizontal_gradient.  Distinct from libraries that
#      require external operation crates.
#
#   4. PIXEL TRAIT GENERICITY — Pixel trait allows custom
#      pixel types (HDR, multispectral, color-spaces beyond
#      RGB/Luma).  Distinct from libraries with fixed pixel
#      vocabulary.
#
#   5. image-rs WORKING-GROUP PROVENANCE — community-
#      maintained Rust working group rather than individual
#      author.  Distinct from David Tolnay / Sean McArthur /
#      Sindre Sorhus / Vitaly Puzrin / Vincent Prouillet /
#      Armin Ronacher / Mathew Roy / Daniel Abramov ecosystems.
#
# -----------------------------------------------------------------------------
#
# THE syno-photo-frame CLI — clap derive + image + reqwest + SDL2 + chrono
#
# syno-photo-frame's CLI is in src/cli.rs.  Uses clap v4
# derive with #[derive(Parser)] Cli + ValueEnum for choices.
#
# Positional:
#   SHARE_LINK              public Synology Photos OR Immich
#                           shared album URL
#
# Backend selection:
#   --backend BACKEND       auto | synology | immich
#                           (default: auto-detect from URL)
#   -p, --password PASSWORD link protection password
#
# Slideshow timing + ordering:
#   -i, --interval SECONDS  photo change interval
#                           (default 30; min 5)
#   -o, --order ORDER       by-date | by-date-descending |
#                           by-name | by-name-descending |
#                           random
#                           (default: by-date)
#       --random-start      start at random photo
#                           (continues per --order)
#
# Visual effects:
#   -t, --transition TRANS  crossfade | fade-to-black | none
#                           (default: crossfade)
#       --background BG     blur | none
#                           (default: blur)
#       --rotate DEG        0 | 90 | 180 | 270
#                           (default: 0)
#       --splash FILE       JPEG to display during startup
#                           (replaces default splash)
#
# Photo metadata overlay:
#       --display-photo-info        show photo datetime + GPS
#                                   location
#       --datetime-format FMT       strftime template
#                                   (default %x — locale date)
#
# Network:
#       --timeout SECONDS           HTTP timeout
#                                   (default 30; min 5)
#       --source-size SIZE          S | M | L
#                                   (default: L; Synology only)
#       --disable-update-check      skip GitHub release check
#                                   on startup
#
# Standard flags:
#   -h, --help                      show help
#   -V, --version                   show version
#
# image is used in src/img.rs for:
#   1. Decoding fetched JPEG/PNG photos via image::ImageReader
#   2. Resizing to screen dimensions via image::imageops::resize
#      with Lanczos3 filter
#   3. Rotation transforms (90/180/270) for --rotate flag
#   4. Blur effect for --background blur via
#      image::imageops::blur
#   5. Encoding modified images back via image::ImageEncoder
#      for SDL2 surface creation
#
# Five-axis distinctness from all previously-documented Rust
# libraries:
#
#   1. IMAGE I/O ABSTRACTION — image decodes/encodes raster
#      formats; distinct from every other Axis.
#
#   2. CROSS-FORMAT UNIFIED API — 14+ formats with one API.
#
#   3. DynamicImage + ImageBuffer DUAL — runtime-polymorphic
#      + typed-at-compile-time pixel access.
#
#   4. PURE RUST — no Cgo / libimagemagick / libvips.
#
#   5. image-rs WORKING-GROUP PROVENANCE — community-
#      maintained; distinct from single-author maintainers.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/caleb9/syno-photo-frame/blob/main/src/cli.rs
# clap v4 derive #[arg] + ValueEnum definitions.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _syno_backends _syno_orders _syno_transitions _syno_backgrounds _syno_sizes
_syno_backends=(
    'auto:detect the backend type automatically (default)'
    'synology:Synology Photos backend'
    'immich:Immich backend'
)
_syno_orders=(
    'by-date:by photo shooting date (older first)'
    'by-date-descending:by photo shooting date (newer first)'
    'by-name:by photo file name (alphabetical)'
    'by-name-descending:by photo file name (reverse alphabetical)'
    'random:randomly'
)
_syno_transitions=(
    'crossfade:crossfade transition (default)'
    'fade-to-black:fade out to black + fade in to next photo'
    'none:no transition (instant change)'
)
_syno_backgrounds=(
    'blur:blur the photo (default)'
    'none:disable background (black bars)'
)
_syno_sizes=(
    'S:small (fastest, lower quality)'
    'M:medium (balanced)'
    'L:large (full quality, default)'
)

_arguments -s -S \
    '--backend=[backend service hosting the album]:backend:->backend' \
    '(-p --password)'{-p+,--password=}'[link protection password]:password:_default' \
    '(-i --interval)'{-i+,--interval=}'[photo change interval in seconds (min 5, default 30)]:seconds:_default' \
    '(-o --order)'{-o+,--order=}'[slideshow ordering]:order:->order' \
    '--random-start[start at randomly selected photo]' \
    '(-t --transition)'{-t+,--transition=}'[transition effect]:transition:->transition' \
    '--background=[background fill effect]:background:->background' \
    '--rotate=[rotate display to match screen orientation]:degrees:(0 90 180 270)' \
    '--splash=[JPEG file to display during startup]:file:_files -g "*.(jpg|jpeg|JPG|JPEG)"' \
    '--display-photo-info[show photo datetime + location]' \
    '--datetime-format=[strftime template for datetime display]:format:_default' \
    '--timeout=[HTTP request timeout in seconds (min 5, default 30)]:seconds:_default' \
    '--source-size=[requested Synology photo size]:size:->size' \
    '--disable-update-check[skip GitHub release check on startup]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1:share link:_default' \
    && ret=0

case $state in
    backend)    _describe -t backends 'backend service' _syno_backends && ret=0 ;;
    order)      _describe -t orders 'slideshow order' _syno_orders && ret=0 ;;
    transition) _describe -t transitions 'transition effect' _syno_transitions && ret=0 ;;
    background) _describe -t backgrounds 'background fill' _syno_backgrounds && ret=0 ;;
    size)       _describe -t sizes 'source size' _syno_sizes && ret=0 ;;
esac

return ret
