#compdef supernova
# Documentation: https://github.com/supercollider/supercollider (server/supernova/server/main.cpp)
# Reference accessed: 2026-05-29
# SuperCollider multi-threaded server (sibling to scsynth).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--dump-version[display supernova version and build info]' \
  '(- *)--help[show help]' \
  '--port=[server port number]:port:' \
  '--rt-pool-size=[real-time memory pool size in KB]:kb:' \
  '--memory-locking[enable memory locking]' \
  '--non-rt[run in non-realtime synthesis mode]' \
  '*--ugen-paths=[paths for loading unit-generator plugins]:path:_directories' \
  '--hw-name=[audio hardware device name(s)]:name:' \
  '--input-channels=[number of audio input channels]:n:' \
  '--output-channels=[number of audio output channels]:n:' \
  '--blocksize=[audio buffer block size]:samples:' \
  '--samplerate=[audio sampling rate in Hz]:hz:' \
  '--hardware-buffer-size=[hardware buffer size (PortAudio)]:samples:' \
  '--safety-clip-threshold=[clipping threshold (macOS PortAudio)]:value:' \
  '--load-synthdefs[load synthesis definitions from default paths]' \
  '--verbosity=[output verbosity level]:level:' && ret=0

return ret
