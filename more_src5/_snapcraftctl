#compdef snapcraftctl
# _snapcraftctl — legacy scriptlet helper for snapcraft (canonical/snapcraft)
# upstream: https://github.com/canonical/snapcraft
# Subcommands from bin/snapcraftctl-compat.

_snapcraftctl() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'pull:run the pull step (deprecated, use craftctl default)'
                'build:run the build step (deprecated)'
                'stage:run the stage step (deprecated)'
                'prime:run the prime step (deprecated)'
                'set-version:set the snap version (deprecated, use craftctl set version=...)'
                'set-grade:set the snap grade (deprecated, use craftctl set grade=...)'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                set-version|set-grade) _arguments '1:value:' ;;
            esac
            ;;
    esac
}

_snapcraftctl "$@"
