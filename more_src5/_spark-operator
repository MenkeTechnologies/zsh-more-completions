#compdef spark-operator
# _spark-operator — Kubeflow Spark Operator (kubeflow/spark-operator)
# upstream: https://github.com/kubeflow/spark-operator
# Subcommands + flags from cmd/operator/{main,controller/start,webhook/start}.go on tip.

_spark-operator() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                controller:'run the SparkApplication / ScheduledSparkApplication controller'
                webhook:'run the mutating/validating admission webhook'
                version:'print version and exit'
            )
            _describe -t commands 'spark-operator command' cmds
            ;;
        args)
            case $words[1] in
                controller)
                    _arguments \
                        '--controller-threads=[worker threads]:n:' \
                        '--namespaces=[comma-sep watched namespaces]:list:' \
                        '--namespace-selector=[label selector for watched namespaces]:sel:' \
                        '--cache-sync-timeout=[informer cache sync timeout]:dur:' \
                        '--max-tracked-executor-per-app=[max executors tracked per SparkApplication]:n:' \
                        '--workqueue-ratelimiter-bucket-qps=[workqueue bucket QPS]:n:' \
                        '--workqueue-ratelimiter-bucket-size=[workqueue bucket size]:n:' \
                        '--workqueue-ratelimiter-max-delay=[workqueue max delay]:dur:' \
                        '--enable-batch-scheduler[enable batch schedulers]' \
                        '--default-batch-scheduler=[default batch scheduler]:name:' \
                        '--enable-ui-service=[expose Spark Web UI Service]:bool:(true false)' \
                        '--ingress-class-name=[ingressClassName for created Ingress resources]:name:' \
                        '--ingress-url-format=[Ingress URL format]:fmt:' \
                        '--ingress-tls=[default TLS config JSON]:json:' \
                        '--ingress-annotations=[default Ingress annotations JSON]:json:' \
                        '--leader-election=[enable leader election]:bool:(true false)' \
                        '--leader-election-lock-name=[leader-election lock name]:name:' \
                        '--leader-election-lock-namespace=[leader-election lock namespace]:ns:' \
                        '--leader-election-lease-duration=[leader lease duration]:dur:' \
                        '--leader-election-renew-deadline=[leader renew deadline]:dur:' \
                        '--leader-election-retry-period=[leader retry period]:dur:' \
                        '--driver-pod-creation-grace-period=[driver-pod-not-found retry window]:dur:' \
                        '--kube-api-burst=[Kubernetes client burst]:n:' \
                        '--enable-metrics[enable Prometheus metrics]' \
                        '--metrics-bind-address=[metrics bind host\:port]:host\:port:' \
                        '--metrics-endpoint=[metrics HTTP path]:path:' \
                        '--metrics-prefix=[metrics name prefix]:prefix:' \
                        '--health-probe-bind-address=[health probe bind host\:port]:host\:port:' \
                        '--secure-metrics[serve metrics over HTTPS]' \
                        '--enable-http2[allow HTTP/2 on metrics/webhook]' \
                        '--pprof-bind-address=[pprof bind host\:port]:host\:port:'
                    ;;
                webhook)
                    _arguments \
                        '--controller-threads=[worker threads]:n:' \
                        '--label-selector-filter=[label selector filter]:sel:' \
                        '--cache-sync-timeout=[informer cache sync timeout]:dur:' \
                        '--kube-api-burst=[Kubernetes client burst]:n:' \
                        '--webhook-cert-dir=[webhook TLS cert/key directory]:dir:_files -/' \
                        '--webhook-cert-name=[webhook TLS cert filename]:name:' \
                        '--webhook-key-name=[webhook TLS key filename]:name:' \
                        '--mutating-webhook-name=[MutatingWebhookConfiguration name]:name:' \
                        '--validating-webhook-name=[ValidatingWebhookConfiguration name]:name:' \
                        '--webhook-port=[webhook server bind port]:port:' \
                        '--webhook-secret-name=[secret containing webhook TLS]:name:' \
                        '--webhook-secret-namespace=[webhook TLS secret namespace]:ns:' \
                        '--webhook-svc-name=[webhook Service name]:name:' \
                        '--webhook-svc-namespace=[webhook Service namespace]:ns:' \
                        '--enable-resource-quota-enforcement[enforce ResourceQuota for SparkApplications]' \
                        '--enable-cert-manager[manage webhook TLS via cert-manager]' \
                        '--leader-election=[enable leader election]:bool:(true false)' \
                        '--enable-metrics[enable Prometheus metrics]' \
                        '--metrics-bind-address=[metrics bind host\:port]:host\:port:' \
                        '--health-probe-bind-address=[health probe bind host\:port]:host\:port:' \
                        '--enable-http2[allow HTTP/2 on metrics/webhook]'
                    ;;
            esac
            ;;
    esac
}

_spark-operator "$@"
