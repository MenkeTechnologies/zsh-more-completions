#compdef swift-tools
# _swift-tools — Swift toolchain helper alias (Apple Swift project, Swift); convenience meta-CLI for swift / swiftc / sourcekitten / etc
# upstream: https://github.com/apple/swift

_swift-tools() {
    local -a sub=(
        'swift:swift compiler and SPM driver'
        'swiftc:Swift compiler frontend'
        'sourcekitten:SourceKit query tool'
        'swiftformat:Swift formatter'
        'swiftlint:Swift linter'
        'periphery:Swift dead code scan'
        'mint:Swift CLI package manager'
        'xcodes:Xcode version manager'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'swift-tools subcommand' sub ;;
    esac
}

_swift-tools "$@"
