#compdef setuser
# _setuser — daemontools-encore setuser (set effective uid/gid/supplementary groups + $UID/$GID/$SHELL/$HOME/$USER from a passwd account name, chdir to home, then exec child; root-only)
# upstream: https://github.com/schmonz/daemontools-encore
# Source: setuser.8 on tip; positional only.

_setuser() {
    _arguments \
        '1:account:_users' \
        '*::child:_command_names -e'
}

_setuser "$@"
