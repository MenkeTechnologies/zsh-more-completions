#compdef recon-all
# recon-all — FreeSurfer full cortical reconstruction pipeline

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-s[subject name]:subject name:' \
  '-i[input volume]:input volume:_files -g "*.{nii,nii.gz,mgz,mgh,dcm}"' \
  '-sd[subjects directory]:subjects dir:_directories' \
  '-all[run all reconstruction stages]' \
  '-autorecon1[run only autorecon1 (motion correction, talairach, normalization)]' \
  '-autorecon2[run only autorecon2 (segmentation, surface generation)]' \
  '-autorecon3[run only autorecon3 (cortical parcellation, stats)]' \
  '-cw256[conform to 256 voxel width (for large FOV)]' \
  '-notal-check[skip Talairach registration check]' \
  '-parallel[run hemispheres in parallel]' \
  '-openmp[number of threads for parallel processing]:number of threads:' \
  '-no-isrunning[do not check for running status file]'
