#compdef searchsploit
# _searchsploit-bin — Exploit-DB local CLI search (Offensive Security, Bash); search exploits from exploitdb mirror for authorized research
# upstream: https://gitlab.com/exploit-database/exploitdb

_searchsploit-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-c --case)'{-c,--case}'[case sensitive]' \
        '(-e --exact)'{-e,--exact}'[exact match]' \
        '(-i --ignore)'{-i,--ignore}'[ignore parts]' \
        '(-j --json)'{-j,--json}'[json output]' \
        '(-m --mirror)'{-m,--mirror}'+[copy exploit to cwd]:eid:' \
        '(-o --overflow)'{-o,--overflow}'[overflow output]' \
        '(-p --path)'{-p,--path}'+[print path]:eid:' \
        '(-t --title)'{-t,--title}'[search title only]' \
        '(-u --update)'{-u,--update}'[update local exploit-db]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-w --www)'{-w,--www}'[show URLs]' \
        '(-x --examine)'{-x,--examine}'[show source code]' \
        '--id+[also show EDB-ID]:bool:' \
        '--colour[force color]' \
        '--exclude+[exclude terms]:terms:' \
        '--cve+[CVE ID]:cve:' \
        '--nmap+[parse nmap xml]:file:_files' \
        '*:search term:'
}

_searchsploit-bin "$@"
