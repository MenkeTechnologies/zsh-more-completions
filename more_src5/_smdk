#compdef smdk
# Documentation: https://www.fluvio.io/docs/smartmodules/smdk/
# Source: https://github.com/infinyon/fluvio/blob/master/crates/smartmodule-development-kit/src/cmd.rs
# Reference accessed: 2026-06-01
# Fluvio SmartModule Development Kit. Install via `fluvio install smdk`.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _smdk_cmds
_smdk_cmds=(
    'build:build the SmartModule into WASM'
    'generate:generate a new SmartModule project'
    'test:run a SmartModule with test inputs'
    'load:load a SmartModule into the current Fluvio cluster'
    'clean:clean the current directory'
    'version:print smdk version information'
    'help:show help'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'smdk command' _smdk_cmds && ret=0
        ;;
    args)
        case $line[1] in
            build|load|test)
                _arguments -s -S \
                    '--release=[release profile name (default release-lto)]:profile:_default' \
                    '(-p --package-name)'{-p+,--package-name=}'[package/project name]:name:_default' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
