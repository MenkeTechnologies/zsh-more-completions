#compdef rivertile
# Documentation: https://man.archlinux.org/man/rivertile.1.en
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for rivertile - tiled layout generator for river

_arguments \
  '(- *)-h[print a help message and exit]' \
  '(- *)-version[print the version number and exit]' \
  '-view-padding[set the padding around views in pixels]:pixels' \
  '-outer-padding[set the padding around the edge of the layout area in pixels]:pixels' \
  '-main-location[set the initial location of the main area]:location:(top bottom left right)' \
  '-main-count[number of views in main area]:count' \
  '-main-ratio[ratio of main area to total layout area (0.1-0.9)]:ratio'
