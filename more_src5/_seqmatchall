#compdef seqmatchall
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/seqmatchall.html
# Reference accessed: 2026-05-21
# Verified: upstream EMBOSS docs at the URL above.
# Adjusted -aformat value list to match upstream-documented set
# (pair markx0..markx10 match sam bam score srspair).

# EMBOSS seqmatchall: find all word matches between every pair of
# sequences in a set (cross-correlation table).
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input sequence(s)]:sequence USA:_files' \
  '-wordsize=[word size for matching]:size:' \
  '-aformat=[alignment output format]:format:(pair markx0 markx1 markx2 markx3 markx10 match sam bam score srspair)' \
  '-aextension=[output file extension]:ext:' \
  '-adirectory=[output directory]:dir:_files -/' \
  '-aname=[output base file name]:name:' \
  '-outfile=[alignment output file]:file:_files' \
  '*:sequence USA:_files' && ret=0

return ret
