#compdef scope
# _scope — Cribl AppScope (eBPF-style process introspection for arbitrary user-space binaries; subcommands: run wrap a command, attach to a pid, ps list scoped procs, history, watch, snapshot, detach, dash, k8s, daemon, start, stop, prune, config, version, completions)
# upstream: https://github.com/criblio/appscope
# Subcommands from appscope cli/cmd on tip.

_scope() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '-l+[log level]:level:(trace debug info warn error)' \
        '--lib+[lib path]:dir:_files -/' \
        '--cribl+[Cribl Edge URL]:url:' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'scope command' '(run attach detach ps history watch snapshot dash k8s daemon start stop prune extract logs events metrics flows config version completions help)' ;;
        args)
            case $line[1] in
                run) _arguments '-r[restart]' '-c+[config]:file:_files' '*::command:_command_names -e' ;;
                attach|detach) _arguments '*:pid:_pids' ;;
                config) _describe -t commands 'config subcommand' '(view set unset)' ;;
                completions) _describe -t commands 'shell' '(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_scope "$@"
