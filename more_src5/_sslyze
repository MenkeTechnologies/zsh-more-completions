#compdef sslyze
# _sslyze — nabla-c0d3 SSLyze (Python TLS scanner; per-protocol cipher enumeration, certificate validation, Heartbleed/ROBOT/CCS-injection/renegotiation/EMS/compression/early-data/SCSV checks, Mozilla TLS profile comparison)
# upstream: https://github.com/nabla-c0d3/sslyze
# Flags from sslyze/cli/command_line_parser.py + sslyze/plugins/scan_commands.py on tip.

_sslyze() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version and exit]' \
        '--update_trust_stores[fetch latest trust stores and exit]' \
        '--cert=[client certificate chain PEM]:file:_files' \
        '--key=[client private key file]:file:_files' \
        '--keyform=[client private key format]:fmt:(DER PEM)' \
        '--pass=[client private key passphrase]:pwd:' \
        '--json_out=[write JSON results to file (- for stdout)]:file:_files' \
        '--targets_in=[file with one host:port per line]:file:_files' \
        '--quiet[suppress stdout output]' \
        '--slow_connection[reduce concurrent connections]' \
        '--https_tunnel=[HTTP CONNECT proxy URL]:url:_urls' \
        '--starttls=[STARTTLS protocol]:proto:(auto smtp xmpp xmpp_server pop3 imap ftp ldap rdp postgres)' \
        '--xmpp_to=[XMPP STARTTLS to= hostname]:host:_hosts' \
        '--sni=[SNI server name override]:sni:' \
        '--custom_tls_config=[Mozilla-format JSON TLS profile file]:file:_files' \
        '--mozilla_config=[Mozilla TLS profile shortcut]:profile:(modern intermediate old disable)' \
        '--certificate_info[scan: certificate info + chain]' \
        '--session_resumption[scan: session resumption support]' \
        '--ssl_2_0_cipher_suites[scan: SSLv2 cipher suites]' \
        '--ssl_3_0_cipher_suites[scan: SSLv3 cipher suites]' \
        '--tls_1_0_cipher_suites[scan: TLS 1.0 cipher suites]' \
        '--tls_1_1_cipher_suites[scan: TLS 1.1 cipher suites]' \
        '--tls_1_2_cipher_suites[scan: TLS 1.2 cipher suites]' \
        '--tls_1_3_cipher_suites[scan: TLS 1.3 cipher suites]' \
        '--tls_compression[scan: TLS-compression / CRIME]' \
        '--tls_1_3_early_data[scan: TLS 1.3 early data (0-RTT)]' \
        '--openssl_ccs_injection[scan: OpenSSL CCS injection (CVE-2014-0224)]' \
        '--tls_fallback_scsv[scan: TLS_FALLBACK_SCSV support]' \
        '--heartbleed[scan: Heartbleed (CVE-2014-0160)]' \
        '--robot[scan: ROBOT attack (CVE-2017-13099)]' \
        '--session_renegotiation[scan: session renegotiation]' \
        '--http_headers[scan: security HTTP headers]' \
        '--elliptic_curves[scan: supported elliptic curves]' \
        '--tls_extended_master_secret[scan: EMS extension (RFC 7627)]' \
        '*:target:_hosts'
}

_sslyze "$@"
