#compdef recsel
# Documentation: https://www.gnu.org/software/recutils/
# Reference accessed: 2026-06-10

# Zsh completion for recsel (GNU Recutils)

_arguments -s -S \
  '-t+[select records of given type]:record type:' \
  '-e+[selection expression]:expression:' \
  '-p+[print specified fields]:fields:' \
  '-P+[print distinct values of fields]:fields:' \
  '-n[print record number]' \
  '-c[print count of matching records only]' \
  '-j+[group by field]:field name:' \
  '-s+[sort by field]:field name:' \
  '-m+[limit number of records returned]:max records:' \
  '-M[compute minimum of field values]' \
  '-S[compute sum of field values]' \
  '-A[compute average of field values]' \
  '-d[print record descriptors]' \
  '-C[collapse output]' \
  '-G[do not print group headers]' \
  '-i[case-insensitive matching]' \
  '-R[select records randomly]' \
  '--random-seed=[set random seed]:seed number:' \
  '-q[quick mode]' \
  '-U[print unique records only]' \
  '--password=[password for encrypted fields]:password:' \
  '*:file:_files'
