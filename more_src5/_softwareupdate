#compdef softwareupdate
# Documentation: https://www.unix.com/man-page/osx/8/softwareupdate/
# Source: Apple macOS — system software update / OTA installer CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-l --list)'{-l,--list}'[list all available updates]' \
    '(-i --install)'{-i,--install}'[download + install each update]' \
    '(-d --download)'{-d,--download}'[download each update (do not install)]' \
    '--ignore[manage per-machine ignored-update list]' \
    '--reset-ignored[clear per-machine ignored-update list]' \
    '--schedule[per-machine automatic-check preference]' \
    '(-a --all)'{-a,--all}'[apply to all available updates]' \
    '(-R --restart)'{-R,--restart}'[automatically restart if needed]' \
    '--no-scan[do not scan again; use last cached list]' \
    '--background[in-background download/install]' \
    '--fetch-full-installer[fetch full macOS installer (.app)]' \
    '--full-installer-version=[macOS version for full installer]:ver:' \
    '--agree-to-license[agree to license without prompt]' \
    '--verbose[verbose output]' \
    '(- *)'{-h,--help}'[show help]' \
    '*:update label:' \
    && ret=0

return ret
