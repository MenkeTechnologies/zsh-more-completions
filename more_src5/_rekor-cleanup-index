#compdef rekor-cleanup-index
# _rekor-cleanup-index — Rekor delete stale Redis search-index entries
# upstream: https://github.com/sigstore/rekor
# Flags from cmd/cleanup-index/main.go on tip.

_rekor-cleanup-index() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-redis-hostname=[Redis hostname]:host:' \
        '-redis-port=[Redis port]:port:' \
        '-redis-password=[Redis password]:pw:' \
        '-redis-enable-tls=[enable TLS to Redis]:bool:(true false)' \
        '-redis-insecure-skip-verify=[skip Redis TLS verification]:bool:(true false)' \
        '-mysql-dsn=[MySQL DSN]:dsn:' \
        '-dry-run=[do not actually delete from Redis]:bool:(true false)' \
        '-version=[print version and exit]:bool:(true false)'
}

_rekor-cleanup-index "$@"
