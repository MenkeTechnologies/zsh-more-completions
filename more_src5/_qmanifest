#compdef qmanifest
# Documentation: https://github.com/gentoo/portage-utils
# Source: gentoo/portage-utils qmanifest.c — generate/verify thick Manifests.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-g --generate)'{-g,--generate}'[generate thick Manifests]' \
    '(-s --signas)'{-s+,--signas=}'[sign with GPG key]:keyid:_default' \
    '(-p --passphrase)'{-p,--passphrase}'[ask GPG password (no agent)]' \
    '(-d --dir)'{-d,--dir}'[treat arguments as directories]' \
    '(-o --overlay)'{-o,--overlay}'[treat arguments as overlay names]' \
    '*:target:_default' \
    && ret=0

return ret
