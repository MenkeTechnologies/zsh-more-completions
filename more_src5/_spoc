#compdef spoc
# _spoc — Security Profiles Operator CLI (record/merge/convert/run profiles)
# upstream: https://github.com/kubernetes-sigs/security-profiles-operator
# Subcommands + flags from cmd/spoc/main.go on tip.

_spoc() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'record:record a Seccomp/SELinux/AppArmor profile from a running command'
                'merge:merge two or more recorded profiles'
                'convert:convert a recorded profile between formats'
                'run:run a command under an existing profile'
                'install:install a recorded profile into the cluster'
                'remove:remove a profile from the cluster'
                'pull:pull a profile from an OCI registry'
                'push:push a profile to an OCI registry'
                'version:print spoc version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                record)
                    _arguments \
                        '(-o --output-file)'{-o,--output-file=}'[output file]:file:_files' \
                        '(-t --type)'{-t,--type=}'[profile type]:type:(seccomp selinux apparmor raw-seccomp raw-selinux)' \
                        '--base-syscalls=[csv of always-allowed syscalls]:csv:' \
                        '--no-base-syscalls[do not add base allowed syscalls]' \
                        '--no-proc-start[do not stop recording on process start]' \
                        '--privileged[run target as privileged]'
                    ;;
                merge)
                    _arguments \
                        '(-o --output-file)'{-o,--output-file=}'[output file]:file:_files' \
                        '--check[verify that inputs are mergeable; do not write output]'
                    ;;
                convert)
                    _arguments \
                        '(-o --output-file)'{-o,--output-file=}'[output file]:file:_files' \
                        '--program-name=[binary name for output profile]:name:'
                    ;;
                run)
                    _arguments \
                        '(-t --type)'{-t,--type=}'[profile type]:type:(seccomp selinux apparmor)' \
                        '(-p --profile)'{-p,--profile=}'[profile file]:file:_files'
                    ;;
            esac
            ;;
    esac
}

_spoc "$@"
