#compdef storj
# Documentation: https://github.com/storj/storj/wiki/Uplink-CLI
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Note: the actual Storj DCS CLI binary is "uplink"; "storj" alias kept for
# historical compatibility. Commands match the Uplink CLI command surface.

_storj_commands() {
  local -a commands=(
    'cp:Copy an object to/from/between Storj DCS buckets'
    'ls:List buckets or objects on your Storj DCS project'
    'mb:Make a new bucket'
    'mv:Move or rename an object'
    'rb:Remove a bucket'
    'rm:Remove an object'
    'meta:Object metadata-related operations'
    'share:Share an object'
    'access:Access-related commands'
  )
  _describe 'command' commands
}

_storj() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '1:command:_storj_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        cp|ls|rm)
          _arguments \
            '--recursive[Operate recursively]' \
            '*:path:_files'
          ;;
        mb|rb)
          _arguments '*:bucket:'
          ;;
        access)
          local -a subcmds=(
            'create:Create an access'
            'export:Export an access'
            'import:Import an access'
            'inspect:Inspect an access'
            'list:List saved accesses'
            'register:Register an access'
            'restrict:Restrict an access'
            'revoke:Revoke an access'
            'use:Set default access'
          )
          _describe 'access subcommand' subcmds
          ;;
        share)
          _arguments \
            '*:path:'
          ;;
        meta)
          local -a subcmds=(
            'get:Get object metadata'
          )
          _describe 'meta subcommand' subcmds
          ;;
      esac
      ;;
  esac
}

_storj "$@"
