#compdef relay
# Documentation: https://gitlab.com/relay-mail/rust/cli
# Reference accessed: 2026-05-20
# Verified: upstream project page at the URL above.
# Replaced fragile single-line `1:` action with explicit state machine
# so completion of subcommands actually works.

# Zsh completion for relay (gitlab.com/relay-mail/rust/cli).

local curcontext="$curcontext" state line ret=1
local -a cmds
cmds=(
  'claim:claim identity on agent'
  'claim-inbox:claim inbox for identity'
  'identities:list local identities'
  'identity:import export or view identity'
  'messages:list inbox messages'
  'read:read message by GID'
  'send:send message to user'
  'wipeout:delete all local data'
)

_arguments -C -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmd' \
  '*::arguments:->rest' && ret=0

case $state in
  cmd) _describe -t commands 'relay command' cmds && ret=0 ;;
  rest) _default && ret=0 ;;
esac

return ret
