#compdef sitecopy
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-u --update)'{-u,--update}'[update remote site]' \
  '(-f --fetch)'{-f,--fetch}'[fetch remote site state]' \
  '(-s --synch)'{-s,--synch}'[synchronize]' \
  '(-l --list)'{-l,--list}'[list changes]' \
  '(-fl --flatlist)'{-fl,--flatlist}'[flat list of changes]' \
  '(-i --initialize)'{-i,--initialize}'[initialize site]' \
  '-r[site name from config]:site name' \
  '-p[local directory]:directory:_directories' \
  '-k[keep going on errors]' \
  '-q[quiet output]' \
  '-d[debug level]:debug level' \
  '-a[show all files]' \
  '-o[operate on only one file]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0
return ret
