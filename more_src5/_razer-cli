#compdef razer-cli
# Documentation: https://github.com/LoLei/razer-cli

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-ls,--list}'[list available devices]' \
  {-d,--device}'=[select device by name]:device:' \
  {-e,--effect}'=[set lighting effect]:effect:(breath breathDual breathRandom breathSingle none reactive ripple spectrum static starlight starlightDual starlightRandom wave)' \
  {-c,--color}'=[set RGB color (hex or R,G,B)]:color:' \
  '--color2=[set secondary RGB color]:color:' \
  {-b,--brightness}'=[set brightness (0-100)]:brightness:' \
  '--dpi=[set DPI]:dpi:' \
  {-p,--poll}'=[set polling rate]:rate:(125 250 500 1000)' \
  '--battery[show battery level]' \
  '--low-battery-threshold=[set low battery threshold]:percent:' \
  '--idle-time=[set idle time for sleep in seconds]:seconds:' \
  '--scroll-mode=[set scroll mode]:mode:(tactile freespin)' \
  '--scroll-acceleration[enable scroll acceleration]' \
  '--no-scroll-acceleration[disable scroll acceleration]' \
  '--scroll-smart-reel[enable smart reel]' \
  '--no-scroll-smart-reel[disable smart reel]' \
  && return 0

return ret
