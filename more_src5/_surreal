#compdef surreal
# Documentation: https://surrealdb.com/docs/surrealdb/cli
# Documentation: https://surrealdb.com/docs/surrealdb/cli/start
# Documentation: https://surrealdb.com/docs/surrealdb/cli/sql
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URLs above.

# Zsh completion for SurrealDB CLI

local curcontext="$curcontext" state line ret=1

local -a surreal_commands
surreal_commands=(
  'backup:backup a running SurrealDB server'
  'export:export a SurrealDB database'
  'fix:fix SurrealDB data files'
  'help:print help information'
  'import:import a SurrealQL file'
  'isready:check if the SurrealDB server is ready'
  'ml:manage SurrealML models'
  'sql:start an interactive SQL shell'
  'start:start the SurrealDB server'
  'upgrade:upgrade to the latest version'
  'validate:validate a SurrealQL file'
  'version:output the version'
)

local -a surreal_global_flags
surreal_global_flags=(
  '(-h --help)'{-h,--help}'[show help]'
  '(-V --version)'{-V,--version}'[show version]'
)

_arguments -s -S \
  $surreal_global_flags \
  '1:command:_describe -t commands command surreal_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      start)
        _arguments -s -S \
          $surreal_global_flags \
          '(-b --bind)'{-b+,--bind=}'[listen address]:address:' \
          '(-l --log)'{-l+,--log=}'[log level]:level:(none full error warn info debug trace)' \
          '--log-format=[log output format]:format:' \
          '--log-socket=[log destination host:port]:host\:port:' \
          '--log-file-level=[file logging level]:level:(none full error warn info debug trace)' \
          '--log-otel-level=[OpenTelemetry logging level]:level:(none full error warn info debug trace)' \
          '--log-socket-level=[socket output logging level]:level:(none full error warn info debug trace)' \
          '--log-socket-format=[socket output format]:format:' \
          '--log-file-enabled[enable file logging]' \
          '--log-file-path=[log file directory]:dir:_directories' \
          '--log-file-name=[log filename]:name:' \
          '--log-file-format=[log file output format]:format:' \
          '--log-file-rotation=[log rotation interval]:interval:(daily hourly never)' \
          '--no-banner[hide the startup banner]' \
          '--unauthenticated[allow unauthenticated access]' \
          {-u+,--username=,--user=}'[initial root username]:username:' \
          {-p+,--password=,--pass=}'[initial root password]:password:' \
          '--no-identification-headers[suppress server identification headers]' \
          '(-A --allow-all)'{-A,--allow-all}'[allow all capabilities]' \
          '--allow-funcs=[allow specific functions]:functions:' \
          '--allow-guests[allow guest user queries]' \
          '--allow-net=[allow outbound network targets]:targets:' \
          '--allow-scripting[enable scripting]' \
          '--allow-rpc=[allow RPC methods]:methods:' \
          '--allow-http=[allow HTTP routes]:routes:' \
          '--allow-arbitrary-query=[allow arbitrary queries by user groups]:groups:' \
          '--allow-experimental=[enable experimental features]:features:' \
          '(-D --deny-all)'{-D,--deny-all}'[deny all capabilities]' \
          '--deny-funcs=[deny specific functions]:functions:' \
          '--deny-guests[deny guest user queries]' \
          '--deny-net=[deny network targets]:targets:' \
          '--deny-scripting[deny scripting]' \
          '--deny-rpc=[deny RPC methods]:methods:' \
          '--deny-http=[deny HTTP routes]:routes:' \
          '--deny-arbitrary-query=[deny arbitrary queries by user groups]:groups:' \
          '--kvs-ca=[KV store CA file]:file:_files' \
          '--kvs-crt=[KV store cert file]:file:_files' \
          '--kvs-key=[KV store key file]:file:_files' \
          '--temporary-directory=[temporary directory]:directory:_directories' \
          '--web-crt=[web TLS certificate]:file:_files' \
          '--web-key=[web TLS private key]:file:_files' \
          '--client-ip=[client IP detection method]:method:' \
          '--query-timeout=[max query execution time]:duration:' \
          '--transaction-timeout=[max transaction execution time]:duration:' \
          '--index-compaction-interval=[index compaction interval]:duration:' \
          '--async-event-interval=[async event interval]:duration:' \
          '--node-membership-refresh-interval=[node refresh interval]:duration:' \
          '--node-membership-check-interval=[node check interval]:duration:' \
          '--node-membership-cleanup-interval=[node cleanup interval]:duration:' \
          '--changefeed-gc-interval=[changefeed GC interval]:duration:' \
          '--slow-log-threshold=[slow query threshold (ms)]:ms:' \
          '--slow-log-param-allow=[parameters to include in slow logs]:params:' \
          '--slow-log-param-deny=[parameters to exclude from slow logs]:params:' \
          '--default-namespace=[initial namespace]:ns:' \
          '--default-database=[initial database]:db:' \
          '--no-defaults[disable automatic namespace/database creation]' \
          '--import-file=[SurrealQL initialization file]:file:_files' \
          '1:path:(memory file\:// rocksdb\:// tikv\:// fdb\:// surrealkv\://)' && ret=0
        ;;
      sql)
        _arguments -s -S \
          $surreal_global_flags \
          {-e+,--endpoint=}'[remote database server URL]:url:' \
          '--db=[database to use]:database:' \
          '--ns=[namespace to use]:namespace:' \
          {-u+,--username=}'[database username]:username:' \
          {-p+,--password=}'[database password]:password:' \
          '--auth-level=[authentication scope]:level:(root namespace database)' \
          {-t+,--token=}'[JWT authentication token]:token:' \
          '--pretty[pretty-print output]' \
          '--json[output results as JSON]' \
          '--multi[enable multi-line mode]' \
          '--hide-welcome[hide welcome message]' \
          '(-A --allow-all)'{-A,--allow-all}'[allow all capabilities]' \
          '(-D --deny-all)'{-D,--deny-all}'[deny all capabilities]' \
          '(-l --log)'{-l+,--log=}'[log level]:level:(none full error warn info debug trace)' && ret=0
        ;;
      export)
        _arguments -s -S \
          $surreal_global_flags \
          {-e+,--endpoint=}'[remote database server URL]:url:' \
          '--db=[database to export]:database:' \
          '--ns=[namespace to export]:namespace:' \
          {-u+,--username=}'[database username]:username:' \
          {-p+,--password=}'[database password]:password:' \
          '--auth-level=[authentication scope]:level:(root namespace database)' \
          {-t+,--token=}'[authentication token]:token:' \
          '1:output file:_files' && ret=0
        ;;
      import)
        _arguments -s -S \
          $surreal_global_flags \
          {-e+,--endpoint=}'[remote database server URL]:url:' \
          '--db=[database to import into]:database:' \
          '--ns=[namespace to import into]:namespace:' \
          {-u+,--username=}'[database username]:username:' \
          {-p+,--password=}'[database password]:password:' \
          '--auth-level=[authentication scope]:level:(root namespace database)' \
          {-t+,--token=}'[authentication token]:token:' \
          '1:input file:_files' && ret=0
        ;;
      backup)
        _arguments -s -S \
          $surreal_global_flags \
          {-e+,--endpoint=}'[remote database server URL]:url:' \
          {-u+,--username=}'[database username]:username:' \
          {-p+,--password=}'[database password]:password:' \
          '--auth-level=[authentication scope]:level:(root namespace database)' \
          {-t+,--token=}'[authentication token]:token:' \
          '--db=[database to backup]:database:' \
          '--ns=[namespace to backup]:namespace:' \
          '1:destination (file or connection string):_files' && ret=0
        ;;
      isready)
        _arguments -s -S \
          $surreal_global_flags \
          {-e+,--endpoint=}'[remote database server URL]:url:' && ret=0
        ;;
      validate)
        _arguments -s -S \
          $surreal_global_flags \
          '*:file:_files -g "*.surql"' && ret=0
        ;;
      fix)
        _arguments -s -S \
          $surreal_global_flags \
          '1:path:_files' && ret=0
        ;;
      upgrade)
        _arguments -s -S \
          $surreal_global_flags \
          '--nightly[upgrade to the latest nightly version]' \
          '--alpha[upgrade to the latest alpha version]' \
          '--beta[upgrade to the latest beta version]' \
          '--version=[upgrade to a specific version]:version:' \
          '--dry-run[do not actually upgrade]' && ret=0
        ;;
      ml)
        local -a ml_commands
        ml_commands=(
          'export:export a SurrealML model'
          'import:import a SurrealML model'
        )
        _arguments -s -S \
          $surreal_global_flags \
          '1:ml command:_describe -t commands command ml_commands' \
          '*::ml args:' && ret=0
        ;;
      *)
        _arguments -s -S $surreal_global_flags '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
