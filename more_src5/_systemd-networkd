#compdef systemd-networkd
# _systemd-networkd (systemd's network configuration manager; reads /etc/systemd/network/*.{network,link,netdev,switch,bond,wireguard} to manage interfaces, addresses, routes, DHCP, VLANs and bridges; daemon binary accepts only standard systemd unit args)
# upstream: https://github.com/systemd/systemd (src/network)
# Argument shape from systemd src/network/networkd.c on tip.

_systemd-networkd() {
    _arguments \
        '--help[show help]' \
        '--version[show version]'
}

_systemd-networkd "$@"
