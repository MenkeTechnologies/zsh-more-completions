#compdef reformail
# Documentation: https://www.courier-mta.org/maildrop/reformail.html
# Source: courier-libs maildrop/reformail.C — mail message reformatter (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d+[add CRs to non-CR lines]:n:_default' \
    '-c[concatenate continuation lines]' \
    '-f+[force From_ line]:flag:(0 1)' \
    '-D+[duplicate cache]:maxlen:->dcache' \
    '*-a+[add header if absent]:header:_default' \
    '*-A+[always add header]:header:_default' \
    '*-i+[replace header]:header:_default' \
    '*-I+[replace header, force]:header:_default' \
    '*-R+[rename header]:oldname newname:_default' \
    '*-u+[unique on header]:header:_default' \
    '*-U+[unique on header, drop later]:header:_default' \
    '*-x+[extract header values]:header:_default' \
    '*-X+[extract header, raw]:header:_default' \
    '-s+[split mailbox on regexp]:regexp:_default' \
    '-t[trust Content-Length]' \
    '-T[trust Content-Length, no fallback]' \
    '-n[suppress original headers]' \
    '-b[keep original Bcc/Resent-Bcc]' \
    '-e[skip body]' \
    '*::command:_command_names -e' \
    && ret=0

case $state in
    dcache)
        _message 'cache maxlen, then cache filename'
        ;;
esac

return ret
