#compdef sails-cli
# _sails-cli — Mike McNeil Sails realtime MVC framework for Node CLI alias (balderdashy team, JavaScript); custom argparse
# upstream: https://github.com/balderdashy/sails

_sails-cli() {
    local -a sub=(
        'new:create new sails app'
        'lift:start sails server'
        'console:open interactive console'
        'run:run a script'
        'generate:scaffold a model/controller/etc.'
        'inspect:inspect routes'
        'debug:run with debugger'
        'help:show help'
        'version:show version'
        'www:lift in production mode'
        'lift:lift sails app'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--silent[suppress output]' \
        '--verbose[verbose output]' \
        '--no-colors[no colors]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'sails subcommand' sub ;;
        args)
            case $words[1] in
                new) _arguments \
                    '1:app name:' \
                    '--no-frontend[skip frontend assets]' \
                    '--minimal[minimal scaffold]' \
                    '--template=+[template]:str:' \
                    '--without=+[features csv]:str:' \
                    '--actions2[scaffold actions2 by default]' \
                    '--force[overwrite existing dir]' \
                    '-f[overwrite existing dir]' ;;
                generate) _arguments \
                    '1:scaffold type:(api model controller adapter helper test action page]' \
                    '*:name:' \
                    '--force[force overwrite]' ;;
                lift) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--prod[production mode]' \
                    '--verbose[verbose]' \
                    '--alter[alter sync]' \
                    '--drop[drop sync]' ;;
                run) _arguments '1:script:_files' ;;
            esac
            ;;
    esac
}

_sails-cli "$@"
