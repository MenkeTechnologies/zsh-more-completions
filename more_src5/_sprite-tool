# fall-through-top-level invocation, Gforth `--`
# separator handling), real binary distributed as
# a shebang script.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# 4 subcommands decoded source-direct from main
# dispatch at sprite-tool.fs:949-957.
local -a sprite_tool_subcmds=(
  'launch:create and configure a sprite with coding agent, git, beads'
  'push:push local file or directory to a sprite'
  'pull:pull file or directory from a sprite'
  'watch:poll a sprite'\''s beads tracker task for progress'
)

_arguments -C \
  '(- *)'{-h,--help}'[show sprite-tool top-level help]' \
  '1: :->topcmd' \
  '*:: :->args' && ret=0

case $state in
  topcmd)
    _describe -t commands 'sprite-tool subcommand' sprite_tool_subcmds && ret=0
    ;;
  args)
    case $words[1] in
      launch)
        # 3 flags + 2 positionals decoded from
        # do-launch at sprite-tool.fs:488-516
        _arguments -s -S \
          '--dry-run[show what would happen without executing]' \
          '--no-checkpoint[disable auto-checkpointing]' \
          '*--upload=[upload a directory (repeatable; up to 8)]:directory:_files -/' \
          '(-h --help)'{-h,--help}'[show launch-specific help]' \
          '1:sprite name:' \
          '2:plan file:_files' && ret=0
        ;;
      push)
        # 2 required + 1 optional positionals (decoded
        # from do-push at sprite-tool.fs)
        _arguments -s -S \
          '1:local path:_files' \
          '2:remote path:' \
          '3:sprite name:' && ret=0
        ;;
      pull)
        _arguments -s -S \
          '1:remote path:' \
          '2:local path:_files' \
          '3:sprite name:' && ret=0
        ;;
      watch)
        # 1 required + 2 optional positionals
        _arguments -s -S \
          '1:sprite name:' \
          '2:task id (e.g. CRM-1):' \
          '3:poll interval (seconds):' && ret=0
        ;;
    esac
    ;;
esac

return ret
