#compdef surge
# Documentation: https://surge.sh/help
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (surge.sh static-site host).

# surge: deploy static sites to surge.sh
# Primary form: surge [path] [domain]
# Documented subcommands: list, teardown, plus, login, logout, whoami,
# account, token, version, help (not all are exhaustively documented at one URL).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'list:list all your projects'
  'teardown:tear down a project'
  'plus:upgrade to Surge Plus features'
  'login:authenticate to surge.sh'
  'logout:log out of surge.sh'
  'whoami:show currently logged-in user'
  'token:print the current account token'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:_files' && ret=0

case $state in
  (cmd) _describe -t cmds 'surge command' commands && ret=0 ;;
esac

return ret
