#compdef sass
# Documentation: https://sass-lang.com/documentation/cli/dart-sass/
# Source: sass-lang/dart-sass — official Sass compiler.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--stdin[read input from stdin]' \
    '--indented[parse input as indented syntax (.sass)]' \
    '*'{-I,--load-path=}'[additional Sass load path]:dir:_directories' \
    '(-p --pkg-importer)'{-p+,--pkg-importer=}'[add pkg: importer]:importer:(node)' \
    '(-s --style)'{-s+,--style=}'[output style]:style:(expanded compressed)' \
    '--no-charset[never emit @charset / UTF-8 BOM]' \
    '--error-css[emit CSS describing errors when compilation fails]' \
    '--update[only compile stylesheets whose deps changed]' \
    '--no-source-map[do not generate source maps]' \
    '--source-map-urls=[how source maps link back to Sass files]:mode:(relative absolute)' \
    '--embed-sources[embed Sass file contents in source map]' \
    '--embed-source-map[embed source map in generated CSS]' \
    '(-w --watch)'{-w,--watch}'[continue compiling on file changes]' \
    '--poll[poll for file changes (no OS notifications)]' \
    '--stop-on-error[stop compiling on first error]' \
    '(-i --interactive)'{-i,--interactive}'[interactive SassScript evaluator]' \
    '(-c --color)'{-c,--color}'[emit terminal colors]' \
    '--no-unicode[ASCII-only error messages]' \
    '--verbose[emit all deprecation warnings]' \
    '(-q --quiet)'{-q,--quiet}'[suppress warnings]' \
    '--quiet-deps[suppress deprecation warnings from dependencies]' \
    '*--fatal-deprecation=[treat deprecation as error]:id:' \
    '*--future-deprecation=[opt-in to future deprecation warnings]:id:' \
    '*--silence-deprecation=[silence a deprecation warning class]:id:' \
    '--trace[print full stack trace on error]' \
    '(- *)'{-h,--help}'[print help]' \
    '(- *)--version[print version]' \
    '*:source.scss [: out.css]:_files' \
    && ret=0

return ret
