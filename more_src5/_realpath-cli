#compdef realpath-cli
# _realpath-cli — GNU coreutils realpath print resolved file name CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_realpath-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-e[require components exist]' \
        '--canonicalize-existing[require components exist]' \
        '-m[no require components exist]' \
        '--canonicalize-missing[no require components exist]' \
        '-L[resolve . and ..]' \
        '--logical[resolve . and ..]' \
        '-P[resolve symlinks]' \
        '--physical[resolve symlinks]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--relative-to=+[dir]:dir:_files -/' \
        '--relative-base=+[dir]:dir:_files -/' \
        '-s[do not expand symlinks]' \
        '--strip[do not expand symlinks]' \
        '--no-symlinks[do not expand symlinks]' \
        '-z[NUL terminator]' \
        '--zero[NUL terminator]' \
        '*:files:_files'
}

_realpath-cli "$@"
