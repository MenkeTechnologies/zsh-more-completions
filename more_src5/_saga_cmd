#compdef saga_cmd
# saga_cmd — SAGA GIS command-line interface

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-f,--flags}'=[output format]:format:((0\:table 1\:xml))' \
  '-s[silent mode, no progress output]' \
  {-c,--cores}'=[number of CPU cores to use]:cores:' \
  '-l[list available libraries]' \
  '1:library:' \
  '2:module:' \
  '*:module options:' && ret=0

return ret
