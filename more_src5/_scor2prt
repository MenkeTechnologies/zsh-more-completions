#compdef scor2prt
# Documentation: scor2prt for PMX 2.74 — split full score into individual instrumental parts.
# Source: scor2prt BASENAME[.pmx] → BASENAMExx.pmx files (one per instrument).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:pmx source basename:_files -g "*.pmx(:r)"' \
    && ret=0

return ret
