#compdef siggen
# Documentation: man siggen(8)
# Source: Tripwire/tripwire-open-source src/siggen/siggencmdline.cpp (master) — tripwire file signature display (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-? --help)'{-\\?,--help}'[show help]' \
    '(-C --CRC32 -a --all)'{-C,--CRC32}'[CRC32 signature]' \
    '(-M --MD5 -a --all)'{-M,--MD5}'[MD5 signature]' \
    '(-S --SHA -a --all)'{-S,--SHA}'[SHA signature]' \
    '(-H --HAVAL -a --all)'{-H,--HAVAL}'[HAVAL signature]' \
    '(-C --CRC32 -M --MD5 -S --SHA -H --HAVAL -a --all)'{-a,--all}'[all signatures]' \
    '(-h --hexadecimal)'{-h,--hexadecimal}'[output in hexadecimal]' \
    '(-t --terse)'{-t,--terse}'[terse output]' \
    '*:file:_files' \
    && ret=0

return ret
