#compdef shuffledns
# _shuffledns-bin — ProjectDiscovery shuffledns massdns wrapper (Go); brute-force / resolve subdomains with wildcard filter
# upstream: https://github.com/projectdiscovery/shuffledns

_shuffledns-bin() {
    _arguments \
        '-h[show help]' \
        '-version[show version]' \
        '-d+[domain]:domain:' \
        '-list+[list file]:file:_files' \
        '-w+[wordlist]:file:_files' \
        '-r+[resolvers file]:file:_files' \
        '-tr+[trusted resolvers]:file:_files' \
        '-massdns+[massdns binary]:file:_files' \
        '-o+[output file]:file:_files' \
        '-json[json output]' \
        '-strict-wildcard[strict wildcard filter]' \
        '-massdns-cmd+[massdns cmd]:str:' \
        '-mode+[mode]:mode:(bruteforce resolve filter)' \
        '-t+[threads]:n:' \
        '-retries+[retries]:n:' \
        '-wt+[wildcard threshold]:n:' \
        '-wd+[wildcard domain]:domain:' \
        '-silent[silent]' \
        '-v[verbose]' \
        '-stats[show stats]' \
        '-no-color[no color]'
}

_shuffledns-bin "$@"
