_shippie() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a global_opts
    global_opts=(
        '--debug[enables debug logging (sets tslog minLevel to 2)]'
        '--telemetry[enable anonymous telemetry (default true)]'
        '--no-telemetry[disable anonymous telemetry]'
        '--help[print help]'
        '--version[print version]'
    )

    _arguments -C \
        $global_opts \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'configure:configure the tool (write platform-specific CI integration scaffolding)'
                'review:review code changes (run the LLM agent against PR diff or local working tree)'
            )
            _describe -t commands 'shippie command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                configure)
                    _arguments \
                        $global_opts \
                        '--platform=[platform to configure for (default github)]:platform:(github gitlab azdev)' && ret=0
                    ;;
                review)
                    _arguments \
                        $global_opts \
                        '--modelString=[model to use for generating the review (default openai:gpt-4.1-mini)]:model spec (provider:model):' \
                        '--reviewLanguage=[target natural language for translation (default English)]:language:' \
                        '--platform=[platform type (default local)]:platform:(github gitlab azdev local)' \
                        '--maxSteps=[maximum number of agentic steps to take (default 50)]:N:' \
                        '--baseUrl=[base URL for the platform]:url:' \
                        '*--ignore=[array of globs which shippie ignores]:glob:' \
                        '--customInstructions=[custom instructions to be added to the review prompt]:text:' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_shippie "$@"
