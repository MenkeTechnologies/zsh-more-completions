#compdef SoapySDRUtil soapy soapy_util SoapySDR SoapyServer
# _soapy — Pothosware SoapySDR SoapySDRUtil generic SDR vendor-agnostic CLI for enumeration probe and stream testing (pothosware team, C++); custom argparse
# upstream: https://github.com/pothosware/SoapySDR

_soapy() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--info[print version info]' \
        '--find[discover devices]' \
        '--make[make device]' \
        '--probe[probe device]' \
        '--watch[watch sensors]' \
        '--check[run sanity test]' \
        '--unbias[unbias measurement]' \
        '--rate=+[Hz]:n:' \
        '--freq=+[Hz]:n:' \
        '--gain=+[dB]:f:' \
        '--bandwidth=+[Hz]:n:' \
        '--samples=+[N]:n:' \
        '--channel=+[N]:n:' \
        '--direction=+[direction]:d:(RX TX)' \
        '--format=+[stream format]:f:(CF32 CF64 CS8 CS16 CU8 CU16 CS12 CU12 CS32 CU32)' \
        '--module=+[module path]:str:' \
        '--driver=+[driver]:str:' \
        '--args=+[args]:str:' \
        '--ant=+[antenna]:str:' \
        '--show-stack[show stack]' \
        '*:device args:'
}

_soapy "$@"
