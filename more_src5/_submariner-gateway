#compdef submariner-gateway
# _submariner-gateway — Submariner gateway engine (establishes inter-cluster tunnels: IPsec/Libreswan or VXLAN/WireGuard)
# upstream: https://github.com/submariner-io/submariner
# Flags from main.go on tip; deeper config via env vars (SUBMARINER_NAMESPACE, SUBMARINER_CLUSTERID, SUBMARINER_CABLEDRIVER, SUBMARINER_HEALTHCHECKENABLED, SUBMARINER_HEALTHCHECKINTERVAL, BROKER_K8S_APISERVER, BROKER_K8S_APISERVERTOKEN, BROKER_K8S_CA, BROKER_K8S_REMOTENAMESPACE, CE_IPSEC_*).

_submariner-gateway() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '--kubeconfig=[path to local-cluster kubeconfig (out-of-cluster only)]:file:_files' \
        '--master=[Kubernetes API URL]:url:_urls' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_submariner-gateway "$@"
