#compdef sniproxy
# _sniproxy — TLS SNI / HTTP Host-header transparent proxy (dlundquist/sniproxy)
# upstream: https://github.com/dlundquist/sniproxy
# Flags from src/sniproxy.c (getopt "fc:n:V").

_sniproxy() {
    _arguments \
        '(- *)-V[show version]' \
        '-c+[config file]:file:_files -g "*.conf"' \
        '-f[run in foreground (no daemonize)]' \
        '-n+[max open files]:n:'
}

_sniproxy "$@"
