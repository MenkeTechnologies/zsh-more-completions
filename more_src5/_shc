#compdef shc
# Documentation: https://neurobin.github.io/shc/man.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '-e[expiration date dd/mm/yyyy]:date:' \
  '-m[expiration message]:message:' \
  '-f[script file name]:file:_files' \
  '-i[inline shell option]:opt:' \
  '-x[exec command (printf format)]:cmd:' \
  '-l[last shell option (e.g. --)]:opt:' \
  '-o[output file]:file:_files' \
  '-r[relax security for redistributable binaries]' \
  '-v[verbose compilation]' \
  '-D[switch on debug exec calls]' \
  '-U[make binary untraceable]' \
  '-C[display license and exit]' \
  '-A[display abstract and exit]' \
  '-B[compile for BusyBox]' \
  '(- *)-h[display help and exit]'
