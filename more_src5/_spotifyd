#compdef spotifyd
# Documentation: https://github.com/Spotifyd/spotifyd
# Reference accessed: 2026-05-21
# Verified: src/config.rs (CliConfig, SharedConfigValues clap definitions)
# Removed: -u/--username, -p/--password (deprecated in upstream; no longer in CliConfig)

# Zsh completion for spotifyd - Spotify daemon

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'authenticate:perform OAuth authentication and store credentials'
  'auth:perform OAuth authentication (alias)'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--no-daemon[do not detach from console]' \
  '--config-path=[path to config file]:file:_files -g "*.toml"' \
  '--pid=[path to PID file]:file:_files' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '--on-song-change-hook=[shell command to run on song change]:command:' \
  '--onevent=[shell command to run on song change (alias)]:command:' \
  '(-c --cache-path)'{-c+,--cache-path=}'[path to cache directory]:directory:_files -/' \
  '--max-cache-size=[maximum cache size in bytes]:bytes:' \
  '--no-audio-cache=-[disable audio cache]:bool:(true false)' \
  '(-b --backend)'{-b+,--backend=}'[audio backend]:backend:' \
  '--volume-controller=[volume controller]:type:(softvol alsa alsa_linear none)' \
  '--volume-control=[volume controller (alias)]:type:(softvol alsa alsa_linear none)' \
  '--device=[audio device or pipe file]:device:' \
  '(-d --device-name)'{-d+,--device-name=}'[device name shown on Spotify]:name:' \
  '(-B --bitrate)'{-B+,--bitrate=}'[stream bitrate]:bitrate:(96 160 320)' \
  '--audio-format=[audio sample format]:format:(F32 S32 S24 S24_3 S16)' \
  '--initial-volume=[initial volume 0-100]:volume:' \
  '--volume-normalisation=-[enable volume normalisation]:bool:(true false)' \
  '--normalisation-pregain=[pregain in dB]:dB:' \
  '--disable-discovery=-[disable Spotify Connect discovery]:bool:(true false)' \
  '--zeroconf-port=[port for Spotify Connect discovery]:port:' \
  '--proxy=[HTTP proxy URL]:url:' \
  '--device-type=[device type shown to clients]:type:(computer tablet smartphone speaker tv avr stb audiodongle)' \
  '--autoplay=-[autoplay similar songs after queue ends]:bool:(true false)' \
  '--use-mpris=-[enable MPRIS interface]:bool:(true false)' \
  '--dbus-type=[D-Bus type for MPRIS]:type:(session system)' \
  '--control=[ALSA control device]:device:' \
  '--mixer=[ALSA mixer name]:mixer:' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'spotifyd command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      authenticate|auth)
        _arguments \
          '--oauth-port=[port for OAuth redirect]:port:' && ret=0
        ;;
    esac
    ;;
esac

return ret
