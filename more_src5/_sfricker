#compdef sfricker
# Documentation: http://www.ahay.org/RSF/sfricker.html
# Source: ahay/src system/seismic/Mricker.c — Ricker wavelet generator / filter.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'm=[initial frequency (Hz)]: :_default' \
    'niter=[number of iterations]: :_default' \
    'verb=[(y/n) verbose]: :(y n)' \
    '*:RSF file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
