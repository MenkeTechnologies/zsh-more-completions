#compdef scsictl
# Documentation: man scsictl(8)
# Source: netbsd/src sbin/scsictl — SCSI device and bus control (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:device:_default' \
    '2::command:(debug defects format identify reassign release reserve reset start stop tur getcache setcache flushcache setspeed getrealloc setrealloc reportluns scan detach)' \
    '*::arg:_default' \
    && ret=0

return ret
