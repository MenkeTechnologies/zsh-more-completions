#compdef sshfs-cli
# _sshfs-cli — libfuse SSHFS mount remote SSH filesystem CLI alias (libfuse / Miklos Szeredi, C); custom argparse
# upstream: https://github.com/libfuse/sshfs

_sshfs-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-o+[mount options key=value csv]:str:' \
        '-d[debug]' \
        '-f[foreground]' \
        '-s[single threaded]' \
        '-p+[port]:port:' \
        '-C[compression]' \
        '-F+[ssh config file]:file:_files -g ".ssh/config"' \
        '-1[force SSH protocol v1]' \
        '-2[force SSH protocol v2]' \
        '-4[force IPv4]' \
        '-6[force IPv6]' \
        '-o+[reconnect option]:str:' \
        '*:remote-and-mountpoint:_files -/'
}

_sshfs-cli "$@"
