#compdef quartus_drc
# _quartus_drc — Intel Altera Quartus quartus_drc CLI for the Design Assistant Design Rule Checker stage of the Quartus Prime FPGA flow validating clock async-reset gated-clock combinational-loop hold-violations Best Practices Hardware Manuals rules (Intel team, C++); custom argparse
# upstream: https://www.intel.com/content/www/us/en/products/details/fpga/development-tools/quartus-prime.html

_quartus_drc() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '--rev=+[revision]:str:' \
        '--revision=+[revision]:str:' \
        '--rule_categories=+[categories]:str:' \
        '--rule_severity=+[s]:s:(critical high medium low)' \
        '--default_rule_set[default rule set]' \
        '--custom_rule_set=+[file]:file:_files -g "*.qdr"' \
        '--report_to=+[report file]:file:_files -g "*.txt *.html"' \
        '--checkable_rules_count[count checkable rules]' \
        '--available_rules[list available rules]' \
        '--list-extensions[list extensions]' \
        '--archive=+[file]:file:_files -g "*.qar"' \
        '--64bit[64-bit mode]' \
        '*:project name:_files -g "*.qpf *.qsf"'
}

_quartus_drc "$@"
