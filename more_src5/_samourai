#compdef samourai samourai-wallet
# _samourai — Samourai Wallet samourai CLI helper utilities for the Samourai Wallet Bitcoin privacy ecosystem managing Whirlpool CoinJoin mixing pools STONEWALL Ricochet Stowaway PayJoin Whirlpool clients via Dojo backend or third-party Whirlpool coordinator (Samourai team, Java); JCommander
# upstream: https://github.com/Samourai-Wallet/whirlpool-client-cli

_samourai() {
    local -a sub=(
        'whirlpool:Whirlpool mixing operations'
        'tx0:create Tx0 premix'
        'mix:run mix'
        'status:show mixing status'
        'address:show address'
        'pools:list mixing pools'
        'wallet:wallet info'
        'utxos:list UTXOs'
        'aggregate:aggregate dust'
        'authenticate:authenticate to Dojo'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d+[directory]:dir:_files -/' \
        '--directory=+[directory]:dir:_files -/' \
        '--config=+[file]:file:_files -g "*.properties *.conf *.yaml *.yml"' \
        '--seed=+[seed mnemonic]:str:' \
        '--passphrase=+[passphrase]:str:' \
        '--scode=+[code]:str:' \
        '--dojo-url=+[url]:str:' \
        '--dojo-apikey=+[key]:str:' \
        '--tor[use Tor]' \
        '--testnet[use testnet]' \
        '--mainnet[use mainnet]' \
        '--client-cycle-clients=+[N]:n:' \
        '--client-cycle-pre-rotation=+[ms]:n:' \
        '--mix-clients=+[N]:n:' \
        '--mix-clients-per-pool=+[N]:n:' \
        '--mix-throttle-burst=+[N]:n:' \
        '--mix-throttle-flush=+[N]:n:' \
        '--pool=+[id]:p:(0.001btc 0.01btc 0.05btc 0.5btc)' \
        '--debug[debug]' \
        '--debug-client[debug client]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'samourai subcommand' sub ;;
        args)
            case $words[1] in
                tx0|mix) _arguments \
                    '--pool=+[id]:p:(0.001btc 0.01btc 0.05btc 0.5btc)' \
                    '--utxo=+[outpoint]:str:' \
                    '--fee-per-byte=+[sat/B]:n:' ;;
            esac
            ;;
    esac
}

_samourai "$@"
