#compdef sediffx
# Documentation: man sediffx(1)
# Source: SETools sediffx (man) — GUI SELinux policy diff tool (Python/Tcl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-d --diff-now)'{-d,--diff-now}'[load policies and diff immediately]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '1::original policy:_files' \
    '2::modified policy:_files' \
    && ret=0

return ret
