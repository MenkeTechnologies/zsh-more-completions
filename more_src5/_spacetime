#compdef spacetime
# Documentation: https://spacetimedb.com/docs/cli-reference
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--root-dir=[override SpacetimeDB root directory]:directory:_directories' \
  '--config-path=[override config file path]:file:_files' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'publish:Create and update a SpacetimeDB database'
      'delete:Remove a database entirely'
      'logs:Retrieve database output with follow/filtering'
      'rename:Change a database identifier'
      'dev:Run client binding generation, rebuild, and publish loop'
      'build:Compile a SpacetimeDB module'
      'generate:Generate client bindings (C#, TypeScript, Rust, Unreal C++)'
      'init:Initialize a new project from a template'
      'call:Execute a reducer in a database'
      'sql:Run SQL queries (interactive mode supported)'
      'subscribe:Subscribe to SQL query results'
      'describe:Inspect database structure/schema'
      'server:Manage server connections (list/add/remove/test)'
      'login:Authenticate with credentials'
      'logout:Clear stored credentials'
      'list:List databases associated with your identity'
      'start:Launch a local SpacetimeDB instance'
      'version:Manage installed SpacetimeDB versions'
      'help:Show help'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
