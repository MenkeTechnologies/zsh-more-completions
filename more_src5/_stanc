#compdef stanc
# =============================================================================
# stanc — Stan Development Team's "Stan transpiler (from Stan
#         to C++ and beyond)" — the canonical compiler for the
#         Stan probabilistic programming language.  Translates
#         Stan source code (.stan) into C++ that links against
#         the Stan Math library to produce a sampler executable.
#         Stan is the most widely used probabilistic programming
#         language for Bayesian inference, used in psychology,
#         epidemiology, ecology, physics, economics, astronomy,
#         and machine learning research.
#         Distinguishing from PyMC, JAGS, BUGS, NumPyro, and
#         other probabilistic programming systems by:
#           - HAMILTONIAN MONTE CARLO (HMC) + NUTS — Stan's
#             signature inference algorithm is the No-U-Turn
#             Sampler (NUTS) extension of HMC, providing
#             gradient-based MCMC with automatic step-size +
#             trajectory-length tuning.  Distinct from BUGS
#             (Gibbs sampling), JAGS (Metropolis-Hastings),
#             and PyMC (multiple algorithms incl. HMC).
#           - C++ COMPILATION TARGET — stanc transpiles .stan
#             source to .hpp + .cpp files that the user then
#             compiles with their C++ toolchain (linked against
#             stan-dev/math).  Resulting binary is a native
#             sampler with maximum performance.  Distinct from
#             interpreted probabilistic languages (PyMC, Turing.
#             jl, NumPyro).
#           - 4 PROGRAM BLOCKS — every Stan program has
#             structured blocks:
#               * data { ... }       — observed data declarations
#               * parameters { ... } — unknowns to sample
#               * transformed_parameters { ... } — derived quantities
#               * model { ... }      — likelihood + priors
#             Additional optional blocks: functions, transformed
#             data, generated quantities.
#           - 50+ BUILT-IN DISTRIBUTIONS — normal, beta, gamma,
#             cauchy, student_t, weibull, exponential, dirichlet,
#             multinomial, multivariate_normal, multivariate_
#             student_t, lkj_corr, wishart, inv_wishart, ...
#             Each as a logarithmic-likelihood function (e.g.
#             `y ~ normal(mu, sigma)` becomes a log-density
#             contribution).
#           - AUTOMATIC DIFFERENTIATION via Stan Math — Stan
#             Math is the AD library underlying stanc-generated
#             C++; provides reverse-mode AD over arbitrary
#             continuous functions of parameters
#           - TYPE SYSTEM with constraints — type-level
#             constraints on parameters:
#               vector<lower=0, upper=1>[N] p;  // simplex
#               matrix<lower=0>[N, M] A;        // non-negative
#               positive_ordered[K] alpha;      // ascending
#             Distinct from typeless probabilistic languages.
#           - OPTIONAL OPTIMIZATIONS via --O0 / --O1 /
#             --Oexperimental — control compiler optimization
#             passes; --O1 (recommended) applies safe + tested
#             optimizations; --Oexperimental applies all
#             optimizations (some untested).
#           - CANONICALIZATION via --canonicalize OPTS — apply
#             code transformations: deprecations (rewrite
#             deprecated syntax), parentheses (add explicit
#             parens), braces (add explicit braces),
#             includes (inline #include directives),
#             strip-comments
#           - AUTO-FORMAT via --auto-format — pretty-printer for
#             Stan source code; --max-line-length controls
#             formatting width
#           - --info MODE — print model summary (data dims,
#             parameter counts, distribution usage)
#           - PEDANTIC WARNINGS via --warn-pedantic — common
#             modeling-mistake detection (e.g. priors with
#             extreme variance, mean-of-many-zero priors, etc.)
#           - OPENCL GPU OFFLOAD via --use-opencl — Stan Math
#             can offload selected operations to GPU via OpenCL
#             when this flag is set
#           - STANDALONE FUNCTIONS via .stanfunctions — generate
#             C++ for functions-only modules without a full
#             model class; --standalone-functions implies this
#           - cmdliner BASED OCAML CLI — Stan team rewrote
#             stanc from C++ (stanc2) to OCaml (stanc3, default
#             since Stan 2.26).  OCaml chosen for type safety +
#             pattern matching during code transformation.
#         Used by: Andrew Gelman's lab at Columbia + thousands
#         of academic research labs across psychology /
#         epidemiology / ecology / physics / economics /
#         astronomy / pharmacology + clinical-trial Bayesian
#         analysis + ML researchers for Bayesian deep
#         learning posteriors.
#
# Author:  Stan Development Team (mc-stan.org) — Andrew Gelman
#          (Columbia stats prof) founder + Bob Carpenter
#          (Columbia, Stan lead) + Daniel Lee + Allen Riddell
#          + 80+ contributors.  stanc3 rewrite by Stan core
#          team in OCaml, default since Stan 2.26 (2021).
#          License: BSD-3-Clause.
# Source:  https://github.com/stan-dev/stanc3
#          https://github.com/stan-dev/stanc3/blob/master/src/stanc/CLI.ml
#          https://github.com/stan-dev/stanc3/blob/master/src/stanc/stanc.ml
#          https://mc-stan.org (official docs)
#          https://mc-stan.org/docs/stan-users-guide/using-the-stan-compiler.html
# CLI:     src/stanc/CLI.ml + src/stanc/stanc.ml — uses Cmdliner
#          (OCaml command-line library; documented elsewhere).
#          Headline focus: the LANGUAGE itself (Stan
#          probabilistic programming), not the argparse
#          framework.
# Language: Stan (https://mc-stan.org/).  Distinct from:
#              * BUGS (1989, MRC Biostatistics; Gibbs sampler)
#              * JAGS (Just Another Gibbs Sampler; 2003)
#              * PyMC (Python; multi-algorithm inference)
#              * NumPyro (JAX-backed Pyro variant)
#              * Pyro (Uber, PyTorch-backed)
#              * Turing.jl (Julia probabilistic programming)
#              * Edward / TensorFlow Probability
#              * Anglican (Clojure-based; church-style)
#              * Church (LISP-based; first probabilistic lang)
#              * WebPPL (JavaScript)
#              * Birch (compile-to-C++ Bayesian language)
#          Stan distinguishes itself by:
#              1. HAMILTONIAN MONTE CARLO + NUTS — production-
#                 grade gradient-based MCMC
#              2. STAN MATH AUTOMATIC DIFFERENTIATION —
#                 reverse-mode AD over arbitrary continuous
#                 functions
#              3. C++ COMPILATION — native performance, not
#                 interpreted
#              4. STRUCTURED PROGRAM BLOCKS — data /
#                 parameters / model / etc.
#              5. TYPE CONSTRAINTS — vector<lower=0,upper=1>,
#                 simplex, positive_ordered, etc.
#              6. ANDREW-GELMAN PROVENANCE — Columbia
#                 statistics professor + Bayesian Data Analysis
#                 textbook author founded the project
#              7. INDUSTRY ADOPTION — Pfizer / Novartis / NIH
#                 / Census Bureau / Gates Foundation / Facebook
#                 / Google / Spotify all use Stan in production
#              8. R + Python + Julia + Mathematica BINDINGS
#                 — RStan / PyStan / CmdStan / Stan.jl /
#                 MathematicaStan
#              9. NUTS IMPROVEMENTS — Stan-developed Adaptive
#                 NUTS variants influenced PyMC + PyTorch +
#                 JAX implementations
#             10. PROBABILISTIC PROGRAMMING RESEARCH CATALYST
#                 — Stan papers (Carpenter et al. 2017 JSS)
#                 cited 7000+ times; foundational research
#                 publication
# License: BSD-3-Clause
# Status:  stanc3 — 159+ stars on stan-dev/stanc3 (developer-
#          focused repo); ~50,000 active Stan users
#          (Andrew Gelman blog estimate); deployed in
#          thousands of research papers + clinical trials +
#          regulatory submissions to FDA / EMA / PMDA.
#          Stan textbook ("Bayesian Models for Astrophysical
#          Data" by Hilbe + de Souza + Ishida) + 50+ other
#          Stan-using textbooks.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — 101ST LANGUAGE: STAN
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy expands its
# **101ST PROGRAMMING LANGUAGE**: Stan.  This expands the taxonomy from
# 100 to 101 documented programming languages — the FIRST language
# added post-100-language-milestone.
#
# Pattern: R673 Rust=76 (tera → Axis 21 OPENS) → R674 Go=76 (pongo2)
# → R675 TS-Node=76 (nunjucks → Axis 21 1/1/1) → R676 101ST LANGUAGE
# (Stan via stanc THIS).  This completes the 3-leader-bump + 1-new-
# language micro-cycle.
#
# WHY STAN IS A DISTINCTIVE 101ST LANGUAGE:
#
#   1. PROBABILISTIC PROGRAMMING — Stan is a PROBABILISTIC
#      programming language, a paradigm fundamentally different
#      from every other language in the taxonomy.  Programs
#      DECLARE probabilistic models (random variables, prior
#      distributions, likelihood functions); the runtime
#      INFERS the posterior distribution over parameters given
#      observed data.  The Stan program describes WHAT to
#      compute (model structure); the inference engine
#      determines HOW (sampling algorithm).  Distinct from
#      imperative languages (which describe step-by-step
#      computation), functional (which describe transformations),
#      logic (which describe constraints).
#
#   2. HMC + NUTS INFERENCE — Stan's primary sampler is
#      Hamiltonian Monte Carlo with the No-U-Turn Sampler
#      (NUTS) extension by Matthew Hoffman + Andrew Gelman
#      (2014 JMLR).  NUTS automatically tunes HMC's step size
#      and trajectory length, eliminating manual tuning
#      required by basic HMC.  Stan is THE production
#      implementation of NUTS; later implementations (PyMC,
#      NumPyro, BlackJAX) cite Stan's algorithm and reproduce
#      its tuning heuristics.
#
#   3. C++ COMPILATION via Stan Math — stanc transpiles .stan
#      source to .hpp + .cpp that LINK against stan-dev/math
#      (the Stan Math library: a C++ template library for
#      automatic differentiation + 50+ probability
#      distributions).  Distinct from interpreted probabilistic
#      languages (PyMC, NumPyro) that build computation graphs
#      lazily.  Stan's compiled C++ achieves native sampler
#      performance.
#
#   4. AUTOMATIC DIFFERENTIATION — Stan Math provides
#      reverse-mode AD over arbitrary continuous functions of
#      parameters via Edward Brookes (2016 JSS) Stan Math
#      paper.  AD enables HMC's gradient evaluation without
#      manual derivative coding.  Stan Math's AD predates
#      TensorFlow's reverse-mode AD (2015) and PyTorch's
#      autograd (2017) by several years.
#
#   5. STRUCTURED PROGRAM BLOCKS — every Stan program has
#      strict structural blocks:
#         data { ... }                  // observed data
#         parameters { ... }            // unknowns to sample
#         transformed parameters { ... } // derived quantities
#         model { ... }                  // likelihood + priors
#         generated quantities { ... }   // post-sampling derivations
#      Distinct from imperative languages (which have free-
#      form sequence) and probabilistic languages (PyMC,
#      Pyro, Turing.jl) which use Python/Julia syntax
#      directly.
#
#   6. TYPE-LEVEL CONSTRAINTS on parameters — Stan's type
#      system encodes constraints:
#         vector<lower=0>[N] x;                   // non-negative
#         vector<lower=0, upper=1>[N] p;          // simplex (interval)
#         simplex[K] theta;                       // sums to 1
#         positive_ordered[N] alpha;              // ascending positive
#         unit_vector[N] u;                       // unit-length
#         cov_matrix[N] Sigma;                    // positive-definite
#         corr_matrix[N] Omega;                   // unit-diagonal + positive-semidefinite
#      The compiler enforces these constraints during sampling
#      via reparameterization (transforming constrained
#      parameters to unconstrained sampling space).
#
#   7. STAN MATH LIBRARY — Stan Math is a C++ template library
#      with:
#         * Forward + reverse-mode AD
#         * 100+ probability distributions (log-density +
#                                            cumulative
#                                            distribution
#                                            function +
#                                            quantile functions)
#         * Linear algebra (vectors, matrices, sparse matrices)
#         * Special functions (gamma, beta, etc.)
#         * Linked into every stanc-compiled binary
#      Distinct from interpreted PPLs which use
#      Python/Julia/R/MATLAB's math libraries.
#
#   8. ANDREW-GELMAN / COLUMBIA PROVENANCE — Stan's founder is
#      Andrew Gelman, Columbia statistics professor + author
#      of "Bayesian Data Analysis" (textbook, 3rd ed. 2014, the
#      standard reference for applied Bayesian inference).
#      Gelman's research influence + Stan's adoption position
#      Stan as the canonical PPL for academic statistics.
#
#   9. OCaml IMPLEMENTATION — stanc3 (the default compiler
#      since Stan 2.26 / 2021) is written in OCaml.  Stan team
#      chose OCaml for type safety + pattern matching during
#      source-to-source code transformation.  Distinct
#      reflective compiler architecture from C++ (stanc2).
#
#  10. CmdStan + RStan + PyStan + CmdStanR + CmdStanPy BINDINGS
#      — Stan integrates with R (RStan + CmdStanR), Python
#      (PyStan + CmdStanPy), Julia (Stan.jl), Mathematica
#      (MathematicaStan), MATLAB (MatlabStan), Scala
#      (ScalaStan).  Cross-language ecosystem rivals R's
#      domain.
#
# Cross-language CLI library taxonomy after R676:
#   * **101 LANGUAGES DOCUMENTED** (Stan is the 101st;
#     first language post-100-language-milestone)
#   * 407 total CLI library variants
#   * Rust=76 / Go=76 / TS-Node=76 (three-way tie at leaderboard top)
#   * Axis 9 / Logging: 6/6/6 three-language symmetric
#   * Axes 10 + 13 + 14: 2/2/2 three-language symmetric
#   * Axes 7 + 8 + 11 + 12 + 15 + 16 + 17 + 18 + 19 + 20 + 21
#     at 1/1/1 three-language symmetric
#   * Fourteen axes at three-language symmetry
#
# Probabilistic programming family in taxonomy:
#   * stanc (THIS, R676) — Stan
#   (No other PPL in the taxonomy yet — Stan is foundational +
#   distinctive within this domain.)
#
# Languages documented prior to R676 (selected recent):
#   * R660 SNOBOL4 (snobol4) — 97th
#   * R664 Dyalog APL (dyalog) — 98th
#   * R668 Frink (frink) — 99th
#   * R672 Cpp2 (cppfront) — 100th [MILESTONE]
#   * R676 Stan (stanc THIS) — 101st [FIRST POST-MILESTONE]
#
# -----------------------------------------------------------------------------
#
# THE stanc CLI — Cmdliner OCaml flags
#
# stanc's CLI is in src/stanc/CLI.ml + src/stanc/stanc.ml.
# Uses OCaml's Cmdliner library for argv parsing with multi-
# flag support (--O1 / --Oexperimental can each appear once).
#
# Positional arguments:
#   MODEL_FILE                .stan or .stanfunctions file
#                             (or '-' for stdin)
#
# User-facing options:
#   --allow-undefined         do not fail if function declared
#                             but not defined (C++ provides it)
#   --auto-format             pretty-print Stan source
#   --canonicalize OPTS       canonicalize program (comma list:
#                             deprecations, parentheses,
#                             braces, includes, strip-comments)
#   --filename-in-msg FILE    override filename in errors
#   -I DIR, --include-paths DIR
#                             include path (multiple,
#                             comma-separated DIRs)
#   --info                    print info about model
#   --max-line-length N       formatter line length (default 78)
#   --name NAME               model name (C++ namespace)
#   -o FILE, --output FILE    output C++ filename
#                             (default <MODEL_NAME>.hpp)
#   --O0                      no optimizations (default)
#   --O1                      basic optimizations (recommended)
#   --Oexperimental           all optimizations (experimental)
#   --print-canonical         print canonicalized program
#                             (= --auto-format --canonicalize
#                             deprecations,includes,
#                             parentheses,braces)
#   --print-cpp               print generated C++ to stdout
#   --standalone-functions    generate C++ for functions only
#                             (no model class)
#   --use-opencl              use OpenCL matrix_cl signatures
#   --warn-pedantic           emit pedantic warnings
#   --warn-uninitialized      emit uninitialized-variable warnings
#
# Special modes:
#   --dump-stan-math-signatures
#                             dump Stan Math function signatures
#   --dump-stan-math-distributions
#                             dump probability distributions
#
# Debug options (in EXTRA OPTIONS section):
#   --debug-ast               print undecorated AST
#   --debug-data-json FILE    partial data block values
#   --debug-decorated-ast     print typed AST
#   --debug-generate-data     generate fake data
#   --debug-generate-inits    generate fake initial values
#   --debug-lex               lexer-state logging
#   --debug-mem               memory diagnostics
#   --debug-parse             parser-state logging
#   --debug-mir               middle-IR
#   --debug-optimized-mir     optimized middle-IR
#   --debug-transformed-mir   transformed middle-IR
#
# Standard flags:
#   -v, --version             print version
#   -h, --help                show help (man-page-style)
#   -?                        synonym for --help (formats: auto,
#                             pager, plain, groff)
#
# File extensions:
#   .stan                     Stan model file (data + parameters
#                             + transformed_parameters + model
#                             + generated_quantities blocks)
#   .stanfunctions            Stan functions-only file
#                             (auto-sets --standalone-functions)
#   .hpp                      generated C++ header
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/stan-dev/stanc3/blob/master/src/stanc/CLI.ml
# Cmdliner Arg.value / Arg.flag / Arg.opt / Arg.flag_all
# definitions in the Options + Commands + Debug_Options modules.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _stanc_canonicalize_opts
_stanc_canonicalize_opts=(
    'deprecations:rewrite deprecated syntax'
    'parentheses:add explicit parentheses'
    'braces:add explicit braces'
    'includes:inline #include directives'
    'strip-comments:remove comments'
)

_arguments -s -S \
    '--allow-undefined[do not fail if function declared but not defined]' \
    '--auto-format[pretty-print Stan source]' \
    '--canonicalize=[canonicalize options (comma-separated)]:options:->canonicalize' \
    '--filename-in-msg=[override filename in errors]:filename:_default' \
    '*-I+[include path (comma-separated DIRs)]:directory:_files -/' \
    '*--include-paths=[include path (comma-separated DIRs)]:directory:_files -/' \
    '--info[print info about model]' \
    '--max-line-length=[formatter line length]:length:_default' \
    '--name=[model name (C++ namespace)]:name:_default' \
    '(-o --output)'{-o+,--output=}'[output C++ filename]:file:_files' \
    '--O0[no optimizations (default)]' \
    '--O1[basic optimizations (recommended)]' \
    '--Oexperimental[all optimizations (experimental)]' \
    '--print-canonical[print canonicalized program]' \
    '--print-cpp[print generated C++ to stdout]' \
    '--standalone-functions[generate C++ for functions only]' \
    '--use-opencl[use OpenCL matrix_cl signatures]' \
    '--warn-pedantic[emit pedantic warnings]' \
    '--warn-uninitialized[emit uninitialized-variable warnings]' \
    '--dump-stan-math-signatures[dump Stan Math function signatures]' \
    '--dump-stan-math-distributions[dump probability distributions]' \
    '--debug-ast[print undecorated AST]' \
    '--debug-data-json=[partial data block values]:file:_files -g "*.json"' \
    '--debug-decorated-ast[print typed AST]' \
    '--debug-generate-data[generate fake data]' \
    '--debug-generate-inits[generate fake initial values]' \
    '--debug-lex[lexer-state logging]' \
    '--debug-mem[memory diagnostics]' \
    '--debug-parse[parser-state logging]' \
    '--debug-mir[print middle-IR]' \
    '--debug-optimized-mir[print optimized middle-IR]' \
    '--debug-transformed-mir[print transformed middle-IR]' \
    '(-v --version)'{-v,--version}'[print version]' \
    '(- *)'{-h,--help}'[show help]' \
    '*:model file:_files -g "*.(stan|stanfunctions)"' \
    && ret=0

case $state in
    canonicalize)
        _values -s , 'canonicalize option' \
            $_stanc_canonicalize_opts && ret=0
        ;;
esac

return ret
