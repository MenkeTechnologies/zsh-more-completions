#compdef rocalution-test rocalution-benchmark
# _rocalution — AMD ROCm rocALUTION sparse iterative solver and preconditioner library test and benchmark runners (ROCm team, C++); custom argparse
# upstream: https://github.com/ROCm/rocALUTION

_rocalution() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--gtest_filter=+[pattern]:str:' \
        '--gtest_list_tests[list tests]' \
        '--gtest_repeat=+[N]:n:' \
        '--gtest_random_seed=+[N]:n:' \
        '--gtest_color=+[mode]:m:(yes no auto)' \
        '--matrix=+[mtx file]:file:_files -g "*.mtx *.bin"' \
        '--solver=+[solver]:s:(CG BiCGStab GMRES FGMRES IDR FixedPoint Krylov Chebyshev MixedPrecisionDC MultiGrid PairwiseAMG SAAMG UAAMG RAS Jacobi ILU ILUT IC ICUT GaussSeidel SOR SSOR MultiColoredGS MultiColoredSGS MultiColoredILU MultiColoredSGS MultiElimination DiagonalScaling AS BlockJacobi VariablePreconditioner LineJacobi)' \
        '--preconditioner=+[preconditioner]:p:(Jacobi MultiColoredGS MultiColoredSGS ILU ILUT IC ICUT GaussSeidel SOR SSOR DiagonalScaling AS BlockJacobi VariablePreconditioner)' \
        '--max-iter=+[N]:n:' \
        '--abs-tol=+[F]:f:' \
        '--rel-tol=+[F]:f:' \
        '--div-tol=+[F]:f:' \
        '--restart=+[N]:n:' \
        '--ilu-fill=+[N]:n:' \
        '--ilut-tol=+[F]:f:' \
        '--levels=+[N]:n:' \
        '--smoother=+[smoother]:str:' \
        '--cycle=+[cycle]:c:(V W F K)' \
        '--coarse-solver=+[solver]:str:' \
        '--device=+[id]:n:' \
        '--threads=+[N]:n:' \
        '--mpi[enable MPI]' \
        '--format=+[format]:f:(csr coo dense bcsr hyb ell dia mcsr)' \
        '--storage=+[format]:f:(csr coo dense bcsr hyb ell dia mcsr)' \
        '--scale=+[scaling]:s:(jacobi none symmetric row column)' \
        '--verbose=+[level]:n:'
}

_rocalution "$@"
