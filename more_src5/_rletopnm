#compdef rletopnm
# Documentation: man rletopnm (Netpbm)
# Source: convert a Utah Raster Toolkit RLE file to PNM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--alphaout=[alpha output file (- for stdout)]:file:_files' \
    '(-h --headerdump)'{-h,--headerdump}'[dump RLE header info]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:rle file:_files -g "*.rle"' \
    && ret=0

return ret
