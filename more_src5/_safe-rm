#compdef safe-rm
# Documentation: https://github.com/kaelzhang/shell-safe-rm
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above. safe-rm is a wrapper around
# rm(1); short flags -f -i -I -r/-R -d -v match the kaelzhang README.
# Long GNU-rm pass-through flags (--interactive=WHEN, --one-file-system,
# --no-preserve-root, --preserve-root) reach the underlying rm.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-f --force)'{-f,--force}'[ignore nonexistent files and arguments]' \
  '(-i)-i[prompt before every removal]' \
  '-I[prompt once before removing more than three files]' \
  '(-r -R --recursive)'{-r,-R,--recursive}'[remove directories and their contents recursively]' \
  '(-d --dir)'{-d,--dir}'[remove empty directories]' \
  '(-v --verbose)'{-v,--verbose}'[explain what is being done]' \
  '--interactive=-[prompt according to WHEN]:when:(never once always)' \
  '--one-file-system[do not cross filesystem boundaries]' \
  '--no-preserve-root[do not treat / specially]' \
  '--preserve-root=-[do not remove /]:option:(all)' \
  '--help[display help]' \
  '--version[display version]' \
  '*:file:_files' && ret=0

return ret
