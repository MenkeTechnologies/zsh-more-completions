#compdef stfinddevice
# _stfinddevice — query Syncthing global-discovery for a device-ID (syncthing/syncthing)
# upstream: https://github.com/syncthing/syncthing
# Flags from cmd/dev/stfinddevice/main.go (stdlib flag).

_stfinddevice() {
    _arguments \
        '(- *)-h[show help]' \
        '-server=[announce server URL (blank = default set)]:url:' \
        '-timeout=[query timeout]:duration:' \
        '1:device ID:'
}

_stfinddevice "$@"
