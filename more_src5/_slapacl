#compdef slapacl
# _slapacl — OpenLDAP slapacl (offline test of slapd access control lists; -F config dir, -f slapd.conf, -b suffix, -D bind DN, -u username SASL authzid, -X authz extended, -d debug, -v verbose, -V version, --version; positional: DN attr=value ...; prints whether the bind DN is permitted to read or write the requested attributes)
# upstream: https://git.openldap.org/openldap/openldap (servers/slapd/slapacl)
# Flags from OpenLDAP servers/slapd/slapacl.c on tip.

_slapacl() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-F+[config dir]:dir:_files -/' \
        '-f+[slapd.conf]:file:_files' \
        '-b+[suffix]:dn:' \
        '-D+[bind DN]:dn:' \
        '-u+[username]:user:_users' \
        '-X+[authzid]:authzid:' \
        '-d+[debug]:level:' \
        '-v[verbose]' \
        '1:DN:' \
        '*:attr=value:'
}

_slapacl "$@"
