#compdef shlibsign
# Documentation: man shlibsign(1)
# Source: nss-dev/nss cmd/shlibsign/shlibsign.c (master) — generate shared library checksums (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-i+[input shared library to process]:file:_files -g "*.{so,dylib,dll}"' \
    '-o+[output checksum file]:file:_files' \
    '-d+[NSS database directory]:dir:_files -/' \
    '-t+[hash algorithm]:hash:(MD2 MD5 SHA1 SHA224 SHA256 SHA384 SHA512)' \
    '-D[sign with DSA (default HMAC)]' \
    '-k+[DSA key size]:bits:_default' \
    '-K+[HMAC key material (hex)]:hex:_default' \
    '-c[compatible versions for old NSS]' \
    '-P+[database prefix]:prefix:_default' \
    '-f+[password file]:file:_files' \
    '(-F -C)-F[force FIPS mode]' \
    '(-F -C)-C[force non-FIPS mode]' \
    '-p+[password]:password:_default' \
    '-v[verbose output]' \
    '-V[perform verify operations]' \
    '-h[short help]' \
    '-H[long help]' \
    && ret=0

return ret
