#compdef sccan
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/sccan.cxx — sparse canonical correlation analysis (C++, itk parser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-o --output)'{-o+,--output=}'[output image / matrix]:file:_files' \
    '(-p --n_permutations)'{-p+,--n_permutations=}'[number of permutations]:n:_default' \
    '(-s --smoother)'{-s+,--smoother=}'[smoother level]:n:_default' \
    '(-z --row_sparseness)'{-z+,--row_sparseness=}'[row sparseness]:n:_default' \
    '(-i --iterations)'{-i+,--iterations=}'[max iterations (default 20)]:n:_default' \
    '(-n --n_eigenvectors)'{-n+,--n_eigenvectors=}'[number of eigenvectors (default 1)]:n:_default' \
    '(-r --robustify)'{-r+,--robustify=}'[robustify flag]:n:(0 1)' \
    '--covering=[covering parameter]:n:_default' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
