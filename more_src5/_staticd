#compdef staticd
# Documentation: https://docs.frrouting.org/en/latest/basic.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --daemon)'{-d,--daemon}'[run in daemon mode]' \
  '(-f --config_file)'{-f,--config_file}'+[set configuration file]:file:_files' \
  '(-i --pid_file)'{-i,--pid_file}'+[pid file]:file:_files' \
  '(-z --socket)'{-z,--socket}'+[zebra socket]:file:_files' \
  '(-A --vty_addr)'{-A,--vty_addr}'+[set VTY local address to bind to]:addr:' \
  '(-P --vty_port)'{-P,--vty_port}'+[set VTY TCP port number]:port:' \
  '(-N --pathspace)'{-N,--pathspace}'+[set namespace the daemon runs in]:ns:' \
  '-u+[set user (and optional :group) to run as]:user:_users' \
  '(-M --module)'{-M,--module}'+[load extension module]:module:' && ret=0

return ret
