#compdef sml
# Documentation: https://github.com/smlnj/smlnj/blob/main/doc/src/man/sml.1.adoc
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-32[run 32-bit version]' \
  '-64[run 64-bit version (x86-64)]' \
  '@SMLwordsize[echo wordsize and exit]' \
  '@SMLversion[echo version and exit]' \
  '@SMLload=[load heap image]:image:_files' \
  '@SMLcmdname=[set command name]:name:' \
  '@SMLsuffix[echo heap suffix and exit]' \
  '@SMLalloc=[allocation area size]:size:' \
  '@SMLrun=[runtime system]:runtime:' \
  '@SMLquiet[load heap silently (default)]' \
  '@SMLverbose[show heap load progress]' \
  '@SMLobjects[show list of executable objects]' \
  '@SMLdebug=[debug info file]:file:_files' \
  '*-C-[set control to value]:ctl=value:' \
  '*-D-[define CM variable]:name=value:' \
  '*-U-[remove CM variable definition]:name:' \
  '-H[complete help listing]' \
  '-h[minimal help listing]' \
  '-S[list all controls with defaults]' \
  '-E[list all controls with env vars]' \
  '-m[switch to CM.make]' \
  '-a[switch to CM.autoload (default)]' \
  '*:file:_files -g "*.(cm|sml|sig|fun)"' && ret=0

return ret
