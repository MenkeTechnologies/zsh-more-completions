#compdef surfaceCheck
# Documentation: https://www.openfoam.com/documentation/user-guide/4-mesh-generation-and-conversion
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/surface/surfaceCheck/surfaceCheck.C — diagnose surface mesh quality.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show application documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[case directory]:dir:_directories' \
    '-fileHandler+[override fileHandler]:handler:_default' \
    '-libs+[pre-load libraries]:libs:_default' \
    '-checkSelfIntersection[also check for self-intersection]' \
    '-splitNonManifold[split surface along non-manifold edges]' \
    '-verbose[verbose operation]' \
    '-blockMesh[write vertices/blocks for blockMeshDict]' \
    '1:surface file:_files -g "*.(stl|obj|nas|inp|vtk|tri|ftr|ofs)(-.)"' \
    && ret=0

return ret
