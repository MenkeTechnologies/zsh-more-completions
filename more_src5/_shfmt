#compdef shfmt
# Documentation: shfmt --help on shfmt 3.13.x
# Source: mvdan/sh — shell formatter (bash/posix/mksh/bats/zsh).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--version[show version and exit]' \
    '(-l --list)'{-l,--list}'[error with list of paths whose formatting differs]' \
    '(-w --write)'{-w,--write}'[write result to file instead of stdout]' \
    '(-d --diff)'{-d,--diff}'[error with a diff when formatting differs]' \
    '--apply-ignore[always apply EditorConfig ignore rules]' \
    '--filename=[provide a name for the standard-input file]:name:' \
    '(-ln --language-dialect)'{-ln,--language-dialect=}'[shell dialect]:dialect:(auto bash posix mksh bats zsh)' \
    '(-p --posix)'{-p,--posix}'[shorthand for -ln=posix]' \
    '(-s --simplify)'{-s,--simplify}'[simplify the code]' \
    '(-i --indent)'{-i,--indent=}'[0 = tabs (default), >0 = number of spaces]:n:' \
    '(-bn --binary-next-line)'{-bn,--binary-next-line}'[binary ops like && and | may start a line]' \
    '(-ci --case-indent)'{-ci,--case-indent}'[indent switch cases]' \
    '(-sr --space-redirects)'{-sr,--space-redirects}'[redirect operators followed by a space]' \
    '(-kp --keep-padding)'{-kp,--keep-padding}'[keep column-alignment paddings]' \
    '(-fn --func-next-line)'{-fn,--func-next-line}'[function opening braces on separate line]' \
    '(-mn --minify)'{-mn,--minify}'[minify code to reduce size (implies -s)]' \
    '(-f --find)'{-f,--find}'[recursively find shell files and print paths]' \
    '--to-json[print syntax tree to stdout as typed JSON]' \
    '--from-json[read syntax tree from stdin as typed JSON]' \
    '*:path:_files' \
    && ret=0

return ret
