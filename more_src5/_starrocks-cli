#compdef starrocks-cli starrocks2 sr-cli
# _starrocks-cli — StarRocks starrocks-cli CLI command-line frontend wrapping the StarRocks high-performance MPP analytical database forked from Apache Doris managing fe-frontend be-backend cn-compute-node broker primary-key-vectorized-engine pipeline-execution-engine materialized-view shared-data shared-nothing data-lake-analytics Iceberg-Hudi-Delta-Hive ETL stream-load broker-load routine-load mysql-protocol-client (CelerData StarRocks team, C++/Java); custom argparse
# upstream: https://www.starrocks.io/

_starrocks-cli() {
    local -a sub=(
        'fe:run frontend'
        'be:run backend'
        'cn:run compute node'
        'broker:run broker'
        'mysql:open MySQL client'
        'stream-load:stream load'
        'broker-load:broker load'
        'routine-load:routine load'
        'spark-load:spark load'
        'insert:insert into'
        'show:show command'
        'admin:admin command'
        'alter:alter command'
        'create:create command'
        'drop:drop command'
        'analyze:analyze stats'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--host=+[host]:_hosts' \
        '-H+[host]:_hosts' \
        '--port=+[port]:n:' \
        '-P+[port]:n:' \
        '--user=+[user]:_users' \
        '-u+[user]:_users' \
        '--password=+[password]:str:' \
        '-p+[password]:str:' \
        '--database=+[db]:str:' \
        '-d+[db]:str:' \
        '--table=+[name]:str:' \
        '-t+[table]:str:' \
        '--label=+[name]:str:' \
        '--columns=+[cols]:str:' \
        '--column-separator=+[sep]:str:' \
        '--row-delimiter=+[delim]:str:' \
        '--format=+[fmt]:f:(csv json orc parquet)' \
        '--max-filter-ratio=+[N]:n:' \
        '--timeout=+[sec]:n:' \
        '--strict-mode[strict mode]' \
        '-c+[config file]:file:_files -g "fe.conf be.conf *.conf"' \
        '--config=+[file]:file:_files -g "fe.conf be.conf *.conf"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'starrocks subcommand' sub ;;
        args) _arguments '*:arg:' ;;
    esac
}

_starrocks-cli "$@"
