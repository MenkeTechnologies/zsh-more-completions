#compdef smolagents
# _smolagents — Hugging Face smolagents minimalist code-agent and tool-use framework CLI running agents that write and execute Python code with secure sandboxing (huggingface team, Python); typer
# upstream: https://github.com/huggingface/smolagents

_smolagents() {
    local -a sub=(
        'run:run an agent'
        'chat:interactive agent chat'
        'eval:run agent eval'
        'list-models:list supported models'
        'list-tools:list available tools'
        'list-sandboxes:list sandboxes'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--model=+[m]:m:(Qwen/Qwen2.5-Coder-32B-Instruct meta-llama/Llama-3.3-70B-Instruct mistralai/Mistral-Large-Instruct-2407 google/gemma-3-27b-it deepseek-ai/DeepSeek-R1 anthropic/claude-opus-4-7 openai/gpt-4o openai/o3 openai/o1)' \
        '--provider=+[p]:p:(hf-inference together fireworks-ai sambanova groq fal-ai novita replicate openai anthropic litellm)' \
        '--agent-type=+[t]:t:(code-agent tool-calling-agent multistep planner reactjson openagi)' \
        '--max-steps=+[N]:n:' \
        '--max-tokens=+[N]:n:' \
        '--temperature=+[F]:f:' \
        '--sandbox=+[s]:s:(local e2b modal docker)' \
        '--api-key=+[key]:str:' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'smolagents subcommand' sub ;;
        args)
            case $words[1] in
                run|chat) _arguments \
                    '--task=+[task]:str:' \
                    '--tools=+[csv]:str:' \
                    '--imports=+[csv modules]:str:' \
                    '--planning-interval=+[N]:n:' \
                    '*:task description:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_smolagents "$@"
