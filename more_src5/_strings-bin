#compdef strings
# _strings-bin — GNU binutils strings; print printable character sequences from binary files
# upstream: https://sourceware.org/binutils

_strings-bin() {
    _arguments \
        '(-a --all)'{-a,--all}'[scan whole file]' \
        '-d[only scan data sections]' \
        '(-f --print-file-name)'{-f,--print-file-name}'[print filename]' \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-i --include-all-whitespace)'{-i,--include-all-whitespace}'[include all whitespace]' \
        '(-n --bytes)'{-n,--bytes}'+[min length]:n:' \
        '(-o)-o[octal offsets]' \
        '(-t --radix)'{-t,--radix}'+[radix for offsets]:base:(d o x)' \
        '(-T --target)'{-T,--target}'+[BFD target]:target:' \
        '(-e --encoding)'{-e,--encoding}'+[encoding]:enc:(s S b l B L)' \
        '(-w --include-all-whitespace)'{-w,--include-all-whitespace}'[include all whitespace]' \
        '-s+[separator]:str:' \
        '(-U --unicode)'{-U,--unicode}'+[unicode]:mode:(default invalid locale escape hex highlight)' \
        '(-V --version)'{-V,--version}'[show version]' \
        '*:file:_files'
}

_strings-bin "$@"
