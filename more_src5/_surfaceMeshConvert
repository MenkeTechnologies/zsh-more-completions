#compdef surfaceMeshConvert
# Documentation: https://cfd.direct/openfoam/user-guide/
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/surface/surfaceMeshConvert — convert surface mesh format with coordinate system support (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[OpenFOAM case directory]:dir:_files -/' \
    '-fileHandler+[file handler]:handler:(uncollated collated masterUncollated)' \
    '-noFunctionObjects[disable function objects]' \
    '-clean[clean/check surface]' \
    '-scaleIn+[input scaling factor]:factor:_default' \
    '-scaleOut+[output scaling factor]:factor:_default' \
    '-from+[input coordinate system]:system:_default' \
    '-to+[output coordinate system]:system:_default' \
    '-tri[force triangulated output]' \
    '1:input surface:_files -g "*.{stl,obj,nas,vtk,off,gts,inp}"' \
    '2:output surface:_files' \
    && ret=0

return ret
