#compdef qqem
# Documentation: https://doc.qt.io/QtQuickEffectMaker/qqem-overview.html
# Reference accessed: 2026-05-20
# Verified: local `qqem --help` output (Qt Quick Effect Maker 6.11.1).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show help including Qt options]' \
  '(- *)'{-v,--version}'[show version]' \
  '--exportpath=[path for exporting effect]:path:_files -/' \
  '--create[create a new project]' \
  '*:project file:_files -g "*.qep"' && ret=0

return ret
