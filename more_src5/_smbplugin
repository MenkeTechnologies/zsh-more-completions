#compdef smbplugin
# _smbplugin — Kubernetes CSI SMB / CIFS driver (mounts SMB shares as PV; supports Windows nodes and Kerberos)
# upstream: https://github.com/kubernetes-csi/csi-driver-smb
# Flags from cmd/smbplugin/main.go on tip.

_smbplugin() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--ver[print the version and exit]' \
        '--endpoint=[CSI endpoint]:uri:' \
        '--nodeid=[node id]:id:' \
        '--drivername=[name of the driver]:name:' \
        '--metrics-address=[Prometheus metrics bind address]:addr:' \
        '--kubeconfig=[kubeconfig file (required out of cluster)]:file:_files' \
        '--enable-get-volume-stats=[allow GET_VOLUME_STATS on agent node]:bool:(true false)' \
        '--remove-smb-mapping-during-unmount=[remove SMBMapping during unmount on Windows]:bool:(true false)' \
        '--working-mount-dir=[temp working dir for provisioner mounts]:dir:_files -/' \
        '--vol-stats-cache-expire-in-minutes=[volume stats cache TTL]:min:' \
        '--krb5-cache-directory=[Kerberos cache directory]:dir:_files -/' \
        '--krb5-prefix=[Kerberos cache filename prefix]:prefix:' \
        '--default-ondelete-policy=[default subdirectory delete policy]:policy:(delete retain archive)' \
        '--remove-archived-volume-path=[remove archived volume path on DeleteVolume]:bool:(true false)' \
        '--enable-windows-host-process[enable Windows HostProcess container]' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_smbplugin "$@"
