#compdef stratovirt
# _stratovirt — Huawei OpenEuler stratovirt secure lightweight hypervisor written in Rust for cloud workloads (openeuler team, Rust); custom argparse
# upstream: https://gitee.com/openeuler/stratovirt

_stratovirt() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-name+[VM name]:str:' \
        '-machine+[machine config]:str:' \
        '-smp+[SMP config]:str:' \
        '-m+[memory size]:str:' \
        '-cpu+[CPU model]:str:' \
        '-kernel+[kernel image]:file:_files' \
        '-initrd+[initrd image]:file:_files' \
        '-append+[kernel cmdline]:str:' \
        '-bios+[BIOS image]:file:_files' \
        '-drive+[drive config]:str:' \
        '-device+[device config]:str:' \
        '-netdev+[netdev config]:str:' \
        '-chardev+[chardev config]:str:' \
        '-serial+[serial config]:str:' \
        '-monitor+[monitor config]:str:' \
        '-qmp+[QMP socket]:str:' \
        '-mod-test+[unit test mode]:str:' \
        '-disable-seccomp[disable seccomp]' \
        '-D+[log file]:file:_files' \
        '-d+[debug filter]:str:' \
        '-pidfile+[pid file]:file:_files' \
        '-mem-prealloc[preallocate memory]' \
        '-mem-share[share memory]' \
        '-mem-path+[memory backing file]:file:_files' \
        '-overcommit+[overcommit policy]:str:' \
        '-display+[display config]:str:' \
        '-vnc+[VNC config]:str:' \
        '-incoming+[migration uri]:str:' \
        '-numa+[NUMA config]:str:' \
        '-object+[object config]:str:' \
        '-iothread+[iothread config]:str:' \
        '-virtio-iothread+[virtio iothread]:str:' \
        '-no-reboot[no reboot]' \
        '-rtc+[RTC config]:str:' \
        '-balloon+[balloon config]:str:' \
        '-no-shutdown[no shutdown]' \
        '-smbios+[SMBIOS config]:str:' \
        '-windows-emu-pid+[pid]:n:' \
        '-fsdev+[fsdev config]:str:' \
        '-pflash+[pflash file]:file:_files' \
        '-stdout-output[stdout output]' \
        '-vmstate-flags+[flags]:str:'
}

_stratovirt "$@"
