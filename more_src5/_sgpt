#compdef sgpt
# Documentation: https://github.com/TheR1D/shell_gpt
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
  '--model[LLM model name]:model:'
  '--temperature[sampling temperature (0.0-2.0)]:temperature:'
  '--top-p[nucleus sampling probability (0.0-1.0)]:top_p:'
  '--md[enable markdown formatting]'
  '--no-md[disable markdown formatting]'
  '(-s --shell)'{-s,--shell}'[generate and execute shell command]'
  '(-d --describe-shell)'{-d,--describe-shell}'[describe shell command]'
  '(-c --code)'{-c,--code}'[generate code only]'
  '--interaction[interactive mode for shell (default)]'
  '--no-interaction[disable interactive mode]'
  '--editor[open editor for prompt input]'
  '--cache[enable request caching]'
  '--no-cache[disable request caching]'
  '--functions[allow function calls (default)]'
  '--no-functions[disallow function calls]'
  '--repl[start interactive REPL session]:session id:'
  '--chat[continue named chat session]:chat id:'
  '--show-chat[display all messages from a chat session]:chat id:'
  '(-lc --list-chats)'{-lc,--list-chats}'[list existing chat sessions]'
  '--role[apply system role]:role:'
  '(-lr --list-roles)'{-lr,--list-roles}'[list available roles]'
  '--create-role[create a new role]:role name:'
  '--show-role[show role definition]:role name:'
  '--version[show version]'
  '*:query:'
)

_arguments -s -S $arguments
