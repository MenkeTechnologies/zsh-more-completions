#compdef starrocks starrocks-cli
# _starrocks — StarRocks Foundation starrocks starrocks-cli CLI command-line frontend wrapping the StarRocks high-performance OLAP open-source analytical database fork of Apache Doris managing frontends backends compute-nodes brokers tables databases users roles privileges resources catalogs materialized-views streaming-load broker-load (StarRocks team, Java); custom argparse
# upstream: https://www.starrocks.io/

_starrocks() {
    local -a sub=(
        'login:authenticate'
        'sql:run SQL'
        'fe:frontend operations'
        'be:backend operations'
        'cn:compute node operations'
        'broker:broker operations'
        'database:database management'
        'table:table management'
        'user:user management'
        'role:role management'
        'resource:resource management'
        'catalog:catalog management'
        'mv:materialized view management'
        'stream-load:stream load operations'
        'broker-load:broker load operations'
        'routine-load:routine load operations'
        'spark-load:spark load operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--fe-host=+[host]:_hosts' \
        '--fe-port=+[port]:n:' \
        '--user=+[user]:str:' \
        '-u+[user]:str:' \
        '--password=+[password]:str:' \
        '-p+[password]:str:' \
        '--database=+[name]:str:' \
        '-d+[database]:str:' \
        '--catalog=+[name]:str:' \
        '--ssl[use SSL]' \
        '--ssl-mode=+[m]:m:(disabled preferred required verify-ca verify-identity)' \
        '-e+[SQL]:str:' \
        '--execute=+[SQL]:str:' \
        '-f+[SQL file]:file:_files -g "*.sql"' \
        '--file=+[file]:file:_files -g "*.sql"' \
        '-o+[format]:f:(table tab csv tsv json yaml)' \
        '--output=+[format]:f:(table tab csv tsv json yaml)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'starrocks subcommand' sub ;;
        args)
            case $words[1] in
                sql) _arguments '*:SQL:' ;;
                fe|be|cn|broker|database|table|user|role|resource|catalog|mv) _arguments '1:op:(list show add drop alter create delete enable disable)' '*:name:' ;;
            esac
            ;;
    esac
}

_starrocks "$@"
