#compdef s5cmd
# Documentation: https://github.com/peak/s5cmd
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '--endpoint-url=[S3 endpoint URL]:url' \
  '--credentials-file=[credentials file]:credentials:_files' \
  '--profile=[AWS profile]:profile' \
  '--no-sign-request[do not sign requests]' \
  '--source-region=[source region for cp]:region' \
  '--destination-region=[destination region for cp]:region' \
  '--json[output as JSON]' \
  '--stat[show stats]' \
  '--numworkers=[number of workers]:workers' \
  '--retry-count=[retry count]:count' \
  '--dry-run[dry run]' \
  '--use-list-objects-v1[use legacy ListObjects API]' \
  '--log=[log level]:level:(trace debug info error)' \
  '--install-completion[print shell completion script]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'ls:list buckets and objects'
      'cp:copy objects'
      'mv:move objects'
      'rm:remove objects'
      'mb:make bucket'
      'rb:remove bucket'
      'du:show disk usage'
      'pipe:read from stdin and upload'
      'cat:print object content'
      'head:print object metadata'
      'run:run commands from file'
      'select:run SQL queries on objects'
      'sync:sync directories and S3 prefixes'
      'version:print version'
    )
    _describe -t commands 's5cmd command' commands && ret=0
    ;;
  args)
    case $words[1] in
      cp|mv)
        _arguments -s -S \
          '--flatten[flatten directory structure]' \
          '--no-clobber[do not overwrite existing]' \
          '--acl=[access control]:acl:(private public-read public-read-write authenticated-read)' \
          '--storage-class=[storage class]:class:(STANDARD REDUCED_REDUNDANCY STANDARD_IA ONEZONE_IA INTELLIGENT_TIERING GLACIER DEEP_ARCHIVE)' \
          '--sse=[server-side encryption]:sse:' \
          '--sse-kms-key-id=[KMS key ID]:kms-id' \
          '--concurrency=[concurrency]:concurrency' \
          '--exclude=[exclude pattern]:pattern' \
          '--include=[include pattern]:pattern' \
          '--content-type=[content type]:type' \
          '--content-encoding=[content encoding]:encoding' \
          '--content-disposition=[content disposition]:disposition' \
          '--cache-control=[cache control]:cache control' \
          '*:source and destination:_files' \
          && ret=0
        ;;
      sync)
        _arguments -s -S \
          '--flatten[flatten directory structure]' \
          '--delete[delete files at destination not in source]' \
          '--size-only[compare by size only]' \
          '--acl=[access control]:acl:(private public-read public-read-write authenticated-read)' \
          '--storage-class=[storage class]:class:(STANDARD REDUCED_REDUNDANCY STANDARD_IA ONEZONE_IA INTELLIGENT_TIERING GLACIER DEEP_ARCHIVE)' \
          '--sse=[server-side encryption]:sse:' \
          '--sse-kms-key-id=[KMS key ID]:kms-id' \
          '--concurrency=[concurrency]:concurrency' \
          '--exclude=[exclude pattern]:pattern' \
          '--include=[include pattern]:pattern' \
          '*:source and destination:_files' \
          && ret=0
        ;;
      rm)
        _arguments -s -S \
          '--exclude=[exclude pattern]:pattern' \
          '*:object' \
          && ret=0
        ;;
      ls)
        _arguments -s -S \
          '--humanize[human readable sizes]' \
          '--show-fullpath[show full path]' \
          '*:prefix' \
          && ret=0
        ;;
      du)
        _arguments -s -S \
          '--humanize[human readable sizes]' \
          '*:prefix' \
          && ret=0
        ;;
      select)
        _arguments -s -S \
          '--compression=[compression of source]:compression:(GZIP BZIP2 NONE)' \
          '--query=[SQL query]:query:' \
          '*:object' \
          && ret=0
        ;;
      run)
        _arguments -s -S \
          '1:command file:_files' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
