#compdef svlc
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/vlc.1.html
# Reference accessed: 2026-05-21
# Verified: upstream vlc(1) manpage (svlc is listed as an alias variant
# of vlc which preselects the skins2 interface).
# Note: VLC's option set is plugin-dependent ("use 'vlc --longhelp --advanced'
# for a complete list"). This completion sticks to flags the man page itself
# documents to avoid fabrication.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-H,--full-help}'[show full help]' \
  '(- *)--longhelp[show long help]' \
  '(- *)--advanced[show advanced options]' \
  '(- *)--list[list available modules]' \
  '(- *)--reset-config[reset config to defaults]' \
  '(- *)--reset-plugins-cache[reset plugins cache]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose=}'[verbosity 0-3]:level:(0 1 2 3)' \
  '(-q --quiet)'{-q,--quiet}'[no output to console]' \
  '*:input:_files' && ret=0

return ret
