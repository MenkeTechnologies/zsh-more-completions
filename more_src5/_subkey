#compdef subkey
# _subkey — Parity Tech subkey Substrate key utility for generating sr25519 ed25519 ecdsa keypairs deriving accounts from seed/mnemonic signing/verifying inspecting addresses (paritytech team, Rust); clap
# upstream: https://github.com/paritytech/substrate

_subkey() {
    local -a sub=(
        'generate:generate new keypair'
        'generate-node-key:generate node key'
        'inspect:inspect key'
        'inspect-node-key:inspect node key'
        'sign:sign a message'
        'verify:verify signature'
        'vanity:generate vanity address'
        'transfer:transfer'
        'sign-transaction:sign extrinsic'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--scheme=+[s]:s:(sr25519 ed25519 ecdsa)' \
        '-n+[network]:n:(substrate kusama polkadot kulupu plasm edgeware reserved generic ksmcc3 dock-mainnet dock-testnet bifrost centrifuge moonriver moonbeam acala karura calamari)' \
        '--network=+[network]:n:(substrate kusama polkadot kulupu plasm edgeware reserved generic ksmcc3)' \
        '-w+[N words]:n:(12 15 18 21 24)' \
        '--words=+[N words]:n:(12 15 18 21 24)' \
        '--password=+[password]:str:' \
        '--password-filename=+[file]:file:_files' \
        '--password-interactive[interactive password]' \
        '--output-type=+[fmt]:f:(text json)' \
        '--public[show public only]' \
        '--secret[show secret only]' \
        '--keystore-path=+[dir]:dir:_files -/' \
        '--keystore-uri=+[uri]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'subkey subcommand' sub ;;
        args)
            case $words[1] in
                sign) _arguments \
                    '--suri=+[uri]:str:' \
                    '--message=+[msg]:str:' \
                    '--hex[hex input]' ;;
                verify) _arguments \
                    '--message=+[msg]:str:' \
                    '--hex[hex input]' \
                    '*:signature address:' ;;
                inspect|vanity|generate) _arguments '*:phrase or pattern:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell elvish)' ;;
            esac
            ;;
    esac
}

_subkey "$@"
