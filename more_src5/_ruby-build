#compdef ruby-build
# Documentation: https://rbenv.org/man/ruby-build.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for ruby-build - compile and install Ruby

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--version[show version]' \
  '(-l --list)'{-l,--list}'[list latest stable releases]' \
  '--definitions[list all local definitions]' \
  '--resolve[print definition name matching version]:version' \
  '(-d --dir)'{-d,--dir}'[install in prefix/definition subdirectory]' \
  '(-k --keep)'{-k,--keep}'[keep source tree after install]' \
  '(-v --verbose)'{-v,--verbose}'[forward all build output to stdout/stderr]' \
  '(-p --patch)'{-p,--patch}'[apply a patch from stdin]' \
  '(-4 --ipv4)'{-4,--ipv4}'[resolve hostnames to IPv4 only]' \
  '(-6 --ipv6)'{-6,--ipv6}'[resolve hostnames to IPv6 only]' \
  '1:version:->versions' \
  '2:prefix:_files -/' && ret=0

case $state in
  versions)
    local -a versions
    versions=(${(f)"$(ruby-build --definitions 2>/dev/null)"})
    _describe -t versions 'Ruby version' versions
    ;;
esac

return ret
