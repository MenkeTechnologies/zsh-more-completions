#compdef ssss-split ssss-combine
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/ssss-split.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local cmd="${words[1]}"

if [[ $cmd == ssss-split ]]; then
  _arguments -s \
    '-t[threshold (shares needed)]:n:' \
    '-n[total shares to generate]:n:' \
    '-w[token (label prefix)]:token:' \
    '-s[security level bits (8..1024, multiple of 8)]:n:' \
    '-x[hex I/O mode]' \
    '-q[quiet]' \
    '-Q[very quiet]' \
    '-v[print version]' \
    '-D[disable diffusion]'
else
  _arguments -s \
    '-t[threshold]:n:' \
    '-x[hex I/O mode]' \
    '-q[quiet]' \
    '-Q[very quiet]' \
    '-v[print version]' \
    '-D[disable diffusion]'
fi
