#compdef sndioctl
# _sndioctl — control / monitor sndio audio devices (OpenBSD sndio)
# upstream: https://sndio.org/  (man.openbsd.org/sndioctl.1)
# Flags from sndioctl(1).

_sndioctl() {
    local -a args
    args=(
        '-d[dump raw list of available controls and exit]'
        '-f+[sndio device to use]:device:'
        '-i[show characteristics instead of values]'
        '-m[monitor + display audio control changes]'
        '-n[suppress printing of the variable name]'
        '-q[suppress all printing when setting a variable]'
        '-v[verbose / multi-channel mode]'
        '*:command (e.g. output.level=+0.1):'
    )
    _arguments -s $args
}

_sndioctl "$@"
