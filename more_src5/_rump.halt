#compdef rump.halt
# Documentation: man rump.halt(1)
# Source: netbsd/src usr.bin/rump_halt — halt a rump kernel (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d[generate a core dump for debugging]' \
    '-h[halt kernel activity, keep host process]' \
    '-n[skip file system cache flush]' \
    && ret=0

return ret
