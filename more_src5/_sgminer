#compdef sgminer
# Documentation: https://github.com/sgminer-dev/sgminer
# Reference accessed: 2026-05-16
# Verified: upstream sgminer-dev/sgminer README.
# Removed from prior file: bogus man.archlinux.org search URL.

# sgminer: Scrypt/SHA OpenCL crypto miner
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-o --url)'{-o+,--url=}'[mining pool URL]:url:_urls' \
  '(-u --user)'{-u+,--user=}'[username]:user:' \
  '(-p --pass)'{-p+,--pass=}'[password]:password:' \
  '(-O --userpass)'{-O+,--userpass=}'[user\:pass combo]:userpass:' \
  '(-U --quota)'{-U+,--quota=}'[quota]:quota:' \
  '--socks-proxy=[SOCKS proxy]:host\:port:' \
  '--sharelog=[share log file]:file:_files' \
  '--disable-adl[disable AMD ADL]' \
  '--without-curses[disable curses interface]' \
  '(-k --kernel)'{-k+,--kernel=}'[kernel name]:kernel:' \
  '(-d --device)'{-d+,--device=}'[device number]:n:' \
  '(-I --intensity)'{-I+,--intensity=}'[intensity 8-31]:n:' \
  '(-X --xintensity)'{-X+,--xintensity=}'[xintensity]:n:' \
  '--thread-concurrency=[thread concurrency]:n:' \
  '(-g --gpu-threads)'{-g+,--gpu-threads=}'[GPU threads]:n:' \
  '--gpu-engine=[GPU engine clock]:mhz:' \
  '--gpu-memclock=[GPU memory clock]:mhz:' \
  '--gpu-fan=[GPU fan speed]:pct:' \
  '--gpu-vddc=[GPU core voltage]:v:' \
  '--temp-target=[target temperature C]:c:' \
  '--temp-overheat=[overheat threshold C]:c:' \
  '--temp-cutoff=[cutoff temperature C]:c:' \
  '--auto-fan[auto fan control]' \
  '--auto-gpu[auto GPU clock]' \
  '(-T --text-only)'{-T,--text-only}'[text-only output]' \
  '(-S --scan-serial)'{-S+,--scan-serial=}'[scan serial device]:device:' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
  '--log-file=[log file]:file:_files' && ret=0
return ret
