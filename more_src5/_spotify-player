#compdef spotify_player
# Documentation: https://github.com/aome510/spotify-player
# Reference accessed: 2026-05-21
# Verified: spotify_player/src/cli/mod.rs (init_cli)

# Zsh completion for spotify_player (aome510/spotify-player).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config-folder)'{-c+,--config-folder=}'[path to config folder]:directory:_directories' \
  '(-C --cache-folder)'{-C+,--cache-folder=}'[path to cache folder]:directory:_directories' \
  '(-t --theme)'{-t+,--theme=}'[application theme]:theme:' \
  '*'{-o+,--config-override=}'[override config setting (KEY=VALUE)]:KEY=VALUE:' \
  '(-d --daemon)'{-d,--daemon}'[run as a daemon (requires daemon feature)]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'authenticate:authenticate the application'
      'get:retrieve Spotify data'
      'playback:interact with playback'
      'search:search Spotify'
      'connect:connect to a Spotify device'
      'like:like the currently playing track'
      'playlist:edit playlists'
      'generate:generate shell completions'
      'print-features:display audio features'
      'lyrics:retrieve lyrics'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      generate)
        _arguments -s -S \
          '1:shell:(bash zsh fish elvish powershell)' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      *)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
