#compdef qmail-qmtpd
# _qmail-qmtpd — qmail's Quick Mail Transfer Protocol daemon (accepts QMTP submissions on UCSPI-TCP, applies rcpthosts/morercpthosts + databytes + RELAYCLIENT rules, then queues via qmail-queue)
# upstream: https://github.com/notqmail/notqmail
# Source: qmail-qmtpd.8 on tip; no flags — env vars come from tcp-environ(5).

_qmail-qmtpd() {
    _arguments '(- *)-h[show help]'
}

_qmail-qmtpd "$@"
