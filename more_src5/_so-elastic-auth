#compdef so-elastic-auth
# _so-elastic-auth — Security Onion so-elastic-auth CLI for managing Elasticsearch authentication realms users roles built-in user passwords and security migration on Security Onion clusters (security-onion team, Bash); getopt
# upstream: https://github.com/Security-Onion-Solutions/securityonion

_so-elastic-auth() {
    local -a sub=(
        'user:user operations'
        'role:role operations'
        'realm:authentication realm operations'
        'role-mapping:role mapping operations'
        'token:API token operations'
        'change-password:reset built-in user password'
        'apikey:API key operations'
        'cluster:cluster security operations'
        'audit:audit log operations'
        'migrate:migrate security configuration'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n+[node]:str:' \
        '--node=+[node]:str:' \
        '-f[force]' \
        '--force[force]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'so-elastic-auth subcommand' sub ;;
        args)
            case $words[1] in
                user) _arguments \
                    '1:action:(add delete list update passwd lock unlock enable disable)' \
                    '--email=+[email]:str:' \
                    '--full-name=+[name]:str:' \
                    '--password=+[password]:str:' \
                    '--roles=+[csv]:str:' \
                    '*:username:' ;;
                role) _arguments \
                    '1:action:(add delete list info)' \
                    '--indices=+[csv]:str:' \
                    '--cluster=+[csv]:str:' \
                    '*:role:' ;;
                change-password) _arguments \
                    '--username=+[name]:str:' \
                    '--password=+[password]:str:' \
                    '--auto[generate password]' ;;
                apikey) _arguments \
                    '1:action:(create invalidate list info)' \
                    '*:apikey name:' ;;
            esac
            ;;
    esac
}

_so-elastic-auth "$@"
