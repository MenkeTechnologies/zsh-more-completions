#compdef subpix
# _subpix — subtract a constant from each pixel listed (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from subpix.c (single-letter getopt-style).

_subpix() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-v[verbose output]' \
        '-n[output new file]' \
        '1:FITS file:_files -g "*.(fits|fit|fts|imh)"' \
        '*:x y value:'
}

_subpix "$@"
