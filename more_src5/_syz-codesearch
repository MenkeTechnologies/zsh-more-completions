#compdef syz-codesearch
# _syz-codesearch — index/search syzkaller-relevant kernel symbol tables (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-codesearch/codesearch.go (flag).

_syz-codesearch() {
    _arguments \
        '-database=[input/output database file]:file:_files' \
        '-kernel-src=[kernel source directory]:dir:_files -/' \
        '-kernel-obj=[kernel build directory]:dir:_files -/' \
        '1:command:(index search)' \
        '*::args:'
}

_syz-codesearch "$@"
