#compdef runit-init utmpset
# Documentation: source-direct extraction from upstream
# void-linux/runit src/runit-init.c + utmpset.c USAGE strings +
# case-arm decoding (runit-init: USAGE " 0|6"; positional is "0"
# halt or "6" reboot, case-arm decoded from `switch (**argv)
# case '0': runit_halt(); case '6': runit_reboot();`; utmpset:
# USAGE " [-w] line"; `-w` writes to wtmp instead of utmp).
# Reference accessed: 2026-05-30 via gh api.
# void-linux runit R131d — 2-stem multi-binary harvest of the
# 2 runit family binaries not previously covered (runit/runsv/
# runsvchdir/runsvdir/sv/chpst were already in the corpus). Runit
# is Gerrit Pape's reimplementation of daemontools that ships as
# pid 1 in Void Linux + as an optional init in Alpine, Artix,
# Devuan, and several others.

case $service in

  runit-init)
    # Single-positional dispatcher: pid-1 form spawns the actual
    # `runit` binary; non-pid-1 form is used as the shutdown
    # interface accepting "0" (halt) or "6" (reboot).
    _arguments -s -S \
      '-V[print version]' \
      '1:runlevel digit:((0\:halt 6\:reboot))'
    ;;

  utmpset)
    # Write a logout record into utmp (the live tty session table)
    # for a given line. Used by getty/login to clean up stale
    # entries when a session disappears without proper logout.
    _arguments -s -S \
      '-w[write the record into wtmp (the historical log) instead of utmp]' \
      '1:tty line (e.g. tty1, pts/0):'
    ;;

esac
