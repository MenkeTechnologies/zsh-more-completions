#compdef sphdistance
# Documentation: https://docs.generic-mapping-tools.org/latest/sphdistance.html
# Source: GenericMappingTools/gmt src/sphdistance.c — make Voronoi distance, node-or-id grid on a sphere (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-C[conserve memory]' \
    '-D[delete duplicate points]' \
    '-E+[output type]:type:(n z d)' \
    '-G+[output grid file]:file:_files -g "*.{grd,nc}"' \
    '-I+[grid increment]:inc:_default' \
    '-L+[distance units]:unit:(d e f k m M n)' \
    '-N+[node table]:file:_files' \
    '-Q+[Voronoi polygon table]:file:_files' \
    '-R+[region]:region:_default' \
    '*-V[verbose (stackable)]' \
    '-bi+[binary input format]:format:_default' \
    '-di+[input nodata↔NaN]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-j+[spherical distance mode]:mode:(e f g)' \
    '-qi+[record selection]:cols:_default' \
    '-r+[grid registration]:reg:(g p)' \
    '*:input table:_files' \
    && ret=0

return ret
