#compdef stack-cli
# _stack-cli — commercialhaskell stack Haskell build tool CLI alias (commercialhaskell / FPComplete, Haskell); custom argparse
# upstream: https://github.com/commercialhaskell/stack

_stack-cli() {
    local -a sub=(
        'build:build the project'
        'install:build copy binary into path'
        'uninstall:uninstall'
        'test:run tests'
        'bench:run benchmarks'
        'haddock:generate docs'
        'ide:IDE helpers'
        'docker:Docker integration'
        'config:configuration commands'
        'clean:clean build outputs'
        'purge:purge entire .stack-work and stack root'
        'init:scaffold stack.yaml'
        'new:scaffold project'
        'templates:list templates'
        'unpack:unpack a package'
        'update:update package index'
        'upgrade:upgrade stack'
        'upload:upload to Hackage'
        'sdist:make sdist'
        'dot:print dependency graph'
        'list-dependencies:list deps'
        'hpc:HPC test coverage'
        'eval:evaluate expression'
        'exec:run command in stack env'
        'ghc:run ghc'
        'ghci:run ghci'
        'runghc:run a haskell file'
        'runhaskell:run a haskell file (alias)'
        'script:run a script'
        'path:show stack paths'
        'query:run query'
        'repl:open ghci alias'
        'setup:install GHC'
        'snapshot:snapshot helpers'
        'ls:list packages/dependencies/stack snapshots'
        'list:list packages/dependencies/stack snapshots (alias)'
        'unregister:unregister package'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbosity=+[verbosity]:v:(silent error warn info debug)' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--quiet[quiet]' \
        '--colour=+[color]:c:(auto always never)' \
        '--terminal[terminal output]' \
        '--no-terminal[no terminal output]' \
        '--terminal-width=+[terminal width]:n:' \
        '--stack-yaml=+[stack.yaml]:file:_files -g "stack.yaml *.yaml"' \
        '--lock-file=+[lock file]:l:(read-only error-on-write ignore read-write)' \
        '--system-ghc[use system ghc]' \
        '--no-system-ghc[do not use system ghc]' \
        '--install-ghc[install ghc]' \
        '--no-install-ghc[do not install ghc]' \
        '--ghc-variant=+[ghc variant]:str:' \
        '--ghc-build=+[ghc build]:str:' \
        '--jobs=+[parallel jobs]:n:' \
        '-j+[parallel jobs]:n:' \
        '--resolver=+[resolver]:str:' \
        '--compiler=+[compiler]:str:' \
        '--allow-different-user[allow different user]' \
        '--allow-stack-root-as-relative[allow stack root as relative]' \
        '--work-dir=+[work dir]:dir:_files -/' \
        '--no-work-dir[no work dir]' \
        '--snapshot=+[snapshot]:str:' \
        '--silent[silent]' \
        '--time-in-log[log times]' \
        '--no-time-in-log[no log times]' \
        '--rsl-in-log[rsl in log]' \
        '--no-rsl-in-log[no rsl in log]' \
        '--locale-encoding-warn[locale encoding warn]' \
        '--no-locale-encoding-warn[no locale encoding warn]' \
        '--default-template=+[default template]:str:' \
        '--http-proxy=+[http proxy]:url:_urls' \
        '--https-proxy=+[https proxy]:url:_urls' \
        '--no-proxy=+[no proxy]:list:' \
        '--copy-bins[copy bins]' \
        '--reinstall[reinstall]' \
        '--no-reinstall[no reinstall]' \
        '--no-rebuild-ghc-options[no rebuild ghc options]' \
        '--ghc-options=+[ghc options]:str:' \
        '--coverage[coverage]' \
        '--no-coverage[no coverage]' \
        '--haddock[haddock]' \
        '--no-haddock[no haddock]' \
        '--bench[benchmarks]' \
        '--no-bench[no benchmarks]' \
        '--test[tests]' \
        '--no-test[no tests]' \
        '--fast[fast build]' \
        '--profile[profile]' \
        '--trace[trace]' \
        '--no-strip[no strip]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'stack subcommand' sub ;;
        args)
            case $words[1] in
                build|test|bench|install|haddock|run) _arguments '*:target:' ;;
                new) _arguments \
                    '1:name:' \
                    '*:template:' ;;
                templates) _arguments '*:arg:' ;;
                exec|ghci|ghc|runghc|runhaskell|repl|script) _arguments '*:cmd:_command_names -e' ;;
                config) _arguments \
                    '1:cmd:(env set show-deprecated-config)' \
                    '*:arg:' ;;
                ide) _arguments \
                    '1:cmd:(packages targets)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_stack-cli "$@"
