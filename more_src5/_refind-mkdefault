#compdef refind-mkdefault
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man8/refind-mkdefault.8.html
# Reference accessed: 2026-05-16
# Verified: Ubuntu jammy refind-mkdefault(8) manpage. Single-flag tool;
# must run as root.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# refind-mkdefault: set rEFInd as default UEFI boot entry
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-L --label)'{-L+,--label=}'[name to search in efibootmgr output (default refind)]:name:' && ret=0
return ret
