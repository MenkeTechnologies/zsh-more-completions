#compdef send
# Documentation: man send(1)
# Source: nmh uip/send.c (master) — send a message draft (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-alias+[alias file]:file:_files' \
    '-debug[debug output]' \
    '-draft[send the draft]' \
    '-draftfolder+[draft folder]:folder:_default' \
    '-draftmessage+[draft message]:msg:_default' \
    '-nodraftfolder[no draft folder]' \
    '(-filter -nofilter)-filter+[filter file]:file:_files' \
    '(-filter -nofilter)-nofilter[no filter]' \
    '(-format -noformat)-format[format addresses]' \
    '(-format -noformat)-noformat[no format]' \
    '(-forward -noforward)-forward[forward via mta]' \
    '(-forward -noforward)-noforward[no forward]' \
    '(-mime -nomime)-mime[apply MIME encoding]' \
    '(-mime -nomime)-nomime[no MIME]' \
    '(-msgid -nomsgid)-msgid[add Message-ID]' \
    '(-msgid -nomsgid)-nomsgid[no Message-ID]' \
    '(-push -nopush)-push[push to background]' \
    '(-push -nopush)-nopush[foreground]' \
    '-split+[split delivery seconds]:seconds:_default' \
    '(-unique -nounique)-unique[unique message numbering]' \
    '(-unique -nounique)-nounique[reuse numbering]' \
    '(-verbose -noverbose)-verbose[verbose]' \
    '(-verbose -noverbose)-noverbose[no verbose]' \
    '(-watch -nowatch)-watch[watch SMTP transcript]' \
    '(-watch -nowatch)-nowatch[no watch]' \
    '-width+[output width]:cols:_default' \
    '-version[show version]' \
    '-help[show help]' \
    '(-dashstuffing -nodashstuffing)-dashstuffing[dash-stuff]' \
    '(-dashstuffing -nodashstuffing)-nodashstuffing[no dash-stuff]' \
    '-client+[client hostname]:host:_hosts' \
    '-server+[SMTP server]:host:_hosts' \
    '-snoop[show server transcript]' \
    '(-sasl -nosasl)-sasl[use SASL]' \
    '(-sasl -nosasl)-nosasl[no SASL]' \
    '-saslmaxssf+[SASL max SSF]:N:_default' \
    '-saslmech+[SASL mechanism]:mech:_default' \
    '-user+[username for auth]:user:_default' \
    '(-attach -noattach)-attach+[attach header field]:field:_default' \
    '(-attach -noattach)-noattach[no attach]' \
    '-attachformat+[attach format]:fmt:_default' \
    '-port+[SMTP port]:port:_default' \
    '(-tls -notls -initialtls)-tls[STARTTLS]' \
    '(-tls -notls -initialtls)-initialtls[immediate TLS]' \
    '(-tls -notls -initialtls)-notls[no TLS]' \
    '-mts+[mail transport]:transport:(smtp sendmail/smtp sendmail/pipe)' \
    '-messageid+[Message-ID format]:format:(localname random)' \
    '*::msgs:_default' \
    && ret=0

return ret
