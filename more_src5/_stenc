#compdef stenc
# Documentation: https://github.com/scsitape/stenc/blob/master/man/stenc.rst
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-f --file)'{-f,--file=}'[tape device]:device:_files -g "/dev/*"' \
  '(-e --encrypt)'{-e,--encrypt=}'[encrypt mode]:mode:(off on)' \
  '(-d --decrypt)'{-d,--decrypt=}'[decrypt mode]:mode:(off on mixed)' \
  '(-a --algorithm)'{-a,--algorithm=}'[encryption algorithm index]:n:' \
  '(-k --key-file)'{-k,--key-file=}'[key file or - for stdin]:file:_files' \
  '--ckod[clear key on demount]' \
  '--allow-raw-read[allow raw read]' \
  '--no-allow-raw-read[disallow raw read]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]'
