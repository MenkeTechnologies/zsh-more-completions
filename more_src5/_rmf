#compdef rmf
# Documentation: man rmf(1)
# Source: nmh uip/rmf.c (master) — remove nmh folder (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-interactive -nointeractive)-interactive[prompt before removing]' \
    '(-interactive -nointeractive)-nointeractive[do not prompt]' \
    '-version[show version]' \
    '-help[show help]' \
    '1::+folder:_default' \
    && ret=0

return ret
