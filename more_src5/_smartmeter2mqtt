#compdef smartmeter2mqtt
# ============================================================================
# _smartmeter2mqtt — zsh completion for Stephan van Rooij's Dutch DSMR
#                    P1 smart-meter ↔ MQTT bridge (mqtt.js)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/svrooij/smartmeter2mqtt
#   Author     : Stephan van Rooij  <stephan@svrooij.io>
#   License    : MIT
#   Stars      : 32
#   Language   : TypeScript
#   Package    : smartmeter2mqtt  (npm)
#   Binary     : smartmeter2mqtt  (package.json bin: ./dist/index.js)
#   Last push  : 2025-03-11
#
# WHAT IT IS
#   smartmeter2mqtt reads the Dutch Smart Meter Requirements (DSMR) P1
#   serial telemetry from a smart meter — either over a USB / RS-232
#   serial adapter (`--port /dev/ttyUSB0`) or over a TCP socket
#   exposed by an ESP8266/ESP32 serial-to-network bridge (`--socket
#   192.168.0.3:3000`) — parses the P1 ASCII frames into normalized
#   datapoints (currentTarrif, totalT1Use, totalT2Use, totalT1Delivered,
#   totalT2Delivered, powerSn, currentUsage, currentDelivery, gas
#   totals), and fans the result out to one or more configured outputs:
#   MQTT broker, web server, JSON TCP server, raw TCP server, HTTP
#   POST endpoint, or debug stdout.  An optional SunSpec Modbus TCP
#   input lets a Modbus-enabled solar inverter feed live PV production
#   numbers into the same stream.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/config.ts yargs builder)
#   smartmeter2mqtt [--port <SERIAL> | --socket <HOST:PORT>] [OUTPUTS...]
#
#   Input source (mutually exclusive — yargs `.conflicts(port, socket)`):
#     --port <PATH>                  P1-to-USB serial device, e.g.
#                                    `/dev/ttyUSB0`
#     --socket <HOST:PORT>           Read from a TCP serial-bridge,
#                                    e.g. `192.168.0.3:3000`
#
#   MQTT output (mqtt.js):
#     --mqtt-url <URL>               MQTT broker URL (mqtt:// / mqtts://
#                                    / ws:// / wss:// / tcp://)
#     --mqtt-topic <PREFIX>          Topic prefix for all messages
#                                    [default: `smartmeter`]
#     --mqtt-distinct                Publish each field as its own
#                                    sub-topic
#     --mqtt-distinct-fields <CSV>   Comma-separated list of fields to
#                                    publish distinct
#       [default: currentTarrif,totalT1Use,totalT2Use,totalT1Delivered,
#                 totalT2Delivered,powerSn,currentUsage,currentDelivery]
#     --mqtt-discovery               Emit Home Assistant MQTT auto-
#                                    discovery messages
#     --mqtt-discovery-prefix <P>    Auto-discovery topic prefix
#                                    [default: `homeassistant`]
#
#   HTTP POST output:
#     --post-url <URL>               POST results to this URL
#     --post-interval <SEC>          Seconds between POSTs [default: 300]
#     --post-json                    POST data as JSON (default: form
#                                    parameters)
#
#   TCP output:
#     --tcp-server <PORT>            Expose a JSON TCP socket on PORT
#     --raw-tcp-server <PORT>        Expose a raw P1 TCP socket on PORT
#
#   Web output:
#     --web-server <PORT>            Expose a web UI on PORT
#
#   Debug:
#     --debug                        Enable debug output to stdout
#
#   SunSpec Modbus solar input:
#     --sunspec-modbus <IP>          IP of a Modbus-TCP-enabled inverter
#     --sunspec-modbus-port <PORT>   Modbus TCP port [default: 502]
#
#   Standard yargs auto-flags:
#     -h, --help                     Show help
#         --version                  Show version
#
#   Environment variables:  All options can also be passed as
#   environment variables — prefix the upper-cased option name with
#   `SMARTMETER_` (e.g. `--mqtt-url` → `SMARTMETER_MQTT_URL`).  Yargs
#   resolution: CLI argv → environment → defaults.
#
# AXIS / CORPUS POSITION
#   Direct dependency on `mqtt ^4.2.6` declared in package.json — the
#   reference Node.js MQTT client maintained by the MQTT.js org
#   (mqttjs/MQTT.js), the npm package literally named `mqtt`.  The
#   bridge's `src/output/mqtt-output.ts` constructs an `mqtt.connect(url)`
#   client, optionally publishes Home Assistant MQTT discovery
#   payloads on `<discovery-prefix>/sensor/...`, and topic-publishes
#   each parsed P1 datapoint on `<topic>/<field>` either as a JSON
#   blob or per-field distinct.  Verified via:
#     gh api repos/svrooij/smartmeter2mqtt/contents/package.json
#       → "mqtt": "^4.2.6"
#     gh api repos/svrooij/smartmeter2mqtt/contents/src/config.ts
#       → yargs builder with --mqtt-url, --mqtt-topic, --mqtt-discovery
#   This entry is the TS-Node=124 leader bump that CLOSES Axis 69
#   (MQTT Client Library) at 1/1/1 three-language symmetry — pairing
#   Rust=rumqttc 0.24 (R865 _bambutop), Go=eclipse/paho.mqtt.golang
#   v1.5.1 (R866 _chirpstack-gateway-bridge), and TS-Node=mqtt.js
#   (this entry).  Triple-124 landmark on commit.
#
#   No completion for `smartmeter2mqtt` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_smartmeter2mqtt() {
    _arguments -s \
        '(--socket)--port=[P1-to-USB serial device path (conflicts with --socket)]:serial device:_files -g "/dev/tty*"' \
        '(--port)--socket=[TCP serial-bridge host:port (conflicts with --port)]:host\:port:' \
        '--mqtt-url=[MQTT broker URL (mqtt\:// / mqtts\:// / ws\:// / wss\:// / tcp\://)]:url:' \
        '--mqtt-topic=[MQTT topic prefix (default smartmeter)]:prefix:' \
        '--mqtt-distinct[publish each field as its own MQTT sub-topic]' \
        '--mqtt-distinct-fields=[comma-separated field list for distinct publishing]:fields:' \
        '--mqtt-discovery[emit Home Assistant MQTT auto-discovery messages]' \
        '--mqtt-discovery-prefix=[auto-discovery topic prefix (default homeassistant)]:prefix:' \
        '--post-url=[HTTP endpoint to POST results to]:url:' \
        '--post-interval=[seconds between POSTs (default 300)]:seconds:' \
        '--post-json[POST as JSON instead of form parameters]' \
        '--tcp-server=[expose a JSON TCP socket on PORT]:port:' \
        '--raw-tcp-server=[expose a raw P1 TCP socket on PORT]:port:' \
        '--web-server=[expose a web UI on PORT]:port:' \
        '--debug[enable debug output to stdout]' \
        '--sunspec-modbus=[IP of a Modbus-TCP-enabled inverter]:host:' \
        '--sunspec-modbus-port=[Modbus TCP port (default 502)]:port:' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]'
}

_smartmeter2mqtt "$@"
