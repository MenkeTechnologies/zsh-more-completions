#compdef rake
# _rake-bin — Ruby Make build tool (Jim Weirich + Ruby community, Ruby); Ruby-based task runner
# upstream: https://github.com/ruby/rake

_rake-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-A --all)'{-A,--all}'[show all tasks]' \
        '(-D --describe)'{-D,--describe}'+[describe matching tasks]:pattern:' \
        '(-G --no-system --nosystem)'{-G,--no-system,--nosystem}'[no system tasks]' \
        '(-I --libdir)'{-I,--libdir}'+[search path]:dir:_files -/' \
        '(-N --no-search --nosearch)'{-N,--no-search,--nosearch}'[no search]' \
        '(-P --prereqs)'{-P,--prereqs}'[show prereqs]' \
        '(-T --tasks)'{-T,--tasks}'+[show tasks matching]:pattern:' \
        '(-W --where)'{-W,--where}'+[show task location matching]:pattern:' \
        '(-X --no-deprecation-warnings)'{-X,--no-deprecation-warnings}'[no deprecation warnings]' \
        '(-e --execute)'{-e,--execute}'+[execute code]:str:' \
        '(-E --execute-continue)'{-E,--execute-continue}'+[execute code, continue]:str:' \
        '(-f --rakefile)'{-f,--rakefile}'+[Rakefile]:file:_files -g "[Rr]akefile*"' \
        '(-g --system)'{-g,--system}'[use system tasks]' \
        '(-j --jobs)'{-j,--jobs}'+[parallel jobs]:n:' \
        '(-m --multitask)'{-m,--multitask}'[run all tasks as multitasks]' \
        '(-n --dry-run)'{-n,--dry-run}'[dry run]' \
        '(-p --execute-print)'{-p,--execute-print}'+[execute code + print]:str:' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '(-Q --no-quiet)'{-Q,--no-quiet}'[no quiet]' \
        '(-r --require)'{-r,--require}'+[require lib]:lib:' \
        '(-R --rakelibdir)'{-R,--rakelibdir}'+[rakelib dirs]:dirs:' \
        '(-s --silent)'{-s,--silent}'[silent]' \
        '(-t --trace)'{-t,--trace}'+[trace error]:level:' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '*:task:'
}

_rake-bin "$@"
