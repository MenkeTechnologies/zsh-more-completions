#compdef s6-tlsserver
# Documentation: https://skarnet.org/software/s6-networking/s6-tlsserver.html
# Reference accessed: 2026-05-30
# s6-tlsserver — TLS-wrapped TCP server runner. Combines s6-tcpserver + s6-tlsd + access control.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-L[enable PROXY protocol support (reads cleartext before TLS tunnel)]' \
  '(-q -Q -v)-q[quiet]' \
  '(-q -Q -v)-Q[normal verbosity (default)]' \
  '(-q -Q -v)-v[verbose]' \
  '-1[print bound port to stdout on bind (readiness)]' \
  '-c+[max concurrent connections]:N:' \
  '-C+[per-IP cap]:N:' \
  '-b+[socket backlog]:N:' \
  '-v0[set TCP access verbosity 0]' \
  '-v2[set TCP access verbosity 2]' \
  '(-w -W)-w[strict DNS/IDENT error handling]' \
  '(-w -W)-W[tolerant DNS/IDENT error handling]' \
  '(-d -D)-d[enable Nagle algorithm]' \
  '(-d -D)-D[disable Nagle algorithm]' \
  '(-r -R)-r[enable IDENT lookups]' \
  '(-r -R)-R[disable IDENT lookups]' \
  '(-p -P)-p[enable paranoid DNS checking]' \
  '(-p -P)-P[disable paranoid DNS checking]' \
  '(-h -H)-H[disable DNS lookups]' \
  '(-h -H)-h[check /etc/hosts before DNS]' \
  '-l+[local name]:name:' \
  '-B+[initial server banner]:banner:' \
  '-t+[lookup timeout]:sec:' \
  '-i+[TCP access rules directory]:dir:_directories' \
  '-x+[TCP access rules file (CDB)]:file:_files -g "*.cdb"' \
  '(-Z -z)-Z[keep s6-tlsd-specific env variables]' \
  '(-Z -z)-z[remove s6-tlsd-specific env variables]' \
  '(-S -s)-S[use close_notify to signal end of TLS connection]' \
  '(-S -s)-s[use EOF to signal end of TLS connection]' \
  '(-J -j)-J[exit nonzero when peer fails to close_notify]' \
  '(-J -j)-j[ignore peer failure to close_notify]' \
  '(-Y -y)-Y[request optional client certificate]' \
  '(-Y -y)-y[require mandatory client certificate]' \
  '-K+[TLS handshake timeout]:ms:' \
  '-k+[SNI level (SNI-based certificate chain support)]:level:' \
  '-u+[change UID (root only)]:uid:_users' \
  '-g+[change GID (root only)]:gid:_groups' \
  '-G+[supplementary GID list (CSV; root only)]:gidlist:' \
  '-U[load UID/GID from environment (root only)]' \
  '1:bind IP:' \
  '2:port:' \
  '*:program + args:_command_names -e' \
  && ret=0

return ret
