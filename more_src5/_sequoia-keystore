#compdef sequoia-keystore
# Documentation: https://gitlab.com/sequoia-pgp/sequoia-keystore/-/raw/main/server/src/server.rs
# Reference accessed: 2026-05-27
# Verified: upstream server/src/server.rs clap Parser derive (sequoia-pgp/sequoia-keystore)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--sequoia-home=[Sequoia home directory (overridable via SEQUOIA_HOME)]:directory:_files -/' \
  '--home=[keystore home directory (overrides --sequoia-home)]:directory:_files -/' \
  '--ephemeral=[create an ephemeral context destroyed on exit]:value:(True False)' \
  '--lib=[directory containing backend servers]:directory:_files -/' \
  '--socket=[file descriptor on which the socket is passed]:fd:' \
  '(- *)--version[print version information]' \
  '(- *)'{-h,--help}'[print help information]' && ret=0

return ret
