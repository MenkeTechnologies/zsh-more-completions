#compdef R-CMD-Rdiff
# _R-CMD-Rdiff — R Core Team R CMD Rdiff compare two R output files producing meaningful diffs for testing (rcore team, C); getopt
# upstream: https://cran.r-project.org/

_R-CMD-Rdiff() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-w[ignore whitespace]' \
        '--ignore-whitespace[ignore whitespace]' \
        '-W+[diff width]:n:' \
        '*:file1 file2:_files'
}

_R-CMD-Rdiff "$@"
