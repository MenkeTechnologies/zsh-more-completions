#compdef regenie

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--step[regression step to run]:step:(1 2)' \
  '--bed[BED file prefix for genetic data]:BED prefix:_files' \
  '--bgen[BGEN file for genetic data]:BGEN file:_files' \
  '--pgen[PGEN file for genetic data]:PGEN file:_files' \
  '--sample[sample file]:sample file:_files' \
  '--phenoFile[phenotype file]:phenotype file:_files' \
  '--covarFile[covariate file]:covariate file:_files' \
  '--phenoCol[phenotype column name]:column name:' \
  '--covarCol[covariate column name]:column name:' \
  '--bt[binary trait analysis]' \
  '--ct[continuous trait analysis]' \
  '--pred[file with predictions from step 1]:prediction file:_files' \
  '--out[output file prefix]:output prefix:_files' \
  '--bsize[size of genotype blocks]:block size:' \
  '--threads[number of threads]:threads:' \
  '--lowmem[use low-memory mode]' \
  '--lowmem-prefix[prefix for temporary files in low-memory mode]:prefix:_files' \
  '--gz[gzip output files]' \
  '--force-step1[force all chromosomes in step 1]' \
  '--nb[number of blocks]:number of blocks:' \
  '--strict[remove samples with missing data]' \
  '--ignore-pred[ignore predictions from step 1]' \
  '--use-relative-path[use relative paths in pred list file]' \
  '--split[split output by chromosome]' \
  '--firth[use Firth likelihood ratio test]' \
  '--approx[use approximate Firth]' \
  '--spa[use saddlepoint approximation]' \
  '--pThresh[p-value threshold]:threshold:' \
  '--test[type of test]:test type:(dominant recessive additive)' \
  '--minMAC[minimum minor allele count]:MAC threshold:' \
  '--minINFO[minimum imputation INFO score]:INFO threshold:' \
  '--af-cc[use case-control allele frequencies]' \
  '--no-split[do not split by chromosome]' \
  '--apply-rint[apply rank-based inverse normal transformation]' \
  '--write-samples[write sample IDs]' \
  '--print-pheno[print phenotype name in header]' \
  '--verbose[verbose output]' \
  '--help[show help message]' && ret=0

return ret
