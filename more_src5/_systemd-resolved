#compdef systemd-resolved
# _systemd-resolved (systemd local-DNS/LLMNR/mDNS/DNSSEC stub resolver daemon; reads /etc/systemd/resolved.conf + per-link configuration applied via resolvectl(1); daemon binary itself accepts only standard systemd unit args)
# upstream: https://github.com/systemd/systemd (src/resolve)
# Argument shape from systemd src/resolve/resolved.c on tip.

_systemd-resolved() {
    _arguments \
        '--help[show help]' \
        '--version[show version]'
}

_systemd-resolved "$@"
