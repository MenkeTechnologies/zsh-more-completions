#compdef rofi-rbw
# _rofi-rbw — rofi-rbw CLI launcher around rbw the unofficial Rust Bitwarden Vaultwarden CLI client displaying available vault entries in a rofi dmenu-style menu picking entry copying username password totp uri notes to wl-clipboard xclip typing via wtype xdotool typedotool (fdw team, Python); custom argparse
# upstream: https://github.com/fdw/rofi-rbw

_rofi-rbw() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-a+[action]:a:(type copy print)' \
        '--action=+[action]:a:(type copy print)' \
        '-t+[target]:t:(username password totp uri notes menu auto autofill)' \
        '--target=+[target]:t:(username password totp uri notes menu auto autofill)' \
        '--prompt=+[prompt]:str:' \
        '-s+[selector]:s:(rofi wofi rofi-wayland dmenu fuzzel walker tofi)' \
        '--selector=+[selector]:s:(rofi wofi rofi-wayland dmenu fuzzel walker tofi)' \
        '--selector-args=+[args]:str:' \
        '--typer=+[t]:t:(wtype xdotool ydotool dotool dotoolwl)' \
        '--clipboarder=+[c]:c:(wl-clipboard xsel xclip wlroots)' \
        '--no-folder[do not include folder]' \
        '--show-folders[include folders]' \
        '--no-help[no help]' \
        '--keybindings=+[binds]:str:' \
        '--rofi-args=+[args]:str:' \
        '*::'
}

_rofi-rbw "$@"
