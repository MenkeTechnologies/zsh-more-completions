#compdef solana-keygen
# Documentation: https://docs.anza.xyz/cli/usage/solana-keygen
# Reference accessed: 2026-05-21
# Verified: upstream Anza Solana CLI documentation lists subcommands
# new, pubkey, verify, recover, grind with the BIP39 word-count
# language flags shown here.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'new:generate new keypair file'
  'pubkey:display pubkey from keypair'
  'verify:verify keypair signs and verifies'
  'recover:recover keypair from seed phrase'
  'grind:grind for vanity keypairs'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-C --config)'{-C+,--config=}'[config file]:file:_files' \
  '(-u --url)'{-u+,--url=}'[JSON RPC URL]:url:' \
  '(-k --keypair)'{-k+,--keypair=}'[keypair file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'solana-keygen command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (new)
        _arguments \
          '(-o --outfile)'{-o+,--outfile=}'[output keypair file]:file:_files' \
          '(-f --force)'{-f,--force}'[overwrite without prompt]' \
          '--no-bip39-passphrase[no BIP39 passphrase]' \
          '--no-outfile[do not write to file]' \
          '--word-count=[seed phrase word count]:n:(12 15 18 21 24)' \
          '--language=[language]:lang:(english chinese-simplified chinese-traditional japanese spanish korean french italian)' \
          '--silent[do not print seed phrase]' \
          '--derivation-path=[BIP44 derivation path]:path:' && ret=0 ;;
      (pubkey)
        _arguments \
          '--skip-seed-phrase-validation[skip validation]' \
          '*:keypair file:_files' && ret=0 ;;
      (verify)
        _arguments \
          '*: :' && ret=0 ;;
      (recover)
        _arguments \
          '(-o --outfile)'{-o+,--outfile=}'[output keypair file]:file:_files' \
          '(-f --force)'{-f,--force}'[overwrite without prompt]' \
          '--language=[language]:lang:(english chinese-simplified chinese-traditional japanese spanish korean french italian)' && ret=0 ;;
      (grind)
        _arguments \
          '--ignore-case[case insensitive match]' \
          '--starts-with=[prefix:count]:spec:' \
          '--ends-with=[suffix:count]:spec:' \
          '--starts-and-ends-with=[prefix:suffix:count]:spec:' \
          '--num-threads=[threads]:n:' \
          '--use-mnemonic[output as seed phrase]' \
          '--no-bip39-passphrase[no BIP39 passphrase]' \
          '--word-count=[seed words]:n:(12 15 18 21 24)' \
          '--language=[language]:lang:(english chinese-simplified chinese-traditional japanese spanish korean french italian)' && ret=0 ;;
    esac ;;
esac

return ret
