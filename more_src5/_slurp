#compdef slurp
# Documentation: https://github.com/emersion/slurp/blob/master/slurp.1.scd
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for slurp - Wayland region selector

_arguments -s -S \
  '(- *)-h[show help message and quit]' \
  '-d[display dimensions of selection]' \
  '-b[set background color]:color:' \
  '-c[set border color]:color:' \
  '-s[set selection color]:color:' \
  '-B[set highlight color for unselected predefined rectangles]:color:' \
  '-F[set font family for the dimensions box]:font family:' \
  '-w[set border weight]:weight:' \
  '-f[set format string]:format:' \
  '-p[select a single pixel instead of a rectangle]' \
  '-o[add predefined rectangles for all outputs]' \
  '-r[restrict selection to predefined rectangles only]' \
  '-a[force selections to have the given aspect ratio]:width\:height:' \
  '-x[draw fullscreen crosshairs on the display output]' \
  && return 0
