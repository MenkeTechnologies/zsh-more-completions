local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:ImageDimension:(2 3 4)' \
    '2:OutName:_files' \
    '3:NGroup1:_default' \
    '4:NGroup2:_default' \
    '*:Group1 then Group2 image lists:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    && ret=0

return ret
