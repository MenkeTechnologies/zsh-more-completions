#compdef redis-tui
# _redis-tui — Mathias Garstenauer redis-tui terminal Redis client CLI alias (mat-rumian team, Go/Rust); custom argparse — multiple implementations
# upstream: https://github.com/mat-rumian/redis-tui

_redis-tui() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--host=+[host]:host:_hosts' \
        '-H+[host]:host:_hosts' \
        '--port=+[port]:port:' \
        '-p+[port]:port:' \
        '--password=+[password]:str:' \
        '-a+[password]:str:' \
        '--db=+[database number]:n:' \
        '-n+[database number]:n:' \
        '--user=+[username]:user:_users' \
        '-u+[username]:user:_users' \
        '--socket=+[unix socket]:file:_files' \
        '-s+[unix socket]:file:_files' \
        '--tls[enable TLS]' \
        '--tls-cert=+[cert file]:file:_files' \
        '--tls-key=+[key file]:file:_files' \
        '--tls-ca=+[ca file]:file:_files' \
        '--tls-insecure[skip TLS verification]' \
        '--sentinel-master=+[sentinel master name]:str:' \
        '--sentinel-addr=+[sentinel address]:str:' \
        '--cluster[cluster mode]' \
        '--theme=+[theme]:t:(dark light auto)' \
        '--scan-batch-size=+[batch size]:n:' \
        '--readonly[readonly mode]' \
        '--log-file=+[log file]:file:_files' \
        '--config=+[config file]:file:_files' \
        '*:cluster nodes:'
}

_redis-tui "$@"
