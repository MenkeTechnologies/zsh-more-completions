#compdef scat
# _scat — search astronomical star catalogs (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from scat.c (single-letter getopt-style).

_scat() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-v[verbose output]' \
        '-a[get closest source]' \
        '-b+[B1950 reference coords]:coords:' \
        '-c+[reference catalog]:cat:(ub1 ub2 ucac4 ucac3 ucac2 gsc2 gsc tycho2 tycho hip act sao ppm bsc usno-b1 usno-a2 2mass usno-b1.0)' \
        '-d[output in degrees instead of sexagesimal]' \
        '-e[ecliptic-coordinate output]' \
        '-f[output in centering coords]' \
        '-g+[galactic-coordinate output (and optional center)]:center:' \
        '-h[output descriptive header]' \
        '-i[output catalog object name instead of number]' \
        '-j+[J2000 reference coords]:coords:' \
        '-k+[keyword to add from tab table]:keyword:' \
        '-l[print center and closest star on one line]' \
        '-m+[magnitude limit]:mag:' \
        '-n+[number of brightest stars to read]:n:' \
        '-o+[object name]:name:' \
        '-p[sort by distance from center]' \
        '-q+[output equinox (years)]:eq:' \
        '-r+[search box/circle half-size (arcsec)]:arcsec:' \
        '-s+[sort by]:sort:(ra dec mag none)' \
        '-t[tab-table output]'
}

_scat "$@"
