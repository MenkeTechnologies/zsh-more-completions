#compdef sliver-server
# _sliver-server — BishopFox sliver-server CLI cross-platform Sliver C2 implant framework server mode listening for connections from sliver implants HTTP HTTPS DNS WireGuard mtls protocol multiplayer mode operator management certificate-bound mTLS authentication for authorized red-team operations (BishopFox team, Go); cobra
# upstream: https://github.com/BishopFox/sliver

_sliver-server() {
    local -a sub=(
        'daemon:run in daemon mode'
        'operator:operator management'
        'cert:certificate operations'
        'completion:generate shell completion'
        'unpack:unpack assets'
        'export:export an operator config'
        'import:import an operator config'
        'console:start the interactive console'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--force[force overwrite]' \
        '--config=+[file]:file:_files -g "*.cfg *.json *.yaml"' \
        '--root-dir=+[dir]:dir:_files -/' \
        '--unsafe-tls[disable TLS verification]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'sliver-server subcommand' sub ;;
        args)
            case $words[1] in
                daemon) _arguments \
                    '-l+[listen host]:_hosts' \
                    '-p+[port]:n:' \
                    '-f+[force]' ;;
                operator) _arguments \
                    '1:op:(add rm list kick)' \
                    '-n+[name]:str:' \
                    '-l+[listen]:_hosts' \
                    '-s+[save dir]:dir:_files -/' ;;
                export|import) _arguments '*:config file:_files' ;;
            esac
            ;;
    esac
}

_sliver-server "$@"
