_sunbeam() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a core_cmds
    core_cmds=(
        'validate:validate a Sunbeam JSON Schema document'
        'edit:open a file in your editor (no args = config)'
        'copy:copy text from stdin to clipboard'
        'paste:paste text from clipboard to stdout'
        'open:open a file or URL in the default application'
        'extension:manage sunbeam extensions'
        'version:print version number'
        'help:show help for a command'
    )

    local -a validate_kinds
    validate_kinds=(
        'list:validate a list'
        'detail:validate a detail'
        'manifest:validate a manifest'
        'config:validate a config'
    )

    local -a extension_cmds
    extension_cmds=(
        'create:create a new sunbeam extension'
        'edit:edit a sunbeam extension'
        'install:install an extension'
        'rename:rename a sunbeam extension'
        'upgrade:upgrade a sunbeam extension (all if omitted)'
        'list:list installed extensions'
        'remove:remove a sunbeam extension'
        'configure:configure extension preferences'
    )

    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '(-): :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        cmd)
            _describe -t commands 'sunbeam command' core_cmds && ret=0
            ;;
        args)
            case $line[1] in
                validate)
                    _arguments -C \
                        '(-): :->vkind' \
                        '*::vrest:->vrest' && ret=0
                    case $state in
                        vkind)
                            _describe -t commands 'validate kind' validate_kinds && ret=0
                            ;;
                        vrest)
                            _arguments '1:schema file:_files -g "*.json"' && ret=0
                            ;;
                    esac
                    ;;
                edit)
                    _arguments \
                        '(-e --extension)'{-e+,--extension=}'[file extension for tempfile]:ext:' \
                        '(-c --config)'{-c,--config}'[edit the config file]' \
                        '1:file:_files' && ret=0
                    ;;
                open)
                    _arguments '1:target file or URL:_files' && ret=0
                    ;;
                extension)
                    _arguments -C \
                        '(-): :->extcmd' \
                        '*::extarg:->extarg' && ret=0
                    case $state in
                        extcmd)
                            _describe -t commands 'extension command' extension_cmds && ret=0
                            ;;
                        extarg)
                            case $line[1] in
                                create)
                                    _arguments \
                                        '(-l --language)'{-l+,--language=}'[language template]:lang:(deno node bash python)' \
                                        '1:extension name:' && ret=0
                                    ;;
                                install)
                                    _arguments \
                                        '--alias=[alias for extension]:alias:' \
                                        '1:origin (URL or path):' && ret=0
                                    ;;
                                edit|configure|remove|upgrade)
                                    _arguments '1:extension alias:' && ret=0
                                    ;;
                                rename)
                                    _arguments \
                                        '1:current alias:' \
                                        '2:new alias:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                copy|paste|version|help)
                    ret=0
                    ;;
            esac
            ;;
    esac
    return ret
}

_sunbeam "$@"
