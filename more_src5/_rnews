#compdef rnews
# Documentation: man rnews(1)
# Source: InterNetNews/inn frontends/rnews.c — inject batched articles into innd (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[do not use additional unpackers]' \
    '-b[back up bad batches]' \
    '-d[log duplicate articles]' \
    '-h+[UUCP source hostname]:host:_hosts' \
    '(-N -U)-N[do not unpack, only test]' \
    '(-N -U)-U[unpack mode]' \
    '-P+[NNTP port]:port:_default' \
    '-v[verbose]' \
    '(-r -S)-r+[remote NNTP server]:host:_hosts' \
    '(-r -S)-S+[remote NNTP server (alias)]:host:_hosts' \
    '1::batch file:_files' \
    && ret=0

return ret
