#compdef quake
# Documentation: https://manpages.org/quake/6
# Reference accessed: 2026-05-20
# Verified: quake(6) Debian wrapper manpage. Only -h/--help and -v/--version
# are processed by the wrapper; any further arguments are passed to the
# engine unmodified.

# quake: id Software Quake (Debian wrapper)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show summary of options]' \
  '(- *)'{-v,--version}'[show version]' \
  '*:engine arg:_files' && ret=0
return ret
