#compdef shadow-cljs
# Documentation: https://shadow-cljs.github.io/docs/UsersGuide.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'compile:compile a build once and exit'
  'watch:compile and watch a build'
  'release:create a :release mode optimized build'
  'check:check a build for errors'
  'server:run shadow-cljs server in foreground'
  'start:start server in background'
  'stop:stop the running server'
  'restart:restart the server'
  'cljs-repl:connect to REPL for a build'
  'clj-repl:REPL to control the server process'
  'node-repl:connect to standalone node REPL'
  'browser-repl:open browser REPL'
  'run:call a Clojure function from the command line'
  'clj-run:call a Clojure function from the command line'
  'init:create default shadow-cljs.edn'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[debug logging / pretty-print + pseudo-names]' \
  '(-A --aliases)'{-A+,--aliases=}'[deps.edn aliases]:aliases:' \
  '--config-merge=[merge additional EDN data into config]:edn:' \
  '--source-maps[enable source maps]' \
  '--force-spawn[force creation of new JVM instance]' \
  '--no-color[disable colored output]' \
  '--verbose[verbose output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'shadow-cljs command' commands && ret=0 ;;
esac

return ret
