#compdef soundkonverter
# _soundkonverter — KDE audio file converter / CD ripper (HessiJames/soundkonverter)
# upstream: https://github.com/HessiJames/soundkonverter
# Flags from src/main.cpp (KCmdLineOptions).

_soundkonverter() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-v,--version}'[show version]'
        '--replaygain[open the Replay Gain tool with the given files]'
        '--rip=[list tracks on the CD device (or "auto")]:device:_files -W /dev/'
        '--profile=[use this conversion profile]:profile:'
        '--format=[use this output format]:format:(wav flac mp3 ogg opus aac m4a wma ac3 mpc ra wv aiff)'
        '--output=[output directory]:dir:_files -/'
        '--invisible[start soundkonverter without a window]'
        '--autostart[start the conversion immediately]'
        '--autoclose[close soundkonverter after conversion finishes]'
        '--command=[command to run after each conversion (%i in, %o out)]:cmd:'
        '--file-list=[load this file list on startup]:file:_files'
        '*:audio file(s):_files'
    )
    _arguments -s $args
}

_soundkonverter "$@"
