#compdef s6-rc-bundle
# Documentation: https://skarnet.org/software/s6-rc/s6-rc-bundle.html
# Reference accessed: 2026-05-30
# s6-rc-bundle — define/delete bundle services in an s6-rc compiled database.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'add:add bundle (replaces if exists with -f)'
  'delete:delete bundle (no-op on missing with -f)'
  'multiple:add multiple bundles via stdin (each line: bundle service1 service2...)'
)

_arguments -C \
  '(-c)-c+[operate on compiled DB instead of live one]:dir:_directories' \
  '(-l)-l+[live state location (ignored if -c; default /run/s6-rc)]:dir:_directories' \
  '-f[force: no error on missing-to-delete or existing-to-add (replace)]' \
  '-b[blocking lock: wait on DB lock contention instead of failing]' \
  '1: :->subcmd' \
  '*:: :->args' && ret=0

case $state in
  subcmd)
    _describe -t commands 'bundle subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      add)
        _arguments \
          '1:bundle name:' \
          '*:member service:' && ret=0
        ;;
      delete)
        _arguments \
          '*:bundle name:' && ret=0
        ;;
      multiple)
        # Reads stdin
        _arguments && ret=0
        ;;
    esac
    ;;
esac

return ret
