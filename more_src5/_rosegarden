#compdef rosegarden
# Documentation: https://manpages.debian.org/bookworm/rosegarden/rosegarden.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream Debian rosegarden(1) manpage. Removed fabricated
# flags from prior file: --help-all, --display, --nosound,
# --existingsequencer, --non-unique (none are documented).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--nosplash[disable splash screen]' \
  '--nosequencer[do not use external sequencer]' \
  '*:file:_files -g "*.{rg,rgp,mid,midi,xml}"' && ret=0

return ret
