#compdef qselect
# _qselect-pbs — PBS qselect (filter PBS jobIDs by attribute expressions; -A account, -N job name, -P project, -s state list, -u user, -t array selector, -l resource list, -c checkpoint, -p priority comparator, -r rerunnable, -M mail user, -q queue or @server target; prints matching jobID list one per line)
# upstream: https://github.com/openpbs/openpbs
# Flags from openpbs src/cmds/qselect.c on tip.

_qselect-pbs() {
    _arguments \
        '-A+[account]:account:' \
        '-N+[job name]:name:' \
        '-P+[project]:project:' \
        '-s+[state list]:states:(Q R H W S T B M U F X)' \
        '-u+[user]:user:_users' \
        '-t+[array selector]:range:' \
        '-l+[resource list]:resources:' \
        '-c+[checkpoint spec]:spec:' \
        '-p+[priority comparator]:cmp:' \
        '-r+[rerunnable]:rerunnable:(y n)' \
        '-M+[mail user]:user:_users' \
        '-q+[queue or @server]:target:' \
        '-x[finished jobs too]'
}

_qselect-pbs "$@"
