#compdef spatialite_dem
# Documentation: https://www.gaia-gis.it/fossil/spatialite-tools/wiki?name=spatialite_dem
# Reference accessed: 2026-05-21
# Verified: upstream gaia-gis spatialite-tools fossil wiki for
# spatialite_dem. Flags grouped: DEM-database (-ddem/-tdem/-gdem/-rdem),
# source/update DB (-d/-t/-g), commands (-sniff/-updatez/-fetchz/
# -create_dem/-import_xyz), general (-mdem/-default_srid/-fetchz_xy/-v/
# -save_conf/--help).

# spatialite_dem: digital elevation model importer for spatialite
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-ddem --dem-path)'{-ddem+,--dem-path=}'[SpatiaLite DEM database path]:file:_files' \
  '(-tdem --table-dem)'{-tdem+,--table-dem=}'[DEM table (SpatialTable/View)]:table:' \
  '(-gdem --geometry-dem-column)'{-gdem+,--geometry-dem-column=}'[DEM geometry column (POINT Z/ZM)]:col:' \
  '(-rdem --dem-resolution)'{-rdem+,--dem-resolution=}'[DEM point resolution]:resolution:' \
  '(-d --db-path)'{-d+,--db-path=}'[source spatialite DB to update]:file:_files' \
  '(-t --table)'{-t+,--table=}'[table to update (SpatialTable)]:table:' \
  '(-g --geometry-column)'{-g+,--geometry-column=}'[geometry column to update (Z/ZM)]:col:' \
  '(-mdem --copy-m)'{-mdem+,--copy-m=}'[copy M values]:n:(0 1)' \
  '(-default_srid --srid)'{-default_srid+,--srid=}'[default SRID for queries]:srid:' \
  '-fetchz_xy[X/Y coords for Z-value query]:xy:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '-save_conf[save configuration to file]' \
  '-sniff[analyze settings without updating]' \
  '-updatez[update Z values in geometries]' \
  '-fetchz[query Z values from coordinates]' \
  '-create_dem[create DEM database from XYZ file]' \
  '-import_xyz[import XYZ file into existing DEM DB]' \
  '*:DEM file:_files' && ret=0
return ret
