#compdef shbasis
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/shbasis.html
# Source: MRtrix3/mrtrix3 cmd/shbasis.cpp — examine or convert SH basis convention (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-convert+[in-place basis conversion mode]:mode:(old new force_oldtonew force_newtoold)' \
    '*:SH images:_files -g "*.{nii,nii.gz,mif}"' \
    && ret=0

return ret
