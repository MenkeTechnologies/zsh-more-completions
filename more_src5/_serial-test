#compdef serial-test
# _serial-test — serial-test CLI for the serial-port loopback and protocol-conformance tester sending receiving fixed binary patterns checksum validation throughput stress timing latency variance reporting (linux team, C); getopt
# upstream: https://github.com/serial-test/serial-test

_serial-test() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-p+[port]:file:_files -g "/dev/tty* /dev/cu*"' \
        '--port=+[port]:file:_files -g "/dev/tty* /dev/cu*"' \
        '-b+[baud]:n:(75 110 300 600 1200 2400 4800 9600 19200 38400 57600 115200 230400 460800 921600 1500000)' \
        '--baud=+[baud]:n:(75 110 300 600 1200 2400 4800 9600 19200 38400 57600 115200 230400 460800 921600 1500000)' \
        '-d+[data bits]:n:(5 6 7 8)' \
        '--databits=+[data bits]:n:(5 6 7 8)' \
        '-r+[parity]:p:(none even odd mark space)' \
        '--parity=+[parity]:p:(none even odd mark space)' \
        '-s+[stop bits]:s:(1 1.5 2)' \
        '--stopbits=+[stop bits]:s:(1 1.5 2)' \
        '-f+[flow control]:f:(none xonxoff rtscts dsrdtr)' \
        '--flow=+[flow control]:f:(none xonxoff rtscts dsrdtr)' \
        '-l+[loopback peer]:file:_files -g "/dev/tty* /dev/cu*"' \
        '--loopback=+[loopback peer]:file:_files -g "/dev/tty* /dev/cu*"' \
        '-n+[N packets]:n:' \
        '--packets=+[N packets]:n:' \
        '-S+[size bytes]:n:' \
        '--size=+[size bytes]:n:' \
        '-T+[timeout sec]:n:' \
        '--timeout=+[timeout sec]:n:' \
        '-P+[pattern]:p:(seq alternating random one zero)' \
        '--pattern=+[pattern]:p:(seq alternating random one zero)' \
        '--stress[stress mode]' \
        '--throughput[throughput mode]' \
        '--latency[latency mode]' \
        '--checksum[checksum mode]' \
        '--no-color[no color]'
}

_serial-test "$@"
