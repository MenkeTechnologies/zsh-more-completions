#compdef surfaceInertia
# Documentation: https://cfd.direct/openfoam/user-guide/
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/surface/surfaceInertia — compute inertia tensor of closed surface (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[OpenFOAM case directory]:dir:_files -/' \
    '-fileHandler+[file handler]:handler:(uncollated collated masterUncollated)' \
    '-noFunctionObjects[disable function objects]' \
    '-shellProperties[shell mode (uses areal density)]' \
    '-density+[material density]:scalar:_default' \
    '-referencePoint+[reference point vector]:vector:_default' \
    '1:surface file:_files -g "*.{stl,obj,nas,vtk,off,gts,inp}"' \
    && ret=0

return ret
