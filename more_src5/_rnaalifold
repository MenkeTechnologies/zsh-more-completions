#compdef rnaalifold
# Documentation: https://www.tbi.univie.ac.at/RNA/RNAalifold.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# ViennaRNA RNAalifold: consensus secondary structure for RNA alignment
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-r --ribosum_scoring)'{-r,--ribosum_scoring}'[apply RIBOSUM scoring]' \
  '(-R --ribosum_file)'{-R,--ribosum_file=}'[use RIBOSUM matrix]:file:_files' \
  '(-p --partfunc)'{-p,--partfunc=-}'[compute partition function]::n:' \
  '--MEA=[maximum expected accuracy structure]:gamma:' \
  '--mis[output most informative sequence]' \
  '(-T --temp)'{-T,--temp=}'[temperature in C]:temp:' \
  '(-d --dangles)'{-d,--dangles=}'[dangling end model]:d:(0 1 2 3)' \
  '(-c --circ)'{-c,--circ}'[circular RNA]' \
  '--noLP[no lonely pairs]' \
  '--noGU[no GU pairs]' \
  '--noClosingGU[no GU at helix ends]' \
  '--cfactor=[cov term weight]:val:' \
  '--nfactor=[non-cov penalty weight]:val:' \
  '(-P --paramFile)'{-P,--paramFile=}'[parameter file]:file:_files' \
  '(-4 --noTetra)'{-4,--noTetra}'[skip special hairpin energies]' \
  '--salt=[salt concentration in molar]:val:' \
  '--color[colour structure plot]' \
  '--aln[generate alignment plot]' \
  '--aln-EPS-cols=[EPS plot columns]:n:' \
  '--aln-stk=-[Stockholm output prefix]::prefix:' \
  '(-f --input-format)'{-f,--input-format=}'[input alignment format]:fmt:(C S F M)' \
  '(-g --gquad)'{-g,--gquad}'[G-quadruplex formation]' \
  '(-S --pfScale)'{-S,--pfScale=}'[pf scaling factor]:factor:' \
  '--bppmThreshold=[bpp threshold]:thresh:' \
  '(-E --endgaps)'{-E,--endgaps}'[score end gaps]' \
  '--sci[compute SCI]' \
  '(-s --stochBT)'{-s,--stochBT=}'[stochastic backtrack samples]:n:' \
  '--auto-id[auto-generate sequence IDs]' \
  '*:RNA alignment file:_files -g "*.(stk|sto|aln|fa|fasta)"' && ret=0
return ret
