#compdef qemu-keymap
# _qemu-keymap — QEMU qemu-keymap (generate a QEMU virtual-keyboard mapping file from a libxkbcommon RMLVO selection (rules+model+layout+variant+options); -m model, -l layout, -v variant, -o output file, -f format (qemu|xkb))
# upstream: https://gitlab.com/qemu-project/qemu (qemu-keymap)
# Flags from qemu qemu-keymap.c on tip.

_qemu-keymap() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-f+[output format]:format:(qemu xkb)' \
        '-l+[layout]:layout:' \
        '-v+[variant]:variant:' \
        '-m+[model]:model:' \
        '-o+[output file]:file:_files' \
        '*--options=*[xkb options]:options:'
}

_qemu-keymap "$@"
