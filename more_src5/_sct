#compdef sct xsct
# Documentation: https://github.com/faf0/sct
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[display the help page]' \
  '(-v --verbose)'{-v,--verbose}'[display debugging information]' \
  '(-d --delta)'{-d+,--delta=}'[shift temperature and brightness relatively]:delta:' \
  '(-s --screen)'{-s+,--screen=}'[screen index]:screen:' \
  '(-t --toggle)'{-t,--toggle}'[toggle between night and day temperature]' \
  '(-c --crtc)'{-c+,--crtc=}'[CRTC index]:crtc:' \
  '1::temperature in Kelvin:' \
  '2::brightness (0.0-1.0):' && ret=0

return ret
