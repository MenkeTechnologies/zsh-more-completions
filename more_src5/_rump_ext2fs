#compdef rump_ext2fs
# Documentation: man rump_ext2fs(8)
# Source: netbsd/src usr.sbin/puffs/rump_ext2fs — mount ext2 images via userspace rump server (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-o+[mount options (see mount_ext2fs(8))]:options:_default' \
    '1:image (supports %DISKLABEL\:p% suffix):_files' \
    '2:mount point:_files -/' \
    && ret=0

return ret
