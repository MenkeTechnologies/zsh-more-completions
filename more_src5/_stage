#compdef stage
# Documentation: https://www.npmjs.com/package/stage
# Reference accessed: 2026-05-23
# Verified: npx stage --help.

# Zsh completion for stage - AWS app staging and deployment CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:run the app locally'
  'build:build app assets'
  'deploy:deploy to your AWS account'
  'help:display command help'
)

_arguments -C   '(-h --help)'{-h,--help}'[show help]'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'stage command' commands && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
