#compdef qucs
# Documentation: https://github.com/Qucs/qucs/blob/master/qucs/qucs/main.cpp
# Reference accessed: 2026-05-20
# Verified: upstream source at the URL above (option parser).
# Qucs: Quite Universal Circuit Simulator GUI.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-n --netlist -p --print)'{-n,--netlist}'[convert schematic to netlist]' \
  '(-n --netlist -p --print)'{-p,--print}'[print schematic to file]' \
  '(-q --quit)'{-q,--quit}'[exit immediately]' \
  '--page=[page size]:size:(A4 A3 B4 B5)' \
  '--dpi=[print resolution]:dpi:(72 96 150 300 600)' \
  '--color=[color mode]:mode:(RGB CMYK)' \
  '--orin=[orientation]:orientation:(portrait landscape)' \
  '-i+[input schematic file]:file:_files -g "*.sch"' \
  '-o+[output file]:file:_files' \
  '-icons[generate component icons]' \
  '-doc[export documentation data]' \
  '-list-entries[list component entry formats]' \
  '*:Qucs schematic file:_files -g "*.(sch|dpl)"' && ret=0
return ret
