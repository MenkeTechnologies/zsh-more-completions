#compdef s6-ipcserver-access
# _s6-ipcserver-access — s6 conn-tools s6-ipcserver-access (peer access-control filter; consults a rules filesystem or rules cdb to allow/deny each incoming connection, then execs `prog`)
# upstream: https://github.com/skarnet/s6
# Flags from src/conn-tools/s6-ipcserver-access.c on tip.

_s6-ipcserver-access() {
    _arguments \
        '-v+[verbosity]:n:' \
        '(-e -E)-e[execute env-substituted rules]' \
        '(-e -E)-E[do not run env-substituted rules]' \
        '-l+[local name (for $PROTOLOCALPATH)]:name:' \
        '(-i -x)-i+[accessrules directory tree]:dir:_files -/' \
        '(-i -x)-x+[accessrules cdb file]:file:_files' \
        '*::program:_command_names -e'
}

_s6-ipcserver-access "$@"
