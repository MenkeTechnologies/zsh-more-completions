#compdef sectok
# Documentation: https://www.freshports.org/security/sectok
# Reference accessed: 2026-05-21
# Verified: FreeBSD/NetBSD ISO 7816 smartcard interactive shell exists per
# FreshPorts; the full upstream manpage was not reachable from this host so
# the subcommand list is not authoritatively verified here.
# STUB: subcommand list left intact for usability but not flag-by-flag verified.

local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'reset:reset card'
  'apdu:send APDU bytes'
  'reader:list / select readers'
  'pin:verify PIN'
  'select:select an EF/DF/AID'
  'read:read binary/record'
  'write:write binary/record'
  'fid:show file id list'
  'class:set CLA byte'
  'help:show help'
  'quit:exit'
)
_arguments -C \
  '(- *)-h[show help]' \
  '-r[reader]:reader:' \
  '-v[verbose]' \
  '-f[script file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'sectok command' commands && ret=0 ;;
esac
return ret
