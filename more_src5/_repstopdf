#compdef repstopdf
# Documentation: repstopdf --help (epstopdf 2.36 restricted mode)
# Source: convert an EPS to PDF (via Ghostscript) in restricted mode (safe for \write18).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '(-o --outfile)'{-o+,--outfile=}'[write result to FILE]:pdf file:_files -g "*.pdf"' \
    '--restricted[use restricted mode (default for repstopdf)]' \
    '(--debug --nodebug)--debug[output debugging info]' \
    '(--debug --nodebug)--nodebug[disable debug]' \
    '(--exact --noexact)--exact[scan ExactBoundingBox]' \
    '(--exact --noexact)--noexact[ignore ExactBoundingBox]' \
    '(--filter --nofilter)--filter[read standard input]' \
    '(--filter --nofilter)--nofilter[read from file]' \
    '(--gs --nogs)--gs[run ghostscript]' \
    '(--gs --nogs)--nogs[disable ghostscript]' \
    '(--hires --nohires)--hires[use %%HiResBoundingBox]' \
    '(--hires --nohires)--nohires[ignore HiResBoundingBox]' \
    '--gscmd=[ghostscript invocation]:gs:_command_names -e' \
    '*--gsopt=[option to pass through to ghostscript]:opt:' \
    '*--gsopts=[multiple ghostscript options (quoted)]:opts:' \
    '--res=[resolution dpi for bitmap output]:dpi:' \
    '--autorotate=[autorotate page]:mode:(None All PageByPage)' \
    '1:eps file:_files -g "*.(eps|ps)"' \
    '2:pdf file:_files -g "*.pdf"' \
    && ret=0

return ret
