#compdef systemsetup
# Documentation: man systemsetup (macOS 26)
# Source: per-machine settings tool (date/time/sleep/wake/remote-login/startup-disk).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[show help]' \
    '(- *)-version[show version]' \
    '(- *)-printCommands[print supported commands]' \
    '-getdate[display current date]' \
    '-setdate+[set current date]:mm\:dd\:yy:' \
    '-gettime[display current time]' \
    '-settime+[set current time]:hh\:mm\:ss:' \
    '-gettimezone[display current time zone]' \
    '-listtimezones[list supported time zones]' \
    '-settimezone+[set local time zone]:timezone:' \
    '-getusingnetworktime[show whether network time is on]' \
    '-setusingnetworktime+[turn network time on/off]:state:(on off)' \
    '-getnetworktimeserver[display network time server]' \
    '-setnetworktimeserver+[set network time server]:timeserver:_hosts' \
    '-getsleep[display idle time until machine sleeps]' \
    '-setsleep+[set idle time until machine sleeps]:minutes:' \
    '-getcomputersleep[display idle time until computer sleeps]' \
    '-setcomputersleep+[set idle time until computer sleeps]:minutes:' \
    '-getdisplaysleep[display idle time until display sleeps]' \
    '-setdisplaysleep+[set idle time until display sleeps]:minutes:' \
    '-getharddisksleep[display idle time until hard disk sleeps]' \
    '-setharddisksleep+[set idle time until hard disk sleeps]:minutes:' \
    '-getwakeonmodem[display wake-on-modem state]' \
    '-setwakeonmodem+[set wake-on-modem state]:state:(on off)' \
    '-getwakeonnetworkaccess[display wake-on-network state]' \
    '-setwakeonnetworkaccess+[set wake-on-network state]:state:(on off)' \
    '-getrestartpowerfailure[display restart-after-power-failure state]' \
    '-setrestartpowerfailure+[set restart-after-power-failure]:state:(on off)' \
    '-getrestartfreeze[display restart-on-freeze state]' \
    '-setrestartfreeze+[set restart-on-freeze]:state:(on off)' \
    '-getallowpowerbuttontosleepcomputer[display power-button-sleep state]' \
    '-setallowpowerbuttontosleepcomputer+[set power-button-sleep]:state:(on off)' \
    '-getremotelogin[display ssh remote-login state]' \
    '-setremotelogin+[set ssh remote-login state]:args:' \
    '-getremoteappleevents[display remote-Apple-events state]' \
    '-setremoteappleevents+[set remote-Apple-events state]:state:(on off)' \
    '-getcomputername[display computer name]' \
    '-setcomputername+[set computer name]:name:' \
    '-getlocalsubnetname[display local-subnet name]' \
    '-setlocalsubnetname+[set local-subnet name]:name:' \
    '-getstartupdisk[display blessed startup disk]' \
    '-liststartupdisks[list available startup disks]' \
    '-setstartupdisk+[set startup disk]:path:_files -/' \
    '-getwaitforstartupafterpowerfailure[display wait-after-power-failure seconds]' \
    '-setwaitforstartupafterpowerfailure+[set wait-after-power-failure seconds]:seconds:' \
    '-getdisablekeyboardwhenenclosurelockisengaged[display enclosure-lock kbd state]' \
    '-setdisablekeyboardwhenenclosurelockisengaged+[set enclosure-lock kbd state]:state:(yes no)' \
    '-getkernelbootarchitecturesetting[display kernel boot architecture]' \
    '-setkernelbootarchitecture+[set kernel boot architecture]:arch:(i386 x86_64 default)' \
    && ret=0

return ret
