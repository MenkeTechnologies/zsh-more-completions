#compdef redo-cli
# _redo-cli — Avery Pennarun redo recursive build system CLI alias (Avery Pennarun / apenwarr, Python); custom argparse
# upstream: https://github.com/apenwarr/redo

_redo-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--jobs=+[parallel jobs]:n:' \
        '-j+[parallel jobs]:n:' \
        '--debug[debug]' \
        '-d[debug]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--xtrace[trace]' \
        '-x[trace]' \
        '--keep-going[keep going]' \
        '-k[keep going]' \
        '--no-color[no color]' \
        '--shuffle[shuffle build order]' \
        '--debug-locks[debug locks]' \
        '--debug-pids[debug pids]' \
        '--debug-pgrp[debug pgrp]' \
        '--debug-deps[debug deps]' \
        '--no-debug-deps[no debug deps]' \
        '--no-status[no status]' \
        '--status[show status]' \
        '--pretty[pretty output]' \
        '--no-pretty[no pretty]' \
        '--no-log[no log file]' \
        '--log[log file]' \
        '--log-inherit[inherit log file]' \
        '--no-log-inherit[no inherit log file]' \
        '--logname-fmt=+[log name format]:str:' \
        '--no-warn[no warn]' \
        '--warn[warn]' \
        '--main-task[main task]' \
        '--cleanout[clean output]' \
        '--profile=+[profile output]:file:_files' \
        '--root=+[root]:dir:_files -/' \
        '*:target:_files'
}

_redo-cli "$@"
