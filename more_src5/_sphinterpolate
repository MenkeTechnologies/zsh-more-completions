#compdef sphinterpolate
# Documentation: https://docs.generic-mapping-tools.org/latest/sphinterpolate.html
# Source: GenericMappingTools/gmt classic-mode sphinterpolate — spherical surface interpolation.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-G+[output grid file]:file:_files' \
    '-I+[grid spacing dx/dy]:spacing:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-D+[exclude duplicates (optional repeating lon)]:east:_default' \
    '-Q+[tension method]:method:(g l p s)' \
    '-T[apply variable tension factors]' \
    '*-V[verbose (stackable)]' \
    '-Z[scale data by max range before interpolation]' \
    '-bi+[binary input format]:format:_default' \
    '-di+[input nodata → NaN]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-r[pixel registration (default gridline)]' \
    '-:[swap first two columns]' \
    '*:input table:_files' \
    && ret=0

return ret
