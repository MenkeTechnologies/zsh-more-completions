#compdef starlight starlight-cli
# _starlight — Astro starlight documentation theme CLI scaffolding new docs sites built on Astro with sidebar i18n search MDX integrations and accessibility defaults (withastro team, TypeScript); commander.js
# upstream: https://github.com/withastro/starlight

_starlight() {
    local -a sub=(
        'create:create new Starlight project'
        'init:add Starlight to existing Astro project'
        'add-integration:add Starlight integration'
        'sync:sync content collections'
        'dev:start dev server'
        'build:build for production'
        'preview:preview production build'
        'check:type-check'
        'i18n:i18n operations'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--cwd=+[dir]:dir:_files -/' \
        '--config=+[file]:file:_files -g "*.ts *.mjs"' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'starlight subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '--name=+[name]:str:' \
                    '--template=+[t]:t:(basics blog with-i18n with-search with-tailwind starter)' \
                    '--git[init git]' \
                    '--no-git[no git]' \
                    '--install[install deps]' \
                    '--no-install[no install]' \
                    '--package-manager=+[pm]:p:(npm pnpm yarn bun)' \
                    '*:project dir:_files -/' ;;
                dev) _arguments \
                    '--port=+[port]:n:' \
                    '--host=+[host]:str:' \
                    '--open[open browser]' ;;
                build) _arguments \
                    '--output=+[dir]:dir:_files -/' ;;
                add-integration) _arguments \
                    '1:integration:(blog markdown-magic image-galleries open-graph llms-txt sidebar-topics view-modes pageant rapide bots search-meilisearch search-pagefind search-algolia)' ;;
                i18n) _arguments \
                    '1:action:(add remove list audit)' \
                    '*:locale:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_starlight "$@"
