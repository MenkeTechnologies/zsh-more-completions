#compdef rpmdev-vercmp
# Documentation: https://github.com/rsrchboy/rpmdevtools/blob/master/rpmdev-vercmp
# Reference accessed: 2026-05-21
# Verified: upstream rsrchboy/rpmdevtools rpmdev-vercmp Python source.
# Accepts -h/--help/-help/--usage and EVR positional args; no -v/--version.
# Usage: rpmdev-vercmp <epoch1> <ver1> <rel1> <epoch2> <ver2> <rel2>
#        rpmdev-vercmp <EVR1> <EVR2>
# Removed from prior file: fabricated -v/--version flag.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help -help --usage)'{-h,--help,-help,--usage}'[show usage]' \
  '*:EVR:' && ret=0
return ret
