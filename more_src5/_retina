#compdef retina
# Documentation: https://github.com/microsoft/retina
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for Retina (kubectl-retina) - Kubernetes network observability.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'capture:capture network traffic'
      'completion:generate shell autocompletion script'
      'config:configure retina CLI'
      'help:help about any command'
      'shell:interactively debug a node or pod (experimental)'
      'trace:retrieve status or results from Retina'
      'version:show version'
    )
    _describe -t commands 'retina command' commands && ret=0
    ;;
  args)
    case $line[1] in
      capture)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(create delete list download)' && ret=0
        ;;
      completion)
        _arguments \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
