#compdef rpm2archive
# Documentation: man rpm2archive(8)
# Source: rpm-software-management/rpm tools/rpm2archive.cc (master) — extract RPM payload as archive (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-n --nocompression)'{-n,--nocompression}'[create uncompressed archive]' \
    '(-f --format)'{-f+,--format=}'[archive format]:format:(pax cpio)' \
    '(-? --help)'{-\\?,--help}'[show help]' \
    '--usage[show usage]' \
    '*:rpm file:_files -g "*.rpm"' \
    && ret=0

return ret
