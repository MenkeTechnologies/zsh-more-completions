#compdef R-CMD-SHLIB
# _R-CMD-SHLIB — R Core Team R CMD SHLIB build shared library from C C++ Fortran source for use with dyn.load (rcore team, C); getopt
# upstream: https://cran.r-project.org/

_R-CMD-SHLIB() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-o+[output file]:file:_files -g "*.so *.dylib *.dll"' \
        '-c[compile only]' \
        '-d[debug build]' \
        '--debug[debug build]' \
        '-n[dry run print commands]' \
        '--dry-run[dry run print commands]' \
        '--preclean[preclean]' \
        '--clean[clean]' \
        '-l+[lib]:str:' \
        '-L+[lib dir]:dir:_files -/' \
        '-I+[include dir]:dir:_files -/' \
        '*:source file:_files -g "*.c *.cpp *.cc *.cxx *.f *.f90 *.f95 *.f03 *.f08 *.h *.hpp *.S *.s *.o"'
}

_R-CMD-SHLIB "$@"
