#compdef solang
# Documentation: upstream src/bin/cli/mod.rs at
# github.com/hyperledger-solang/solang
# Reference accessed: 2026-05-30 via gh api inspection of every
# clap derive #[command(...)] and #[arg(...)] macro.
# Hyperledger Solang R74 — Solidity compiler written in Rust with
# LLVM backend (Solana / Polkadot / Soroban / EVM targets).
# 6 top-level subcommands.

local curcontext="$curcontext" state line ret=1

local -a _subcmds _targets _emits _opts _shells
_subcmds=(
  'compile:compile Solidity source files'
  'doc:generate documentation for contracts using doc comments'
  'shell-complete:print shell completion for various shells to STDOUT'
  'language-server:start LSP language server on stdin/stdout'
  'idl:generate Solidity interface files from Anchor IDL files'
  'new:create a new Solang project'
)
_targets=( solana polkadot evm )
_emits=( ast-dot cfg llvm-ir llvm-bc object asm )
_opts=( none less default aggressive )
_shells=( bash zsh fish elvish powershell )

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-): :->subcmd' \
  '(-)*:: :->subcmd_args' \
  && ret=0

case $state in
  subcmd)
    _describe -t commands 'solang subcommand' _subcmds && ret=0
    ;;
  subcmd_args)
    case $words[1] in
      compile)
        _arguments -s -S \
          '--config-file=[take arguments from configuration file (default solang.toml)]:file:_files' \
          '*-I+[directory to search for Solidity files (repeatable)]:directory:_directories' \
          '*--importpath=[directory to search for Solidity files (repeatable)]:directory:_directories' \
          '*-m+[map directory for Solidity files (map=path)]:map=path:' \
          '*--importmap=[map directory for Solidity files (map=path)]:map=path:' \
          '--target=[target to build for]:target:(solana polkadot evm soroban)' \
          '--address-length=[address length on the Polkadot Parachain (4..1024)]:N:' \
          '--value-length=[value length on the Polkadot Parachain (4..1024)]:N:' \
          '--emit=[emit compiler state at early stage]:format:($_emits)' \
          '--standard-json[mimic solidity json output on stdout]' \
          '(-o --output)'{-o,--output}'=[output directory]:directory:_directories' \
          '--output-meta=[output directory for metadata]:directory:_directories' \
          '(-v --verbose)'{-v,--verbose}'[show debug messages]' \
          '--no-dead-storage[disable dead storage codegen optimization]' \
          '--no-constant-folding[disable constant folding codegen optimization]' \
          '--no-strength-reduce[disable strength reduce codegen optimization]' \
          '--no-vector-to-slice[disable vector to slice codegen optimization]' \
          '--no-cse[disable common subexpression elimination]' \
          '-O+[LLVM optimizer level]:level:($_opts)' \
          '--no-log-runtime-errors[disable logging runtime errors in the environment]' \
          '--no-prints[disable logging prints in the environment]' \
          '(-g --generate-debug-info)'{-g,--generate-debug-info}'[enable generating LLVM IR debug information]' \
          '--release[disable all debug features]' \
          '--strict-soroban-types[Soroban integer width warnings become errors]' \
          '*:Solidity source file:_files -g "*.sol"' \
          && ret=0
        ;;
      doc)
        _arguments -s -S \
          '*-I+[directory to search for Solidity files (repeatable)]:directory:_directories' \
          '*--importpath=[directory to search for Solidity files (repeatable)]:directory:_directories' \
          '*-m+[map directory for Solidity files (map=path)]:map=path:' \
          '*--importmap=[map directory for Solidity files (map=path)]:map=path:' \
          '--target=[target to build for]:target:($_targets)' \
          '--address-length=[address length on the Polkadot Parachain]:N:' \
          '--value-length=[value length on the Polkadot Parachain]:N:' \
          '(-v --verbose)'{-v,--verbose}'[show debug messages]' \
          '(-o --output)'{-o,--output}'=[output directory]:directory:_directories' \
          '*:Solidity source file:_files -g "*.sol"' \
          && ret=0
        ;;
      shell-complete)
        _arguments '1:shell:($_shells)' && ret=0
        ;;
      language-server)
        _arguments -s -S \
          '--target=[target to build for]:target:($_targets)' \
          '--address-length=[address length on the Polkadot Parachain]:N:' \
          '--value-length=[value length on the Polkadot Parachain]:N:' \
          '*-I+[directory to search for Solidity files (repeatable)]:directory:_directories' \
          '*--importpath=[directory to search for Solidity files (repeatable)]:directory:_directories' \
          '*-m+[map directory for Solidity files (map=path)]:map=path:' \
          '*--importmap=[map directory for Solidity files (map=path)]:map=path:' \
          && ret=0
        ;;
      idl)
        _arguments -s -S \
          '(-o --output)'{-o,--output}'=[output file]:file:_files' \
          '*:IDL file:_files -g "*.json"' \
          && ret=0
        ;;
      new)
        _arguments \
          '--target=[target to build for]:target:($_targets)' \
          '1:project name:' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
