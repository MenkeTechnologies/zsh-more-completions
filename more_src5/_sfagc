#compdef sfagc
# Documentation: http://www.ahay.org/RSF/sfagc.html
# Source: ahay/src system/generic/Magc.c — automatic gain control via local-RMS triangle smoothing.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'repeat=[repeat the filtering N times]: :_default' \
    'rect1=[smoothing radius, 1st axis (default 125)]: :_default' \
    'rect2=[smoothing radius, 2nd axis]: :_default' \
    'rect3=[smoothing radius, 3rd axis]: :_default' \
    '*:RSF file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
