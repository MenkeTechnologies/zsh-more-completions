#compdef reg_ppcnr
# Documentation: https://github.com/KCL-BMEIS/niftyreg
# Source: KCL-BMEIS/niftyreg reg-apps/reg_ppcnr.cpp — Principal Component Non-Rigid registration (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(- *)-help[show help]' \
    '(- *)-v[print version]' \
    '(- *)-version[print version]' \
    '-source+[source 4D image]:file:_files -g "*.{nii,nii.gz}"' \
    '(-makesource -makesourcex)-makesource+[create source 4D image from list]:list:_default' \
    '(-makesource -makesourcex)-makesourcex+[create source 4D image (extended)]:list:_default' \
    '-distribute[distributed mode]' \
    '-pmask+[principal-component mask]:file:_files' \
    '-target+[target image]:file:_files -g "*.{nii,nii.gz}"' \
    '-aff+[initial affine transformation]:file:_files' \
    '-incpp+[initial control-point grid]:file:_files' \
    '-result+[output result image]:file:_files' \
    '-cpp+[output control-point grid]:file:_files' \
    '-prinComp+[number of principal components]:n:_default' \
    '-locality+[local images to form mean]:n:_default' \
    '-tp+[time-points for local mean]:n:_default' \
    '(-pca0 -pca1 -pca2 -pca3 -pca123)-pca0[write PCA images without registration]' \
    '(-pca0 -pca1 -pca2 -pca3 -pca123)-pca1[write PCA images during registration]' \
    '(-pca0 -pca1 -pca2 -pca3 -pca123)-pca2[write output images during registration]' \
    '(-pca0 -pca1 -pca2 -pca3 -pca123)-pca3[write CPP images during registration]' \
    '(-pca0 -pca1 -pca2 -pca3 -pca123)-pca123[write all output images]' \
    '-mean[iterative registration to the mean]' \
    '-flirt[use FLIRT (placeholder)]' \
    '-autolevel[autolevel resampling]' \
    && ret=0

return ret
