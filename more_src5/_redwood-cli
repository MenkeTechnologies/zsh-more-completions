#compdef redwood-cli
# _redwood-cli — RedwoodJS full-stack JS framework CLI alias (RedwoodJS, TypeScript); yargs
# upstream: https://github.com/redwoodjs/redwood

_redwood-cli() {
    local -a sub=(
        'build:build production app'
        'check:diagnose redwood install'
        'console:start REPL'
        'dataMigrate:run data migrations'
        'deploy:deploy app'
        'destroy:destroy a thing'
        'dev:start dev servers'
        'exec:execute custom script'
        'experimental:experimental commands'
        'g:generate code (alias)'
        'generate:generate code'
        'info:show env info'
        'lint:lint code'
        'prerender:prerender pages'
        'prisma:run prisma'
        'record:start session record'
        'serve:serve production'
        'setup:setup utilities (auth/storybook/i18n etc.)'
        'storybook:run Storybook'
        'studio:open Redwood Studio'
        'test:run tests'
        'tsc:run typescript compiler'
        'type-check:run typescript type check'
        'upgrade:upgrade redwood version'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--cwd=+[change working dir]:dir:_files -/' \
        '--telemetry[enable telemetry]' \
        '--no-telemetry[disable telemetry]' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'redwood subcommand' sub ;;
        args)
            case $words[1] in
                generate|g) _arguments \
                    '1:thing:(cell component dataMigration directive function layout model page sdl scaffold script service types graphiql secret realtime mailer dbAuth dbAuthScaffold)' \
                    '*:name:' ;;
                destroy) _arguments \
                    '1:thing:(cell component directive function layout page sdl service types)' \
                    '*:name:' ;;
                build) _arguments \
                    '--api[build api]' \
                    '--web[build web]' \
                    '--verbose[verbose]' \
                    '--stats[print stats]' \
                    '--prerender[prerender]' \
                    '--prisma[generate prisma client]' ;;
                dev) _arguments \
                    '--api[run api only]' \
                    '--web[run web only]' \
                    '--apiPort=+[api port]:port:' \
                    '--webPort=+[web port]:port:' \
                    '--apiHost=+[api host]:host:_hosts' \
                    '--webHost=+[web host]:host:_hosts' \
                    '--watchNodeModules[watch node modules]' \
                    '--apiDebugPort=+[api debug port]:port:' \
                    '--debug[debug]' ;;
                deploy) _arguments \
                    '1:provider:(baremetal coherence flightcontrol netlify render serverless vercel)' \
                    '*:arg:' ;;
                setup) _arguments \
                    '1:cmd:(auth cache custom-web-index db-auth deploy generator graphql i18n mailer monitoring package realtime sentry server-file storybook tsconfig ui vite webpack jest)' \
                    '*:arg:' ;;
                prisma) _arguments \
                    '*:arg:' ;;
                test) _arguments \
                    '--api[api tests]' \
                    '--web[web tests]' \
                    '--watch[watch]' \
                    '--collect-coverage[coverage]' \
                    '--watch-all[watch all]' \
                    '--clear-cache[clear cache]' ;;
                exec) _arguments \
                    '1:script:_files -g "*.(ts|js)"' \
                    '*:arg:' ;;
                serve) _arguments \
                    '1:target:(api web both)' \
                    '--api[serve api]' \
                    '--web[serve web]' \
                    '--port=+[port]:port:' \
                    '--host=+[host]:host:_hosts' \
                    '--apiRootPath=+[api root path]:str:' \
                    '--socket=+[socket]:str:' ;;
                upgrade) _arguments \
                    '--dry-run[dry run]' \
                    '-d[dry run]' \
                    '--tag=+[tag]:t:(rc latest canary next experimental)' \
                    '-t+[tag]:t:(rc latest canary next experimental)' \
                    '--pr=+[pull request]:str:' \
                    '--verbose[verbose]' ;;
                experimental) _arguments \
                    '1:cmd:(setup-server-file setup-streaming-ssr setup-realtime setup-trusted-documents setup-rsc)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_redwood-cli "$@"
