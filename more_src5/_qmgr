#compdef qmgr
# Documentation: https://manpages.debian.org/wheezy/torque-client/qmgr.1b.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# qmgr (TORQUE PBS batch system manager). Synopsis:
# qmgr [-a] [-c command] [-e] [-n] [-z] [server...]

local curcontext="$curcontext" ret=1

_arguments -C \
  '-a[abort qmgr on any syntax error or rejected request]' \
  '-c+[execute a single command and exit]:command:' \
  '-e[echo all commands to stdout]' \
  '-n[no commands - syntax check only]' \
  '-z[suppress error output to stderr]' \
  '*:server:_hosts' && ret=0

return ret
