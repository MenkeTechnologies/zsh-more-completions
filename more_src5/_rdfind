#compdef rdfind
# Documentation: https://github.com/pauldreik/rdfind
# Source: pauldreik/rdfind Options.cc — find duplicate files (C++, single-dash long options).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-makesymlinks[replace duplicates with symlinks]:bool:(true false)' \
    '-makehardlinks[replace duplicates with hardlinks]:bool:(true false)' \
    '-makeresultsfile[write a results.txt]:bool:(true false)' \
    '-outputname[results filename]:file:_files' \
    '-ignoreempty[ignore empty files]:bool:(true false)' \
    '-minsize[minimum file size in bytes]:size:_default' \
    '-maxsize[maximum file size in bytes]:size:_default' \
    '-deleteduplicates[delete duplicates]:bool:(true false)' \
    '-followsymlinks[follow symlinks during scanning]:bool:(true false)' \
    '-dryrun[do not modify the filesystem]:bool:(true false)' \
    '-n[short alias for -dryrun true]:bool:(true false)' \
    '-removeidentinode[treat hardlinked files as identical]:bool:(true false)' \
    '-deterministic[deterministic ordering of duplicates]:bool:(true false)' \
    '-firstbytessize[bytes to compare at file start]:size:_default' \
    '-lastbytessize[bytes to compare at file end]:size:_default' \
    '-checksum[checksum algorithm]:algo:(md5 sha1 sha256 sha512 xxh128)' \
    '-buffersize[I/O buffer size in bytes]:size:_default' \
    '-sleep[microseconds to sleep between files]:us:_default' \
    '-progress[show progress information]:bool:(true false)' \
    '(- *)-help[show help]' \
    '(- *)-h[show help]' \
    '(- *)-version[show version]' \
    '(- *)-v[show version]' \
    '*:directory:_files -/' \
    && ret=0

return ret
