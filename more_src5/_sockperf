#compdef sockperf
# Documentation: https://manpages.ubuntu.com/manpages/noble/man1/sockperf.1.html
# Reference accessed: 2026-05-21
# Verified: upstream Ubuntu sockperf(1) manpage.

local curcontext="$curcontext" state line ret=1
local -a modes

modes=(
  'help:show help'
  'under-load:run under-load test'
  'ping-pong:run ping-pong test'
  'playback:replay test'
  'throughput:throughput test'
  'pp:ping-pong (alias)'
  'tp:throughput (alias)'
  'ul:under-load (alias)'
  'pb:playback (alias)'
  'server:run server'
  'sr:server (alias)'
  'version:show version'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--debug[debug output]' \
  '1: :->mode' \
  '*::arg:->args' && ret=0

case $state in
  (mode) _describe -t modes 'sockperf mode' modes && ret=0 ;;
  (args)
    _arguments \
      '(-i --ip)'{-i+,--ip=}'[server IP]:ip:_hosts' \
      '(-p --port)'{-p+,--port=}'[server port]:port:' \
      '(-f --file)'{-f+,--file=}'[hosts file]:file:_files' \
      '(-F --feedfile)'{-F+,--feedfile=}'[feed file]:file:_files' \
      '(-m --msg-size)'{-m+,--msg-size=}'[message size]:n:' \
      '(-r --range)'{-r+,--range=}'[size range]:r:' \
      '(-t --time)'{-t+,--time=}'[run time s]:s:' \
      '(--client_port)--client_port=[client port]:port:' \
      '(--client_ip)--client_ip=[client IP]:ip:' \
      '(--tcp)--tcp[use TCP]' \
      '(--tcp-skip-blocking-send)--tcp-skip-blocking-send[skip blocking]' \
      '(--mc-rx-if)--mc-rx-if=[multicast RX if]:if:_net_interfaces' \
      '(--mc-tx-if)--mc-tx-if=[multicast TX if]:if:_net_interfaces' \
      '(--mc-loopback-disable)--mc-loopback-disable[disable mc loopback]' \
      '(--mc-ttl)--mc-ttl=[multicast TTL]:n:' \
      '(--mc-source-filter)--mc-source-filter=[mc source filter]:s:' \
      '(--uc-reuseaddr)--uc-reuseaddr[unicast reuseaddr]' \
      '(-b --burst)'{-b+,--burst=}'[burst size]:n:' \
      '(--mps)--mps=[messages per sec]:n:' \
      '(--reply-every)--reply-every=[reply every n]:n:' \
      '(--full-rtt)--full-rtt[full RTT]' \
      '(--full-log)--full-log=[full log file]:file:_files' \
      '(-d --debug)'{-d,--debug}'[debug]' \
      '(--threads-num)--threads-num=[threads]:n:' \
      '(--cpu-affinity)--cpu-affinity=[CPU affinity]:c:' \
      '(--vmazcopy)--vmazcopy[vma zero copy]' \
      '(--no-rdtsc)--no-rdtsc[no rdtsc]' \
      '(--load-vma)--load-vma[load VMA]' \
      '(--rate-limit)--rate-limit=[rate limit]:r:' \
      '(--sender-affinity)--sender-affinity=[sender affinity]:c:' \
      '(--receiver-affinity)--receiver-affinity=[receiver affinity]:c:' \
      '(--giga-size)--giga-size[show GB]' \
      '(--increase_output_precision)--increase_output_precision[high precision]' \
      '(--data-integrity)--data-integrity[check data integrity]' \
      '(--ipv4)--ipv4[force IPv4]' \
      '(--ipv6)--ipv6[force IPv6]' \
      '*: :' && ret=0 ;;
esac

return ret
