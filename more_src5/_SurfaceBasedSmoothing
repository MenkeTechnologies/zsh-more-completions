#compdef SurfaceBasedSmoothing
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/SurfaceBasedSmoothing.cxx — geodesic smoothing on a surface defined by label==1 (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:ImageToSmooth:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '2:sigma (geodesic neighbourhood radius, default 1.0):_default' \
    '3:SurfaceImage (label==1 defines surface):_files -g "*.{nii,nii.gz}"' \
    '4:outname:_files' \
    '5::numrepeatsofsmoothing (default 0):_default' \
    && ret=0

return ret
