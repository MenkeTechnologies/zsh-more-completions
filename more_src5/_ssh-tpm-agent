#compdef ssh-tpm-agent ssh-tpm-add ssh-tpm-keygen ssh-tpm-hostkeys
# Documentation: source-direct extraction from upstream
# Foxboron/ssh-tpm-agent cmd/<name>/main.go Go-stdlib flag.*
# declarations decoded source-direct.  Go's stdlib flag package
# uses single-dash long-form (-flag NOT --flag) - all flag
# names in this completion follow that convention.
# Reference accessed: 2026-05-30 via gh api.
# Foxboron ssh-tpm-agent R192 — SSH-via-TPM2 tooling for using
# TPM2-sealed keys as SSH client/server identities.  Sister
# tools to the heavily-covered SSH family (openssh-server,
# sshd, ssh-keygen, ssh-add, ssh-agent, ssh-keyscan, scp,
# rsync-ssh, sshpass) and the TPM2 family (tpm2-tools, p11tool,
# pkcs11-tool, ykman, yubico-piv-tool) already in the corpus.

case $service in

  ssh-tpm-agent)
    # SSH agent that holds TPM2-sealed SSH keys instead of
    # plaintext keys.  Listens on a UNIX socket like ssh-agent.
    _arguments -s -S \
      '-l+[path of the UNIX socket to listen on (default $SSH_AUTH_SOCK)]:socket:_files' \
      '*-A+[fallback ssh-agent sockets (repeatable)]:socket:_files' \
      '-swtpm[use swtpm software emulator instead of actual TPM]' \
      '-print-socket[print path of UNIX socket to stdout]' \
      '-key-dir+[directory to look for keys in]:dir:_files -/' \
      '-install-user-units[install systemd user units]' \
      '-install-system[install systemd system units]' \
      '-no-load[do not load TPM-sealed keys on startup]' \
      '-confirm-loaded[require confirmation for all preloaded keys]' \
      '(-o -owner-password)'{-o,-owner-password}'[ask for the TPM owner password]' \
      '-d[debug mode]' \
      '-no-cache[do not cache key passphrases between uses]' \
      '-hierarchy+[hierarchy for the created key]:hierarchy:(owner endorsement platform null)'
    ;;

  ssh-tpm-add)
    # Add a TPM-sealed key to the running ssh-tpm-agent.
    _arguments -s -S \
      '-ca+[CA authority URL for SSH host CA validation]:url:' \
      '-host+[SSH host (hostname:port)]:host:_hosts' \
      '-user+[remote SSH user]:user:_users' \
      '-c[require confirmation before each use]' \
      '*:TPM-sealed key file:_files -g "*.(tpm|key)"'
    ;;

  ssh-tpm-keygen)
    # Create a TPM-sealed SSH key (analog of ssh-keygen).
    _arguments -s -S \
      '(-o -owner-password)'{-o,-owner-password}'[ask for the TPM owner password]' \
      '-C+[comment (default user@host)]:comment:' \
      '-f+[output keyfile path]:file:_files' \
      '-N+[new passphrase for the key]:pin:' \
      '-t+[key type to create (default ecdsa)]:type:(ecdsa rsa ed25519)' \
      '-b+[number of bits (RSA only)]:bits:(2048 3072 4096)' \
      '(-I -import)'{-I+,-import=}'[import an existing SSH key into the TPM]:file:_files' \
      '-p[change passphrase on existing key]' \
      '-P+[old passphrase (when -p)]:passphrase:' \
      '-swtpm[use swtpm software emulator instead of actual TPM]' \
      '-A[generate host keys for /etc/ssh/ssh_host_*]' \
      '-supported[list TPM-supported algorithms and exit]' \
      '-print-pubkey+[print TPM pubkey for the given key]:keyfile:_files' \
      '-wrap+[wrap key]:key:_files' \
      '-wrap-with+[wrap with key]:key:_files' \
      '-parent-handle+[parent handle for the key (default owner)]:handle:(owner endorsement platform null)' \
      '-hierarchy+[hierarchy for the created key]:hierarchy:(owner endorsement platform null)'
    ;;

  ssh-tpm-hostkeys)
    # Install systemd units + sshd config to make sshd use
    # TPM-sealed host keys.
    _arguments -s -S \
      '-install-system-units[install systemd system units]' \
      '-install-sshd-config[install sshd config snippet for TPM host keys]'
    ;;

esac
