#compdef sento
# Documentation: https://github.com/sentoagent/sento
# Reference accessed: 2026-05-22
# Verified: bin/sento.js commander command definitions.

# Zsh completion for sento - self-improving AI agent CLI (Sentō)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'sento command' \
      'init[initialize a new AI agent]' \
      'status[check if agent is running and healthy]' \
      'config[change model, tokens, keys, and settings]' \
      'channels[manage Discord, Telegram, and Slack channels]' \
      'skills[list, install, export, or import skills]' \
      'logs[view agent output and watchdog history]' \
      'update[update Claude Code, plugins, and patches]' \
      'start[start the agent]' \
      'stop[stop the agent]' \
      'restart[restart the agent]' \
      'doctor[diagnose and fix common issues]' \
      'pair[pair with another Sentō agent]' \
      'agents[list this agent info and paired agents]' && ret=0
    ;;
  args)
    case $line[1] in
      skills)
        _values 'skills action' list install export import && ret=0
        ;;
      logs)
        _arguments \
          '-n[number of lines to show]:count:' \
          '--lines[number of lines to show]:count:' \
          '-w[show watchdog restart log]' \
          '--watchdog[show watchdog restart log]' && ret=0
        ;;
      update)
        _arguments '--skip-self-update[skip CLI self-update during run]' && ret=0
        ;;
      doctor)
        _arguments '-f[auto-fix issues where possible]' '--fix[auto-fix issues where possible]' && ret=0
        ;;
      pair)
        _arguments \
          '--host[other agent host]:host:' \
          '--port[other agent comms port]:port:' \
          '--my-host[your host address for pairing]:host:' && ret=0
        ;;
    esac
    ;;
esac

return ret
