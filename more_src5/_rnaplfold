#compdef rnaplfold
# Documentation: https://www.tbi.univie.ac.at/RNA/RNAplfold.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# ViennaRNA RNAplfold: local folding for long RNA, gives bpp probabilities
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-W --winsize)'{-W,--winsize=}'[averaging window length]:size:' \
  '(-L --span)'{-L,--span=}'[max base-pair span]:span:' \
  '(-c --cutoff)'{-c,--cutoff=}'[bpp threshold for output]:val:' \
  '(-u --ulength)'{-u,--ulength=}'[unpaired probabilities up to length]:n:' \
  '(-T --temp)'{-T,--temp=}'[temperature in C]:temp:' \
  '(-d --dangles)'{-d,--dangles=}'[dangling end model]:d:(0 1 2 3)' \
  '--noLP[no lonely pairs]' \
  '--noGU[no GU pairs]' \
  '--noClosingGU[no GU at helix ends]' \
  '(-P --paramFile)'{-P,--paramFile=}'[parameter file]:file:_files' \
  '(-4 --noTetra)'{-4,--noTetra}'[skip special hairpin energies]' \
  '--salt=[salt concentration in molar]:val:' \
  '(-o --print_onthefly)'{-o,--print_onthefly}'[save memory; print during computation]' \
  '(-O --opening_energies)'{-O,--opening_energies}'[output logarithms not probabilities]' \
  '(-b --binaries)'{-b,--binaries}'[binary output format]' \
  '--plex_output[create additional RNAplex output files]' \
  '--betaScale=[scale Boltzmann factors]:val:' \
  '(-S --pfScale)'{-S,--pfScale=}'[pf scaling factor]:factor:' \
  '--noconv[do not convert T to U]' \
  '--shape=[SHAPE reactivity data]:file:_files' \
  '--shapeMethod=[SHAPE conversion strategy]:method:' \
  '--commands=[command/constraints file]:file:_files' \
  '--auto-id[auto-generate sequence IDs]' \
  '*:RNA sequence file:_files -g "*.(fa|fasta|seq)"' && ret=0
return ret
