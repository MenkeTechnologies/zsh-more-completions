#compdef rabbitmq_exporter
# _rabbitmq_exporter — Prometheus exporter for RabbitMQ (kbudde/rabbitmq_exporter)
# upstream: https://github.com/kbudde/rabbitmq_exporter
# Flags from main.go (flag).

_rabbitmq_exporter() {
    _arguments \
        '(- *)-h[show help]' \
        '-check-url=[curl URL and return exit code]:url:' \
        '-config-file=[JSON config path]:file:_files -g "*.(json|conf)"'
}

_rabbitmq_exporter "$@"
