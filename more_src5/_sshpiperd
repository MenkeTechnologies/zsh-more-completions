#compdef sshpiperd
# Documentation: https://github.com/tg123/sshpiper
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
#
# Only flags explicitly documented in the upstream README are included.
# sshpiperd has many plugin-specific flags loaded at runtime that are not enumerated upstream.

_arguments -s \
  '(-i --server-key)'{-i,--server-key}'=[server identity key file]:file:_files' \
  '--server-key-generate-mode=[server key generate mode]:mode:(disable notexist always)' \
  '--log-level=[log level]:level:(trace debug info warn error fatal panic)' \
  '--screen-recording-dir=[session recording directory]:dir:_files -/' \
  '--screen-recording-format=[recording format]:format:(typescript asciicast)' \
  '--admin-grpc-port=[admin gRPC port]:port:' \
  '--admin-grpc-insecure[disable TLS for admin gRPC]' \
  '--admin-grpc-tls-cert=[admin gRPC TLS cert]:file:_files' \
  '--admin-grpc-tls-key=[admin gRPC TLS key]:file:_files' \
  '--admin-grpc-tls-cacert=[admin gRPC TLS CA]:file:_files' \
  '(- *)'{-h,--help}'[show help]' \
  '*::plugin: '
