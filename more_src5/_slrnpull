#compdef slrnpull
# Documentation: https://www.jedsoft.org/slrn/doc/slrnpull.html
# Reference accessed: 2026-05-21
# Verified: upstream slrnpull(1) man page.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[print version number]' \
  '-h+[NNTP host (host[:port])]:host:_hosts' \
  '-d+[spool directory]:dir:_files -/' \
  '--debug+[write server dialog/debug output to file]:file:_files' \
  '--logfile+[direct log messages to file]:file:_files' \
  '--kill-log+[log articles killed by scorefile]:file:_files' \
  '--kill-score+[kill articles with score below n]:n' \
  '--fetch-score+[retrieve article bodies meeting score threshold]:n' \
  '--marked-bodies[only fetch bodies marked for download in slrn]' \
  '--no-post[do not post any articles to the server]' \
  '--post[obsolete; same as --post-only]' \
  '--post-only[post outgoing articles, do not fetch news]' \
  '--rebuild[expire old messages and rebuild overview]' \
  '--expire[expire old messages, do not fetch news]' \
  '--new-groups[check for newly available groups]' \
  '*: :_files' && ret=0

return ret
