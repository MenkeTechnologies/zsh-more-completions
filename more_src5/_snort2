#compdef snort2
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man8/snort.8.html
# Reference accessed: 2026-05-21
# Verified: Ubuntu jammy snort(8) manpage. Adds previously missing
# -B/-C/-E/-H/-I/-m/-n/-O/-R/-s/-U/-W/-x/-?, long flags --logid,
# --perfmon-file, --pid-path, --snaplen, --dynamic-*-lib, --alert-before-pass,
# --treat-drop-as-alert, --treat-drop-as-ignore, --process-all-events,
# --enable-inline-test, --create-pidfile, --nolock-pidfile,
# --no-interface-pidfile, --pcap-*, --exit-check, --conf-error-out, --daq*,
# --cs-dir, --ha-peer, --ha-out, --ha-in.

# Snort 2: legacy IDS engine
local curcontext="$curcontext" ret=1
_arguments -C \
  '-A[alert mode]:mode:(fast full none unsock console cmg)' \
  '-b[log packets in tcpdump format]' \
  '-B[anonymize IPs using subnet mask]:mask:' \
  '-c[rules file]:file:_files -g "*.(conf|rules)"' \
  '-C[print packet payload in ASCII only]' \
  '-d[dump app layer]' \
  '-D[run as daemon]' \
  '-e[show 2nd layer headers]' \
  '-E[enable Windows Event Log alerts]' \
  '-f[turn off PCAP packet buffering]' \
  '-F[BPF filter from file]:file:_files' \
  '-G[generator ID for log]:n:' \
  '-g[run as group]:group:_groups' \
  '-h[home network]:cidr:' \
  '-H[use deterministic hashing for tables]' \
  '-i[interface]:iface:' \
  '-I[include interface name in alerts]' \
  '-k[checksum mode]:mode:(all noip notcp noudp noicmp none)' \
  '-K[log format]:fmt:(pcap ascii none)' \
  '-l[log dir]:dir:_files -/' \
  '-L[binary log filename]:name:' \
  '-m[umask]:mask:' \
  '-n[stop after n packets]:n:' \
  '-N[disable packet logging]' \
  '-O[obfuscate IPs in logs]' \
  '-p[disable promiscuous mode]' \
  '-P[snaplen]:n:' \
  '-q[quiet mode]' \
  '-Q[enable inline mode]' \
  '-r[read pcap]:file:_files -g "*.(pcap|cap|pcapng)"' \
  '-R[pidfile suffix]:suffix:' \
  '-s[send alerts to syslog]' \
  '-S[set variable]:var=value:' \
  '-t[chroot dir]:dir:_files -/' \
  '-T[test config and exit]' \
  '-u[run as user]:user:_users' \
  '-U[use UTC timestamps]' \
  '-v[verbose]' \
  '-V[show version]' \
  '-w[show wireless mgmt frames]' \
  '-W[enumerate interfaces]' \
  '-x[exit on config error]' \
  '-X[dump raw packet starting at link layer]' \
  '-y[show year in timestamps]' \
  '-Z[perfmonitor stats file]:file:_files' \
  '-?[help]' \
  '--logid=[hex log id]:n:' \
  '--perfmon-file=[perfmonitor stats file]:file:_files' \
  '--pid-path=[pid path]:dir:_files -/' \
  '--snaplen=[snap length]:n:' \
  '--help[show help]' \
  '--version[show version]' \
  '--dynamic-engine-lib=[dynamic engine library]:file:_files' \
  '--dynamic-detection-lib=[dynamic detection library]:file:_files' \
  '--dynamic-preprocessor-lib=[dynamic preprocessor library]:file:_files' \
  '--dynamic-output-lib=[dynamic output library]:file:_files' \
  '--alert-before-pass[evaluate alert rules before pass]' \
  '--treat-drop-as-alert[treat drop rules as alert]' \
  '--treat-drop-as-ignore[treat drop rules as ignore]' \
  '--process-all-events[process all triggered events]' \
  '--enable-inline-test[enable inline test mode]' \
  '--create-pidfile[create pidfile even when not in daemon mode]' \
  '--nolock-pidfile[do not lock pidfile]' \
  '--no-interface-pidfile[do not include interface in pidfile name]' \
  '--pcap-single=[read single pcap file]:file:_files' \
  '--pcap-filter=[pcap filter]:filter:' \
  '--pcap-list=[pcap file list]:list:' \
  '--pcap-dir=[pcap directory]:dir:_files -/' \
  '--pcap-file=[file containing pcap list]:file:_files' \
  '--pcap-no-filter[reset pcap filter]' \
  '--pcap-reset[reset state between pcaps]' \
  '--pcap-reload[reload config between pcaps]' \
  '--pcap-show[show pcap names]' \
  '--exit-check=[exit after n packets]:n:' \
  '--conf-error-out[exit on config error]' \
  '--daq=[DAQ module]:module:' \
  '--daq-mode=[DAQ mode]:mode:(passive inline read-file)' \
  '--daq-var=[DAQ variable]:var=value:' \
  '--daq-dir=[DAQ module directory]:dir:_files -/' \
  '--daq-list[list DAQ modules]' \
  '--cs-dir=[control socket directory]:dir:_files -/' \
  '--ha-peer[enable HA peer]' \
  '--ha-out=[HA output file]:file:_files' \
  '--ha-in=[HA input file]:file:_files' \
  '*::snort2 args:_files' && ret=0
return ret
