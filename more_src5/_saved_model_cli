#compdef saved_model_cli
# Documentation: https://www.tensorflow.org/guide/saved_model
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above and the source file
# https://github.com/tensorflow/tensorflow/blob/master/tensorflow/python/tools/saved_model_cli.py

# saved_model_cli: inspect / run / scan / convert / aot_compile_cpu / freeze_model
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'show:show metadata for SavedModel'
  'run:run a graph with given inputs'
  'scan:scan SavedModel for compatibility issues'
  'convert:convert a SavedModel'
  'aot_compile_cpu:AOT compile SavedModel for CPU'
  'freeze_model:freeze SavedModel into a constant graph'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--dir=[SavedModel directory]:dir:_files -/' \
  '--tag_set=[tag set]:tags:' \
  '--signature_def=[signature def key]:key:' \
  '--all[show all info]' \
  '--list_ops[output ops used by a MetaGraphDef]' \
  '--input_exprs=[input expressions]:expr:' \
  '--inputs=[inputs (key=file)]:inputs:' \
  '--input_examples=[example inputs]:examples:' \
  '--outdir=[output directory for .npy files]:dir:_files -/' \
  '--overwrite[overwrite existing files]' \
  '--tf_debug[run with tf-debugger]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'saved_model_cli command' commands && ret=0 ;;
esac
return ret
