#compdef qv4l2
# _qv4l2 — Linux v4l-utils qv4l2 CLI for the Qt-based Video4Linux2 test bench control utility configuring camera settings format frame-rate brightness contrast preview overlay debug control panels (linuxtv team, C++/Qt); Qt argparse
# upstream: https://git.linuxtv.org/v4l-utils.git

_qv4l2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-d+[device]:file:_files -g "/dev/video*"' \
        '--device=+[device]:file:_files -g "/dev/video*"' \
        '-V+[vbi device]:file:_files -g "/dev/vbi*"' \
        '--vbi-device=+[vbi device]:file:_files -g "/dev/vbi*"' \
        '-S+[sdr device]:file:_files -g "/dev/swradio*"' \
        '--sdr-device=+[sdr device]:file:_files -g "/dev/swradio*"' \
        '-r+[radio device]:file:_files -g "/dev/radio*"' \
        '--radio-device=+[radio device]:file:_files -g "/dev/radio*"' \
        '-D+[subdev device]:file:_files -g "/dev/v4l-subdev*"' \
        '--subdev=+[subdev device]:file:_files -g "/dev/v4l-subdev*"' \
        '-T+[touch device]:file:_files -g "/dev/v4l-touch*"' \
        '--touch=+[touch device]:file:_files -g "/dev/v4l-touch*"' \
        '-R[raw mode]' \
        '--raw[raw mode]' \
        '-h+[hardware acceleration]:m:(opengl glcompositor render)' \
        '--render-method=+[mode]:m:(opengl glcompositor render)' \
        '--no-color-bar[no color bar]' \
        '--single-buffer[single buffer]' \
        '--win-pos=+[x,y]:str:' \
        '--win-size=+[w,h]:str:' \
        '--fullscreen[fullscreen]'
}

_qv4l2 "$@"
