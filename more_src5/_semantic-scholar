#compdef semantic-scholar semanticscholar s2
# _semantic-scholar — Allen Institute for AI Semantic Scholar CLI client to the Semantic Scholar REST API searching papers authors venues TLDRs by query DOI ARXIVid CORPUSid PMID PubMed-Central ACL-id MAG-id citing referenced batch ID lookup ML-driven recommendation S2-graph paper-id (Allen AI team, Python); custom argparse
# upstream: https://www.semanticscholar.org/

_semantic-scholar() {
    local -a sub=(
        'search:search papers'
        'paper:fetch single paper by ID'
        'author:fetch single author by ID'
        'recommendations:get recommendations'
        'citations:list citing papers'
        'references:list referenced papers'
        'authors:search authors'
        'graph:explore citation graph'
        'snippet:fetch ML-driven TLDR'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--limit=+[N]:n:' \
        '--offset=+[N]:n:' \
        '--fields=+[fields]:str:' \
        '--year=+[year]:str:' \
        '--venue=+[venue]:str:' \
        '--openAccessPdf=+[bool]:s:(true false)' \
        '--minCitationCount=+[N]:n:' \
        '--publicationType=+[t]:t:(Review JournalArticle CaseReport ClinicalTrial Conference Dataset Editorial LettersAndComments MetaAnalysis News Study Book BookSection)' \
        '--publicationDate=+[range]:str:' \
        '-f+[format]:f:(json bibtex ris csv yaml table)' \
        '--format=+[format]:f:(json bibtex ris csv yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'semantic-scholar subcommand' sub ;;
        args)
            case $words[1] in
                search|authors) _arguments '*:query:' ;;
                paper|author|citations|references|recommendations|snippet|graph) _arguments '*:id:' ;;
            esac
            ;;
    esac
}

_semantic-scholar "$@"
