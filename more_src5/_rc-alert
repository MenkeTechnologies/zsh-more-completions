#compdef rc-alert
# Documentation: https://manpages.debian.org/rc-alert
# Source: debian/devscripts scripts/rc-alert.pl — list installed packages with RC bugs (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '--cache[force download of bug list cache]' \
    '(-f --include-tags)'{-f+,--include-tags=}'[include tags (P+HMRSUI)]:tags:_default' \
    '--exclude-tags=-[exclude tags]:tags:_default' \
    '(-t --include-tag-op)'{-t+,--include-tag-op=}'[include tag op]:op:(or and)' \
    '--exclude-tag-op=-[exclude tag op]:op:(or and)' \
    '(-d --include-dists)'{-d+,--include-dists=}'[include distributions (OSTUE)]:dists:_default' \
    '--exclude-dists=-[exclude distributions]:dists:_default' \
    '(-o --include-dist-op)'{-o+,--include-dist-op=}'[include dist op]:op:(or and)' \
    '--exclude-dist-op=-[exclude dist op]:op:(or and)' \
    '--debtags=-[debtags filter]:tags:_default' \
    '--debtags-database=-[debtags db]:file:_files' \
    '--popcon[order by popcon]' \
    '--pc-vote[popcon by vote (with --popcon)]' \
    '--pc-local[popcon by local install]' \
    '*:package:_default' \
    && ret=0

return ret
