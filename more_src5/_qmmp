#compdef qmmp
# _qmmp — Qmmp Qt-based Multimedia Player (C++); Winamp-style audio player with broad codec support
# upstream: https://qmmp.ylsoftware.com

_qmmp() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--quit[exit running instance]' \
        '--toggle-play-pause[toggle play/pause]' \
        '--play[play]' \
        '--pause[pause]' \
        '--stop[stop]' \
        '--next[next track]' \
        '--previous[previous track]' \
        '--volume-up[volume up]' \
        '--volume-down[volume down]' \
        '--volume+[set volume]:n:' \
        '--toggle-mute[toggle mute]' \
        '--jump-to-track[show jump dialog]' \
        '--add-file+[add file]:file:_files' \
        '--add+[add files]:files:_files' \
        '--enqueue+[enqueue files]:files:_files' \
        '--show-mw[show main window]' \
        '--hide-mw[hide main window]' \
        '--show-pl[show playlist]' \
        '--show-eq[show equalizer]' \
        '--multiple-instances[allow multiple instances]' \
        '*:audio file:_files'
}

_qmmp "$@"
