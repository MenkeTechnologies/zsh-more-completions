#compdef snobol4
# =============================================================================
# snobol4 — "SNOBOL4 interpreter" — Phil Budne's CSNOBOL4
#           port of the Bell Telephone Labs Macro Implementation
#           of SNOBOL4 (StriNg Oriented and symBOlic Language,
#           version 4) to portable C.  SNOBOL4 is the foundational
#           string-pattern-matching language designed by Ralph
#           Griswold, Ivan Polonsky, and David Farber at Bell
#           Labs (1962-1972), the conceptual ancestor of regex,
#           AWK, Icon, and Perl's text-processing features.
#           Distinguishing from awk, sed, perl, Python regex,
#           and other string-processing tools by:
#             - PATTERN MATCHING AS FIRST-CLASS DATA — patterns
#               are constructable, composable, named, stored in
#               variables, passed to functions:
#                 IDENT = ANY(&UCASE) (ANY(&UCASE &LCASE &DIGITS) | NULL)
#                 KEYWORD = "if" | "then" | "else" | "while"
#                 STMT = (KEYWORD | IDENT) " " *(REM &END)
#                 ;match against subject string:
#                 STRING ? STMT
#             - PRIMITIVE PATTERN OPERATORS — ANY (char set),
#               NOTANY (negation), SPAN (greedy span), BREAK
#               (search for terminator), LEN (fixed length),
#               TAB (move to column), RTAB (move from end), POS
#               (anchor), RPOS (anchor from end), REM (rest of
#               line), ARB (arbitrary length), ARBNO (zero or
#               more), BAL (balanced parens)
#             - VALUE / IMMEDIATE ASSIGNMENT in patterns —
#               PATTERN . VAR (assignment after match success)
#               PATTERN $ VAR (immediate assignment during match)
#               permit pattern matching to ALSO capture
#               substrings into variables
#             - SUCCESS / FAILURE control flow — no boolean
#               type; expressions either SUCCEED with a value
#               or FAIL.  Conditional statements use success/
#               failure as the predicate:
#                 STR PATTERN :S(WIN) F(LOSE)
#                 ; if PATTERN matches STR, goto WIN; else LOSE
#             - GOTO-CENTRIC CONTROL FLOW — no structured
#               control statements (no if/while/for); flow uses
#               labels + conditional gotos:
#                   :S(LABEL)   ; goto LABEL on success
#                   :F(LABEL)   ; goto LABEL on failure
#                   :(LABEL)    ; unconditional goto
#                   :S(WIN)F(LOSE)  ; combined
#             - INDIRECT REFERENCE via $ OPERATOR — `$VAR`
#               retrieves the variable whose name is the value
#               of VAR (one level of indirection):
#                 NAME = "FOO"
#                 $NAME = 42   ;sets variable FOO to 42
#                 OUTPUT = $NAME  ;outputs 42
#             - TABLE + ARRAY + USER-DEFINED DATATYPES — tables
#               (associative arrays with arbitrary keys), arrays
#               (multi-dimensional), DATA() function to define
#               record types with field-access syntax:
#                 DATA('node(value, left, right)')
#                 NODE = node(10, , )
#                 NODE = value(NODE)   ;access field
#             - DYNAMIC STORAGE WITH GARBAGE COLLECTION — strings
#               + patterns + arrays + tables managed by a stop-
#               the-world mark-sweep GC; --dynamic region
#               configurable via -d flag
#             - ASCII-ORIENTED but 8-BIT-CLEAN — handles any
#               byte; UTF-8 sequences treatable as
#               "alphabetic" via utf.sno include file
#             - SPITBOL / SITBOL / SNOBOL4B EXTENSIONS —
#               compile-time enabled extensions from later
#               SNOBOL4 dialects (Catspaw SPITBOL by Mark
#               Emmer, ITS SITBOL, SNOBOL4B BLOCKS extension)
#             - HOST() FUNCTION — access to OS environment,
#               command-line parameters (-u param), shell
#               commands, file system
#             - 12+ CSNOBOL4 EXTENSIONS — FFI to C libraries
#               (libffi), SQLite3, Tcl, ndbm/GDBM, additional
#               I/O channels, OS interface
#             - 50+ COMPILE-TIME OPTIONS via configure script
#             - SCRIPT-INTERPRETER COMPATIBLE — `#!/usr/bin/env
#               snobol4` shebang lines work because # is a
#               comment character in SNOBOL4
#           Used by: computational linguistics + text processing
#           historians + language-design research; SNOBOL4 is
#           the canonical reference for pattern-matching
#           language design.  Phil Budne's CSNOBOL4 is the
#           actively-maintained modern implementation (separate
#           from the SPITBOL family which targets IBM 360
#           mainframes).
#
# Author:  Phil Budne (philbudne on GitHub) — Boston-based
#          retired Bell Labs/Cisco engineer; maintained CSNOBOL4
#          since the 1990s.  Original SNOBOL4 by Ralph Griswold
#          (1934-2006) + Ivan Polonsky + David Farber at Bell
#          Telephone Labs (1962-1972).  License: Public Domain
#          (SNOBOL4) + custom permissive (CSNOBOL4).
# Source:  https://github.com/philbudne/csnobol4
#          https://github.com/philbudne/csnobol4/blob/master/doc/snobol4.1.pea
#          https://github.com/philbudne/csnobol4/blob/master/doc/snobol4cmd.1.pea
#          http://www.snobol4.org/csnobol4/ (Phil Budne's site)
# Manpage: snobol4(1), snobol4cmd(1)
# Language: SNOBOL4 (https://www.snobol4.org/, Wikipedia: SNOBOL).
#           Distinct from Icon (R652, Griswold's successor),
#           awk, sed, perl, Python, and other string-processing
#           languages by being:
#              1. PATTERNS AS FIRST-CLASS VALUES — constructable,
#                 composable, named, stored in variables
#              2. SUCCESS/FAILURE CONTROL — no boolean; flow
#                 uses success/failure
#              3. GOTO-CENTRIC — no if/while/for; conditional
#                 gotos on success/failure
#              4. INDIRECT REFERENCE via $ — runtime name
#                 resolution
#              5. UNTYPED DATA — values dynamically typed
#                 (string / integer / real / pattern / array /
#                 table / code)
#              6. NO STRUCTURED CONTROL — historically novel;
#                 inspired Icon's goal-directed evaluation +
#                 string scanning
#              7. PUBLIC-DOMAIN since 1996 — distributed freely
#                 since the U Arizona Icon Project ended
#              8. INFLUENCED REGEX — Larry Wall acknowledged
#                 SNOBOL4 patterns as one of Perl's regex
#                 inspirations
#              9. FOUNDATION OF AWK + PYTHON STRING PROCESSING
#                 — many text-processing primitives trace back
#                 to SNOBOL4
#             10. ARBITRARY-PRECISION INTEGERS via bignum
#                 extension
# License: Public Domain (SNOBOL4 spec); custom permissive (CSNOBOL4 source).
# Status:  CSNOBOL4 — 2+ stars on philbudne/csnobol4, active
#          maintenance through 2026; the canonical modern
#          SNOBOL4 implementation.  SPITBOL family (spitbol/
#          360) maintained separately by David Shields and
#          others.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — 97TH LANGUAGE: SNOBOL4
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy expands its
# **97TH PROGRAMMING LANGUAGE**: SNOBOL4.  This expands the taxonomy from
# 96 to 97 documented programming languages.  Pattern: R657 Rust=72
# (tokio-tungstenite → Axis 18 OPENS) → R658 Go=72 (gorilla/websocket)
# → R659 TS-Node=72 (ws → Axis 18 1/1/1) → R660 97TH LANGUAGE (SNOBOL4
# via snobol4 THIS).  This completes the 3-leader-bump + 1-new-language
# micro-cycle.
#
# WHY SNOBOL4 IS A DISTINCTIVE 97TH LANGUAGE:
#
#   1. PATTERN MATCHING AS FIRST-CLASS DATA — SNOBOL4 was the
#      FIRST programming language to treat patterns as first-
#      class constructable + composable values:
#         IDENT = ANY(&UCASE) (ANY(&UCASE &LCASE &DIGITS) | NULL)
#         ; IDENT is a PATTERN VALUE assigned to a variable
#         ; can be combined with other patterns: STMT = IDENT " = " REM
#      Distinct from regex (sub-pattern only, not data),
#      Icon (string scanning operations, not data), and
#      every modern regex-only string-processing tool.
#
#   2. SUCCESS / FAILURE INSTEAD OF BOOLEAN — SNOBOL4
#      pioneered the success/failure control concept later
#      adopted by Icon (R652) and refined into goal-directed
#      evaluation.  There is no `true` / `false` value:
#         STR PATTERN :S(WIN) F(LOSE)
#         ; if STR matches PATTERN, goto WIN; else LOSE
#      Influenced Icon, miniKanren, and other backtracking
#      languages.
#
#   3. GOTO-CENTRIC CONTROL FLOW — radical 1962-era design
#      choice: no if/while/for; flow uses labels + conditional
#      gotos:
#           :S(LABEL)    ; goto LABEL on success
#           :F(LABEL)    ; goto LABEL on failure
#           :(LABEL)     ; unconditional goto
#           :S(WIN) F(LOSE)  ; combined
#      Distinct from every structured-control language.
#      Considered an artifact of pre-Dijkstra "Go To Statement
#      Considered Harmful" (1968) era programming.
#
#   4. INDIRECT REFERENCE via $ OPERATOR — `$VAR` evaluates VAR
#      and uses the result as a variable name (one level of
#      indirection).  Enables runtime metaprogramming:
#         FOREACH = "A B C"
#         FOREACH " " . NEXT
#         $NEXT = 0  ;sets the variable named by NEXT to 0
#      Distinct from C/Python where `eval()` is required
#      for runtime name binding.
#
#   5. PUBLIC DOMAIN SINCE 1996 — SNOBOL4's reference
#      implementation has been in the public domain since
#      Bell Labs released it.  CSNOBOL4 inherits this status.
#      Distinct from MIT / BSD / GPL licenses by being NO
#      license at all (true public domain).
#
#   6. INFLUENCED REGEX — Larry Wall, designer of Perl,
#      cited SNOBOL4 as one of Perl's regex inspirations.
#      Many regex primitives (alternation, capture groups,
#      lookaheads) trace conceptually to SNOBOL4 pattern
#      operators.
#
#   7. CONCEPTUAL ANCESTOR OF Icon — Ralph Griswold's NEXT
#      language was Icon (1977), which refined SNOBOL4's
#      pattern matching into goal-directed evaluation + string
#      scanning.  Icon is in our taxonomy (R652).  SNOBOL4 →
#      Icon → Unicon lineage; all by the same Griswold team.
#
#   8. PRIMITIVE PATTERN OPERATORS — ANY / NOTANY / SPAN /
#      BREAK / LEN / TAB / RTAB / POS / RPOS / REM / ARB /
#      ARBNO / BAL.  Each addresses a distinct text-processing
#      need.  ARB (arbitrary match) + ARBNO (zero or more)
#      provide backtracking matching.
#
#   9. INDIRECT-GOTO COMPILATION — SNOBOL4 programs compile to
#      a unique format where each statement ends with a
#      "goto field" specifying conditional successor labels.
#      The interpreter's main loop executes statements +
#      branches on success/failure.
#
#  10. CSNOBOL4 EXTENSIONS — Phil Budne's port adds 12+
#      extensions while preserving original SNOBOL4 semantics:
#      libffi (C library FFI), libsqlite3 (SQLite database),
#      libtcl (Tcl integration), ndbm/GDBM (key-value store),
#      additional I/O channels, OS interface.
#
# Cross-language CLI library taxonomy after R660:
#   * 97 languages documented (SNOBOL4 is the 97th)
#   * 395 total CLI library variants
#   * Rust=72 / Go=72 / TS-Node=72 (three-way tie at leaderboard top)
#   * Axis 9 / Logging: 6/6/6 three-language symmetric
#   * Axes 10 + 13 + 14: 2/2/2 three-language symmetric
#   * Axes 7 + 11 + 12 + 15 + 16 + 17 + 18: 1/1/1 three-language symmetric
#   * Ten axes at three-language symmetry
#
# Griswold lineage in taxonomy:
#   * SNOBOL4 (R660 THIS)  — Bell Labs 1962, the foundation
#   * Icon    (R652)        — U Arizona 1977, successor
#   * Unicon  (in blacklist) — Jeffery+Wampler 1996, Icon + OOP
#
# Languages documented prior to R660 (selected):
#   * R605 ATS2 (patsopt) — 84th
#   * R612 Logtalk (logtalk_backend_select) — 85th
#   * R616 M/MUMPS (ydbinstall.sh) — 86th
#   * R620 REXX (regina) — 87th
#   * R624 Austral (austral) — 88th
#   * R628 Onyx (onyx) — 89th
#   * R632 TXR (txr) — 90th
#   * R636 Ioke (ioke) — 91st
#   * R640 Falcon (falcon) — 92nd
#   * R644 Slang (slangc) — 93rd
#   * R648 Clarity (clarity-cli) — 94th
#   * R652 Icon (icont) — 95th
#   * R656 Limbo (limbo) — 96th
#   * R660 SNOBOL4 (snobol4 THIS) — 97th
#
# -----------------------------------------------------------------------------
#
# THE snobol4 CLI — manpage-sourced flags
#
# snobol4 accepts the following flags (sourced verbatim from
# the snobol4cmd(1) manpage in philbudne/csnobol4/doc/
# snobol4cmd.1.pea):
#
#   -b                   Disable startup banner + termination output
#                        (only displayed when no source files given)
#   -d NDESC             Allocate dynamic storage region (descriptors).
#                        Suffix k = ×1024, suffix m = ×1048576.
#   -f                   Toggle case folding of identifiers
#   -g                   Enable garbage collection tracing (&GTRACE=-1)
#   -h                   Show help including default sizes
#   -k                   Toggle running programs with compilation errors
#   -l LISTINGFILE       Enable listing output to file (default side LEFT)
#   -n                   Toggle running programs after compilation
#   -p                   Toggle SPITBOL extensions (-PLUSOPS control)
#   -r                   Toggle reading INPUT from cmdline after END
#   -s                   Toggle termination statistics (off by default)
#   -u PARAM             Specify parameter string for HOST(0)
#   -v                   Show version and exit
#   -x                   Force banner + termination output
#   -z                   Show directory search path and exit
#   -B                   Toggle SNOBOL4B operators (-[NO]BLOCKS)
#   -I DIRECTORY         Add DIR to search path before defaults (multiple)
#   -L FILE              Preload SNOBOL4 source file (multiple)
#   -M                   Treat remaining items as filenames
#   -N                   Disable standard search path (no STDINCLUDE)
#   -P NDESC             Pattern match stack size (descriptors)
#                        Suffix k/m as for -d.
#   -S NDESC             Interpreter stack size (descriptors)
#                        Suffix k/m as for -d.
#   -U                   Disable stdio buffering
#   --                   End option processing
#
# Environment:
#   SNOBOL4UNBUFFERED    Same as -U if non-empty
#   SNOPATH              Colon-separated additional search dirs
#                        (semicolon on VMS/Windows)
#   SNOLIB               Base directory for compiled-in stdlib search
#
# File extensions:
#   .sno                 SNOBOL4 source file
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/philbudne/csnobol4/blob/master/doc/snobol4cmd.1.pea
# manpage option entries.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '-b[disable startup banner + termination output]' \
    '-d+[dynamic storage region descriptors (k/m suffixes)]:ndesc:_default' \
    '-f[toggle case folding of identifiers]' \
    '-g[enable garbage collection tracing]' \
    '-h[show help including default sizes]' \
    '-k[toggle running programs with compilation errors]' \
    '-l+[enable listing output to file]:listing file:_files' \
    '-n[toggle running programs after compilation]' \
    '-p[toggle SPITBOL extensions]' \
    '-r[toggle reading INPUT from cmdline after END]' \
    '-s[toggle termination statistics]' \
    '-u+[parameter string for HOST(0)]:param:_default' \
    '-v[show version and exit]' \
    '-x[force banner and termination output]' \
    '-z[show directory search path and exit]' \
    '-B[toggle SNOBOL4B operators]' \
    '*-I+[add directory to search path before defaults]:directory:_files -/' \
    '*-L+[preload SNOBOL4 source file]:file:_files -g "*.sno"' \
    '-M[treat remaining items as filenames]' \
    '-N[disable standard search path]' \
    '-P+[pattern match stack descriptors (k/m suffixes)]:ndesc:_default' \
    '-S+[interpreter stack descriptors (k/m suffixes)]:ndesc:_default' \
    '-U[disable stdio buffering]' \
    '--[end option processing]' \
    '*:source file:_files -g "*.sno"' \
    && ret=0

return ret
