#compdef scdoc
# Documentation: https://git.sr.ht/~sircmpwn/scdoc
# Reference accessed: 2026-05-21
# Verified: scdoc reads markup on stdin, writes troff on stdout; per
# upstream README/man, it takes no flags besides standard help/version
# behavior printed by the binary. No documented option set published.
# STUB: minimal CLI.

local curcontext="$curcontext" ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-v,--version}'[show version]' && ret=0
return ret
