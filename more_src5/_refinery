#compdef refinery
# _refinery — SQL migration toolkit for Rust (rust-db/refinery)
# upstream: https://github.com/rust-db/refinery
# Subcommands + flags from refinery_cli/src/cli.rs (clap derive).

_refinery() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_refinery_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                migrate)
                    _arguments \
                        '-c+[config file (default ./refinery.toml)]:file:_files -g "*.toml"' \
                        '-p+[migrations directory (default ./migrations)]:dir:_files -/' \
                        '-e+[load database URL from this environment variable]:env var:' \
                        '-g[run migrations grouped in a single transaction]' \
                        '-f[do not run migrations; only update the schema history table]' \
                        '-t+[migrate to the specified target version]:version:' \
                        '--table-name=[name of the schema history table (default refinery_schema_history)]:table:' \
                        '-d[abort if divergent migrations are found]' \
                        '-m[abort if missing migrations are found]' && ret=0 ;;
                setup) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_refinery_commands] )) ||
_refinery_commands() {
    local -a commands
    commands=(
        'setup:run refinery setup hooks to generate the config file'
        'migrate:run pending SQL migrations against the configured database'
    )
    _describe -t commands 'refinery command' commands
}

_refinery "$@"
