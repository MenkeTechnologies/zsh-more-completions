#compdef samtools
# Documentation: https://www.htslib.org/doc/samtools.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
#autoload

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1: :->cmds' \
  '2:: :->args' && ret=0

case $state in
  cmds)
    _values "samtools command" \
        "view[SAM<->BAM<->CRAM conversion]" \
        "sort[sort alignment file]" \
        "mpileup[multi-way pileup]" \
        "depth[compute read depth at each position]" \
        "faidx[index/extract FASTA]" \
        "tview[text alignment viewer]" \
        "index[index alignment]" \
        "idxstats[BAM index stats]" \
        "fixmate[fix mate information]" \
        "flagstat[simple stats]" \
        "calmd[recalculate MD/NM tags and '=' bases]" \
        "merge[merge sorted alignments]" \
        "markdup[mark duplicate alignments]" \
        "rmdup[(obsolete) remove PCR duplicates; use markdup]" \
        "reheader[replace BAM header]" \
        "cat[concatenate BAMs]" \
        "bedcov[read depth per BED region]" \
        "targetcut[cut fosmid regions]" \
        "phase[phase heterozygotes]"
    ret=0
    ;;
  *)
    _files
    ;;
esac

return ret
