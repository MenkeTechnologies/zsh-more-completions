#compdef sha512deep
# Documentation: https://github.com/jessek/hashdeep
# Reference accessed: 2026-05-21
# Verified: upstream man/md5deep.1 at the URL above (shared option set
# across sha512deep, sha256deep, sha1deep, md5deep).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '(- *)-V[show copyright]' \
  '-r[recursive directory traversal]' \
  '-e[show progress indicator and time estimate]' \
  '-f+[read filenames from file]:file:_files' \
  '-l[use relative file paths]' \
  '-b[bare mode: strip directory paths]' \
  '-z[prepend file size to hash output]' \
  '-Z[triage format output]' \
  '-0[NULL line terminator]' \
  '-c[CSV mode output]' \
  '-k[asterisk separator (binary mode)]' \
  '-q[quiet mode: omit filenames]' \
  '-t[display GMT timestamp]' \
  '-u[quote Unicode output]' \
  '-d[output in DFXML format]' \
  '-m+[match against known hashes]:file:_files' \
  '-M+[match against known hashes and display hash]:file:_files' \
  '-x+[negative match: show files not in list]:file:_files' \
  '-X+[negative match and display hash]:file:_files' \
  '-a+[add single hash to matching list]:hash:' \
  '-A+[add single hash for negative matching]:hash:' \
  '-w[display matching known hash filename]' \
  '-n[display unmatched known hashes only]' \
  '-p+[piecewise mode block size]:size' \
  '-i+[skip files exceeding size threshold]:size' \
  '-I+[only process files exceeding size threshold]:size' \
  '-j+[number of worker threads]:threads' \
  '-F+[I/O mode]:mode:(b u m)' \
  '-o+[expert mode file type filter]:flags:(f b c p l s d e)' \
  '-s[silent mode]' \
  '-S[silent with hash warnings]' \
  '*:file:_files' && ret=0

return ret
