#compdef raidstart
# Documentation: https://www.unix.com/man-page/redhat/8/raidstart
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# raidstart: legacy mdadm-replaced tool to start RAID arrays from /etc/raidtab
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-a[start all defined arrays]' \
  '--all[start all defined arrays]' \
  '-c[config file]:file:_files -g "*.tab"' \
  '--configfile=[config file]:file:_files -g "*.tab"' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '*:raid device:_files -g "/dev/md*"' && ret=0
return ret
