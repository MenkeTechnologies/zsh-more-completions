#compdef st
# _st-bin — suckless st simple terminal (suckless.org); minimal X11 terminal emulator with patch-based customization
# upstream: https://st.suckless.org

_st-bin() {
    _arguments \
        '-a[disable alt screen]' \
        '-c+[wm class]:class:' \
        '-f+[font]:font:' \
        '-g+[geometry]:geom:' \
        '-i+[fixed geometry pixel]:str:' \
        '-n+[wm name]:name:' \
        '-o+[write tty output to file]:file:_files' \
        '-T+[window title]:title:' \
        '-t+[title (legacy)]:title:' \
        '-l+[device]:device:' \
        '-w+[parent window id]:id:' \
        '-e+[command and args]:cmd:_command_names -e' \
        '-v[show version]' \
        '*::command:_command_names -e'
}

_st-bin "$@"
