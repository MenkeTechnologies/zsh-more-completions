#compdef rmdir-cli
# _rmdir-cli — GNU coreutils rmdir remove empty directories CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_rmdir-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--ignore-fail-on-non-empty[ignore fail on non-empty]' \
        '-p[remove ancestor dirs]' \
        '--parents[remove ancestor dirs]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '*:directories:_files -/'
}

_rmdir-cli "$@"
