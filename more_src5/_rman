#compdef rman
# Documentation: https://docs.oracle.com/en/database/oracle/oracle-database/19/rcmrf/RMAN.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Oracle RMAN (Recovery Manager) command-line client.

local -a rman_params

rman_params=(
  TARGET CATALOG AUXILIARY NOCATALOG CMDFILE LOG APPEND PIPE TIMEOUT
  CHECKSYNTAX MSGNO SCRIPT USING SEND
)

_arguments -s \
  "*:RMAN parameter:($rman_params)"
