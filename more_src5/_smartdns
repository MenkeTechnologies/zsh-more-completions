#compdef smartdns
# Documentation: https://github.com/pymumu/smartdns/blob/master/src/smartdns.c
# Reference accessed: 2026-05-21
# Verified: upstream _help()/getopt_long() in src/smartdns.c.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-f[run in foreground mode]' \
  '-c+[config file path]:file:_files -g "*.conf"' \
  "-p+[pid file location (- to disable)]:file:_files" \
  '-R[enable automatic restart on crash]' \
  '-S[ignore segmentation fault signals]' \
  '-x[enable verbose screen output]' \
  '-N+[dump DNS packets to file (debug builds only)]:file:_files' \
  '--cache-print[print cache contents to file]:file:_files' \
  '--is-quic-supported[check QUIC/HTTP3 support]' && ret=0

return ret
