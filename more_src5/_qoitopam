#compdef qoitopam
# Documentation: man qoitopam (Netpbm)
# Source: convert a QOI (Quite OK Image) file to PAM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:qoi file:_files -g "*.qoi"' \
    && ret=0

return ret
