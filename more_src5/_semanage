#compdef semanage
# _semanage — SELinux semanage (manage policy components: subcommands: login, user, port, interface, module, node, fcontext, boolean, permissive, dontaudit, ibendport, ibpkey, export, import; flags -a add, -d delete, -m modify, -l list, -D delete-all, -n no header, -E export, -S store, -h help, -V version, -o output file)
# upstream: https://github.com/SELinuxProject/selinux
# Subcommands from SELinuxProject/selinux python/semanage on tip.

_semanage() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-h[show help]' \
        '-V[show version]' \
        '-S+[policy store]:store:' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'semanage subcommand' '(login user port interface module node fcontext boolean permissive dontaudit ibendport ibpkey export import)' ;;
        args)
            _arguments \
                '-a[add]' \
                '-d[delete]' \
                '-m[modify]' \
                '-l[list]' \
                '-D[delete all]' \
                '-n[no header]' \
                '-N[no reload of policy]' \
                '-E[export current configuration]' \
                '-o+[output file]:file:_files' \
                '-t+[type]:type:' \
                '-r+[range]:range:' \
                '-s+[seuser]:seuser:' \
                '-p+[protocol]:protocol:(tcp udp dccp sctp)' \
                '-c+[class]:class:' \
                '-f+[file type]:type:(a b c d l s p)' \
                '-R+[roles]:roles:' \
                '-L+[level]:level:' \
                '*:target:' \
            ;;
    esac
}

_semanage "$@"
