#compdef srm
# _srm — van Hauser secure-delete srm CLI for securely deleting files and directories by overwriting with random patterns Gutmann 35-pass DoD 5220.22-M renaming truncating before unlink preventing forensic recovery (THC team, C); getopt
# upstream: https://github.com/THC-OSS/secure-delete

_srm() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-q[quiet]' \
        '-r[recursive]' \
        '-R[recursive]' \
        '-f[fast non-secure single pass]' \
        '-l[fewer passes]' \
        '-ll[less passes]' \
        '-z[zero last write]' \
        '-d[ignore . and ..]' \
        '-i[ignore errors]' \
        '*:files or directories:_files'
}

_srm "$@"
