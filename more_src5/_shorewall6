#compdef shorewall6
# Documentation: https://shorewall.org/manpages6/shorewall6.html
# Reference accessed: 2026-05-21
# Verified: shorewall6 is a symlink to shorewall(8) executed with -6;
# command set mirrors shorewall(8).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add interface or IP to a zone'
  'allow:allow access from a host'
  'check:check configuration'
  'clear:clear firewall'
  'compile:compile rules'
  'delete:remove from zone'
  'disable:disable a rule'
  'drop:drop packets'
  'dump:print debugging info'
  'enable:enable a rule'
  'forget:remove old saved state'
  'help:show help'
  'hits:show packet hits'
  'iprange:show IP range'
  'ipcalc:IP calc'
  'iptrace:trace packets'
  'load:load to remote firewall'
  'logdrop:log and drop'
  'logreject:log and reject'
  'logwatch:watch logs'
  'noiptrace:stop trace'
  'reenable:reenable'
  'refresh:refresh blacklist'
  'reject:reject packet from host'
  'reload:reload firewall'
  'reset:reset chain counters'
  'restart:restart firewall'
  'restore:restore saved state'
  'safe-restart:safe restart with rollback'
  'safe-start:safe start with rollback'
  'save:save state'
  'savesets:save dynamic ipsets'
  'show:show shorewall info'
  'start:start firewall'
  'stop:stop firewall'
  'status:show status'
  'try:try a directory'
  'update:update configuration'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-v[verbose]' \
  '-q[quiet]' \
  '-V+[verbosity 0-2]:level:(0 1 2)' \
  '-T+[show command timing]' \
  '-x[show extended details]' \
  '-c+[config dir]:dir:_files -/' \
  '-D+[debug]' \
  '-n[do not modify routes/dns]' \
  '-p[purge old chains]' \
  '-f[fast]' \
  '-d[debug]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'shorewall6 command' commands && ret=0 ;;
esac

return ret
