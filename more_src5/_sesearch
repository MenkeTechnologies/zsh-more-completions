#compdef sesearch
# _sesearch — SELinux setools sesearch (search rules in a SELinux policy: --allow/--neverallow/--auditallow/--dontaudit/--allowxperm/--type/--role/--transition/--role_transition/--range_transition/--nlmsg/--ibendport/--ibpkey; -s source type, -t target type, -c class, -p permission, -b bool, -m match attributes, -d show inferred attributes, -nN no header, -V version)
# upstream: https://github.com/SELinuxProject/setools
# Flags from SELinuxProject/setools setools/sesearch.py on tip.

_sesearch() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--allow[allow rules]' \
        '--neverallow[neverallow rules]' \
        '--auditallow[auditallow rules]' \
        '--dontaudit[dontaudit rules]' \
        '--allowxperm[allowxperm rules]' \
        '--type[type rules]' \
        '--role[role rules]' \
        '--user[user rules]' \
        '--transition[type_transition]' \
        '--role_transition[role_transition]' \
        '--range_transition[range_transition]' \
        '--nlmsg[nlmsg rules]' \
        '-s+[source type]:source:' \
        '-t+[target type]:target:' \
        '-c+[class]:class:' \
        '-p+[permission]:perm:' \
        '-b+[bool]:bool:' \
        '-m[match attributes]' \
        '-d[show inferred attributes]' \
        '-nN[no header]' \
        '1::policy file:_files'
}

_sesearch "$@"
