#compdef restview
# Documentation: https://github.com/mgedmin/restview
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-l --listen)'{-l+,--listen=}'[listen on port or interface:port]:addr:' \
  '(-b --browser)'{-b,--browser}'[open browser on start]' \
  '(-B --no-browser)'{-B,--no-browser}'[do not open browser]' \
  '(-e --execute)'{-e+,--execute=}'[execute command producing RST]:cmd:' \
  '--long-description[render Python package long_description]' \
  '--strict[halt on minor issues]' \
  '--pypi-strict[enable PyPI-specific validation]' \
  '--report-level=[docutils report_level]:level:(1 2 3 4)' \
  '--halt-level=[docutils halt_level]:level:(1 2 3 4)' \
  '*'{-w+,--watch=}'[watch file or directory]:path:_files' \
  '*--css=[stylesheet URL or file]:css:_files -g "*.css"' \
  '--allowed-hosts=[allowed Host header values]:list:' \
  '*: :_files -g "*.(rst|txt)"' && ret=0

return ret
