#compdef rump_tmpfs
# Documentation: man rump_tmpfs(8)
# Source: netbsd/src usr.sbin/puffs/rump_tmpfs — mount tmpfs images via userspace rump server (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-o+[mount options (see mount_tmpfs(8))]:options:_default' \
    '1:image (supports %DISKLABEL\:p% suffix):_files' \
    '2:mount point:_files -/' \
    && ret=0

return ret
