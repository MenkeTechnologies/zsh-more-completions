#compdef rabbitmq-streams
# Documentation: https://www.rabbitmq.com/docs/man/rabbitmq-streams.8
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'add_super_stream:create a partitioned super stream'
  'add_replica:add stream replica on node'
  'delete_replica:remove stream replica from node'
  'stream_status:display status of a stream'
  'restart_stream:restart a stream and its replicas'
)

_arguments -C \
  '-n=[node name]:node:' \
  '-q[quiet output]' \
  '-l[long node names]' \
  '-t=[timeout secs]:secs:' \
  '--erlang-cookie=[Erlang cookie]:cookie:' \
  '--formatter=[output formatter]:fmt:' \
  '--no-table-headers[no table headers]' \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'rabbitmq-streams subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (add_super_stream)
        _arguments \
          '--vhost=[virtual host]:vhost:' \
          '--partitions=[partition count]:n:' \
          '--binding-keys=[binding keys]:keys' \
          '--max-length-bytes=[max length bytes]:bytes' \
          '--max-age=[max age]:duration' \
          '--stream-max-segment-size-bytes=[max segment size]:bytes' \
          '--leader-locator=[leader locator strategy]:locator' \
          '--initial-cluster-size=[initial cluster size]:n' \
          ':super stream name:' && ret=0
        ;;
      (add_replica|delete_replica)
        _arguments \
          '--vhost=[virtual host]:vhost:' \
          ':queue name:' \
          ':node:' && ret=0
        ;;
      (stream_status)
        _arguments \
          '--vhost=[virtual host]:vhost:' \
          ':stream name:' && ret=0
        ;;
      (restart_stream)
        _arguments \
          '--vhost=[virtual host]:vhost:' \
          '--preferred-leader-node=[preferred leader node]:node' \
          ':stream name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
