#compdef reverb-cli
# _reverb-cli — Laravel Reverb first-party WebSocket server CLI alias (laravel team, PHP); artisan-based
# upstream: https://github.com/laravel/reverb

_reverb-cli() {
    local -a sub=(
        'reverb:install:install reverb'
        'reverb:start:start reverb server'
        'reverb:restart:restart reverb workers'
        'reverb:ping:ping running server'
        'reverb:signal:send signal to workers'
        'reverb:stats:show server stats'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--env=+[env]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'reverb subcommand' sub ;;
        args)
            case $words[1] in
                reverb:install) _arguments \
                    '--without-node[skip node setup]' \
                    '--force[force overwrite]' ;;
                reverb:start) _arguments \
                    '--host=+[host]:host:_hosts' \
                    '--port=+[port]:port:' \
                    '--hostname=+[hostname]:str:' \
                    '--debug[debug]' ;;
                reverb:restart) ;;
            esac
            ;;
    esac
}

_reverb-cli "$@"
