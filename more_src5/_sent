#compdef sent
# Documentation: https://tools.suckless.org/sent/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# sent: suckless plaintext presentation tool. Usage: sent [FILE]
# If FILE is omitted or equals '-', stdin is read.
local curcontext="$curcontext" ret=1
_arguments -s -S \
  '1:presentation file:_files' && ret=0
return ret
