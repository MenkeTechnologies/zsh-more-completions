#compdef slackdump
# slackdump - Export Slack workspace data

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a commands=(
  'archive:create a Slack export archive'
  'dump:dump conversations'
  'emoji:download custom emoji'
  'export:export workspace data'
  'list:list workspace resources'
  'users:list workspace users'
  'workspace:manage workspace connections'
  'version:show version'
  'help:show help'
)

_arguments -C -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--trace[enable trace output]' \
  '(-t --token)'{-t+,--token=}'[Slack API token]:token:' \
  '(-c --cookie)'{-c+,--cookie=}'[Slack cookie value]:cookie:' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'slackdump command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      archive|export)
        _arguments \
          '(-o --output)'{-o+,--output=}'[output directory or file]:path:_files' \
          '(-T --type)'{-T+,--type=}'[export type]:type:(standard mattermost)' \
          '*:channel ID or name:' \
          && ret=0
        ;;
      dump)
        _arguments \
          '(-o --output)'{-o+,--output=}'[output directory]:directory:_files -/' \
          '--files[download files]' \
          '--no-files[skip file downloads]' \
          '*:channel ID or name:' \
          && ret=0
        ;;
      list)
        _arguments \
          '1:resource type:(channels conversations users)' \
          && ret=0
        ;;
      emoji)
        _arguments \
          '(-o --output)'{-o+,--output=}'[output directory]:directory:_files -/' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
