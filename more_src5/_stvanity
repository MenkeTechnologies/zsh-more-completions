#compdef stvanity
# _stvanity — Syncthing vanity device-ID generator (syncthing/syncthing)
# upstream: https://github.com/syncthing/syncthing
# Flags from cmd/dev/stvanity/main.go (stdlib flag, positional only).

_stvanity() {
    _arguments \
        '(- *)-h[show help]' \
        '1:vanity device-ID prefix (uppercase, no dashes):'
}

_stvanity "$@"
