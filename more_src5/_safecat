#compdef safecat
# Documentation: man safecat(1)
# Source: aperezdc/safecat safecat.c — qmail Maildir-style atomic copy (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:tempdir:_files -/' \
    '2:destdir:_files -/' \
    && ret=0

return ret
