#compdef showfont
# Documentation: man showfont(1)
# Source: apple-oss-distributions/X11apps showfont-1.0.3/showfont.c — XFS font dumper (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-server+[font server]:server:_default' \
    '-extents_only[only show extents]' \
    '-noprops[suppress font properties]' \
    '(-lsb -msb)-lsb[LSB-first bit order]' \
    '(-lsb -msb)-msb[MSB-first bit order]' \
    '(-LSB -MSB)-LSB[LSB-first byte order]' \
    '(-LSB -MSB)-MSB[MSB-first byte order]' \
    '-unit+[bit-order unit]:n:_default' \
    '-pad+[scanline padding bits]:n:_default' \
    '-bitmap_pad+[bitmap pad value]:value:_default' \
    '-start+[first character]:char:_default' \
    '-end+[last character]:char:_default' \
    '-fn+[font name]:fontname:_default' \
    && ret=0

return ret
