#compdef sem-ai
# Documentation: https://github.com/semaphoreio/sem-ai
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-f --format)'{-f+,--format=}'[output format]:format:(json table yaml)' \
  '(-v --verbose)'{-v,--verbose}'[print detailed output]' \
  '--examples[show usage examples]' \
  '--project=[project name]:project:' \
  '--branch=[branch filter]:branch:' \
  '--help[show help]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a commands
    commands=(
      'connect:connect to a Semaphore organization'
      'discover:return a structured map of all commands and flags'
      'mcp:MCP server commands'
      'version:show version'
      'context:manage active organizations'
      'project:project commands (list/show/update/delete)'
      'workflow:workflow commands (list/show/run/rerun/stop)'
      'pipeline:pipeline commands (show/list/stop/rebuild/promote/topology)'
      'job:job commands (list/show/log/stop)'
      'analytics:analytics commands (summary/duration/failures/queue/deploys/trend)'
      'test:test intelligence (summary/report/flaky)'
      'deploy:deployment targets (targets/show/history/create/activate/deactivate/delete)'
      'secret:secrets management (list/show/create/update/delete)'
      'notification:notification commands'
      'task:task commands'
      'agent:agent commands'
      'artifact:artifact commands (list/get)'
      'open:open in browser'
      'watch:watch resource'
      'api-spec:show API spec'
      'yaml:yaml commands (validate)'
      'troubleshoot:troubleshooting tool'
      'status:compound status'
      'diagnose:analyze failures'
      'health:health summary'
      'critical-path:critical path analysis'
      'blast-radius:blast radius analysis'
      'rerun-failed:rerun failed jobs'
      'promote-and-wait:promote pipeline and wait'
      'testbox:testbox commands (warmup/run/ssh/stop)'
    )
    _describe -t commands 'sem-ai command' commands
    ;;
  args)
    _files
    ;;
esac

return ret
