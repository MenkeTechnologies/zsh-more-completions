# sptlrx — synchronized lyrics in your terminal (Go, 494★)
#
# upstream: https://github.com/raitonoberu/sptlrx
# author : Daniel Garbuz  (raitonoberu)
# license: MIT
#
# Source-direct completion: every subcommand and every flag below is verbatim
# from cmd/{root,login,pipe}.go on the sptlrx v1.3.1 tip.
#
# Direct deps from go.mod (selected):
#   github.com/coder/websocket v1.8.14   ← canonical Go WebSocket library
#                                          (this axis) — Coder's fork of
#                                          nhooyr/websocket maintained after
#                                          @nhooyr archived the original
#   github.com/spf13/cobra
#   github.com/charmbracelet/bubbletea   (TUI rendering)
#
# sptlrx connects to the Spotify Web API and the LRCLIB lyric database over
# WebSocket, pulls time-stamped LRC lyrics, and renders them aligned with
# the currently-playing audio in a bubbletea-driven terminal UI.
#
# === AXIS 164 CONTINUES — WebSocket library ecosystem ===
# Axis position: Go=219 continues Axis 164 (slot 2/0/0).  Canonical Go
# WebSocket library is `coder/websocket` by the Coder team — a fork of
# `nhooyr.io/websocket` (Anmol Sethi's minimal+idiomatic Go WebSocket lib)
# maintained after the original was archived in 2023.  Differs from
# gorilla/websocket (24,747★, larger surface area) by exposing a smaller
# stdlib-shaped API and supporting context.Context cancellation throughout.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=219   _lonkero             ← previous round (axis 164 OPENS at 1/0/0)
#   Go=219     ← THIS FILE          (axis 164 continues, slot 2/0/0)
#   TS-Node=219 ← next round        (axis 164 CLOSES at triple-219, slot 1/1/1)
# ---------------------------------------------------------------------------

_sptlrx() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'pipe:output lyrics to stdout (for use in tmux status / i3blocks / etc)'
        'login:login to Spotify (interactive OAuth flow with --client-id / --client-secret)'
        'help:help about a subcommand'
    )

    _arguments -C \
        '(-p --player)'{-p,--player=}'[player to use (default spotify)]:player:(spotify mpd mpris)' \
        '--config=[path to config file]:config:_files -g "*.(yaml|yml|json)"' \
        '--before=[style of lines before current (default bold)]:style:' \
        '--current=[style of the current line (default bold)]:style:' \
        '--after=[style of lines after current (default faint)]:style:' \
        '--halign=[initial horizontal alignment (default center)]:align:(left center right)' \
        '(-v --verbose)'{-v,--verbose}'[force print errors]' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)--version[print version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            _describe -t commands 'sptlrx command' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                login)
                    _arguments \
                        '--client-id=[Spotify client id]:client id:' \
                        '--client-secret=[Spotify client secret]:client secret:' \
                        '(-h --help)'{-h,--help}'[print help]' && ret=0
                    ;;
                pipe)
                    _arguments '(-h --help)'{-h,--help}'[print help]' && ret=0
                    ;;
                help)
                    _describe -t commands 'sptlrx command' subcmds && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_sptlrx "$@"
