# ---------------------------------------------------------------------------
# rssnix — Unix-style filesystem-based RSS/Atom/JSON Feed fetcher and reader
#          (Go, 190★)
#
# upstream: https://github.com/aidlx/rssnix
# author : aidlx
# license: MIT
#
# Source-direct completion: every subcommand and alias below is verbatim
# from main.go on the aidlx/rssnix tip — the `urfave/cli/v2` Commands
# slice with Name + Aliases + Usage fields parsed exactly as declared.
# No global flags (the CLI uses urfave/cli/v2's default --help / --version
# only; per-subcommand flags omitted because each subcommand takes only
# positional feed names).
#
# Direct deps from go.mod (selected):
#   github.com/mmcdole/gofeed       v1.1.3   ← canonical Go unified feed
#                                              parser (this axis) — by
#                                              Mike McDole (mmcdole/
#                                              gofeed); single pure-Go
#                                              package that parses RSS
#                                              0.90 / 0.91 / 0.92 / 1.0 /
#                                              2.0 + Atom 0.3 / 1.0 + JSON
#                                              Feed 1.0/1.1 into a
#                                              UNIFIED model (`gofeed.
#                                              Feed` + `gofeed.Item`)
#                                              with auto-format detection
#                                              via `gofeed.Parser`.  No
#                                              "is this RSS or Atom?"
#                                              dispatch needed at the
#                                              call site — gofeed sniffs
#                                              the document root, picks
#                                              the right backend
#                                              (RSSParser /
#                                              AtomParser / JSONParser),
#                                              and returns the same
#                                              shape.  THE Go answer to
#                                              "parse this web feed" —
#                                              used by miniflux, hugo,
#                                              huginn-go, freshrss-
#                                              import tools, and the
#                                              majority of Go RSS-
#                                              consuming tools.  rssnix
#                                              uses gofeed inside
#                                              feed.go's UpdateFeed /
#                                              UpdateAllFeeds pipeline:
#                                              each feed URL is fetched
#                                              concurrently via a
#                                              gofeed.Parser, and items
#                                              are persisted as
#                                              individual files in the
#                                              filesystem under
#                                              `${XDG_DATA_HOME}/rssnix/
#                                              <feed-name>/`.  The
#                                              "new" subdirectory holds
#                                              unread items; users `mv`
#                                              files between directories
#                                              with regular Unix tooling
#                                              instead of running
#                                              custom commands.
#   github.com/urfave/cli/v2        v2.23.5  (CLI parser — App+Commands)
#   github.com/gilliek/go-opml      v1.0.0   (OPML import file format)
#   github.com/go-ini/ini           v1.67.0  (~/.config/rssnix/rssnix.ini)
#   github.com/PuerkitoBio/goquery  v1.5.1   (HTML parsing for inline
#                                              article rendering)
#   github.com/sirupsen/logrus      v1.9.0   (structured logging)
#   github.com/russross/blackfriday/v2 v2.1.0 (Markdown → HTML for stored
#                                              items so the reader can
#                                              render to terminal cleanly)
#
# rssnix is a Unix-philosophy RSS/Atom/JSON Feed reader: feeds are stored
# as plain files under `${XDG_DATA_HOME}/rssnix/<feed-name>/`, configured
# via `${XDG_CONFIG_HOME}/rssnix/rssnix.ini` with `[feeds]` section
# `name=url` lines, and managed by standard Unix tooling (`mv` / `rm` /
# `cat` / `grep` / `less` / `bat`) on the individual item files.  The
# reader concept is just "files in directories" — no SQLite, no JSON
# blob store, no proprietary format — so any tool that operates on files
# can also operate on rssnix.  `rssnix update` fetches new items into
# the `new/` subdirectory of each feed; `rssnix refetch` deletes and re-
# fetches; `rssnix open` shells out to `xdg-open`/`open` for a feed's
# directory.  Feeds are added via `rssnix add <name> <url>` or by
# importing an OPML file via `rssnix import <file.opml>`.  Single-letter
# aliases mirror most subcommands (a / r / u / o / i / c / v) for
# fast typing.
#
# === AXIS 182 CONTINUES — RSS/Atom feed syndication parsing libraries ====
# Axis position: Go=237 continues Axis 182 (slot 2/0/0).  Canonical Go
# RSS+Atom+JSON Feed parser is `github.com/mmcdole/gofeed` by Mike McDole
# — a single pure-Go package that parses every dominant web-feed format
# (RSS 0.x / 1.0 / 2.0 + Atom 0.3 / 1.0 + JSON Feed 1.0 / 1.1) into a
# UNIFIED `gofeed.Feed` + `gofeed.Item` model with auto-format detection
# via `gofeed.Parser`.  No dispatch on Content-Type / root element needed
# at the call site — gofeed sniffs the document and picks the backend
# (RSSParser / AtomParser / JSONParser) internally.  THE Go answer to
# "parse this web feed".  Used by miniflux (the dominant self-hosted Go
# feed aggregator), hugo's data-loaders, huginn-go, freshrss-import
# tools, and the majority of Go feed-consuming tools.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=237     _blog                ← previous round (axis 182 OPENS, 1/0/0)
#   Go=237       ← THIS FILE          (axis 182 continues, slot 2/0/0)
#   TS-Node=237  ← next round         (axis 182 CLOSES at triple-237, 1/1/1)
#
# Cross-language design contrast for axis 182:
#   Rust    : rust-syndication SPLITS the work across two sibling crates
#             (rss + atom_syndication).  Consumers dispatch by Content-
#             Type / root element to the appropriate crate, then map to
#             a unified consumer-side model.  Two crates, two models,
#             unified at the consumer.
#   Go      : mmcdole/gofeed UNIFIES the work in one package.  Single
#             `gofeed.Parser` with internal format detection; consumers
#             always get back `gofeed.Feed` regardless of source format.
#             One crate, one model, unified at the library.
#   JS/Node : depends on the closer — either lightweight modern
#             (`rss-parser`, slightly unified shape) or older
#             battle-tested (`node-feedparser`, raw event-emitter API).
#             [TBD next round]
# ---------------------------------------------------------------------------

_rssnix() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[print the version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'config:opens the config file with $EDITOR (alias: c)'
                'c:opens the config file with $EDITOR (alias of config)'
                'refetch:delete and refetch given feed(s) or all feeds if no argument is given (alias: r)'
                'r:delete and refetch (alias of refetch)'
                'update:update given feed(s) or all feeds if no argument is given (alias: u)'
                'u:update feeds (alias of update)'
                'open:open given feed'\''s directory or root feeds directory if no argument is given (alias: o)'
                'o:open feed directory (alias of open)'
                'add:add a given feed to config (alias: a; usage: rssnix add NAME URL)'
                'a:add a feed (alias of add)'
                'import:import an OPML file (alias: i; usage: rssnix import FILE.opml)'
                'i:import OPML (alias of import)'
                'version:display the version (alias: v)'
                'v:display the version (alias of version)'
                'help:show help'
                'h:show help (alias of help)'
            )
            _describe -t commands 'rssnix command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                import|i)
                    _arguments '*:OPML file:_files -g "*.(opml|xml|OPML|XML)"' && ret=0
                    ;;
                add|a)
                    _arguments \
                        '1:feed name (key in [feeds] section of rssnix.ini):' \
                        '2:feed URL (https:// preferred):' && ret=0
                    ;;
                refetch|r|update|u|open|o)
                    _arguments '*:feed name (from [feeds] section of rssnix.ini; omit to operate on all):' && ret=0
                    ;;
                help|h)
                    local -a allsubs
                    allsubs=(
                        config refetch update open add import version
                    )
                    _describe -t commands 'subcommand for help' allsubs && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_rssnix "$@"
