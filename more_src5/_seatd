#compdef seatd
# Documentation: https://manpages.opensuse.org/Tumbleweed/seatd/seatd.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for seatd (minimal seat management daemon)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show help message and quit]' \
  '-v[show version number and quit]' \
  '-n+[FD to notify readiness on]:fd:' \
  '-u+[user to own the seatd socket]:user:_users' \
  '-g+[group to own the seatd socket]:group:_groups' \
  '-l+[log level (debug, info, error, silent)]:level:(debug info error silent)' \
  '-s+[socket path (Debian build)]:socket path:_files' && ret=0

return ret
