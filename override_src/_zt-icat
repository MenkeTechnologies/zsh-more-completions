#compdef zt-icat

# Completion for zt-icat — inline image display via the Kitty graphics
# protocol. Options mirror those parsed in extra/zterminal-icat.

_zt-icat() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -s -S : \
        '(- *)'{-h,--help}'[show help and exit]' \
        '(- *)--selftest[emit a small test image to verify graphics support]' \
        '(-w --width)'{-w+,--width=}'[cap width at COLS character columns]:columns:_zt-icat_dims' \
        '(-H --height)'{-H+,--height=}'[cap height at ROWS character rows]:rows:_zt-icat_dims' \
        '(-u --scale-up)'{-u,--scale-up}'[enlarge images smaller than the box]' \
        '(-n --no-tmux)'{-n,--no-tmux}'[force direct display even inside tmux]' \
        '(--selftest)*:image:_zt-icat_images' \
        && ret=0

    return ret
}

# Image files the bundled sips pipeline can read (macOS), plus directories.
(( $+functions[_zt-icat_images] )) ||
_zt-icat_images() {
    _files -g '*.(#i)(png|jpg|jpeg|gif|bmp|tif|tiff|webp|heic|heif|ico|psd|tga)'
}

# Plain numeric argument for --width / --height; no fixed list, just a hint.
(( $+functions[_zt-icat_dims] )) ||
_zt-icat_dims() {
    _message -e 'cells' 'number of character cells'
}

if [ "$funcstack[1]" = "_zt-icat" ]; then
    _zt-icat "$@"
else
    compdef _zt-icat zt-icat
fi
