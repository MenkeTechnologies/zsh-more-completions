local arguments

arguments=(
    '--version[output the version number]'
    {-e,--ejs}'[add ejs engine support]'
    '--pug[add pug engine support]'
    '--hbs[add handlebars engine support]'
    {-H,--hogan}'[add hogan.js engine support]'
    {-v,--view}'[add view engine (ejs|hbs|hjs|pug|twig|vash; default pug)]:engine:(ejs hbs hjs pug twig vash)'
    '--no-view[generate app without view engine (API-only mode)]'
    {-c,--css}'[add stylesheet engine (less|stylus|compass|sass; default plain css)]:engine:(less stylus compass sass)'
    '--git[add .gitignore]'
    {-f,--force}'[force generation in non-empty directory]'
    '(- * :)'{-h,--help}'[output usage information]'
    '*:directory:_files -/'
)

_arguments -s $arguments
