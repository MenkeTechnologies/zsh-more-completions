#compdef curl

# Zsh completion for curl 8.x (tested with 8.19.0)
# Comprehensive options based on `curl --help all`

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_curl_crypto_engine() {
    local -a vals
    vals=( ${${(f)"$(curl --engine list 2>/dev/null)":gs/ /}[2,$]} )
    _describe -t engines 'crypto engines' vals && return 0
}

_curl_post_data() {
    # Raw content after =
    compset -P '=' && _message 'raw content' && return 0

    # Filename or stdin for @ syntax
    compset -P '*@' && {
        local expl
        _description files expl stdin
        compadd "$expl[@]" - "-"
        _files
        return 0
    }

    # After name=, expect data value
    compset -P '*=' && _message 'data value' && return 0

    # Otherwise, name (or @ or =)
    _message 'data name' && return 0
}

_curl_http_methods() {
    local -a methods
    methods=(
        GET POST PUT DELETE PATCH HEAD OPTIONS TRACE CONNECT
        LINK UNLINK PROPFIND PROPPATCH MKCOL COPY MOVE LOCK UNLOCK
        PURGE REPORT SEARCH MKACTIVITY CHECKOUT MERGE
        M-SEARCH NOTIFY SUBSCRIBE UNSUBSCRIBE
    )
    _describe -t methods 'HTTP method' methods
}

