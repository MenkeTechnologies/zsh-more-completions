# Pull dep names from the project's stryke.toml so `s remove`/`s info` complete
# with the real dep set instead of arbitrary words. Walks up from cwd to find
# the manifest. Cheap (just grep over a small TOML file).
# Names from ~/.stryke/installed.toml — used by `s use -g`, `s uninstall -g`.
# Falls back to scanning the store dir when installed.toml is absent (old
# layouts pre-v0.16.30 didn't have the pin file).
_stryke_global_pkg_names() {
  local idx="${STRYKE_HOME:-$HOME/.stryke}/installed.toml"
  local -a names
  if [[ -f "$idx" ]]; then
    names=(${(f)"$(awk -F'"' '/^name = /{print $2}' "$idx" 2>/dev/null)"})
  fi
  if (( ${#names} == 0 )); then
    local store="${STRYKE_HOME:-$HOME/.stryke}/store"
    [[ -d "$store" ]] || return
    names=(${(f)"$(command ls "$store" 2>/dev/null | awk -F@ 'NF==2{print $1}' | sort -u)"})
  fi
  _describe 'installed package' names
}

# Versions present in ~/.stryke/store/<name>@*/ — used by `s use -g name@<TAB>`.
# `$1` is the package name extracted from the partial spec.
_stryke_global_pkg_versions() {
  local name="$1"
  [[ -n "$name" ]] || return
  local store="${STRYKE_HOME:-$HOME/.stryke}/store"
  [[ -d "$store" ]] || return
  local -a versions
  versions=(${(f)"$(command ls "$store" 2>/dev/null | awk -F@ -v n="$name" 'NF==2 && $1==n {print $2}' | sort -ru)"})
  (( ${#versions} == 0 )) && return
  local -a tagged
  local v
  for v in $versions; do tagged+=("$name@$v"); done
  _describe 'installed version' tagged
}

# Combined NAME and NAME@VERSION completer for `s use -g`. If the current
# word contains `@`, suggest matching versions; otherwise suggest names.
_stryke_global_pkg_spec() {
  if [[ "$PREFIX" == *@* ]]; then
    _stryke_global_pkg_versions "${PREFIX%%@*}"
  else
    _stryke_global_pkg_names
  fi
}

_stryke_pkg_dep_names() {
  local manifest_dir="$PWD"
  while [[ "$manifest_dir" != "/" && ! -f "$manifest_dir/stryke.toml" ]]; do
    manifest_dir="${manifest_dir:h}"
  done
  [[ -f "$manifest_dir/stryke.toml" ]] || return
  local -a deps
  # Match three forms in stryke.toml: shorthand `name = "ver"`, table `[deps.NAME]`,
  # and grouped `[deps]` then `name = ...`. Keep it conservative — just enough to
  # complete the common cases.
  deps=(${(f)"$(awk '
    /^\[deps\.[^]]+\]/ { gsub(/\[deps\.|\]/, ""); print; next }
    /^\[deps\]/ { in_deps = 1; next }
    /^\[/ { in_deps = 0; next }
    in_deps && /^[a-zA-Z][-_a-zA-Z0-9]*[ \t]*=/ { sub(/[ \t]*=.*/, ""); print }
  ' "$manifest_dir/stryke.toml" 2>/dev/null)"})
  _describe 'project dep' deps
}

# `s install [--offline] | install -g SPEC`
#   no -g: resolve manifest deps + write stryke.lock
#   -g:    install a package globally; SPEC is PATH | gh:owner/repo |
#          github.com/owner/repo | https://github.com/owner/repo (with
#          optional @VERSION)
_stryke_install() {
  _arguments -s -S \
    '(-g --global)'{-g,--global}'[install globally into ~/.stryke/store + installed.toml]' \
    '--offline[only use cached packages; never fetch]' \
    '(-h --help)'{-h,--help}'[show s install usage]' \
    '*: :->install_arg'
  case $state in
    install_arg)
      # If `-g`/`--global` is on the line, the positional is a SPEC; otherwise
      # `install` takes no positional args (resolves the project manifest).
      if (( ${words[(I)-g]} || ${words[(I)--global]} )); then
        _alternative \
          'paths:local package dir:_directories' \
          'github:github.com/owner/repo:( gh:MenkeTechnologies/stryke-gui github.com/MenkeTechnologies/stryke-gui https://github.com/MenkeTechnologies/stryke-gui )'
      fi
      ;;
  esac
}

