# `s pkg <subcommand>` — dispatcher mirror for the package commands above.
_stryke_pkg() {
  local curcontext="$curcontext" state line
  _arguments -C \
    '(-h --help)'{-h,--help}'[show s pkg usage]' \
    '1:pkg subcommand:->pkg_cmd' \
    '*::pkg arg:->pkg_args'
  case $state in
    pkg_cmd)
      local -a pkg_subcmds
      pkg_subcmds=(
        'init:scaffold project in cwd'
        'new:scaffold project at ./NAME/'
        'install:resolve deps + write stryke.lock (alias: i; with -g: install a package globally)'
        'i:alias for install'
        'uninstall:drop a global pin + its launchers (alias: un; requires -g)'
        'un:alias for uninstall'
        'list:list global packages, launchers, orphans (alias: ls; requires -g)'
        'ls:alias for list'
        'update:re-resolve manifest + rewrite stryke.lock (alias: up, upgrade)'
        'up:alias for update'
        'upgrade:alias for update'
        'publish:push package to registry (alias: pub)'
        'pub:alias for publish'
        'yank:yank a published version from the registry'
        'use:switch which installed version `use Foo` resolves to (requires -g NAME@VERSION)'
        'gc:delete store entries no longer pinned (requires -g)'
        'add:add a dep to stryke.toml'
        'remove:drop a dep from stryke.toml'
        'tree:print resolved dep graph'
        'info:show lockfile entry for a dep'
        'outdated:list installed deps newer than stryke.lock'
        'audit:security audit of resolved dep tree'
        'vendor:vendor deps into ./vendor/ for offline builds'
        'clean:remove caches and build artifacts'
        'search:search the registry for packages'
      )
      _describe 'pkg subcommand' pkg_subcmds
      ;;
    pkg_args)
      case $line[1] in
        init)      _stryke_init ;;
        new)       _stryke_new ;;
        install|i) _stryke_install ;;
        uninstall|un) _stryke_uninstall ;;
        list|ls)   _stryke_list ;;
        use)       _stryke_use ;;
        gc)        _stryke_gc ;;
        add)       _stryke_add ;;
        remove)    _stryke_remove ;;
        tree)      _stryke_tree ;;
        info)      _stryke_info ;;
        test|t)    _stryke_test ;;
        update|up|upgrade) _stryke_update ;;
        publish|pub) _stryke_publish ;;
        yank)      _stryke_yank ;;
        outdated)  _stryke_outdated ;;
        audit)     _stryke_audit ;;
        vendor)    _stryke_vendor ;;
        clean)     _stryke_clean ;;
        search)    _stryke_search ;;
      esac
      ;;
  esac
}

