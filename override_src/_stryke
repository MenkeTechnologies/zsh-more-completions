    '(-p --project)'{-p+,--project=}'[bundle project directory (main.stk + lib/)]:directory:_directories' \
    '--mcp-server[wrap output as an MCP server over stdio JSON-RPC]' \
    '(-h --help)'{-h,--help}'[show s build usage]' \
    '1:script file:_files -g "*.stk *.pl *.pm"'
}

