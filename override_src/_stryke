# `s docs [FLAGS|TOPIC]` — built-in documentation browser.
#
# Two completion sources merged:
#   * Long flags (`--toc` / `--list` / `--list-all` / `--search` / `--help`)
#   * Topic names from `s docs --list-all` — the full set of every
#     callable spelling, including aliases (`tj`, `bn`), `CORE::name` /
#     `main::name` qualified forms, sigil-prefixed reflection hashes
#     (`%a`, `%b`, `%stryke::builtins`), and language keywords. Drives
#     ~27k completion candidates so any name the user might type
#     resolves cleanly.
#
# `--list-all` was added specifically for shell tab-complete. Do NOT
# fall back to `--list`: that drops aliases and qualified spellings,
# breaking completion for `s docs CORE::<TAB>` and friends.
#
# IMPORTANT: topics are fed through `compadd`, NOT `_describe`. zsh's
# `_describe` treats `:` as the name/description separator, so any
# entry containing `::` (`CORE::print`, `main::sum`, `%main::ENV`,
# `@main::a`, `%stryke::builtins`) gets parsed as `name=CORE` /
# `description=:print` — collapsing thousands of qualified spellings
# into duplicate `CORE` / `main` / `@main` / `%main` / `%stryke` rows
# with the suffix stuffed into the description column. `compadd -a`
# adds the array verbatim with no colon parsing.
# Flag set for `s docs` — pulled into its own helper so `_alternative`
# can register it as a distinct tag/section.
_stryke_docs_flags() {
  local -a _flags
  _flags=(
    '--toc:table of contents'
    '-t:table of contents'
    '--list:list all pages (primaries + keywords)'
    '-l:list all pages (primaries + keywords)'
    '--list-all:every callable spelling (full completion set)'
    '-L:every callable spelling (full completion set)'
    '--search:search all pages'
    '-s:search all pages'
    '--help:show docs subcommand usage'
    '-h:show docs subcommand usage'
  )
  _describe -t flags 'flag' _flags
}

# Topic set for `s docs` — `compadd -a` (NOT `_describe`) so entries
# containing `::` (`CORE::print`, `%stryke::builtins`, `@main::a`,
# `%main::ENV`) survive intact. `_describe` would split each at the
# first `:` and collapse thousands of qualified spellings into
# duplicate `CORE` / `@main` / `%main` / `%stryke` rows.
_stryke_docs_topics() {
  local -a _topics
  _topics=(${(f)"$(s docs --list-all 2>/dev/null | sed 's/^ *[0-9]*\. //')"})
  compadd -a _topics
}

_stryke_docs() {
  _alternative \
    'flags:flag:_stryke_docs_flags' \
    'topics:docs topic:_stryke_docs_topics'
}

# `s serve [PORT] [SCRIPT]` — built-in HTTP server (default port 8000)
_stryke_serve() {
  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show s serve usage]' \
    '1:port (default 8000):' \
    '2:script or -e:_files -g "*.stk *.pl"'
}

_stryke_deconvert() {
  _arguments -s -S \
    '(-i --in-place)'{-i,--in-place}'[write .pl files alongside originals]' \
    '(-d --output-delim)'{-d+,--output-delim=}'[delimiter for s/// tr/// m// (default: preserve original)]:delimiter:' \
    '(-h --help)'{-h,--help}'[show s deconvert usage]' \
    '*:stryke files:_files -g "*.stk"'
}
# `s convert [-i] [-d DELIM] FILE...` — convert Perl source to idiomatic stryke syntax
_stryke_convert() {
  _arguments -s -S \
    '(-i --in-place)'{-i,--in-place}'[rewrite files in place]' \
    '(-d --output-delim)'{-d+,--output-delim=}'[delimiter for s/// tr/// m// (default: preserve original)]:delimiter:' \
    '(-h --help)'{-h,--help}'[show s convert usage]' \
    '*:perl files:_files -g "*.pl *.pm *.t *.cgi *.psgi"'
}

_stryke() {
  local curcontext="$curcontext" state state_descr line
  typeset -A opt_args

  # Top-level: every flag is exposed via `_arguments`. The two trailing positional specs
  # (`1:...:->cmd` and `*::arg:->args`) defer subcommand handling to the case block below.
  #
  # `-C` is mandatory: without it, `$state` is not exported to the surrounding function.
  _arguments -s -S \
    '--lsp[run language server over stdio (no script needed)]' \
    '--remote-worker[persistent cluster worker over stdio]' \
    '--remote-worker-v1[legacy one-shot cluster worker over stdio]' \
    '--compat[Perl 5 strict-compat: disable all stryke extensions]' \
    '--static[mandatory static typing: require types everywhere (Kotlin-style)]' \
    '--script[force arg to be a script file (skip code detection)]' \
    '*-e+[one line of program (several allowed)]:code:' \
    '*-E+[like -e but enables all optional features]:code:' \
    '-c[check syntax only (parse; does not compile or run)]' \
    '(--lint --check)'{--lint,--check}'[parse + compile bytecode without running]' \
    '(--disasm --disassemble)'{--disasm,--disassemble}'[print bytecode disassembly to stderr before running]' \
    '--ast[dump parsed AST as JSON and exit (no execution)]' \
    '--fmt[pretty-print parsed Perl to stdout and exit]' \
    '--profile[wall-clock profile: per-line + per-sub timings to stderr]' \
    '--flame[SVG flamegraph to stdout (st --flame script.stk > flame.svg)]' \
    '--no-jit[disable Cranelift JIT (bytecode interpreter only)]' \
    '--explain=[print expanded hint for an error code]:error code (e.g. E0001):' \
    '--no-interop[enforce idiomatic stryke]' \
    '-d+[run program under debugger]::module:' \
    '-D+[set debugging flags]:flags:_stryke_debug_flags' \
    '-u[dump core after parsing program]' \
    '-n[assume "while (<>) \{ ... \}" loop around program]' \
    '-p[assume loop like -n but print line also like sed]' \
    '-a[autosplit mode with -n or -p (splits $_ into @F)]' \
    '-F+[split() pattern for -a switch]:pattern:' \
    '-l+[enable line ending processing]::octnum:' \
    '-0+[specify record separator]::octal:' \
    '-g[read all input in one go (slurp mode, alias for -0777)]' \
    '-i+[edit <> files in place (backup if extension supplied)]::extension:' \
    '*-M+[use module before executing program]:module:_perl_modules' \
    '*-m+[use module() before executing program (no import)]:module:_perl_modules' \
    '*-I+[specify @INC directory]:directory:_directories' \
    '-f[do not do $sitelib/sitecustomize.pl at startup]' \
    '-S[look for programfile using PATH]' \
    '-x+[ignore text before \#!perl line]::directory:_directories' \
    '-C+[enable listed Unicode features]::number/list:' \
    '-t[enable tainting warnings]' \
    '-T[enable tainting checks]' \
    '-U[allow unsafe operations]' \
    '-s[enable switch parsing after programfile]' \
    '-w[enable many useful warnings]' \
    '-W[enable all warnings]' \
    '-X[disable all warnings]' \
    '(-v --version)'{-v,--version}'[print version patchlevel and license]' \
    '-V+[print configuration summary]::config variable:(version api_version archname osname threads useithreads usethreads use64bitint use64bitall cc optimize prefix installprefix perlpath)' \
    '(- *)'{-h,--help}'[print help]' \
    '(-j --threads)'{-j+,--threads=}'[number of threads for parallel operations]:threads:' \
    '(-)1:script or subcommand:->script_or_subcommand' \
    '(-)*::script arguments:->script_args' && return 0

  case $state in
    script_or_subcommand)
      # Offer subcommands alongside the script-file glob.
      local -a subcmds
      subcmds=(
        'build:compile script/project into standalone binary'
        'run:run ./main.stk or specified script'
        'prun:run multiple files in parallel'
        'test:run tests in t/ (alias: t)'
        't:alias for test'
        'bench:run benchmarks in bench/'
        'check:parse + compile without executing'
        'disasm:disassemble bytecode'
        'profile:run with profiling'
        'fmt:format stryke source files'
        'minify:strip comments/POD/whitespace, collapse to one line w/ `;`'
        'init:scaffold project in cwd (stryke.toml + dirs)'
        'new:scaffold a new project at ./NAME/'
        'install:resolve deps + write stryke.lock (alias: i; with -g: install a package globally)'
        'i:alias for install'
        'uninstall:drop a global pin + its launchers (alias: un; requires -g)'
        'un:alias for uninstall'
        'list:list global packages, launchers, orphans (alias: ls; requires -g)'
        'ls:alias for list'
        'update:re-resolve manifest + rewrite stryke.lock (alias: up, upgrade)'
        'up:alias for update'
        'upgrade:alias for update'
        'publish:push package to registry (alias: pub)'
        'pub:alias for publish'
        'yank:yank a published version from the registry'
        'outdated:list installed deps newer than stryke.lock'
        'audit:security audit of resolved dep tree'
        'vendor:vendor deps into ./vendor/ for offline builds'
        'clean:remove caches and build artifacts'
        'search:search the registry for packages'
        'add:add a dep to stryke.toml'
        'remove:drop a dep from stryke.toml'
        'tree:print resolved dep graph from stryke.lock'
        'info:show lockfile entry + store path for a dep'
        'pkg:package-manager subcommand dispatcher'
        'agent:distributed load-testing agent (worker side)'
        'controller:distributed load-testing controller REPL'
        'ai:AI helper (prompt-driven code generation / explanation)'
        'repl:start interactive REPL'
        'lsp:start Language Server Protocol'
        'completions:emit shell completions'
        'ast:dump AST as JSON'
        'gen-docs:generate Markdown module docs for every source file'
        'convert:convert Perl to stryke syntax'
        'deconvert:convert stryke to Perl syntax'
        'docs:documentation browser'
        'serve:start HTTP server'
      )
      _alternative \
        'subcommands:stryke subcommand:((${subcmds}))' \
        'scripts:perl script:_files -g "*.stk *.pl *.pm *.t *.cgi *.psgi"'
      ;;
    script_args)
      # Delegate to subcommand handler based on first positional.
      case $line[1] in
        build)     _stryke_build ;;
        fmt)       _stryke_fmt ;;
        minify)    _stryke_minify ;;
        check)     _stryke_check ;;
        disasm)    _stryke_disasm ;;
        profile)   _stryke_profile ;;
        bench)     _stryke_bench ;;
        test|t)    _stryke_test ;;
        init)      _stryke_init ;;
        new)       _stryke_new ;;
        install|i) _stryke_install ;;
        uninstall|un) _stryke_uninstall ;;
        list|ls)   _stryke_list ;;
        add)       _stryke_add ;;
        remove)    _stryke_remove ;;
        tree)      _stryke_tree ;;
        info)      _stryke_info ;;
        update|up|upgrade) _stryke_update ;;
        publish|pub) _stryke_publish ;;
        yank)      _stryke_yank ;;
        outdated)  _stryke_outdated ;;
        audit)     _stryke_audit ;;
        vendor)    _stryke_vendor ;;
        clean)     _stryke_clean ;;
        search)    _stryke_search ;;
        agent)     _stryke_agent ;;
        controller) _stryke_controller ;;
        ai)        _stryke_ai ;;
        pkg)       _stryke_pkg ;;
        repl)      _stryke_repl ;;
        run)       _stryke_run ;;
        prun)      _stryke_prun ;;
        lsp)       _stryke_lsp ;;
        completions) _stryke_completions ;;
        ast)       _stryke_ast ;;
        gen-docs)  _stryke_gen_docs ;;
        convert)   _stryke_convert ;;
        deconvert) _stryke_deconvert ;;
        docs)      _stryke_docs ;;
        serve)     _stryke_serve ;;
        *.stk|*.pl|*.pm|*.t)
          # Multi-file execution: `st *.stk` runs all files
          _files -g "*.stk *.pl *.pm *.t"
          ;;
        *)         _files ;;
      esac
      ;;
  esac
}

_stryke "$@"
