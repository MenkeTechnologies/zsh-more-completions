#compdef stryke st s

# Zsh completion for stryke / s — a Perl interpreter written in Rust
#
# Subcommands:
#   s build [--project DIR] SCRIPT [-o OUT]  — AOT compile to standalone binary
#   s convert [-i] [-d DELIM] FILE...        — convert Perl to stryke syntax with |> pipes
#   s deconvert [-i] FILE...                 — convert stryke back to Perl syntax
#   s fmt [-i] FILE...                       — format stryke source files
#   s check FILE...                          — parse + compile without executing
#   s disasm [--jit] FILE                    — disassemble bytecode
#   s profile [--flame] [--json] FILE        — run with profiling
#   s bench [FILE|DIR]                       — run benchmark files
#   s test [FILE|DIR]                        — run test files
#   s init [NAME]                            — scaffold a new project
#   s repl [--load FILE]                     — start interactive REPL
#   s lsp                                    — start Language Server Protocol
#   s completions [SHELL]                    — emit shell completions
#   s ast FILE                               — dump AST as JSON
#   s docs [TOPIC]                           — documentation browser
#   s serve [PORT] [SCRIPT]                  — HTTP server
#   s run [SCRIPT]                           — run main.stk
#   s prun FILE...                           — run multiple files in parallel
#   s *.stk                                  — run multiple files sequentially
#   s -j4 *.stk                              — run multiple files in parallel (4 threads)
#   s [perl-flags] [SCRIPT] [args]           — normal interpreter mode
#
# Note on the dispatch pattern: we use `_arguments -C` + `'1: :->cmd'` + `'*::arg:->args'`
# so subcommand handlers run via the standard state-machine.

_stryke_debug_flags() {
  _values -s '' 'debug flag' \
    'p[tokenizing and parsing]' \
    's[stack snapshots]' \
    'l[label stack processing]' \
    't[trace execution]' \
    'o[method and overloading resolution]' \
    'c[string/numeric conversions]' \
    'P[print profiling info]' \
    'm[memory and SV allocation]' \
    'f[format processing]' \
    'r[regular expression parsing and execution]' \
    'x[syntax tree dump]' \
    'u[tainting checks]' \
    'H[hash dump]' \
    'X[scratchpad allocation]' \
    'D[cleaning up]' \
    'S[op slab allocation]' \
    'T[tokenizing]' \
    'R[include reference counts of dumped variables]' \
    'J[show s/// junctions]' \
    'v[verbose: use abs path when printing file names]'
}

# `s build [--project DIR] SCRIPT [-o OUT]` — bake a Perl script into a standalone executable
_stryke_build() {
  _arguments -s -S \
    '(-o --output)'{-o+,--output=}'[output binary path]:output:_files' \
    '(-p --project)'{-p+,--project=}'[bundle project directory (main.stk + lib/)]:directory:_directories' \
    '(-h --help)'{-h,--help}'[show s build usage]' \
    '1:script file:_files -g "*.stk *.pl *.pm"'
}

# `s fmt [-i] FILE...` — format stryke source files
_stryke_fmt() {
  _arguments -s -S \
    '(-i --in-place)'{-i,--in-place}'[rewrite files in place]' \
    '(-h --help)'{-h,--help}'[show s fmt usage]' \
    '*:stryke files:_files -g "*.stk *.pl *.pm"'
}

# `s check FILE...` — parse + compile without executing
_stryke_check() {
  _arguments -s -S \
    '(-q --quiet)'{-q,--quiet}'[only output errors, no success messages]' \
    '--json[output diagnostics as JSON]' \
    '(-h --help)'{-h,--help}'[show s check usage]' \
    '*:stryke files:_files -g "*.stk *.pl *.pm"'
}

# `s disasm [--jit] FILE` — disassemble bytecode
_stryke_disasm() {
  _arguments -s -S \
    '--jit[also show Cranelift IR]' \
    '(-h --help)'{-h,--help}'[show s disasm usage]' \
    '1:script file:_files -g "*.stk *.pl *.pm"'
}

# `s profile [OPTIONS] FILE` — run with profiling
_stryke_profile() {
  _arguments -s -S \
    '(-o --output)'{-o+,--output=}'[write output to file]:output:_files' \
    '--flame[generate flamegraph SVG]' \
    '--json[output profile data as JSON]' \
    '(-h --help)'{-h,--help}'[show s profile usage]' \
    '1:script file:_files -g "*.stk *.pl *.pm"'
}

# `s bench [FILE|DIR]` — run benchmark files
_stryke_bench() {
  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show s bench usage]' \
    '1:benchmark file or directory:_files -g "*.stk *.pl"'
}

# `s test [FILE|DIR]` — run test files
_stryke_test() {
  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show s test usage]' \
    '1:test file or directory:_files -g "*.stk *.pl *.t"'
}

# `s init [NAME]` — scaffold a new project
_stryke_init() {
  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show s init usage]' \
    '1:project name:'
}

# `s repl [--load FILE]` — start interactive REPL
_stryke_repl() {
  _arguments -s -S \
    '(-l --load)'{-l+,--load=}'[evaluate file before REPL]:file:_files -g "*.stk *.pl *.pm"' \
    '(-h --help)'{-h,--help}'[show s repl usage]'
}

# `s run [SCRIPT]` — run main.stk or specified script
_stryke_run() {
  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show s run usage]' \
    '1:script file:_files -g "*.stk *.pl"'
}

# `s prun FILE...` — run multiple files in parallel
_stryke_prun() {
  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show s prun usage]' \
    '*:script files:_files -g "*.stk *.pl *.pm *.t"'
}

# `s lsp` — start Language Server Protocol over stdio
_stryke_lsp() {
  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show s lsp usage]'
}

# `s completions [SHELL]` — emit shell completions
_stryke_completions() {
  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show s completions usage]' \
    '1:shell:(zsh)'
}

# `s ast FILE` — dump AST as JSON
_stryke_ast() {
  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show s ast usage]' \
    '1:script file:_files -g "*.stk *.pl *.pm"'
}

# `s docs [TOPIC]` — built-in documentation browser
_stryke_docs() {
  local -a _topics
  _topics=(${(f)"$(s docs --list 2>/dev/null | sed 's/^ *[0-9]*\. //')"})
  _describe 'docs topic' _topics
}

# `s serve [PORT] [SCRIPT]` — built-in HTTP server (default port 8000)
_stryke_serve() {
  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show s serve usage]' \
    '1:port (default 8000):' \
    '2:script or -e:_files -g "*.stk *.pl"'
}

_stryke_deconvert() {
  _arguments -s -S \
    '(-i --in-place)'{-i,--in-place}'[write .pl files alongside originals]' \
    '(-d --output-delim)'{-d+,--output-delim=}'[delimiter for s/// tr/// m// (default: preserve original)]:delimiter:' \
    '(-h --help)'{-h,--help}'[show s deconvert usage]' \
    '*:stryke files:_files -g "*.stk"'
}
# `s convert [-i] [-d DELIM] FILE...` — convert Perl source to idiomatic stryke syntax
_stryke_convert() {
  _arguments -s -S \
    '(-i --in-place)'{-i,--in-place}'[rewrite files in place]' \
    '(-d --output-delim)'{-d+,--output-delim=}'[delimiter for s/// tr/// m// (default: preserve original)]:delimiter:' \
    '(-h --help)'{-h,--help}'[show s convert usage]' \
    '*:perl files:_files -g "*.pl *.pm *.t *.cgi *.psgi"'
}

_stryke() {
  local curcontext="$curcontext" state state_descr line
  typeset -A opt_args

  # Top-level: every flag is exposed via `_arguments`. The two trailing positional specs
  # (`1:...:->cmd` and `*::arg:->args`) defer subcommand handling to the case block below.
  #
  # `-C` is mandatory: without it, `$state` is not exported to the surrounding function.
  _arguments -s -S \
    '--lsp[run language server over stdio (no script needed)]' \
    '--remote-worker[persistent cluster worker over stdio]' \
    '--remote-worker-v1[legacy one-shot cluster worker over stdio]' \
    '--compat[Perl 5 strict-compat: disable all stryke extensions]' \
    '--script[force arg to be a script file (skip code detection)]' \
    '*-e+[one line of program (several allowed)]:code:' \
    '*-E+[like -e but enables all optional features]:code:' \
    '-c[check syntax only (parse; does not compile or run)]' \
    '(--lint --check)'{--lint,--check}'[parse + compile bytecode without running]' \
    '(--disasm --disassemble)'{--disasm,--disassemble}'[print bytecode disassembly to stderr before running]' \
    '--ast[dump parsed AST as JSON and exit (no execution)]' \
    '--fmt[pretty-print parsed Perl to stdout and exit]' \
    '--profile[wall-clock profile: per-line + per-sub timings to stderr]' \
    '--flame[SVG flamegraph to stdout (st --flame script.stk > flame.svg)]' \
    '--no-jit[disable Cranelift JIT (bytecode interpreter only)]' \
    '--explain=[print expanded hint for an error code]:error code (e.g. E0001):' \
    '-d+[run program under debugger]::module:' \
    '-D+[set debugging flags]:flags:_stryke_debug_flags' \
    '-u[dump core after parsing program]' \
    '-n[assume "while (<>) \{ ... \}" loop around program]' \
    '-p[assume loop like -n but print line also like sed]' \
    '-a[autosplit mode with -n or -p (splits $_ into @F)]' \
    '-F+[split() pattern for -a switch]:pattern:' \
    '-l+[enable line ending processing]::octnum:' \
    '-0+[specify record separator]::octal:' \
    '-g[read all input in one go (slurp mode, alias for -0777)]' \
    '-i+[edit <> files in place (backup if extension supplied)]::extension:' \
    '*-M+[use module before executing program]:module:_perl_modules' \
    '*-m+[use module() before executing program (no import)]:module:_perl_modules' \
    '*-I+[specify @INC directory]:directory:_directories' \
    '-f[do not do $sitelib/sitecustomize.pl at startup]' \
    '-S[look for programfile using PATH]' \
    '-x+[ignore text before \#!perl line]::directory:_directories' \
    '-C+[enable listed Unicode features]::number/list:' \
    '-t[enable tainting warnings]' \
    '-T[enable tainting checks]' \
    '-U[allow unsafe operations]' \
    '-s[enable switch parsing after programfile]' \
    '-w[enable many useful warnings]' \
    '-W[enable all warnings]' \
    '-X[disable all warnings]' \
    '(-v --version)'{-v,--version}'[print version patchlevel and license]' \
    '-V+[print configuration summary]::config variable:(version api_version archname osname threads useithreads usethreads use64bitint use64bitall cc optimize prefix installprefix perlpath)' \
    '(- *)'{-h,--help}'[print help]' \
    '(-j --threads)'{-j+,--threads=}'[number of threads for parallel operations]:threads:' \
    '(-)1:script or subcommand:->script_or_subcommand' \
    '(-)*::script arguments:->script_args' && return 0

  case $state in
    script_or_subcommand)
      # Offer subcommands alongside the script-file glob.
      local -a subcmds
      subcmds=(
        'build:compile script/project into standalone binary'
        'run:run ./main.stk or specified script'
        'prun:run multiple files in parallel'
        'test:run tests in t/'
        'bench:run benchmarks in bench/'
        'check:parse + compile without executing'
        'disasm:disassemble bytecode'
        'profile:run with profiling'
        'fmt:format stryke source files'
        'init:scaffold a new stryke project'
        'repl:start interactive REPL'
        'lsp:start Language Server Protocol'
        'completions:emit shell completions'
        'ast:dump AST as JSON'
        'convert:convert Perl to stryke syntax'
        'deconvert:convert stryke to Perl syntax'
        'docs:documentation browser'
        'serve:start HTTP server'
      )
      _alternative \
        'subcommands:stryke subcommand:((${subcmds}))' \
        'scripts:perl script:_files -g "*.stk *.pl *.pm *.t *.cgi *.psgi"'
      ;;
    script_args)
      # Delegate to subcommand handler based on first positional.
      case $line[1] in
        build)     _stryke_build ;;
        fmt)       _stryke_fmt ;;
        check)     _stryke_check ;;
        disasm)    _stryke_disasm ;;
        profile)   _stryke_profile ;;
        bench)     _stryke_bench ;;
        test)      _stryke_test ;;
        init)      _stryke_init ;;
        repl)      _stryke_repl ;;
        run)       _stryke_run ;;
        prun)      _stryke_prun ;;
        lsp)       _stryke_lsp ;;
        completions) _stryke_completions ;;
        ast)       _stryke_ast ;;
        convert)   _stryke_convert ;;
        deconvert) _stryke_deconvert ;;
        docs)      _stryke_docs ;;
        serve)     _stryke_serve ;;
        *.stk|*.pl|*.pm|*.t)
          # Multi-file execution: `st *.stk` runs all files
          _files -g "*.stk *.pl *.pm *.t"
          ;;
        *)         _files ;;
      esac
      ;;
  esac
}

_stryke "$@"
