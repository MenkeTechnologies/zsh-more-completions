#compdef lftp

local expl bookmarks
local XDG_DATA_HOME=${XDG_DATA_HOME:-$HOME/.local/share}

bookmarks=$XDG_DATA_HOME/$service/bookmarks

if [[ -f $bookmarks ]]; then
  bookmarks=(${"${(f)$(<$bookmarks)}"%%[[:space:],]*})
  _wanted bookmarks expl bookmark compadd -a bookmarks && return 0
fi

local -a arguments

arguments=(
  '-f[execute commands from file and exit]:file:_files'
  '-c[execute the given commands and exit]:commands'
  '--norc[do not execute rc files on startup]'
  '(- *)'{-h,--help}'[print help and exit]'
  '(- *)--version[print lftp version and exit]'
  '-e[execute command after connecting]:command'
  '-u[use user\[,password\] for authentication]:user\[,pass\]'
  '-p[use specified port for connection]:port'
  '-s[assign connection to named slot]:slot'
  '-d[enable debug output]'
  '--dumpcmd[dump commands being sent]:file:_files'
  '--queue[execute in lftp'\''s background queue]'
  '--rcfile[execute specified rc file on startup]:file:_files'
  '--log[log commands and output to file]:file:_files'
  '--delete[delete file from the server]:file'
  '--env-password[take password from LFTP_PASSWORD environment variable]'
  '*:url:_urls'
)

_arguments -s $arguments
