#compdef cheat

# Zsh completion for cheat.sh (https://github.com/chubin/cheat.sh)
# Caches the language list to avoid network calls on every completion

local cache_file="${XDG_CACHE_HOME:-$HOME/.cache}/cheat_sh_list"
local -a cheat_langs

# Cache the list for 24 hours
if [[ -f "$cache_file" && -n "$(find "$cache_file" -mtime -1 2>/dev/null)" ]]; then
  cheat_langs=("${(@f)$(< "$cache_file")}")
elif (( $+commands[curl] )); then
  curl -s cheat.sh/:list 2>/dev/null > "$cache_file" &!
  [[ -f "$cache_file" ]] && cheat_langs=("${(@f)$(< "$cache_file")}")
fi

_arguments -s -C \
  '(- *)--help[show help message and exit]' \
  '(- *)--shell[enter interactive shell mode]' \
  '1:cheat sheet:compadd -a cheat_langs' \
  '*::query:_message "search query"'
