#compdef zshrs-daemon

# zsh completion for zshrs-daemon (the singleton cache + recorder + HTTP
# service binary). Drop this file into a directory on $fpath and either
# `compinit` or restart the shell. See bins/zshrs-daemon.rs for the
# canonical option list.

local curcontext=$curcontext state line
typeset -A opt_args

_arguments -S -s : \
    '(- *)'{-h,--help}'[print help and exit]' \
    '(- *)--version[print version and exit]' \
    '--home[override $ZSHRS_HOME for this session (default ~/.zshrs)]:zshrs root:_directories' \
    '--log-level[set ZSHRS_LOG directive (e.g. info, debug, info,fsnotify=trace)]:directive:(off error warn info debug trace)' \
    '--log-stderr[stream tracing output to stderr in addition to ~/.cache/zshrs/zshrs.log]' \
    '--verbose-init[show daemon work to stderr on every run; implies --log-stderr + ZSHRS_LOG=debug]' \
    '--quiet-first-run[suppress the 6-line first-run stderr block]' \
    '(- *)--print-paths[print resolved cache/socket/config/log paths as JSON, then exit]' \
    '(- *)--check-config[parse ~/.config/zshrs/daemon.toml + report status as JSON, then exit]' \
    && return 0
